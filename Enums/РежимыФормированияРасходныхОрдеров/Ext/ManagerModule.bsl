#Область ПрограммныйИнтерфейс

// Возвращает текст подсказки по режиму формирования расходных ордеров.
//
// Параметры:
//  РежимФормированияРасходныхОрдеров	 - ПеречислениеСсылка.РежимыФормированияРасходныхОрдеров - режим формирования
//  расходных ордеров.
// 
// Возвращаемое значение:
//  Строка - подсказка по режиму формирования расходных ордеров.
//
Функция ПодсказкаПоРежимуФормирования(РежимФормированияРасходныхОрдеров) Экспорт
	
	ИспользуетсяДоставка20 =
		(ПолучитьФункциональнуюОпцию("ИспользоватьУправлениеДоставкой")
			И ПолучитьФункциональнуюОпцию("НеИспользоватьУправлениеДоставкой25"));
	
	Если РежимФормированияРасходныхОрдеров = Перечисления.РежимыФормированияРасходныхОрдеров.Автоматически Тогда
		
		Если ИспользуетсяДоставка20 Тогда
			
			ТекстПодсказки = НСтр("ru = 'Ордера формируются и переформировываются автоматически после записи документов, влияющих на их формирование: заказов, накладных, заданий на перевозку.'");
			
		Иначе
			
			ТекстПодсказки = НСтр("ru = 'Ордера формируются и переформировываются автоматически после записи документов, влияющих на их формирование: заказов, накладных, рейсов.'");
			
		КонецЕсли;
		
	ИначеЕсли РежимФормированияРасходныхОрдеров = Перечисления.РежимыФормированияРасходныхОрдеров.Менеджером Тогда
		
		Если ИспользуетсяДоставка20 Тогда
			
			ТекстПодсказки = НСтр("ru = 'Менеджер инициирует формирование и переформирование расходных ордеров из списков распоряжений на отгрузку (т.е. из списков заказов и накладных). При использовании доставки ордера формирует менеджер по доставке в целом по заданию на перевозку.'");
			
		Иначе
			
			ТекстПодсказки = НСтр("ru = 'Менеджер инициирует формирование и переформирование расходных ордеров из списков распоряжений на отгрузку (т.е. из списков заказов и накладных). При использовании доставки менеджер по доставке формирует ордера по рейсам.'");
			
		КонецЕсли;
		
	ИначеЕсли РежимФормированияРасходныхОрдеров = Перечисления.РежимыФормированияРасходныхОрдеров.Кладовщиком Тогда
		
		ТекстПодсказки = НСтр("ru = 'Кладовщик вручную инициирует формирование и переформирование расходных ордеров по распоряжениям на отгрузку в рабочем месте ""Отгрузка"".'");
		
	Иначе
		
		ТекстПодсказки = НСтр("ru = 'Определяет инициатора формирования расходных ордеров.'");
		
	КонецЕсли;
	
	Возврат ТекстПодсказки;
	
КонецФункции

#КонецОбласти

#КонецЕсли