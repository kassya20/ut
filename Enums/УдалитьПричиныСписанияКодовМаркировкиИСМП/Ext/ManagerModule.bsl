Функция ПричинаСписанияЧерезСУЗМех(Знач ЗначениеПоиска)
	
	Если ЗначениеПоиска = Испорчен Тогда
		Возврат "CORRUPTED";
	ИначеЕсли ЗначениеПоиска = Утерян Тогда
		Возврат "LOST";
	Иначе
		Возврат "";
	КонецЕсли;
	
КонецФункции

Функция ПричинаСписанияЧерезГИСМТ(Знач ЗначениеПоиска)
	
	Если ЗначениеПоиска = Испорчен Тогда
		Возврат "KM_SPOILED";
	ИначеЕсли ЗначениеПоиска = Утерян Тогда
		Возврат "KM_LOST";
	ИначеЕсли ЗначениеПоиска = Уничтожен Тогда
		Возврат "KM_DESTROYED";
	Иначе
		Возврат "";
	КонецЕсли;
	
КонецФункции

