// Подбирает значение перечисления, соответствующее значению перечисления DMDocumentStatus из XDTO пакета DM.
//
// Параметры:
//   СтатусДО - Строка - статус документа в 1С:Документооборот.
//
// Возвращаемое значение:
//   ПеречислениеСсылка.СостоянияСогласованияВДокументообороте
//
Функция ЗначениеСоответствующееСтатусуДО(СтатусДО) Экспорт
	
	Если СтатусДО = "AwaitingApproval" Тогда
		Результат = НаСогласовании;
		
	ИначеЕсли СтатусДО = "Approved" Тогда
		Результат = Согласован;
		
	ИначеЕсли СтатусДО = "NotApproved" Тогда
		Результат = НеСогласован;
		
	Иначе
		Результат = ПустаяСсылка();
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти

#КонецЕсли