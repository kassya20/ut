	<WindowOpeningMode>LockOwnerWindow</WindowOpeningMode>
	<AutoCommandBar name="ФормаКоманднаяПанель" id="-1"/>
	<Events>
		<Event name="OnCreateAtServer">ПриСозданииНаСервере</Event>
	</Events>
	<ChildItems>
		<InputField name="Код" id="1">
			<DataPath>Объект.Code</DataPath>
			<EditMode>EnterOnInput</EditMode>
			<ExtendedEditMultipleValues>true</ExtendedEditMultipleValues>
			<ContextMenu name="КодКонтекстноеМеню" id="2"/>
			<ExtendedTooltip name="КодРасширеннаяПодсказка" id="3"/>
		</InputField>
		<InputField name="Наименование" id="4">
			<DataPath>Объект.Description</DataPath>
			<EditMode>EnterOnInput</EditMode>
			<ExtendedEditMultipleValues>true</ExtendedEditMultipleValues>
			<ContextMenu name="НаименованиеКонтекстноеМеню" id="5"/>
			<ExtendedTooltip name="НаименованиеРасширеннаяПодсказка" id="6"/>
		</InputField>
		<InputField name="ДатаОбмена" id="7">
			<DataPath>Объект.ExchangeDate</DataPath>
			<EditMode>EnterOnInput</EditMode>
			<ExtendedEditMultipleValues>true</ExtendedEditMultipleValues>
			<ContextMenu name="ДатаОбменаКонтекстноеМеню" id="8"/>
			<ExtendedTooltip name="ДатаОбменаРасширеннаяПодсказка" id="9"/>
		</InputField>
		<InputField name="ОбластьДанныхОсновныеДанные" id="10">
			<DataPath>Объект.ОбластьДанныхОсновныеДанные</DataPath>
			<EditMode>EnterOnInput</EditMode>
			<ExtendedEditMultipleValues>true</ExtendedEditMultipleValues>
			<ContextMenu name="ОбластьДанныхОсновныеДанныеКонтекстноеМеню" id="11"/>
			<ExtendedTooltip name="ОбластьДанныхОсновныеДанныеРасширеннаяПодсказка" id="12"/>
		</InputField>
		<UsualGroup name="РаботаВАвтономномРежиме" id="19">
			<Title>
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Работа в автономном режиме</v8:content>
				</v8:item>
			</Title>
			<ToolTip>
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Приложение имеет возможность работать в автономном режиме. При наличии подключения к основному серверу приложение будет копировать необходимые данные в локальную базу, а после потери соединения переключится в автономный режим и продолжит работу с данными.</v8:content>
				</v8:item>
			</ToolTip>
			<ToolTipRepresentation>Button</ToolTipRepresentation>
			<Group>Vertical</Group>
			<ExtendedTooltip name="РаботаВАвтономномРежимеРасширеннаяПодсказка" id="20"/>
			<ChildItems>
				<InputField name="ДатаНачалаВыгрузкиДокументов" id="16">
					<DataPath>Объект.ДатаНачалаВыгрузкиДокументов</DataPath>
					<ToolTip>
						<v8:item>
							<v8:lang>ru</v8:lang>
							<v8:content>В автономный режим будут выгружаться только те документы, дата которых больше или равна этой</v8:content>
						</v8:item>
					</ToolTip>
					<ToolTipRepresentation>Button</ToolTipRepresentation>
					<EditMode>EnterOnInput</EditMode>
					<ExtendedEditMultipleValues>true</ExtendedEditMultipleValues>
					<ContextMenu name="ДатаНачалаВыгрузкиДокументовКонтекстноеМеню" id="17"/>
					<ExtendedTooltip name="ДатаНачалаВыгрузкиДокументовРасширеннаяПодсказка" id="18"/>
					<Events>
						<Event name="OnChange">ДатаНачалаВыгрузкиДокументовПриИзменении</Event>
					</Events>
				</InputField>
				<CheckBoxField name="ВключитьОбменДанными" id="13">
					<DataPath>Объект.ВключитьОбменДанными</DataPath>
					<Title>
						<v8:item>
							<v8:lang>ru</v8:lang>
							<v8:content>Включить обмен данными</v8:content>
						</v8:item>
					</Title>
					<TitleLocation>Left</TitleLocation>
					<ToolTip>
						<v8:item>
							<v8:lang>ru</v8:lang>
							<v8:content>Запускает первоначальный обмен с основной базой и регулярно выполняет синхронизацию</v8:content>
						</v8:item>
					</ToolTip>
					<ToolTipRepresentation>Button</ToolTipRepresentation>
					<EditMode>EnterOnInput</EditMode>
					<CheckBoxType>Switcher</CheckBoxType>
					<ContextMenu name="ВключитьОбменДаннымиКонтекстноеМеню" id="14"/>
					<ExtendedTooltip name="ВключитьОбменДаннымиРасширеннаяПодсказка" id="15"/>
					<Events>
						<Event name="OnChange">ВключитьОбменДаннымиПриИзменении</Event>
					</Events>
				</CheckBoxField>
			</ChildItems>
		</UsualGroup>
	</ChildItems>
	<Attributes>
		<Attribute name="Объект" id="1">
			<Type>
				<v8:Type>cfg:ExchangePlanObject.Мобильные</v8:Type>
			</Type>
			<MainAttribute>true</MainAttribute>
			<SavedData>true</SavedData>
		</Attribute>
		<Attribute name="ДатаНачалаВыгрузкиДокументовКопия" id="2">
			<Title>
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Дата начала выгрузки документов копия</v8:content>
				</v8:item>
			</Title>
			<Type>
				<v8:Type>xs:dateTime</v8:Type>
				<v8:DateQualifiers>
					<v8:DateFractions>Date</v8:DateFractions>
				</v8:DateQualifiers>
			</Type>
		</Attribute>
	</Attributes>
</Form>