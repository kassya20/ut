#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Если Объект.ЭтотУзел Тогда
		Элементы.РаботаВАвтономномРежиме.Видимость = Ложь;
	Иначе
		Если Не ЗначениеЗаполнено(Объект.ДатаНачалаВыгрузкиДокументов) Тогда
			Объект.ДатаНачалаВыгрузкиДокументов = НачалоДня(ТекущаяДатаСеанса());
		КонецЕсли;
		ДатаНачалаВыгрузкиДокументовКопия = Объект.ДатаНачалаВыгрузкиДокументов;
		Элементы.ДатаНачалаВыгрузкиДокументов.Подсказка = СтрШаблон(НСтр("ru = 'В автономный режим будут выгружаться только те документы, дата которых больше или равна %1'"), Формат(Объект.ДатаНачалаВыгрузкиДокументов, НСтр("ru='ДЛФ=Д'")));
		Элементы.РаботаВАвтономномРежиме.Подсказка = НСтр("ru = 'Приложение имеет возможность работать в автономном режиме. При наличии подключения к основному серверу приложение будет копировать необходимые данные в локальную базу, а после потери соединения переключится в автономный режим и продолжит работу с данными.'");
		Элементы.ДатаНачалаВыгрузкиДокументов.Доступность = Не Объект.ВключитьОбменДанными;
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура ВключитьОбменДаннымиПриИзменении(Элемент)
	
	Если Объект.ВключитьОбменДанными = Истина Тогда
		СписокЗначений = Новый СписокЗначений;
		СписокЗначений.Добавить("Включить", НСтр("ru = 'Включить'"));
		СписокЗначений.Добавить("НеВключать", НСтр("ru = 'Не включать'"));
		
		Оповещение = Новый ОписаниеОповещения("ПослеЗакрытияВопросаВключитьОбменДанными", ЭтотОбъект);
		ПоказатьВопрос(Оповещение, НСтр("ru = 'После включения синхронизации при запуске приложения начнется обмен данными, который может занять длительное время. Включить синхронизацию?'"), СписокЗначений, 0);
	Иначе
		СписокЗначений = Новый СписокЗначений;
		СписокЗначений.Добавить("Выключить", НСтр("ru = 'Выключить'"));
		СписокЗначений.Добавить("НеВыключать", НСтр("ru = 'Не выключать'"));
		
		Оповещение = Новый ОписаниеОповещения("ПослеЗакрытияВопросаВключитьОбменДанными", ЭтотОбъект);
		ПоказатьВопрос(Оповещение, НСтр("ru = 'После выключения синхронизации обмен больше не будет выполняться, и данные в автономном режиме могут стать неактуальными. Выключить синхронизацию?'"), СписокЗначений, 0);
	
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ДатаНачалаВыгрузкиДокументовПриИзменении(Элемент)
	
	Если Не ЗначениеЗаполнено(Объект.ДатаНачалаВыгрузкиДокументов) Тогда
		СписокЗначений = Новый СписокЗначений;
		СписокЗначений.Добавить("Очистить", НСтр("ru = 'Очистить'"));
		СписокЗначений.Добавить("НеОчищать", НСтр("ru = 'Не очищать'"));
		
		Оповещение = Новый ОписаниеОповещения("ПослеЗакрытияВопросаДатаНачалаВыгрузкиДокументов", ЭтотОбъект);
		ПоказатьВопрос(Оповещение, НСтр("ru = 'Если оставить дату незаполненной, то в автономную конфигурацию будут выгружаться документы за весь период, что может занять продолжительное время. Очистить дату?'"), СписокЗначений, 0);
	Иначе
		ДатаНачалаВыгрузкиДокументовКопия = Объект.ДатаНачалаВыгрузкиДокументов;
		Элементы.ДатаНачалаВыгрузкиДокументов.Подсказка = СтрШаблон(НСтр("ru = 'В автономный режим будут выгружаться только те документы, дата которых больше или равна  %1'"), Формат(Объект.ДатаНачалаВыгрузкиДокументов, НСтр("ru='ДЛФ=Д'")));
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Процедура ПослеЗакрытияВопросаВключитьОбменДанными(Результат, Параметры) Экспорт
	
	Если Результат = "Включить" Или Результат = "НеВыключать" Тогда
		Объект.ВключитьОбменДанными = Истина;
	Иначе
		Объект.ВключитьОбменДанными = Ложь;
	КонецЕсли;
	
	Элементы.ДатаНачалаВыгрузкиДокументов.Доступность = Не Объект.ВключитьОбменДанными;
	
КонецПроцедуры

&НаКлиенте
Процедура ПослеЗакрытияВопросаДатаНачалаВыгрузкиДокументов(Результат, Параметры) Экспорт
	
	Если Результат = "НеОчищать" Тогда
		Объект.ДатаНачалаВыгрузкиДокументов = ДатаНачалаВыгрузкиДокументовКопия;
	Иначе
		ДатаНачалаВыгрузкиДокументовКопия = Объект.ДатаНачалаВыгрузкиДокументов;
	КонецЕсли;
	Элементы.ДатаНачалаВыгрузкиДокументов.Подсказка = СтрШаблон(НСтр("ru = 'В автономный режим будут выгружаться только те документы, дата которых больше или равна  %1'"), Формат(Объект.ДатаНачалаВыгрузкиДокументов, НСтр("ru='ДЛФ=Д'")));
	
КонецПроцедуры

#КонецОбласти
