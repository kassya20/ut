// @strict-types


#Область ОбработчикиСобытий

&НаКлиенте
Процедура ОбработкаКоманды(ПараметрКоманды, ПараметрыВыполненияКоманды)
	
	ПараметрыФормы = АвтоматическоеПолучениеЭДОКлиент.НовыеПараметрыФормыСпискаСостояний();
	ПараметрыФормы.ТолькоИзменение = Истина;
	КлючУникальности = Новый УникальныйИдентификатор();
	Если ТипЗнч(ПараметрКоманды) = Тип("СправочникСсылка.УчетныеЗаписиЦентровЭДО") Тогда
		ПараметрыФормы.ИдентификаторыЭДО = ИдентификаторыЭДОУчетнойЗаписи(ПараметрКоманды);
	КонецЕсли;
	АвтоматическоеПолучениеЭДОКлиент.ОткрытьФормуСпискаСостояний(ПараметрыФормы, ПараметрыВыполненияКоманды.Окно,
		КлючУникальности);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Параметры:
//  УчетнаяЗапись - СправочникСсылка.УчетныеЗаписиЦентровЭДО
// 
// Возвращаемое значение:
//  Массив из Строка
&НаСервере
Функция ИдентификаторыЭДОУчетнойЗаписи(Знач УчетнаяЗапись)
	
	Возврат РегистрыСведений.НастройкиИнтеграцииЦентраЭДО.ИдентификаторыЭДОУчетнойЗаписи(УчетнаяЗапись);
	
КонецФункции

#КонецОбласти
