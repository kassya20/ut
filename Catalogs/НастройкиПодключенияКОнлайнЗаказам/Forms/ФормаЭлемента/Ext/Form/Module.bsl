&НаСервере
Процедура ПослеИзмененияИспользованияОплатФискализации()
	
	УстановитьДоступностьНастроекОплатФискализации();
	
КонецПроцедуры

&НаКлиенте
Процедура УстановитьИспользованиеСпособаОплаты(СпособОплаты, Использование)
	
	Модифицированность = Истина;
	
	Отбор = Новый Структура;
	Отбор.Вставить("СпособОплаты", СпособОплаты);
	
	НайденныеЗначения = Объект.НастройкиОплаты.НайтиСтроки(Отбор);
	
	Для Каждого НайденноеЗначение Из НайденныеЗначения Цикл
		
		НайденноеЗначение.Используется = Использование;
		
	КонецЦикла;
	
	ПослеИзмененияИспользованияОплатФискализации();
	
КонецПроцедуры

&НаКлиенте
Процедура ПриИзмененииНастройкиОплаты(СпособОплаты, НоваяНастройкаОплаты)
	
	Модифицированность = Истина;
	
	Отбор = Новый Структура;
	Отбор.Вставить("СпособОплаты", СпособОплаты);
	
	НайденныеЗначения = Объект.НастройкиОплаты.НайтиСтроки(Отбор);
	
	Для Каждого НайденноеЗначение Из НайденныеЗначения Цикл
		
		Если ЗначениеЗаполнено(НоваяНастройкаОплаты) Тогда
			НайденноеЗначение.НастройкаПодключения = НоваяНастройкаОплаты;
		Иначе
			Объект.НастройкиОплаты.Удалить(НайденноеЗначение);
		КонецЕсли;
		
	КонецЦикла;
	
	Если НайденныеЗначения.Количество() = 0
		И ЗначениеЗаполнено(НоваяНастройкаОплаты) Тогда
		НастройкаОплаты = Объект.НастройкиОплаты.Добавить();
		НастройкаОплаты.СпособОплаты = СпособОплаты;
		НастройкаОплаты.НастройкаПодключения = НоваяНастройкаОплаты;
		НастройкаОплаты.Используется = Истина;
	КонецЕсли;
	
	ПослеИзмененияИспользованияОплатФискализации();
	
КонецПроцедуры

