		ПредопределенноеЗначение("Перечисление.СпособыОплатыОнлайнЗаказов.СБПc2b"),
		НастройкаПодключенияКСБПc2b);
	
КонецПроцедуры

&НаКлиенте
Процедура НастройкаПодключенияКСБПc2bНачалоВыбора(Элемент, ДанныеВыбора, ВыборДобавлением, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	ОнлайнЗаказыКлиентСобытия.ПриВыбореНастройкиПодключения(
		ЭтотОбъект,
		Новый ОписаниеОповещения("ПослеВыбораНастройкиПодключенияСБПc2b", ЭтотОбъект),
		ПредопределенноеЗначение("Перечисление.СпособыОплатыОнлайнЗаказов.СБПc2b"));
	
КонецПроцедуры

&НаКлиенте
Процедура НастройкаПодключенияКСБПc2bСоздание(Элемент, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	Если Не ОбщегоНазначенияКлиент.ПодсистемаСуществует("ИнтернетПоддержкаПользователей.НастройкиПлатежныхСистем") Тогда
		Возврат;
	КонецЕсли;
	
	ОнлайнЗаказыКлиентСобытия.ПриПодключенииПлатежнойСистемы(
		ПредопределенноеЗначение("Перечисление.СпособыОплатыОнлайнЗаказов.СБПc2b"),
		Новый ОписаниеОповещения(
			"СозданиеНастройкиПодключенияКСБПc2bЗавершение",
			ЭтотОбъект));
	
КонецПроцедуры

