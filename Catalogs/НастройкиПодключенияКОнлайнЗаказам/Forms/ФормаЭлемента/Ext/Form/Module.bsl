#Область ОтзывТокенов

&НаСервере
Функция СуществуютНастройки(ВидТокена, НастройкаПодключения)
	
	Если ВидТокена = ОнлайнЗаказыСлужебный.ИдентификаторВидаТокенаПриемОплат() Тогда
		Возврат Справочники.НастройкиПодключенияКОнлайнЗаказам.СуществуютНастройкиПоНастройкеОплаты(
			НастройкаПодключения,
			Объект.Ссылка)
	ИначеЕсли ВидТокена = ОнлайнЗаказыСлужебный.ИдентификаторВидаТокенаОблачнаяКасса() Тогда
		Возврат Справочники.НастройкиПодключенияКОнлайнЗаказам.СуществуютНастройкиПоОблачнойКассе(
			НастройкаПодключения,
			Объект.Ссылка)
	КонецЕсли
	
КонецФункции

&НаСервере
Функция ОтозватьТокеныЗапускЗадания()
	
	НеиспользуемыеНастройки = Справочники.НастройкиПодключенияКОнлайнЗаказам.НеиспользуемыеНастройки(
		Объект.Ссылка);
	
	Если Не ЗначениеЗаполнено(НеиспользуемыеНастройки[ОнлайнЗаказыСлужебный.ИдентификаторВидаТокенаПриемОплат()])
		И Не ЗначениеЗаполнено(НеиспользуемыеНастройки[ОнлайнЗаказыСлужебный.ИдентификаторВидаТокенаОблачнаяКасса()]) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияВФоне(
		УникальныйИдентификатор);
	ПараметрыВыполнения.НаименованиеФоновогоЗадания = НСтр("ru = 'Отзыв неиспользуемых токенов онлайн-заказов.'");
	
	РезультатВыполнения = ДлительныеОперации.ВыполнитьФункцию(
		ПараметрыВыполнения,
		"ОнлайнЗаказыСлужебный.ОтозватьНеиспользуемыеТокеныНастройкиПодключения",
		НеиспользуемыеНастройки);
	
	Возврат РезультатВыполнения;
	
КонецФункции

&НаКлиенте
Процедура ОтозватьТокеныЗавершение(
		Результат,
		ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		ПослеЗавершенияОперацийСТокенами(ДополнительныеПараметры);
		Возврат;
	КонецЕсли;
	
	Если Результат.Статус = "Выполнено" Тогда
		
		РезультатОперации = ПолучитьИзВременногоХранилища(Результат.АдресРезультата);
		Если ЗначениеЗаполнено(РезультатОперации.КодОшибки) Тогда
			Оповещение = Новый ОписаниеОповещения(
				"ПослеОтветаНаВопросОПовторномОтзывеТокенов",
				ЭтотОбъект,
				ДополнительныеПараметры);
			ПоказатьВопрос(
				Оповещение,
				НСтр("ru = 'При отзыве токенов возникла ошибка. Повторить попытку?'"),
				РежимДиалогаВопрос.ДаНетОтмена);
		КонецЕсли;
		
	ИначеЕсли Результат.Статус = "Ошибка" Тогда
		Оповещение = Новый ОписаниеОповещения(
			"ПослеОтветаНаВопросОПовторномОтзывеТокенов",
			ЭтотОбъект,
			ДополнительныеПараметры);
		ПоказатьВопрос(
			Оповещение,
			НСтр("ru = 'При отзыве токенов возникла ошибка. Повторить попытку?'"),
			РежимДиалогаВопрос.ДаНетОтмена);
	КонецЕсли;
	
	ПослеЗавершенияОперацийСТокенами(ДополнительныеПараметры);
	
КонецПроцедуры

&НаКлиенте
Процедура ПослеОтветаНаВопросОПовторномОтзывеТокенов(Результат, Параметры) Экспорт
	
	Если Результат = КодВозвратаДиалога.Да Тогда
		ОтозватьТокеныЗапускЗадания();
		Возврат;
	КонецЕсли;
	
	ПослеЗавершенияОперацийСТокенами(Параметры);
	
КонецПроцедуры

&НаКлиенте
Процедура ПослеЗавершенияОперацийСТокенами(ДополнительныеПараметры)
	
	Если РезультатПроверкиШаблонов <> Неопределено
		И Не РезультатПроверкиШаблонов.ВсеШаблоны Тогда
		
		Оповещение = Новый ОписаниеОповещения(
			"ПослеОтветаНаВопросОСозданииШаблонов",
			ЭтотОбъект,
			ДополнительныеПараметры);
		
		ПоказатьВопрос(
			Оповещение,
			НСтр("ru = 'Создать шаблоны сообщений для автоматического заполнения на основании данных документов?'"),
			РежимДиалогаВопрос.ДаНет);
			
	Иначе
		
		Если ЗначениеЗаполнено(Объект.Ссылка) Тогда
			ОбновитьНастройкуВСервисе(
				ДополнительныеПараметры.ЗакрытьПослеЗаписи,
				Ложь);
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбновлениеНастройкиВСервисе

&НаКлиенте
Процедура ОбновитьНастройкуВСервисе(
	ЗакрытьПослеЗаписи,
	ПоказыватьПредупреждение)
	
	ДополнительныеПараметры = Новый Структура;
	ДополнительныеПараметры.Вставить("ЗакрытьПослеЗаписи", ЗакрытьПослеЗаписи);
	ДополнительныеПараметры.Вставить("ПоказыватьПредупреждение", ПоказыватьПредупреждение);
	
	Если Объект.ОшибкаСинхронизации Тогда
		
		ПараметрыОжидания = ДлительныеОперацииКлиент.ПараметрыОжидания(ЭтотОбъект);
		ПараметрыОжидания.ВыводитьОкноОжидания = Истина;
		ПараметрыОжидания.ТекстСообщения = НСтр("ru = 'Ревизия токенов и обновление настройки онлайн-заказов в сервисе.'");
		
		РезультатВыполнения = ОбновитьНастройкуВСервисеСРевизиейТокеновЗапускЗадания();
		
	ИначеЕсли ЗначениеЗаполнено(НеактуальныеНастройки) Тогда
		
		ПараметрыОжидания = ДлительныеОперацииКлиент.ПараметрыОжидания(ЭтотОбъект);
		ПараметрыОжидания.ВыводитьОкноОжидания = Истина;
		ПараметрыОжидания.ТекстСообщения = НСтр("ru = 'Отзыв токенов и обновление настройки онлайн-заказов в сервисе.'");
		
		РезультатВыполнения = ОбновитьНастройкуВСервисеСОтзывомТокеновЗапускЗадания();
		
	Иначе
		
		ПараметрыОжидания = ДлительныеОперацииКлиент.ПараметрыОжидания(ЭтотОбъект);
		ПараметрыОжидания.ВыводитьОкноОжидания = Истина;
		ПараметрыОжидания.ТекстСообщения = НСтр("ru = 'Обновление настройки онлайн-заказов в сервисе.'");
		
		РезультатВыполнения = ОбновитьНастройкуВСервисеЗапускЗадания();
		
	КонецЕсли;
	
	ОповещениеОЗавершении = Новый ОписаниеОповещения(
		"ОбновитьНастройкуВСервисеЗавершение",
		ЭтотОбъект,
		ДополнительныеПараметры);
		
	Если РезультатВыполнения.Статус = "Выполнено" Или РезультатВыполнения.Статус = "Ошибка" Тогда
		ОбновитьНастройкуВСервисеЗавершение(
			РезультатВыполнения,
			ДополнительныеПараметры);
		Возврат;
	КонецЕсли;
	
	ДлительныеОперацииКлиент.ОжидатьЗавершение(
		РезультатВыполнения,
		ОповещениеОЗавершении,
		ПараметрыОжидания);
	
КонецПроцедуры

&НаСервере
Функция ОбновитьНастройкуВСервисеСРевизиейТокеновЗапускЗадания()
	
	ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияВФоне(
		УникальныйИдентификатор);
	ПараметрыВыполнения.НаименованиеФоновогоЗадания
		= НСтр("ru = 'Ревизия токенов и обновление настройки онлайн-заказов в сервисе.'");
	
	РезультатВыполнения = ДлительныеОперации.ВыполнитьФункцию(
		ПараметрыВыполнения,
		"ОнлайнЗаказыСлужебный.ОбновитьНастройкуСРевизиейТокенов",
		Объект.Ссылка,
		ЭтоНоваяНастройка);
	
	Возврат РезультатВыполнения;
	
КонецФункции

&НаСервере
Функция ОбновитьНастройкуВСервисеСОтзывомТокеновЗапускЗадания()
	
	НеиспользуемыеНастройкиОплат = Новый Соответствие;
	НеиспользуемыеНастройкиОблачныхКасс = Новый Соответствие;
	
	Для Каждого НеактуальнаяНастройка Из НеактуальныеНастройки Цикл
		
		Если СуществуютНастройки(НеактуальнаяНастройка.Значение.ВидТокена, НеактуальнаяНастройка.Ключ) Тогда
			Продолжить;
		КонецЕсли;
		
		Если НеактуальнаяНастройка.Значение.ВидТокена =
			ОнлайнЗаказыСлужебный.ИдентификаторВидаТокенаПриемОплат() Тогда
			
			НеиспользуемыеНастройкиОплат.Вставить(
				НеактуальнаяНастройка.Значение.СпособОплаты,
				НеактуальнаяНастройка.Ключ);
			
		ИначеЕсли НеактуальнаяНастройка.Значение.ВидТокена =
				ОнлайнЗаказыСлужебный.ИдентификаторВидаТокенаОблачнаяКасса() Тогда
			
			НеиспользуемыеНастройкиОблачныхКасс.Вставить(
				НеактуальнаяНастройка.Значение.СпособОплаты,
				НеактуальнаяНастройка.Ключ);
			
		КонецЕсли;
		
	КонецЦикла;
	
	Если ЗначениеЗаполнено(НеиспользуемыеНастройкиОплат)
		Или ЗначениеЗаполнено(НеиспользуемыеНастройкиОблачныхКасс) Тогда
		
		НеиспользуемыеНастройки = Новый Структура;
		НеиспользуемыеНастройки.Вставить(
			ОнлайнЗаказыСлужебный.ИдентификаторВидаТокенаПриемОплат(),
			НеиспользуемыеНастройкиОплат);
		НеиспользуемыеНастройки.Вставить(
			ОнлайнЗаказыСлужебный.ИдентификаторВидаТокенаОблачнаяКасса(),
			НеиспользуемыеНастройкиОблачныхКасс);
		
		ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияВФоне(
			УникальныйИдентификатор);
		ПараметрыВыполнения.НаименованиеФоновогоЗадания
			= НСтр("ru = 'Отзыв токенов и обновление настройки онлайн-заказов в сервисе.'");
		
		РезультатВыполнения = ДлительныеОперации.ВыполнитьФункцию(
			ПараметрыВыполнения,
			"ОнлайнЗаказыСлужебный.ОбновитьНастройкуСОтзывомТокенов",
			Объект.Ссылка,
			НеиспользуемыеНастройки,
			ЭтоНоваяНастройка);
		
	Иначе
		РезультатВыполнения = ОбновитьНастройкуВСервисеЗапускЗадания();
	КонецЕсли;
	
	Возврат РезультатВыполнения;
	
КонецФункции

&НаСервере
Функция ОбновитьНастройкуВСервисеЗапускЗадания()
	
	ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияВФоне(
		УникальныйИдентификатор);
	ПараметрыВыполнения.НаименованиеФоновогоЗадания
		= НСтр("ru = 'Обновление настроек онлайн-заказов в сервисе.'");
	
	РезультатВыполнения = ДлительныеОперации.ВыполнитьФункцию(
		ПараметрыВыполнения,
		"ОнлайнЗаказыСлужебный.ОбновитьНастройку",
		Объект.Ссылка,
		ЭтоНоваяНастройка);
	
	Возврат РезультатВыполнения;
	
КонецФункции

&НаКлиенте
Процедура ОбновитьНастройкуВСервисеЗавершение(
		Результат,
		ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если Результат.Статус = "Выполнено" Тогда
		
		РезультатОперации = ПолучитьИзВременногоХранилища(Результат.АдресРезультата);
		Если ЗначениеЗаполнено(РезультатОперации.КодОшибки) Тогда
			
			ПоказатьПредупреждение(
				Неопределено,
				РезультатОперации.СообщениеОбОшибке);
			
			Если Объект.ОшибкаСинхронизации <> Истина Тогда
				УстановитьОшибкуСинхронизации(Истина);
			КонецЕсли;
			
		Иначе
			
			Если Объект.ОшибкаСинхронизации <> Ложь Тогда
				УстановитьОшибкуСинхронизации(Ложь);
			КонецЕсли;
			
			ЭтоНоваяНастройка = Ложь;
			
			Если ДополнительныеПараметры.ПоказыватьПредупреждение Тогда
				ПоказатьПредупреждение(
					Неопределено,
					НСтр("ru = 'Настройки успешно обновлены.'"));
			ИначеЕсли ДополнительныеПараметры.ЗакрытьПослеЗаписи Тогда
				Закрыть(Истина);
				Возврат;
			КонецЕсли;
			
		КонецЕсли;
		
	ИначеЕсли Результат.Статус = "Ошибка" Тогда
		
		ДанныеОшибки = ОбщегоНазначенияКлиентСервер.УточнениеИсключения(
			Результат.ИнформацияОбОшибке,
			НСтр("ru = 'Ошибка обновления настройки онлайн-заказов в сервисе.'"));
		
		ПоказатьПредупреждение(
			Неопределено,
			ДанныеОшибки.Текст);
		
	КонецЕсли;
	
	Прочитать();
	
КонецПроцедуры

#КонецОбласти

#Область НастройкаВнешнегоВидаСтраницы

&НаКлиенте
Процедура НастроитьВнешнийВидСтраницы()
	
	Результат = URLНастройкиПодключения(Объект.Ссылка);
	
	Если Результат.КодОшибки = ОнлайнЗаказыКлиент.КодОшибкиДанныеАутентификацииИППНеЗаполнены() Тогда
		Если ИнтернетПоддержкаПользователейКлиент.ДоступноПодключениеИнтернетПоддержки() Тогда
			ИнтернетПоддержкаПользователейКлиент.ПодключитьИнтернетПоддержкуПользователей(
				Новый ОписаниеОповещения("ПриЗавершенииПодключенияИнтернетПоддержки", ЭтотОбъект),
				ЭтотОбъект);
		Иначе
			ПоказатьПредупреждение(
				,
				НСтр("ru = 'Необходимо подключить Интернет-поддержку пользователей.
				|Обратитесь к администратору системы.'"));
		КонецЕсли;
	ИначеЕсли ПустаяСтрока(Результат.КодОшибки) Тогда
		ФайловаяСистемаКлиент.ОткрытьНавигационнуюСсылку(Результат.URLНастройкиПодключения);
	Иначе
		ПоказатьПредупреждение(
			,
			Результат.СообщениеОбОшибке);
	КонецЕсли;
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция URLНастройкиПодключения(Знач НастройкаПодключения)
	
	Возврат ОнлайнЗаказыСлужебный.URLНастройкиПодключения(НастройкаПодключения);
	
КонецФункции

#КонецОбласти

#Область Прочее

&НаСервере
Процедура ПроверитьАктуальностьНастроек()
	
	НеактуальныеНастройкиВрем = Новый Соответствие;
	ИзмененыНастройкиОплатФискализации = Ложь;
	ИзмененыНастройкиСтраницы = Ложь;
	НастройкаОбъект = Объект.Ссылка.ПолучитьОбъект();
	
	Если Не Объект.ОшибкаСинхронизации Тогда
		НеобходимОтзывТокенов = Не Объект.Используется И НастройкаОбъект.Используется;
	КонецЕсли;
	
	ПроверитьАктуальностьНастроекФискализации(НастройкаОбъект, НеактуальныеНастройкиВрем);
	ПроверитьАктуальностьНастроекОплат(НастройкаОбъект, НеактуальныеНастройкиВрем);
	
	Если НастройкаОбъект.Используется <> Объект.Используется
		Или НастройкаОбъект.Наименование <> Объект.Наименование
		Или ИзмененыНастройкиОплатФискализации Тогда
		ИзмененыНастройкиСтраницы = Истина;
	КонецЕсли;
	
	НеактуальныеНастройки = Новый ФиксированноеСоответствие(НеактуальныеНастройкиВрем);
	
КонецПроцедуры

&НаСервере
Процедура ПроверитьАктуальностьНастроекФискализации(НастройкаОбъект, НеактуальныеНастройкиВрем)
	
	Если НастройкаОбъект.ФискализироватьОнлайнЗаказы <> Объект.ФискализироватьОнлайнЗаказы Тогда
		ИзмененыНастройкиОплатФискализации = Истина;
	КонецЕсли;
	
	НастройкаПодключенияКОблачнойКассеСохраненная = ?(
		НастройкаОбъект.ФискализироватьОнлайнЗаказы,
		НастройкаОбъект.НастройкаПодключенияКОблачнойКассе,
		Неопределено);
	
	НастройкаПодключенияКОблачнойКассе = ?(
		Объект.ФискализироватьОнлайнЗаказы,
		Объект.НастройкаПодключенияКОблачнойКассе,
		Неопределено);
	
	Если Объект.ФискализироватьОнлайнЗаказы
		И НастройкаПодключенияКОблачнойКассеСохраненная <> НастройкаПодключенияКОблачнойКассе Тогда
		ИзмененыНастройкиОплатФискализации = Истина;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(НастройкаПодключенияКОблачнойКассеСохраненная)
		И НастройкаПодключенияКОблачнойКассеСохраненная <> НастройкаПодключенияКОблачнойКассе Тогда
		
		НеактуальныеНастройкиВрем.Вставить(
			НастройкаПодключенияКОблачнойКассеСохраненная,
			ПараметрыНастройкиПодключения(
				ОнлайнЗаказыСлужебный.ИдентификаторВидаТокенаОблачнаяКасса(),
				Перечисления.СпособыОплатыОнлайнЗаказов.ПустаяСсылка()));
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ПроверитьАктуальностьНастроекОплат(НастройкаОбъект, НеактуальныеНастройкиВрем)
	
	Если НастройкаОбъект.ПоРеквизитамОтФизЛиц <> Объект.ПоРеквизитамОтФизЛиц
		Или НастройкаОбъект.ПоРеквизитамОтЮрЛиц <> Объект.ПоРеквизитамОтЮрЛиц Тогда
		ИзмененыНастройкиОплатФискализации = Истина;
	КонецЕсли;
	
	Если НастройкаОбъект.НастройкиОплаты.Количество() <> Объект.НастройкиОплаты.Количество() Тогда
		ИзмененыНастройкиОплатФискализации = Истина;
	КонецЕсли;
	
	Для Каждого СохраненнаяНастройкаОплаты Из НастройкаОбъект.НастройкиОплаты Цикл
		
		НастройкаОплаты = Неопределено;
		Используется = Ложь;
		
		Отбор = Новый Структура;
		Отбор.Вставить("СпособОплаты", СохраненнаяНастройкаОплаты.СпособОплаты);
		
		НайденныеЗначения = Объект.НастройкиОплаты.НайтиСтроки(Отбор);
		
		Для Каждого НайденноеЗначение Из НайденныеЗначения Цикл
			НастройкаОплаты = НайденноеЗначение.НастройкаПодключения;
			Используется = НайденноеЗначение.Используется;
		КонецЦикла;
		
		Если СохраненнаяНастройкаОплаты.Используется <> Используется Тогда
			ИзмененыНастройкиОплатФискализации = Истина;
		ИначеЕсли Используется
			И СохраненнаяНастройкаОплаты.НастройкаПодключения <> НастройкаОплаты Тогда
			ИзмененыНастройкиОплатФискализации = Истина;
		КонецЕсли;
		
		Если НастройкаНеактуальна(СохраненнаяНастройкаОплаты, НастройкаОплаты, Используется) Тогда
			НеактуальныеНастройкиВрем.Вставить(
				СохраненнаяНастройкаОплаты.НастройкаПодключения,
				ПараметрыНастройкиПодключения(
					ОнлайнЗаказыСлужебный.ИдентификаторВидаТокенаПриемОплат(),
					СохраненнаяНастройкаОплаты.СпособОплаты));
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Функция НастройкаНеактуальна(СохраненнаяНастройкаОплаты, НастройкаОплаты, Используется)
	
	Если СохраненнаяНастройкаОплаты.Используется = Ложь
		И Используется = Ложь Тогда
		Возврат Ложь;
	ИначеЕсли СохраненнаяНастройкаОплаты.Используется И Не Используется Тогда
		Возврат Истина;
	ИначеЕсли СохраненнаяНастройкаОплаты.Используется
		И СохраненнаяНастройкаОплаты.НастройкаПодключения <> НастройкаОплаты Тогда
		Возврат Истина;
	Иначе
		Возврат Ложь;
	КонецЕсли;
	
КонецФункции

&НаСервере
Функция ПараметрыНастройкиПодключения(
	ВидТокена,
	СпособОплаты)
	
	Результат = Новый Структура;
	Результат.Вставить("ВидТокена", ВидТокена);
	Результат.Вставить("СпособОплаты", СпособОплаты);
	
	Возврат Результат;
	
КонецФункции

&НаСервере
Процедура УстановитьВидимостьДоступность()
	
	Элементы.НастроитьСтраницуЗаказа.Доступность = НастройкаОнлайнЗаказовДоступна;
	Элементы.ФормаОбновитьНастройки.Доступность = НастройкаОнлайнЗаказовДоступна;
	Элементы.ФормаЗаписатьИЗакрыть.Доступность = НастройкаОнлайнЗаказовДоступна;
	Элементы.ГруппаПодключениеКСБПc2b.Доступность = НастройкаОнлайнЗаказовДоступна;
	Элементы.ГруппаПодключениеЭквайринг.Доступность = НастройкаОнлайнЗаказовДоступна;
	Элементы.ГруппаПодключениеОзонПэй.Доступность = НастройкаОнлайнЗаказовДоступна;
	Элементы.ГруппаПоБанковскимРеквизитамФизЛица.Доступность = НастройкаОнлайнЗаказовДоступна;
	Элементы.ГруппаПодключениеКОблачнойКассе.Доступность = НастройкаОнлайнЗаказовДоступна;
	Элементы.ГруппаПодключениеКСБПb2b.Доступность = НастройкаОнлайнЗаказовДоступна;
	Элементы.ГруппаПоБанковскимРеквизитамЮрЛица.Доступность = НастройкаОнлайнЗаказовДоступна;
	
	Если Параметры.РежимФормы = "ОтправкаURLОнлайнЗаказов" Тогда
		Элементы.Используется.Видимость = Ложь;
	КонецЕсли;
	
	УстановитьВидимостьПредставлениеСБП();
	УстановитьВидимостьПредставлениеИнтернетЭквайринга();
	УстановитьВидимостьПредставлениеОблачнойФискализации();
	УстановитьПредставлениеДекорацииПредупреждение();
	УстановитьВидимостьПредставлениеОзонПэй();
	
КонецПроцедуры

&НаСервере
Процедура УправлениеЭлементамиФормыПоДанным()
	
	Если ЗначениеЗаполнено(Объект.Ссылка) Тогда
		Элементы.ГруппаПредупреждение.Видимость = Объект.ОшибкаСинхронизации;
	Иначе
		Элементы.ГруппаПредупреждение.Видимость = Ложь;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура УстановитьДоступностьНастроекОплатФискализации()
	
	Элементы.НастройкаПодключенияКСБПc2b.Доступность = ПриниматьОплатуСБПc2b;
	Элементы.НастройкаПодключенияКОзонПэй.Доступность = ПриниматьОплатуОзонПэй;
	Элементы.НастройкаПодключенияКИнтернетЭквайрингу.Доступность = ПриниматьОплатуИнтернетЭквайринг;
	Элементы.НастройкаПодключенияКОблачнойКассе.Доступность = Объект.ФискализироватьОнлайнЗаказы;
	
	Элементы.НастройкаПодключенияКСБПb2b.Доступность = ПриниматьОплатуСБПb2b;
	
КонецПроцедуры

&НаСервере
Процедура УстановитьВидимостьПредставлениеСБП()
	
	ЧтениеНастроекСБПДоступно = Ложь;
	
	Если ОбщегоНазначения.ПодсистемаСуществует("ИнтернетПоддержкаПользователей.СистемаБыстрыхПлатежей.БазоваяФункциональностьСБП") Тогда
		МодульСистемаБыстрыхПлатежейСлужебный = ОбщегоНазначения.ОбщийМодуль("СистемаБыстрыхПлатежейСлужебный");
		ЧтениеНастроекСБПДоступно = МодульСистемаБыстрыхПлатежейСлужебный.ЧтениеНастроекДоступно();
	КонецЕсли;
	
	Если Не ЧтениеНастроекСБПДоступно
		Или Не ОбщегоНазначения.ПодсистемаСуществует("ИнтернетПоддержкаПользователей.СистемаБыстрыхПлатежей.ПереводыСБПc2b") Тогда
		Элементы.ГруппаПодключениеКСБПc2b.Видимость = Ложь;
	Иначе
		
		Если Не ЗначениеЗаполнено(НастройкаПодключенияКСБПc2b) Тогда
			НастройкаПодключенияКСБПc2b =
				ПредопределенноеЗначение("Справочник.НастройкиПодключенияКСистемеБыстрыхПлатежей.ПустаяСсылка");
		КонецЕсли;
		
		Элементы.НастройкаПодключенияКСБПc2b.ПараметрыВыбора = ПараметрыВыбораОплаты(
			Перечисления.СпособыОплатыОнлайнЗаказов.СБПc2b);
		
	КонецЕсли;
	
	Если Не ЧтениеНастроекСБПДоступно
		Или Не ОбщегоНазначения.ПодсистемаСуществует("ИнтернетПоддержкаПользователей.СистемаБыстрыхПлатежей.ПереводыСБПb2b") Тогда
		Элементы.ГруппаПодключениеКСБПb2b.Видимость = Ложь;
	Иначе
		
		Если Не ЗначениеЗаполнено(НастройкаПодключенияКСБПb2b) Тогда
			НастройкаПодключенияКСБПb2b =
				ПредопределенноеЗначение("Справочник.НастройкиПодключенияКСистемеБыстрыхПлатежей.ПустаяСсылка");
		КонецЕсли;
		
		Элементы.НастройкаПодключенияКСБПb2b.ПараметрыВыбора = ПараметрыВыбораОплаты(
			Перечисления.СпособыОплатыОнлайнЗаказов.СБПb2b);
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура УстановитьВидимостьПредставлениеИнтернетЭквайринга()
	
	ЧтениеНастроекИнтернетЭквайрингаДоступно = Ложь;
	
	Если ОбщегоНазначения.ПодсистемаСуществует("ИнтернетПоддержкаПользователей.ИнтернетЭквайринг") Тогда
		МодульИнтернетЭквайрингСлужебный = ОбщегоНазначения.ОбщийМодуль("ИнтернетЭквайрингСлужебный");
		ЧтениеНастроекИнтернетЭквайрингаДоступно = МодульИнтернетЭквайрингСлужебный.ЧтениеНастроекДоступно();
	КонецЕсли;
	
	Элементы.ГруппаПодключениеЭквайринг.Видимость = ЧтениеНастроекИнтернетЭквайрингаДоступно;
	
	Если ЧтениеНастроекИнтернетЭквайрингаДоступно
		И Не ЗначениеЗаполнено(НастройкаПодключенияКИнтернетЭквайрингу)Тогда
		НастройкаПодключенияКИнтернетЭквайрингу =
			ПредопределенноеЗначение("Справочник.НастройкиПодключенияКИнтернетЭквайрингу.ПустаяСсылка");
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура УстановитьВидимостьПредставлениеОзонПэй()
	
	Если ЧтениеНастроекПлатежныхСистемДоступно
		И ОбщегоНазначения.ПодсистемаСуществует("ИнтернетПоддержкаПользователей.ПлатежныеСистемы.ОзонПэй") Тогда
		
		Элементы.ГруппаПодключениеОзонПэй.Видимость = Истина;
		
		Если Не ЗначениеЗаполнено(НастройкаПодключенияКОзонПэй) Тогда
			НастройкаПодключенияКОзонПэй =
				ПредопределенноеЗначение("Справочник.НастройкиПодключенияКПлатежнымСистемам.ПустаяСсылка");
		КонецЕсли;
		
	Иначе
		Элементы.ГруппаПодключениеОзонПэй.Видимость = Ложь;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура УстановитьВидимостьПредставлениеОблачнойФискализации()
	
	ЧтениеНастроекОблачныхКассДоступно = Ложь;
	
	Если ОбщегоНазначения.ПодсистемаСуществует("ИнтернетПоддержкаПользователей.ОблачныеКассы") Тогда
		МодульОблачныеКассы = ОбщегоНазначения.ОбщийМодуль("ОблачныеКассы");
		ЧтениеНастроекОблачныхКассДоступно = МодульОблачныеКассы.ЧтениеНастроекПодключенияДоступно();
	КонецЕсли;
	
	Элементы.ГруппаПодключениеКОблачнойКассе.Видимость = ЧтениеНастроекОблачныхКассДоступно;
	
КонецПроцедуры

&НаСервере
Процедура УстановитьПредставлениеДекорацииПредупреждение()
	
	ЧастиСтрок = Новый Массив;
	ЧастиСтрок.Добавить(НСтр("ru = 'Не удалось обновить данные в сервисе.'"));
	
	Если НастройкаОнлайнЗаказовДоступна Тогда
		ЧастиСтрок.Добавить(" ");
		ЧастиСтрок.Добавить(
			Новый ФорматированнаяСтрока(
				НСтр("ru = 'Повторить отправку'")
				,
				,
				,
				,
				"operation:pageSettings"));
	КонецЕсли;
	
	Элементы.ДекорацияПредупреждение.Заголовок = Новый ФорматированнаяСтрока(ЧастиСтрок);
	
КонецПроцедуры

&НаСервере
Функция ПараметрыВыбораОплаты(СпособОплаты)
	
	Возврат ОнлайнЗаказыСлужебный.ПараметрыВыбораОплаты(СпособОплаты);
	
КонецФункции

&НаКлиенте
Процедура ПриЗавершенииПодключенияИнтернетПоддержки(ДанныеАутентификации, ДопПараметры) Экспорт
	
	Если ДанныеАутентификации <> Неопределено Тогда
		НастроитьВнешнийВидСтраницы();
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура УстановитьОшибкуСинхронизации(Знач ЗначениеОшибки)
	
	Прочитать();
	Объект.ОшибкаСинхронизации = ЗначениеОшибки;
	ИзменениеАктуальности = Истина;
	Записать();
	
КонецПроцедуры

#КонецОбласти

#КонецОбласти
