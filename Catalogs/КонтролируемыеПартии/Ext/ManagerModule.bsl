#Область ОбновлениеИнформационнойБазы

// см. ОбновлениеИнформационнойБазыБСП.ПриДобавленииОбработчиковОбновления
//
Процедура ПриДобавленииОбработчиковОбновления(Обработчики) Экспорт
	
	Обработчик = Обработчики.Добавить();
	Обработчик.Процедура = "Справочники.КонтролируемыеПартии.ОбработатьДанныеДляПереходаНаНовуюВерсию";
	Обработчик.Версия = "11.5.27.26";
	Обработчик.РежимВыполнения = "Отложенно";
	Обработчик.Идентификатор = Новый УникальныйИдентификатор("4a0d0088-7303-40bd-94cc-d6954c6af9a4");
	Обработчик.Многопоточный = Истина;
	Обработчик.ПроцедураЗаполненияДанныхОбновления = "Справочники.КонтролируемыеПартии.ЗарегистрироватьДанныеКОбработкеДляПереходаНаНовуюВерсию";
	Обработчик.ПроцедураПроверки = "ОбновлениеИнформационнойБазы.ДанныеОбновленыНаНовуюВерсиюПрограммы";
	Обработчик.Порядок = Перечисления.ПорядокОбработчиковОбновления.Некритичный;
	
	СписокОписаний = Новый Массив;
	СписокОписаний.Добавить(НСтр("ru = 'Обновление справочника ""Контролируемые партии"":'"));
	СписокОписаний.Добавить(НСтр("ru = '- Заполнение нового реквизита ""Подразделение"" из реквизита ""Партия"", для партий, не связанных с заявками на контроль качества товаров';"));
	
	Обработчик.Комментарий = СтрСоединить(СписокОписаний, Символы.ПС);
	
	Читаемые = Новый Массив;
	Читаемые.Добавить(Метаданные.Документы.ВозвратТоваровОтКлиента.ПолноеИмя());
	
	
	
	Читаемые.Добавить(Метаданные.Документы.ЗаказНаПеремещение.ПолноеИмя());
	Читаемые.Добавить(Метаданные.Документы.ЗаказНаСборку.ПолноеИмя());
	
	
	Читаемые.Добавить(Метаданные.Документы.ЗаказПоставщику.ПолноеИмя());
	Читаемые.Добавить(Метаданные.Документы.ЗаявкаНаВозвратТоваровОтКлиента.ПолноеИмя());
	Читаемые.Добавить(Метаданные.Документы.ПеремещениеТоваров.ПолноеИмя());
	Читаемые.Добавить(Метаданные.Документы.ПоступлениеТоваровНаСклад.ПолноеИмя());
	Читаемые.Добавить(Метаданные.Документы.ПоступлениеТоваровОтКлиента.ПолноеИмя());
	Читаемые.Добавить(Метаданные.Документы.ПоступлениеТоваровОтХранителя.ПолноеИмя());
	Читаемые.Добавить(Метаданные.Документы.ПриемкаТоваровНаХранение.ПолноеИмя());
	Читаемые.Добавить(Метаданные.Документы.ПриобретениеТоваровУслуг.ПолноеИмя());
	Читаемые.Добавить(Метаданные.Документы.ПрочееОприходованиеТоваров.ПолноеИмя());
	Читаемые.Добавить(Метаданные.Документы.СборкаТоваров.ПолноеИмя());
	Читаемые.Добавить(Метаданные.Справочники.ДоговорыКонтрагентов.ПолноеИмя());
	
	Обработчик.ЧитаемыеОбъекты = СтрСоединить(Читаемые, ",");
	
	Изменяемые = Новый Массив;
	Изменяемые.Добавить(Метаданные.Справочники.КонтролируемыеПартии.ПолноеИмя());
	Обработчик.ИзменяемыеОбъекты = СтрСоединить(Изменяемые, ",");
	
	Блокируемые = Новый Массив;
	Обработчик.БлокируемыеОбъекты = СтрСоединить(Блокируемые, ",");

	Обработчик = Обработчики.Добавить();
	Обработчик.Процедура = "Справочники.КонтролируемыеПартии.ОбработатьКонтролируемыеПартииЗаявокНаКонтрольКачестваТоваров";
	Обработчик.Версия = "11.5.27.26";
	Обработчик.РежимВыполнения = "Отложенно";
	Обработчик.Идентификатор = Новый УникальныйИдентификатор("e7903a65-98ce-4d6d-9e79-8c75b675fdfb");
	Обработчик.Многопоточный = Истина;
	Обработчик.ПроцедураЗаполненияДанныхОбновления = "Справочники.КонтролируемыеПартии.ЗарегистрироватьКонтролируемыеПартииЗаявокНаКонтрольКачестваТоваров";
	Обработчик.ПроцедураПроверки = "ОбновлениеИнформационнойБазы.ДанныеОбновленыНаНовуюВерсиюПрограммы";
	Обработчик.Порядок = Перечисления.ПорядокОбработчиковОбновления.Некритичный;
	
	СписокОписаний = Новый Массив;
	СписокОписаний.Добавить(НСтр("ru = 'Обновление справочника ""Контролируемые партии"":'"));
	СписокОписаний.Добавить(НСтр("ru = '- Заполнение нового реквизита ""Подразделение"" из партий документа, для партий, связанных с заявками на контроль качества товаров';"));
	
	Обработчик.Комментарий = СтрСоединить(СписокОписаний, Символы.ПС);
	
	Читаемые = Новый Массив;
	Читаемые.Добавить(Метаданные.Справочники.КонтролируемыеПартии.ПолноеИмя());
	Читаемые.Добавить(Метаданные.Документы.ЗаявкаНаКонтрольКачестваТоваров.ПолноеИмя());
	
	Обработчик.ЧитаемыеОбъекты = СтрСоединить(Читаемые, ",");
	
	Изменяемые = Новый Массив;
	Изменяемые.Добавить(Метаданные.Справочники.КонтролируемыеПартии.ПолноеИмя());
	Обработчик.ИзменяемыеОбъекты = СтрСоединить(Изменяемые, ",");
	
	Блокируемые = Новый Массив;
	Обработчик.БлокируемыеОбъекты = СтрСоединить(Блокируемые, ",");
	
	Обработчик.ПриоритетыВыполнения = ОбновлениеИнформационнойБазы.ПриоритетыВыполненияОбработчика();
	
	НоваяСтрока = Обработчик.ПриоритетыВыполнения.Добавить();
	НоваяСтрока.Процедура = "Справочники.КонтролируемыеПартии.ОбработатьДанныеДляПереходаНаНовуюВерсию";
	НоваяСтрока.Порядок = "После";
	
КонецПроцедуры

// Параметры:
// 	Параметры - см. ОбновлениеИнформационнойБазы.ОсновныеПараметрыОтметкиКОбработке
//
Процедура ЗарегистрироватьДанныеКОбработкеДляПереходаНаНовуюВерсию(Параметры) Экспорт
	
	ПараметрыВыборки = Параметры.ПараметрыВыборки;
	ПараметрыВыборки.ПолныеИменаОбъектов = ПустаяСсылка().Метаданные().ПолноеИмя();
	ПараметрыВыборки.СпособВыборки = ОбновлениеИнформационнойБазы.СпособВыборкиСсылки();
	ПараметрыВыборки.ДополнительныеИсточникиДанных.Вставить("Партия");
	
	Запрос = Новый Запрос();
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Партии.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.КонтролируемыеПартии КАК Партии
	|ГДЕ
	|	НЕ Партии.УдалитьПодразделениеОбработано
	|	И НЕ ТИПЗНАЧЕНИЯ(Партии.Партия) = ТИП(Документ.ЗаявкаНаКонтрольКачестваТоваров)";
	ТаблицаПартий = Запрос.Выполнить().Выгрузить();
	ОбновлениеИнформационнойБазы.ОтметитьКОбработке(Параметры, ТаблицаПартий.ВыгрузитьКолонку("Ссылка"));
	
КонецПроцедуры

// Обработчик обновления
// 
// Параметры:
// 	Параметры - См. ОбновлениеИнформационнойБазы.ДополнительныеПараметрыВыборкиДанныхДляМногопоточнойОбработки 
//
Процедура ОбработатьДанныеДляПереходаНаНовуюВерсию(Параметры) Экспорт
	
	Параметры.ОбработкаЗавершена = Ложь;
	
	ПолноеИмяОбъекта = ПустаяСсылка().Метаданные().ПолноеИмя();
	
	ОбновляемыеДанные = ОбновлениеИнформационнойБазы.ДанныеДляОбновленияВМногопоточномОбработчике(Параметры);
	
	Если ОбновляемыеДанные.Количество() = 0 Тогда
		
		Параметры.ОбработкаЗавершена =
			ОбновлениеИнформационнойБазы.ОбработкаДанныхЗавершена(Параметры.Очередь, ПолноеИмяОбъекта);
		Возврат;
		
	КонецЕсли;
	
	Запрос = Новый Запрос();
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ОбновляемыеДанные.Ссылка КАК Ссылка
	|ПОМЕСТИТЬ ОбновляемыеДанные
	|ИЗ
	|	&ОбновляемыеДанные КАК ОбновляемыеДанные
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ОбновляемыеДанные.Ссылка КАК Ссылка,
	|	РеквизитыСправочника.Партия КАК Партия,
	|	РеквизитыСправочника.ВерсияДанных КАК ВерсияДанных
	|ИЗ
	|	ОбновляемыеДанные КАК ОбновляемыеДанные
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.КонтролируемыеПартии КАК РеквизитыСправочника
	|		ПО РеквизитыСправочника.Ссылка = ОбновляемыеДанные.Ссылка";
	
	Запрос.УстановитьПараметр("ОбновляемыеДанные", ОбновляемыеДанные);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	ИсключенияПриОбновлении = Новый Массив();
	Пока Выборка.Следующий() Цикл
		
		ПричинаИсключения = "";
		
		НачатьТранзакцию();
		
		Попытка
			
			ПричинаИсключения = "БЛОКИРОВКА";
			
			Блокировка = Новый БлокировкаДанных;
			
			ЭлементБлокировки = Блокировка.Добавить(ПолноеИмяОбъекта);
			ЭлементБлокировки.УстановитьЗначение("Ссылка", Выборка.Ссылка);
			ЭлементБлокировки.Режим = РежимБлокировкиДанных.Исключительный;
			
			Если ЗначениеЗаполнено(Выборка.Партия) Тогда
				ЭлементБлокировки = Блокировка.Добавить(Выборка.Партия.Метаданные().ПолноеИмя());
				ЭлементБлокировки.УстановитьЗначение("Ссылка", Выборка.Партия);
				ЭлементБлокировки.Режим = РежимБлокировкиДанных.Разделяемый;
			КонецЕсли;
			
			Блокировка.Заблокировать();
			
			СправочникОбъект = ОбновлениеИнформационнойБазыУТ.ПроверитьПолучитьОбъект(
				Выборка.Ссылка, Выборка.ВерсияДанных, Параметры.Очередь); // СправочникОбъект
			
			ПричинаИсключения = "ПЛОХИЕ_ДАННЫЕ";
			
			ОбъектИзменен = Ложь;
			
			Если СправочникОбъект <> Неопределено Тогда
				
				Если ЗначениеЗаполнено(Выборка.Партия)
						И (ТипЗнч(Выборка.Партия) = Тип("ДокументСсылка.ВозвратТоваровОтКлиента")
							
							
							Или ТипЗнч(Выборка.Партия) = Тип("ДокументСсылка.ЗаказНаПеремещение")
							Или ТипЗнч(Выборка.Партия) = Тип("ДокументСсылка.ЗаказНаСборку")
							
							
							Или ТипЗнч(Выборка.Партия) = Тип("ДокументСсылка.ЗаказПоставщику")
							Или ТипЗнч(Выборка.Партия) = Тип("ДокументСсылка.ЗаявкаНаВозвратТоваровОтКлиента")
							Или ТипЗнч(Выборка.Партия) = Тип("ДокументСсылка.ПеремещениеТоваров")
							Или ТипЗнч(Выборка.Партия) = Тип("ДокументСсылка.ПоступлениеТоваровНаСклад")
							Или ТипЗнч(Выборка.Партия) = Тип("ДокументСсылка.ПоступлениеТоваровОтКлиента")
							Или ТипЗнч(Выборка.Партия) = Тип("ДокументСсылка.ПоступлениеТоваровОтХранителя")
							Или ТипЗнч(Выборка.Партия) = Тип("ДокументСсылка.ПриемкаТоваровНаХранение")
							Или ТипЗнч(Выборка.Партия) = Тип("ДокументСсылка.ПриобретениеТоваровУслуг")
							Или ТипЗнч(Выборка.Партия) = Тип("ДокументСсылка.ПрочееОприходованиеТоваров")
							Или ТипЗнч(Выборка.Партия) = Тип("ДокументСсылка.СборкаТоваров")
							Или ТипЗнч(Выборка.Партия) = Тип("СправочникСсылка.ДоговорыКонтрагентов")) Тогда
								
								ЗначениеРеквизита = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Выборка.Партия, "Подразделение");
								СправочникОбъект.Подразделение = ЗначениеРеквизита;
								
				КонецЕсли;
				СправочникОбъект.УдалитьПодразделениеОбработано = Истина;
				
				ОбъектИзменен = Истина;
				
			КонецЕсли;
			
			ПричинаИсключения = "ЗАПИСЬ";
			
			Если ОбъектИзменен Тогда
				ОбновлениеИнформационнойБазы.ЗаписатьДанные(СправочникОбъект);
			Иначе
				ОбновлениеИнформационнойБазы.ОтметитьВыполнениеОбработки(Выборка.Ссылка);
			КонецЕсли;
			
			ЗафиксироватьТранзакцию();
			
		Исключение
			
			ОтменитьТранзакцию();
			
			ОбновлениеИнформационнойБазыУТ.СообщитьОНеудачнойОбработке(ИнформацияОбОшибке(), Выборка.Ссылка);
			
			Если ПричинаИсключения = "ПЛОХИЕ_ДАННЫЕ" Тогда
				
				Рекомендация = НСтр("ru = 'Проверьте данные справочника вручную.'");
				ОписаниеПроблемы = ОбновлениеИнформационнойБазыУТ.ПроблемаСДанными(
					Выборка.Ссылка, Рекомендация, ИнформацияОбОшибке());
				ИсключенияПриОбновлении.Добавить(ОписаниеПроблемы);
				
			ИначеЕсли ПричинаИсключения = "ЗАПИСЬ" Тогда
				
				ОбновлениеИнформационнойБазыУТ.ЗаписатьПлохиеДанные(ИсключенияПриОбновлении, 1, Параметры);
				ТекстИсключения = НСтр("ru = 'Не удалось обработать справочник ""Контролируемые партии"".'");
				ВызватьИсключение СтрСоединить(ТекстИсключения, Символы.ПС);
				
			КонецЕсли;
			
		КонецПопытки;
		
	КонецЦикла;
	ОбновлениеИнформационнойБазыУТ.ЗаписатьПлохиеДанные(ИсключенияПриОбновлении, 1, Параметры);
	
	Параметры.ОбработкаЗавершена = ОбновлениеИнформационнойБазы.ОбработкаДанныхЗавершена(
		Параметры.Очередь, ПолноеИмяОбъекта);
	
КонецПроцедуры

// Параметры:
// 	Параметры - см. ОбновлениеИнформационнойБазы.ОсновныеПараметрыОтметкиКОбработке
//
Процедура ЗарегистрироватьКонтролируемыеПартииЗаявокНаКонтрольКачестваТоваров(Параметры) Экспорт
	
	ПараметрыВыборки = Параметры.ПараметрыВыборки;
	ПараметрыВыборки.ПолныеИменаОбъектов = ПустаяСсылка().Метаданные().ПолноеИмя();
	ПараметрыВыборки.СпособВыборки = ОбновлениеИнформационнойБазы.СпособВыборкиСсылки();
	ПараметрыВыборки.ДополнительныеИсточникиДанных.Вставить("Партия");
	
	Запрос = Новый Запрос();
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Партии.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.КонтролируемыеПартии КАК Партии
	|ГДЕ
	|	НЕ Партии.УдалитьПодразделениеОбработано
	|	И ТИПЗНАЧЕНИЯ(Партии.Партия) = ТИП(Документ.ЗаявкаНаКонтрольКачестваТоваров)";
	ТаблицаПартий = Запрос.Выполнить().Выгрузить();
	ОбновлениеИнформационнойБазы.ОтметитьКОбработке(Параметры, ТаблицаПартий.ВыгрузитьКолонку("Ссылка"));
	
КонецПроцедуры

// Обработчик обновления
// 
// Параметры:
// 	Параметры - См. ОбновлениеИнформационнойБазы.ДополнительныеПараметрыВыборкиДанныхДляМногопоточнойОбработки 
//
Процедура ОбработатьКонтролируемыеПартииЗаявокНаКонтрольКачестваТоваров(Параметры) Экспорт
	
	Параметры.ОбработкаЗавершена = Ложь;
	
	ПолноеИмяОбъекта = ПустаяСсылка().Метаданные().ПолноеИмя();
	
	Если ОбновлениеИнформационнойБазы.ЕстьЗаблокированныеПредыдущимиОчередямиДанные(Параметры.Очередь, ПолноеИмяОбъекта) Тогда
		Параметры.ОбработкаЗавершена = Ложь;
		Возврат;
	КонецЕсли;
	
	ОбновляемыеДанные = ОбновлениеИнформационнойБазы.ДанныеДляОбновленияВМногопоточномОбработчике(Параметры);
	
	Если ОбновляемыеДанные.Количество() = 0 Тогда
		
		Параметры.ОбработкаЗавершена =
			ОбновлениеИнформационнойБазы.ОбработкаДанныхЗавершена(Параметры.Очередь, ПолноеИмяОбъекта);
		Возврат;
		
	КонецЕсли;
	
	Запрос = Новый Запрос();
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ОбновляемыеДанные.Ссылка КАК Ссылка
	|ПОМЕСТИТЬ ОбновляемыеДанные
	|ИЗ
	|	&ОбновляемыеДанные КАК ОбновляемыеДанные
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ОбновляемыеДанные.Ссылка КАК Ссылка,
	|	РеквизитыСправочника.Партия КАК Партия,
	|	РеквизитыСправочника.ВерсияДанных КАК ВерсияДанных
	|ИЗ
	|	ОбновляемыеДанные КАК ОбновляемыеДанные
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.КонтролируемыеПартии КАК РеквизитыСправочника
	|		ПО РеквизитыСправочника.Ссылка = ОбновляемыеДанные.Ссылка";
	
	Запрос.УстановитьПараметр("ОбновляемыеДанные", ОбновляемыеДанные);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	ИсключенияПриОбновлении = Новый Массив();
	Пока Выборка.Следующий() Цикл
		
		ПричинаИсключения = "";
		
		НачатьТранзакцию();
		
		Попытка
			
			ПричинаИсключения = "ПЛОХИЕ_ДАННЫЕ";
			Блокировка = Новый БлокировкаДанных;
			
			ЭлементБлокировки = Блокировка.Добавить(ПолноеИмяОбъекта);
			ЭлементБлокировки.УстановитьЗначение("Ссылка", Выборка.Ссылка);
			ЭлементБлокировки.Режим = РежимБлокировкиДанных.Исключительный;
			
			Если ЗначениеЗаполнено(Выборка.Партия) Тогда
				ЭлементБлокировки = Блокировка.Добавить(Выборка.Партия.Метаданные().ПолноеИмя());
				ЭлементБлокировки.УстановитьЗначение("Ссылка", Выборка.Партия);
				ЭлементБлокировки.Режим = РежимБлокировкиДанных.Разделяемый;
				
				Запрос = Новый Запрос();
				Запрос.Текст =
					"ВЫБРАТЬ РАЗЛИЧНЫЕ
					|	Товары.КонтролируемаяПартия КАК КонтролируемаяПартия
					|ИЗ
					|	Документ.ЗаявкаНаКонтрольКачестваТоваров.Товары КАК Товары
					|ГДЕ
					|	Товары.Ссылка = &ЗаявкаНаКонтроль
					|	И Товары.КонтролируемаяПартия <> ЗНАЧЕНИЕ(Справочник.КонтролируемыеПартии.ПустаяСсылка)";
				Запрос.УстановитьПараметр("ЗаявкаНаКонтроль", Выборка.Партия);
				РезультатЗапросаПартий = Запрос.Выполнить();
				ЭлементБлокировки = Блокировка.Добавить("Справочник.КонтролируемыеПартии");
				ЭлементБлокировки.ИсточникДанных = РезультатЗапросаПартий;
				ЭлементБлокировки.ИспользоватьИзИсточникаДанных("Ссылка", "КонтролируемаяПартия");
				ЭлементБлокировки.Режим = РежимБлокировкиДанных.Разделяемый;
				
			КонецЕсли;
			
			ПричинаИсключения = "БЛОКИРОВКА";
			Блокировка.Заблокировать();
			
			СправочникОбъект = ОбновлениеИнформационнойБазыУТ.ПроверитьПолучитьОбъект(
				Выборка.Ссылка, Выборка.ВерсияДанных, Параметры.Очередь); // СправочникОбъект
			
			ПричинаИсключения = "ПЛОХИЕ_ДАННЫЕ";
			
			ОбъектИзменен = Ложь;
			
			Если СправочникОбъект <> Неопределено Тогда
				
				Запрос = Новый Запрос();
				Запрос.Текст =
					"ВЫБРАТЬ
					|	МИНИМУМ(Товары.КонтролируемаяПартия.Подразделение) КАК ПодразделениеМинимум,
					|	МАКСИМУМ(Товары.КонтролируемаяПартия.Подразделение) КАК ПодразделениеМаксимум
					|ИЗ
					|	Документ.ЗаявкаНаКонтрольКачестваТоваров.Товары КАК Товары
					|ГДЕ
					|	Товары.Ссылка = &ЗаявкаНаКонтроль";
				Запрос.УстановитьПараметр("ЗаявкаНаКонтроль", Выборка.Партия);
				ВыборкаЗаявок = Запрос.Выполнить().Выбрать();
				Если ВыборкаЗаявок.Следующий()
						И ЗначениеЗаполнено(ВыборкаЗаявок.ПодразделениеМинимум)
						И ЗначениеЗаполнено(ВыборкаЗаявок.ПодразделениеМаксимум)
						И ВыборкаЗаявок.ПодразделениеМинимум = ВыборкаЗаявок.ПодразделениеМаксимум Тогда
							СправочникОбъект.Подразделение = ВыборкаЗаявок.ПодразделениеМаксимум;
				КонецЕсли;
				СправочникОбъект.УдалитьПодразделениеОбработано = Истина;
				
				ОбъектИзменен = Истина;
				
			КонецЕсли;
			
			ПричинаИсключения = "ЗАПИСЬ";
			
			Если ОбъектИзменен Тогда
				ОбновлениеИнформационнойБазы.ЗаписатьДанные(СправочникОбъект);
			Иначе
				ОбновлениеИнформационнойБазы.ОтметитьВыполнениеОбработки(Выборка.Ссылка);
			КонецЕсли;
			
			ЗафиксироватьТранзакцию();
			
		Исключение
			
			ОтменитьТранзакцию();
			
			ОбновлениеИнформационнойБазыУТ.СообщитьОНеудачнойОбработке(ИнформацияОбОшибке(), Выборка.Ссылка);
			
			Если ПричинаИсключения = "ПЛОХИЕ_ДАННЫЕ" Тогда
				
				Рекомендация = НСтр("ru = 'Проверьте данные справочника вручную.'");
				ОписаниеПроблемы = ОбновлениеИнформационнойБазыУТ.ПроблемаСДанными(
					Выборка.Ссылка, Рекомендация, ИнформацияОбОшибке());
				ИсключенияПриОбновлении.Добавить(ОписаниеПроблемы);
				
			ИначеЕсли ПричинаИсключения = "ЗАПИСЬ" Тогда
				
				ОбновлениеИнформационнойБазыУТ.ЗаписатьПлохиеДанные(ИсключенияПриОбновлении, 1, Параметры);
				ТекстИсключения = НСтр("ru = 'Не удалось обработать справочник ""Контролируемые партии"".'");
				ВызватьИсключение СтрСоединить(ТекстИсключения, Символы.ПС);
				
			КонецЕсли;
			
		КонецПопытки;
		
	КонецЦикла;
	ОбновлениеИнформационнойБазыУТ.ЗаписатьПлохиеДанные(ИсключенияПриОбновлении, 1, Параметры);
	
	Параметры.ОбработкаЗавершена = ОбновлениеИнформационнойБазы.ОбработкаДанныхЗавершена(
		Параметры.Очередь, ПолноеИмяОбъекта);
	
КонецПроцедуры

#КонецОбласти

#КонецОбласти

#КонецЕсли