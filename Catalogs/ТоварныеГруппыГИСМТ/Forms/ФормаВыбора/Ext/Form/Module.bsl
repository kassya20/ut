#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Если Параметры.Свойство("АвтоТест") Тогда // Возврат при получении формы для анализа.
		Возврат;
	КонецЕсли;
	
	ОбработатьВходящиеПараметры();
	
	ОбщегоНазначенияСобытияФормИСПереопределяемый.ПриСозданииНаСервере(ЭтотОбъект, Отказ, СтандартнаяОбработка);
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	Если ИмяСобытия = "Запись_ТоварныеГруппыГИСМТ" Тогда
		Элементы.Список.Обновить();
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура ОбработатьВходящиеПараметры()
	
	Если ЗначениеЗаполнено(Параметры.ЭлементКонструктора) Тогда
		Список.ПроизвольныйЗапрос = Истина;
		Список.ТекстЗапроса = Справочники.ТоварныеГруппыГИСМТ.ТекстЗапросаТоварныхГруппСОтборомПоЭлементуКонструктора();
		
		ОбщегоНазначенияКлиентСервер.УстановитьПараметрДинамическогоСписка(
			Список, "ЭлементКонструктораДляОпределенияДоступныхВидовПродукции", Параметры.ЭлементКонструктора);
		
	ИначеЕсли ЗначениеЗаполнено(Параметры.ТоварныеГруппы) Тогда
		
		ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(
			Список, "Ссылка", Параметры.ТоварныеГруппы,,, Истина);
			
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти
