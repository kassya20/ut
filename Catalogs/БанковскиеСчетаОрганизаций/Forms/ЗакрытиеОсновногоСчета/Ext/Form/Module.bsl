
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Организация = Параметры.Организация;
	ЗакрываемыйСчет = Параметры.БанковскийСчет;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура УстановитьОсновнымДругойСчетПриИзменении(Элемент)
	УстановитьДоступностьОсновногоБанковскогоСчета();
КонецПроцедуры

&НаКлиенте
Процедура ЗакрытьСчетПриИзменении(Элемент)
	УстановитьДоступностьОсновногоБанковскогоСчета();
КонецПроцедуры

&НаКлиенте
Процедура ОчиститьОсновнойСчетПриИзменении(Элемент)
	УстановитьДоступностьОсновногоБанковскогоСчета();
КонецПроцедуры

&НаКлиенте
Процедура ОсновнойБанковскийСчетАвтоПодбор(Элемент, Текст, ДанныеВыбора, ПараметрыПолученияДанных, Ожидание, СтандартнаяОбработка)
	СтандартнаяОбработка = Ложь;
	ДанныеВыбора = БанковскиеСчетаДляВыбора(Организация, ЗакрываемыйСчет, Текст);
КонецПроцедуры

&НаКлиенте
Процедура ОсновнойБанковскийСчетНачалоВыбора(Элемент, ДанныеВыбора, ВыборДобавлением, СтандартнаяОбработка)
	СтандартнаяОбработка = Ложь;
	ДанныеВыбора = БанковскиеСчетаДляВыбора(Организация, ЗакрываемыйСчет);
КонецПроцедуры

&НаКлиенте
Процедура ОсновнойБанковскийСчетОкончаниеВводаТекста(Элемент, Текст, ДанныеВыбора, ПараметрыПолученияДанных, СтандартнаяОбработка)
	СтандартнаяОбработка = Ложь;
	ДанныеВыбора = БанковскиеСчетаДляВыбора(Организация, ЗакрываемыйСчет, Текст);
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура КомандаОК(Команда)
	
	ОчиститьСообщения();
	
	БанковскийСчет = Неопределено;
	Если ДействиеСОсновнымСчетом = 0 Тогда // установить основным другой счет
		Если ЗначениеЗаполнено(ОсновнойБанковскийСчет) Тогда
			БанковскийСчет = ОсновнойБанковскийСчет;
		Иначе
			ЗаголовокПоля = Элементы.ОсновнойБанковскийСчет.Заголовок;
			ТекстСообщения = ОбщегоНазначенияКлиентСервер.ТекстОшибкиЗаполнения(, , ЗаголовокПоля);
			ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения, , Элементы.ОсновнойБанковскийСчет.Имя);
			Возврат;
		КонецЕсли;
	ИначеЕсли ДействиеСОсновнымСчетом = 1 Тогда // очистить основной счет
		БанковскийСчет = ПредопределенноеЗначение("Справочник.БанковскиеСчетаОрганизаций.ПустаяСсылка");
	КонецЕсли;
	
	Если БанковскийСчет <> Неопределено Тогда
		УстановитьОсновнойБанковскийСчет(Организация, БанковскийСчет);
		Оповестить("Запись_Организации", БанковскийСчет, Организация);
	КонецЕсли;
	
	Закрыть(КодВозвратаДиалога.ОК);
	
КонецПроцедуры

&НаКлиенте
Процедура КомандаОтмена(Команда)
	
	Закрыть(КодВозвратаДиалога.Отмена);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Процедура УстановитьДоступностьОсновногоБанковскогоСчета()
	
	СчетДоступен = ДействиеСОсновнымСчетом = 0;
	Элементы.ОсновнойБанковскийСчет.АвтоОтметкаНезаполненного = СчетДоступен;
	Элементы.ОсновнойБанковскийСчет.Доступность = СчетДоступен;
	
КонецПроцедуры

&НаСервереБезКонтекста
Процедура УстановитьОсновнойБанковскийСчет(Знач Организация, Знач БанковскийСчет)
	
	Справочники.Организации.УстановитьОсновнойБанковскийСчет(Организация, БанковскийСчет);
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция БанковскиеСчетаДляВыбора(Знач Организация, Знач ЗакрываемыйСчет, Знач СтрокаПоиска = "")
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Владелец", Организация);
	Запрос.УстановитьПараметр("Ссылка", ЗакрываемыйСчет);
	Запрос.Текст =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	Данные.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.БанковскиеСчетаОрганизаций КАК Данные
	|ГДЕ
	|	Данные.Владелец = &Владелец
	|	И Данные.Ссылка <> &Ссылка
	|	И НЕ Данные.ПометкаУдаления
	|	И НЕ Данные.Закрыт
	|	И &УсловиеПоискаПоСтроке
	|
	|УПОРЯДОЧИТЬ ПО
	|	Данные.Наименование
	|АВТОУПОРЯДОЧИВАНИЕ";
	
	Если ПустаяСтрока(СтрокаПоиска) Тогда
		УсловиеПоискаПоСтроке = "ИСТИНА";
	Иначе
		УсловиеПоискаПоСтроке = "Данные.Наименование ПОДОБНО &СтрокаПоиска";
	КонецЕсли;
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеПоискаПоСтроке", УсловиеПоискаПоСтроке);
	Запрос.УстановитьПараметр("СтрокаПоиска", СтрокаПоиска + "%");
	
	ДанныеВыбора = Новый СписокЗначений;
	ДанныеВыбора.ЗагрузитьЗначения(Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Ссылка"));
	
	Возврат ДанныеВыбора;
	
КонецФункции

#КонецОбласти
