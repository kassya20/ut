#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Если Не ЗначениеЗаполнено(Объект.Ссылка) Тогда
		ВызватьИсключение НСтр("ru = 'Создание объекта через форму элемента запрещено.'");
	КонецЕсли;
	
	НастройкаПодключенияДоступна = ПлатежныеСистемы.НастройкаПодключенияДоступна();
	
	Элементы.ГруппаНастройкиПодключения.ТолькоПросмотр = Не НастройкаПодключенияДоступна;
	Элементы.ГруппаНастройкиОплаты.ТолькоПросмотр = Не НастройкаПодключенияДоступна;
	
	ПлатежныеСистемыСлужебный.ДобавитьНастройкиАутентификации(
		ЭтотОбъект,
		Элементы.ГруппаНастройкиПодключения,
		Объект.ПлатежнаяСистема,
		Объект.Ссылка);
	
	ПлатежныеСистемыСлужебный.ДобавитьНастройкиОплаты(
		ЭтотОбъект,
		Элементы.ГруппаНастройкиОплаты,
		Объект.ПлатежнаяСистема,
		Объект.Ссылка);
	
	ПлатежныеСистемыСлужебный.НастроитьЭлементыФормыПодключения(
		ЭтотОбъект,
		Объект.ПлатежнаяСистема,
		Объект.Ссылка);
	
	ЗаполнитьДекорацияНастройкиШаблонов();
	
КонецПроцедуры

&НаСервере
Процедура ПриЧтенииНаСервере(ТекущийОбъект)
	
	Если Настройки <> Неопределено Тогда
		ПлатежныеСистемыСлужебный.ЗаполнитьНастройкиАутентификации(ЭтотОбъект, Объект.Ссылка);
		ПлатежныеСистемыСлужебный.ЗаполнитьНастройкиОплаты(ЭтотОбъект, Объект.Ссылка, Объект.ПлатежнаяСистема);
	КонецЕсли;
	
	Заголовок = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
		НСтр("ru = 'Настройка подключения (%1)'"),
		Строка(ТекущийОбъект.ПлатежнаяСистема));
	
КонецПроцедуры

&НаСервере
Процедура ОбработкаПроверкиЗаполненияНаСервере(Отказ, ПроверяемыеРеквизиты)
	
	ПлатежныеСистемыСлужебный.ПроверитьДанныеАутентификации(ЭтотОбъект, Отказ);
	ПлатежныеСистемыСлужебный.ПроверитьНастройкиОплаты(ЭтотОбъект, Отказ);
	
КонецПроцедуры

&НаСервере
Процедура ПередЗаписьюНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	
	ОбновитьТокен = ОбновитьТокенОнлайнЗаказы(ТекущийОбъект, Отказ);
	
КонецПроцедуры

&НаСервере
Процедура ПриЗаписиНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	
	НастройкиОплаты = ПлатежныеСистемыСлужебный.НастройкиОплатыПоДаннымФормы(ЭтотОбъект);
	
	// Сохранение прикладных настроек
	РезультатСохранения = ПлатежныеСистемыСлужебный.ЗаписатьНастройкиОплаты(
		НастройкиОплаты,
		ТекущийОбъект.Ссылка,
		ТекущийОбъект.ПлатежнаяСистема);
	Если РезультатСохранения.Отказ Тогда
		ОбщегоНазначения.СообщитьПользователю(
			РезультатСохранения.СообщениеОбОшибке,
			,
			,
			,
			Отказ);
		Возврат;
	КонецЕсли;
	
	// Сохранение данных аутентификации.
	НастройкиАутентификации = ПлатежныеСистемыСлужебный.НастройкиАутентификацииПоДаннымФормы(
		ЭтотОбъект);
	
	ПараметрыАутентификацииИзменены = Ложь;
	ПлатежныеСистемыСлужебный.СохранитьНастройкиАутентификации(
		ТекущийОбъект.Ссылка,
		НастройкиАутентификации,
		ПараметрыАутентификацииИзменены);
	
	Если ПараметрыАутентификацииИзменены Тогда
		ОбновитьТокен = Истина;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ПослеЗаписиНаСервере(ТекущийОбъект, ПараметрыЗаписи)
	
	Если ОбновитьТокен Тогда
		Если ОбщегоНазначения.ПодсистемаСуществует("ИнтернетПоддержкаПользователей.ОнлайнЗаказы") Тогда
			МодульОнлайнЗаказыСлужебный = ОбщегоНазначения.ОбщийМодуль("ОнлайнЗаказыСлужебный");
			ОбновитьТокен = МодульОнлайнЗаказыСлужебный.СуществуютНастройкиПоНастройкеОплаты(
				ТекущийОбъект.Ссылка);
		Иначе
			ОбновитьТокен = Ложь;
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПослеЗаписи(ПараметрыЗаписи)
	
	ДополнительныеПараметры = Новый Структура;
	ДополнительныеПараметры.Вставить("ЗакрытьПослеЗаписи", Ложь);
	ЗаполнитьЗначенияСвойств(ДополнительныеПараметры, ПараметрыЗаписи);
	
	Если ОбновитьТокен Тогда
		Если ОбщегоНазначенияКлиент.ПодсистемаСуществует("ИнтернетПоддержкаПользователей.ОнлайнЗаказы") Тогда
			МодульОнлайнЗаказыКлиент = ОбщегоНазначенияКлиент.ОбщийМодуль("ОнлайнЗаказыКлиент");
			МодульОнлайнЗаказыКлиент.ПоказатьВопросОбновленияНастроекПодключенияПоНастройкеОплаты(
				Объект.Ссылка,
				ЭтотОбъект,
				ДополнительныеПараметры.ЗакрытьПослеЗаписи);
			КонецЕсли;
	ИначеЕсли ДополнительныеПараметры.ЗакрытьПослеЗаписи Тогда
		Закрыть(Истина);
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура ДекорацияНастройкиШаблоновОбработкаНавигационнойСсылки(
		Элемент,
		НавигационнаяСсылкаФорматированнойСтроки,
		СтандартнаяОбработка)
		
	Если НавигационнаяСсылкаФорматированнойСтроки <> "open:paymentPurpose" Тогда
		Возврат;
	КонецЕсли;
	
	СтандартнаяОбработка = Ложь;
	
	Если Модифицированность Тогда
		ОбщегоНазначенияКлиент.СообщитьПользователю(
			НСтр("ru = 'Перед настройкой шаблонов назначения необходимо записать изменения.'"));
		Возврат;
	КонецЕсли;
	
	Если Не Объект.Используется Тогда
		ОбщегоНазначенияКлиент.СообщитьПользователю(
			НСтр("ru = 'Для отключенной настройки подключения недоступно изменение шаблонов назначения.'"));
		Возврат;
	КонецЕсли;
	
	ОписаниеОповещения = Новый ОписаниеОповещения(
		"ДекорацияНастройкиШаблоновЗавершение",
		ЭтотОбъект);
	
	НастройкиПлатежныхСистемКлиент.ОткрытьНастройкуШаблоновНазначения(
		Объект.Ссылка,
		ЭтотОбъект,
		ОписаниеОповещения);
		
КонецПроцедуры

&НаКлиенте
Процедура Подключаемый_ПриИзмененииДанныхАутентификации(Элемент)
	
	ЭтотОбъект[Элемент.Имя] = НастройкиПлатежныхСистемКлиентСервер.УдалитьНечитаемыеСимволы(ЭтотОбъект[Элемент.Имя]);
	
КонецПроцедуры

&НаКлиенте
Процедура Подключаемый_ПриИзмененииСекретныхДанных(Элемент)
	
	ЭтотОбъект[Элемент.Имя] = НастройкиПлатежныхСистемКлиентСервер.УдалитьНечитаемыеСимволы(
		ЭтотОбъект[Элемент.Имя]);
	ИнтернетПоддержкаПользователейКлиент.ПриИзмененииСекретныхДанных(
		Элемент);
	
КонецПроцедуры

&НаКлиенте
Процедура Подключаемый_НачалоВыбораСекретныхДанных(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	ИнтернетПоддержкаПользователейКлиент.ОтобразитьСекретныеДанные(
		ЭтотОбъект,
		Элемент,
		Элемент.Имя);
	
КонецПроцедуры

&НаКлиенте
Процедура Подключаемый_ПриИзмененииНастройкиОплаты(Элемент)
	
	ПриИзмененииНастройкиОплатыНаСервере();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура ПроверитьПодключение(Команда)
	
	Если Модифицированность Тогда
		ОбщегоНазначенияКлиент.СообщитьПользователю(
			НСтр("ru = 'Перед проверкой настроек необходимо записать изменения.'"));
	Иначе
		
		РезультатПроверки = ПроверитьПодключениеПлатежнойСистемы();
		Если РезультатПроверки.Статус = "Выполнено"
			Или РезультатПроверки.Статус = "Ошибка" Тогда
			
			ПроверитьПодключениеПлатежнойСистемыЗавершение(РезультатПроверки, Неопределено);
			
		Иначе
			
			ОповещениеОЗавершении = Новый ОписаниеОповещения(
				"ПроверитьПодключениеПлатежнойСистемыЗавершение",
				ЭтотОбъект);
			
			ПараметрыОжидания = ДлительныеОперацииКлиент.ПараметрыОжидания(ЭтотОбъект);
			ПараметрыОжидания.ВыводитьОкноОжидания = Истина;
			ПараметрыОжидания.ТекстСообщения       =
				НСтр("ru = 'Проверка параметров подключения к платежной системе.'");
			
			ДлительныеОперацииКлиент.ОжидатьЗавершение(РезультатПроверки, ОповещениеОЗавершении, ПараметрыОжидания);
			
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаписатьИЗакрыть(Команда)
	
	Записать(Новый Структура("ЗакрытьПослеЗаписи", Истина));

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура ПриИзмененииНастройкиОплатыНаСервере()
	
	ПлатежныеСистемыСлужебный.НастроитьЭлементыФормыПодключения(
		ЭтотОбъект,
		Объект.ПлатежнаяСистема,
		Объект.Ссылка);
	
КонецПроцедуры

&НаСервере
Функция ПроверитьПодключениеПлатежнойСистемы()
	
	ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияВФоне(УникальныйИдентификатор);
	ПараметрыВыполнения.НаименованиеФоновогоЗадания =
		НСтр("ru = 'Проверка параметров подключения к платежной системе.'");
	
	Возврат ДлительныеОперации.ВыполнитьФункцию(
		ПараметрыВыполнения,
		"ПлатежныеСистемыСлужебный.ПроверитьПараметрыПодключения",
		Объект.Ссылка,
		Объект.ПлатежнаяСистема);
	
КонецФункции

&НаКлиенте
Процедура ПроверитьПодключениеПлатежнойСистемыЗавершение(
		Результат,
		ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	ИначеЕсли Результат.Статус = "Выполнено" Тогда
		
		РезультатОперации = ПолучитьИзВременногоХранилища(Результат.АдресРезультата);
		Если ЗначениеЗаполнено(РезультатОперации.КодОшибки) Тогда
			ПоказатьПредупреждение(, РезультатОперации.СообщениеОбОшибке);
		Иначе
			ПоказатьПредупреждение(, НСтр("ru = 'Подключение завершено успешно.'"));
		КонецЕсли;
		
		УдалитьИзВременногоХранилища(Результат.АдресРезультата);
		
	ИначеЕсли Результат.Статус = "Ошибка" Тогда
		ПоказатьПредупреждение(, Результат.КраткоеПредставлениеОшибки);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ДекорацияНастройкиШаблоновЗавершение(
		Результат,
		ДополнительныеПараметры) Экспорт
	
	НастройкиПлатежныхСистемКлиент.ОбновитьТекстНастройкиШаблонов(
		Результат,
		Элементы.ДекорацияНастройкиШаблонов);
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьДекорацияНастройкиШаблонов()
	
	ПредопределенныеШаблоны = ПлатежныеСистемыСлужебный.НастройкиПодключения(
		Объект.ПлатежнаяСистема).ШаблоныНазначений;
	
	НастройкиПлатежныхСистемСлужебный.ЗаполнитьДекорациюНастройкиШаблонов(
		ПредопределенныеШаблоны,
		Элементы.ДекорацияНастройкиШаблонов,
		Объект.Ссылка);
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ОбновитьТокенОнлайнЗаказы(ТекущийОбъект, Отказ)

	Если Не ОбщегоНазначения.ПодсистемаСуществует("ИнтернетПоддержкаПользователей.ОнлайнЗаказы") Тогда
		Возврат Ложь;
	КонецЕсли;
	
	ЗначенияРеквизитов = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(
		ТекущийОбъект.Ссылка,
		"Используется");
		
	ОбновитьТокен = Ложь;
	
	Если ЗначениеЗаполнено(ТекущийОбъект.Ссылка)
		И ЗначенияРеквизитов.Используется <> ТекущийОбъект.Используется Тогда
		
		ОбновитьТокен = Истина;
		РезультатОперации = ПлатежныеСистемыСлужебный.НовыйРезультатОперации();
		РезультатОперации.Вставить("Ошибка", Ложь);
		
		МодульОнлайнЗаказыСобытия = ОбщегоНазначения.ОбщийМодуль("ОнлайнЗаказыСобытия");

		ИдентификаторПоСпособу = ПлатежныеСистемыСлужебный.ИдентификаторСпособаОплатыОнлайнЗаказов(
			ТекущийОбъект.ПлатежнаяСистема);
		
		МодульОнлайнЗаказыСобытия.ПриИзмененииИспользованияНастройкиОплаты(
			ТекущийОбъект.Ссылка,
			ТекущийОбъект.Используется,
			ИдентификаторПоСпособу,
			Ложь,
			РезультатОперации);
		
		Если РезультатОперации.Ошибка Тогда
			Отказ = Истина;
			ОбщегоНазначения.СообщитьПользователю(РезультатОперации.СообщениеОбОшибке);
			Возврат Ложь;
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат ОбновитьТокен;
	
КонецФункции

#КонецОбласти