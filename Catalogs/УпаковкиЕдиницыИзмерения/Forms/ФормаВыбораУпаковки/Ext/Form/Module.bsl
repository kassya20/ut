
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	// Пропускаем инициализацию, чтобы гарантировать получение формы при передаче параметра "АвтоТест".
	Если Параметры.Свойство("АвтоТест") Тогда
		Возврат;
	КонецЕсли;
	Номенклатура = Неопределено;
	Если Параметры.Свойство("Номенклатура", Номенклатура) Тогда
		
		Если Номенклатура.НаборУпаковок = Справочники.НаборыУпаковок.ИндивидуальныйДляНоменклатуры Тогда
			ВладелецДляОтбора = Номенклатура;
		Иначе
			ВладелецДляОтбора = Номенклатура.НаборУпаковок;
		КонецЕсли;
		
#Если Не МобильныйАвтономныйСервер Тогда
		ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(Список,
																			"Владелец",
																			ВладелецДляОтбора,
																			ВидСравненияКомпоновкиДанных.Равно,
																			,
																			Истина);
#Иначе
		МобильноеРабочееМестоКладовщикаКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(Список,
																			"Владелец",
																			ВладелецДляОтбора,
																			ВидСравненияКомпоновкиДанных.Равно,
																			,
																			Истина);
#КонецЕсли
	КонецЕсли;
	
	Если Параметры.Свойство("Ссылка") Тогда
		
		ПараметрыСсылка = Параметры["Ссылка"]; // СправочникСсылка.ПодключаемоеОборудование
		
#Если Не МобильныйАвтономныйСервер Тогда
		ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(Список,
																			"Ссылка",
																			ПараметрыСсылка,
																			ВидСравненияКомпоновкиДанных.НеРавно,
																			,
																			Истина);
#Иначе
		МобильноеРабочееМестоКладовщикаКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(Список,
																			"Ссылка",
																			ПараметрыСсылка,
																			ВидСравненияКомпоновкиДанных.НеРавно,
																			,
																			Истина);
#КонецЕсли
		
	КонецЕсли;
	// СтандартныеПодсистемы.БазоваяФункциональность
#Если Не МобильныйАвтономныйСервер Тогда
	МультиязычностьСервер.ПриСозданииНаСервере(ЭтотОбъект);
#КонецЕсли
	// Конец СтандартныеПодсистемы.БазоваяФункциональность	
КонецПроцедуры

#КонецОбласти
