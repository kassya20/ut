#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ОбработчикиСобытий

Процедура ПередЗаписью(Отказ)
	
	Если ОбменДанными.Загрузка Тогда
		Возврат;
	КонецЕсли;

	Если Не ПометкаУдаления Тогда

		Запрос = Новый Запрос;
		Запрос.Текст =
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	УчетныеЗаписиЭТП.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.УчетныеЗаписиЭлектронныхТорговыхПлощадок КАК УчетныеЗаписиЭТП
		|ГДЕ
		|	УчетныеЗаписиЭТП.Ссылка <> &Ссылка
		|	И УчетныеЗаписиЭТП.ВидЭТП = &ВидЭТП
		|	И УчетныеЗаписиЭТП.Сервер = &Сервер
		|	И УчетныеЗаписиЭТП.Организация = &Организация
		|	И НЕ УчетныеЗаписиЭТП.ПометкаУдаления";

		Запрос.УстановитьПараметр("Организация", Организация);
		Запрос.УстановитьПараметр("Сервер", Сервер);
		Запрос.УстановитьПараметр("ВидЭТП", ВидЭТП);
		Запрос.УстановитьПараметр("Ссылка", Ссылка);

		УстановитьПривилегированныйРежим(Истина);
		РезультатЗапроса = Запрос.Выполнить();
		УстановитьПривилегированныйРежим(Ложь);

		Если Не РезультатЗапроса.Пустой() Тогда

			ТекстОшибки = НСтр(
				"ru='Для организации ""%1"" уже существует активная учетная запись. Создание новой учетной записи невозможно.'");
			ОбщегоНазначения.СообщитьПользователю(СтрШаблон(ТекстОшибки, Строка(Организация)), , , , Отказ);

		КонецЕсли;
	КонецЕсли;
	
	// Заполнение наименования
	ИменаСерверов = ИнтеграцияСЭлектроннымиТорговымиПлощадкамиКлиентСервер.ИменаСерверовБидзаар();
	ЭлементСписка = ИменаСерверов.НайтиПоЗначению(Сервер);
	Если ЭлементСписка <> Неопределено Тогда
		ПредставлениеСервера = ЭлементСписка.Представление;
	Иначе
		ПредставлениеСервера = НСтр("ru = 'Рабочий'");
	КонецЕсли;
	Наименование = СтрШаблон("%1 (%2)", Строка(Организация), ПредставлениеСервера);

КонецПроцедуры

Процедура ПриЗаписи(Отказ)
	
	Если ВидЭТП = Перечисления.ВидыЭлектронныхТорговыхПлощадок.БидзаарПоставщики Или
		ВидЭТП = Перечисления.ВидыЭлектронныхТорговыхПлощадок.БидзаарПокупатели Тогда
		
		ИнтеграцияСЭлектроннымиТорговымиПлощадками.ОчиститьТокены(ВидЭТП, Ссылка);
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#КонецЕсли