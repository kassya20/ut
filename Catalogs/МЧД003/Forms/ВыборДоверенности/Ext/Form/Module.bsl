// @strict-types

#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	СертификатЭлектроннойПодписи = Параметры.СертификатОрганизации;
	
	ДоверенностиОрганизации = Параметры.ДоверенностиОрганизации;
	ЗаполнитьСписокВыбораДляВыбораДоверенности(ДоверенностиОрганизации.Доверенности);
	
	КоличествоНаборовДанных = Параметры.КоличествоНаборовДанных;
	КоличествоСообщенийВНабореДанных = Параметры.КоличествоСообщенийВНабореДанных;
			
	ПоказатьТекстНадписиМассовоеПодписаниеДокументов(КоличествоНаборовДанных, КоличествоСообщенийВНабореДанных);
	УстановитьТекстПоясняющейНадписи(КоличествоСообщенийВНабореДанных, ДоверенностиОрганизации.Организация);
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура ДоверенностьПриИзменении(Элемент)
	
	ПредставлениеДоверенности = "";
	
	Если ЗначениеЗаполнено(Доверенность) Тогда
		ПредставлениеДоверенности = ПолучитьПредставлениеДоверенности(Доверенность);
	КонецЕсли;
		
	Элементы.ПредставлениеДоверенности.Видимость = ЗначениеЗаполнено(Доверенность);
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура Подписать(Команда)
	
	Если ПроверитьЗаполнение() Тогда
		Закрыть(Доверенность);
	КонецЕсли;

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Заполняет список выбора для выбора доверенности.
// 
// Параметры:
//  СписокДоверенностей - Массив из ОпределяемыйТип.МашиночитаемаяДоверенность
&НаСервере
Процедура ЗаполнитьСписокВыбораДляВыбораДоверенности(СписокДоверенностей)
	
	Если ТипЗнч(СписокДоверенностей) = Тип("Массив") Тогда
		Элементы.Доверенность.СписокВыбора.ЗагрузитьЗначения(СписокДоверенностей);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ПоказатьТекстНадписиМассовоеПодписаниеДокументов(КоличествоНаборовДанных, КоличествоСообщенийВНабореДанных)

	Показывать = КоличествоНаборовДанных > 1 Или КоличествоСообщенийВНабореДанных > 1;
	
	Элементы.НадписьМассовоеПодписаниеШапка.Видимость = Показывать;
	
КонецПроцедуры

// Устанавливает текст поясняющей надписи в шапке формы.
// 
// Параметры:
//  КоличествоСообщенийВНабореДанных - Число
//  Организация - ОпределяемыйТип.Организация
&НаСервере
Процедура УстановитьТекстПоясняющейНадписи(КоличествоСообщенийВНабореДанных, Организация)
	
	ШаблонТекста = Элементы.НадписьИнформацияШапка.Заголовок;
	Элементы.НадписьИнформацияШапка.Заголовок = 
		СтрШаблон(ШаблонТекста, КоличествоСообщенийВНабореДанных, Организация);
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ПолучитьПредставлениеДоверенности(Знач Доверенность)
	
	Возврат МашиночитаемыеДоверенности.ПолучитьПредставлениеДоверенностиМногострочныйТекст(Доверенность);
		
КонецФункции

#КонецОбласти
