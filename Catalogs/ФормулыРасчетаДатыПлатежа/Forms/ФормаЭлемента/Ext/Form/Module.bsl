#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	// СтандартныеПодсистемы.ПодключаемыеКоманды
	ПодключаемыеКоманды.ПриСозданииНаСервере(ЭтотОбъект);
	// Конец СтандартныеПодсистемы.ПодключаемыеКоманды
	
	СобытияФорм.ПриСозданииНаСервере(ЭтотОбъект, Отказ, СтандартнаяОбработка);
	
	Элементы.РедактироватьФормулу.Доступность = ПравоДоступа("Редактирование",Метаданные.Справочники.ФормулыРасчетаДатыПлатежа);
	
КонецПроцедуры

&НаСервере
Процедура ПриЧтенииНаСервере(ТекущийОбъект)
	// СтандартныеПодсистемы.ПодключаемыеКоманды
	ПодключаемыеКомандыКлиентСервер.ОбновитьКоманды(ЭтотОбъект, ЭтотОбъект.Объект);
	// Конец СтандартныеПодсистемы.ПодключаемыеКоманды
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	// СтандартныеПодсистемы.ПодключаемыеКоманды
	ПодключаемыеКомандыКлиент.НачатьОбновлениеКоманд(ЭтотОбъект);
	// Конец СтандартныеПодсистемы.ПодключаемыеКоманды
КонецПроцедуры

&НаКлиенте
Процедура ПослеЗаписи(ПараметрыЗаписи)
	ПодключаемыеКомандыКлиент.ПослеЗаписи(ЭтотОбъект, ЭтотОбъект.Объект, ПараметрыЗаписи);
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура РедактироватьФормулу(Команда)
	
	МестаИспользования = МестаИспользованияФормулы();
	Если МестаИспользования.Количество() > 0 Тогда 
		ТекстВопроса = СтрШаблон(НСтр("ru='Объектов, использующих формулу: %1. Продолжить редактирование?'"),МестаИспользования.Количество());
		ПоказатьВопрос(Новый ОписаниеОповещения("РедактироватьФормулуЗавершение", ЭтотОбъект), ТекстВопроса, РежимДиалогаВопрос.ДаНет);
	Иначе
		ПродолжитьРедактирование();
	КонецЕсли;
		
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Процедура РедактироватьФормулуЗавершение(РезультатВопроса, ДополнительныеПараметры) Экспорт
	
	Если РезультатВопроса = КодВозвратаДиалога.Да Тогда
		ПродолжитьРедактирование();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПродолжитьРедактирование()
	
	ПараметрыРедактирования = ПараметрыРедактированияФормул();
	
	ПараметрыКонструктора = Новый Структура;
	ПараметрыКонструктора.Вставить("Формула", Объект.Формула);
	ПараметрыКонструктора.Вставить("ТипРезультата", Новый ОписаниеТипов("Дата"));
	ПараметрыКонструктора.Вставить("ДеревоОперандов", ПараметрыРедактирования.ДеревоОперандов);
	ПараметрыКонструктора.Вставить("Операторы", ПараметрыРедактирования.Операторы);
	
	ОписаниеОповещения = Новый ОписаниеОповещения("ИзменениеФормулыЗавершение", ЭтотОбъект);
	
	ОткрытьФорму(
		"ОбщаяФорма.КонструкторФормул",
		ПараметрыКонструктора,
		ЭтотОбъект,
		,
		,
		,
		ОписаниеОповещения,
		РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	
КонецПроцедуры

&НаКлиенте
Процедура ИзменениеФормулыЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат <> Неопределено Тогда
		Результат = СокрЛП(Результат);
		Если Объект.Формула <> Результат Тогда
			Модифицированность = Истина;
			Объект.Формула = Результат;
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция ПараметрыРедактированияФормул()
	ПараметрыРедактирования = Новый Структура;
	
	ДеревоОперандовДляФормулы = ЭтапыОплатыСервер.ДеревоОперандовДляФормулы();
	АдресХраненияДеревоОперандов = ПоместитьВоВременноеХранилище(ДеревоОперандовДляФормулы, Новый УникальныйИдентификатор);
	ПараметрыРедактирования.Вставить("ДеревоОперандов",АдресХраненияДеревоОперандов);
	
	ПараметрыОператоров = Новый Структура;
	ПараметрыОператоров.Вставить("СтандартныеОператоры",Истина);
	ПараметрыОператоров.Вставить("ЛогическиеОператоры",Истина);
	ПараметрыОператоров.Вставить("Функции",Истина);
	
	АдресХраненияОператоры = РаботаСФормулами.ПостроитьДеревоОператоров(ПараметрыОператоров, Новый УникальныйИдентификатор);
	ПараметрыРедактирования.Вставить("Операторы",АдресХраненияОператоры);
	
	Возврат ПараметрыРедактирования
	
КонецФункции

&НаСервере
Функция МестаИспользованияФормулы()
	
	Если НЕ ЗначениеЗаполнено(Объект.Ссылка) Тогда
		Возврат Новый Массив;
	КонецЕсли;
	
	Возврат КритерииОтбора.ИспользованиеФормул.Найти(Объект.Ссылка);
	
КонецФункции

// СтандартныеПодсистемы.ПодключаемыеКоманды
&НаКлиенте
Процедура Подключаемый_ВыполнитьКоманду(Команда)
	ПодключаемыеКомандыКлиент.НачатьВыполнениеКоманды(ЭтотОбъект, Команда, ЭтотОбъект.Объект);
КонецПроцедуры

&НаКлиенте
Процедура Подключаемый_ПродолжитьВыполнениеКомандыНаСервере(ПараметрыВыполнения, ДополнительныеПараметры) Экспорт
	ВыполнитьКомандуНаСервере(ПараметрыВыполнения);
КонецПроцедуры

&НаСервере
Процедура ВыполнитьКомандуНаСервере(ПараметрыВыполнения)
	ПодключаемыеКоманды.ВыполнитьКоманду(ЭтотОбъект, ПараметрыВыполнения, ЭтотОбъект.Объект);
КонецПроцедуры

&НаКлиенте
Процедура Подключаемый_ОбновитьКоманды()
	ПодключаемыеКомандыКлиентСервер.ОбновитьКоманды(ЭтотОбъект, ЭтотОбъект.Объект);
КонецПроцедуры
// Конец СтандартныеПодсистемы.ПодключаемыеКоманды

#КонецОбласти
