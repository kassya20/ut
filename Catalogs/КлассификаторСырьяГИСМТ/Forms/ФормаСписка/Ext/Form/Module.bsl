
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	УстановитьУсловноеОформление();
	
	Если Параметры.Свойство("АвтоТест") Тогда // Возврат при получении формы для анализа.
		Возврат;
	КонецЕсли;
	
	Элементы.Список.РежимВыбора = Параметры.РежимВыбора;
	Элементы.ЗагрузитьПоОстаткам.Видимость = Не Параметры.РежимВыбора;
	
	Если ЗначениеЗаполнено(Параметры.ВидПродукцииИС) Тогда
		
		ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(
			Список, "ВидПродукции", Параметры.ВидПродукцииИС,,, Истина);
			
	КонецЕсли;
	
	ОбщегоНазначенияСобытияФормИСПереопределяемый.ПриСозданииНаСервере(ЭтотОбъект, Отказ, СтандартнаяОбработка);
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура ЗагрузитьПоОстаткам(Команда)
	
	ОчиститьСообщения();
	ЗагрузитьСырьеПоОстаткамНаКлиенте();
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура УстановитьУсловноеОформление()
	
	УсловноеОформление.Элементы.Очистить();
	
КонецПроцедуры

&НаСервере
Функция ЗагрузитьСписокИзГИСМТНаСервере(Организация)
	
	Результат = ИнтеграцияИСМПСлужебный.СырьеПоОстаткамНаСкладе(Организация);
	
	Если Результат.ТребуетсяОбновлениеКлючаСессии Тогда
		Возврат Истина;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Результат.ТекстОшибки) Тогда
		ОбщегоНазначения.СообщитьПользователю(Результат.ТекстОшибки);
	ИначеЕсли Результат.Сырье.Количество() = 0 Тогда
		ОбщегоНазначения.СообщитьПользователю(СтрШаблон(
			НСтр("ru = 'По организации %1 не найдено сырья на остатках.'"),
			Строка(Организация)));
	Иначе
		Справочники.КлассификаторСырьяГИСМТ.СоздатьОбновитьСырьеПоДаннымСервиса(Результат.Сырье);
		ОбщегоНазначения.СообщитьПользователю(НСтр("ru = 'Загрузка завершена.'"));
		Элементы.Список.Обновить();
	КонецЕсли;
	
	Возврат Неопределено;
	
КонецФункции

&НаКлиенте
Процедура ЗагрузитьСырьеПоОстаткамНаКлиенте()
	
	ДоступныеОрганизации = ДоступныеОрганизации();
	Если ДоступныеОрганизации.Количество() = 0 Тогда
		ПоказатьПредупреждение(,
			НСтр("ru = 'Отсутствуют организации по которым возможно обращение в ФГИС ""Честный знак""'"));
		Возврат;
	КонецЕсли;
	
	Если ДоступныеОрганизации.Количество() > 1 Тогда
		ПараметрыОткрытияФормы = Новый Структура;
		ПараметрыОткрытияФормы.Вставить("Организации", ДоступныеОрганизации);
		ОткрытьФорму(
			"ОбщаяФорма.ФормаВыбораСпискаОрганизацийИСМП", ПараметрыОткрытияФормы,
			ЭтотОбъект, , , , Новый ОписаниеОповещения("ПослеВыбораОрганизации", ЭтотОбъект));
	Иначе
		ЗагрузитьСырьеПоОстаткамОрганизации(ДоступныеОрганизации[0]);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПослеВыбораОрганизации(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат <> Неопределено
		И Результат.Организации.Количество() Тогда
		
		Для Каждого Организация Из Результат.Организации Цикл
			ЗагрузитьСырьеПоОстаткамОрганизации(Организация);
		КонецЦикла;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ЗагрузитьСырьеПоОстаткамОрганизации(Организация, ВызовПослеАвторизации = Ложь) Экспорт
	
	ТребуетсяОбновитьКлючСессии = ЗагрузитьСписокИзГИСМТНаСервере(Организация);
	
	Если ТребуетсяОбновитьКлючСессии = Истина Тогда
		Если ВызовПослеАвторизации Тогда
			ТекстОшибки = НСтр("ru = 'Не удалось выполнить авторизацию.'");
			ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстОшибки);
		Иначе
			ЗапроситьКлючСессииНачало(Организация);
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ЗапроситьКлючСессииНачало(Организация)
	
	ДополнительныеПараметры = Новый Структура;
	ДополнительныеПараметры.Вставить("Организация", Организация);
	
	ОповещениеПриЗапросеКлючаСессии = Новый ОписаниеОповещения("ЗапроситьКлючСессииЗавершение", ЭтотОбъект, ДополнительныеПараметры);
	ПараметрыЗапроса = ИнтерфейсИСМПОбщегоНазначенияКлиентСервер.ПараметрыЗапросаКлючаСессии(Организация);
	
	ИнтерфейсАвторизацииИСМПКлиент.ЗапроситьКлючСессии(
		ПараметрыЗапроса, 
		ОповещениеПриЗапросеКлючаСессии);
	
КонецПроцедуры

&НаКлиенте
Процедура ЗапроситьКлючСессииЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	ОтказОтАвторизации = Ложь;
	ОшибкаАвторизации  = Ложь;
	
	Если ТипЗнч(Результат) <> Тип("Соответствие") Тогда
		ОтказОтАвторизации = Истина;
	Иначе
		РезультатАвторизации = Результат[ДополнительныеПараметры.Организация];
		Если РезультатАвторизации = Неопределено Тогда
			ОшибкаАвторизации = Истина;
			ТекстОшибки = НСтр("ru = 'Произошла ошибка при авторизации.'");
		ИначеЕсли РезультатАвторизации <> Истина Тогда
			ОшибкаАвторизации = Истина;
			ТекстОшибки = РезультатАвторизации;
		КонецЕсли;
	КонецЕсли;
	
	Если ОтказОтАвторизации Тогда
		Возврат;
	ИначеЕсли ОшибкаАвторизации Тогда
		ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстОшибки);
	Иначе
		ЗагрузитьСырьеПоОстаткамОрганизации(ДополнительныеПараметры.Организация, Истина);
	КонецЕсли;
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ДоступныеОрганизации()
	
	Возврат ОбщегоНазначенияИС.ДоступныеОрганизации().ВыгрузитьЗначения();
	
КонецФункции

#КонецОбласти