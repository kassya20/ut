#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Если Параметры.Свойство("АвтоТест") Тогда // Возврат при получении формы для анализа.
		Возврат;
	КонецЕсли;
	
	ОбработатьВходящиеПараметры();
	
	ОбщегоНазначенияСобытияФормИСПереопределяемый.ПриСозданииНаСервере(ЭтотОбъект, Отказ, СтандартнаяОбработка);
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	Если ИмяСобытия = "Запись_ВидыПродукцииИС" Тогда
		Элементы.Список.Обновить();
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыСписок

&НаСервереБезКонтекста
Процедура СписокПриПолученииДанныхНаСервере(ИмяЭлемента, Настройки, Строки)
	
	Если Не ОбщегоНазначенияИС.ПодсистемаСуществует("ИСМП") Тогда
		Возврат;
	КонецЕсли;
	
	МодульКонструкторИСМПОбщегоНазначенияКлиентСервер = ОбщегоНазначенияИСПовтИсп.ОбщийМодуль("КонструкторИСМПОбщегоНазначенияКлиентСервер");
	
	Для каждого Строка Из Строки Цикл
		
		ДанныеСтроки = Строка.Значение.Данные;
		
		Если Не ДанныеСтроки.Свойство("Наименование") Тогда
			Продолжить;
		КонецЕсли;
		
		Оформление = Строка.Значение.Оформление["Наименование"];
		Если Оформление <> Неопределено Тогда
			Оформление.УстановитьЗначениеПараметра(
				"Текст",
				МодульКонструкторИСМПОбщегоНазначенияКлиентСервер.ПредставлениеТоварнойКатегории(
					ДанныеСтроки.Ссылка, ДанныеСтроки.Наименование));
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура ОбработатьВходящиеПараметры()
	
	Если ЗначениеЗаполнено(Параметры.ОтборПоПодсистеме) Тогда
		Список.ПроизвольныйЗапрос = Истина;
		Если Параметры.ТолькоВыключенные Тогда
			ИмяПараметраЭлементКонструктораДляОпределенияДоступныхВидовПродукции = "ЭлементКонструктораДляОпределенияДоступныхВидовПродукции";
			Список.ТекстЗапроса = Справочники.ВидыПродукцииИС.ТекстЗапросаВыключенныхВидовПродукцииСОтборомПоЭлементуКонструктора(
				ИмяПараметраЭлементКонструктораДляОпределенияДоступныхВидовПродукции,
				Параметры.ОтборПоПодсистеме,,
				Ложь);
			Список.Параметры.УстановитьЗначениеПараметра(
				ИмяПараметраЭлементКонструктораДляОпределенияДоступныхВидовПродукции,
				Параметры.ЭлементКонструктораДляОпределенияДоступныхВидовПродукции);
		Иначе
			Список.ТекстЗапроса = Справочники.ВидыПродукцииИС.ТекстЗапросаВидовПродукцииСОтборомПоПодсистеме(Параметры.ОтборПоПодсистеме);
		КонецЕсли;
		Если ОбщегоНазначенияИС.ПодсистемаСуществует("ИСМП")
			И Параметры.ОтборПоПодсистеме = "ГИСМТ" Тогда
			Заголовок     = НСтр("ru='Товарные категории'");
			АвтоЗаголовок = Ложь;
		КонецЕсли;

		Если Параметры.МножественныйВыбор <> Неопределено Тогда
			Элементы.Список.МножественныйВыбор = Параметры.МножественныйВыбор;
		КонецЕсли;

	КонецЕсли;

КонецПроцедуры

#КонецОбласти
