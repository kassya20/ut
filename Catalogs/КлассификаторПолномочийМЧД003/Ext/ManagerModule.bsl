// Возвращает данные ограничения "Вид документа ЭДО".
// 
// Возвращаемое значение:
//  Структура:
// * КодОграничения - Строка
// * НаименованиеОграничения - Строка
Функция ОграничениеВидДокументаЭДО() Экспорт
	
 	Результат = Новый Структура;
	Результат.Вставить("КодОграничения", МашиночитаемыеДоверенностиКлиентСервер.КодОграниченияВидДокументаЭДО());
	Результат.Вставить("НаименованиеОграничения", НСтр("ru = 'Вид документа ЭДО'"));
	
