КонецФункции

// Проверяет, находится ли код указанного полномочия в списке полномочий, поддерживающих ограничения
// 
// Параметры:
//  КодКлассификатора - Строка
// 
// Возвращаемое значение:
//  Булево
Функция ЭтоПолномочиеИспользуетОграничения(КодКлассификатора) Экспорт
	
	Результат = Ложь;
	
	СписокПолномочийСОграничениями = ПолучитьСписокПолномочийСОграничениями();
	Если СписокПолномочийСОграничениями.Найти(КодКлассификатора) <> Неопределено Тогда 
		Результат = Истина;
	КонецЕсли;
		
	Возврат Результат;
	
КонецФункции

// Возвращает список кодов полномочий, поддерживающих ограничения.
// 
// Возвращаемое значение:
//  Массив из Строка
Функция ПолучитьСписокПолномочийСОграничениями() Экспорт

	Результат = Новый Массив;
	Результат.Добавить(КодПолномочия_KLASS_2_0_SIGN_ELECTRONIC_DOCUMENTS());
	Результат.Добавить(КодПолномочия_KLASS_2_0_SIGN_DIG_DOC());
	
	Возврат Результат;
	
КонецФункции

// Контекст полномочий по кодам.
// 
// Параметры:
//  КодыПолномочий - Массив из Строка
// 
// Возвращаемое значение:
//  Соответствие из Строка
Функция КонтекстПолномочийПоКодам(КодыПолномочий) Экспорт
		
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ
		|	КлассификаторПолномочийМЧД003.КодКлассификатора КАК КодКлассификатора,
		|	КлассификаторПолномочийМЧД003.КонтекстПолномочия КАК КонтекстПолномочия
		|ИЗ
		|	Справочник.КлассификаторПолномочийМЧД003 КАК КлассификаторПолномочийМЧД003
		|ГДЕ
		|	КлассификаторПолномочийМЧД003.КодКлассификатора В (&КодыПолномочий)";
	
	Запрос.УстановитьПараметр("КодыПолномочий", КодыПолномочий);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Результат = Новый Соответствие;
	
	Если РезультатЗапроса.Пустой() Тогда
		Возврат Результат;
	КонецЕсли;
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		Результат.Вставить(ВыборкаДетальныеЗаписи.КодКлассификатора, ВыборкаДетальныеЗаписи.КонтекстПолномочия);	
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти

#КонецЕсли