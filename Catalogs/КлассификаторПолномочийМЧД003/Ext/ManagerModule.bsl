	Результат.Добавить(МашиночитаемыеДоверенностиКлиентСервер.КодОграниченияОрганВласти());
	Результат.Добавить(МашиночитаемыеДоверенностиКлиентСервер.КодОграниченияОбъект());
	Результат.Добавить(МашиночитаемыеДоверенностиКлиентСервер.КодОграниченияТипОбъекта());
