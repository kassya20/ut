// Возвращает данные полномочия KLASS_2_0_SIGN_ELECTRONIC_DOCUMENTS.
// 
// Возвращаемое значение:
//  Структура:
// * КодКлассификатора - Строка
// * Мнемоника - Строка
// * Полномочие - Строка
// * ОписаниеПолномочия - Строка
// * КонтекстПолномочия - Строка
//
Функция ПолучитьДанныеПолномочия_KLASS_2_0_SIGN_ELECTRONIC_DOCUMENTS() Экспорт 
	
	КодКлассификатора = КодПолномочия_KLASS_2_0_SIGN_ELECTRONIC_DOCUMENTS();
	
	Результат = Новый Структура;
	Результат.Вставить("КодКлассификатора", "");
	Результат.Вставить("Мнемоника", "");
	Результат.Вставить("Полномочие", "");
	Результат.Вставить("ОписаниеПолномочия", "");
	Результат.Вставить("КонтекстПолномочия", "");
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	КлассификаторПолномочийМЧД003.КодКлассификатора КАК КодКлассификатора,
	|	КлассификаторПолномочийМЧД003.Мнемоника КАК Мнемоника,
	|	КлассификаторПолномочийМЧД003.Полномочие КАК Полномочие,
	|	КлассификаторПолномочийМЧД003.ОписаниеПолномочия КАК ОписаниеПолномочия,
	|	КлассификаторПолномочийМЧД003.КонтекстПолномочия КАК КонтекстПолномочия
	|ИЗ
	|	Справочник.КлассификаторПолномочийМЧД003 КАК КлассификаторПолномочийМЧД003
	|ГДЕ
	|	КлассификаторПолномочийМЧД003.КодКлассификатора = &КодКлассификатора";
	
	Запрос.УстановитьПараметр("КодКлассификатора", КодКлассификатора);
	
	УстановитьПривилегированныйРежим(Истина);
	РезультатЗапроса = Запрос.Выполнить();
	УстановитьПривилегированныйРежим(Ложь);
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Если ВыборкаДетальныеЗаписи.Следующий() Тогда 
		ЗаполнитьЗначенияСвойств(Результат, ВыборкаДетальныеЗаписи);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Возвращает данные поддерживаемых ограничений из классификатора.
// 
// Возвращаемое значение:
//  Соответствие из КлючИЗначение:
//   * Ключ - Строка - код ограничения.
//   * Значение - Строка - наименование ограничения.
//
Функция ПолучитьДанныеПоддерживаемыхОграниченийИзКлассификатора() Экспорт
	
	КодыКлассификатора = ПоддерживаемыеКодыОграничений();
	
	Результат = Новый Соответствие;
	
	КлассификаторОграничений = РегистрыСведений.КлассификаторыОграниченийМЧД.КлассификаторОграничений();
	
	Для Каждого Элемент Из КодыКлассификатора Цикл 
		
		НайденноеОграничение = КлассификаторОграничений.Найти(Элемент, "Код");
		
		Если НайденноеОграничение <> Неопределено Тогда
			ЗначенияРеквизитов = Новый Структура;
			ЗначенияРеквизитов.Вставить("КодОграничения", НайденноеОграничение.Код);
			ЗначенияРеквизитов.Вставить("НаименованиеОграничения", НайденноеОграничение.Наименование);
		КонецЕсли;
		
		Результат.Вставить(Элемент, ЗначенияРеквизитов);
		
	КонецЦикла;
	
	Возврат Результат;

КонецФункции

