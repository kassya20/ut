// @strict-types

#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Параметры.ДополнительныеПараметры.Свойство("ПорядковыйНомер", ПорядковыйНомер);
	Параметры.ДополнительныеПараметры.Свойство("Редактирование", Редактирование);
	Параметры.ДополнительныеПараметры.Свойство("СозданиеМЧД", СозданиеМЧД);
	Параметры.ДополнительныеПараметры.Свойство("БезОграничений", БезОграничений);
	
	Если СозданиеМЧД И Не Редактирование Тогда
		ЗаполнитьТекущиеНастройкиПолномочияПоУмолчанию();
	Иначе 
		
		НастройкиТекущегоПравила = Параметры.ДополнительныеПараметры.НастройкиТекущегоПравила;
		Если НастройкиТекущегоПравила.Количество() > 0 Тогда 
			ЗаполнитьТекущиеНастройкиПолномочия(НастройкиТекущегоПравила);
		Иначе
			ЗаполнитьТекущиеНастройкиПолномочияПоУмолчанию();
		КонецЕсли;

	КонецЕсли;
	
	УправлениеФормой();
	
	ЗагрузитьНастройкиВидимостиОграниченийПоПользователю();
	
КонецПроцедуры

&НаКлиенте
Процедура ПередЗакрытием(Отказ, ЗавершениеРаботы, ТекстПредупреждения, СтандартнаяОбработка)
	
	Если Модифицированность И Не ЗавершениеРаботы Тогда
		Отказ = Истина;
		ТекстВопроса = НСтр("ru = 'Выйти без сохранения?'");
		ПоказатьВопрос(Новый ОписаниеОповещения("СпроситьОЗакрытииЗавершение", ЭтотОбъект), ТекстВопроса,
			РежимДиалогаВопрос.ДаНет);
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

