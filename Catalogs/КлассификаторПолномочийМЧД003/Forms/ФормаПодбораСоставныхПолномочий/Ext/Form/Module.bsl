			НомерОграничения = НомерОграничения + 1;
			
		КонецЦикла;
		
		Для Каждого ТекущееЗначение Из ТоварыРаботыУслуги Цикл 
			
			КодОграниченияТовары = МашиночитаемыеДоверенностиКлиентСервер.КодОграниченияТовары();
			КодОграниченияУслуги = МашиночитаемыеДоверенностиКлиентСервер.КодОграниченияУслуги();
			КодОграниченияРаботы = МашиночитаемыеДоверенностиКлиентСервер.КодОграниченияРаботы();
			
			Ограничение = ДанныеОграничений.Получить(КодОграниченияТовары);
			
			Если СтрНачинаетсяС(ТекущееЗначение.Код, КодОграниченияУслуги) Тогда
				Ограничение = ДанныеОграничений.Получить(КодОграниченияУслуги);
			ИначеЕсли СтрНачинаетсяС(ТекущееЗначение.Код, КодОграниченияРаботы) Тогда
				Ограничение = ДанныеОграничений.Получить(КодОграниченияРаботы);
			КонецЕсли;
			
			ЗначениеОграничения = Новый Структура;
			ЗначениеОграничения.Вставить("КодЗначенияОграничения", ТекущееЗначение.Код); 
			ЗначениеОграничения.Вставить("НаименованиеЗначенияОграничения" , ТекущееЗначение.Наименование);
			
			НастройкиПравила = 
				Справочники.ПравилаПроверкиПолномочийМЧД.ПолучитьНастройкиПроверкиРасширенные(ПорядковыйНомер, 
