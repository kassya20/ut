&НаКлиенте
Процедура НастройкиОграничений(Команда)
	
	СписокОтображаемыхОграничений =  Новый СписокЗначений();
	
	СписокОтображаемыхОграничений.Добавить("СтраницаВидОбязательств",
		НСтр("ru = 'Вид обязательств'"), Элементы.Найти("СтраницаВидОбязательств").Видимость);
		
	СписокОтображаемыхОграничений.Добавить("СтраницаТоварыРаботыУслуги",
		НСтр("ru = 'Товары, работы, услуги'"), Элементы.Найти("СтраницаТоварыРаботыУслуги").Видимость);
		
	СписокОтображаемыхОграничений.Добавить("СтраницаТерритория",
		НСтр("ru = 'Территория'"), Элементы.Найти("СтраницаТерритория").Видимость);
		
	СписокОтображаемыхОграничений.Добавить("СтраницаОрганВласти",
		НСтр("ru = 'Орган власти'"), Элементы.Найти("СтраницаОрганВласти").Видимость);
		
	СписокОтображаемыхОграничений.Добавить("СтраницаОбъектТипОбъекта",
		НСтр("ru = 'Объект, тип объекта'"), Элементы.Найти("СтраницаОбъектТипОбъекта").Видимость);
		
	СписокОтображаемыхОграничений.Добавить("СертификатЭлектроннойПодписиПредставителя",
		НСтр("ru = 'Сертификат ЭП представителя'"),
			Элементы.Найти("СертификатЭлектроннойПодписиПредставителя").Видимость);
		
	СписокОтображаемыхОграничений.Добавить("ФилиалДоверителя",
		НСтр("ru = 'Филиал доверителя'"), Элементы.Найти("ФилиалДоверителя").Видимость);
		
	СписокОтображаемыхОграничений.Добавить("СтраницаХарактеристикаУслугиРаботыТовара",
		НСтр("ru = 'Характеристика услуги, работы, товара'"),
			Элементы.Найти("СтраницаХарактеристикаУслугиРаботыТовара").Видимость);
	
	ОповещениеПослеОтметкиОграничений = 
		Новый ОписаниеОповещения("ПослеОтметкиОграничений", ЭтотОбъект);
	
	СписокОтображаемыхОграничений.ПоказатьОтметкуЭлементов(
		ОповещениеПослеОтметкиОграничений, НСтр("ru = 'Доступные ограничения'"));
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Извлекает серийный номер из загружаемого из файла сертификата.
// 
// Параметры:
//  ПомещенныйФайл - Неопределено
//                 - Структура:
//                   * Хранение - Строка
//                   * Имя - Строка
//  ДополнительныеПараметры - Структура
&НаКлиенте
Процедура УстановитьСерийныйНомерИзЗагружаемогоСертификатаЗавершение(ПомещенныйФайл, ДополнительныеПараметры) Экспорт
	
	Если Не ЗначениеЗаполнено(ПомещенныйФайл) Тогда
		Возврат;
	КонецЕсли;
	
	АдресСертификата = ПомещенныйФайл.Хранение;
	
	ДанныеСертификата = ПолучитьИзВременногоХранилища(АдресСертификата);
	ЭтоСертификат = ИнтеграцияБСПБЭДВызовСервера.ФайлЯвляетсяСертификатом(ДанныеСертификата);
	Если Не ЭтоСертификат Тогда
		ПоказатьПредупреждение(, НСтр("ru = 'Файл сертификата должен быть в формате DER X.509.'"));
		Возврат;
	КонецЕсли;
	
	Сертификат = Новый СертификатКриптографии(ДанныеСертификата);
	СвойстваСертификата = ЭлектроннаяПодписьКлиент.СвойстваСертификата(Сертификат);
	
	СертификатЭлектроннойПодписиПредставителя = Base64Строка(СвойстваСертификата.СерийныйНомер);
	
	Модифицированность = Истина;
	
КонецПроцедуры

&НаСервере
Процедура СохранитьНастройкиВидимостиОграниченийДляПользователя(Параметры)
	
	ПолноеИмяПользователя = ПользователиИнформационнойБазы.ТекущийПользователь().ПолноеИмя;
	
	ОбщегоНазначения.ХранилищеНастроекДанныхФормСохранить(
		ИмяФормы, "НастройкиВидимостиОграничений", Параметры, , ПолноеИмяПользователя);
		
КонецПроцедуры

&НаСервере
Процедура ЗагрузитьНастройкиВидимостиОграниченийПоПользователю()
	
	Если Не СозданиеМЧД Тогда
		Возврат;
	КонецЕсли;
	
	ПолноеИмяПользователя = ПользователиИнформационнойБазы.ТекущийПользователь().ПолноеИмя;
	
	НастройкиВидимостиОграничений = ОбщегоНазначения.ХранилищеНастроекДанныхФормЗагрузить(
		ИмяФормы, "НастройкиВидимостиОграничений", , , ПолноеИмяПользователя);
		
	Если Не НастройкиВидимостиОграничений = Неопределено Тогда
		
		Для Каждого ОтмеченныйЭлемент Из НастройкиВидимостиОграничений Цикл
			
			НайденныйЭлемент = Элементы.Найти(ОтмеченныйЭлемент.Значение);
			Если Не НайденныйЭлемент = Неопределено Тогда
				Если ОтмеченныйЭлемент.Значение = "СтраницаВидОбязательств" Тогда
					НайденныйЭлемент.Видимость = ВидОбязательств.Количество() > 0 Или ОтмеченныйЭлемент.Пометка;
				ИначеЕсли ОтмеченныйЭлемент.Значение = "СтраницаТоварыРаботыУслуги" Тогда
					НайденныйЭлемент.Видимость = ТоварыРаботыУслуги.Количество() > 0 Или ОтмеченныйЭлемент.Пометка;
				ИначеЕсли ОтмеченныйЭлемент.Значение = "СтраницаОбъектТипОбъекта" Тогда
					Элементы.СтраницаОбъектТипОбъекта.Видимость = 
						ЗначениеЗаполнено(Объект) Или ЗначениеЗаполнено(ТипОбъекта) Или ОтмеченныйЭлемент.Пометка;
				ИначеЕсли ОтмеченныйЭлемент.Значение = "СтраницаТерритория" Тогда
					НайденныйЭлемент.Видимость = Территория.Количество() > 0 Или ОтмеченныйЭлемент.Пометка;
				ИначеЕсли ОтмеченныйЭлемент.Значение = "СтраницаОрганВласти" Тогда
					НайденныйЭлемент.Видимость = ОрганВласти.Количество() > 0 Или ОтмеченныйЭлемент.Пометка;
				ИначеЕсли ОтмеченныйЭлемент.Значение = "ФилиалДоверителя" Тогда
					Элементы.ФилиалДоверителя.Видимость = ЗначениеЗаполнено(ФилиалДоверителя) Или ОтмеченныйЭлемент.Пометка;
				ИначеЕсли ОтмеченныйЭлемент.Значение = "СертификатЭлектроннойПодписиПредставителя" Тогда
					Элементы.СертификатЭлектроннойПодписиПредставителя.Видимость = 
						ЗначениеЗаполнено(СертификатЭлектроннойПодписиПредставителя) Или ОтмеченныйЭлемент.Пометка;
				ИначеЕсли ОтмеченныйЭлемент.Значение = "СтраницаХарактеристикаУслугиРаботыТовара" Тогда
					НайденныйЭлемент.Видимость = 
						ХарактеристикаУслугиРаботыТовара.Количество() > 0 Или ОтмеченныйЭлемент.Пометка;
				КонецЕсли;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПослеВыбораЗначенияОграничений(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если ДополнительныеПараметры.КодОграничения = МашиночитаемыеДоверенностиКлиентСервер.КодОграниченияТипСуммы() Тогда
		ТипСуммы.Очистить();
		ДобавитьРезультатВыбораВТаблицуОграничения(Результат, ТипСуммы);
	ИначеЕсли ДополнительныеПараметры.КодОграничения = МашиночитаемыеДоверенностиКлиентСервер.КодОграниченияТипДокумента() Тогда
		ТипДокумента.Очистить();
		ДобавитьРезультатВыбораВТаблицуОграничения(Результат, ТипДокумента);
	ИначеЕсли ДополнительныеПараметры.КодОграничения = МашиночитаемыеДоверенностиКлиентСервер.КодОграниченияТипВалюты() Тогда
		ТипВалюты.Очистить();
		ДобавитьРезультатВыбораВТаблицуОграничения(Результат, ТипВалюты);
	ИначеЕсли ДополнительныеПараметры.КодОграничения = МашиночитаемыеДоверенностиКлиентСервер.КодОграниченияВидОбязательств() Тогда
		ДобавитьРезультатВыбораВТаблицуОграничения(Результат, ВидОбязательств);
	ИначеЕсли ДополнительныеПараметры.КодОграничения = МашиночитаемыеДоверенностиКлиентСервер.КодОграниченияТовары()
		Или ДополнительныеПараметры.КодОграничения = МашиночитаемыеДоверенностиКлиентСервер.КодОграниченияРаботы() 
		Или ДополнительныеПараметры.КодОграничения = МашиночитаемыеДоверенностиКлиентСервер.КодОграниченияУслуги() Тогда
		ДобавитьРезультатВыбораВТаблицуОграничения(Результат, ТоварыРаботыУслуги);
	ИначеЕсли ДополнительныеПараметры.КодОграничения = МашиночитаемыеДоверенностиКлиентСервер.КодОграниченияТерритория() Тогда
		ДобавитьРезультатВыбораВТаблицуОграничения(Результат, Территория);
	ИначеЕсли ДополнительныеПараметры.КодОграничения = МашиночитаемыеДоверенностиКлиентСервер.КодОграниченияОрганВласти() Тогда
		ДобавитьРезультатВыбораВТаблицуОграничения(Результат, ОрганВласти);
	КонецЕсли;
	
	ОбновитьОтметкуНезаполненногоОграниченийПоСумме();
	
	Модифицированность = Истина;
	
КонецПроцедуры

&НаКлиенте
Процедура ПослеВыбораПолномочияСОграничением(Результат, ДополнительныеПараметры) Экспорт
		
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Полномочие.Очистить();
	
	УстанавливаемоеПолномочие = Полномочие.Добавить();
	УстанавливаемоеПолномочие.Код = Результат.НастройкиТекущегоПравила[0].КодПолномочия;
	УстанавливаемоеПолномочие.Наименование = Результат.НастройкиТекущегоПравила[0].НаименованиеПолномочия;
	УстанавливаемоеПолномочие.Мнемоника = Результат.НастройкиТекущегоПравила[0].МнемоникаПолномочия;
	
	Модифицированность = Истина;
	
КонецПроцедуры

&НаКлиенте
Процедура ПослеВыбораКонтрагента(ВыбранныеЭлементы, ДополнительныеПараметры) Экспорт 
	
	Если ВыбранныеЭлементы = Неопределено Тогда
		Возврат;
	КонецЕсли; 
	
	Если Не ТипЗнч(ВыбранныеЭлементы) = Тип("Массив") Тогда
		ВыбранныеЭлементы = ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(ВыбранныеЭлементы);
	КонецЕсли;
	
	ДобавитьКонтрагентов(ВыбранныеЭлементы);
	
	Модифицированность = Истина;
	
КонецПроцедуры

&НаКлиенте
Процедура ПослеОтметкиОграничений(ВыбранныеЭлементы, ДополнительныеПараметры) Экспорт
	
	Если ВыбранныеЭлементы = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Для Каждого ОтмеченныйЭлемент Из ВыбранныеЭлементы Цикл
		НайденныйЭлемент = Элементы.Найти(ОтмеченныйЭлемент.Значение);
		Если Не НайденныйЭлемент = Неопределено Тогда
			НайденныйЭлемент.Видимость = ОтмеченныйЭлемент.Пометка;
		КонецЕсли;
		
		Если Не НайденныйЭлемент.Видимость Тогда
			Если ОтмеченныйЭлемент.Значение = "СтраницаВидОбязательств" Тогда
				ВидОбязательств.Очистить();
			ИначеЕсли ОтмеченныйЭлемент.Значение = "СтраницаТоварыРаботыУслуги" Тогда
				ТоварыРаботыУслуги.Очистить();
			ИначеЕсли ОтмеченныйЭлемент.Значение = "СтраницаОбъектТипОбъекта" Тогда
				Объект = "";
				ТипОбъекта = "";
			ИначеЕсли ОтмеченныйЭлемент.Значение = "СтраницаТерритория" Тогда
				Территория.Очистить();
			ИначеЕсли ОтмеченныйЭлемент.Значение = "СтраницаОрганВласти" Тогда
				ОрганВласти.Очистить();
			ИначеЕсли ОтмеченныйЭлемент.Значение = "ФилиалДоверителя" Тогда
				ФилиалДоверителя = "";
			ИначеЕсли ОтмеченныйЭлемент.Значение = "СертификатЭлектроннойПодписиПредставителя" Тогда
				СертификатЭлектроннойПодписиПредставителя = "";
			ИначеЕсли ОтмеченныйЭлемент.Значение = "СтраницаХарактеристикаУслугиРаботыТовара" Тогда
				ХарактеристикаУслугиРаботыТовара.Очистить();
			КонецЕсли;
		КонецЕсли;
		
	КонецЦикла;
	
	СохранитьНастройкиВидимостиОграниченийДляПользователя(ВыбранныеЭлементы);
	
КонецПроцедуры

&НаКлиенте
Процедура ДобавитьРезультатВыбораВТаблицуОграничения(Результат, ТаблицаОграничения) 
	
	Для Каждого ЗначениеРезультата Из Результат Цикл
		ПараметрыОтбора = Новый Структура("Код", ЗначениеРезультата.Код);
		Если ТаблицаОграничения.НайтиСтроки(ПараметрыОтбора).Количество() > 0 Тогда
			Продолжить;
		КонецЕсли;
		СтрокаТаблицы = ТаблицаОграничения.Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаТаблицы, ЗначениеРезультата); 
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьФормуВыбораЗначенияОграничения(ПараметрыОткрытия)

	ОткрытьФорму("РегистрСведений.КлассификаторыОграниченийМЧД.Форма.ВыборЗначенияОграниченияПолномочия",
		ПараметрыОткрытия, ЭтотОбъект,,,, 
			Новый ОписаниеОповещения("ПослеВыбораЗначенияОграничений", ЭтотОбъект, ПараметрыОткрытия),
				РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
		
КонецПроцедуры

&НаСервере 
Процедура УправлениеФормой()
	
	Если Не СозданиеМЧД Тогда 
		Элементы.Полномочие.Видимость = Ложь;
		Заголовок = НСтр("ru = 'Настройка правила проверки'");
	КонецЕсли;
	
	Элементы.СтраницаТипыДокументов.Видимость = СозданиеМЧД;
	Элементы.СтраницаВидыДокументовЭДО.Видимость = Не СозданиеМЧД;
	Элементы.НастройкиОграничений.Видимость = СозданиеМЧД;
	Элементы.ГруппаЗаголовок.Доступность = Не БезОграничений;

КонецПроцедуры

&НаСервере
Процедура ЗаполнитьТекущиеНастройкиПолномочия(Настройки)
	
	ПолномочиеИзНастройки = 
		Справочники.КлассификаторПолномочийМЧД003.НайтиПоРеквизиту("КодКлассификатора",
			Настройки[0].КодПолномочия);
	
	ЗначенияПолномочияПоУмолчанию = 
		ОбщегоНазначения.ЗначенияРеквизитовОбъекта(
			ПолномочиеИзНастройки, "КодКлассификатора, Полномочие, Мнемоника");
			
	НоваяСтрокаПолномочие = Полномочие.Добавить();
	НоваяСтрокаПолномочие.Код = ЗначенияПолномочияПоУмолчанию.КодКлассификатора;
	НоваяСтрокаПолномочие.Наименование = ЗначенияПолномочияПоУмолчанию.Полномочие;
	НоваяСтрокаПолномочие.Мнемоника = ЗначенияПолномочияПоУмолчанию.Мнемоника;
	
	СписокИНН = Новый Массив; //Массив из Строка
	СписокКПП = Новый Массив; //Массив из Строка
	
	Для Каждого ТекущаяНастройка Из Настройки Цикл
		
		Если ТекущаяНастройка.КодОграничения = МашиночитаемыеДоверенностиКлиентСервер.КодОграниченияЛимитПоСумме() Тогда
			
			ЛимитПоСумме = СтроковыеФункцииКлиентСервер.СтрокаВЧисло(ТекущаяНастройка.ТекстовоеОписаниеОграничения);
			
		ИначеЕсли ТекущаяНастройка.КодОграничения = МашиночитаемыеДоверенностиКлиентСервер.КодОграниченияОбъект() Тогда
			
			Объект = СокрЛП(ТекущаяНастройка.ТекстовоеОписаниеОграничения);
			
		ИначеЕсли ТекущаяНастройка.КодОграничения = МашиночитаемыеДоверенностиКлиентСервер.КодОграниченияФилиалДоверителя() Тогда
			
			ФилиалДоверителя = СокрЛП(ТекущаяНастройка.ТекстовоеОписаниеОграничения);
			
		ИначеЕсли ТекущаяНастройка.КодОграничения = МашиночитаемыеДоверенностиКлиентСервер.КодОграниченияСертификатЭППредставителя() Тогда
			
			СертификатЭлектроннойПодписиПредставителя = СокрЛП(ТекущаяНастройка.ТекстовоеОписаниеОграничения);
			
		ИначеЕсли ТекущаяНастройка.КодОграничения = МашиночитаемыеДоверенностиКлиентСервер.КодОграниченияТипОбъекта() Тогда
			
			ТипОбъекта = СокрЛП(ТекущаяНастройка.ТекстовоеОписаниеОграничения);
			
		ИначеЕсли ТекущаяНастройка.КодОграничения = МашиночитаемыеДоверенностиКлиентСервер.КодОграниченияТипСуммы() Тогда
			
			ЗаполнитьЗначениеНастройки(ТекущаяНастройка, ТипСуммы);
			
		ИначеЕсли ТекущаяНастройка.КодОграничения = МашиночитаемыеДоверенностиКлиентСервер.КодОграниченияТипВалюты() Тогда 
			
			ЗаполнитьЗначениеНастройки(ТекущаяНастройка, ТипВалюты);
			
		ИначеЕсли ТекущаяНастройка.КодОграничения = МашиночитаемыеДоверенностиКлиентСервер.КодОграниченияКонтрагент() Тогда 
			
			СписокИНН.Добавить(СокрЛП(ТекущаяНастройка.ТекстовоеОписаниеОграничения));
			
		ИначеЕсли ТекущаяНастройка.КодОграничения = 
			МашиночитаемыеДоверенностиКлиентСервер.КодОграниченияФилиалКонтрагента() Тогда
			
			СписокКПП.Добавить(СокрЛП(ТекущаяНастройка.ТекстовоеОписаниеОграничения)); 
			
		ИначеЕсли ТекущаяНастройка.КодОграничения = МашиночитаемыеДоверенностиКлиентСервер.КодОграниченияТипДокумента() Тогда
			
			ЗаполнитьЗначениеНастройки(ТекущаяНастройка, ТипДокумента);
			
		ИначеЕсли ТекущаяНастройка.КодОграничения = МашиночитаемыеДоверенностиКлиентСервер.КодОграниченияВидДокументаЭДО() Тогда
			
			ЗаполнитьЗначениеНастройкиВидыДокументовЭДО(ТекущаяНастройка);
		
		ИначеЕсли ТекущаяНастройка.КодОграничения = МашиночитаемыеДоверенностиКлиентСервер.КодОграниченияВидОбязательств() Тогда
			
			ЗаполнитьЗначениеНастройки(ТекущаяНастройка, ВидОбязательств);
			
		ИначеЕсли ТекущаяНастройка.КодОграничения = МашиночитаемыеДоверенностиКлиентСервер.КодОграниченияТерритория() Тогда
			
			ЗаполнитьЗначениеНастройки(ТекущаяНастройка, Территория);
			
		ИначеЕсли ТекущаяНастройка.КодОграничения = МашиночитаемыеДоверенностиКлиентСервер.КодОграниченияОрганВласти() Тогда
			
			ЗаполнитьЗначениеНастройки(ТекущаяНастройка, ОрганВласти);
			
		ИначеЕсли ТекущаяНастройка.КодОграничения = МашиночитаемыеДоверенностиКлиентСервер.КодОграниченияТовары()
			Или ТекущаяНастройка.КодОграничения = МашиночитаемыеДоверенностиКлиентСервер.КодОграниченияУслуги()
			Или ТекущаяНастройка.КодОграничения = МашиночитаемыеДоверенностиКлиентСервер.КодОграниченияРаботы() Тогда
			
				ЗаполнитьЗначениеНастройки(ТекущаяНастройка, ТоварыРаботыУслуги);
				
		ИначеЕсли ТекущаяНастройка.КодОграничения = 
			МашиночитаемыеДоверенностиКлиентСервер.КодОграниченияХарактеристикаУслугиРаботыТовара() Тогда
			
				СтрокаТаблицы = ХарактеристикаУслугиРаботыТовара.Добавить();
				СтрокаТаблицы.Код = СокрЛП(ТекущаяНастройка.ТекстовоеОписаниеОграничения);
		КонецЕсли;
		
	КонецЦикла;
	
	ЗаполнитьКонтрагентов(СписокИНН, СписокКПП);
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьТекущиеНастройкиПолномочияПоУмолчанию()
	
	ПолномочиеПоУмолчанию = 
		Справочники.КлассификаторПолномочийМЧД003.НайтиПоРеквизиту("КодКлассификатора",
			Справочники.КлассификаторПолномочийМЧД003.КодПолномочия_KLASS_2_0_SIGN_ELECTRONIC_DOCUMENTS());
	
	ЗначенияПолномочияПоУмолчанию = 
		ОбщегоНазначения.ЗначенияРеквизитовОбъекта(
			ПолномочиеПоУмолчанию, "КодКлассификатора, Полномочие, Мнемоника");
			
	НоваяСтрокаПолномочие = Полномочие.Добавить();
	НоваяСтрокаПолномочие.Код = ЗначенияПолномочияПоУмолчанию.КодКлассификатора;
	НоваяСтрокаПолномочие.Наименование = ЗначенияПолномочияПоУмолчанию.Полномочие;
	НоваяСтрокаПолномочие.Мнемоника = ЗначенияПолномочияПоУмолчанию.Мнемоника;
	
	КлассификаторЗначенийОграничений = РегистрыСведений.КлассификаторыОграниченийМЧД.КлассификаторЗначенийОграничений();
	
	ЗначениеОграниченияТипВалюты = 
		КлассификаторЗначенийОграничений.Найти(МашиночитаемыеДоверенности.КодыПоддерживаемыхВалют()[0], "Код");
	
	НоваяСтрокаТипВалюты = ТипВалюты.Добавить();
	НоваяСтрокаТипВалюты.Код = ЗначениеОграниченияТипВалюты.Код;
	НоваяСтрокаТипВалюты.Наименование = ЗначениеОграниченияТипВалюты.Наименование;
	
	ЗначениеОграниченияТипСуммы = 
		КлассификаторЗначенийОграничений.Найти(МашиночитаемыеДоверенности.КодЗначенияОграниченияТипСуммыСНДС(), "Код");
	
	НоваяСтрокаТипСуммы = ТипСуммы.Добавить();
	НоваяСтрокаТипСуммы.Код = ЗначениеОграниченияТипСуммы.Код;
	НоваяСтрокаТипСуммы.Наименование = ЗначениеОграниченияТипСуммы.Наименование;
	
	Если СозданиеМЧД И Не Редактирование Тогда

		ЗначениеОграниченияТипДокумента = КлассификаторЗначенийОграничений.Найти(
			МашиночитаемыеДоверенности.КодЗначенияОграниченияТипДокументаУПД(), "Код");

		НоваяСтрокаТипДокумента = ТипДокумента.Добавить();
		НоваяСтрокаТипДокумента.Код = ЗначениеОграниченияТипДокумента.Код;
		НоваяСтрокаТипДокумента.Наименование = ЗначениеОграниченияТипДокумента.Наименование;

	КонецЕсли;
		
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьЗначениеНастройки(Настройка, Таблица)

	ПараметрыОтбора = Новый Структура("Код", Настройка.КодЗначенияОграничения);
	Значение = Таблица.НайтиСтроки(ПараметрыОтбора);
	
	Если Значение.Количество() = 0 Тогда 
		НоваяСтрока = Таблица.Добавить();
		НоваяСтрока.Код = Настройка.КодЗначенияОграничения;
		НоваяСтрока.Наименование = Настройка.НаименованиеЗначенияОграничения;
	КонецЕсли
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьЗначениеНастройкиВидыДокументовЭДО(Настройка)
	
	ВидДокументаЭДО = Настройка.ОбъектСопоставления;
	
	Если Не ЗначениеЗаполнено(ВидДокументаЭДО) Тогда
		Возврат;
	КонецЕсли;
	
	ЭлементСписка = ВидыДокументовЭДО.НайтиПоЗначению(ВидДокументаЭДО);
	
	Если ЭлементСписка = Неопределено Тогда
		ВидыДокументовЭДО.Добавить(ВидДокументаЭДО);
	КонецЕсли
	
КонецПроцедуры

&НаСервере
Процедура ДобавитьКонтрагентов(Контрагенты)

	ИННКонтрагента = ЭлектронноеВзаимодействие.ИмяНаличиеОбъектаРеквизитаВПрикладномРешении("ИННКонтрагента");
	КППКонтрагента = ЭлектронноеВзаимодействие.ИмяНаличиеОбъектаРеквизитаВПрикладномРешении("КППКонтрагента");
	ПредставлениеКонтрагента = ЭлектронноеВзаимодействие.ИмяНаличиеОбъектаРеквизитаВПрикладномРешении("НаименованиеКонтрагентаДляСообщенияПользователю");

	МассивРеквизитов = Новый Массив(); // Массив Из Строка
	МассивРеквизитов.Добавить(ИННКонтрагента);
	МассивРеквизитов.Добавить(КППКонтрагента);
	МассивРеквизитов.Добавить(ПредставлениеКонтрагента);
	
	ЗначенияРеквизитовКонтрагентов = 
		ОбщегоНазначения.ЗначенияРеквизитовОбъектов(Контрагенты, СтрСоединить(МассивРеквизитов, ","));
	
	Для Каждого Элемент Из ЗначенияРеквизитовКонтрагентов Цикл
		
		ЭтоЮрЛицо = СтрДлина(СокрЛП(Элемент.Значение[ИННКонтрагента])) = 10;
		
		Если СозданиеМЧД И Не ЭтоЮрЛицо Тогда
			ТекстОшибки = НСтр("ru='ИНН контрагента может принимать значение только в соответствии с ИНН юридического лица';");
			ОбщегоНазначения.СообщитьПользователю(ТекстОшибки);
			Продолжить;
		КонецЕсли;
		
		ПараметрыОтбора = Новый Структура("ИНН, КПП", "", "");
		ПараметрыОтбора.ИНН = Элемент.Значение[ИННКонтрагента];
		ПараметрыОтбора.КПП = Элемент.Значение[КППКонтрагента];

		НайденныеЭлементы = СписокКонтрагентов.НайтиСтроки(ПараметрыОтбора);
		
		Если НайденныеЭлементы.Количество() = 0 Тогда
			НоваяСтрока = СписокКонтрагентов.Добавить();
			НоваяСтрока.ИНН = Элемент.Значение[ИННКонтрагента];
			НоваяСтрока.КПП = Элемент.Значение[КППКонтрагента];
			НоваяСтрока.Представление = Элемент.Значение[ПредставлениеКонтрагента];
			НоваяСтрока.ИспользуетсяКПП = СтрДлина(СокрЛП(НоваяСтрока.ИНН)) = 10;
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура СообщитьОНесоответствииИННКонтрагента()
	ТекстОшибки = НСтр("ru='ИНН контрагента может принимать значение только в соответствии с ИНН юридического лица';");
	ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстОшибки);
КонецПроцедуры

&НаКлиенте
Процедура ПроверитьЗаполнениеПолномочия(Отказ)
	
	Если Полномочие.Количество() = 0 Тогда
		Отказ = Истина;
	КонецЕсли;
	
	Если Отказ Тогда
		ПоказатьПредупреждение(, НСтр("ru = 'Для продолжения укажите полномочие.'"));
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПроверитьЗаполнениеУсловныхПолей(Отказ)
	
	Если БезОграничений Тогда 
		Возврат;
	КонецЕсли;
	
	НеобходимоЗаполнитьТипВалюты = ЗначениеЗаполнено(ЛимитПоСумме) И Не ЗначениеЗаполнено(ТипВалюты);
	НеобходимоЗаполнитьТипСуммы = ЗначениеЗаполнено(ЛимитПоСумме) И Не ЗначениеЗаполнено(ТипСуммы);
	
	ОбновитьОтметкуНезаполненногоОграниченийПоСумме();
	
	Если НеобходимоЗаполнитьТипВалюты И НеобходимоЗаполнитьТипСуммы Тогда
		ТекстСообщения = НСтр("ru='При указании лимита по сумме также необходимо указать тип валюты и тип суммы.';");
			ПоказатьПредупреждение(, ТекстСообщения);
		Отказ = Истина;
		Возврат;
	КонецЕсли;
	
	Если НеобходимоЗаполнитьТипВалюты Тогда
			ТекстСообщения = НСтр("ru='При указании лимита по сумме также необходимо указать тип валюты.';");
			ПоказатьПредупреждение(, ТекстСообщения);
		Отказ = Истина;
		Возврат;
	КонецЕсли;
	
	Если НеобходимоЗаполнитьТипСуммы Тогда
			ТекстСообщения = НСтр("ru='При указании лимита по сумме также необходимо указать тип суммы.';");
			ПоказатьПредупреждение(, ТекстСообщения);
		Отказ = Истина;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПроверитьЗаполнениеРеквизитовФормы(Отказ)
	
	Если БезОграничений Тогда
		Возврат;
	КонецЕсли;
	
	СписокОшибок = Новый Массив; //Массив из Строка
	ПроверитьЗаполнениеРеквизитаСписокКонтрагентов(СписокОшибок);
	
	ТекстСообщения = СтрСоединить(СписокОшибок, Символы.ПС);
	Если ЗначениеЗаполнено(ТекстСообщения) Тогда
		Отказ = Истина;
		ПоказатьПредупреждение(, ТекстСообщения);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ПроверитьЗаполнениеРеквизитаСписокКонтрагентов(СписокОшибок)
	
	НайденныеСтроки = СписокКонтрагентов.НайтиСтроки(Новый Структура("ИНН",""));
	
	Для Каждого ТекущаяСтрока Из НайденныеСтроки Цикл
		
		ТекущийНомерСтроки = СписокКонтрагентов.Индекс(ТекущаяСтрока) + 1;
		
		ШаблонОшибки = НСтр("ru = 'В строке %1 табличной части ""%2"" не заполнен ИНН.'");
		ТекстОшибки = СтрШаблон(ШаблонОшибки, ТекущийНомерСтроки, Элементы.СписокКонтрагентов.Заголовок);
		
		СписокОшибок.Добавить(ТекстОшибки);
		
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ПодготовитьПараметрыЗаписиПередЗакрытием(ПараметрыЗаписи)
	
	ПараметрыЗаписи.ПорядковыйНомер = ПорядковыйНомер;
	ПараметрыЗаписи.Редактирование = Редактирование;
	
	УстанавливаемоеПолномочие = 
		Справочники.КлассификаторПолномочийМЧД003.ПолучитьДанныеПолномочия_KLASS_2_0_SIGN_ELECTRONIC_DOCUMENTS();
	
	ДанныеОграничений = 
		Справочники.КлассификаторПолномочийМЧД003.ПолучитьДанныеПоддерживаемыхОграниченийИзКлассификатора();
	
	Если СозданиеМЧД И Полномочие.Количество() > 0 Тогда
			
		ПолномочиеИзНастройки = 
			Справочники.КлассификаторПолномочийМЧД003.НайтиПоРеквизиту("КодКлассификатора", Полномочие[0].Код);
	
		Если ЗначениеЗаполнено(ПолномочиеИзНастройки) Тогда
			УстанавливаемоеПолномочие = 
				ОбщегоНазначения.ЗначенияРеквизитовОбъекта(
					ПолномочиеИзНастройки, 
						"КодКлассификатора, Полномочие, Мнемоника, ОписаниеПолномочия, КонтекстПолномочия");
		КонецЕсли;
	КонецЕсли;
	
	НомерОграничения = 1;
	ПодготовленноеПравило = Новый Массив; //массив из Структура
	НастройкиПравила = МашиночитаемыеДоверенностиКлиентСервер.НовыйНастройкиПроверкиРасширенные();
	
	Если БезОграничений Тогда 
		
		НастройкиПравила = 
			Справочники.ПравилаПроверкиПолномочийМЧД.ПолучитьНастройкиПроверкиРасширенные(ПорядковыйНомер, 
				УстанавливаемоеПолномочие, НомерОграничения, Неопределено, Неопределено);
				
		ПодготовленноеПравило.Добавить(НастройкиПравила);
		
	Иначе
		
		Для Каждого ТекущееЗначение Из ТипДокумента Цикл 
			
			Ограничение = ДанныеОграничений.Получить(МашиночитаемыеДоверенностиКлиентСервер.КодОграниченияТипДокумента());
			
			ЗначениеОграничения = Новый Структура;
			ЗначениеОграничения.Вставить("КодЗначенияОграничения", ТекущееЗначение.Код); 
			ЗначениеОграничения.Вставить("НаименованиеЗначенияОграничения" , ТекущееЗначение.Наименование);
			
			НастройкиПравила = 
				Справочники.ПравилаПроверкиПолномочийМЧД.ПолучитьНастройкиПроверкиРасширенные(ПорядковыйНомер, 
					УстанавливаемоеПолномочие, НомерОграничения, Ограничение, ЗначениеОграничения);
			
			ПодготовленноеПравило.Добавить(НастройкиПравила);
			
			НомерОграничения = НомерОграничения + 1;
			
		КонецЦикла;
		
		УникальныеЗначенияВидДокументовЭДО = ОбщегоНазначенияКлиентСервер.СвернутьМассив(
			ВидыДокументовЭДО.ВыгрузитьЗначения());

		Для Каждого ТекущийВидДокумента Из УникальныеЗначенияВидДокументовЭДО Цикл

			ОграничениеВидДокументаЭДО = Справочники.КлассификаторПолномочийМЧД003.ОграничениеВидДокументаЭДО();

			НастройкиПравила = Справочники.ПравилаПроверкиПолномочийМЧД.ПолучитьНастройкиПроверкиРасширенные(
				ПорядковыйНомер, УстанавливаемоеПолномочие, НомерОграничения, ОграничениеВидДокументаЭДО, , ,
				ТекущийВидДокумента);

			ПодготовленноеПравило.Добавить(НастройкиПравила);

			НомерОграничения = НомерОграничения + 1;

		КонецЦикла;
		
		Если ЗначениеЗаполнено(ЛимитПоСумме) Тогда 
			
			ТекстовоеОписаниеОграничения = Строка(ЛимитПоСумме);
			Ограничение = ДанныеОграничений.Получить(МашиночитаемыеДоверенностиКлиентСервер.КодОграниченияЛимитПоСумме());
			
			НастройкиПравила = 
				Справочники.ПравилаПроверкиПолномочийМЧД.ПолучитьНастройкиПроверкиРасширенные(ПорядковыйНомер, 
					УстанавливаемоеПолномочие, НомерОграничения, Ограничение, Неопределено, ТекстовоеОписаниеОграничения);
			
			ПодготовленноеПравило.Добавить(НастройкиПравила);
			
			НомерОграничения = НомерОграничения + 1;
			
		КонецЕсли;
		
		Если ЗначениеЗаполнено(ФилиалДоверителя) Тогда 
			
			ТекстовоеОписаниеОграничения = Строка(ФилиалДоверителя);
			Ограничение = 
				ДанныеОграничений.Получить(МашиночитаемыеДоверенностиКлиентСервер.КодОграниченияФилиалДоверителя());
			
			НастройкиПравила = 
				Справочники.ПравилаПроверкиПолномочийМЧД.ПолучитьНастройкиПроверкиРасширенные(ПорядковыйНомер, 
					УстанавливаемоеПолномочие, НомерОграничения, Ограничение, Неопределено, ТекстовоеОписаниеОграничения);
			
			ПодготовленноеПравило.Добавить(НастройкиПравила);
			
			НомерОграничения = НомерОграничения + 1;
			
		КонецЕсли;
		
		Если ЗначениеЗаполнено(СертификатЭлектроннойПодписиПредставителя) Тогда 
			
			ТекстовоеОписаниеОграничения = Строка(СертификатЭлектроннойПодписиПредставителя);
			Ограничение = 
				ДанныеОграничений.Получить(МашиночитаемыеДоверенностиКлиентСервер.КодОграниченияСертификатЭППредставителя());
			
			НастройкиПравила = 
				Справочники.ПравилаПроверкиПолномочийМЧД.ПолучитьНастройкиПроверкиРасширенные(ПорядковыйНомер, 
					УстанавливаемоеПолномочие, НомерОграничения, Ограничение, Неопределено, ТекстовоеОписаниеОграничения);
			
			ПодготовленноеПравило.Добавить(НастройкиПравила);
			
			НомерОграничения = НомерОграничения + 1;
			
		КонецЕсли;
		
		Если ЗначениеЗаполнено(Объект) Тогда 
			
			ТекстовоеОписаниеОграничения = СокрЛП(Объект);
			Ограничение = ДанныеОграничений.Получить(МашиночитаемыеДоверенностиКлиентСервер.КодОграниченияОбъект());
			
			НастройкиПравила = 
