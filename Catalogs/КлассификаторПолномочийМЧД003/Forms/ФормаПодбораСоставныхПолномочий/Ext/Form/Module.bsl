			ПодготовленноеПравило.Добавить(НастройкиПравила);
			
			НомерОграничения = НомерОграничения + 1;
			
		КонецЦикла;
		
		Для Каждого ТекущееЗначение Из ВидОбязательств Цикл 
			
			Ограничение = ДанныеОграничений.Получить(МашиночитаемыеДоверенностиКлиентСервер.КодОграниченияВидОбязательств());
			
			ЗначениеОграничения = Новый Структура;
			ЗначениеОграничения.Вставить("КодЗначенияОграничения", ТекущееЗначение.Код); 
			ЗначениеОграничения.Вставить("НаименованиеЗначенияОграничения" , ТекущееЗначение.Наименование);	
			
			НастройкиПравила = 
				Справочники.ПравилаПроверкиПолномочийМЧД.ПолучитьНастройкиПроверкиРасширенные(ПорядковыйНомер, 
					УстанавливаемоеПолномочие, НомерОграничения, Ограничение, ЗначениеОграничения);
			
			ПодготовленноеПравило.Добавить(НастройкиПравила);
			
			НомерОграничения = НомерОграничения + 1;
			
		КонецЦикла;
		
		Для Каждого ТекущееЗначение Из Территория Цикл 
			
			Ограничение = ДанныеОграничений.Получить(МашиночитаемыеДоверенностиКлиентСервер.КодОграниченияТерритория());
			
			ЗначениеОграничения = Новый Структура;
			ЗначениеОграничения.Вставить("КодЗначенияОграничения", ТекущееЗначение.Код); 
			ЗначениеОграничения.Вставить("НаименованиеЗначенияОграничения" , ТекущееЗначение.Наименование);	
			
			НастройкиПравила = 
				Справочники.ПравилаПроверкиПолномочийМЧД.ПолучитьНастройкиПроверкиРасширенные(ПорядковыйНомер, 
					УстанавливаемоеПолномочие, НомерОграничения, Ограничение, ЗначениеОграничения);
			
			ПодготовленноеПравило.Добавить(НастройкиПравила);
			
			НомерОграничения = НомерОграничения + 1;
			
		КонецЦикла;
		
		Для Каждого ТекущееЗначение Из ОрганВласти Цикл 
			
			Ограничение = ДанныеОграничений.Получить(МашиночитаемыеДоверенностиКлиентСервер.КодОграниченияОрганВласти());
			
			ЗначениеОграничения = Новый Структура;
			ЗначениеОграничения.Вставить("КодЗначенияОграничения", ТекущееЗначение.Код); 
			ЗначениеОграничения.Вставить("НаименованиеЗначенияОграничения" , ТекущееЗначение.Наименование);
			
			НастройкиПравила = 
				Справочники.ПравилаПроверкиПолномочийМЧД.ПолучитьНастройкиПроверкиРасширенные(ПорядковыйНомер, 
