#Область ОбработчикиСобытийЭлементовТаблицыФормыВидыДокументовЭДО

&НаКлиенте
Процедура ВидыДокументовЭДОПередНачаломДобавления(Элемент, Отказ, Копирование, Родитель, ЭтоГруппа, Параметр)
	
	Отказ = Истина;
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("МножественныйВыбор", Истина);
	Если Элемент.ТекущиеДанные <> Неопределено Тогда  
		ПараметрыФормы.Вставить("ТекущаяСтрока", Элемент.ТекущиеДанные.Значение);
	КонецЕсли;
	
	ОткрытьФорму("Справочник.ВидыДокументовЭДО.ФормаВыбора", ПараметрыФормы, Элемент);

КонецПроцедуры

&НаКлиенте
Процедура ВидыДокументовЭДООбработкаВыбора(Элемент, ВыбранноеЗначение, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	Если ТипЗнч(ВыбранноеЗначение) <> Тип("Массив") Тогда 
		ВыбранноеЗначение = 
			ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(ВыбранноеЗначение);
	КонецЕсли;
	
	Для Каждого ТекущийВидДокумента Из ВыбранноеЗначение Цикл
	
		НайденноеЗначение = ВидыДокументовЭДО.НайтиПоЗначению(ТекущийВидДокумента);
		Если НайденноеЗначение = Неопределено Тогда
			ВидыДокументовЭДО.Добавить(ТекущийВидДокумента);
		КонецЕсли;
		
	КонецЦикла;
	
	Если ВидыДокументовЭДО.Количество() > 1 Тогда
		Элементы.ВидыДокументовЭДО.ТекущаяСтрока = ВидыДокументовЭДО.Количество() - 1;
	КонецЕсли;

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыСписокКонтрагентов

&НаКлиенте
Процедура СписокКонтрагентовПередОкончаниемРедактирования(Элемент, НоваяСтрока, ОтменаРедактирования, Отказ)
	
	Если ОтменаРедактирования Тогда
		СписокКонтрагентов.Удалить(СписокКонтрагентов.Индекс(Элемент.ТекущиеДанные));
		Возврат;
	КонецЕсли;
	
	ИНН = СокрЛП(Элемент.ТекущиеДанные.ИНН); 
	КПП = СокрЛП(Элемент.ТекущиеДанные.КПП);
	
	Если ПустаяСтрока(ИНН) Тогда
		Возврат;
	КонецЕсли;
	
	ЭтоЮрЛицо = СтрДлина(СокрЛП(ИНН)) = 10;
	
	Если СозданиеМЧД И Не ЭтоЮрЛицо Тогда
		СообщитьОНесоответствииИННКонтрагента();
		Элемент.ТекущиеДанные.ИНН = "";
		Возврат;
	КонецЕсли;
	
	КоличествоДублейСтрок = 0;
	Для Каждого ТекущаяСтрокаСписка Из СписокКонтрагентов Цикл
		Если СокрЛП(ТекущаяСтрокаСписка.ИНН) = ИНН И СокрЛП(ТекущаяСтрокаСписка.КПП) = КПП Тогда
			КоличествоДублейСтрок = КоличествоДублейСтрок + 1;
		КонецЕсли;
	КонецЦикла;
	
	Если КоличествоДублейСтрок > 1 Тогда
		Отказ = Истина;
	КонецЕсли;
	
	Если Отказ Тогда
		
		Если ЗначениеЗаполнено(КПП) Тогда
			ТекстСообщения = 
				СтрШаблон(НСтр("ru = 'Строка с ИНН %1 и КПП %2 уже добавлена в табличную часть.'"), ИНН, КПП);
		Иначе
			ТекстСообщения = 
				СтрШаблон(НСтр("ru = 'Строка с ИНН %1 и пустым КПП уже добавлена в табличную часть.'"), ИНН);
		КонецЕсли;
				
		ПоказатьПредупреждение(, ТекстСообщения);
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура КонтрагентИННПриИзменении(Элемент)
	
	Если Элемент.Родитель.ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Элемент.Родитель.ТекущиеДанные.ИспользуетсяКПП = 
		СтрДлина(СокрЛП(Элемент.Родитель.ТекущиеДанные.ИНН)) = 10;

КонецПроцедуры

#КонецОбласти

