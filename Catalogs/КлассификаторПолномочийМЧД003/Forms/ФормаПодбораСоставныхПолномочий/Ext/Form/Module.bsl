#Область ОбработчикиСобытийЭлементовТаблицыФормыТипДокумента

&НаКлиенте
Процедура ТипДокументаПередНачаломДобавления(Элемент, Отказ, Копирование, Родитель, ЭтоГруппа, Параметр)
	
	ОтмеченныеЭлементы = Новый Массив(); // Массив Из Строка
	Для Каждого СтрокаТипДокумента Из ТипДокумента Цикл
		ОтмеченныеЭлементы.Добавить(СтрокаТипДокумента.Код);
	КонецЦикла;
		
	ПараметрыОткрытия = Новый Структура;
	ПараметрыОткрытия.Вставить("КодОграничения", МашиночитаемыеДоверенностиКлиентСервер.КодОграниченияТипДокумента());
	ПараметрыОткрытия.Вставить("ИмяЭлемента", Элемент.Имя);
	ПараметрыОткрытия.Вставить("ОтмеченныеЭлементы", ОтмеченныеЭлементы);
	ПараметрыОткрытия.Вставить("ДоступнаОтметкаНесколькихЗначений", Истина);
	
	ОткрытьФормуВыбораЗначенияОграничения(ПараметрыОткрытия);
	
КонецПроцедуры

