#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Элементы.Список.МножественныйВыбор = Параметры.МножественныйВыбор;
	
	Параметры.ДополнительныеПараметры.Свойство("ПорядковыйНомер", ПорядковыйНомер);
	Параметры.ДополнительныеПараметры.Свойство("Редактирование", Редактирование);
	Параметры.ДополнительныеПараметры.Свойство("СозданиеМЧД", СозданиеМЧД);
	
	Если ЗначениеЗаполнено(Параметры.КодКлассификатора) Тогда
		Параметры.ТекущаяСтрока = 
			Справочники.КлассификаторПолномочийМЧД003.НайтиПолномочиеПоКоду(Параметры.КодКлассификатора);
	КонецЕсли;
	
	ОбновитьИспользованиеПараметровСписка();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыСписок

&НаКлиенте
Процедура СписокВыборЗначения(Элемент, Значение, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	ВыбранныеПолномочия = Новый Массив;
	
	Если Не Элементы.Список.МножественныйВыбор Тогда
		Значение = ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(Значение);
	КонецЕсли;
	
	Для Каждого ВыбранныйЭлемент Из Значение Цикл
		
		ТекущиеДанные = Элементы.Список.ДанныеСтроки(ВыбранныйЭлемент);
		ВыбранныеПолномочия.Добавить(ТекущиеДанные.Ссылка);
		
	КонецЦикла;
	
	ПараметрыЗаписи = МашиночитаемыеДоверенностиКлиент.НовыйПараметрыОткрытияФормыРедактированияПолномочий();
	ПодготовитьПараметрыЗаписиПередЗакрытием(ПараметрыЗаписи, ВыбранныеПолномочия);
	
	Закрыть(ПараметрыЗаписи);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура ОбновитьИспользованиеПараметровСписка()
	
	ОбщегоНазначенияКлиентСервер.УстановитьПараметрДинамическогоСписка(Список, "ТекущаяДата", ТекущаяДатаСеанса());
	
	Если Параметры.ТолькоПолномочияСОграничениями Тогда
		
		ОбщегоНазначенияКлиентСервер.УстановитьПараметрДинамическогоСписка(Список, 
			"ПризнакСПрименениемОграничений", 
				МашиночитаемыеДоверенностиКлиентСервер.ПризнакПолномочиеСОграничением()); 
		
		Элементы.Список.Отображение = ОтображениеТаблицы.Список;
		Список.КомпоновщикНастроек.Настройки.Структура.Очистить();
		
	КонецЕсли;
	
	Если Параметры.ТолькоПолномочияБезПримененияОграничений Тогда
		
		ОбщегоНазначенияКлиентСервер.УстановитьПараметрДинамическогоСписка(Список, 
			"ПризнакБезПримененияОграничений",
				МашиночитаемыеДоверенностиКлиентСервер.ПризнакПолномочиеСОграничением()); 
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ПодготовитьПараметрыЗаписиПередЗакрытием(ПараметрыЗаписи, ВыбранныеПолномочия)
	
	ПараметрыЗаписи.ПорядковыйНомер = ПорядковыйНомер;
	ПараметрыЗаписи.Редактирование = Редактирование;

	ЗначенияРеквизитовВыбранныхПолномочий = 
		ОбщегоНазначения.ЗначенияРеквизитовОбъектов(
			ВыбранныеПолномочия, "КодКлассификатора, Полномочие, Мнемоника, ОписаниеПолномочия, КонтекстПолномочия");
			
	ПодготовленноеПравило = Новый Массив;
	
	Для Каждого Полномочие Из ВыбранныеПолномочия Цикл
	
		НомерОграничения = 1;
	
		УстанавливаемоеПолномочие = ЗначенияРеквизитовВыбранныхПолномочий[Полномочие];
		
		НастройкиПравила = 
			Справочники.ПравилаПроверкиПолномочийМЧД.ПолучитьНастройкиПроверкиРасширенные(ПорядковыйНомер, 
				УстанавливаемоеПолномочие, НомерОграничения, Неопределено, Неопределено);
				
		ПодготовленноеПравило.Добавить(НастройкиПравила);
		ПорядковыйНомер = ПорядковыйНомер + 1;
	
	КонецЦикла;
	
	ПараметрыЗаписи.НастройкиТекущегоПравила = ПодготовленноеПравило;
	
КонецПроцедуры

#КонецОбласти