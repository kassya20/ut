&НаКлиенте
Процедура ПоказатьСтраницуПредупреждения()
	
	// Для показа страницы Предупреждения о наличии синхронизации, скроем все лишние элементы,
	//  чтобы максимально уменьшить форму.
	// А если страницу Предупреждения показали и теперь ее надо скрыть, то вернем видимость элементам скрытым ранее.
	Элементы.Шаги.ОтображениеСтраниц = ОтображениеСтраницФормы.Нет;
	Если ПоказатьСтраницуОНаличииСинхронизации Тогда
		
		Элементы.ПредупреждениеПодтвердить.КнопкаПоУмолчанию = Истина;
		Элементы.Шаги.ТекущаяСтраница = Элементы.СтраницаПредупреждениеОНаличииСинхронизации;
		СкрытьИЗапомнитьЭлементФормы(Элементы.ИнформацияНаСайтеБанка);
		СкрытьИЗапомнитьЭлементФормы(Элементы.СтраницаВыборОрганизацииИБанка);
		СкрытьИЗапомнитьЭлементФормы(Элементы.СтраницаВыборСпособаСозданияНастройки);
		СкрытьИЗапомнитьЭлементФормы(Элементы.СтраницаПолучениеССервера);
		СкрытьИЗапомнитьЭлементФормы(Элементы.СтраницаВыборФайлаНастроек);
		СкрытьИЗапомнитьЭлементФормы(Элементы.СтраницаЗапросИспользованияВнешнегоМодуля);
		СкрытьИЗапомнитьЭлементФормы(Элементы.СтраницаАсинхронныйОбмен);
		СкрытьИЗапомнитьЭлементФормы(Элементы.СтраницаСертификаты);
		СкрытьИЗапомнитьЭлементФормы(Элементы.СтраницаФинал);
		СкрытьИЗапомнитьЭлементФормы(Элементы.СтраницаПодождите);
		СкрытьИЗапомнитьЭлементФормы(Элементы.СтраницаУпрощенныйРежимНастройки); 
		
	Иначе
		
		Индекс = 0;
		Для Каждого ЭлементФормы Из МассивСкрываемыхЭлементов Цикл
			
			ЭлементФормы.Видимость = МассивВидимостиСкрываемыхЭлементов[Индекс];
			Индекс = Индекс + 1;
			
		КонецЦикла;
		Элементы.ПредупреждениеПодтвердить.КнопкаПоУмолчанию = Ложь;
		Элементы.ДалееПервая.КнопкаПоУмолчанию = Истина;
		ФлагОтказ = Ложь;
		ФлагСтандартнаяОбработка = Истина;
		
		ВыполнитьДействияПриОткрытииНаСервере(ФлагОтказ, ФлагСтандартнаяОбработка);
		ВыполнитьДействияПриОткрытииНаКлиенте(ФлагОтказ);
		ИзменитьЗаголовок();
		
	КонецЕсли;
	
	Элементы.Шапка.Видимость = Не ПоказатьСтраницуОНаличииСинхронизации;
	Элементы.ШапкаПредупреждениеОСинхронизации.Видимость = ПоказатьСтраницуОНаличииСинхронизации;
	Элементы.СтраницаПредупреждениеОНаличииСинхронизации.Видимость = ПоказатьСтраницуОНаличииСинхронизации;
	
	Элементы.КомандыНавигации.Видимость = Не ПоказатьСтраницуОНаличииСинхронизации;
	
КонецПроцедуры

&НаКлиенте
Процедура СкрытьИЗапомнитьЭлементФормы(ЭлементФормы)
	
	МассивВидимостиСкрываемыхЭлементов.Добавить(ЭлементФормы.Видимость);
	МассивСкрываемыхЭлементов.Добавить(ЭлементФормы);
	ЭлементФормы.Видимость = Ложь;
	
КонецПроцедуры

