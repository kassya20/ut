&НаКлиенте
Процедура АдресСервераНастроекПриИзменении(Элемент)
	
	АдресСервера = СокрЛП(АдресСервераНастроек);
	
	МассивАдресаСерверовБанка = АдресаСерверовБанка.ВыгрузитьЗначения();
	Индекс = МассивАдресаСерверовБанка.Найти(АдресСервера);
	
	ВыбранныйСпособАутентификацииБанка = "";
	Если СпособыАутентификацииБанка.Количество() = 1 Тогда
		
		ВыбранныйСпособАутентификацииБанка = СпособыАутентификацииБанка.Получить(0).Значение;
		
	ИначеЕсли Индекс <> Неопределено Тогда
		
		// Указанный пользователем адрес сервера есть в АдресаСерверовБанка, значит мы можем определить СпособАутентификации
		//  из макета по соответствующему элементу из СпособыАутентификацииБанка по индексу
		
		ВыбранныйСпособАутентификацииБанка = СпособыАутентификацииБанка.Получить(Индекс).Значение;
		
	ИначеЕсли Индекс = Неопределено Тогда
		
		// Если мы не нашли введенный пользователем адрес сервера банка в АдресаСерверовБанка, значит заранее мы не знаем
		//  тип Способ Аутентификации, поэтому пользователь будет сам указывать эти параметры.
		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ВыбранныйСпособАутентификацииБанка) Тогда

		Если ВыбранныйСпособАутентификацииБанка = "ПоЛогинуИлиСертификату"
			ИЛИ ВыбранныйСпособАутентификацииБанка = "ПоСертификату" Тогда
			
			НастройкиОбменаСБанком.СпособАутентификации = "ПоЛогинуИлиСертификату";
			СпособСозданияНастройки = 0;
			СпособАутентификации = 0;
			СпособАутентификацииПриИзменении(СпособАутентификации);
			
		ИначеЕсли ВыбранныйСпособАутентификацииБанка = "ПоЛогину" Тогда
			
			НастройкиОбменаСБанком.СпособАутентификации = "ПоЛогину";
			СпособАутентификации = 1;
			СпособСозданияНастройки = 0;
			СпособАутентификацииПриИзменении(СпособАутентификации);
			
		КонецЕсли;
		#Если ВебКлиент Тогда
			ОбновитьОтображениеДанных();
		#КонецЕсли
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура УказатьАдресСервераБанкаПриИзменении(Элемент)
	
	Элементы.АдресСервераСмешанныйПоСертификату.Видимость = Ложь;
	Элементы.АдресСервераСмешанныйПоЛогину.Видимость = Ложь;
	Элементы.АдресСервераСмешанныйПоСертификату.КнопкаВыпадающегоСписка = Ложь;
	Элементы.АдресСервераСмешанныйПоЛогину.КнопкаВыпадающегоСписка = Ложь;
	
	Если (АдресаСерверовБанка.Количество() > 1) ИЛИ (АдресаСерверовБанка.Количество() = 0 И ПустаяСтрока(АдресСервера)) Тогда
		
		УказатьАдресСервераБанка = Истина;
		
	КонецЕсли;
	
	КнопкаВыпадающегоСпискаАдресСервераБанка = УказатьАдресСервераБанка;
	
	Если АдресаСерверовБанка.Количество() = 0 И ПустаяСтрока(АдресСервера) Тогда
		
		КнопкаВыпадающегоСпискаАдресСервераБанка = Ложь;
		
	КонецЕсли;
	
	Если Элементы.СтраницыСпособыПолученияНастроек.ТекущаяСтраница = Элементы.СтраницаНастройкиПоСертификату Тогда
		
		Элементы.АдресСервераСмешанныйПоСертификату.Видимость = УказатьАдресСервераБанка;
		Элементы.АдресСервераСмешанныйПоСертификату.КнопкаВыпадающегоСписка = КнопкаВыпадающегоСпискаАдресСервераБанка;
		
	Иначе
		
		Элементы.АдресСервераСмешанныйПоЛогину.Видимость = УказатьАдресСервераБанка;
		Элементы.АдресСервераСмешанныйПоЛогину.КнопкаВыпадающегоСписка = КнопкаВыпадающегоСпискаАдресСервераБанка;
		
	КонецЕсли;
	
КонецПроцедуры

