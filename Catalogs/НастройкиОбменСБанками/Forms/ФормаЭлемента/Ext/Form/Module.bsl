&НаКлиенте
Процедура ОшибкаВЖурналеРегистрацииОбработкаНавигационнойСсылки(
	Элемент, НавигационнаяСсылкаФорматированнойСтроки, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	Отбор = Новый Структура;
	Отбор.Вставить("ДатаНачала", НачалоДня(ДатаСинхронизацииАвтоматическогоПолученияВыписки));
	Отбор.Вставить("ДатаОкончания", КонецДня(ДатаСинхронизацииАвтоматическогоПолученияВыписки));
	Отбор.Вставить("Уровень", "Ошибка");
	Отбор.Вставить("Данные", Объект.Ссылка);
	ЖурналРегистрацииКлиент.ОткрытьЖурналРегистрации(Отбор, ЭтотОбъект);
	
