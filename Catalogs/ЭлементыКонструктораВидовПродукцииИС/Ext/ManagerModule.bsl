#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ПрограммныйИнтерфейс

// Получает текущие элементы конструктора видов продукции ИС.
// 
// Возвращаемое значение:
//  Соответствие из КлючИЗначение:
//   * Ключ     - СправочникСсылка.ЭлементыКонструктораВидовПродукцииИС - элемент конструктора.
//   * Значение - Структура из КлючИЗначение:
//      ** Ключ1     - Строка - Параметризуется.
//      ** Значение1 - Булево - Истина, если параметризуется.
//      ** Ключ2     - Строка - ВидыПродукции.
//      ** Значение2 - Соответствие из КлючИЗначение:
//          *** Ключ     - СправочникСсылка.ВидыПродукцииИС - вид продукции.
//          *** Значение - Соответствие из КлючИЗначение - значения:
//               **** Ключ     - ОпределяемыйТип.ЗначениеЭлементаКонструктораВидовПродукцииИС - значение,
//                               Строка - имя ключа атрибутов, если не Параметризуется и ИспользоватьАтрибуты.
//               **** Значение - Структура - из КлючИЗначение - имена и значения атрибутов:
//                     ***** Ключ     - Строка - имя атрибута.
//                     ***** Значение - Произвольный - значение атрибута.
//
Функция ЭлементыКонструктора() Экспорт
	
	Результат = Новый Соответствие;
	
	УстановитьПривилегированныйРежим(Истина);
	
	Подсистемы = Новый Массив;
	Для Каждого Суффикс Из КонструкторИСОбщегоНазначенияКлиентСервер.СуффиксыВидовПродукции() Цикл
		Если ОбщегоНазначенияИС.ПодсистемаИспользуется(Суффикс) Тогда
			Подсистемы.Добавить(
				Справочники.ЭлементыКонструктораВидовПродукцииИС["ВидыПродукции"+Суффикс]);
		КонецЕсли;
	КонецЦикла;
	
	ПараметрыЭлементовКонструктора = ПараметрыЭлементовКонструктора();
	ЭлементыПоВсемВидамПродукции = ЭлементыПоВсемВидамПродукции(ПараметрыЭлементовКонструктора);
	
	Если Подсистемы.Количество() > 0
		Или ЭлементыПоВсемВидамПродукции.Количество() > 0 Тогда
		
		КлючАтрибутовВидаПродукции = КонструкторИСОбщегоНазначенияКлиентСервер.КлючАтрибутовВидаПродукции();
		
		Запрос = Новый Запрос;
		Запрос.УстановитьПараметр("Подсистемы", Подсистемы);
		Запрос.УстановитьПараметр("ЭлементыПоВсемВидамПродукции", ЭлементыПоВсемВидамПродукции);
		Запрос.Текст =
		"ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ЗначенияЭлементовКонструктора.ВидПродукции КАК ВидПродукции
		|ПОМЕСТИТЬ ДоступныеВидыПродукции
		|ИЗ
		|	РегистрСведений.ЗначенияЭлементовКонструктораВидовПродукцииИС КАК ЗначенияЭлементовКонструктора
		|	ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ЗначенияПользователяЭлементовКонструктораВидовПродукцииИС КАК ЗначенияПользователяЭлементовКонструктора
		|		ПО ЗначенияЭлементовКонструктора.ЭлементКонструктора = ЗначенияПользователяЭлементовКонструктора.ЭлементКонструктора
		|		И ЗначенияЭлементовКонструктора.ВидПродукции = ЗначенияПользователяЭлементовКонструктора.ВидПродукции
		|ГДЕ
		|	ЗначенияЭлементовКонструктора.ЭлементКонструктора В (&Подсистемы)
		|	И ЗначенияПользователяЭлементовКонструктора.ЭлементКонструктора ЕСТЬ NULL
		|
		|ОБЪЕДИНИТЬ
		|
		|ВЫБРАТЬ
		|	ЗначенияПользователяЭлементовКонструктора.ВидПродукции КАК ВидПродукции
		|ИЗ
		|	РегистрСведений.ЗначенияПользователяЭлементовКонструктораВидовПродукцииИС КАК ЗначенияПользователяЭлементовКонструктора
		|ГДЕ
		|	ЗначенияПользователяЭлементовКонструктора.ЭлементКонструктора В (&Подсистемы)
		|	И НЕ ЗначенияПользователяЭлементовКонструктора.ПометкаУдаления
		|;
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ЗначенияЭлементовКонструктора.ЭлементКонструктора КАК ЭлементКонструктора,
		|	ЗначенияЭлементовКонструктора.ВидПродукции КАК ВидПродукции,
		|	ЗначенияЭлементовКонструктора.Значение КАК Значение
		|ПОМЕСТИТЬ ЗначенияЭлементовКонструктора
		|ИЗ
		|	ДоступныеВидыПродукции КАК ДоступныеВидыПродукции
		|	ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.ЗначенияЭлементовКонструктораВидовПродукцииИС КАК ЗначенияЭлементовКонструктора
		|		ПО ДоступныеВидыПродукции.ВидПродукции = ЗначенияЭлементовКонструктора.ВидПродукции
		|ГДЕ
		|	ЗначенияЭлементовКонструктора.ЭлементКонструктора.Предопределенный
		|	И НЕ ЗначенияЭлементовКонструктора.ЭлементКонструктора.ЭтоГруппа
		|	И НЕ ЗначенияЭлементовКонструктора.ЭлементКонструктора В (&ЭлементыПоВсемВидамПродукции)
		|;
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ЗначенияПользователяЭлементовКонструктора.ЭлементКонструктора КАК ЭлементКонструктора,
		|	ЗначенияПользователяЭлементовКонструктора.ВидПродукции КАК ВидПродукции,
		|	ЗначенияПользователяЭлементовКонструктора.Значение КАК Значение,
		|	ЗначенияПользователяЭлементовКонструктора.ПометкаУдаления КАК ПометкаУдаления
		|ПОМЕСТИТЬ ЗначенияПользователяЭлементовКонструктора
		|ИЗ
		|	ДоступныеВидыПродукции КАК ДоступныеВидыПродукции
		|	ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.ЗначенияПользователяЭлементовКонструктораВидовПродукцииИС КАК ЗначенияПользователяЭлементовКонструктора
		|		ПО ДоступныеВидыПродукции.ВидПродукции = ЗначенияПользователяЭлементовКонструктора.ВидПродукции
		|ГДЕ
		|	ЗначенияПользователяЭлементовКонструктора.ЭлементКонструктора.Предопределенный
		|	И НЕ ЗначенияПользователяЭлементовКонструктора.ЭлементКонструктора.ЭтоГруппа
		|	И НЕ ЗначенияПользователяЭлементовКонструктора.ЭлементКонструктора В (&ЭлементыПоВсемВидамПродукции)
		|;
		|ВЫБРАТЬ
		|	ЗначенияЭлементовКонструктора.ЭлементКонструктора КАК ЭлементКонструктора,
		|	ЗначенияЭлементовКонструктора.ВидПродукции КАК ВидПродукции,
		|	ЗначенияЭлементовКонструктора.Значение КАК Значение
		|ПОМЕСТИТЬ ЗначенияЭлементовКонструктораПоВсемВП
		|ИЗ
		|	РегистрСведений.ЗначенияЭлементовКонструктораВидовПродукцииИС КАК ЗначенияЭлементовКонструктора
		|ГДЕ
		|	ЗначенияЭлементовКонструктора.ЭлементКонструктора.Предопределенный
		|	И НЕ ЗначенияЭлементовКонструктора.ЭлементКонструктора.ЭтоГруппа
		|	И ЗначенияЭлементовКонструктора.ЭлементКонструктора В (&ЭлементыПоВсемВидамПродукции)
		|;
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ЗначенияПользователяЭлементовКонструктора.ЭлементКонструктора КАК ЭлементКонструктора,
		|	ЗначенияПользователяЭлементовКонструктора.ВидПродукции КАК ВидПродукции,
		|	ЗначенияПользователяЭлементовКонструктора.Значение КАК Значение,
		|	ЗначенияПользователяЭлементовКонструктора.ПометкаУдаления КАК ПометкаУдаления
		|ПОМЕСТИТЬ ЗначенияПользователяЭлементовКонструктораПоВсемВП
		|ИЗ
		|	РегистрСведений.ЗначенияПользователяЭлементовКонструктораВидовПродукцииИС КАК ЗначенияПользователяЭлементовКонструктора
		|ГДЕ
		|	ЗначенияПользователяЭлементовКонструктора.ЭлементКонструктора.Предопределенный
		|	И НЕ ЗначенияПользователяЭлементовКонструктора.ЭлементКонструктора.ЭтоГруппа
		|	И ЗначенияПользователяЭлементовКонструктора.ЭлементКонструктора В (&ЭлементыПоВсемВидамПродукции)
		|;
		|ВЫБРАТЬ
		|	ЗначенияЭлементовКонструктора.ЭлементКонструктора КАК ЭлементКонструктора,
		|	ЗначенияЭлементовКонструктора.ВидПродукции КАК ВидПродукции,
		|	ЗначенияЭлементовКонструктора.Значение КАК Значение,
		|	ЛОЖЬ КАК ЭтоЗначениеПользователя,
		|	ЗначенияАтрибутов.Атрибуты КАК Атрибуты
		|ИЗ
		|	ЗначенияЭлементовКонструктора КАК ЗначенияЭлементовКонструктора
		|	ЛЕВОЕ СОЕДИНЕНИЕ ЗначенияПользователяЭлементовКонструктора КАК ЗначенияПользователяЭлементовКонструктора
		|		ПО ЗначенияЭлементовКонструктора.ЭлементКонструктора = ЗначенияПользователяЭлементовКонструктора.ЭлементКонструктора
		|		И ЗначенияЭлементовКонструктора.ВидПродукции = ЗначенияПользователяЭлементовКонструктора.ВидПродукции
		|		И ЗначенияЭлементовКонструктора.Значение = ЗначенияПользователяЭлементовКонструктора.Значение
		|	ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.ЗначенияЭлементовКонструктораВидовПродукцииИС КАК ЗначенияАтрибутов
		|		ПО ЗначенияЭлементовКонструктора.ЭлементКонструктора = ЗначенияАтрибутов.ЭлементКонструктора
		|		И ЗначенияЭлементовКонструктора.ВидПродукции = ЗначенияАтрибутов.ВидПродукции
		|		И ЗначенияЭлементовКонструктора.Значение = ЗначенияАтрибутов.Значение
		|ГДЕ
		|	ЗначенияПользователяЭлементовКонструктора.ЭлементКонструктора ЕСТЬ NULL
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	ЗначенияПользователяЭлементовКонструктора.ЭлементКонструктора КАК ЭлементКонструктора,
		|	ЗначенияПользователяЭлементовКонструктора.ВидПродукции КАК ВидПродукции,
		|	ЗначенияПользователяЭлементовКонструктора.Значение КАК Значение,
		|	ИСТИНА КАК ЭтоЗначениеПользователя,
		|	ЗначенияАтрибутов.Атрибуты КАК Атрибуты
		|ИЗ
		|	ЗначенияПользователяЭлементовКонструктора КАК ЗначенияПользователяЭлементовКонструктора
		|	ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.ЗначенияПользователяЭлементовКонструктораВидовПродукцииИС КАК ЗначенияАтрибутов
		|		ПО ЗначенияПользователяЭлементовКонструктора.ЭлементКонструктора = ЗначенияАтрибутов.ЭлементКонструктора
		|		И ЗначенияПользователяЭлементовКонструктора.ВидПродукции = ЗначенияАтрибутов.ВидПродукции
		|		И ЗначенияПользователяЭлементовКонструктора.Значение = ЗначенияАтрибутов.Значение
		|ГДЕ
		|	НЕ ЗначенияПользователяЭлементовКонструктора.ПометкаУдаления
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	ЭлементыКонструктора.Ссылка КАК ЭлементКонструктора,
		|	ЗНАЧЕНИЕ(Справочник.ВидыПродукцииИС.ПустаяСсылка) КАК ВидПродукции,
		|	НЕОПРЕДЕЛЕНО КАК Значение,
		|	ЛОЖЬ КАК ЭтоЗначениеПользователя,
		|	НЕОПРЕДЕЛЕНО КАК Атрибуты
		|ИЗ
		|	Справочник.ЭлементыКонструктораВидовПродукцииИС КАК ЭлементыКонструктора
		|	ЛЕВОЕ СОЕДИНЕНИЕ ЗначенияЭлементовКонструктора КАК ЗначенияЭлементовКонструктора
		|	ПО ЭлементыКонструктора.Ссылка = ЗначенияЭлементовКонструктора.ЭлементКонструктора
		|	ЛЕВОЕ СОЕДИНЕНИЕ ЗначенияПользователяЭлементовКонструктора КАК ЗначенияПользователяЭлементовКонструктора
		|	ПО ЭлементыКонструктора.Ссылка = ЗначенияПользователяЭлементовКонструктора.ЭлементКонструктора
		|ГДЕ
		|	ЭлементыКонструктора.Предопределенный
		|	И НЕ ЭлементыКонструктора.ЭтоГруппа
		|	И ЗначенияЭлементовКонструктора.ЭлементКонструктора ЕСТЬ NULL
		|	И ЗначенияПользователяЭлементовКонструктора.ЭлементКонструктора ЕСТЬ NULL
		|	И НЕ ЭлементыКонструктора.Ссылка В (&ЭлементыПоВсемВидамПродукции)
		|	
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	ЗначенияЭлементовКонструктора.ЭлементКонструктора КАК ЭлементКонструктора,
		|	ЗначенияЭлементовКонструктора.ВидПродукции КАК ВидПродукции,
		|	ЗначенияЭлементовКонструктора.Значение КАК Значение,
		|	ЛОЖЬ КАК ЭтоЗначениеПользователя,
		|	ЗначенияАтрибутов.Атрибуты КАК Атрибуты
		|ИЗ
		|	ЗначенияЭлементовКонструктораПоВсемВП КАК ЗначенияЭлементовКонструктора
		|	ЛЕВОЕ СОЕДИНЕНИЕ ЗначенияПользователяЭлементовКонструктораПоВсемВП КАК ЗначенияПользователяЭлементовКонструктора
		|		ПО ЗначенияЭлементовКонструктора.ЭлементКонструктора = ЗначенияПользователяЭлементовКонструктора.ЭлементКонструктора
		|		И ЗначенияЭлементовКонструктора.ВидПродукции = ЗначенияПользователяЭлементовКонструктора.ВидПродукции
		|		И ЗначенияЭлементовКонструктора.Значение = ЗначенияПользователяЭлементовКонструктора.Значение
		|	ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.ЗначенияЭлементовКонструктораВидовПродукцииИС КАК ЗначенияАтрибутов
		|		ПО ЗначенияЭлементовКонструктора.ЭлементКонструктора = ЗначенияАтрибутов.ЭлементКонструктора
		|		И ЗначенияЭлементовКонструктора.ВидПродукции = ЗначенияАтрибутов.ВидПродукции
		|		И ЗначенияЭлементовКонструктора.Значение = ЗначенияАтрибутов.Значение
		|ГДЕ
		|	ЗначенияПользователяЭлементовКонструктора.ЭлементКонструктора ЕСТЬ NULL
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	ЗначенияПользователяЭлементовКонструктора.ЭлементКонструктора КАК ЭлементКонструктора,
		|	ЗначенияПользователяЭлементовКонструктора.ВидПродукции КАК ВидПродукции,
		|	ЗначенияПользователяЭлементовКонструктора.Значение КАК Значение,
		|	ИСТИНА КАК ЭтоЗначениеПользователя,
		|	ЗначенияАтрибутов.Атрибуты КАК Атрибуты
		|ИЗ
		|	ЗначенияПользователяЭлементовКонструктораПоВсемВП КАК ЗначенияПользователяЭлементовКонструктора
		|	ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.ЗначенияПользователяЭлементовКонструктораВидовПродукцииИС КАК ЗначенияАтрибутов
		|		ПО ЗначенияПользователяЭлементовКонструктора.ЭлементКонструктора = ЗначенияАтрибутов.ЭлементКонструктора
		|		И ЗначенияПользователяЭлементовКонструктора.ВидПродукции = ЗначенияАтрибутов.ВидПродукции
		|		И ЗначенияПользователяЭлементовКонструктора.Значение = ЗначенияАтрибутов.Значение
		|ГДЕ
		|	НЕ ЗначенияПользователяЭлементовКонструктора.ПометкаУдаления
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	ЭлементыКонструктора.Ссылка КАК ЭлементКонструктора,
		|	ЗНАЧЕНИЕ(Справочник.ВидыПродукцииИС.ПустаяСсылка) КАК ВидПродукции,
		|	НЕОПРЕДЕЛЕНО КАК Значение,
		|	ЛОЖЬ КАК ЭтоЗначениеПользователя,
		|	НЕОПРЕДЕЛЕНО КАК Атрибуты
		|ИЗ
		|	Справочник.ЭлементыКонструктораВидовПродукцииИС КАК ЭлементыКонструктора
		|	ЛЕВОЕ СОЕДИНЕНИЕ ЗначенияЭлементовКонструктораПоВсемВП КАК ЗначенияЭлементовКонструктора
		|	ПО ЭлементыКонструктора.Ссылка = ЗначенияЭлементовКонструктора.ЭлементКонструктора
		|	ЛЕВОЕ СОЕДИНЕНИЕ ЗначенияПользователяЭлементовКонструктораПоВсемВП КАК ЗначенияПользователяЭлементовКонструктора
		|	ПО ЭлементыКонструктора.Ссылка = ЗначенияПользователяЭлементовКонструктора.ЭлементКонструктора
		|ГДЕ
		|	ЭлементыКонструктора.Предопределенный
		|	И НЕ ЭлементыКонструктора.ЭтоГруппа
		|	И ЗначенияЭлементовКонструктора.ЭлементКонструктора ЕСТЬ NULL
		|	И ЗначенияПользователяЭлементовКонструктора.ЭлементКонструктора ЕСТЬ NULL
		|	И ЭлементыКонструктора.Ссылка В (&ЭлементыПоВсемВидамПродукции)
		|	
		|ИТОГИ ПО
		|	ЭлементКонструктора,
		|	ВидПродукции";
		
		ВыборкаЭлементКонструктора = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		Пока ВыборкаЭлементКонструктора.Следующий() Цикл
			Параметры = ПараметрыЭлементовКонструктора[ВыборкаЭлементКонструктора.ЭлементКонструктора];
			Если Параметры = Неопределено Тогда
				Продолжить;
			КонецЕсли;
			
			ВидыПродукции = Новый Соответствие;
			
			ВыборкаВидПродукции = ВыборкаЭлементКонструктора.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
			Пока ВыборкаВидПродукции.Следующий() Цикл
				Если Не ЗначениеЗаполнено(ВыборкаВидПродукции.ВидПродукции) Тогда
					Продолжить;
				КонецЕсли;
				Выборка = ВыборкаВидПродукции.Выбрать();
				Значения = Новый Соответствие;
				ЗначениеПользователя = Неопределено;
				Пока Выборка.Следующий() Цикл
					Атрибуты = Новый Структура;
					Если Параметры.Параметризуется Тогда
						Если Выборка.Значение = Неопределено Тогда
							Продолжить;
						КонецЕсли;
						Значение = Выборка.Значение;
					ИначеЕсли Параметры.ИспользоватьАтрибуты Тогда
						Значение = КлючАтрибутовВидаПродукции;
					Иначе
						Продолжить;
					КонецЕсли;
					Если Параметры.ИспользоватьАтрибуты Тогда
						Если Выборка.Атрибуты <> Неопределено Тогда
							АтрибутыЭлемента = Выборка.Атрибуты.Получить();
							Если ТипЗнч(АтрибутыЭлемента) = Тип("Структура") Тогда
								Атрибуты = АтрибутыЭлемента;
							КонецЕсли;
						КонецЕсли;
					КонецЕсли;
					Значения.Вставить(Значение, Атрибуты);
					Если Параметры.КаждомуВидуПродукцииСоответствуетОдноЗначение
						И Выборка.ЭтоЗначениеПользователя Тогда
						ЗначениеПользователя = Значение;
					КонецЕсли;
				КонецЦикла;
				Если ЗначениеПользователя <> Неопределено
					И Значения.Количество() > 1 Тогда
					Атрибуты = Значения[ЗначениеПользователя];
					Значения.Очистить();
					Значения.Вставить(ЗначениеПользователя, Атрибуты);
				КонецЕсли;
				ВидыПродукции.Вставить(ВыборкаВидПродукции.ВидПродукции, Значения);
			КонецЦикла;
			ДанныеЭлемента = Новый Структура;
			ДанныеЭлемента.Вставить("Параметризуется", Параметры.Параметризуется);
			ДанныеЭлемента.Вставить("ВидыПродукции", ВидыПродукции);
			Результат.Вставить(ВыборкаЭлементКонструктора.ЭлементКонструктора, ДанныеЭлемента);
		КонецЦикла;
		
	КонецЕсли;
	
	УстановитьПривилегированныйРежим(Ложь);
	
	Возврат Результат;
	
КонецФункции

