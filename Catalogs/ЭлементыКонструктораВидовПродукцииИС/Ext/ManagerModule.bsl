		ОбщегоНазначения.ОписаниеТипаСтрока(15));

	//
	ДобавитьПараметризуемыеЭлементы(Результат, ПолеСпособВводаВОборот,
		Тип("ПеречислениеСсылка.ВидыОперацийИСМП")); // СпособыВводаВОборотСУЗ в расширенной версии
	
	//
	ПараметризуемыеЭлементы = Новый Массив;
	ПараметризуемыеЭлементы.Добавить(АгрегацияЧерезГИСМТ);
	ПараметризуемыеЭлементы.Добавить(АгрегацияЧерезСУЗ);
	ПараметризуемыеЭлементы.Добавить(ВидыУпаковок);
	ПараметризуемыеЭлементы.Добавить(ДопустимыеВидыУпаковокВнутриЛогистическойУпаковки);
	ДобавитьПараметризуемыеЭлементы(Результат, ПараметризуемыеЭлементы,
		Тип("ПеречислениеСсылка.ВидыУпаковокИС"));
	
	// 
	Результат[ВидыУпаковок].ПоВсемВидамПродукции = Истина;
	Результат[ВидыУпаковок].ИспользоватьАтрибуты = Истина;
	АтрибутыВидовУпаковок = КонструкторИСОбщегоНазначенияКлиентСервер.АтрибутыВидовУпаковок();
	Для Каждого КлючИЗначение Из АтрибутыВидовУпаковок Цикл
		Результат[ВидыУпаковок].Атрибуты.Вставить(КлючИЗначение.Ключ, КлючИЗначение.Значение.ОписаниеТипа);
	КонецЦикла;
	Результат[ВидыУпаковок].Атрибуты.Вставить(
		"СокращенноеПредставление", ОбщегоНазначения.ОписаниеТипаСтрока(50));
	
	//
	ПараметризуемыеЭлементы = Новый Массив;
	ПараметризуемыеЭлементы.Добавить(МинимальнаяДлинаКодаЛогистическойУпаковки);
	ПараметризуемыеЭлементы.Добавить(МаксимальнаяДлинаКодаЛогистическойУпаковки);
	ДобавитьПараметризуемыеЭлементы(Результат, ПараметризуемыеЭлементы,
		ОбщегоНазначения.ОписаниеТипаЧисло(3));
	
	//
	ПараметризуемыеЭлементы = Новый Массив;
	ПараметризуемыеЭлементы.Добавить(ДопустимыеТипыШтрихкодовВнутриSSCC);
	ПараметризуемыеЭлементы.Добавить(ДопустимыеТипыШтрихкодовВнутриGS1);
	ДобавитьПараметризуемыеЭлементы(Результат, ПараметризуемыеЭлементы,
		Тип("ПеречислениеСсылка.ТипыШтрихкодов"),
		Тип("ПеречислениеСсылка.ВидыУпаковокИС"));
	
	//
	ДобавитьПараметризуемыеЭлементы(Результат, КоэффициентПересчетаКоличестваЧастичногоВыбытияДляРазрешительногоРежима,
		ОбщегоНазначения.ОписаниеТипаЧисло(4, 3, ДопустимыйЗнак.Неотрицательный));
	
	//
	ДобавитьПараметризуемыеЭлементы(Результат, СвязьЭлементаСправочникаИЗначенияПеречисленияВидаПродукции,
		Тип("ПеречислениеСсылка.ВидыПродукцииИС"));
	Результат[СвязьЭлементаСправочникаИЗначенияПеречисленияВидаПродукции].ПоВсемВидамПродукции = Истина;
	
	//
	ДобавитьПараметризуемыеЭлементы(Результат, ЧастичноеВыбытие,
		Тип("ПеречислениеСсылка.ВидыОперацийИСМП"),
		Тип("ПеречислениеСсылка.ВидыДокументовЕГАИС"));
	
	//
	ДобавитьПараметризуемыеЭлементы(Результат, МераКоличестваПредметаРасчетаПриЧастичномВыбытии,
		Тип("ПеречислениеСсылка.МераКоличестваПредметаРасчетаККТ"));
	Результат[МераКоличестваПредметаРасчетаПриЧастичномВыбытии].КаждомуВидуПродукцииСоответствуетОдноЗначение = Истина;
	
	Результат[ВУПДПередаватьКодФИАСОтправителя].ИспользоватьАтрибуты = Истина;
	Результат[ВУПДПередаватьКодФИАСОтправителя].Атрибуты.Вставить(
		"ИндивидуальныйПредприниматель", Новый ОписаниеТипов("Булево"));
	Результат[ВУПДПередаватьКодФИАСОтправителя].Атрибуты.Вставить(
		"ЮридическоеЛицо", Новый ОписаниеТипов("Булево"));
	Результат[ВУПДПередаватьКодФИАСОтправителя].Атрибуты.Вставить(
		"ПоднадзорныйОбъектВЕТИС", Новый ОписаниеТипов("Булево"));
		
	Результат[ВУПДПередаватьКодФИАСПолучателя].ИспользоватьАтрибуты = Истина;
	Результат[ВУПДПередаватьКодФИАСПолучателя].Атрибуты.Вставить(
		"ИндивидуальныйПредприниматель", Новый ОписаниеТипов("Булево"));
	Результат[ВУПДПередаватьКодФИАСПолучателя].Атрибуты.Вставить(
		"ЮридическоеЛицо", Новый ОписаниеТипов("Булево"));
	Результат[ВУПДПередаватьКодФИАСПолучателя].Атрибуты.Вставить(
		"ПоднадзорныйОбъектВЕТИС", Новый ОписаниеТипов("Булево"));
	
	Если ОбщегоНазначенияИСКлиентСерверПовтИсп.ЭтоРасширеннаяВерсияГосИС() Тогда
		МодульИнтеграцияИС = ОбщегоНазначенияИСПовтИсп.ОбщийМодуль("ИнтеграцияИС"); // - ОбщийМодуль.ИнтеграцияИС
		МодульИнтеграцияИС.ДополнитьПараметрыЭлементовКонструктора(Результат);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Получает предопределенные параметры элемента конструктора.
// 
// Параметры:
//   ЭлементКонструктора - СправочникСсылка.ЭлементыКонструктораВидовПродукцииИС - элемент конструктора.
// 
// Возвращаемое значение:
//  см. НачальныеПараметрыЭлементаКонструктора
//
Функция ПараметрыЭлементаКонструктора(ЭлементКонструктора) Экспорт
	
	ПараметрыЭлементовКонструктора = ПараметрыЭлементовКонструктора();
	Параметры = ПараметрыЭлементовКонструктора[ЭлементКонструктора];
	Если Параметры = Неопределено Тогда
		Возврат НачальныеПараметрыЭлементаКонструктора();
	КонецЕсли;
	
	Возврат Параметры;
	
КонецФункции

#Область ДляВызоваИзДругихПодсистем

// Возвращает реквизиты справочника, которые образуют естественный ключ
// для элементов справочника.
//
// Возвращаемое значение:
//  Массив из Строка - массив имен реквизитов, образующих естественный ключ.
//
Функция ПоляЕстественногоКлюча() Экспорт
	
	Результат = Новый Массив();
	Результат.Добавить("ИмяПредопределенныхДанных");
	Возврат Результат;
	
КонецФункции

#КонецОбласти

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Получает начальные параметры для элемента конструктора.
// 
// Возвращаемое значение:
//   Структура из КлючИЗначение:
//     * Ключ1     - Строка - Параметризуется.
//     * Значение1 - Булево - если Истина, тогда для вида продукции возможно указание значений.
//     * Ключ2     - Строка - ТипЗначения.
//     * Значение2 - ОписаниеТипов - типы используемого значения.
//     * Ключ3     - Строка - КаждомуВидуПродукцииСоответствуетОдноЗначение.
//     * Значение3 - Булево - если Истина, тогда для вида продукции возможно указание только одного значения.
//     * Ключ4     - Строка - ИспользоватьАтрибуты.
//     * Значение4 - Булево - если Истина, тогда доступно использование атрибутов.
//     * Ключ5     - Строка - Атрибуты.
//     * Значение5 - Структура из КлючИЗначение:
//         * Ключ     - Строка - имя атрибута.
//         * Значение - ОписаниеТипов - типы атрибута.
//
Функция НачальныеПараметрыЭлементаКонструктора()
	
	Результат = Новый Структура;
	Результат.Вставить("Параметризуется",      Ложь);
	Результат.Вставить("ТипЗначения",          Новый ОписаниеТипов("Неопределено"));
	Результат.Вставить("КаждомуВидуПродукцииСоответствуетОдноЗначение", Ложь);
	Результат.Вставить("ИспользоватьАтрибуты", Ложь);
	Результат.Вставить("Атрибуты",             Новый Структура);
	Результат.Вставить("ИзменяетсяВИнтерфейсеПользователя", Ложь);
	Результат.Вставить("ПоВсемВидамПродукции", Ложь);
	
	Возврат Результат;
	
КонецФункции

Функция ЭлементыПоВсемВидамПродукции(ПараметрыЭлементовКонструктора)
	
	Результат = Новый Массив;
	
	Для Каждого КлючИЗначение Из ПараметрыЭлементовКонструктора Цикл
		Если КлючИЗначение.Значение.ПоВсемВидамПродукции Тогда
			Результат.Добавить(КлючИЗначение.Ключ);
		КонецЕсли;
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Процедура ДобавитьСтандартныеЭлементы(Результат, СтандартныеЭлементы)
	
	Для Каждого Элемент Из СтандартныеЭлементы Цикл
		Результат.Вставить(Элемент, НачальныеПараметрыЭлементаКонструктора());
	КонецЦикла;
	
КонецПроцедуры

Процедура ДобавитьДаты(Результат, Даты)
	
	Для Каждого ЭлементМассива Из Даты Цикл
		Результат.Вставить(ЭлементМассива, НачальныеПараметрыЭлементаКонструктора());
		Результат[ЭлементМассива].Параметризуется = Истина;
		Результат[ЭлементМассива].ТипЗначения = ОбщегоНазначения.ОписаниеТипаДата(ЧастиДаты.Дата);
		Результат[ЭлементМассива].КаждомуВидуПродукцииСоответствуетОдноЗначение = Истина;
	КонецЦикла;
	
КонецПроцедуры

Процедура ДобавитьПараметризуемыеЭлементы(Результат, ПараметризуемыеЭлементы, ДоступныеТипы1, ДоступныеТипы2 = Неопределено, ДоступныеТипы3 = Неопределено, ДоступныеТипы4 = Неопределено) Экспорт

	Если ТипЗнч(ПараметризуемыеЭлементы) = Тип("Массив") Тогда
		Элементы = ПараметризуемыеЭлементы;
	Иначе
		Элементы = ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(ПараметризуемыеЭлементы);
	КонецЕсли;

	Типы = Новый Массив;

	Если ТипЗнч(ДоступныеТипы1) = Тип("Массив") Тогда
		ОбщегоНазначенияКлиентСервер.ДополнитьМассив(Типы, ДоступныеТипы1, Истина);
	Иначе
		Типы.Добавить(ДоступныеТипы1);
	КонецЕсли;

	Если ДоступныеТипы2 <> Неопределено Тогда
		Если ТипЗнч(ДоступныеТипы2) = Тип("Массив") Тогда
			ОбщегоНазначенияКлиентСервер.ДополнитьМассив(Типы, ДоступныеТипы2, Истина);
		Иначе
			Типы.Добавить(ДоступныеТипы2);
		КонецЕсли;
	КонецЕсли;

	Если ДоступныеТипы3 <> Неопределено Тогда
		Если ТипЗнч(ДоступныеТипы3) = Тип("Массив") Тогда
			ОбщегоНазначенияКлиентСервер.ДополнитьМассив(Типы, ДоступныеТипы3, Истина);
		Иначе
			Типы.Добавить(ДоступныеТипы3);
		КонецЕсли;
	КонецЕсли;
	
	Если ДоступныеТипы4 <> Неопределено Тогда
		Если ТипЗнч(ДоступныеТипы4) = Тип("Массив") Тогда
			ОбщегоНазначенияКлиентСервер.ДополнитьМассив(Типы, ДоступныеТипы4, Истина);
		Иначе
			Типы.Добавить(ДоступныеТипы4);
		КонецЕсли;
	КонецЕсли;
	
	Квалификаторы = Новый Структура("КвалификаторыДаты,КвалификаторыДвоичныхДанных,КвалификаторыСтроки,КвалификаторыЧисла");
	ВГраница = Типы.ВГраница();
	Для Счетчик = 0 По ВГраница Цикл
		Индекс = ВГраница - Счетчик;
		Тип = Типы[Индекс];
		Если ТипЗнч(Тип) = Тип("ОписаниеТипов") Тогда
			Если Тип.СодержитТип(Тип("Дата")) Тогда
				Квалификаторы.КвалификаторыДаты = Тип.КвалификаторыДаты;
			КонецЕсли;
			Если Тип.СодержитТип(Тип("ДвоичныеДанные")) Тогда
				Квалификаторы.КвалификаторыДвоичныхДанных = Тип.КвалификаторыДвоичныхДанных;
			КонецЕсли;
			Если Тип.СодержитТип(Тип("Строка")) Тогда
				Квалификаторы.КвалификаторыСтроки = Тип.КвалификаторыСтроки;
			КонецЕсли;
			Если Тип.СодержитТип(Тип("Число")) Тогда
				Квалификаторы.КвалификаторыЧисла = Тип.КвалификаторыЧисла;
			КонецЕсли;
			Типы.Удалить(Индекс);
			ОбщегоНазначенияКлиентСервер.ДополнитьМассив(Типы, Тип.Типы(), Истина);
		КонецЕсли;
	КонецЦикла;

	Для Каждого ПараметризуемыйЭлемент Из Элементы Цикл
		
		СуществующийЭлемент = Результат[ПараметризуемыйЭлемент];
		Если СуществующийЭлемент = Неопределено Тогда
			Результат.Вставить(ПараметризуемыйЭлемент, НачальныеПараметрыЭлементаКонструктора());
			Результат[ПараметризуемыйЭлемент].ТипЗначения = Новый ОписаниеТипов(Типы,
				Квалификаторы.КвалификаторыЧисла,
				Квалификаторы.КвалификаторыСтроки,
				Квалификаторы.КвалификаторыДаты,
				Квалификаторы.КвалификаторыДвоичныхДанных);
		Иначе
			КвалификаторыЧисла          = ?(Квалификаторы.КвалификаторыЧисла = Неопределено, СуществующийЭлемент.ТипЗначения.КвалификаторыЧисла, Квалификаторы.КвалификаторыЧисла);
			КвалификаторыСтроки         = ?(Квалификаторы.КвалификаторыСтроки = Неопределено, СуществующийЭлемент.ТипЗначения.КвалификаторыСтроки, Квалификаторы.КвалификаторыСтроки);
			КвалификаторыДаты           = ?(Квалификаторы.КвалификаторыДаты = Неопределено, СуществующийЭлемент.ТипЗначения.КвалификаторыДаты, Квалификаторы.КвалификаторыДаты);
			КвалификаторыДвоичныхДанных = ?(Квалификаторы.КвалификаторыДвоичныхДанных = Неопределено, СуществующийЭлемент.ТипЗначения.КвалификаторыДвоичныхДанных, Квалификаторы.КвалификаторыДвоичныхДанных);
			СуществующийЭлемент.ТипЗначения = Новый ОписаниеТипов(
				СуществующийЭлемент.ТипЗначения,
				Типы,,
				КвалификаторыЧисла,
				КвалификаторыСтроки,
				КвалификаторыДаты,
				КвалификаторыДвоичныхДанных);
		КонецЕсли;
		Результат[ПараметризуемыйЭлемент].Параметризуется = Истина;
		
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти

#КонецЕсли