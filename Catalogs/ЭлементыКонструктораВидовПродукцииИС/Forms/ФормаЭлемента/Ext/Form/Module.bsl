
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	УстановитьУсловноеОформление();
	
	Если Параметры.Свойство("АвтоТест") Тогда
		Возврат;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Объект.Ссылка) Тогда
		КонструкторИСОбщегоНазначенияКлиентСервер.ДанныеЭлементаКонструктора(Объект.Ссылка);
	КонецЕсли;
	
	ПроверитьВозможностьИспользования(Отказ);
	
	Если Отказ Тогда
		Возврат;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ПриЧтенииНаСервере(ТекущийОбъект)
	
	ОбновитьДанныеФормы();
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	Если ИмяСобытия = "ИзменениеДанныхКонструктораВидовПродукцииИС" Тогда
		ОбновитьДанныеФормы();
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыЗначения

&НаКлиенте
Процедура ЗначенияВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	ТекущиеДанные = Элемент.ТекущиеДанные;
	
	ПараметрыОткрытия = Новый Структура;
	
	Если ТекущиеДанные.СтатусСтроки = 5 Тогда
		ИмяРегистра = "ЗначенияЭлементовКонструктораВидовПродукцииИС";
		ПараметрыОткрытия.Вставить("ТолькоПросмотр", Истина);
	Иначе
		ИмяРегистра = "ЗначенияПользователяЭлементовКонструктораВидовПродукцииИС";
	КонецЕсли;
	
	ПараметрыКлючаЗаписи = Новый Структура;
	ПараметрыКлючаЗаписи.Вставить("ЭлементКонструктора", Объект.Ссылка);
	ПараметрыКлючаЗаписи.Вставить("ВидПродукции",        ТекущиеДанные.ВидПродукции);
	ПараметрыКлючаЗаписи.Вставить("Значение",            ТекущиеДанные.Значение);
	
	ПараметрыОткрытия.Вставить("Ключ", ПолучитьКлючЗаписи(ИмяРегистра, ПараметрыКлючаЗаписи));
	
	ОткрытьФорму(СтрШаблон("РегистрСведений.%1.ФормаЗаписи", ИмяРегистра),
		ПараметрыОткрытия,
		ЭтотОбъект);
	
КонецПроцедуры

&НаКлиенте
Процедура ЗначенияПередНачаломДобавления(Элемент, Отказ, Копирование, Родитель, ЭтоГруппа, Параметр)
	
	Отказ = Истина;
	
	ПараметрыОткрытия = Новый Структура;
	ПараметрыОткрытия.Вставить("ЗначенияЗаполнения", Новый Структура);
	ПараметрыОткрытия.ЗначенияЗаполнения.Вставить("ЭлементКонструктора", Объект.Ссылка);
	
	Если Копирование Тогда
		ТекущиеДанные = Элемент.ТекущиеДанные;
		Если ТекущиеДанные <> Неопределено Тогда
			ПараметрыОткрытия.ЗначенияЗаполнения.Вставить("ВидПродукции", ТекущиеДанные.ВидПродукции);
			ПараметрыОткрытия.ЗначенияЗаполнения.Вставить("Значение", ТекущиеДанные.Значение);
		КонецЕсли;
	КонецЕсли;
	
	ОткрытьФорму("РегистрСведений.ЗначенияПользователяЭлементовКонструктораВидовПродукцииИС.ФормаЗаписи",
		ПараметрыОткрытия,
		ЭтотОбъект,,,,
		ОписаниеОповещенияОкончаниеИзмененияЗначений());
	
КонецПроцедуры

&НаКлиенте
Процедура ЗначенияПередУдалением(Элемент, Отказ)
	
	Отказ = Истина;
	
	ПараметрыЗаписи = Новый Структура;
	ПараметрыЗаписи.Вставить("ЭлементКонструктора", Объект.Ссылка);
	ПараметрыЗаписи.Вставить("Данные", Новый Массив);
	
	ЕстьДанныеДляПометкиУдаления = Ложь;
	
	Для Каждого ВыделеннаяСтрока Из Элемент.ВыделенныеСтроки Цикл
		ТекущиеДанные = Значения.НайтиПоИдентификатору(ВыделеннаяСтрока);
		СтрокаДанных = Новый Структура;
		СтрокаДанных.Вставить("ИмяРегистра",     "ЗначенияПользователяЭлементовКонструктораВидовПродукцииИС");
		СтрокаДанных.Вставить("ВидПродукции",    ТекущиеДанные.ВидПродукции);
		СтрокаДанных.Вставить("Значение",        ТекущиеДанные.Значение);
		СтрокаДанных.Вставить("УдалитьЗапись",   Ложь);
		СтрокаДанных.Вставить("ПометкаУдаления", Ложь);
		Если ТекущиеДанные.СтатусСтроки = 3
			Или ТекущиеДанные.СтатусСтроки = 4 Тогда
			СтрокаДанных.УдалитьЗапись = Истина;
		ИначеЕсли ТекущиеДанные.СтатусСтроки = 5 Тогда
			СтрокаДанных.ПометкаУдаления = Истина;
			ЕстьДанныеДляПометкиУдаления = Истина;
		Иначе
			Продолжить;
		КонецЕсли;
		ПараметрыЗаписи.Данные.Добавить(СтрокаДанных);
	КонецЦикла;
	
	Если ЕстьДанныеДляПометкиУдаления Тогда
		УдалитьИзДанныхНеПомеченныеНаУдаление(ПараметрыЗаписи.Данные);
	КонецЕсли;
	
	Если ПараметрыЗаписи.Данные.Количество() > 0 Тогда
		ИзменитьДанныеРегистров(ПараметрыЗаписи);
		ОбновитьДанныеФормы();
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыМестаПрименения

