	КонецЕсли;
	
	ОткрытьФорму("РегистрСведений.МестаПримененияЭлементовКонструктораВидовПродукцииИС.ФормаЗаписи",
		ПараметрыОткрытия,
		ЭтотОбъект,,,,
		ОписаниеОповещенияОкончаниеИзмененияЗначений());
	
КонецПроцедуры

&НаКлиенте
Процедура МестаПримененияПередУдалением(Элемент, Отказ)
	
	Отказ = Истина;
	
	ПараметрыЗаписи = Новый Структура;
	ПараметрыЗаписи.Вставить("ЭлементКонструктора", Объект.Ссылка);
	ПараметрыЗаписи.Вставить("Данные", Новый Массив);
	
	ЕстьДанныеДляПометкиУдаления = Ложь;
	
	Для Каждого ВыделеннаяСтрока Из Элемент.ВыделенныеСтроки Цикл
		ТекущиеДанные = МестаПрименения.НайтиПоИдентификатору(ВыделеннаяСтрока);
		Если ТекущиеДанные.СтатусСтроки <> 0 Тогда
			СтрокаДанных = Новый Структура;
			СтрокаДанных.Вставить("ИмяРегистра",     "МестаПримененияЭлементовКонструктораВидовПродукцииИС");
			СтрокаДанных.Вставить("МестоПрименения", ТекущиеДанные.МестоПрименения);
			СтрокаДанных.Вставить("ПометкаУдаления", ТекущиеДанные.СтатусСтроки <> 4);
			Если СтрокаДанных.ПометкаУдаления Тогда
				ЕстьДанныеДляПометкиУдаления = Истина;
			КонецЕсли;
			ПараметрыЗаписи.Данные.Добавить(СтрокаДанных);
		КонецЕсли;
	КонецЦикла;
	
	Если ЕстьДанныеДляПометкиУдаления Тогда
		УдалитьИзДанныхНеПомеченныеНаУдаление(ПараметрыЗаписи.Данные);
	КонецЕсли;
	
	Если ПараметрыЗаписи.Данные.Количество() > 0 Тогда
		ИзменитьДанныеРегистров(ПараметрыЗаписи);
		ОбновитьДанныеФормы();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура МестаПримененияПриАктивизацииСтроки(Элемент)
	
	УстановитьПризнакИспользованияЗначенияПоМестуПрименения(ЭтотОбъект);
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыДоступныеЗначения

&НаКлиенте
Процедура ДоступныеЗначенияВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	МестаПримененияТекущиеДанные = Элементы.МестаПрименения.ТекущиеДанные;
	
	ПараметрыЗаписи = Новый Структура;
	ПараметрыЗаписи.Вставить("Данные", Новый Массив);
	
	Для Каждого ВыделеннаяСтрока Из Элемент.ВыделенныеСтроки Цикл
		СтрокаДанных = Новый Структура;
		СтрокаДанных.Вставить("ЗаписатьДоступноеЗначение", Ложь);
		СтрокаДанных.Вставить("ЗаписатьДоступноеЗначениеПоМестуПрименения", Ложь);
		ТекущиеДанные = ДоступныеЗначения.НайтиПоИдентификатору(ВыделеннаяСтрока);
		Если МестаПримененияТекущиеДанные.СтатусСтроки = 0
			И ТекущиеДанные.СтатусСтроки = СтатусСтрокиИспользуетсяИНедоступно() Тогда
			СтрокаДанных.ЗаписатьДоступноеЗначение = Истина;
		ИначеЕсли МестаПримененияТекущиеДанные.СтатусСтроки <> 0
			И Не ТекущиеДанные.ИспользуетсяПоМестуПрименения
			И ТекущиеДанные.СтатусСтроки <> 4 Тогда
			СтрокаДанных.ЗаписатьДоступноеЗначениеПоМестуПрименения = Истина;
			Если ТекущиеДанные.СтатусСтроки = СтатусСтрокиИспользуетсяИНедоступно() Тогда
				СтрокаДанных.ЗаписатьДоступноеЗначение = Истина;
			КонецЕсли;
		Иначе
			Продолжить;
		КонецЕсли;
		СтрокаДанных.Вставить("Значение", ТекущиеДанные.Значение);
		ПараметрыЗаписи.Данные.Добавить(СтрокаДанных);
	КонецЦикла;
	
	КоличествоДобавляемыхЗначений = ПараметрыЗаписи.Данные.Количество();
	Если КоличествоДобавляемыхЗначений > 0 Тогда
		
		ПараметрыЗаписи.Вставить("ЭлементКонструктора", Объект.Ссылка);
		ПараметрыЗаписи.Вставить("МестоПрименения",     МестаПримененияТекущиеДанные.МестоПрименения);
		
		Если КоличествоДобавляемыхЗначений = 1 Тогда
			ТекстДополнения = "";
			ТекстЗаголовка = НСтр("ru = 'Добавить доступное значение'");
		Иначе
			ТекстДополнения = СтрШаблон(НСтр(
				"ru = ' + еще (%1)'"),
				КоличествоДобавляемыхЗначений - 1);
			ТекстЗаголовка = НСтр("ru = 'Добавить доступные значения'");
		КонецЕсли;
		
		Если МестаПримененияТекущиеДанные.СтатусСтроки = 0 Тогда
			ТекстВопроса = СтрШаблон(НСтр(
				"ru = 'Добавить %1%2 в доступные значения?'"),
				ПараметрыЗаписи.Данные[0].Значение,
				ТекстДополнения);
		Иначе
			ТекстВопроса = СтрШаблон(НСтр(
				"ru = 'Добавить %1%2 в доступные значения по месту применения %3?'"),
				ПараметрыЗаписи.Данные[0].Значение,
				ТекстДополнения,
				МестаПримененияТекущиеДанные.МестоПрименения);
		КонецЕсли;
		
		ПоказатьВопрос(
			Новый ОписаниеОповещения("ВопросДобавитьДоступноеЗначение", ЭтотОбъект, ПараметрыЗаписи),
			ТекстВопроса,
			РежимДиалогаВопрос.ДаНет,,,
			ТекстЗаголовка);
		
	Иначе
		
		ТекущиеДанные = Элемент.ТекущиеДанные;
		ИмяРегистра = "ДоступныеЗначенияЭлементовКонструктораВидовПродукцииИС";
		
		ПараметрыКлючаЗаписи = Новый Структура;
		ПараметрыКлючаЗаписи.Вставить("ЭлементКонструктора", Объект.Ссылка);
		ПараметрыКлючаЗаписи.Вставить("Значение",            ТекущиеДанные.Значение);
		
		ПараметрыОткрытия = Новый Структура;
		ПараметрыОткрытия.Вставить("Ключ", ПолучитьКлючЗаписи(ИмяРегистра, ПараметрыКлючаЗаписи));
		ПараметрыОткрытия.Вставить("ТолькоПросмотр", Истина);
		
		ОткрытьФорму(СтрШаблон("РегистрСведений.%1.ФормаЗаписи", ИмяРегистра),
			ПараметрыОткрытия,
			ЭтотОбъект);
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ДоступныеЗначенияПередНачаломДобавления(Элемент, Отказ, Копирование, Родитель, ЭтоГруппа, Параметр)
	
	Отказ = Истина;
	
	ПараметрыОткрытия = Новый Структура;
	ПараметрыОткрытия.Вставить("ЗначенияЗаполнения", Новый Структура);
	ПараметрыОткрытия.ЗначенияЗаполнения.Вставить("ЭлементКонструктора", Объект.Ссылка);
	ПараметрыОткрытия.ЗначенияЗаполнения.Вставить("Изменен", Истина);
	
	Если Копирование Тогда
		ТекущиеДанные = Элемент.ТекущиеДанные;
		Если ТекущиеДанные <> Неопределено Тогда
			ПараметрыОткрытия.ЗначенияЗаполнения.Вставить("Значение", ТекущиеДанные.Значение);
		КонецЕсли;
	КонецЕсли;
	
	ОткрытьФорму("РегистрСведений.ДоступныеЗначенияЭлементовКонструктораВидовПродукцииИС.ФормаЗаписи",
		ПараметрыОткрытия,
		ЭтотОбъект,,,,
		ОписаниеОповещенияОкончаниеИзмененияЗначений());
	
КонецПроцедуры

&НаКлиенте
Процедура ДоступныеЗначенияПередУдалением(Элемент, Отказ)
	
	Отказ = Истина;
	
	ПараметрыЗаписи = Новый Структура;
	ПараметрыЗаписи.Вставить("ЭлементКонструктора", Объект.Ссылка);
	ПараметрыЗаписи.Вставить("Данные", Новый Массив);
	
	ЕстьДанныеДляПометкиУдаления = Ложь;
	
	МестаПримененияТекущиеДанные = Элементы.МестаПрименения.ТекущиеДанные;
	Если МестаПримененияТекущиеДанные.СтатусСтроки = 0 Тогда
		ИмяРегистра = "ДоступныеЗначенияЭлементовКонструктораВидовПродукцииИС";
	Иначе
		ИмяРегистра = "ДоступныеЗначенияПоМестамПримененияЭлементовКонструктораВидовПродукцииИС";
	КонецЕсли;
	
	Для Каждого ВыделеннаяСтрока Из Элемент.ВыделенныеСтроки Цикл
		ТекущиеДанные = ДоступныеЗначения.НайтиПоИдентификатору(ВыделеннаяСтрока);
		СтрокаДанных = Новый Структура;
		СтрокаДанных.Вставить("Значение",        ТекущиеДанные.Значение);
		СтрокаДанных.Вставить("ПометкаУдаления", ТекущиеДанные.СтатусСтроки <> 4);
		Если СтрокаДанных.ПометкаУдаления Тогда
			ЕстьДанныеДляПометкиУдаления = Истина;
		КонецЕсли;
		Если МестаПримененияТекущиеДанные.СтатусСтроки = 0
			И ТекущиеДанные.СтатусСтроки = СтатусСтрокиИспользуетсяИНедоступно() Тогда
			Продолжить;
		ИначеЕсли МестаПримененияТекущиеДанные.СтатусСтроки = 0
			Или ТекущиеДанные.СтатусСтроки = 4 Тогда
			ИмяРегистра = "ДоступныеЗначенияЭлементовКонструктораВидовПродукцииИС";
		ИначеЕсли Не ТекущиеДанные.ИспользуетсяПоМестуПрименения Тогда
			Продолжить;
		Иначе
			СтрокаДанных.Вставить("МестоПрименения", МестаПримененияТекущиеДанные.МестоПрименения);
			ИмяРегистра = "ДоступныеЗначенияПоМестамПримененияЭлементовКонструктораВидовПродукцииИС";
		КонецЕсли;
		СтрокаДанных.Вставить("ИмяРегистра", ИмяРегистра);
		ПараметрыЗаписи.Данные.Добавить(СтрокаДанных);
	КонецЦикла;
	
	Если ЕстьДанныеДляПометкиУдаления Тогда
		УдалитьИзДанныхНеПомеченныеНаУдаление(ПараметрыЗаписи.Данные);
	КонецЕсли;
	
	Если ПараметрыЗаписи.Данные.Количество() > 0 Тогда
		ИзменитьДанныеРегистров(ПараметрыЗаписи);
		ОбновитьДанныеФормы();
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

