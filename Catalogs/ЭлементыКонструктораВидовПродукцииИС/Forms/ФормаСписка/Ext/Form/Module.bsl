		"РегистрСведений.МестаПримененияЭлементовКонструктораВидовПродукцииИС.Форма.НастройкаМестПрименения",
		ПараметрыОткрытия,
		ЭтотОбъект,
		ПараметрыОткрытия.ЭлементКонструктора);
	
КонецПроцедуры

&НаКлиенте
Процедура НастроитьДоступныеЗначенияПоМестамПрименения(Команда)
	
	ПараметрыОткрытия = Новый Структура;
	ПараметрыОткрытия.Вставить("ЭлементКонструктора", Элементы.Список.ТекущиеДанные.Ссылка);
	
	ОткрытьФорму(
		"РегистрСведений.ДоступныеЗначенияПоМестамПримененияЭлементовКонструктораВидовПродукцииИС.Форма.НастройкаДоступныхЗначенийПоМестамПрименения",
		ПараметрыОткрытия,
