#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	УстановитьУсловноеОформление();
	
	Если Параметры.Свойство("АвтоТест") Тогда // Возврат при получении формы для анализа.
		Возврат;
	КонецЕсли;
	
	ОбновлениеИнформационнойБазы.ПроверитьОбъектОбработан(Объект, ЭтотОбъект);
	
	Если Не ЗначениеЗаполнено(Объект.Ссылка) Тогда
		
		ПриСозданииЧтенииНаСервере();
		
	КонецЕсли;
	
	ОбщегоНазначенияСобытияФормИСПереопределяемый.ПриСозданииНаСервере(ЭтотОбъект, Отказ, СтандартнаяОбработка);

КонецПроцедуры

&НаСервере
Процедура ПриЧтенииНаСервере(ТекущийОбъект)
	
	Если Объект.Предопределенный Тогда
		Элементы.ДлинаСерийногоНомера.Видимость = Ложь;
		Элементы.ИдентификаторыПримененияОтсутствуют.Видимость = Ложь;
		Элементы.СоставКодаМаркировки.Видимость = Ложь;
		ТолькоПросмотр = Истина;
	КонецЕсли;
	
	ПриСозданииЧтенииНаСервере();
	
	ОбщегоНазначенияСобытияФормИСПереопределяемый.ПриЧтенииНаСервере(ЭтотОбъект, ТекущийОбъект);
	
КонецПроцедуры

&НаКлиенте
Процедура ПередЗаписью(Отказ, ПараметрыЗаписи)
	
	Если Не Объект.Предопределенный Тогда
		СформироватьНаименование();
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура УстановитьУсловноеОформление()
	
	УсловноеОформление.Элементы.Очистить();
	
КонецПроцедуры

//@skip-check module-empty-method
&НаСервере
Процедура ПриСозданииЧтенииНаСервере()
	
КонецПроцедуры

&НаКлиенте
Процедура СформироватьНаименование()
	
	Состав = Новый Массив;
	Для Каждого Строка Из Объект.СоставКодаМаркировки Цикл
		НаименованиеЭлемента = Строка(Строка.ЭлементСоставаКодаМаркировки);
		Если Объект.ИдентификаторыПримененияОтсутствуют Тогда
			Позиция = СтрНайти(НаименованиеЭлемента, " ");
			Если Позиция > 0 Тогда
				НаименованиеЭлемента = Сред(НаименованиеЭлемента, Позиция + 1);
			КонецЕсли;
		КонецЕсли;
		Если Объект.ДлинаСерийногоНомера > 0
			И Строка.ЭлементСоставаКодаМаркировки = ПредопределенноеЗначение(
			"Перечисление.ЭлементыСоставаКодаМаркировкиИСМП.СерийныйНомер") Тогда
			НаименованиеЭлемента = СтрЗаменить(НаименованиеЭлемента, "NN", Объект.ДлинаСерийногоНомера);
		КонецЕсли;
		Состав.Добавить(НаименованиеЭлемента);
	КонецЦикла;
	
	Объект.Наименование = СтрСоединить(Состав, " + ");
	
КонецПроцедуры

#КонецОбласти
