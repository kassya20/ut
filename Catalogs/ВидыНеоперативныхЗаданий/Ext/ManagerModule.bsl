	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЗависимостьЧтениеЗапись.ВидЗаданияЧтение.Наименование КАК ВидЗаданияЧтение,
	|	ЗависимостьЧтениеЗапись.ВидЗаданияЗапись.Наименование КАК ВидЗаданияЗапись,
	|	ЗависимостьЗаписьЧтение.ВидЗаданияЧтение КАК Конфликт
	|ИЗ
	|	ВТ_ЗависимостьВидовЗаданий КАК ЗависимостьЗаписьЧтение
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_ЗависимостьВидовЗаданий КАК ЗависимостьЧтениеЗапись
	|		ПО ЗависимостьЧтениеЗапись.ВидЗаданияЗапись = ЗависимостьЗаписьЧтение.ВидЗаданияЧтение
	|		И ЗависимостьЧтениеЗапись.ВидЗаданияЧтение = ЗависимостьЗаписьЧтение.ВидЗаданияЗапись
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_ЗависимостьВидовЗаданий.ВидЗаданияЧтение КАК ВидЗаданияЧтение,
	|	ВТ_ЗависимостьВидовЗаданий.ВидЗаданияЗапись КАК ВидЗаданияЗапись
	|ИЗ
	|	ВТ_ЗависимостьВидовЗаданий КАК ВТ_ЗависимостьВидовЗаданий
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВидыНеоперативныхЗаданий.Ссылка КАК Ссылка,
	|	ВидыНеоперативныхЗаданий.НомерОчереди КАК НомерОчереди
	|ИЗ
	|	Справочник.ВидыНеоперативныхЗаданий КАК ВидыНеоперативныхЗаданий
	|ГДЕ
	|	НЕ ВидыНеоперативныхЗаданий.Ссылка В (&ИсключаемыеВидыЗаданий)";
	
	// Исключаемые виды заданий указаны в справочнике справочно.
	// В механизме неоперативной очереди по ним не должны регистрироваться и обрабатываться задания.
	ИсключаемыеВидыЗаданий = Новый Массив;
	
	
	
	Запрос.УстановитьПараметр("ИсключаемыеВидыЗаданий", ИсключаемыеВидыЗаданий);
	
	ПакетыЗапросов = Запрос.ВыполнитьПакет();
	
	ЦиклическаяЗависимость = ПакетыЗапросов[4].Выгрузить();
	
	Если ЦиклическаяЗависимость.Количество() > 0 Тогда
		
		СписокОписаний = Новый Массив;
		СписокОписаний.Добавить(НСтр("ru = 'При определении номера очереди видов заданий обнаружены циклические зависимости:'"));
		
		Для каждого Зависимость Из ЦиклическаяЗависимость Цикл
			
			СписокОписаний.Добавить(СтрШаблон(НСтр("ru = '- вид задания ""%1"" зависит от ""%2""'"),
				Зависимость.ВидЗаданияЧтение, Зависимость.ВидЗаданияЗапись));
			
		КонецЦикла;
		
		ТекстИсключения = СтрСоединить(СписокОписаний, Символы.ПС);
		ВызватьИсключение ТекстИсключения;
		
	КонецЕсли;
	
	ЗависимостьВидовЗаданий = ПакетыЗапросов[5].Выгрузить();
	ЗависимостьВидовЗаданий.Индексы.Добавить("ВидЗаданияЧтение");

	СписокВидовЗаданий = ПакетыЗапросов[6].Выгрузить();
	
	ПорядокЗаданийОчереди = Новый Соответствие;
	
	// Первоначальное заполнение номеров очереди для последующего расчета
	Для каждого ВидЗадания Из СписокВидовЗаданий Цикл
		ПорядокЗаданийОчереди.Вставить(ВидЗадания.Ссылка, 1);
	КонецЦикла;
	
	// Определение номера очереди с учетом зависимости видов заданий
	Для каждого ВидЗадания Из СписокВидовЗаданий Цикл
		ОпределитьНомерЗаданияПоЗависимости(ВидЗадания.Ссылка, ЗависимостьВидовЗаданий, 0, ПорядокЗаданийОчереди);
	КонецЦикла;
	
	// Автоматический расчет номера очереди задания РаспределениеПродажПоНаправлениямДеятельности не учитывает,
	// что оно должно выполняться после АктуализацияДвиженийПоФинансовымРегистрам, поэтому установим номер очереди +1
	НомерОчередиАктуализацияДвиженийПоФинансовымРегистрам = ПорядокЗаданийОчереди[Справочники.ВидыНеоперативныхЗаданий.АктуализацияДвиженийПоФинансовымРегистрам];
	ВидЗаданияОбъект = Справочники.ВидыНеоперативныхЗаданий.РаспределениеПродажПоНаправлениямДеятельности.ПолучитьОбъект();
	ВидЗаданияОбъект.НомерОчереди = НомерОчередиАктуализацияДвиженийПоФинансовымРегистрам + 1;
	ВидЗаданияОбъект.ОбменДанными.Загрузка = Истина;
	ВидЗаданияОбъект.Записать();
	
	НомерОчередиОтраженияДокументов = 0;
	Для каждого ВидЗадания Из СписокВидовЗаданий Цикл
		НомерОчереди = ПорядокЗаданийОчереди.Получить(ВидЗадания.Ссылка);
		НомерОчередиОтраженияДокументов = Макс(НомерОчередиОтраженияДокументов, НомерОчереди);
		Если Не НомерОчереди = ВидЗадания.НомерОчереди Тогда
			ВидЗаданияОбъект = ВидЗадания.Ссылка.ПолучитьОбъект();
			ВидЗаданияОбъект.НомерОчереди = НомерОчереди;
			ВидЗаданияОбъект.ОбменДанными.Загрузка = Истина;
			ВидЗаданияОбъект.Записать();
		КонецЕсли;
	КонецЦикла;
	
	
	
КонецПроцедуры

Процедура ОпределитьНомерЗаданияПоЗависимости(ВидЗадания, ЗависимостьВидовЗаданий, НомерЗадания, ПорядокЗаданийОчереди) 
	
	СтруктураОтбора = Новый Структура;
	СтруктураОтбора.Вставить("ВидЗаданияЧтение", ВидЗадания);
	
	НайденнаяЗависимость = ЗависимостьВидовЗаданий.НайтиСтроки(СтруктураОтбора);
	Если НайденнаяЗависимость.Количество() > 0 Тогда
		
		Для каждого ТекЗависимость Из НайденнаяЗависимость Цикл
			
			НомерЗадания = ПорядокЗаданийОчереди.Получить(ТекЗависимость.ВидЗаданияЗапись);
			ОпределитьНомерЗаданияПоЗависимости(ТекЗависимость.ВидЗаданияЗапись, ЗависимостьВидовЗаданий, НомерЗадания, ПорядокЗаданийОчереди);
			ПорядокЗаданийОчереди.Вставить(ТекЗависимость.ВидЗаданияЗапись, НомерЗадания);
			НомерЗадания = НомерЗадания + 1;
			
			Если ПорядокЗаданийОчереди.Получить(ВидЗадания) < НомерЗадания Тогда
				ПорядокЗаданийОчереди.Вставить(ВидЗадания, НомерЗадания);
			КонецЕсли;
			
		КонецЦикла;
			
	Иначе
		
		НомерЗадания = 1;
		ПорядокЗаданийОчереди.Вставить(ВидЗадания, НомерЗадания); 
		
	КонецЕсли;
	
КонецПроцедуры 

#КонецОбласти

