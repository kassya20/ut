//
Процедура ПриДобавленииОбработчиковОбновления(Обработчики) Экспорт

	Обработчик = Обработчики.Добавить();
	Обработчик.Процедура = "Справочники.ВидыНеоперативныхЗаданий.ЗаполнитьПредопределенныеНастройкиВидовНеоперативныхЗаданий";
	Обработчик.Версия = "*";
	Обработчик.РежимВыполнения = "Оперативно";
	Обработчик.Идентификатор = Новый УникальныйИдентификатор("cd45555d-f1f6-4a32-a02a-c00bf89351c1");
	Обработчик.Комментарий = НСтр("ru = 'Обновляет реквизиты предопределенных элементов справочника  ""Виды неоперативных заданий""'");
	Обработчик.ОбщиеДанные = Истина;
	
	Изменяемые = Новый Массив;
	Изменяемые.Добавить(Метаданные.Справочники.ВидыНеоперативныхЗаданий.ПолноеИмя());
	Обработчик.ИзменяемыеОбъекты = СтрСоединить(Изменяемые, ",");
	
КонецПроцедуры

Процедура ЗаполнитьПредопределенныеНастройкиВидовНеоперативныхЗаданий(Параметры = Неопределено) Экспорт
	
	// 1. Удаление элементов справочника, не являющихся предопределенными.
	Запрос = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ
	|	ВидыНеоперативныхЗаданий.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.ВидыНеоперативныхЗаданий КАК ВидыНеоперативныхЗаданий
	|ГДЕ
	|	НЕ ВидыНеоперативныхЗаданий.Предопределенный";
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		ВидНеоперативныхЗаданийОбъект = Выборка.Ссылка.ПолучитьОбъект();
		ВидНеоперативныхЗаданийОбъект.ОбменДанными.Загрузка = Истина;
		ВидНеоперативныхЗаданийОбъект.Удалить();
	КонецЦикла;
	
	// 2. Обработка предопределенных видов неоперативных заданий.
	МетаданныеОбъекта = Метаданные.Справочники.ВидыНеоперативныхЗаданий;
	НастройкиОбновления = МультиязычностьСервер.НастройкиОбновлениеПредопределенныхДанных(МетаданныеОбъекта);
	
	ТабличныеЧасти = Новый Массив;
	ТабличныеЧасти.Добавить("ЧитаемыеРегистры");
	ТабличныеЧасти.Добавить("ИзменяемыеРегистры");
	
	Для Каждого ДанныеЭлемента Из НастройкиОбновления.ПредопределенныеДанные Цикл
		
		ЭлементСсылка = Справочники.ВидыНеоперативныхЗаданий[ДанныеЭлемента.ИмяПредопределенныхДанных];
		ЭлементОбъект = ЭлементСсылка.ПолучитьОбъект();
		
		ЗаполнитьЗначенияСвойств(ЭлементОбъект, ДанныеЭлемента, ,
			"Ссылка, ПометкаУдаления, МаксимальнаяПорция, НомерОчереди");
		
		Если Не ЗначениеЗаполнено(ЭлементОбъект.МаксимальнаяПорция) Тогда
			ЭлементОбъект.МаксимальнаяПорция = ДанныеЭлемента.МаксимальнаяПорция;
		КонецЕсли;
		
		Для Каждого ИмяТабличнойЧасти Из ТабличныеЧасти Цикл
			ЭлементОбъект[ИмяТабличнойЧасти].Загрузить(ДанныеЭлемента[ИмяТабличнойЧасти]);
		КонецЦикла;
		
		Если ОбщегоНазначения.РазделениеВключено() Тогда
			
			Для Каждого ЛокализуемыйРеквизитОбъекта Из НастройкиОбновления.ЛокализуемыеРеквизитыОбъекта Цикл
				Имя = ЛокализуемыйРеквизитОбъекта.Ключ;
				ЭлементОбъект[Имя] = ДанныеЭлемента[Имя + "_" + НастройкиОбновления.ОсновнойЯзык];

				СведенияОбЯзыках = МультиязычностьСервер.СведенияОЯзыках();
				Для Каждого ЯзыкИспользуется Из СведенияОбЯзыках.Используется Цикл
					Если ЯзыкИспользуется.Значение Тогда
						КодЯзыка = СведенияОбЯзыках[ЯзыкИспользуется.Ключ];
						ЭлементОбъект[Имя + ЯзыкИспользуется.Ключ] = ДанныеЭлемента[Имя + "_" + КодЯзыка];
					КонецЕсли;
				КонецЦикла;
			КонецЦикла;
			
		КонецЕсли;
		
		ЭлементОбъект.ОбменДанными.Загрузка = Истина;
		ЭлементОбъект.Записать();
		
	КонецЦикла;
	
	ЗаполнитьНомерОчередиВидовНеоперативныхЗаданий();

КонецПроцедуры

