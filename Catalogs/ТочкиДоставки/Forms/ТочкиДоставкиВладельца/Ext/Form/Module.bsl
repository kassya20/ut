//@strict-types

#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Если НЕ Параметры.Отбор.Свойство("Владелец") Тогда
		
		ТекстСообщения = НСтр("ru = 'Форма не предназначена для непосредственного открытия'");
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения,,,, Отказ);
		
	КонецЕсли;
	
	Владелец = Параметры.Отбор.Владелец; // СправочникСсылка.Партнеры, СправочникСсылка.Склады -
	
	Если Параметры.РежимВыбора Тогда
		
		Элементы.Список.РежимВыбора = Истина;
		
	КонецЕсли;
	
	Если ТипЗнч(Владелец) = Тип("СправочникСсылка.Партнеры") Тогда
		
		ШаблонЗаголовка = НСтр("ru = 'Точки доставки по партнеру %1'");
		
	ИначеЕсли ТипЗнч(Владелец) = Тип("СправочникСсылка.Склады") Тогда
		
		ШаблонЗаголовка = НСтр("ru = 'Точки доставки по складу %1'");
		
	Иначе
		
		ШаблонИсключения = НСтр("ru = 'Тип владельца точек доставки %1 не поддерживается'");
		
		ТипВладельца = ТипЗнч(Владелец);
		ПредставлениеТипа = Строка(ТипВладельца);
		
		ТекстИсключения = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(ШаблонИсключения, ПредставлениеТипа);
		
		ВызватьИсключение ТекстИсключения;
		
	КонецЕсли;
	
	ПроверяемыеСсылки = ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(Владелец);
	
	ПредставленияПоСсылкам = ОбщегоНазначения.ПредставленияСсылок(ПроверяемыеСсылки);
	ПредставлениеВладельца = ПредставленияПоСсылкам[Владелец];
	
	Заголовок = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(ШаблонЗаголовка, ПредставлениеВладельца);
	
	УстановитьУсловноеОформление();
	
	УстановитьВидимостьПолейИдентификаторов();
	УстановитьДоступностьКомандыАрхивации();
	ДоставкаТоваровКлиентСервер.ИзменитьОтборАктуальныхТочек(ЭтотОбъект);
	
	СобытияФорм.ПриСозданииНаСервере(ЭтотОбъект, Отказ, СтандартнаяОбработка);
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура ОтображатьНеиспользуемые(Команда)
	
	ДоставкаТоваровКлиентСервер.ИзменитьОтборАктуальныхТочек(ЭтотОбъект);
	
КонецПроцедуры

&НаКлиенте
Процедура ИзменитьПризнакИспользования(Команда)
	
	ОчиститьСообщения();
	
	ВыделенныеСтроки = ОбщегоНазначенияУТКлиент.ПроверитьПолучитьВыделенныеВСпискеСсылки(Элементы.Список); // Массив из СправочникСсылка.ТочкиДоставки
	
	Для Каждого ТекущаяТочка Из ВыделенныеСтроки Цикл
		
		ТекущиеДанные = Элементы.Список.ДанныеСтроки(ТекущаяТочка);
		
		Если НЕ ТекущиеДанные.НеИспользуется
		   И ТекущиеДанные.ОсновнаяТочка Тогда
			
			ШаблонСообщения = НСтр("ru = 'Невозможно отключить использование: точка доставки ""%1"" является основным адресом доставки'");
			ПредставлениеТочки = Строка(ТекущиеДанные.Ссылка);
			
			ТекстСообщения = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
				ШаблонСообщения,
				ПредставлениеТочки);
				
			ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения, ТекущиеДанные.Ссылка);
			
		Иначе
			
			НовыйПризнак = НЕ ТекущиеДанные.НеИспользуется;
			ИзменитьПризнакИспользованияТочкиДоставки(ТекущаяТочка, НовыйПризнак);
			ОповеститьОбИзменении(ТекущаяТочка);
			
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура УстановитьУсловноеОформление()
	
	Список.УсловноеОформление.Элементы.Очистить();
	
	// Шрифт основной точки доставки
	Элемент = Список.УсловноеОформление.Элементы.Добавить();
	
	ОтборЭлемента = Элемент.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ОтборЭлемента.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("ОсновнаяТочка");
	ОтборЭлемента.ВидСравнения = ВидСравненияКомпоновкиДанных.Равно;
	ОтборЭлемента.ПравоеЗначение = Истина;
	
	Элемент.Оформление.УстановитьЗначениеПараметра("Шрифт", ШрифтыСтиля.ЖирныйШрифт);
	
	// Цвет не используемой точки доставки
	ДоставкаТоваров.УстановитьОформлениеНеиспользуемыхТочекДоставки(Список);
	
КонецПроцедуры

&НаСервере
Процедура ИзменитьПризнакИспользованияТочкиДоставки(Знач ТочкаДоставки, Знач НеИспользуется)
	
	ТочкаОбъект = ТочкаДоставки.ПолучитьОбъект();
	ТочкаОбъект.НеИспользуется = НеИспользуется;
	ТочкаОбъект.Записать();
	
КонецПроцедуры

&НаСервере
Процедура УстановитьДоступностьКомандыАрхивации()
	
	Если НЕ ПравоДоступа("Изменение", Метаданные.Справочники.ТочкиДоставки) Тогда
		
		ИменаЭлементов = Новый Массив; // Массив из Строка
		ИменаЭлементов.Добавить(Элементы.ФормаИзменитьПризнакИспользования.Имя);
		ИменаЭлементов.Добавить(Элементы.СписокКонтекстноеМенюИзменитьПризнакИспользования.Имя);
		
		ОбщегоНазначенияУТКлиентСервер.УстановитьСвойствоЭлементовФормы(Элементы, ИменаЭлементов, "Видимость", Ложь);
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура УстановитьВидимостьПолейИдентификаторов()
	
	Элементы.ГруппаИдентификаторАдреса.Видимость = ОбщегоНазначения.ОбъектМетаданныхДоступенПоФункциональнымОпциям(
		Метаданные.Справочники.ТочкиДоставки.Реквизиты.ИдентификаторАдреса);
	
КонецПроцедуры

#КонецОбласти