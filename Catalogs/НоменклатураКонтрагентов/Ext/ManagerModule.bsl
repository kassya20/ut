#Область СлужебныеПроцедурыИФункции

Функция РазмерПорцииОбработки()
	Возврат 10000;
КонецФункции

Процедура ОбработкаДанных_1_9_16(СправочникОбъект, СправочникСсылка)
	
	Если СправочникОбъект = Неопределено Тогда
		ЗначенияРеквизитов = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(СправочникСсылка, 
			"Наименование,
			|Артикул,
			|КодНоменклатуры,
			|Штрихкод,
			|ХешНаименования,
			|ХешАртикула,
			|ХешКодаНоменклатуры,
			|ХешШтрихкода,
			|ЭтоГруппа,
			|ПометкаУдаления,
			|Недействителен");
	Иначе
		ЗначенияРеквизитов = СправочникОбъект;
	КонецЕсли;
	
	Если ЗначенияРеквизитов.ЭтоГруппа
		Или ЗначенияРеквизитов.ПометкаУдаления
		Или ЗначенияРеквизитов.Недействителен Тогда
		Возврат;
	КонецЕсли;
	
	ИсходныеКлючи = СопоставлениеНоменклатурыКонтрагентовСлужебный.ХешиНатуральныхКлючейНоменклатуры("", "", "", "");
	ЗаполнитьЗначенияСвойств(ИсходныеКлючи, ЗначенияРеквизитов);
	НовыеКлючи = СопоставлениеНоменклатурыКонтрагентовСлужебный.ХешиНатуральныхКлючейНоменклатуры(
		ЗначенияРеквизитов.Наименование,
		ЗначенияРеквизитов.Артикул,
		ЗначенияРеквизитов.КодНоменклатуры,
		ЗначенияРеквизитов.Штрихкод);
	
	Если Не ОбщегоНазначения.ДанныеСовпадают(ИсходныеКлючи, НовыеКлючи) Тогда
		Если СправочникОбъект = Неопределено Тогда
			СправочникОбъект = СправочникСсылка.ПолучитьОбъект();
		КонецЕсли;
		ЗаполнитьЗначенияСвойств(СправочникОбъект, НовыеКлючи);
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#КонецЕсли


