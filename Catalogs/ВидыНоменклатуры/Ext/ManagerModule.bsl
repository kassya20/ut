// Создает дерево возможных операндов для формулы по шаблону.
//
// Параметры:
// 	НаборыСвойств - Структура:
// 		* НаборСвойств - СправочникСсылка.НаборыДополнительныхРеквизитовИСведений
// 		* НаборСвойствСерий - СправочникСсылка.НаборыДополнительныхРеквизитовИСведений
// 		* НаборСвойствХарактеристик - СправочникСсылка.НаборыДополнительныхРеквизитовИСведений
// 	ИмяШаблона - Строка
//
// Возвращаемое значение:
//	см. РаботаСФормулами.ПолучитьПустоеДеревоОперандов
//
Функция ПодготовитьДеревоОперандов(НаборыСвойств, ИмяШаблона) Экспорт
	
	НаборСвойств = Новый Структура();
	НаборСвойств.Вставить("НаборСвойствНоменклатуры", Ложь);
	НаборСвойств.Вставить("НаборСвойствХарактеристик", Ложь);
	НаборСвойств.Вставить("Набор", Неопределено);
	
	Если ИмяШаблона = "ШаблонНаименованияДляПечатиНоменклатуры"
		Или ИмяШаблона = "ШаблонРабочегоНаименованияНоменклатуры" Тогда
		
		НаборСвойств.НаборСвойствНоменклатуры = Истина;
		НаборСвойств.Набор = НаборыСвойств.НаборСвойств;
		
	ИначеЕсли ИмяШаблона = "ШаблонНаименованияДляПечатиХарактеристики"
		Или ИмяШаблона = "ШаблонРабочегоНаименованияХарактеристики" Тогда
		
		НаборСвойств.НаборСвойствХарактеристик = Истина;
		НаборСвойств.Набор = НаборыСвойств.НаборСвойствХарактеристик;
		
	Иначе
		
		НаборСвойств.Набор = НаборыСвойств.НаборСвойствСерий;
		
	КонецЕсли;
	
	ДеревоОперандов = РаботаСФормулами.ПолучитьПустоеДеревоОперандов();
	
	КорневаяСтрокаДерева = РаботаСФормулами.НоваяСтрокаДереваОперанда(ДеревоОперандов);
	Если НаборСвойств.НаборСвойствНоменклатуры Тогда
		
		КорневаяСтрокаДерева.Идентификатор = "Номенклатура";
		КорневаяСтрокаДерева.Представление = НСтр("ru = 'Номенклатура'");
		КорневаяСтрокаДерева.ТипЗначения = Новый ОписаниеТипов("СправочникСсылка.Номенклатура");
		
		НаборОбщихСвойств = УправлениеСвойствами.НаборСвойствПоИмени("Справочник_Номенклатура_Общие");
		
	ИначеЕсли НаборСвойств.НаборСвойствХарактеристик Тогда
		
		КорневаяСтрокаДерева.Идентификатор = "ХарактеристикаНоменклатуры";
		КорневаяСтрокаДерева.Представление = НСтр("ru = 'Характеристика номенклатуры'");
		КорневаяСтрокаДерева.ТипЗначения = Новый ОписаниеТипов("СправочникСсылка.ХарактеристикиНоменклатуры");
		
		НаборОбщихСвойств = УправлениеСвойствами.НаборСвойствПоИмени("Справочник_ХарактеристикиНоменклатуры_Общие");
		
	Иначе
		
		КорневаяСтрокаДерева.Идентификатор = "СерияНоменклатуры";
		КорневаяСтрокаДерева.Представление = НСтр("ru = 'Серия номенклатуры'");
		КорневаяСтрокаДерева.ТипЗначения = Новый ОписаниеТипов("СправочникСсылка.СерииНоменклатуры");
		
		НаборОбщихСвойств = УправлениеСвойствами.НаборСвойствПоИмени("Справочник_СерииНоменклатуры_Общие");
		
	КонецЕсли;
	
	КорневаяСтрокаДерева.РазрешаетсяВыборОперанда = Ложь;
	КорневаяСтрокаДерева.ВключаетсяВИдентификатор = Ложь;
	КорневаяСтрокаДерева.РазворачиватьДоРеквизитов = Истина;
	
	ОграниченияРазвертки = РаботаСФормулами.ОграниченияРазверткиОперандов();
	ОграниченияРазвертки.НаборыДополнительныхРеквизитов.Добавить(НаборСвойств.Набор);
	ОграниченияРазвертки.НаборыДополнительныхРеквизитов.Добавить(НаборОбщихСвойств);
	ОграниченияРазвертки.НеВыводимыеРеквизиты = "ВерсияДанных,УдалитьПодакцизныйТовар,ПодконтрольнаяПродукцияВЕТИС";
	
	РаботаСФормулами.РазвернутьСтрокуОперанда(КорневаяСтрокаДерева, ОграниченияРазвертки);
	
	Возврат ДеревоОперандов;
	
КонецФункции

// Заполняет соответствие операндов их типам.
//
// Параметры:
// 	ДеревоОперандов - см. РаботаСФормулами.ПолучитьПустоеДеревоОперандов
// 	Результат - Соответствие Из Строка
//
Процедура ПолучитьТипыОперандов(ДеревоОперандов, Результат) Экспорт
	
	Для Каждого СтрокаДерева Из ДеревоОперандов.Строки Цикл
		
		ПолучитьТипыОперандов(СтрокаДерева, Результат);
		
		Если СтрокаДерева.РазрешаетсяВыборОперанда Тогда
			Результат.Вставить(СтрокаДерева.Идентификатор, СтрокаДерева.ТипЗначения);
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти

// Возвращает признак использования в системе настроек ведения учета уникальных штрихкодов по видам номенклатуры.
//
// Параметры:
//	ИспользоватьНеуникальныеШтрихкоды - Булево - признак использования в системе ведения учета неуникальных
//													штрихкодов номенклатуры.
//
// Возвращаемое значение:
//	Булево - Истина, в системе включены настройки ведения учета уникальных штрихкодов по видам номенклатуры.
//
Функция ЕстьУстановленныеНастройкиУникальностиШтрихкода(ИспользоватьНеуникальныеШтрихкоды) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = ТекстЗапросаНастроекКонтроляУникальностиШтрихкода(ИспользоватьНеуникальныеШтрихкоды, Истина);
	
	УстановитьПривилегированныйРежим(Истина);
	РезультатЗапроса = Запрос.Выполнить();
	УстановитьПривилегированныйРежим(Ложь);
	
	Возврат Не РезультатЗапроса.Пустой();
	
КонецФункции

// Выполняет установку настроек уникальности штрихкода по умолчанию для элементов справочника.
//
// Параметры:
//	ИспользоватьНеуникальныеШтрихкоды - Булево - признак использования в системе ведения учета неуникальных
//													штрихкодов номенклатуры.
Процедура УстановитьНастройкиУникальностиШтрихкодаПоУмолчанию(ИспользоватьНеуникальныеШтрихкоды) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = ТекстЗапросаНастроекКонтроляУникальностиШтрихкода(ИспользоватьНеуникальныеШтрихкоды);
	
	УстановитьПривилегированныйРежим(Истина);
	РезультатЗапроса = Запрос.Выполнить();
	УстановитьПривилегированныйРежим(Ложь);
	
	Если РезультатЗапроса.Пустой() Тогда
		Возврат;
	КонецЕсли;
	
	КоличествоДанныхКОбработке = 0;
	
	ОписаниеЗамера = ОценкаПроизводительности.НачатьЗамерДлительнойОперации(
						"Справочник.ВидыНоменклатуры.МодульМенеджера.УстановитьНастройкиУникальностиШтрихкодаПоУмолчанию");
	
	ИмяСобытия			= НСтр("ru = 'Обновление настроек реквизитов для контроля номенклатуры'", ОбщегоНазначения.КодОсновногоЯзыка());
	ШаблонКомментария	= НСтр("ru = 'Не удалось обновить настройки реквизитов для контроля номенклатуры для вида номенклатуры ""%1"", по причине: %2'");
	
	Выборка = РезультатЗапроса.Выбрать();
	
	Пока Выборка.Следующий() Цикл
		КоличествоДанныхКОбработке = КоличествоДанныхКОбработке + 1;
		
		НачатьТранзакцию();
		
		Попытка
			Блокировка = Новый БлокировкаДанных;
			ЭлементБлокировки = Блокировка.Добавить("Справочник.ВидыНоменклатуры");
			ЭлементБлокировки.УстановитьЗначение("Ссылка", Выборка.Ссылка);
			ЭлементБлокировки.Режим = РежимБлокировкиДанных.Исключительный;
			Блокировка.Заблокировать();
			
			ВидНоменклатуры = Выборка.Ссылка.ПолучитьОбъект(); // СправочникОбъект.ВидыНоменклатуры -
			
			Если ВидНоменклатуры <> Неопределено Тогда
				НастройкаКонтроля = ВидНоменклатуры.РеквизитыДляКонтроляНоменклатуры.Найти("Штрихкод", "ИмяРеквизита");
				
				Если НастройкаКонтроля <> Неопределено Тогда
					НастройкаКонтроля.Уникален				= Не ИспользоватьНеуникальныеШтрихкоды;
					НастройкаКонтроля.ДоступностьУникален	= ИспользоватьНеуникальныеШтрихкоды;
				КонецЕсли;
			КонецЕсли;
			
			Если ВидНоменклатуры.Модифицированность() Тогда
				ВидНоменклатуры.Записать();
			КонецЕсли;
			
			ЗафиксироватьТранзакцию();
		Исключение
			ОтменитьТранзакцию();
			
			ТекстСообщения = СтрШаблон(ШаблонКомментария,
										Выборка.Ссылка,
										ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
			
			ЗаписьЖурналаРегистрации(
				ИмяСобытия,
				УровеньЖурналаРегистрации.Предупреждение,
				Метаданные.Справочники.ВидыНоменклатуры,
				,
				ТекстСообщения);
		КонецПопытки;
	КонецЦикла;
	
	ОценкаПроизводительности.ЗакончитьЗамерДлительнойОперации(ОписаниеЗамера, КоличествоДанныхКОбработке);
	
КонецПроцедуры

// Добавляет переданные объекты в табличную части "ПолитикиУчетаСерий" видов номенклатуры.  
// 
// Параметры:
//  ДобавляемыеОбъекты - Массив Из СправочникСсылка.Склады, СправочникСсылка.СтруктураПредприятия - Которые необходимо добавить в табличную часть.
// 
Процедура ДобавитьОбъектыВСоставПолитикУчетаСерий(ДобавляемыеОбъекты) Экспорт

	НачатьТранзакцию();
	
	Попытка
		
		Блокировка = Новый БлокировкаДанных;
		Блокировка.Добавить("Справочник.ВидыНоменклатуры");
		Блокировка.Заблокировать();
		
		Запрос = Новый Запрос;
		Запрос.Текст =
		"ВЫБРАТЬ
		|	ВидыНоменклатуры.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.ВидыНоменклатуры КАК ВидыНоменклатуры
		|ГДЕ
		|	ВидыНоменклатуры.ИспользоватьСерии";
		
		РезультатЗапроса = Запрос.Выполнить();
		Выборка = ВыбратьПоСсылкам(РезультатЗапроса);
		
		Пока Выборка.Следующий() Цикл
			
			ВидНоменклатуры = Выборка.ПолучитьОбъект();
			
			Для Каждого ДобавляемыйОбъект Из ДобавляемыеОбъекты Цикл
				СтрокаПолитики = ВидНоменклатуры.ПолитикиУчетаСерий.Добавить();
				СтрокаПолитики.ПолитикаУчетаСерий = ВидНоменклатуры.ПолитикаУчетаСерий;
				СтрокаПолитики.Склад = ДобавляемыйОбъект;
			КонецЦикла;
			
			ВидНоменклатуры.ОбменДанными.Загрузка = Истина;
			ВидНоменклатуры.Записать();
			
		КонецЦикла;
		
		ЗафиксироватьТранзакцию();
		
	Исключение
		
		ОтменитьТранзакцию();
		ВызватьИсключение;
		
	КонецПопытки;

КонецПроцедуры

// Удаляет переданные объекты из табличной части "ПолитикиУчетаСерий" видов номенклатуры  
// 
// Параметры:
//  УдаляемыеОбъекты - Массив Из СправочникСсылка.Склады, СправочникСсылка.СтруктураПредприятия - Которые необходимо удалить из табличной части.
// 
Процедура УдалитьОбъектыИзПолитикУчетаСерий(УдаляемыеОбъекты) Экспорт

	НачатьТранзакцию();
	
	Попытка
		
		Блокировка = Новый БлокировкаДанных;
		Блокировка.Добавить("Справочник.ВидыНоменклатуры");
		Блокировка.Заблокировать();
		
		Запрос = Новый Запрос;
		Запрос.Текст =
		"ВЫБРАТЬ
		|	ПолитикиУчетаСерий.Ссылка КАК Ссылка,
		|	ПолитикиУчетаСерий.НомерСтроки КАК НомерСтроки
		|ИЗ
		|	Справочник.ВидыНоменклатуры.ПолитикиУчетаСерий КАК ПолитикиУчетаСерий
		|ГДЕ
		|	ПолитикиУчетаСерий.Склад В (&УдаляемыеОбъекты)
		|
		|УПОРЯДОЧИТЬ ПО
		|	Ссылка УБЫВ,
		|	НомерСтроки УБЫВ";
		
		Запрос.УстановитьПараметр("УдаляемыеОбъекты", УдаляемыеОбъекты);
		РезультатЗапроса = Запрос.Выполнить();
		
		ВыборкаСтрок = РезультатЗапроса.Выбрать();
		УдаляемыеСтрокиВидовНоменклатуры = Новый Соответствие;
		УдаляемыеСтроки = Неопределено;
		ТекущаяСсылка = ПустаяСсылка();
		
		Пока ВыборкаСтрок.Следующий() Цикл
			
			Если ТекущаяСсылка <> ВыборкаСтрок.Ссылка Тогда
				
				ТекущаяСсылка = ВыборкаСтрок.Ссылка;
				
				УдаляемыеСтроки = Новый Массив;
				УдаляемыеСтрокиВидовНоменклатуры.Вставить(ТекущаяСсылка, УдаляемыеСтроки);
			
			КонецЕсли;
			
			УдаляемыеСтроки.Добавить(ВыборкаСтрок.НомерСтроки);
			
		КонецЦикла;
		
		ВыборкаОбъектов = ВыбратьПоСсылкам(РезультатЗапроса);
		Пока ВыборкаОбъектов.Следующий() Цикл
			
			ВидНоменклатуры = ВыборкаОбъектов.ПолучитьОбъект();
			Для Каждого НомерСтроки Из УдаляемыеСтрокиВидовНоменклатуры.Получить(ВидНоменклатуры.Ссылка) Цикл
				ВидНоменклатуры.ПолитикиУчетаСерий.Удалить(НомерСтроки - 1);
			КонецЦикла;
			
			ВидНоменклатуры.ОбменДанными.Загрузка = Истина;
			ВидНоменклатуры.Записать();
			
		КонецЦикла;
		
		ЗафиксироватьТранзакцию();
		
	Исключение
		
		ОтменитьТранзакцию();
		ВызватьИсключение;
		
	КонецПопытки;

КонецПроцедуры

