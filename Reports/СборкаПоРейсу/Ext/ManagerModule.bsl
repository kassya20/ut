// @strict-types

#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ПрограммныйИнтерфейс

// Вариант отчета в зависимости от настроек склада в рейсе
// 
// Параметры:
//  Рейс - ДокументСсылка.Рейс
// 
// Возвращаемое значение:
//  СправочникСсылка.ВариантыОтчетов, Неопределено -
//
Функция ВариантОтчетаПоРейсу(Рейс) Экспорт
	
	ПараметрыВариантаОтчета = ПараметрыВариантаОтчетаПоРейсу(Рейс);
	Если НЕ ПараметрыВариантаОтчета.СкладИспользуетОрдернуюСхему
	 ИЛИ ПараметрыВариантаОтчета.КлючВарианта = "" Тогда
		
		Вариант = Справочники.ВариантыОтчетов.ПустаяСсылка();
		
	Иначе
		
		Отчет = ОбщегоНазначения.ИдентификаторОбъектаМетаданных(Метаданные.Отчеты.СборкаПоРейсу);
		Вариант = ВариантыОтчетов.ВариантОтчета(Отчет, ПараметрыВариантаОтчета.КлючВарианта);
		
	КонецЕсли;
	
	Возврат Вариант;
	
КонецФункции

#Область ДляВызоваИзДругихПодсистем

// Задает расширенные настройки отчета
//
// Параметры:
//   Настройки - см. ВариантыОтчетовПереопределяемый.НастроитьВариантыОтчетов.Настройки.
//   НастройкиОтчета - см. ВариантыОтчетов.ОписаниеОтчета.
//
Процедура НастроитьВариантыОтчета(Настройки, НастройкиОтчета) Экспорт
	
	НастройкиОтчета = ВариантыОтчетов.ОписаниеОтчета(Настройки, Метаданные.Отчеты.СборкаПоРейсу);
	НастройкиОтчета.ФункциональныеОпции.Добавить("НеИспользоватьУправлениеДоставкой20");
	НастройкиОтчета.ОпределитьНастройкиФормы = Истина;
	
	НастройкиОтчета.ПоказыватьВПодменюВариантов = Ложь;
	НастройкиОтчета.Наименование = НаименованиеОтчета();
	ВариантыОтчетов.УстановитьРежимВыводаВПанеляхОтчетов(Настройки, НастройкиОтчета, Ложь);
	ВариантыОтчетовУТПереопределяемый.ОтключитьОтчет(НастройкиОтчета);
	
КонецПроцедуры

#КонецОбласти

#Область КомандыПодменюОтчеты

// Добавляет команду отчета в список команд.
// 
// Параметры:
//   КомандыОтчетов - См. ВариантыОтчетовПереопределяемый.ПередДобавлениемКомандОтчетов.КомандыОтчетов
//   Параметры - см. ВариантыОтчетовПереопределяемый.ПередДобавлениемКомандОтчетов.Параметры
//   КлючВарианта - Строка - 
//   
//	Возвращаемое значение:
//		СтрокаТаблицыЗначений - описание созданной команды.
//
Функция ДобавитьКомандуОтчета(КомандыОтчетов, Параметры, КлючВарианта = "") Экспорт
	
	КомандаОтчет = Неопределено;
	
	Если ПравоДоступа("Просмотр", Метаданные.Отчеты.СборкаПоРейсу) Тогда
		
		КомандаОтчет = КомандыОтчетов.Добавить();
		
		КомандаОтчет.Менеджер = Метаданные.Отчеты.СборкаПоРейсу.ПолноеИмя();
		КомандаОтчет.Представление = НаименованиеОтчета();
		КомандаОтчет.МножественныйВыбор = Ложь;
		КомандаОтчет.Неконтекстный = Ложь;
		КомандаОтчет.РежимЗаписи = "Проводить";
		КомандаОтчет.ФункциональныеОпции = "НеИспользоватьУправлениеДоставкой20";
		КомандаОтчет.Важность = "Обычное";
		
		КомандаОтчет.ПараметрыФормы = Новый Структура;
		КомандаОтчет.ПараметрыФормы.Вставить("ВидимостьКомандВариантовОтчетов", Ложь);
		
	КонецЕсли;
	
	Возврат КомандаОтчет;
	
КонецФункции

#КонецОбласти

#КонецОбласти

#Область СлужебныйПрограммныйИнтерфейс

// Параметры:
//  Рейс - ДокументСсылка.Рейс
// 
// Возвращаемое значение:
//  Структура:
// * СкладИспользуетОрдернуюСхему - Булево - 
// * КлючВарианта - Строка - 
//
Функция ПараметрыВариантаОтчетаПоРейсу(Рейс) Экспорт
	
	ПараметрыВарианта = Новый Структура;
	ПараметрыВарианта.Вставить("СкладИспользуетОрдернуюСхему", Ложь);
	ПараметрыВарианта.Вставить("КлючВарианта", "");
	
	ТекстЗапроса =
	"ВЫБРАТЬ
	|	Рейс.ДатаВыезда КАК ДатаВыезда,
	|	Склады.ИспользоватьОрдернуюСхемуПриОтгрузке КАК ИспользоватьОрдернуюСхемуПриОтгрузке,
	|	Склады.ДатаНачалаОрдернойСхемыПриОтгрузке КАК ДатаНачалаОрдернойСхемыПриОтгрузке,
	|	Склады.НачинатьОтгрузкуПослеФормированияЗаданияНаПеревозку КАК СборкаПослеПланированияДоставки
	|ИЗ
	|	Документ.Рейс КАК Рейс
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Склады КАК Склады
	|		ПО Рейс.СкладОтправления = Склады.Ссылка
	|ГДЕ
	|	Рейс.Ссылка = &Ссылка";
	
	Запрос = Новый Запрос;
	Запрос.Текст = ТекстЗапроса;
	Запрос.УстановитьПараметр("Ссылка", Рейс);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда
		
		Если Выборка.ИспользоватьОрдернуюСхемуПриОтгрузке
		   И Выборка.ДатаНачалаОрдернойСхемыПриОтгрузке <= Выборка.ДатаВыезда Тогда
			
			ПараметрыВарианта.СкладИспользуетОрдернуюСхему = Истина;
			Если Выборка.СборкаПослеПланированияДоставки Тогда
				
				ПараметрыВарианта.КлючВарианта = "СборкаПоДаннымРейса";
				
			Иначе
				
				ПараметрыВарианта.КлючВарианта = "СборкаНезависимоОтРейса";
				
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат ПараметрыВарианта;
	
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция НаименованиеОтчета()
	
	Возврат НСтр("ru = 'Сборка по распоряжениям рейса'");
	
КонецФункции

#КонецОбласти

#КонецЕсли