		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ
	ДоставкаОбороты.Номенклатура КАК Номенклатура,
	ДоставкаОбороты.Характеристика КАК Характеристика,
	ДоставкаОбороты.Серия КАК Серия,
	ДоставкаОбороты.Распоряжение КАК Распоряжение,
	ДоставкаОбороты.Получатель КАК Получатель,
	ДоставкаОбороты.ТочкаПолучателя КАК ТочкаПолучателя,
	ДоставкаОбороты.ВРейсеОборот КАК ВРейсе,
	ДоставкаОбороты.КСборкеОборот КАК КСборке,
	ДоставкаОбороты.ЗапланированаСборкаОборот КАК ЗапланированаСборка,
	ДоставкаОбороты.СобираетсяОборот КАК Собирается,
	ДоставкаОбороты.СобраноОборот КАК Собрано
ПОМЕСТИТЬ ВТ_ДанныеДоставки
ИЗ
	РегистрНакопления.Доставка.Обороты(
			{(&amp;НачалоПериода)},
			{(&amp;КонецПериода)},
			,
			Рейс = &amp;Рейс
				И ТипДоставки = ЗНАЧЕНИЕ(Перечисление.ТипыДоставки.Исходящая)
				И Плечо В (&amp;НомераПлеч)) КАК ДоставкаОбороты
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	ДанныеДоставки.Номенклатура КАК Номенклатура,
	ДанныеДоставки.Характеристика КАК Характеристика,
	ДанныеДоставки.Серия КАК Серия,
	ДанныеДоставки.Распоряжение КАК Распоряжение,
	СУММА(ДанныеДоставки.ЗапланированаСборка) КАК ЗапланированаСборка,
	СУММА(ДанныеДоставки.Собирается) КАК Собирается,
	СУММА(ДанныеДоставки.Собрано) КАК Собрано
ПОМЕСТИТЬ ВТ_ДанныеСборки
ИЗ
	ВТ_ДанныеДоставки КАК ДанныеДоставки

СГРУППИРОВАТЬ ПО
	ДанныеДоставки.Номенклатура,
	ДанныеДоставки.Характеристика,
	ДанныеДоставки.Серия,
	ДанныеДоставки.Распоряжение
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	ТоварыКОтгрузкеОбороты.ДокументОтгрузки КАК ДокументОтгрузки,
	ТоварыКОтгрузкеОбороты.Номенклатура КАК Номенклатура,
	ТоварыКОтгрузкеОбороты.Характеристика КАК Характеристика,
	ТоварыКОтгрузкеОбороты.Серия КАК Серия,
	ТоварыКОтгрузкеОбороты.КОтгрузкеПриход КАК КОтгрузке,
	ТоварыКОтгрузкеОбороты.КСборкеОборот + ТоварыКОтгрузкеОбороты.СобираетсяОборот КАК Собирается,
	ТоварыКОтгрузкеОбороты.СобраноОборот + ТоварыКОтгрузкеОбороты.КОтгрузкеРасход КАК Собрано
ПОМЕСТИТЬ ВТ_ДанныеПоОтгрузке
ИЗ
	РегистрНакопления.ТоварыКОтгрузке.Обороты(
			{(&amp;НачалоПериода)},
			{(&amp;КонецПериода)},
			,
			(ДокументОтгрузки, Номенклатура, Характеристика, Серия) В
				(ВЫБРАТЬ
					Таблица.Распоряжение КАК ДокументОтгрузки,
					Таблица.Номенклатура КАК Номенклатура,
					Таблица.Характеристика КАК Характеристика,
					Таблица.Серия КАК Серия
				ИЗ
					ВТ_ДанныеСборки КАК Таблица)) КАК ТоварыКОтгрузкеОбороты
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	ДанныеДоставки.Распоряжение КАК Распоряжение,
	ДанныеДоставки.Номенклатура КАК Номенклатура,
	ДанныеДоставки.Характеристика КАК Характеристика,
	ДанныеДоставки.Серия КАК Серия,
	ДанныеДоставки.Получатель КАК Получатель,
	ДанныеДоставки.ТочкаПолучателя КАК ТочкаПолучателя,
	ДанныеДоставки.ВРейсе КАК ВРейсе,
	ДанныеДоставки.КСборке КАК КСборке,
	ЕСТЬNULL(ДанныеСборки.ЗапланированаСборка, 0) КАК ЗапланированаСборка,
	ЕСТЬNULL(ДанныеСборки.Собирается, 0) КАК Собирается,
	ЕСТЬNULL(ДанныеСборки.Собрано, 0) КАК Собрано,
	ЕСТЬNULL(ДанныеПоОтгрузке.Собирается, 0) КАК СобираетсяОтгрузка,
	ЕСТЬNULL(ДанныеПоОтгрузке.КОтгрузке, 0) КАК КОтгрузке,
	ЕСТЬNULL(ДанныеПоОтгрузке.Собрано, 0) КАК СобраноОтгрузка
{ВЫБРАТЬ
	Распоряжение.*,
	Номенклатура.*,
	Характеристика.*,
	Серия.*,
	Получатель.* КАК ПунктМаршрута,
	ТочкаПолучателя.* КАК ТочкаДоставки,
	ВРейсе,
	КСборке,
	ЗапланированаСборка,
	Собирается,
	Собрано,
	СобираетсяОтгрузка,
	КОтгрузке,
	СобраноОтгрузка}
ИЗ
	ВТ_ДанныеДоставки КАК ДанныеДоставки
		{ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ДанныеСборки КАК ДанныеСборки
		ПО ДанныеДоставки.Распоряжение = ДанныеСборки.Распоряжение
			И ДанныеДоставки.Номенклатура = ДанныеСборки.Номенклатура
			И ДанныеДоставки.Характеристика = ДанныеСборки.Характеристика
			И ДанныеДоставки.Серия = ДанныеСборки.Серия}
		{ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ДанныеПоОтгрузке КАК ДанныеПоОтгрузке
		ПО ДанныеДоставки.Распоряжение = ДанныеПоОтгрузке.ДокументОтгрузки
			И ДанныеДоставки.Номенклатура = ДанныеПоОтгрузке.Номенклатура
			И ДанныеДоставки.Характеристика = ДанныеПоОтгрузке.Характеристика
			И ДанныеДоставки.Серия = ДанныеПоОтгрузке.Серия}
{ГДЕ
	ДанныеДоставки.Распоряжение.*,
	ДанныеДоставки.Получатель.* КАК ПунктМаршрута,
	ДанныеДоставки.Номенклатура.*,
	ДанныеДоставки.Характеристика.*}</query>
		<autoFillFields>false</autoFillFields>
	</dataSet>
