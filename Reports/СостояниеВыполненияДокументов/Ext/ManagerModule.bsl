#Область ТестыЗапросовДоставки

Функция ТекстЗапросаВтСтрокиРаспоряженийНаДоставку(ИмяТаблицы, СтруктураПараметров)
	
	СтруктураДопЗапросов = СтруктураПараметров.СтруктураДопЗапросов;
	Если ЗначениеЗаполнено(СтруктураДопЗапросов)
	   И СтруктураДопЗапросов.Свойство("ВтСтрокиРаспоряженийНаДоставку") Тогда
		Возврат СтруктураДопЗапросов.ВтСтрокиРаспоряженийНаДоставку;
	КонецЕсли;
	
	ТекстыЗапросов = Новый Массив; // Массив Из Строка
	
	ТекстЗапроса =
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	РаспоряженияНаОтгрузку.Регистратор КАК ДокументСсылка,
	|	РаспоряженияНаОтгрузку.Распоряжение КАК Распоряжение,
	|	РаспоряженияНаОтгрузку.КодСтроки КАК КодСтроки
	|ПОМЕСТИТЬ ВТСтрокиРаспоряженийНаДоставку
	|ИЗ
	|	РегистрНакопления.РаспоряженияНаОтгрузкуИВозврат КАК РаспоряженияНаОтгрузку
	|ГДЕ
	|	РаспоряженияНаОтгрузку.Регистратор В
	|		(ВЫБРАТЬ
	|			ВтДокументы.ДокументСсылка КАК ДокументСсылка
	|		ИЗ
	|			ВтДокументы КАК ВтДокументы)
	|	И РаспоряженияНаОтгрузку.КодСтроки <> 0
	|	И &УсловияДляРТиУ";
	
	Если ИмяТаблицы = "Документ.РеализацияТоваровУслуг" Тогда
		
		УсловияДляРТиУ = "(НЕ ВЫРАЗИТЬ(РаспоряженияНаОтгрузку.Регистратор КАК Документ.РеализацияТоваровУслуг).РеализацияПоЗаказам
		|	ИЛИ ЕСТЬNULL(ВЫРАЗИТЬ(РаспоряженияНаОтгрузку.Распоряжение КАК Документ.ЗаказКлиента).ЭтоЗаказКакСчет, НЕ &ИспользоватьРасширенныеВозможностиЗаказаКлиента))";
		
	Иначе
		
		УсловияДляРТиУ = "ИСТИНА";
		
	КонецЕсли;
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&УсловияДляРТиУ", УсловияДляРТиУ);
	
	ТекстыЗапросов.Добавить(ТекстЗапроса);
	
	Если ИмяТаблицы = "Документ.РеализацияТоваровУслуг"
	 ИЛИ ИмяТаблицы = "Документ.ЗаказКлиента"
	 ИЛИ ИмяТаблицы = "Документ.ОтгрузкаТоваровКлиенту" Тогда
		
		ТекстЗапроса =
		"ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	СтрокиСверхЗаказа.Распоряжение,
		|	СтрокиСверхЗаказа.Распоряжение,
		|	СтрокиСверхЗаказа.КодСтроки
		|ИЗ
		|	РегистрНакопления.Доставка КАК СтрокиСверхЗаказа
		|ГДЕ
		|	СтрокиСверхЗаказа.Распоряжение В
		|		(ВЫБРАТЬ
		|			ВтДокументы.ДокументСсылка КАК ДокументСсылка
		|		ИЗ
		|			ВтДокументы КАК ВтДокументы)
		|	И &УсловияДляРТиУ";
		
		Если ИмяТаблицы = "Документ.РеализацияТоваровУслуг" Тогда
			
			УсловияДляРТиУ = "(НЕ ВЫРАЗИТЬ(СтрокиСверхЗаказа.Регистратор КАК Документ.РеализацияТоваровУслуг).РеализацияПоЗаказам
			|	ИЛИ ЕСТЬNULL(ВЫРАЗИТЬ(СтрокиСверхЗаказа.Распоряжение КАК Документ.ЗаказКлиента).ЭтоЗаказКакСчет, НЕ &ИспользоватьРасширенныеВозможностиЗаказаКлиента))";
			
		Иначе
			
			УсловияДляРТиУ = "ИСТИНА";
			
		КонецЕсли;
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&УсловияДляРТиУ", УсловияДляРТиУ);
		
		ТекстыЗапросов.Добавить(ТекстЗапроса);
		
	КонецЕсли;
	
	ТекстЗапроса = СтрСоединить(ТекстыЗапросов, ОбщегоНазначенияУТ.РазделительЗапросовВОбъединении(Истина))
		+ ОбщегоНазначения.РазделительПакетаЗапросов();
	
	Возврат ТекстЗапроса;
	
КонецФункции

Функция ТекстЗапросаВтДоставкаОбороты(СтруктураПараметров)
	
	СтруктураДопЗапросов = СтруктураПараметров.СтруктураДопЗапросов;
	Если ЗначениеЗаполнено(СтруктураДопЗапросов)
	   И СтруктураДопЗапросов.Свойство("ВтДоставкаОбороты") Тогда
		Возврат СтруктураДопЗапросов.ТекстЗапросаТаблицаДоставка;
	КонецЕсли;
	
	ТекстЗапроса =
	"ВЫБРАТЬ
	|	ДоставкаОбороты.Распоряжение КАК Распоряжение,
	|	ДоставкаОбороты.КодСтроки КАК КодСтроки,
	|	ДоставкаОбороты.Номенклатура КАК Номенклатура,
	|	ДоставкаОбороты.Характеристика КАК Характеристика,
	|	ДоставкаОбороты.Серия КАК Серия,
	|	ДоставкаОбороты.КДоставкеОборот КАК КДоставкеОборот,
	|	ДоставкаОбороты.КРейсуОборот КАК КРейсуОборот,
	|	ДоставкаОбороты.ВРейсеОборот КАК ВРейсеОборот,
	|	ДоставкаОбороты.ВПутиОборот КАК ВПутиОборот,
	|	ДоставкаОбороты.ДоставленоОборот КАК ДоставленоОборот,
	|	ДоставкаОбороты.ОтмененоОборот КАК ОтмененоОборот
	|ПОМЕСТИТЬ ВТДоставкаОбороты
	|ИЗ
	|	РегистрНакопления.Доставка.Обороты(
	|			,
	|			,
	|			,
	|			ТипДоставки = &ТипДоставки
	|				И Плечо = 1
	|				И (Распоряжение, КодСтроки) В
	|					(ВЫБРАТЬ
	|						ВТСтрокиРаспоряженийНаДоставку.Распоряжение КАК Распоряжение,
	|						ВТСтрокиРаспоряженийНаДоставку.КодСтроки КАК КодСтроки
	|					ИЗ
	|						ВТСтрокиРаспоряженийНаДоставку КАК ВТСтрокиРаспоряженийНаДоставку)) КАК ДоставкаОбороты";
	
	ТекстЗапроса = ТекстЗапроса + ОбщегоНазначения.РазделительПакетаЗапросов();
	Возврат ТекстЗапроса;
	
КонецФункции

Функция ТекстЗапросаТаблицаДоставка(СтруктураПараметров)
	
	СтруктураДопЗапросов = СтруктураПараметров.СтруктураДопЗапросов;
	Если ЗначениеЗаполнено(СтруктураДопЗапросов)
	   И СтруктураДопЗапросов.Свойство("ТекстЗапросаТаблицаДоставка") Тогда
		Возврат СтруктураДопЗапросов.ТекстЗапросаТаблицаДоставка;
	КонецЕсли;
	
	ТекстЗапроса =
	"ВЫБРАТЬ
	|	ВТСтрокиРаспоряженийНаДоставку.ДокументСсылка КАК Документ,
	|	ВТДоставкаОбороты.Номенклатура КАК Номенклатура,
	|	ВТДоставкаОбороты.Характеристика КАК Характеристика,
	|	ВТДоставкаОбороты.Серия КАК Серия,
	|	КОЛИЧЕСТВО(*) КАК КоличествоСтрокТоваров,
	|	СУММА(ВТДоставкаОбороты.КДоставкеОборот) КАК КДоставкеОборот,
	|	СУММА(ВТДоставкаОбороты.КРейсуОборот) КАК КРейсуОборот,
	|	СУММА(ВТДоставкаОбороты.ВРейсеОборот) КАК ВРейсеОборот,
	|	СУММА(ВТДоставкаОбороты.ВПутиОборот) КАК ВПутиОборот,
	|	СУММА(ВТДоставкаОбороты.ДоставленоОборот) КАК ДоставленоОборот,
	|	СУММА(ВТДоставкаОбороты.ОтмененоОборот) КАК ОтмененоОборот,
	|	СУММА(ВТДоставкаОбороты.КДоставкеОборот) - СУММА(ВТДоставкаОбороты.КРейсуОборот) КАК Запланировать,
	|	СУММА(ВТДоставкаОбороты.КРейсуОборот) - СУММА(ВТДоставкаОбороты.ВРейсеОборот) + СУММА(ВТДоставкаОбороты.ОтмененоОборот) КАК Оформить,
	|	СУММА(ВТДоставкаОбороты.ВРейсеОборот) - СУММА(ВТДоставкаОбороты.ОтмененоОборот) КАК Оформлено
	|ИЗ
	|	ВТСтрокиРаспоряженийНаДоставку КАК ВТСтрокиРаспоряженийНаДоставку
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТДоставкаОбороты КАК ВТДоставкаОбороты
	|		ПО ВТСтрокиРаспоряженийНаДоставку.Распоряжение = ВТДоставкаОбороты.Распоряжение
	|			И ВТСтрокиРаспоряженийНаДоставку.КодСтроки = ВТДоставкаОбороты.КодСтроки
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТУпорядочиваниеНХС КАК ВТУпорядочивание
	|		ПО ВТДоставкаОбороты.Распоряжение = ВТУпорядочивание.Документ
	|			И ВТДоставкаОбороты.Номенклатура = ВТУпорядочивание.Номенклатура
	|			И ВТДоставкаОбороты.Характеристика = ВТУпорядочивание.Характеристика
	|			И ВТДоставкаОбороты.Серия = ВТУпорядочивание.Серия
	|СГРУППИРОВАТЬ ПО
	|	ВТСтрокиРаспоряженийНаДоставку.ДокументСсылка,
	|	ВТДоставкаОбороты.Номенклатура,
	|	ВТДоставкаОбороты.Характеристика,
	|	ВТДоставкаОбороты.Серия
	|ИМЕЮЩИЕ
	|	СУММА(ВТДоставкаОбороты.КДоставкеОборот) <> СУММА(ВТДоставкаОбороты.ДоставленоОборот)
	|
	|УПОРЯДОЧИТЬ ПО
	|	МИНИМУМ(ВТУпорядочивание.Порядок)
	|ИТОГИ
	|	СУММА(КоличествоСтрокТоваров),
	|	СУММА(КДоставкеОборот),
	|	СУММА(КРейсуОборот),
	|	СУММА(ВРейсеОборот),
	|	СУММА(ВПутиОборот),
	|	СУММА(ДоставленоОборот)
	|
	|ПО
	|	Документ";
	
	ТекстЗапроса = ТекстЗапроса + ОбщегоНазначения.РазделительПакетаЗапросов();
	Возврат ТекстЗапроса;
	
КонецФункции

