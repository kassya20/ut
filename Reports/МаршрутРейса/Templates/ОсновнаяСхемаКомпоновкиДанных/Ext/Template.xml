		<query>ВЫБРАТЬ
	Маршрут.Ссылка КАК Ссылка,
	Маршрут.НомерСтроки КАК НомерСтроки,
	Маршрут.Пункт КАК Пункт,
	Маршрут.ТочкаДоставки КАК ТочкаДоставки,
	Маршрут.ЗонаДоставки КАК ЗонаДоставки,
	Маршрут.Операция КАК Операция,
	ЕСТЬNULL(Содержимое.НомерСтроки, 0) КАК НомерСтрокиСодержимого,
	ЕСТЬNULL(Содержимое.Распоряжение, НЕОПРЕДЕЛЕНО) КАК Распоряжение,
	ЕСТЬNULL(Содержимое.Номенклатура, ЗНАЧЕНИЕ(Справочник.Номенклатура.ПустаяСсылка)) КАК Номенклатура,
	ЕСТЬNULL(Содержимое.Характеристика, ЗНАЧЕНИЕ(Справочник.ХарактеристикиНоменклатуры.ПустаяСсылка)) КАК Характеристика,
	ЕСТЬNULL(Содержимое.Серия, ЗНАЧЕНИЕ(Справочник.СерииНоменклатуры.ПустаяСсылка)) КАК Серия,
	ЕСТЬNULL(Содержимое.Количество, 0) КАК Количество,
	ЕСТЬNULL(Содержимое.КонечнаяТочкаДоставки, ЗНАЧЕНИЕ(Справочник.ТочкиДоставки.ПустаяСсылка)) КАК	КонечнаяТочкаДоставки,
	ЕСТЬNULL(Содержимое.КонечнаяЗонаДоставки, ЗНАЧЕНИЕ(Справочник.ЗоныДоставки.ПустаяСсылка)) КАК КонечнаяЗонаДоставки
{ВЫБРАТЬ
	Ссылка.* КАК Рейс,
	НомерСтроки КАК НомерСтрокиМаршрута,
	Пункт.* КАК ПунктМаршрута,
	ТочкаДоставки.*,
	ЗонаДоставки.*,
	Операция,
	НомерСтрокиСодержимого,
	Распоряжение.*,
	Номенклатура.*,
	Характеристика.*,
	Серия.*,
	Количество,
	КонечнаяТочкаДоставки.*,
	КонечнаяЗонаДоставки
}
ИЗ
	Документ.Рейс.Маршрут КАК Маршрут
		ЛЕВОЕ СОЕДИНЕНИЕ Документ.Рейс.Содержимое КАК Содержимое
		ПО Маршрут.Ссылка = Содержимое.Ссылка
		И Маршрут.КлючСвязи = Содержимое.КлючСвязи
		И НЕ Содержимое.Отменено
ГДЕ
	Маршрут.Ссылка = &amp;Рейс
	И НЕ Маршрут.Отменено
{ГДЕ
	Пункт.*,
	Маршрут.НомерСтроки КАК НомерСтрокиМаршрута,
	ТочкаДоставки.*,
	ЗонаДоставки.*,
	Операция,
	Распоряжение.*,
	Номенклатура.*,
	Характеристика.*,
	Серия.*,
	Количество
}</query>
		<autoFillFields>false</autoFillFields>
