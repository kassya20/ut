Функция ИспользованиеРазделаУчетаПоФункциональнымОпциям(ЭлементОтбора)
	
	ТипЭлементаОтбора = ТипЗнч(ЭлементОтбора);
	
	ЭтоЛогическоеСложение = ТипЭлементаОтбора = Тип("ГруппаЭлементовОтбораКомпоновкиДанных")
		И ЭлементОтбора.ТипГруппы = ТипГруппыЭлементовОтбораКомпоновкиДанных.ГруппаИли;
	
	ЭтоЛогическоеУмножение = ТипЭлементаОтбора = Тип("ОтборКомпоновкиДанных")
		ИЛИ (ТипЭлементаОтбора = Тип("ГруппаЭлементовОтбораКомпоновкиДанных")
		И ЭлементОтбора.ТипГруппы = ТипГруппыЭлементовОтбораКомпоновкиДанных.ГруппаИ);
	
	Если ЭтоЛогическоеУмножение Тогда
		РазделУчетаИспользуется = Истина;
		Для Каждого ПодчиненныйЭлемент Из ЭлементОтбора.Элементы Цикл
			Если НЕ ИспользованиеРазделаУчетаПоФункциональнымОпциям(ПодчиненныйЭлемент) Тогда
				РазделУчетаИспользуется = Ложь;
				Прервать;
			КонецЕсли;
		КонецЦикла;
	ИначеЕсли ЭтоЛогическоеСложение Тогда
		РазделУчетаИспользуется = Ложь;
		Для Каждого ПодчиненныйЭлемент Из ЭлементОтбора.Элементы Цикл
			Если ИспользованиеРазделаУчетаПоФункциональнымОпциям(ПодчиненныйЭлемент) Тогда
				РазделУчетаИспользуется = Истина;
				Прервать;
			КонецЕсли;
		КонецЦикла;
	ИначеЕсли ТипЭлементаОтбора = Тип("ЭлементОтбораКомпоновкиДанных") Тогда
		РазделУчетаИспользуется = ПолучитьФункциональнуюОпцию(Строка(ЭлементОтбора.ЛевоеЗначение));
		ЭлементОтбора.ПравоеЗначение = РазделУчетаИспользуется;
	Иначе
		РазделУчетаИспользуется = Истина;
	КонецЕсли;
	
	Возврат РазделУчетаИспользуется;
	
КонецФункции

Функция ИменаТаблицРесурсов()
	
	ИменаТаблицРесурсов = Новый Массив();
	ИменаТаблицРесурсов.Добавить(ГруппаРесурсовУправленческогоУчета());
	ИменаТаблицРесурсов.Добавить(ГруппаРесурсовРегламентированногоУчета());
	ИменаТаблицРесурсов.Добавить(ГруппаРесурсовВалютногоУчета());
	ИменаТаблицРесурсов.Добавить(ГруппаРесурсовКоличественногоУчета());
	
	Возврат ИменаТаблицРесурсов;
	
КонецФункции

Процедура ЗаполнитьТаблицыРесурсов(ОписаниеОбъектаУчета, ВыборкаЗапросаОбъектовУчета)
	
	ИменаТаблицРесурсов = ИменаТаблицРесурсов();
	
	Для Каждого ИмяТаблицы Из ИменаТаблицРесурсов Цикл
		РезультатЗапросаРесурсов = ВыборкаЗапросаОбъектовУчета[ИмяТаблицы]; // РезультатЗапроса -
		ВыборкаРесурсов = РезультатЗапросаРесурсов.Выбрать();
		ТаблицаРесурсов = НоваяТаблицаРесурсов();
		
		Пока ВыборкаРесурсов.Следующий() Цикл
			ЗаполнитьЗначенияСвойств(ТаблицаРесурсов.Добавить(), ВыборкаРесурсов);
		КонецЦикла;
		
		ТаблицаРесурсов.Сортировать("ИмяРесурса");
		ОписаниеОбъектаУчета[ИмяТаблицы] = ТаблицаРесурсов;
	КонецЦикла;
	
КонецПроцедуры

Процедура ЗаполнитьОписанияПоказателей(ОписаниеОбъектаУчета, ВыборкаЗапросаОбъектовУчета)
	
	ИменаТаблицРесурсов = ИменаТаблицРесурсов();
	
	Для Каждого ИмяТаблицы Из ИменаТаблицРесурсов Цикл
		РезультатЗапросаРесурсов = ВыборкаЗапросаОбъектовУчета[ИмяТаблицы]; // РезультатЗапроса -
		ВыборкаРесурсов = РезультатЗапросаРесурсов.Выбрать();
		
		Пока ВыборкаРесурсов.Следующий() Цикл
			Если ОписаниеОбъектаУчета.Показатели[ВыборкаРесурсов.Показатель] = Неопределено Тогда
				ОписаниеПоказателя = НовоеОписаниеПоказателя();
				ОписаниеОбъектаУчета.Показатели.Вставить(ВыборкаРесурсов.Показатель, ОписаниеПоказателя);
			КонецЕсли;
			
			ТаблицаРесурсов = ОписаниеОбъектаУчета.Показатели[ВыборкаРесурсов.Показатель][ИмяТаблицы];
			ЗаполнитьЗначенияСвойств(ТаблицаРесурсов.Добавить(), ВыборкаРесурсов);
		КонецЦикла;
	КонецЦикла;
	
	РезультатЗапросаПоказателей = ВыборкаЗапросаОбъектовУчета.ДополнительныеПоказатели; // РезультатЗапроса -
	ВыборкаПоказателей = РезультатЗапросаПоказателей.Выбрать();
	
	Пока ВыборкаПоказателей.Следующий() Цикл
		Если ИменаТаблицРесурсов.Найти(ВыборкаПоказателей.ГруппаРесурсов) = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		Если ОписаниеОбъектаУчета.Показатели[ВыборкаПоказателей.Показатель] = Неопределено Тогда
			ОписаниеПоказателя = НовоеОписаниеПоказателя();
			ОписаниеОбъектаУчета.Показатели.Вставить(ВыборкаПоказателей.Показатель, ОписаниеПоказателя);
		КонецЕсли;
		
		ТаблицаРесурсов = ОписаниеОбъектаУчета.Показатели[ВыборкаПоказателей.Показатель][ВыборкаПоказателей.ГруппаРесурсов];
		ЗаполнитьЗначенияСвойств(ТаблицаРесурсов.Добавить(), ВыборкаПоказателей);
	КонецЦикла;
	
КонецПроцедуры

Процедура ЗаполнитьСвойстваПрочихАктивовПассивов(ОписаниеОбъектаУчета)
	
	Если ОписаниеОбъектаУчета.ОтборДанных.Элементы.Количество() = 0 Тогда
		НовыйЭлемент = ОписаниеОбъектаУчета.ОтборДанных.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
		НовыйЭлемент.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("Статья");
		НовыйЭлемент.ВидСравнения = ВидСравненияКомпоновкиДанных.Равно;
		НовыйЭлемент.ПравоеЗначение = ОписаниеОбъектаУчета.ОбъектУчета;
	КонецЕсли;
	
	МетаИсточникДанныхПрочихАктивовПассивов = Метаданные.РегистрыНакопления.ДвиженияПоПрочимАктивамПассивам;
	РесурсыИсточникаПрочихАктивовПассивов = МетаИсточникДанныхПрочихАктивовПассивов.Ресурсы;
	
	Если ОписаниеОбъектаУчета.РесурсыУпр.Количество() = 0 Тогда
		ДобавитьРесурсы(ОписаниеОбъектаУчета.РесурсыУпр, РесурсыИсточникаПрочихАктивовПассивов.СуммаУпр.Имя);
	КонецЕсли;
	
	Если ОписаниеОбъектаУчета.РесурсыРегл.Количество() = 0 Тогда
		ДобавитьРесурсы(ОписаниеОбъектаУчета.РесурсыРегл, РесурсыИсточникаПрочихАктивовПассивов.СуммаРегл.Имя);
	КонецЕсли;
	
	Если ОписаниеОбъектаУчета.Показатели.Количество() = 0 Тогда
		ОписаниеПоказателя = НовоеОписаниеПоказателя();
		ДобавитьРесурсы(ОписаниеПоказателя.РесурсыУпр, РесурсыИсточникаПрочихАктивовПассивов.СуммаУпр.Имя);
		ДобавитьРесурсы(ОписаниеПоказателя.РесурсыРегл, РесурсыИсточникаПрочихАктивовПассивов.СуммаРегл.Имя);
		ОписаниеОбъектаУчета.Показатели.Вставить(Перечисления.ПоказателиАналитическихРегистров.Сумма, ОписаниеПоказателя);
	КонецЕсли;
	
КонецПроцедуры

Функция КопияОписанияОбъектаУчета(ОписаниеОбъектаУчета)
	
	ОписаниеОбъектовУчета = ОписаниеОбъектаУчета.Владелец();
	КопияОписанияОбъектаУчета = ОписаниеОбъектовУчета.Добавить();
	
	ИменаТабличныхЧастей = ИменаТаблицРесурсов();
	ИменаТабличныхЧастей.Добавить("ПутиКДаннымСубконто");
	
	ИсключаемыеСвойства = СтрСоединить(ИменаТабличныхЧастей, ",");
	ИсключаемыеСвойства = ИсключаемыеСвойства + ",Показатели";
	
	ЗаполнитьЗначенияСвойств(КопияОписанияОбъектаУчета, ОписаниеОбъектаУчета,, ИсключаемыеСвойства);
	
	Для Каждого ИмяТабличнойЧасти Из ИменаТабличныхЧастей Цикл
		КопияОписанияОбъектаУчета[ИмяТабличнойЧасти] = ОписаниеОбъектаУчета[ИмяТабличнойЧасти].Скопировать();
	КонецЦикла;
	
	КопияОписанияОбъектаУчета.Показатели = ОбщегоНазначения.СкопироватьРекурсивно(ОписаниеОбъектаУчета.Показатели);
	
	Возврат КопияОписанияОбъектаУчета;
	
КонецФункции

Процедура ПодавитьДанныеИсточникаБезОтбора(ОписаниеОбъектаУчета)
	
	ОписаниеОбъектовУчета = ОписаниеОбъектаУчета.Владелец();
	
	НеиспользуемыеДанные = ОписаниеОбъектовУчета.Добавить();
	НеиспользуемыеДанные.ОбъектУчета = ПланыВидовХарактеристик.СтатьиАктивовПассивов.ПустаяСсылка();
	НеиспользуемыеДанные.ИсточникДанных = ОписаниеОбъектаУчета.ИсточникДанных;
	НеиспользуемыеДанные.ПутьКДаннымИдентификаторФинЗаписи = "&ИдентификаторНеиспользуемойФинЗаписи";
	
	ИменаТаблицРесурсов = ИменаТаблицРесурсов();
	
	Для Каждого ИмяТаблицы Из ИменаТаблицРесурсов Цикл
		НеиспользуемыеДанные[ИмяТаблицы] = ОписаниеОбъектаУчета[ИмяТаблицы].Скопировать();
	КонецЦикла;
	
	НеиспользуемыеДанные.ПутиКДаннымСубконто = ОписаниеОбъектаУчета.ПутиКДаннымСубконто.СкопироватьКолонки();
	
КонецПроцедуры

Процедура ЗаполнитьПризнакиУчетаКорреспонденций(ОписаниеОбъектаУчета, ПризнакУчета, Значение)
	
	ПризнакиУчетаКорреспонденций = НоваяТаблицаПризнакиУчетаКорреспонденций();
	
	Если ОписаниеОбъектаУчета.ОбъектУчета = ВыручкаОтПродаж
	 ИЛИ ОписаниеОбъектаУчета.ОбъектУчета = ВыручкаОтПродажСНДС
	 ИЛИ ОписаниеОбъектаУчета.ОбъектУчета = РасчетыПоНДС
	 ИЛИ ОписаниеОбъектаУчета.ОбъектУчета = НДСПоОтгрузкамБезПереходаПраваСобственности Тогда
		НоваяСтрока = ПризнакиУчетаКорреспонденций.Добавить();
		НоваяСтрока.ОбъектУчета = ЗадолженностьКлиентов;
		
		НоваяСтрока = ПризнакиУчетаКорреспонденций.Добавить();
		НоваяСтрока.ОбъектУчета = АвансыПолученныеОтКлиентов;
		
		НоваяСтрока = ПризнакиУчетаКорреспонденций.Добавить();
		НоваяСтрока.ОбъектУчета = РасчетыСРозничнымиПокупателями;
	КонецЕсли;
	
	Если ОписаниеОбъектаУчета.ОбъектУчета = ПрочаяВыручка
	 ИЛИ ОписаниеОбъектаУчета.ОбъектУчета = ПрочаяВыручкаСНДС Тогда
		НоваяСтрока = ПризнакиУчетаКорреспонденций.Добавить();
		НоваяСтрока.ОбъектУчета = ЗадолженностьКлиентов;
		
		НоваяСтрока = ПризнакиУчетаКорреспонденций.Добавить();
		НоваяСтрока.ОбъектУчета = АвансыПолученныеОтКлиентов;
		
		НоваяСтрока = ПризнакиУчетаКорреспонденций.Добавить();
		НоваяСтрока.ОбъектУчета = ЗаймыВыданные;
		
		НоваяСтрока = ПризнакиУчетаКорреспонденций.Добавить();
		НоваяСтрока.ОбъектУчета = ДепозитыКредитыЗаймыВыданныеКомиссия;
		
		НоваяСтрока = ПризнакиУчетаКорреспонденций.Добавить();
		НоваяСтрока.ОбъектУчета = ДепозитыКредитыЗаймыВыданныеПроценты;
	КонецЕсли;
	
	Если ОписаниеОбъектаУчета.ОбъектУчета = НДССПродаж
	 ИЛИ ОписаниеОбъектаУчета.ОбъектУчета = НДССПрочихПродаж Тогда
		НоваяСтрока = ПризнакиУчетаКорреспонденций.Добавить();
		НоваяСтрока.ОбъектУчета = РасчетыПоНДС;
		
		НоваяСтрока = ПризнакиУчетаКорреспонденций.Добавить();
		НоваяСтрока.ОбъектУчета = НДСПоОтгрузкамБезПереходаПраваСобственности;
	КонецЕсли;
	
	ПризнакиУчетаКорреспонденций.ЗаполнитьЗначения(ПризнакУчета, "ПризнакУчета");
	ПризнакиУчетаКорреспонденций.ЗаполнитьЗначения(Значение, "Значение");
	
	ОписаниеОбъектаУчета.ПризнакиУчетаКорреспонденций = ПризнакиУчетаКорреспонденций;
	
КонецПроцедуры

#КонецОбласти

Функция МассивИменОбъектов(ИменаОбъектов)
	
	Если ТипЗнч(ИменаОбъектов) = Тип("Строка") Тогда
		Возврат СтрРазделить(ИменаОбъектов, ",");
	Иначе
		Возврат ОбщегоНазначенияУТКлиентСервер.Массив(ИменаОбъектов);
	КонецЕсли;
	
КонецФункции

Функция ОписаниеТиповПоПолномуИмениОбъекта(ПолноеИмяОбъекта)
	
	Если ПустаяСтрока(ПолноеИмяОбъекта) Тогда
		Возврат Новый ОписаниеТипов();
	КонецЕсли;
	
	МенеджерОбъекта = ОбщегоНазначения.МенеджерОбъектаПоПолномуИмени(ПолноеИмяОбъекта);
	ПустаяСсылка = МенеджерОбъекта.ПустаяСсылка();
	
	Возврат ОбщегоНазначенияУТ.ОписаниеТиповПоТипу(ТипЗнч(ПустаяСсылка));
	
КонецФункции

Функция ОтборКомпоновкиИзХранилищаНастроек(ХранилищеНастроек)
	
	ОтборКомпоновкиДанных = Новый ОтборКомпоновкиДанных();
	
	НастройкиКомпоновкиДанных = ХранилищеНастроек.Получить();
	Если ТипЗнч(НастройкиКомпоновкиДанных) = Тип("НастройкиКомпоновкиДанных") Тогда
		КомпоновкаДанныхКлиентСервер.СкопироватьЭлементы(ОтборКомпоновкиДанных, НастройкиКомпоновкиДанных.Отбор);
	КонецЕсли;
	
	Возврат ОтборКомпоновкиДанных;
	
КонецФункции

