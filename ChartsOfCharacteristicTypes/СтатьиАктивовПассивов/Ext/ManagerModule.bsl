КонецФункции

// Дополняет таблицу объектов финансового учета свойствами для обращения к данным.
// Если какой-либо параметр является выражением языка запросов, то описания полей в нем должны содержать
// псевдоним источника данных, полученный через функцию ФинансовыйУчетПоДаннымБалансовыхРегистров.ПсевдонимИсточникаДанныхПоУмолчанию().
// Если параметр является только именем поля,в том числе разыменованным через точку, его можно указывать без псевдонима источника данных.
// Допускается использовать параметры запроса из функции МеждународныйУчетПоДаннымФинансовыхРегистров.ЗапросДанныхФинансовыхРегистров().
// Допускается использовать строковые шаблоны из функции МеждународныйУчетПоДаннымФинансовыхРегистров.ТекстыЗапросовЗаписейРегистров().
// 
// Параметры:
//  НастройкиУчета - см. НастройкиФинансовогоУчета
//  ОписаниеОбъектовУчета - см. НоваяТаблицаОбъектовФинансовогоУчета
// 
Процедура ДополнитьОписаниеОбъектовУчетаДляПолученияДанных(НастройкиУчета, ОписаниеОбъектовУчета)
	
	МетаРегистрыНакопления = Метаданные.РегистрыНакопления;
	ПоказателиАналитическихРегистров = Перечисления.ПоказателиАналитическихРегистров;
	ДобавитьОписаниеСлужебныхОбъектов = ОписаниеОбъектовУчета.Количество() > 1;
	
	
	
	ОписаниеОбъектаУчета = ОписаниеОбъектовУчета.Найти(ОбязательстваПоНеотфактурованнымПоставкам, "ОбъектУчета");
	Если ОписаниеОбъектаУчета <> Неопределено Тогда
		ОписаниеОбъектаУчета.ПутьКДаннымОбъектНастройки = "НЕОПРЕДЕЛЕНО";
	КонецЕсли;
	
	ОписаниеОбъектаУчета = ОписаниеОбъектовУчета.Найти(ОбязательстваПоНеотфактурованномуНДС, "ОбъектУчета");
	Если ОписаниеОбъектаУчета <> Неопределено Тогда
		ОписаниеОбъектаУчета.ПутьКДаннымИдентификаторФинЗаписи = "&ИдентификаторНеиспользуемойФинЗаписи";
		Если ДобавитьОписаниеСлужебныхОбъектов Тогда
			ПодавитьДанныеИсточникаБезОтбора(ОписаниеОбъектаУчета);
		КонецЕсли;
	КонецЕсли;
	
	ОписаниеОбъектаУчета = ОписаниеОбъектовУчета.Найти(АвансыВыданныеПоставщикам, "ОбъектУчета");
	Если ОписаниеОбъектаУчета <> Неопределено Тогда
		ОписаниеОбъектаУчета.УсловиеДебет = СтрЗаменить(
			"ПсевдонимИсточникаДанных.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход)",
			"ПсевдонимИсточникаДанных",
			ФинансовыйУчетПоДаннымБалансовыхРегистров.ПсевдонимИсточникаДанныхПоУмолчанию());
		ОписаниеОбъектаУчета.УсловиеКредит = СтрЗаменить(
			"ПсевдонимИсточникаДанных.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход)",
			"ПсевдонимИсточникаДанных",
			ФинансовыйУчетПоДаннымБалансовыхРегистров.ПсевдонимИсточникаДанныхПоУмолчанию());
	КонецЕсли;
	
	ОписаниеОбъектаУчета = ОписаниеОбъектовУчета.Найти(ЗадолженностьПередПоставщиками, "ОбъектУчета");
	Если ОписаниеОбъектаУчета <> Неопределено Тогда
		ОписаниеОбъектаУчета.ИнверсияДвижений = Истина;
