			"ПсевдонимИсточникаДанных",
			ФинансовыйУчетПоДаннымБалансовыхРегистров.ПсевдонимИсточникаДанныхПоУмолчанию());
		ОписаниеОбъектаУчета.УсловиеКредит = СтрЗаменить(
			"ПсевдонимИсточникаДанных.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход)",
			"ПсевдонимИсточникаДанных",
			ФинансовыйУчетПоДаннымБалансовыхРегистров.ПсевдонимИсточникаДанныхПоУмолчанию());
	КонецЕсли;
	
	ОписаниеОбъектаУчета = ОписаниеОбъектовУчета.Найти(ЗадолженностьКлиентов, "ОбъектУчета");
	Если ОписаниеОбъектаУчета <> Неопределено Тогда
		ОписаниеОбъектаУчета.УсловиеДебет = СтрЗаменить(
			"ПсевдонимИсточникаДанных.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход)",
			"ПсевдонимИсточникаДанных",
			ФинансовыйУчетПоДаннымБалансовыхРегистров.ПсевдонимИсточникаДанныхПоУмолчанию());
		ОписаниеОбъектаУчета.УсловиеКредит = СтрЗаменить(
