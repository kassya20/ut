	НоваяСтрока = ТаблицаПоказателей.Добавить();
	НоваяСтрока.Показатель = ПоказателиАналитическихРегистров.СуммаДопРасходовБезНДС;
	НоваяСтрока.ГруппаРесурсов = ГруппаРесурсовУправленческогоУчета();
	НоваяСтрока.ИмяРесурса = "Трудозатраты";
	НоваяСтрока.Коэффициент = 1;
	
	НоваяСтрока = ТаблицаПоказателей.Добавить();
