	КонецЕсли;
	
	ОписаниеОбъектаУчета = ОписаниеОбъектовУчета.Найти(Налоги, "ОбъектУчета");
	Если ОписаниеОбъектаУчета <> Неопределено Тогда
		ОписаниеОбъектаУчета.ПутьКДаннымОбъектНастройки = "Аналитика";
