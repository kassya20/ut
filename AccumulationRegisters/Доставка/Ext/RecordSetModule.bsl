#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ОбработчикиСобытий

Процедура ПередЗаписью(Отказ, Замещение)
	
	Если ОбменДанными.Загрузка
	 ИЛИ НЕ ПроведениеДокументов.РассчитыватьИзменения(ДополнительныеСвойства) Тогда
		Возврат;
	КонецЕсли;
	
	ДополнительныеСвойстваМВТ = ДополнительныеСвойства.МенеджерВременныхТаблиц; // МенеджерВременныхТаблиц
	
	Если ДополнительныеСвойстваМВТ.Таблицы.Найти("ДвиженияДоставкаПередЗаписью") <> Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ДополнительныеСвойстваДокумента = ДополнительныеСвойства.СвойстваДокумента; // См. ПроведениеДокументов.СвойстваДокумента
	
	Регистраторы = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(
		ДополнительныеСвойства, "Регистраторы", Новый Массив); // Массив Из ДокументСсылка
	
	Если ЗначениеЗаполнено(Отбор.Регистратор.Значение) Тогда
		
		// Отмена проведения
		Регистраторы.Добавить(Отбор.Регистратор.Значение);
		
	КонецЕсли;
	
	Регистраторы = ОбщегоНазначенияКлиентСервер.СвернутьМассив(Регистраторы);  // Массив Из ДокументСсылка
	
	Запрос = Новый Запрос;
	ТекстЗапроса = ТекстЗапросаПередЗаписью();
	Запрос.Текст = ТекстЗапроса;
	
	Запрос.УстановитьПараметр("Регистраторы", Регистраторы);
	Запрос.УстановитьПараметр("ЭтоНовый", ДополнительныеСвойстваДокумента.ЭтоНовый);
	Запрос.УстановитьПараметр("ОбменДанными", ОбменДанными.Загрузка);
	РассчитыватьИзменения = ПроведениеДокументов.РассчитыватьИзменения(ДополнительныеСвойства);
	Запрос.УстановитьПараметр("РассчитыватьИзменения", РассчитыватьИзменения);
	Запрос.МенеджерВременныхТаблиц = ДополнительныеСвойстваМВТ;
	
	Запрос.Выполнить();
	
КонецПроцедуры

Процедура ПриЗаписи(Отказ, Замещение)
	
	Если ОбменДанными.Загрузка
	 ИЛИ НЕ ПроведениеДокументов.РассчитыватьИзменения(ДополнительныеСвойства) Тогда
		Возврат;
	КонецЕсли;
	
	ФиксироватьИзмененияПослеЗаписи = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(
		ДополнительныеСвойства, "ФиксироватьИзмененияПослеЗаписи", Истина);
	
	Если ФиксироватьИзмененияПослеЗаписи Тогда
		
		СформироватьТаблицуИзменений();
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

