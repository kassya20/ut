Функция ТекстЗапросаЕстьИзмененияМерныхТоваров()
	
	ТекстЗапроса =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	ИСТИНА КАК ЕстьИзмененияМерныхТоваров
	|ИЗ
	|	(ВЫБРАТЬ РАЗЛИЧНЫЕ
	|		ВЫРАЗИТЬ(ДвиженияДоставкаИзменение.Номенклатура КАК Справочник.Номенклатура) КАК Номенклатура
	|	ИЗ
	|		ДвиженияДоставкаИзменение КАК ДвиженияДоставкаИзменение) КАК НоменклатураИзменений
	|ГДЕ
	|	НоменклатураИзменений.Номенклатура.ЕдиницаИзмерения.ТипИзмеряемойВеличины В(&МерныеТипыЕдиницИзмерений)";
	
	Возврат ТекстЗапроса;
	
КонецФункции

Процедура СформироватьТаблицуИзменений()
	
	Регистраторы = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(
		ДополнительныеСвойства, "Регистраторы", Новый Массив); // Массив Из ДокументСсылка
	
	ДополнительныеСвойстваМВТ = ДополнительныеСвойства.МенеджерВременныхТаблиц; // МенеджерВременныхТаблиц
	
	Если ЗначениеЗаполнено(Отбор.Регистратор.Значение) Тогда
		
		// Отмена проведения
		Регистраторы.Добавить(Отбор.Регистратор.Значение);
		
	КонецЕсли;
	
	Регистраторы = ОбщегоНазначенияКлиентСервер.СвернутьМассив(Регистраторы);  // Массив Из ДокументСсылка
	
	Запрос = Новый Запрос;
	ТекстЗапроса = ТекстЗапросаИзмененияПослеЗаписи();
	Запрос.Текст = ТекстЗапроса;
	
	Запрос.УстановитьПараметр("Регистраторы", Регистраторы);
	Запрос.УстановитьПараметр("ОбменДанными", ОбменДанными.Загрузка);
	РассчитыватьИзменения = ПроведениеДокументов.РассчитыватьИзменения(ДополнительныеСвойства);
	Запрос.УстановитьПараметр("РассчитыватьИзменения", РассчитыватьИзменения);
	Запрос.МенеджерВременныхТаблиц = ДополнительныеСвойстваМВТ;
	
	Результат = Запрос.ВыполнитьПакет();
	ВыборкаИзменение = Результат[Результат.ВГраница() - 2].Выбрать();
	ЕстьИзменения = (ВыборкаИзменение.Следующий() И ВыборкаИзменение.Количество > 0);
	
	ПараметрыТаблицыКонтроля = ДоставкаТоваров.НовыеПараметрыТаблицыКонтроляДоставки();
	ВыборкаФлаги = Результат[Результат.ВГраница() - 1].Выбрать();
	Если ВыборкаФлаги.Следующий() Тогда
		ЗаполнитьЗначенияСвойств(ПараметрыТаблицыКонтроля, ВыборкаФлаги);
	КонецЕсли;
	
	Если ЕстьИзменения
		И ПолучитьФункциональнуюОпцию("ИспользоватьДопустимоеОтклонениеОтгрузкиПриемкиМерныхТоваров") Тогда
		
		ТекстЗапроса = ТекстЗапросаЕстьИзмененияМерныхТоваров();
		Запрос.Текст = ТекстЗапроса;
		МерныеТипыЕдиницИзмерений = Справочники.УпаковкиЕдиницыИзмерения.МерныеТипыЕдиницИзмерений();
		Запрос.УстановитьПараметр("МерныеТипыЕдиницИзмерений", МерныеТипыЕдиницИзмерений);
		
		Выборка = Запрос.Выполнить().Выбрать();
		Если Выборка.Следующий() Тогда
			ЗаполнитьЗначенияСвойств(ПараметрыТаблицыКонтроля, Выборка);
		КонецЕсли;
		
	КонецЕсли;
	
	ПроведениеДокументов.ЗарегистрироватьТаблицуКонтроля(
		ДополнительныеСвойства,
		"ДвиженияДоставкаИзменение",
		ЕстьИзменения,
		ПараметрыТаблицыКонтроля);
	
КонецПроцедуры

#КонецОбласти

#КонецЕсли
