	|	Регистратор";	

	ВыборкаРегистратор = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	Пока ВыборкаРегистратор.Следующий() Цикл
		
		Регистратор = ВыборкаРегистратор.Регистратор;
		ПричинаИсключения = "";
		Рекомендация = "";
	
		СписокОписаний = Новый Массив;
		СписокОписаний.Добавить(НСтр("ru = 'Не удалось выполнить заполнение регистра ""Прочие доходы"" по данным регистра ""(Не используется) Прочие доходы"".'"));
		
		НачатьТранзакцию();
		
		Попытка
			
			ПричинаИсключения = "Блокировка";
			
			Блокировка = Новый БлокировкаДанных;
			
			ЭлементБлокировки = Блокировка.Добавить("РегистрНакопления.УдалитьПрочиеДоходы.НаборЗаписей");
			ЭлементБлокировки.УстановитьЗначение("Регистратор", Регистратор);
			ЭлементБлокировки.Режим = РежимБлокировкиДанных.Исключительный;
			
			Блокировка.Заблокировать();
				
			ПричинаИсключения = "ПлохиеДанные";
			Рекомендация = НСтр("ru = 'Перепроведите документ вручную.'");
			
			НаборЗаписей = РегистрыНакопления.ПрочиеДоходы.СоздатьНаборЗаписей();
			НаборЗаписей.Отбор.Регистратор.Установить(Регистратор);
			
			Выборка = ВыборкаРегистратор.Выбрать();
			
			Пока Выборка.Следующий() Цикл
				Запись = НаборЗаписей.Добавить();
				ЗаполнитьЗначенияСвойств(Запись, Выборка);
			КонецЦикла;
			
			ПричинаИсключения = "Запись";
			
			Если НаборЗаписей.Модифицированность() Тогда
				ОбновлениеИнформационнойБазы.ЗаписатьНаборЗаписей(НаборЗаписей);
			КонецЕсли;
			СтарыйНаборЗаписей = РегистрыНакопления.УдалитьПрочиеДоходы.СоздатьНаборЗаписей();
			СтарыйНаборЗаписей.Отбор.Регистратор.Установить(Регистратор);
			
			ОбновлениеИнформационнойБазы.ОтметитьВыполнениеОбработки(СтарыйНаборЗаписей);

			СтруктураПоиска = Новый Структура("Регистратор", Регистратор);
			Строки = ОбновляемыеДанные.НайтиСтроки(СтруктураПоиска);
			Если Строки.Количество() > 0 Тогда
				ОбщегоНазначенияУТ.УдалитьСтрокиТаблицы(ОбновляемыеДанные, Строки);
			КонецЕсли;
			ЗафиксироватьТранзакцию();
			
		Исключение
			
			ОтменитьТранзакцию();
			ОбновлениеИнформационнойБазыУТ.СообщитьОНеудачнойОбработке(ИнформацияОбОшибке(), Регистратор);
			
			Если ПричинаИсключения = "ПлохиеДанные" Тогда
				
				ОбновлениеИнформационнойБазы.ЗарегистрироватьПроблемуСДанными(Регистратор, Рекомендация, Параметры);
				
			ИначеЕсли ПричинаИсключения = "Запись" Тогда
				
				ВызватьИсключение СтрСоединить(СписокОписаний, Символы.ПС);
				
			КонецЕсли;
			
		КонецПопытки;
	
	КонецЦикла;
	
	Если ОбновляемыеДанные.Количество() > 0 Тогда 
		Для Каждого Строка Из ОбновляемыеДанные Цикл 
			СтарыйНаборЗаписей = РегистрыНакопления.УдалитьПрочиеДоходы.СоздатьНаборЗаписей();
			СтарыйНаборЗаписей.Отбор.Регистратор.Установить(Строка.Регистратор);
			
			ОбновлениеИнформационнойБазы.ОтметитьВыполнениеОбработки(СтарыйНаборЗаписей);
		КонецЦикла;
	КонецЕсли;

	Параметры.ОбработкаЗавершена = ОбновлениеИнформационнойБазы.ОбработкаДанныхЗавершена(Параметры.Очередь, "РегистрНакопления.УдалитьПрочиеДоходы");

КонецПроцедуры

Процедура ОбработатьДанныеДляПереходаНаНовуюВерсию_ЗаданияКЗакрытиюМесяца(Параметры) Экспорт

	ВыбранныеДанные = ОбновлениеИнформационнойБазы.ДанныеДляОбновленияВМногопоточномОбработчике(Параметры);
	МетаданныеРегистра = Метаданные.РегистрыСведений.ЗаданияКЗакрытиюМесяца;
	ПолноеИмяРегистра= МетаданныеРегистра.ПолноеИмя();
	
	Для Каждого ТекущиеДанные Из ВыбранныеДанные Цикл
		Набор = РегистрыСведений.ЗаданияКЗакрытиюМесяца.СоздатьНаборЗаписей();
		Набор.Отбор.Месяц.Установить(ТекущиеДанные.Месяц);
		Набор.Отбор.Операция.Установить(ТекущиеДанные.Операция);
		Набор.Отбор.Организация.Установить(ТекущиеДанные.Организация);
		НачатьТранзакцию();
		Попытка
			БлокировкаДанных = Новый БлокировкаДанных;
			
			ЭлементБлокировки= БлокировкаДанных.Добавить(ПолноеИмяРегистра);
			ЭлементБлокировки.УстановитьЗначение("Месяц",   ТекущиеДанные.Месяц);
			ЭлементБлокировки.УстановитьЗначение("Операция", ТекущиеДанные.Операция);
			ЭлементБлокировки.УстановитьЗначение("Организация", ТекущиеДанные.Организация);
			
			БлокировкаДанных.Заблокировать();
			
			Запись = Набор.Добавить();
			ЗаполнитьЗначенияСвойств(Запись, ТекущиеДанные);
			Запись.НомерЗадания = РегистрыСведений.ЗаданияКЗакрытиюМесяца.ПолучитьНомерЗадания();
			
			ОбновлениеИнформационнойБазы.ЗаписатьНаборЗаписей(Набор);
			ЗафиксироватьТранзакцию();
		Исключение
			ОтменитьТранзакцию();
			ОбновлениеИнформационнойБазыУТ.СообщитьОНеудачнойОбработке(ИнформацияОбОшибке(), Набор);
		КонецПопытки;
	КонецЦикла;
	
	Параметры.ОбработкаЗавершена = Не ОбновлениеИнформационнойБазы.ЕстьДанныеДляОбработки(Параметры.Очередь, ПолноеИмяРегистра);
	
КонецПроцедуры

