#Область ОбновлениеИнформационнойБазы

// Добавляет в список процедуры-обработчики обновления данных ИБ
// для всех поддерживаемых версий библиотеки или конфигурации.
// Вызывается перед началом обновления данных ИБ для построения плана обновления.
//
// Параметры:
// 	Обработчики - см. ОбновлениеИнформационнойБазы.НоваяТаблицаОбработчиковОбновления
//
Процедура ПриДобавленииОбработчиковОбновления(Обработчики) Экспорт

	Обработчик = Обработчики.Добавить();
	Обработчик.Процедура = "РегистрыНакопления.РасчетыСПоставщиками.ОбработатьДанныеДляПереходаНаНовуюВерсию";
	Обработчик.Версия = "11.5.27.21";
	Обработчик.РежимВыполнения = "Отложенно";
	Обработчик.Идентификатор = Новый УникальныйИдентификатор("a2f265d9-44a0-4a59-a251-a9dcd21023bc");
	Обработчик.Многопоточный = Истина;
	Обработчик.ПроцедураЗаполненияДанныхОбновления = "РегистрыНакопления.РасчетыСПоставщиками.ЗарегистрироватьДанныеКОбработкеДляПереходаНаНовуюВерсию";
	Обработчик.ПроцедураПроверки = "ОбновлениеИнформационнойБазы.ДанныеОбновленыНаНовуюВерсиюПрограммы";
	Обработчик.Порядок = Перечисления.ПорядокОбработчиковОбновления.Критичный;
	Обработчик.Комментарий = СтрШаблон(НСтр("ru = 'Исправляет реквизит ""%1"" для движений расчетов.
	                                              |Исправляет дату регистратора ""Бронирование"".
	                                              |Исправляет реквизит ""%2"" для движений платежей без даты погашения.
	                                              |Заполняет реквизиты курсов валют взаиморасчетов и упр. учета.'"),
		Метаданные.РегистрыНакопления.РасчетыСПоставщиками.Реквизиты.ПорядокОперации.Представление(),
		Метаданные.РегистрыНакопления.РасчетыСПоставщиками.Реквизиты.ПорядокЗачетаПоДатеПлатежа.Представление());
	
	Читаемые = Новый Массив;
	Читаемые.Добавить(Метаданные.РегистрыНакопления.РасчетыСПоставщиками.ПолноеИмя());
	Обработчик.ЧитаемыеОбъекты = СтрСоединить(Читаемые, ",");
	
	Изменяемые = Новый Массив;
	Изменяемые.Добавить(Метаданные.РегистрыНакопления.РасчетыСПоставщиками.ПолноеИмя());
	Обработчик.ИзменяемыеОбъекты = СтрСоединить(Изменяемые, ",");
	
	Обработчик.БлокируемыеОбъекты = "";

КонецПроцедуры

// Процедура регистрации данных для обработчика обновления ОбработатьДанныеДляПереходаНаВерсию.
// 
// Параметры:
//  Параметры - см. ОбновлениеИнформационнойБазы.ОсновныеПараметрыОтметкиКОбработке
Процедура ЗарегистрироватьДанныеКОбработкеДляПереходаНаНовуюВерсию(Параметры) Экспорт
	
	ПолноеИмяРегистра = "РегистрНакопления.РасчетыСПоставщиками";
	
	МассивТипов = Новый Массив;
	Для Каждого ТипРегистратора Из Метаданные.РегистрыНакопления.РасчетыСПоставщиками.СтандартныеРеквизиты.Регистратор.Тип.Типы() Цикл
		МассивТипов.Добавить(Метаданные.НайтиПоТипу(ТипРегистратора).ПолноеИмя());
	КонецЦикла;
	
	ПараметрыВыборки = Параметры.ПараметрыВыборки;
	ПараметрыВыборки.ПолныеИменаОбъектов = СтрСоединить(МассивТипов, ",");
	ПараметрыВыборки.ПолныеИменаРегистров = ПолноеИмяРегистра;
	ПараметрыВыборки.ПоляУпорядочиванияПриРаботеПользователей.Добавить("Период УБЫВ");
	ПараметрыВыборки.ПоляУпорядочиванияПриОбработкеДанных.Добавить("Период УБЫВ");
	ПараметрыВыборки.СпособВыборки = ОбновлениеИнформационнойБазы.СпособВыборкиРегистраторыРегистра();
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	#Область ТекстЗапроса
	Запрос.Текст = "
	|// Исправить дату регистратора документов ""Бронирование""
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Расчеты.Регистратор КАК Регистратор
	|ПОМЕСТИТЬ ВтКОбработке
	|ИЗ
	|	РегистрНакопления.РасчетыСПоставщиками КАК Расчеты
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ОперацияСЭлектроннымБилетом КАК ОперацияСЭлектроннымБилетом
	|		ПО Расчеты.Регистратор = ОперацияСЭлектроннымБилетом.Ссылка
	|ГДЕ
	|	НЕ Расчеты.Период = Расчеты.ДатаРегистратора
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|// ИсправлениеПорядковОперацииПлатежейБезДатыПогашения
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Расчеты.Регистратор КАК Регистратор
	|ИЗ
	|	РегистрНакопления.РасчетыСПоставщиками КАК Расчеты
	|ГДЕ
	|	Расчеты.ДатаПлатежа = ДАТАВРЕМЯ(1,1,1)
	|	И Расчеты.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход)
	|	И Расчеты.Сумма > 0
	|	И ВЫРАЗИТЬ(ЛЕВ(Расчеты.ПорядокЗачетаПоДатеПлатежа, 4) КАК Строка(4))<> ""3000""
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|// ИсправлениеПорядковОперацииВводаОстатковАвансов
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Расчеты.Регистратор КАК Регистратор
	|ИЗ
	|	РегистрНакопления.РасчетыСПоставщиками КАК Расчеты
	|ГДЕ
	|	(Расчеты.Регистратор ССЫЛКА Документ.ВводОстатковВзаиморасчетов
	|		ИЛИ Расчеты.Регистратор ССЫЛКА Документ.ВводОстатков)
	|	И Расчеты.Период <> Расчеты.ДатаРегистратора
	|	И Расчеты.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход)
	|	И Расчеты.ДатаРегистратора >= ДАТАВРЕМЯ(2010,1,1)
	|	И (СТРОКА(ГОД(Расчеты.Период) - 2000) <> ПОДСТРОКА(Расчеты.ПорядокОперации, 3, 2)
	|		ИЛИ ВЫБОР КОГДА МЕСЯЦ(Расчеты.Период) > 9
	|				ТОГДА СТРОКА(МЕСЯЦ(Расчеты.Период)) <> ПОДСТРОКА(Расчеты.ПорядокОперации, 5, 2)
	|				ИНАЧЕ СТРОКА(МЕСЯЦ(Расчеты.Период)) <> ПОДСТРОКА(Расчеты.ПорядокОперации, 6, 1)
	|					ИЛИ ПОДСТРОКА(Расчеты.ПорядокОперации, 5, 1) <> ""0""
	|			КОНЕЦ
	|		ИЛИ ВЫБОР КОГДА ДЕНЬ(Расчеты.Период) > 9
	|				ТОГДА СТРОКА(ДЕНЬ(Расчеты.Период)) <> ПОДСТРОКА(Расчеты.ПорядокОперации, 7, 2)
	|				ИНАЧЕ СТРОКА(ДЕНЬ(Расчеты.Период)) <> ПОДСТРОКА(Расчеты.ПорядокОперации, 8, 1)
	|					ИЛИ ПОДСТРОКА(Расчеты.ПорядокОперации, 7, 1) <> ""0""
	|			КОНЕЦ)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|// ИсправлениеПорядковОперацииСторно
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Расчеты.Регистратор КАК Регистратор
	|ИЗ
	|	РегистрНакопления.РасчетыСПоставщиками КАК Расчеты
	|ГДЕ
	|	Расчеты.Сторно
	|	И ПОДСТРОКА(Расчеты.ПорядокОперации, 9, 1) = ""1""
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Расчеты.Регистратор КАК Регистратор
	|ИЗ
	|	РегистрНакопления.РасчетыСПоставщиками КАК Расчеты
	|ГДЕ
	|	Расчеты.Сторно
	|	И ПОДСТРОКА(Расчеты.ПорядокОперации, 9, 1) = ""9""
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	РасчетыСПоставщиками.Регистратор КАК Регистратор
	|ИЗ
	|	РегистрНакопления.РасчетыСПоставщиками КАК РасчетыСПоставщиками
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.КлючиАналитикиУчетаПоПартнерам КАК КлючиАналитикиУчетаПоПартнерам
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Организации КАК Организации
	|			ПО КлючиАналитикиУчетаПоПартнерам.Организация = Организации.Ссылка
	|		ПО РасчетыСПоставщиками.АналитикаУчетаПоПартнерам = КлючиАналитикиУчетаПоПартнерам.Ссылка
	|ГДЕ
	|	РасчетыСПоставщиками.Сумма <> 0
	|	И РасчетыСПоставщиками.СуммаРегл <> 0
	|	И РасчетыСПоставщиками.Валюта <> Организации.ВалютаРегламентированногоУчета
	|	И РасчетыСПоставщиками.ВалютаДокумента <> Организации.ВалютаРегламентированногоУчета
	|	И РасчетыСПоставщиками.КурсЧислительВалютыВзаиморасчетов = 0
	|	И РасчетыСПоставщиками.КурсЗнаменательВалютыВзаиморасчетов = 0
	|	И НЕ РасчетыСПоставщиками.ХозяйственнаяОперация В (&ОперацииСРучнымКурсом)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	РасчетыСПоставщиками.Регистратор
	|ИЗ
	|	РегистрНакопления.РасчетыСПоставщиками КАК РасчетыСПоставщиками
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Константа.ВалютаУправленческогоУчета КАК ВалютаУправленческогоУчета
	|		ПО РасчетыСПоставщиками.Валюта <> ВалютаУправленческогоУчета.Значение
	|			И РасчетыСПоставщиками.ВалютаДокумента <> ВалютаУправленческогоУчета.Значение
	|ГДЕ
	|	РасчетыСПоставщиками.Сумма <> 0
	|	И РасчетыСПоставщиками.СуммаУпр <> 0
	|	И РасчетыСПоставщиками.КурсЧислительВалютыУпр = 0
	|	И РасчетыСПоставщиками.КурсЗнаменательВалютыУпр = 0
	|	И НЕ РасчетыСПоставщиками.ХозяйственнаяОперация В (&ОперацииСРучнымКурсом)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	РасчетыСПоставщиками.Регистратор КАК Регистратор
	|ИЗ
	|	РегистрНакопления.РасчетыСПоставщиками КАК РасчетыСПоставщиками
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.КлючиАналитикиУчетаПоПартнерам КАК КлючиАналитикиУчетаПоПартнерам
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Организации КАК Организации
	|			ПО КлючиАналитикиУчетаПоПартнерам.Организация = Организации.Ссылка
	|		ПО РасчетыСПоставщиками.АналитикаУчетаПоПартнерам = КлючиАналитикиУчетаПоПартнерам.Ссылка
	|ГДЕ
	|	ТИПЗНАЧЕНИЯ(РасчетыСПоставщиками.Регистратор) В (ТИП(Документ.ВводОстатков), ТИП(Документ.ВводОстатковВзаиморасчетов))
	|	И РасчетыСПоставщиками.Сумма <> 0
	|	И РасчетыСПоставщиками.СуммаРегл <> 0
	|	И РасчетыСПоставщиками.Валюта <> Организации.ВалютаРегламентированногоУчета
	|	И РасчетыСПоставщиками.КурсЧислительВалютыВзаиморасчетов = 0
	|	И РасчетыСПоставщиками.КурсЗнаменательВалютыВзаиморасчетов = 0
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	РасчетыСПоставщиками.Регистратор
	|ИЗ
	|	РегистрНакопления.РасчетыСПоставщиками КАК РасчетыСПоставщиками
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Константа.ВалютаУправленческогоУчета КАК ВалютаУправленческогоУчета
	|		ПО РасчетыСПоставщиками.Валюта <> ВалютаУправленческогоУчета.Значение
	|ГДЕ
	|	ТИПЗНАЧЕНИЯ(РасчетыСПоставщиками.Регистратор) В (ТИП(Документ.ВводОстатков), ТИП(Документ.ВводОстатковВзаиморасчетов))
	|	И РасчетыСПоставщиками.Сумма <> 0
	|	И РасчетыСПоставщиками.СуммаУпр <> 0
	|	И РасчетыСПоставщиками.КурсЧислительВалютыУпр = 0
	|	И РасчетыСПоставщиками.КурсЗнаменательВалютыУпр = 0
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|// ОчисткаПриемниковИсточниковУСторно
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Расчеты.Регистратор КАК Регистратор
	|ИЗ
	|	РегистрНакопления.РасчетыСПоставщиками КАК Расчеты
	|ГДЕ
	|	Расчеты.Сторно
	|	И Расчеты.АналитикаУчетаПоПартнерамПриемник <> ЗНАЧЕНИЕ(Справочник.КлючиАналитикиУчетаПоПартнерам.ПустаяСсылка)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Расчеты.Регистратор КАК Регистратор
	|ИЗ
	|	РегистрНакопления.РасчетыСПоставщиками КАК Расчеты
	|ГДЕ
	|	Расчеты.Сторно
	|	И Расчеты.КорАналитикаУчетаПоПартнерам <> ЗНАЧЕНИЕ(Справочник.КлючиАналитикиУчетаПоПартнерам.ПустаяСсылка)
	|
	|ИНДЕКСИРОВАТЬ ПО 
	|	Регистратор
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|// ИсправлениеПорядковОперацииПереносаРасчетов
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Расчеты.Регистратор КАК Регистратор,
	|	Реестр.НомерДокументаИБ КАК НомерДокумента
	|ПОМЕСТИТЬ ВтКПолучениюНомеров
	|ИЗ
	|	РегистрНакопления.РасчетыСПоставщиками КАК Расчеты
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.РеестрДокументов КАК Реестр
	|		ПО Расчеты.Регистратор = Реестр.Ссылка
	|			И НЕ Реестр.ДополнительнаяЗапись
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВтКОбработке КАК ВтКОбработке
	|		ПО Расчеты.Регистратор = ВтКОбработке.Регистратор
	|			И ВтКОбработке.Регистратор ЕСТЬ NULL
	|ГДЕ
	|	НЕ Расчеты.Сторно
	|	И Расчеты.АналитикаУчетаПоПартнерамПриемник <> ЗНАЧЕНИЕ(Справочник.КлючиАналитикиУчетаПоПартнерам.ПустаяСсылка)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|// ИсправлениеПорядковОперацииСторно
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Расчеты.Регистратор КАК Регистратор,
	|	Реестр.НомерДокументаИБ КАК НомерДокумента
	|ИЗ
	|	РегистрНакопления.РасчетыСПоставщиками КАК Расчеты
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.РеестрДокументов КАК Реестр
	|		ПО Расчеты.Регистратор = Реестр.Ссылка
	|			И НЕ Реестр.ДополнительнаяЗапись
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВтКОбработке КАК ВтКОбработке
	|		ПО Расчеты.Регистратор = ВтКОбработке.Регистратор
	|			И ВтКОбработке.Регистратор ЕСТЬ NULL
	|ГДЕ
	|	Расчеты.Сторно
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|// ИсправлениеПорядковОперацииОтгрузка
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Расчеты.Регистратор КАК Регистратор,
	|	Реестр.НомерДокументаИБ КАК НомерДокумента
	|ИЗ
	|	РегистрНакопления.РасчетыСПоставщиками КАК Расчеты
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.РеестрДокументов КАК Реестр
	|		ПО Расчеты.Регистратор = Реестр.Ссылка
	|			И НЕ Реестр.ДополнительнаяЗапись
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВтКОбработке КАК ВтКОбработке
	|		ПО Расчеты.Регистратор = ВтКОбработке.Регистратор
	|			И ВтКОбработке.Регистратор ЕСТЬ NULL
	|ГДЕ
	|	Расчеты.ОперацияВзаиморасчетов = ЗНАЧЕНИЕ(Перечисление.ОперацииВзаиморасчетов.Отгрузка)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|// ИсправлениеПорядковОперацииПереносЗадолженностиПоЦД
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Расчеты.Регистратор КАК Регистратор,
	|	Реестр.НомерДокументаИБ КАК НомерДокумента
	|ИЗ
	|	РегистрНакопления.РасчетыСПоставщиками КАК Расчеты
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.РеестрДокументов КАК Реестр
	|		ПО Расчеты.Регистратор = Реестр.Ссылка
	|			И НЕ Реестр.ДополнительнаяЗапись
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВтКОбработке КАК ВтКОбработке
	|		ПО Расчеты.Регистратор = ВтКОбработке.Регистратор
	|			И ВтКОбработке.Регистратор ЕСТЬ NULL
	|ГДЕ
	|	Расчеты.ХозяйственнаяОперация = ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.ПереносЗадолженностиМеждуФилиалами)
	|	И НЕ ТИПЗНАЧЕНИЯ(Расчеты.Регистратор) В (ТИП(Документ.ВозвратТоваровПоставщику),
	|	                                         ТИП(Документ.ВозвратТоваровМеждуОрганизациями),
	
	|	                                         ТИП(Документ.ОперацияСЭлектроннымБилетом))
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВтКПолучениюНомеров.Регистратор КАК Регистратор,
	|	ВЫРАЗИТЬ(ЕСТЬNULL(ВтКПолучениюНомеров.НомерДокумента, """") КАК СТРОКА) КАК НомерДокумента
	|ПОМЕСТИТЬ ВтНомераЗаполненныеПоРеестру
	|ИЗ
	|	ВтКПолучениюНомеров КАК ВтКПолучениюНомеров
	|ГДЕ
	|	ДЛИНАСТРОКИ(ВЫРАЗИТЬ(ЕСТЬNULL(ВтКПолучениюНомеров.НомерДокумента, """") КАК СТРОКА)) > 0
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВтКПолучениюНомеров.Регистратор КАК Регистратор
	|ИЗ
	|	ВтКПолучениюНомеров КАК ВтКПолучениюНомеров
	|ГДЕ
	|	ДЛИНАСТРОКИ(ВЫРАЗИТЬ(ЕСТЬNULL(ВтКПолучениюНомеров.НомерДокумента, """") КАК СТРОКА) ) = 0
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ ВтКПолучениюНомеров
	|";
	#КонецОбласти
	
	Запрос.УстановитьПараметр("ОперацииСРучнымКурсом", ОперативныеВзаиморасчетыСервер.ХозяйственныеОперацииСРучнымКурсом());
	РегистраторыСПустымиНомерами = Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Регистратор");
	РегистраторыСНомерами = ОбщегоНазначения.ЗначениеРеквизитаОбъектов(
		РегистраторыСПустымиНомерами,
		Метаданные.Документы.ПриобретениеТоваровУслуг.СтандартныеРеквизиты.Номер.Имя); 
	ТзРегистраторыСНомерами = Новый ТаблицаЗначений;
	ТзРегистраторыСНомерами.Колонки.Добавить("Регистратор",
		Новый ОписаниеТипов(Метаданные.РегистрыНакопления.РасчетыСПоставщиками.СтандартныеРеквизиты.Регистратор.Тип.Типы()));
	ТзРегистраторыСНомерами.Колонки.Добавить("НомерДокумента", Новый ОписаниеТипов("Строка"));
	Для Каждого КлючИЗначение Из РегистраторыСНомерами Цикл
		Если Не ЗначениеЗаполнено(КлючИЗначение.Значение) Тогда
			Продолжить;
		КонецЕсли;
		НоваяСтрока = ТзРегистраторыСНомерами.Добавить();
		НоваяСтрока.Регистратор = КлючИЗначение.Ключ;
		НоваяСтрока.НомерДокумента = КлючИЗначение.Значение;
	КонецЦикла;
	
	Запрос.УстановитьПараметр("ТзРегистраторыСНомерами", ТзРегистраторыСНомерами);
	#Область ТекстЗапроса
	Запрос.Текст = "
	|ВЫБРАТЬ
	|	Таблица.Регистратор КАК Регистратор,
	|	ВЫРАЗИТЬ(Таблица.НомерДокумента КАК СТРОКА) КАК НомерДокумента
	|ПОМЕСТИТЬ ВтНомераЗаполненныеВнеЗапроса
	|ИЗ
	|	&ТзРегистраторыСНомерами КАК Таблица
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Таблица.Регистратор КАК Регистратор,
	|	Таблица.НомерДокумента КАК НомерДокумента
	|ПОМЕСТИТЬ ВтНомера
	|ИЗ
	|	ВтНомераЗаполненныеВнеЗапроса КАК Таблица
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	Таблица.Регистратор КАК Регистратор,
	|	Таблица.НомерДокумента КАК НомерДокумента
	|ИЗ
	|	ВтНомераЗаполненныеПоРеестру КАК Таблица
	|
	|ИНДЕКСИРОВАТЬ ПО 
	|	Регистратор
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|// Документы к обработке, найденные до получения номеров
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ВтКОбработке.Регистратор КАК Регистратор
	|ИЗ
	|	ВтКОбработке КАК ВтКОбработке
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|// Сторно с заполненным порядком операции внутри документа
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Расчеты.Регистратор КАК Регистратор
	|ИЗ
	|	РегистрНакопления.РасчетыСПоставщиками КАК Расчеты
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВтНомера КАК ВтНомера
	|		ПО Расчеты.Регистратор = ВтНомера.Регистратор
	|ГДЕ
	|	Расчеты.Сторно
	|	И СТРНАЙТИ(Расчеты.ПорядокОперации, ВтНомера.НомерДокумента) > 0
	|	И ПОДСТРОКА(Расчеты.ПорядокОперации, СТРНАЙТИ(Расчеты.ПорядокОперации, ВтНомера.НомерДокумента) + ДЛИНАСТРОКИ(ВтНомера.НомерДокумента), 1) <> """"
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|// Документы с лишними символами в порядке операции внутри документа
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Расчеты.Регистратор КАК Регистратор
	|ИЗ
	|	РегистрНакопления.РасчетыСПоставщиками КАК Расчеты
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВтНомера КАК ВтНомера
	|		ПО Расчеты.Регистратор = ВтНомера.Регистратор
	|ГДЕ
	|	СТРНАЙТИ(Расчеты.ПорядокОперации, ВтНомера.НомерДокумента) > 0
	|	И ДЛИНАСТРОКИ(ПОДСТРОКА(Расчеты.ПорядокОперации, СТРНАЙТИ(Расчеты.ПорядокОперации, ВтНомера.НомерДокумента) + ДЛИНАСТРОКИ(ВтНомера.НомерДокумента), 2)) > 1
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|// Источники без порядка операции внутри документа
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Расчеты.Регистратор КАК Регистратор
	|ИЗ
	|	РегистрНакопления.РасчетыСПоставщиками КАК Расчеты
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВтНомера КАК ВтНомера
	|		ПО Расчеты.Регистратор = ВтНомера.Регистратор
	|ГДЕ
	|	Расчеты.АналитикаУчетаПоПартнерамПриемник <> ЗНАЧЕНИЕ(Справочник.КлючиАналитикиУчетаПоПартнерам.ПустаяСсылка)
	|	И НЕ Расчеты.Сторно
	|	И СТРНАЙТИ(Расчеты.ПорядокОперации, ВтНомера.НомерДокумента) > 0
	|	И ДЛИНАСТРОКИ(ПОДСТРОКА(Расчеты.ПорядокОперации, СТРНАЙТИ(Расчеты.ПорядокОперации, ВтНомера.НомерДокумента) + ДЛИНАСТРОКИ(ВтНомера.НомерДокумента), 2)) = 0
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|// Приемники без порядка операции внутри документа
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Расчеты.Регистратор КАК Регистратор
	|ИЗ
	|	РегистрНакопления.РасчетыСПоставщиками КАК Расчеты
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВтНомера КАК ВтНомера
	|		ПО Расчеты.Регистратор = ВтНомера.Регистратор
	|ГДЕ
	|	Расчеты.КорАналитикаУчетаПоПартнерам <> ЗНАЧЕНИЕ(Справочник.КлючиАналитикиУчетаПоПартнерам.ПустаяСсылка)
	|	И НЕ Расчеты.Сторно
	|	И СТРНАЙТИ(Расчеты.ПорядокОперации, ВтНомера.НомерДокумента) > 0
	|	И ДЛИНАСТРОКИ(ПОДСТРОКА(Расчеты.ПорядокОперации, СТРНАЙТИ(Расчеты.ПорядокОперации, ВтНомера.НомерДокумента) + ДЛИНАСТРОКИ(ВтНомера.НомерДокумента), 2)) = 0
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|// Отгрузка с порядком операции внутри документа 1
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Расчеты.Регистратор КАК Регистратор
	|ИЗ
	|	РегистрНакопления.РасчетыСПоставщиками КАК Расчеты
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВтНомера КАК ВтНомера
	|		ПО Расчеты.Регистратор = ВтНомера.Регистратор
	|ГДЕ
	|	Расчеты.ОперацияВзаиморасчетов = ЗНАЧЕНИЕ(Перечисление.ОперацииВзаиморасчетов.Отгрузка)
	|	И НЕ Расчеты.Сторно
	|	И СТРНАЙТИ(Расчеты.ПорядокОперации, ВтНомера.НомерДокумента) > 0
	|	И ПОДСТРОКА(Расчеты.ПорядокОперации, СТРНАЙТИ(Расчеты.ПорядокОперации, ВтНомера.НомерДокумента) + ДЛИНАСТРОКИ(ВтНомера.НомерДокумента), 1) <> ""4""
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|// ПереносЗадолженностиМеждуФилиалами с порядком операции внутри документа 2
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Расчеты.Регистратор КАК Регистратор
	|ИЗ
	|	РегистрНакопления.РасчетыСПоставщиками КАК Расчеты
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВтНомера КАК ВтНомера
	|		ПО Расчеты.Регистратор = ВтНомера.Регистратор
	|ГДЕ
	|	Расчеты.ХозяйственнаяОперация = ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.ПереносЗадолженностиМеждуФилиалами)
	|	И НЕ Расчеты.Сторно
	|	И НЕ ТИПЗНАЧЕНИЯ(Расчеты.Регистратор) В (ТИП(Документ.ВозвратТоваровПоставщику),
	|	                                         ТИП(Документ.ВозвратТоваровМеждуОрганизациями),
	
	|	                                         ТИП(Документ.ОперацияСЭлектроннымБилетом))
	|	И СТРНАЙТИ(Расчеты.ПорядокОперации, ВтНомера.НомерДокумента) > 0
	|	И ПОДСТРОКА(Расчеты.ПорядокОперации, СТРНАЙТИ(Расчеты.ПорядокОперации, ВтНомера.НомерДокумента) + ДЛИНАСТРОКИ(ВтНомера.НомерДокумента), 1) <> ""5""
	|";
	#КонецОбласти
	
	Регистраторы = Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Регистратор");
	ОбновлениеИнформационнойБазы.ОтметитьРегистраторыКОбработке(
		Параметры, 
		Регистраторы,
		ПолноеИмяРегистра);
	
КонецПроцедуры

Процедура ОбработатьДанныеДляПереходаНаНовуюВерсию(Параметры) Экспорт
	
	ПолноеИмяОбъекта = "РегистрНакопления.РасчетыСПоставщиками";

	ОбновляемыеДанные = ОбновлениеИнформационнойБазы.ДанныеДляОбновленияВМногопоточномОбработчике(Параметры);
	Если ОбновляемыеДанные.Количество() = 0 Тогда
		Параметры.ОбработкаЗавершена = ОбновлениеИнформационнойБазы.ОбработкаДанныхЗавершена(Параметры.Очередь, ПолноеИмяОбъекта);
		Возврат;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ОбновляемыеДанные", ОбновляемыеДанные);
	Запрос.Текст = "
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ОбновляемыеДанные.Регистратор КАК Регистратор
		|ПОМЕСТИТЬ ВтДляОбработки
		|ИЗ
		|	&ОбновляемыеДанные КАК ОбновляемыеДанные
		|ИНДЕКСИРОВАТЬ ПО
		|	Регистратор
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	СсылкиДляОбработки.Регистратор КАК Регистратор,
		|	РеестрДокументов.СторнируемыйДокумент КАК СторнируемыйДокумент
		|ПОМЕСТИТЬ ВтСторнируемыеДокументы
		|ИЗ
		|	ВтДляОбработки КАК СсылкиДляОбработки
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.РеестрДокументов КАК РеестрДокументов
		|			ПО СсылкиДляОбработки.Регистратор = РеестрДокументов.Ссылка
		|				И РеестрДокументов.СторноИсправление
		|				И НЕ РеестрДокументов.ДополнительнаяЗапись
		|ИНДЕКСИРОВАТЬ ПО
		|	СторнируемыйДокумент
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	СторнируемыеДокументы.Регистратор КАК Регистратор,
		|	РасчетыСПоставщиками.АналитикаУчетаПоПартнерам КАК АналитикаУчетаПоПартнерам,
		|	РасчетыСПоставщиками.ОбъектРасчетов КАК ОбъектРасчетов,
		|	РасчетыСПоставщиками.Валюта КАК Валюта,
		|	РасчетыСПоставщиками.ВидДвижения КАК ВидДвижения,
		|	РасчетыСПоставщиками.Сумма КАК Сумма,
		|	РасчетыСПоставщиками.КОплате КАК КОплате,
		|	РасчетыСПоставщиками.КПоступлению КАК КПоступлению,
		|	ПОДСТРОКА(РасчетыСПоставщиками.ПорядокОперации, 9, 1) КАК ВидОперацииДляСортировки
		|ИЗ
		|	ВтСторнируемыеДокументы КАК СторнируемыеДокументы
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрНакопления.РасчетыСПоставщиками КАК РасчетыСПоставщиками
		|			ПО СторнируемыеДокументы.СторнируемыйДокумент = РасчетыСПоставщиками.Регистратор
		|ГДЕ
		|	НЕ РасчетыСПоставщиками.Сторно
		|	И (РасчетыСПоставщиками.Сумма <> 0
		|		ИЛИ РасчетыСПоставщиками.КОплате <> 0
		|		ИЛИ РасчетыСПоставщиками.КПоступлению <> 0)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	СсылкиДляОбработки.Регистратор КАК Регистратор,
		|	РеестрДокументов.НомерДокументаИБ КАК НомерДокумента
		|ИЗ
		|	ВтДляОбработки КАК СсылкиДляОбработки
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.РеестрДокументов КАК РеестрДокументов
		|			ПО СсылкиДляОбработки.Регистратор = РеестрДокументов.Ссылка
		|				И НЕ РеестрДокументов.ДополнительнаяЗапись
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	РасчетыСПоставщиками.АналитикаУчетаПоПартнерам КАК АналитикаУчетаПоПартнерам,
		|	Организации.ВалютаРегламентированногоУчета КАК ВалютаРегламентированногоУчета
		|ИЗ
		|	РегистрНакопления.РасчетыСПоставщиками КАК РасчетыСПоставщиками
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.КлючиАналитикиУчетаПоПартнерам КАК КлючиАналитикиУчетаПоПартнерам
		|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Организации КАК Организации
		|			ПО КлючиАналитикиУчетаПоПартнерам.Организация = Организации.Ссылка
		|		ПО РасчетыСПоставщиками.АналитикаУчетаПоПартнерам = КлючиАналитикиУчетаПоПартнерам.Ссылка
		|ГДЕ
		|	РасчетыСПоставщиками.Регистратор В(ВЫБРАТЬ Т.Регистратор ИЗ ВтДляОбработки КАК Т)
		|";
	
	РезультатЗапроса = Запрос.ВыполнитьПакет();
	
	ДанныеСторнируемыхДокументов = РезультатЗапроса[2].Выгрузить();
	ДанныеСторнируемыхДокументов.Индексы.Добавить("Регистратор");
	ДанныеСторнируемыхДокументов.Индексы.Добавить("Регистратор, АналитикаУчетаПоПартнерам, ОбъектРасчетов, Валюта, ВидДвижения, Сумма, КОплате, КПоступлению");
	
	НомераДокументов = РезультатЗапроса[3].Выгрузить();
	НомераДокументов.Индексы.Добавить("Регистратор");
	
	ВалютыРегл = РезультатЗапроса[4].Выгрузить();
	ВалютыРегл.Индексы.Добавить("АналитикаУчетаПоПартнерам");
	ВалютаУпр = ОбщегоНазначенияУТПовтИсп.ЗначениеКонстанты("ВалютаУправленческогоУчета");
	РазрядностьЦелойЧастиКурса = Метаданные.ОпределяемыеТипы.КурсВалюты.Тип.КвалификаторыЧисла.Разрядность
	                           - Метаданные.ОпределяемыеТипы.КурсВалюты.Тип.КвалификаторыЧисла.РазрядностьДробнойЧасти;
	ОграничениеЦелойЧасти = Pow(10, РазрядностьЦелойЧастиКурса - 1);
	
	Для Каждого СтрокаОбновляемыхДанных Из ОбновляемыеДанные Цикл
		
		ОбновляемыйРегистратор = СтрокаОбновляемыхДанных.Регистратор;
				
		НачатьТранзакцию();
		
		Попытка
			
			ПричинаИсключения = "Блокировка";
			#Область Блокировки
			Блокировка = Новый БлокировкаДанных;
			
			ЭлементБлокировки = Блокировка.Добавить("РегистрНакопления.РасчетыСПоставщиками.НаборЗаписей");
			ЭлементБлокировки.УстановитьЗначение("Регистратор", ОбновляемыйРегистратор);
			ЭлементБлокировки.Режим = РежимБлокировкиДанных.Исключительный;
			
			Блокировка.Заблокировать();
			#КонецОбласти
			
			ПричинаИсключения = "ПлохиеДанные";
			НаборЗаписей = СоздатьНаборЗаписей();
			НаборЗаписей.Отбор.Регистратор.Установить(ОбновляемыйРегистратор);
			НаборЗаписей.Прочитать();
			
			#Область ОчисткаПриемниковИсточниковУСторно
			Для Каждого Запись Из НаборЗаписей Цикл
				Если Запись.Сторно 
					И (Запись.ПоДаннымОбъектаРасчетовИсточника
						Или ЗначениеЗаполнено(Запись.КорАналитикаУчетаПоПартнерам)
						Или ЗначениеЗаполнено(Запись.КорОбъектРасчетов)
						Или ЗначениеЗаполнено(Запись.АналитикаУчетаПоПартнерамПриемник)
						Или ЗначениеЗаполнено(Запись.ОбъектРасчетовПриемник)
						Или ЗначениеЗаполнено(Запись.ВалютаПриемник)
						Или Запись.СуммаПриемник <> 0) Тогда
						Запись.ПоДаннымОбъектаРасчетовИсточника  = Ложь;
						Запись.КорАналитикаУчетаПоПартнерам      = Справочники.КлючиАналитикиУчетаПоПартнерам.ПустаяСсылка();
						Запись.КорОбъектРасчетов                 = Справочники.ОбъектыРасчетов.ПустаяСсылка();
						Запись.АналитикаУчетаПоПартнерамПриемник = Справочники.КлючиАналитикиУчетаПоПартнерам.ПустаяСсылка();
						Запись.ОбъектРасчетовПриемник            = Справочники.ОбъектыРасчетов.ПустаяСсылка();
						Запись.ВалютаПриемник                    = Справочники.Валюты.ПустаяСсылка();
						Запись.СуммаПриемник                     = 0;
				КонецЕсли;
			КонецЦикла;
			#КонецОбласти
			
			#Область ИсправлениеДатыРегистратора
			Если ТипЗнч(ОбновляемыйРегистратор) = Тип("ДокументСсылка.ОперацияСЭлектроннымБилетом") Тогда
				Для Каждого Запись Из НаборЗаписей Цикл
					Если НЕ Запись.ДатаРегистратора = Запись.Период Тогда
						
						Запись.ДатаРегистратора = Запись.Период;
						ДатаСтрокой  = Формат(Запись.ДатаРегистратора, "ДФ=yyyyMMdd");
						НовыйПорядок = ДатаСтрокой + Сред(Запись.ПорядокОперации, 9);
						Запись.ПорядокОперации = НовыйПорядок;
						
					КонецЕсли;
				КонецЦикла;
			КонецЕсли;
			#КонецОбласти
			
			#Область ИсправлениеПорядковОперацииВнутриДокумента
			СтрокиНомерДокумента = НомераДокументов.НайтиСтроки(Новый Структура("Регистратор", ОбновляемыйРегистратор));
			Если СтрокиНомерДокумента.Количество() > 0
				И ЗначениеЗаполнено(СтрокиНомерДокумента[0].НомерДокумента) Тогда
				НомерДокумента = СтрокиНомерДокумента[0].НомерДокумента;
			Иначе
				НомерДокумента = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ОбновляемыйРегистратор,
					Метаданные.Документы.ПриобретениеТоваровУслуг.СтандартныеРеквизиты.Номер.Имя);
			КонецЕсли;
			РегистрыНакопления.РасчетыСКлиентами.ИсправитьПорядокОперацииВПределахДокумента(НаборЗаписей, НомерДокумента);
			#КонецОбласти
			
			#Область ИсправлениеПорядковОперацииПлатежейБезДатыПогашения
			Для Каждого Запись Из НаборЗаписей Цикл
				Если Запись.ВидДвижения = ВидДвиженияНакопления.Приход
					И Запись.Сумма > 0 
					И Запись.ДатаПлатежа = Дата(1,1,1)
					И Лев(Запись.ПорядокЗачетаПоДатеПлатежа,4) <> "3000" Тогда
					Запись.ПорядокЗачетаПоДатеПлатежа = "30000101" + Прав(Запись.ПорядокЗачетаПоДатеПлатежа,СтрДлина(Запись.ПорядокЗачетаПоДатеПлатежа)-8);
				КонецЕсли;
			КонецЦикла;
			#КонецОбласти
			
			#Область ИсправлениеПорядковОперацииВводаОстатковАвансов
			Для Каждого Запись Из НаборЗаписей Цикл
				Если (ТипЗнч(ОбновляемыйРегистратор) = Тип("ДокументСсылка.ВводОстатковВзаиморасчетов")
						Или ТипЗнч(ОбновляемыйРегистратор) = Тип("ДокументСсылка.ВводОстатков"))
					И Запись.ДатаРегистратора <> Запись.Период
					И Запись.ВидДвижения = ВидДвиженияНакопления.Приход
					И Запись.ДатаРегистратора >= Дата(2010, 1, 1)
					И Лев(Запись.ПорядокОперации, 8) <> Формат(Запись.Период, "ДФ=yyyyMMdd") Тогда
					
					ДатаСтрокой = Формат(Запись.Период, "ДФ=yyyyMMdd");
					Запись.ПорядокОперации = ДатаСтрокой + Сред(Запись.ПорядокОперации, 9);
					
				КонецЕсли;
			КонецЦикла;
			#КонецОбласти
			
			#Область ИсправлениеПорядковОперацииСторно
			ДвиженияСторнируемогоДокумента = ДанныеСторнируемыхДокументов.НайтиСтроки(Новый Структура("Регистратор", ОбновляемыйРегистратор));
			Для Каждого Запись Из НаборЗаписей Цикл
				Если Запись.Сторно
					И (Сред(Запись.ПорядокОперации, 9, 1) = "1"
						Или Сред(Запись.ПорядокОперации, 9, 1) = "9") Тогда
					
					// Проверим количество разных видов операций в движениях исправляемого документа
					ЕстьРазныеВидыОпераций = Ложь;
					ВидОперацииДляСортировки = "";
					Для Каждого СтрокаДвижений Из ДвиженияСторнируемогоДокумента Цикл
						Если ЗначениеЗаполнено(СтрокаДвижений.ВидОперацииДляСортировки) Тогда
							Если Не ЗначениеЗаполнено(ВидОперацииДляСортировки) Тогда
								ВидОперацииДляСортировки = СтрокаДвижений.ВидОперацииДляСортировки;
							ИначеЕсли СтрокаДвижений.ВидОперацииДляСортировки <> ВидОперацииДляСортировки Тогда
								ЕстьРазныеВидыОпераций = Истина;
							КонецЕсли;
						КонецЕсли;
					КонецЦикла;
					
					// Если есть несколько разных видов операций, то нужно заполнить вид операции для сортировки
					// по ключевым полям и ресурсам исправляемого документа, иначе - берем единственный вид опереции.
					Если ЕстьРазныеВидыОпераций Тогда
						
						СтруктураОтбора = Новый Структура;
						СтруктураОтбора.Вставить("Регистратор",               ОбновляемыйРегистратор);
						СтруктураОтбора.Вставить("АналитикаУчетаПоПартнерам", Запись.АналитикаУчетаПоПартнерам);
						СтруктураОтбора.Вставить("ОбъектРасчетов",            Запись.ОбъектРасчетов);
						СтруктураОтбора.Вставить("Валюта",                    Запись.Валюта);
						СтруктураОтбора.Вставить("ВидДвижения",               Запись.ВидДвижения);
						СтруктураОтбора.Вставить("Сумма",                   - Запись.Сумма);
						СтруктураОтбора.Вставить("КОплате",                 - Запись.КОплате);
						СтруктураОтбора.Вставить("КПоступлению",            - Запись.КПоступлению);
						
						ВидыОперацийПоКлючевымПолям = ДанныеСторнируемыхДокументов.НайтиСтроки(СтруктураОтбора);
						
						ВидОперацииДляСортировки = "";
						Для Каждого СтрокаДвижений Из ВидыОперацийПоКлючевымПолям Цикл
							Если ЗначениеЗаполнено(СтрокаДвижений.ВидОперацииДляСортировки) Тогда
								ВидОперацииДляСортировки = СтрокаДвижений.ВидОперацииДляСортировки;
								Прервать;
							КонецЕсли;
						КонецЦикла;
						
						Запись.ПорядокОперации = Лев(Запись.ПорядокОперации, 8) 
							+ ?(ЗначениеЗаполнено(ВидОперацииДляСортировки), ВидОперацииДляСортировки, "2")
							+ Сред(Запись.ПорядокОперации, 10);
						
					Иначе
						
						Запись.ПорядокОперации = Лев(Запись.ПорядокОперации, 8) 
							+ ?(ЗначениеЗаполнено(ВидОперацииДляСортировки), ВидОперацииДляСортировки, "2")
							+ Сред(Запись.ПорядокОперации, 10);
						
					КонецЕсли;
					
				КонецЕсли;
			КонецЦикла;
			#КонецОбласти
			
			#Область ЗаполнениеКурсов
			Для Каждого Запись Из НаборЗаписей Цикл
				Если Запись.Сумма <> 0
					И Запись.СуммаРегл <> 0
					И Запись.КурсЧислительВалютыВзаиморасчетов = 0
					И Запись.КурсЗнаменательВалютыВзаиморасчетов = 0 Тогда
					СтрокаВалютыРегл = ВалютыРегл.Найти(Запись.АналитикаУчетаПоПартнерам, "АналитикаУчетаПоПартнерам");
					Если СтрокаВалютыРегл <> Неопределено 
						И Запись.Валюта <> СтрокаВалютыРегл.ВалютаРегламентированногоУчета
						И (Запись.ВалютаДокумента <> СтрокаВалютыРегл.ВалютаРегламентированногоУчета
							Или ТипЗнч(ОбновляемыйРегистратор) = Тип("ДокументСсылка.ВводОстатков")
							Или ТипЗнч(ОбновляемыйРегистратор) = Тип("ДокументСсылка.ВводОстатковВзаиморасчетов")) Тогда
						КурсВалютыВзаиморасчетов = Запись.СуммаРегл / Запись.Сумма;
						ЧислительПриведенный = КурсВалютыВзаиморасчетов;
						ЗнаменательПриведенный = 1;
						Пока ЧислительПриведенный < ОграничениеЦелойЧасти
							И ЗнаменательПриведенный < ОграничениеЦелойЧасти Цикл
							ЧислительПриведенный = ЧислительПриведенный * 10;
							ЗнаменательПриведенный = ЗнаменательПриведенный * 10;
						КонецЦикла;
						Запись.КурсЧислительВалютыВзаиморасчетов = ЧислительПриведенный;
						Запись.КурсЗнаменательВалютыВзаиморасчетов = ЗнаменательПриведенный;
					КонецЕсли;
				КонецЕсли;
				Если Запись.СуммаРегл <> 0
					И Запись.СуммаУпр <> 0
					И Запись.КурсЧислительВалютыУпр = 0
					И Запись.КурсЗнаменательВалютыУпр = 0
					И Запись.Валюта <> ВалютаУпр
					И (Запись.ВалютаДокумента <> ВалютаУпр
						Или ТипЗнч(ОбновляемыйРегистратор) = Тип("ДокументСсылка.ВводОстатков")
						Или ТипЗнч(ОбновляемыйРегистратор) = Тип("ДокументСсылка.ВводОстатковВзаиморасчетов")) Тогда
					КурсВалютыУпр = Запись.СуммаРегл / Запись.СуммаУпр;
					ЧислительПриведенный = КурсВалютыУпр;
					ЗнаменательПриведенный = 1;
					Пока ЧислительПриведенный < ОграничениеЦелойЧасти
						И ЗнаменательПриведенный < ОграничениеЦелойЧасти Цикл
						ЧислительПриведенный = ЧислительПриведенный * 10;
						ЗнаменательПриведенный = ЗнаменательПриведенный * 10;
					КонецЦикла;
					Запись.КурсЧислительВалютыУпр = ЧислительПриведенный;
					Запись.КурсЗнаменательВалютыУпр = ЗнаменательПриведенный;
				КонецЕсли;
			КонецЦикла;
			#КонецОбласти
			
			ИзменилисьИтоги = Ложь;
			Если НаборЗаписей.Количество() > 0 Тогда
				ИзменилисьИтоги = РегистрыНакопления.РасчетыСКлиентами.ЕстьИзмененияИтоговНабора(НаборЗаписей);
			КонецЕсли;
			
			Если НаборЗаписей.Модифицированность() И НЕ ИзменилисьИтоги Тогда
				ОбновлениеИнформационнойБазы.ЗаписатьДанные(НаборЗаписей);
			Иначе
				ОбновлениеИнформационнойБазы.ОтметитьВыполнениеОбработки(НаборЗаписей);
			КонецЕсли;
			
			ЗафиксироватьТранзакцию();
			
		Исключение
			
			ОтменитьТранзакцию();
			Если ПричинаИсключения = "ПлохиеДанные" Тогда
				ОбновлениеИнформационнойБазыУТ.СообщитьОНеудачнойОбработке(ИнформацияОбОшибке(), ОбновляемыйРегистратор);
				Если ЗначениеЗаполнено(ОбновляемыйРегистратор) Тогда
					ОбновлениеИнформационнойБазы.ОтметитьВыполнениеОбработки(НаборЗаписей);
					ОбновлениеИнформационнойБазы.ЗарегистрироватьПроблемуСДанными(
						ОбновляемыйРегистратор,
						РегистрыНакопления.РасчетыСКлиентами.ТекстСообщенияОбОшибке(ИнформацияОбОшибке(), ОбновляемыйРегистратор)
						+ Символы.ПС + РегистрыНакопления.РасчетыСКлиентами.ТекстПерепроведитеДокументВРучную());
				КонецЕсли;
			КонецЕсли;
			
		КонецПопытки;
		
	КонецЦикла;
	
	Параметры.ОбработкаЗавершена = ОбновлениеИнформационнойБазы.ОбработкаДанныхЗавершена(Параметры.Очередь, ПолноеИмяОбъекта);
	
КонецПроцедуры

#КонецОбласти

#КонецОбласти

#КонецЕсли