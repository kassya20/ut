	УстановитьПоляИндексов(Запрос, ПараметрыРасчета, "РасчетыСКлиентами_ПогашенияАвансов");
	
	ПараметрыПутей = ИнициализироватьПараметрыДляОтбораАвансов_ПутиКПолямИТекстуЗамены();
