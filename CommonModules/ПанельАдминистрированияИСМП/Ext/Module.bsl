#Область СлужебныеПроцедурыИФункции

Процедура ПриСозданииНаСервере(Форма, Отказ, СтандартнаяОбработка) Экспорт

	Форма.РедактированиеАвтоматическойОтправкиДанных = ПравоДоступа(
		"Редактирование", Метаданные.Константы.ИспользоватьАвтоматическуюОтправкуПолучениеДанныхИСМП);
	
	Форма.РедактированиеСрокаХранения = ПравоДоступа(
		"Редактирование", Метаданные.Константы.СрокХраненияИспользованныхКодовМаркировки);
	
	Форма.РедактированиеАвтоматическогоУдаленияНеиспользованныхКодовМаркировки = ПравоДоступа(
		"Редактирование", Метаданные.Константы.ИспользоватьАвтоматическоеУдалениеНеиспользованныхКодовМаркировкиИСМП);
		
	Форма.РедактированиеАвтоматическогоУдаленияНеиспользованныхКодовМаркировки = ПравоДоступа(
		"Редактирование", Метаданные.Константы.ИспользоватьАвтоматическуюЗагрузкуСведенийОбОтклоненияхИСМП);
	
	Форма.УдалятьКодыМаркировкиИзПула = Форма.НаборКонстант.СрокХраненияИспользованныхКодовМаркировки > 0;
	
КонецПроцедуры

Процедура НастроитьЭлементыФормыНаСервере(Форма, СтандартнаяОбработка) Экспорт
	
	Элементы        = Форма.Элементы;
	ЛегкийИнтерфейс = Форма.УпрощеннаяИнтеграцияБЭД Или Не Форма.ЭтоПолноправныйПользователь;
	
	Если ЛегкийИнтерфейс Тогда
		
		Форма.Заголовок = Нстр("ru = 'Товарные группы'");
		Элементы.СтраницыНастройки.ОтображениеСтраниц    = ОтображениеСтраницФормы.Нет;
		Элементы.СтраницаНастройки.Видимость             = Ложь;
		Элементы.СтраницаРегламентныеЗадания.Видимость   = Ложь;
		Элементы.СтраницаРозница.Видимость               = Ложь;
		Элементы.СтраницаСУЗ.Видимость                   = Ложь;
		Элементы.СтраницаСправочники.Видимость           = Ложь;
		Элементы.СтраницаНастройкиСканирования.Видимость = Ложь;
		
		Элементы.СписокМаркируемаяПродукцияИзменитьФорму.Видимость = Истина;
		Элементы.ФормаИзменитьФорму.Видимость                      = Ложь;
		
		Элементы.СтраницаТоварныеГруппы.ТолькоПросмотр = Не Форма.УпрощеннаяИнтеграцияБЭД;
		Элементы.СинхронизацияТоварныхГрупп.Видимость  = Форма.УпрощеннаяИнтеграцияБЭД;
		
		СтандартнаяОбработка = Ложь;
		Возврат;
		
	КонецЕсли;
	
	Элементы.ОткрытьКассыНеПередающиеДанныеВИСМП.Видимость = Форма.ЭтоРасширеннаяВерсияГосИС
		И ПравоДоступа("Просмотр", Метаданные.РегистрыСведений.КассыНеПередающиеДанныеВИСМП);
	Элементы.ОткрытьПулКодовМаркировкиСУЗ.Видимость = 
		ПравоДоступа("Просмотр", Метаданные.РегистрыСведений.ПулКодовМаркировкиСУЗ);
	
	// МРЦ
	ВозможноВключение              = Истина;
	ВозможноОтключение             = Истина;
	ПричинаНевозможностиВключения  = "";
	ПричинаНевозможностиОтключения = "";
	
	ИнтеграцияИСМППереопределяемый.ПриОпределенииВозможностиВключенияОтключенияВеденияУчетаМРЦ(
		ВозможноВключение,
		ПричинаНевозможностиВключения,
		ВозможноОтключение,
		ПричинаНевозможностиОтключения);
	
	ОписаниеВеденияУчета = Новый Массив;
	ОписаниеВеденияУчета.Добавить(
		НСтр("ru = 'При проверке поступления табачной продукции или при сканировании табачных кодов маркировки'"));
	ОписаниеВеденияУчета.Добавить(" ");
	ОписаниеВеденияУчета.Добавить(
		НСтр("ru = 'МРЦ будет распознаваться из состава кода маркировки или запрашиваться из сервиса ГИС МТ.'"));
	ОписаниеВеденияУчета.Добавить(" ");
	ОписаниеВеденияУчета.Добавить(
		НСтр("ru = 'МРЦ может использоваться при ведении классификаторов номенклатуры или для контроля цены при оформлении розничных продаж.'"));
	
	ВключенаПродукцияИспользующаяМРЦ = Ложь;
	Для Каждого ВидПродукции Из КонструкторИСМПОбщегоНазначенияКлиентСервер.ВидыПродукцииКоторымДоступноПолеМРЦ() Цикл
		Если ОбщегоНазначенияИСМПВызовСервера.ВестиУчетМаркируемойПродукции(ВидПродукции) Тогда
			ВключенаПродукцияИспользующаяМРЦ = Истина;
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
	ВключенаПродукцияПоддерживающаяСеруюЗону = Ложь;
	ВидыПродукцииПоддерживающиеСеруюЗону = КонструкторИСМПКлиентСервер.ВидыПродукцииПоддерживающиеСеруюЗону();
	Для Каждого ВидПродукции Из ВидыПродукцииПоддерживающиеСеруюЗону Цикл
		Если ОбщегоНазначенияИСМПВызовСервера.ВестиУчетМаркируемойПродукции(ВидПродукции) Тогда
			ВключенаПродукцияПоддерживающаяСеруюЗону = Истина;
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
	ВключенаТабачнаяПродукция = Ложь;
	Для Каждого ВидПродукции Из КонструкторИСОбщегоНазначенияКлиентСервер.ВидыПродукцииМОТП() Цикл
		Если ОбщегоНазначенияИСМПВызовСервера.ВестиУчетМаркируемойПродукции(ВидПродукции) Тогда
			ВключенаТабачнаяПродукция = Истина;
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
	Если Форма.УчитыватьМРЦ Тогда
		
		Если ВозможноОтключение Тогда
			Элементы.УчитыватьМРЦ.ТолькоПросмотр = Ложь;
		Иначе
			Элементы.УчитыватьМРЦ.ТолькоПросмотр = Истина;
			ОписаниеВеденияУчета.Добавить(Символы.ПС);
			ОписаниеВеденияУчета.Добавить(ПричинаНевозможностиОтключения);
		КонецЕсли;
		
	Иначе
		
		Если ВозможноВключение Тогда
			Элементы.УчитыватьМРЦ.ТолькоПросмотр = Ложь;
		Иначе
			Элементы.УчитыватьМРЦ.ТолькоПросмотр = Истина;
			ОписаниеВеденияУчета.Добавить(Символы.ПС);
			ОписаниеВеденияУчета.Добавить(ПричинаНевозможностиВключения);
		КонецЕсли;
		
	КонецЕсли;
	
	Элементы.РежимКонтроляСредствамиККТ.СписокВыбора.Очистить();
	РежимыКонтроля          = НастройкаПараметровСканированияСлужебныйКлиентСерверПовтИсп.РежимыКонтроляСредствамиККТ();
	ПредставленияПараметров = НастройкаПараметровСканированияСлужебныйКлиентСерверПовтИсп.ПредставленияПараметровСканирования();
	
	Элементы.РежимКонтроляСредствамиККТ.СписокВыбора.Добавить(
		РежимыКонтроля.ПриСканировании,
		ПредставленияПараметров.Получить(РежимыКонтроля.ПриСканировании));
	
	Элементы.РежимКонтроляСредствамиККТ.СписокВыбора.Добавить(
		РежимыКонтроля.ПередПробитиемЧека,
		ПредставленияПараметров.Получить(РежимыКонтроля.ПередПробитиемЧека));
	
	Если Не ЗначениеЗаполнено(Форма.РежимКонтроляСредствамиККТ) Тогда
		Форма.РежимКонтроляСредствамиККТ = РежимыКонтроля.ПриСканировании;
	КонецЕсли;
	
	Элементы.ГруппаСераяЗона.Видимость = ВключенаПродукцияПоддерживающаяСеруюЗону;
	
	ОписаниеВеденияУчета.Добавить(Символы.ПС);
	ОписаниеВеденияУчета.Добавить(НСтр("ru = 'Не поддерживается для альтернативной табачной продукции.'"));
	
	Элементы.УчитыватьМРЦ.РасширеннаяПодсказка.Заголовок = Новый ФорматированнаяСтрока(ОписаниеВеденияУчета);
	Элементы.УчитыватьМРЦ.Видимость = ВключенаПродукцияИспользующаяМРЦ;
	
	Элементы.ГруппаТабачнаяПродукция.Видимость = ВключенаТабачнаяПродукция;
	
	ВедетсяУчетСырья = Ложь;
	Для Каждого ВидПродукции Из ОбщегоНазначенияИСМПКлиентСерверПовтИсп.УчитываемыеВидыМаркируемойПродукции() Цикл
		Если КонструкторИСМПКлиентСервер.ЭтоСырьеГИСМТ(ВидПродукции) Тогда
			ВедетсяУчетСырья = Истина;
		КонецЕсли;
	КонецЦикла;
	
	Элементы.ОткрытьКлассификаторСырьяГИСМТ.Видимость = ВедетсяУчетСырья
		И ПравоДоступа("Просмотр", Метаданные.Справочники.КлассификаторСырьяГИСМТ);
	
КонецПроцедуры

Процедура УстановитьУсловноеОформление(Форма) Экспорт
	
	Элементы = Форма.Элементы;
	
	// запрет редактирования даты действия вывода из оборота
	ВидыПродукцииВыводаИзОборота = КонструкторИСОбщегоНазначенияКлиентСервер.ВидыПродукцииПоЭлементуКонструктора(
			ПредопределенноеЗначение(
				"Справочник.ЭлементыКонструктораВидовПродукцииИС.ПричиныВыводаИзОборотаОСУ"));
	ОбщегоНазначенияКлиентСервер.ДополнитьМассив(
		ВидыПродукцииВыводаИзОборота,
		КонструкторИСОбщегоНазначенияКлиентСервер.ВидыПродукцииПоЭлементуКонструктора(
			ПредопределенноеЗначение(
				"Справочник.ЭлементыКонструктораВидовПродукцииИС.ПричиныВыводаИзОборотаПоштучно")),
		Истина);
	
	СписокВидовПродукцийВыводаИзОборота = Новый СписокЗначений;
	СписокВидовПродукцийВыводаИзОборота.ЗагрузитьЗначения(ВидыПродукцииВыводаИзОборота);
	
	Элемент = Форма.УсловноеОформление.Элементы.Добавить();
	
	ПолеЭлемента = Элемент.Поля.Элементы.Добавить();
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(Элементы.МаркируемаяПродукцияДатаНачалаВыводаИзОборота.Имя);
	
	ОтборЭлемента = Элемент.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ОтборЭлемента.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("МаркируемаяПродукция.ВидПродукции");
	ОтборЭлемента.ВидСравнения  = ВидСравненияКомпоновкиДанных.НеВСписке;
	ОтборЭлемента.ПравоеЗначение = СписокВидовПродукцийВыводаИзОборота;
	
	Элемент.Оформление.УстановитьЗначениеПараметра("Текст",          НСтр("ru = 'не применимо'"));
	Элемент.Оформление.УстановитьЗначениеПараметра("ЦветТекста",     ЦветаСтиля.ЦветТекстаНеТребуетВниманияГосИС);
	Элемент.Оформление.УстановитьЗначениеПараметра("ТолькоПросмотр", Истина);
	
	//ОСУ
	СписокВидовПродукцийПоддерживающихОСУ = Новый СписокЗначений();
	СписокВидовПродукцийПоддерживающихОСУ.ЗагрузитьЗначения(
		КонструкторИСОбщегоНазначенияКлиентСервер.ВидыПродукцииОбъемноСортовогоУчета());
	
	Элемент = Форма.УсловноеОформление.Элементы.Добавить();
	
	ПолеЭлемента = Элемент.Поля.Элементы.Добавить();
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(Элементы.МаркируемаяПродукцияДатаНачалаОформленияУПДОСУ.Имя);
	
	ОтборЭлемента = Элемент.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ОтборЭлемента.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("МаркируемаяПродукция.ВидПродукции");
	ОтборЭлемента.ВидСравнения  = ВидСравненияКомпоновкиДанных.НеВСписке;
	ОтборЭлемента.ПравоеЗначение = СписокВидовПродукцийПоддерживающихОСУ;
	
	Элемент.Оформление.УстановитьЗначениеПараметра("Текст",          НСтр("ru = 'не применимо'"));
	Элемент.Оформление.УстановитьЗначениеПараметра("ЦветТекста",     ЦветаСтиля.ЦветТекстаНеТребуетВниманияГосИС);
	Элемент.Оформление.УстановитьЗначениеПараметра("ТолькоПросмотр", Истина);	
	
	// надпись действует для ОСУ
	Элемент = Форма.УсловноеОформление.Элементы.Добавить();
	
	ПолеЭлемента = Элемент.Поля.Элементы.Добавить();
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(Элементы.МаркируемаяПродукцияДатаНачалаОформленияУПДОСУ.Имя);
	
	ГруппаОтбора = Элемент.Отбор.Элементы.Добавить(Тип("ГруппаЭлементовОтбораКомпоновкиДанных"));
	ГруппаОтбора.ТипГруппы = ТипГруппыЭлементовОтбораКомпоновкиДанных.ГруппаИ;
	
	ОтборЭлемента = ГруппаОтбора.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ОтборЭлемента.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("МаркируемаяПродукция.ДатаНачалаОформленияУПДОСУ");
	ОтборЭлемента.ВидСравнения  = ВидСравненияКомпоновкиДанных.МеньшеИлиРавно;
	ОтборЭлемента.ПравоеЗначение = НачалоДня(ТекущаяДатаСеанса());
	
	ОтборЭлемента = ГруппаОтбора.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ОтборЭлемента.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("МаркируемаяПродукция.ДатаНачалаОформленияУПДОСУ");
	ОтборЭлемента.ВидСравнения  = ВидСравненияКомпоновкиДанных.Заполнено;
	
	Элемент.Оформление.УстановитьЗначениеПараметра("Текст",          НСтр("ru = 'действует'"));
	
	// запрет редактирования даты контроля перемещения между МОД, не поддерживающих перемещение между МОД
	СписокВидовПродукцийПоддерживающихПеремещениеМеждуМОД = Новый СписокЗначений;
	СписокВидовПродукцийПоддерживающихПеремещениеМеждуМОД.ЗагрузитьЗначения(
		КонструкторИСМПКлиентСервер.ВидыПродукцииПрослеживаемогоПеремещенияМеждуМОД());
	
	Элемент = Форма.УсловноеОформление.Элементы.Добавить();
	
	ПолеЭлемента = Элемент.Поля.Элементы.Добавить();
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(Элементы.МаркируемаяПродукцияДатаНачалаПрослеживаемостиПеремещенияМеждуМОД.Имя);
	
	ОтборЭлемента = Элемент.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ОтборЭлемента.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("МаркируемаяПродукция.ВидПродукции");
	ОтборЭлемента.ВидСравнения  = ВидСравненияКомпоновкиДанных.НеВСписке;
	ОтборЭлемента.ПравоеЗначение = СписокВидовПродукцийПоддерживающихПеремещениеМеждуМОД;
	
	Элемент.Оформление.УстановитьЗначениеПараметра("Текст",          НСтр("ru = 'не применимо'"));
	Элемент.Оформление.УстановитьЗначениеПараметра("ЦветТекста",     ЦветаСтиля.ЦветТекстаНеТребуетВниманияГосИС);
	Элемент.Оформление.УстановитьЗначениеПараметра("ТолькоПросмотр", Истина);
	
КонецПроцедуры

#КонецОбласти