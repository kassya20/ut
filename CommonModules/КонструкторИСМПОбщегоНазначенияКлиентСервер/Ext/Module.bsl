КонецФункции

// Возвращает представление вида упаковки по виду продукции
//
// Параметры:
//  ВидПродукцииТоварнаяГруппа - СправочникСсылка.КлючиВидовПродукцииИС,
//                               СправочникСсылка.ВидыПродукцииИС,
//                               Массив из СправочникСсылка.ВидыПродукцииИС - Виды продукции,
//                               СправочникСсылка.ТоварныеГруппыГИСМТ - Товарная группа
//  ВидУпаковки - ПеречислениеСсылка.ВидыУпаковкиЕГАИС - вид упаковки
//  Падеж - Строка - падеж для склонения (по умолчанию "Именительный")
//  ГрамматическоеЧисло - Строка - грамматическое число (по умолчанию "Единственное")
//  ЭтоОписаниеКоличества - Булево - признак описания количества (по умолчанию Ложь)
//
// Возвращаемое значение:
//  Строка - представление вида упаковки
//
Функция ПредставлениеВидаУпаковкиПоВидуПродукции(ВидПродукцииТоварнаяГруппа, ВидУпаковки, Падеж = "Именительный", ГрамматическоеЧисло = "Единственное", ЭтоОписаниеКоличества = Ложь) Экспорт
	
	Если ВидПродукцииТоварнаяГруппа = ПредопределенноеЗначение("Справочник.ТоварныеГруппыГИСМТ.ПустаяСсылка")
		Или ВидПродукцииТоварнаяГруппа = ПредопределенноеЗначение("Справочник.КлючиВидовПродукцииИС.ПустаяСсылка") Тогда
		ВидыПродукции = ПредопределенноеЗначение("Справочник.ВидыПродукцииИС.ПустаяСсылка");
	Иначе
		ВидыПродукции = ВидыПродукции(ВидПродукцииТоварнаяГруппа);
	КонецЕсли;
	
	Возврат КонструкторИСОбщегоНазначенияКлиентСервер.ПредставлениеВидаУпаковкиПоВидуПродукции(
		ВидыПродукции,
		ВидУпаковки,
		Падеж,
		ГрамматическоеЧисло,
		ЭтоОписаниеКоличества);
	
КонецФункции

// Проверяет, поддерживается ли подключение к оборудованию розлива для указанного вида продукции
//
// Параметры:
//  ВидПродукцииТоварнаяГруппа - СправочникСсылка.КлючиВидовПродукцииИС,
//                               СправочникСсылка.ВидыПродукцииИС,
//                               Массив из СправочникСсылка.ВидыПродукцииИС - Виды продукции,
//                               СправочникСсылка.ТоварныеГруппыГИСМТ - Товарная группа
//
// Возвращаемое значение:
//  Булево - Истина, если поддерживается подключение к оборудованию розлива
//
Функция ПоддерживаетсяПодключениеКОборудованиюРозлива(ВидПродукцииТоварнаяГруппа) Экспорт
	
	Возврат КонструкторИСОбщегоНазначенияКлиентСервер.ЗначенияЭлементаКонструктораПоВидуПродукции(
		ПредопределенноеЗначение(
			"Справочник.ЭлементыКонструктораВидовПродукцииИС.ПоддерживаетсяПодключениеКОборудованиюРозлива"),
			ВидыПродукции(ВидПродукцииТоварнаяГруппа));
	
КонецФункции

// Возвращает имя товарной группы по виду продукции или товарной группе.
//
// Параметры:
//  ВидПродукцииТоварнаяГруппа - СправочникСсылка.КлючиВидовПродукцииИС,
//                               СправочникСсылка.ВидыПродукцииИС,
//                               СправочникСсылка.ТоварныеГруппыГИСМТ - Товарная группа.
//
// Возвращаемое значение:
//  Строка - имя товарной группы,
//  Неопределено - если товарная группа не найдена.
//
Функция ИмяТоварнойГруппы(ВидПродукцииТоварнаяГруппа) Экспорт
	
	Результат = Неопределено;
	
	Если ТипЗнч(ВидПродукцииТоварнаяГруппа) = Тип("СправочникСсылка.ТоварныеГруппыГИСМТ") Тогда
		ТоварнаяГруппа = ВидПродукцииТоварнаяГруппа;
	Иначе
		ТоварнаяГруппа = ТоварнаяГруппаПоВидуПродукции(ВидПродукцииТоварнаяГруппа);
	КонецЕсли;
	
	Если ТоварнаяГруппа <> Неопределено Тогда
		Результат = ОбщегоНазначенияИСМПКлиентСерверПовтИсп.ДанныеТоварнойГруппы(ТоварнаяГруппа).Имя;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

