Функция ПредставлениеТоварнойКатегории(ВидПродукции, Наименование) Экспорт
	
	Результат = "";
	
	ТоварнаяГруппа = ТоварнаяГруппаПоВидуПродукции(ВидПродукции);
	ВидыПродукции = ВидыПродукцииПоТоварнойГруппе(ТоварнаяГруппа);
	
	Если ВидыПродукции.Количество() = 1 Тогда
		Результат = ТоварнаяГруппа;
	Иначе
		Результат = СтрШаблон("%1 (%2)", Наименование, ТоварнаяГруппа);
	КонецЕсли;
	
	Возврат Результат;
	
