Функция ИменаДатНачалаРаботыСМаркируемойПродукцией(КакСтруктура = Ложь) Экспорт
	
	Если КакСтруктура Тогда
		Результат = Новый Структура;
		Результат.Вставить("ДатаНачалаПроизводства",                        "ДатаНачалаПроизводства");
		Результат.Вставить("ДатаНачалаОформленияУПДОСУ",                    "ДатаНачалаОформленияУПДОСУ");
		Результат.Вставить("ДатаНачалаОформленияУПДПоштучно",               "ДатаНачалаОформленияУПДПоштучно");
		Результат.Вставить("ДатаНачалаРозничныхПродаж",                     "ДатаНачалаРозничныхПродаж");
		Результат.Вставить("ДатаНачалаРазрешительногоРежима",               "ДатаНачалаРазрешительногоРежима");
		Результат.Вставить("ДатаНачалаИспользованияЛокальногоМодуля",       "ДатаНачалаИспользованияЛокальногоМодуля");
		Результат.Вставить("ДатаНачалаВыводаИзОборота",                     "ДатаНачалаВыводаИзОборота");
		Результат.Вставить("ДатаНачалаЗапретаПродажБезМарок",               "ДатаНачалаЗапретаПродажБезМарок");
		Результат.Вставить("ДатаНачалаПрослеживаемостиПеремещенияМеждуМОД", "ДатаНачалаПрослеживаемостиПеремещенияМеждуМОД");
		Результат.Вставить("ДатаНачалаКонтроляРазрешительныхДокументов",    "ДатаНачалаКонтроляРазрешительныхДокументов");
	Иначе
		Результат = Новый Массив;
		Результат.Добавить("ДатаНачалаПроизводства");
		Результат.Добавить("ДатаНачалаОформленияУПДОСУ");
		Результат.Добавить("ДатаНачалаОформленияУПДПоштучно");
		Результат.Добавить("ДатаНачалаРозничныхПродаж");
		Результат.Добавить("ДатаНачалаРазрешительногоРежима");
		Результат.Добавить("ДатаНачалаИспользованияЛокальногоМодуля");
		Результат.Добавить("ДатаНачалаВыводаИзОборота");
		Результат.Добавить("ДатаНачалаЗапретаПродажБезМарок");
		Результат.Добавить("ДатаНачалаПрослеживаемостиПеремещенияМеждуМОД");
		Результат.Добавить("ДатаНачалаКонтроляРазрешительныхДокументов");
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

