// Возвращает минимальную длину кода логистической упаковки
//
// Параметры:
//  ВидПродукцииТоварнаяГруппа - СправочникСсылка.КлючиВидовПродукцииИС,
//                               СправочникСсылка.ВидыПродукцииИС,
//                               Массив из СправочникСсылка.ВидыПродукцииИС - Виды продукции,
//                               СправочникСсылка.ТоварныеГруппыГИСМТ - Товарная группа.
// Возвращаемое значение:
//  Число - Минимальная длина кода логистической упаковки.
Функция МинимальнаяДлинаКодаЛогистическойУпаковки(ВидПродукцииТоварнаяГруппа) Экспорт
	
	Значения = КонструкторИСОбщегоНазначенияКлиентСервер.ЗначенияЭлементаКонструктораПоВидуПродукции(
		ПредопределенноеЗначение(
			"Справочник.ЭлементыКонструктораВидовПродукцииИС.МинимальнаяДлинаКодаЛогистическойУпаковки"),
			ВидыПродукции(ВидПродукцииТоварнаяГруппа));
	
	МинимальноеЗначение = Неопределено;
	Для Каждого Значение Из Значения Цикл
		Если МинимальноеЗначение = Неопределено Тогда
			МинимальноеЗначение = Значение;
		Иначе
			МинимальноеЗначение = Мин(МинимальноеЗначение, Значение);
		КонецЕсли;
	КонецЦикла;
	
	Если МинимальноеЗначение = Неопределено Тогда
		МинимальноеЗначение = 0;
	КонецЕсли;
	
	Возврат МинимальноеЗначение;
	
КонецФункции

// Возвращает максимальную длину кода логистической упаковки
//
// Параметры:
//  ВидПродукцииТоварнаяГруппа - СправочникСсылка.КлючиВидовПродукцииИС,
//                               СправочникСсылка.ВидыПродукцииИС,
//                               Массив из СправочникСсылка.ВидыПродукцииИС - Виды продукции,
//                               СправочникСсылка.ТоварныеГруппыГИСМТ - Товарная группа.
// Возвращаемое значение:
//  Число - Максамальная длина кода логистической упаковки.
Функция МаксимальнаяДлинаКодаЛогистическойУпаковки(ВидПродукцииТоварнаяГруппа) Экспорт
	
	Значения = КонструкторИСОбщегоНазначенияКлиентСервер.ЗначенияЭлементаКонструктораПоВидуПродукции(
		ПредопределенноеЗначение(
			"Справочник.ЭлементыКонструктораВидовПродукцииИС.МаксимальнаяДлинаКодаЛогистическойУпаковки"),
			ВидыПродукции(ВидПродукцииТоварнаяГруппа));
	
	МаксимальноеЗначение = Неопределено;
	Для Каждого Значение Из Значения Цикл
		Если МаксимальноеЗначение = Неопределено Тогда
			МаксимальноеЗначение = Значение;
		Иначе
			МаксимальноеЗначение = Макс(МаксимальноеЗначение, Значение);
		КонецЕсли;
	КонецЦикла;
	
	Если МаксимальноеЗначение = Неопределено Тогда
		МаксимальноеЗначение = 0;
	КонецЕсли;
	
	Возврат МаксимальноеЗначение;
	
КонецФункции

