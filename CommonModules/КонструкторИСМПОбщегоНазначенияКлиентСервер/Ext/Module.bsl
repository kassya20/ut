#Область ПрограммныйИнтерфейс

// Возвращает дату начала прослеживаемости перемещения между МОД
// для указанного вида продукции (товарной группы).
//
// Параметры:
//  ВидПродукцииТоварнаяГруппа - Строка, СправочникСсылка - вид продукции или товарная группа,
//                                для которой определяется дата начала прослеживаемости
//                                перемещения между МОД
//
// Возвращаемое значение:
//  Дата - дата начала прослеживаемости перемещения между МОД,
//  Неопределено - если дата не задана для указанного вида продукции
//
Функция ДатаНачалаПрослеживаемостиПеремещенияМеждуМОД(ВидПродукцииТоварнаяГруппа) Экспорт
	
	Результат = Неопределено;
	
	Даты = КонструкторИСОбщегоНазначенияКлиентСервер.ЗначенияЭлементаКонструктораПоВидуПродукции(
		ПредопределенноеЗначение(
			"Справочник.ЭлементыКонструктораВидовПродукцииИС.ДатыНачалаПрослеживаемостиПеремещенияМеждуМОД"),
		ВидыПродукции(ВидПродукцииТоварнаяГруппа));
	
	Если Даты.Количество() > 0 Тогда
		Результат = Даты[0];
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Проверяет, доступно ли поле "Минимальная розничная цена" для указанного вида продукции.
//
// Параметры:
//  ВидПродукцииТоварнаяГруппа - СправочникСсылка.КлючиВидовПродукцииИС,
//                               СправочникСсылка.ВидыПродукцииИС,
//                               Массив из СправочникСсылка.ВидыПродукцииИС - Виды продукции,
//                               СправочникСсылка.ТоварныеГруппыГИСМТ - Товарная группа
//
// Возвращаемое значение:
//  Булево - Истина, если поле МРЦ доступно
//
Функция ДоступноПолеМРЦ(ВидПродукцииТоварнаяГруппа) Экспорт
	
	Возврат КонструкторИСОбщегоНазначенияКлиентСервер.ЗначенияЭлементаКонструктораПоВидуПродукции(
		ПредопределенноеЗначение(
			"Справочник.ЭлементыКонструктораВидовПродукцииИС.ПолеМРЦ"),
		ВидыПродукции(ВидПродукцииТоварнаяГруппа));
	
КонецФункции

// Возвращает виды продукции, для которых доступно поле "Минимальная розничная цена".
//
// Возвращаемое значение:
//  Массив из СправочникСсылка.ВидыПродукцииИС - Виды продукции, для которых доступно поле МРЦ
//
Функция ВидыПродукцииКоторымДоступноПолеМРЦ() Экспорт
	
	Возврат КонструкторИСОбщегоНазначенияКлиентСервер.ВидыПродукцииПоЭлементуКонструктора(
		ПредопределенноеЗначение(
			"Справочник.ЭлементыКонструктораВидовПродукцииИС.ПолеМРЦ"));
	
КонецФункции

// Проверяет, нужно ли использовать числитель и знаменатель при частичном выбытии на ККТ
// для указанного вида продукции.
//
// Параметры:
//  ВидПродукцииТоварнаяГруппа - СправочникСсылка.КлючиВидовПродукцииИС,
//                               СправочникСсылка.ВидыПродукцииИС,
//                               Массив из СправочникСсылка.ВидыПродукцииИС - Виды продукции,
//                               СправочникСсылка.ТоварныеГруппыГИСМТ - Товарная группа.
//
// Возвращаемое значение:
//  Булево - Истина, если нужно использовать числитель и знаменатель при частичном выбытии на ККТ
//
Функция ИспользоватьЧислительИЗнаменательПриЧастичномВыбытииНаККТ(ВидПродукцииТоварнаяГруппа) Экспорт
	
	Возврат КонструкторИСОбщегоНазначенияКлиентСервер.ЗначенияЭлементаКонструктораПоВидуПродукции(
		ПредопределенноеЗначение(
			"Справочник.ЭлементыКонструктораВидовПродукцииИС.ИспользоватьЧислительИЗнаменательПриЧастичномВыбытииНаККТ"),
			ВидыПродукции(ВидПродукцииТоварнаяГруппа));
	
КонецФункции

// Проверяет, является ли продукция продукцией ЕГАИС
//
// Параметры:
//  ВидПродукцииТоварнаяГруппа - СправочникСсылка.КлючиВидовПродукцииИС,
//                               СправочникСсылка.ВидыПродукцииИС,
//                               Массив из СправочникСсылка.ВидыПродукцииИС - Виды продукции,
//                               СправочникСсылка.ТоварныеГруппыГИСМТ - Товарная группа
//
// Возвращаемое значение:
//  Булево - Истина, если продукция является продукцией ЕГАИС
//
Функция ЭтоПродукцияЕГАИС(ВидПродукцииТоварнаяГруппа) Экспорт
	
	Возврат КонструкторИСОбщегоНазначенияКлиентСервер.ЭтоПродукцияЕГАИС(
		ВидыПродукции(ВидПродукцииТоварнаяГруппа));
	
КонецФункции

// Проверяет, является ли продукция продукцией ИС МП
//
// Параметры:
//  ВидПродукцииТоварнаяГруппа - СправочникСсылка.КлючиВидовПродукцииИС,
//                               СправочникСсылка.ВидыПродукцииИС,
//                               Массив из СправочникСсылка.ВидыПродукцииИС - Виды продукции,
//                               СправочникСсылка.ТоварныеГруппыГИСМТ - Товарная группа
//  ВключатьТабачнуюПродукцию - Булево - включать ли табачную продукцию (по умолчанию Ложь)
//
// Возвращаемое значение:
//  Булево - Истина, если продукция является продукцией ИС МП
//
Функция ЭтоПродукцияИСМП(ВидПродукцииТоварнаяГруппа, ВключатьТабачнуюПродукцию = Ложь) Экспорт
	
	Возврат КонструкторИСОбщегоНазначенияКлиентСервер.ЭтоПродукцияИСМП(
		ВидыПродукции(ВидПродукцииТоварнаяГруппа), ВключатьТабачнуюПродукцию);
	
КонецФункции

// Проверяет, является ли вид продукции ГИС МТ связанным с ЕГАИС
//
// Параметры:
//  ВидПродукции - СправочникСсылка.ВидыПродукцииИС - Вид продукции
//               - Массив Из СправочникСсылка.ВидыПродукцииИС - Массив видов продукции
//               - СправочникСсылка.КлючиВидовПродукцииИС - Ключ видов продукции
//               - СправочникСсылка.ТоварныеГруппыГИСМТ - Товарная группа
// Возвращаемое значение:
//  Булево - Истина, если вид продукции ГИС МТ связан с подконтрольной ЕГАИС продукцией.
Функция ЭтоВидПродукцииИСМПЕГАИС(Знач ВидПродукции) Экспорт
	
	ВидыПродукцииПодконтрольныеЕГАИС = КонструкторИСОбщегоНазначенияКлиентСервер.ВидыПродукцииИСМПЕГАИС();
	
	Если ТипЗнч(ВидПродукции) = Тип("Массив") Тогда
		Для Каждого ВидПродукцииИзМассива Из ВидПродукции Цикл
			Если ВидыПродукцииПодконтрольныеЕГАИС.Найти(ВидПродукцииИзМассива) <> Неопределено Тогда
				Возврат Истина;
			КонецЕсли;
		КонецЦикла;
		Возврат Ложь;
	ИначеЕсли ТипЗнч(ВидПродукции) = Тип("СправочникСсылка.КлючиВидовПродукцииИС") Тогда
		ВидПродукции = КонструкторИСОбщегоНазначенияКлиентСервер.ВидПродукцииКлючаПоПодсистеме(ВидПродукции, "ГИСМТ");
	ИначеЕсли ТипЗнч(ВидПродукции) = Тип("СправочникСсылка.ТоварныеГруппыГИСМТ") Тогда
		Для Каждого ВидПродукцииИзМассива Из ВидыПродукции(ВидПродукции) Цикл
			Если ВидыПродукцииПодконтрольныеЕГАИС.Найти(ВидПродукцииИзМассива) <> Неопределено Тогда
				Возврат Истина;
			КонецЕсли;
		КонецЦикла;
		Возврат Ложь;
	КонецЕсли;
	
	Возврат ВидыПродукцииПодконтрольныеЕГАИС.Найти(ВидПродукции) <> Неопределено;
	
КонецФункции

// Возвращает виды продукции, которые поддерживают подключение к оборудованию розлива
//
//Возвращаемое значение:
//  Массив из СправочникСсылка.ВидыПродукцииИС - Виды продукции, поддерживающие переменное количество
Функция ВидыПродукцииПоддерживающиеПодключениеКОборудованиюРозлива() Экспорт
	
	Возврат КонструкторИСОбщегоНазначенияКлиентСервер.ВидыПродукцииПоЭлементуКонструктора(
		ПредопределенноеЗначение(
			"Справочник.ЭлементыКонструктораВидовПродукцииИС.ПоддерживаетсяПодключениеКОборудованиюРозлива"));
	
КонецФункции

// Возвращает товарную группу для указанного вида продукции
//
// Параметры:
//  ВидПродукцииТоварнаяГруппа - СправочникСсылка.КлючиВидовПродукцииИС,
//                               СправочникСсылка.ВидыПродукцииИС,
//                               Массив из СправочникСсылка.ВидыПродукцииИС - Виды продукции,
//                               СправочникСсылка.ТоварныеГруппыГИСМТ - Товарная группа
//
// Возвращаемое значение:
//  СправочникСсылка.ТоварныеГруппыГИСМТ - товарная группа,
//  Неопределено - если товарная группа не найдена
//
Функция ТоварнаяГруппаПоВидуПродукции(ВидПродукцииТоварнаяГруппа) Экспорт
	
	Результат = Неопределено;
	
	ТоварныеГруппы = КонструкторИСОбщегоНазначенияКлиентСервер.ЗначенияЭлементаКонструктораПоВидуПродукции(
		ПредопределенноеЗначение(
			"Справочник.ЭлементыКонструктораВидовПродукцииИС.ТоварныеГруппыГИСМТ"),
		ВидыПродукции(ВидПродукцииТоварнаяГруппа));
	
	Если ТоварныеГруппы.Количество() > 0 Тогда
		Возврат ТоварныеГруппы[0];
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Возвращает список видов продукции для указанной товарной группы
//
// Параметры:
//  ТоварнаяГруппа - СправочникСсылка.ТоварныеГруппыГИСМТ - товарная группа
//
// Возвращаемое значение:
//  Массив из СправочникСсылка.ВидыПродукцииИС
//
Функция ВидыПродукцииПоТоварнойГруппе(ТоварнаяГруппа) Экспорт
	
	Если ЗначениеЗаполнено(ТоварнаяГруппа) Тогда
		Результат = КонструкторИСОбщегоНазначенияКлиентСервер.ВидыПродукцииПоЗначениюЭлементаКонструктора(
			ПредопределенноеЗначение(
				"Справочник.ЭлементыКонструктораВидовПродукцииИС.ТоварныеГруппыГИСМТ"),
			ТоварнаяГруппа);
	Иначе
		Результат = Новый Массив;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Возвращает дату начала оформления УПД ОСУ для указанного вида продукции
//
// Параметры:
//  ВидПродукцииТоварнаяГруппа - СправочникСсылка.КлючиВидовПродукцииИС,
//                               СправочникСсылка.ВидыПродукцииИС,
//                               Массив из СправочникСсылка.ВидыПродукцииИС - Виды продукции,
//                               СправочникСсылка.ТоварныеГруппыГИСМТ - Товарная группа
//
// Возвращаемое значение:
//  Дата - дата начала оформления УПД ОСУ,
//  Неопределено - если дата не задана
//
Функция ДатаНачалаОформленияУПДОСУ(ВидПродукцииТоварнаяГруппа) Экспорт
	
	Результат = Неопределено;
	
	Даты = КонструкторИСОбщегоНазначенияКлиентСервер.ЗначенияЭлементаКонструктораПоВидуПродукции(
		ПредопределенноеЗначение(
			"Справочник.ЭлементыКонструктораВидовПродукцииИС.ДатыНачалаОформленияУПДОСУ"),
		ВидыПродукции(ВидПродукцииТоварнаяГруппа));
	
	Если Даты.Количество() > 0 Тогда
		Результат = Даты[0];
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Возвращает дату начала оформления УПД поштучно для указанного вида продукции
//
// Параметры:
//  ВидПродукцииТоварнаяГруппа - СправочникСсылка.КлючиВидовПродукцииИС,
//                               СправочникСсылка.ВидыПродукцииИС,
//                               Массив из СправочникСсылка.ВидыПродукцииИС - Виды продукции,
//                               СправочникСсылка.ТоварныеГруппыГИСМТ - Товарная группа
//
// Возвращаемое значение:
//  Дата - дата начала оформления УПД поштучно,
//  Неопределено - если дата не задана
//
Функция ДатаНачалаОформленияУПДПоштучно(ВидПродукцииТоварнаяГруппа) Экспорт
	
	Результат = Неопределено;
	
	Даты = КонструкторИСОбщегоНазначенияКлиентСервер.ЗначенияЭлементаКонструктораПоВидуПродукции(
		ПредопределенноеЗначение(
			"Справочник.ЭлементыКонструктораВидовПродукцииИС.ДатыНачалаОформленияУПДПоштучно"),
		ВидыПродукции(ВидПродукцииТоварнаяГруппа));
	
