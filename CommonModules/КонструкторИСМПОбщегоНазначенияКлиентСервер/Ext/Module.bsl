//
Функция ВидыПродукцииОбязательнойОнлайнПроверкиПередРозничнойПродажей() Экспорт
	
	Возврат ВидыПродукцииОбязательнойОнлайнПроверкиПередРозничнойПродажейНаДату('00010101');
	
КонецФункции

// Возвращает перечень маркируемой продукции, для которой обязательная онлайн проверка перед розничной продажей на конкретную дату.
// 
// Параметры:
//  НаДату - Дата - дата проверки
//  
// Возвращаемое значение:
//   Массив Из СправочникСсылка.ВидыПродукцииИС - список видов маркируемой продукции.
//
Функция ВидыПродукцииОбязательнойОнлайнПроверкиПередРозничнойПродажейНаДату(НаДату = Неопределено) Экспорт
	
	МассивПродукции = Новый Массив();
	
	Если НаДату = Неопределено Тогда
		#Если Сервер Или ВнешнееСоединение Или МобильноеПриложениеСервер Или МобильныйАвтономныйСервер Тогда
			НаДату = ТекущаяДатаСеанса();
		#Иначе
			НаДату = ОбщегоНазначенияКлиент.ДатаСеанса();
		#КонецЕсли
	КонецЕсли;
	
	ВидыПродукции = ОбщегоНазначенияИСМПКлиентСерверПовтИсп.УчитываемыеВидыМаркируемойПродукции();
	Для Каждого ВидПродукции Из ВидыПродукции Цикл
		ДатаНачалаРазрешительногоРежима = ДатаНачалаРазрешительногоРежима(ВидПродукции);
		Если ЗначениеЗаполнено(ДатаНачалаРазрешительногоРежима)
			И (ДатаНачалаРазрешительногоРежима <= НачалоДня(НаДату) Или НаДату = '00010101') Тогда
			МассивПродукции.Добавить(ВидПродукции);
		КонецЕсли;
	КонецЦикла;
	
	Возврат МассивПродукции;
	
КонецФункции

// Возвращает перечень маркируемой продукции, для которой обязательная офлайн проверка перед розничной продажей на конкретную дату.
