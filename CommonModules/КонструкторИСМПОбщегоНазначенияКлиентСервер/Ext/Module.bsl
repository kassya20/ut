// Признак использования объемно-сортового учета для вида продукции по виду операции.
// 
// Параметры:
//  ВидПродукцииТоварнаяГруппа - СправочникСсылка.ТоварныеГруппыГИСМТ - Товарная группа,
//                               СправочникСсылка.ВидыПродукцииИС - Вид продукции,
//                               СправочникСсылка.КлючиВидовПродукцииИС - ключ видов продукции,
//                               Массив из СправочникСсылка.ВидыПродукцииИС.
//  Операция - ПеречислениеСсылка.ВидыОперацийИСМП - Операция
//           - Массив из ПеречислениеСсылка.ВидыОперацийИСМП
// Возвращаемое значение:
//   Булево - Признак использования объемно-сортового учета для вида продукции.
//
Функция ПоддерживаетсяОбъемноСортовойУчет(ВидПродукцииТоварнаяГруппа, Операция) Экспорт
	
	ВидыПродукции = ВидыПродукции(ВидПродукцииТоварнаяГруппа);
	Возврат КонструкторИСОбщегоНазначенияКлиентСервер.ИспользуетсяВидУпаковки(
		ВидыПродукции,
		ПредопределенноеЗначение("Перечисление.ВидыУпаковокИС.ОбъемноСортовойУчет"))
		И КонструкторИСОбщегоНазначенияКлиентСервер.ЭлементКонструктораСодержитЗначение(
			ПредопределенноеЗначение("Справочник.ЭлементыКонструктораВидовПродукцииИС.ПоддерживаетсяОСУ"),
			ВидыПродукции,
