// Возвращает признак необходимости контроля статусов кодов маркировки
//
// Параметры:
//  ВидПродукцииТоварнаяГруппа - СправочникСсылка.КлючиВидовПродукцииИС,
//                               СправочникСсылка.ВидыПродукцииИС,
//                               Массив из СправочникСсылка.ВидыПродукцииИС - Виды продукции,
//                               СправочникСсылка.ТоварныеГруппыГИСМТ - Товарная группа.
//  Операция - ПеречислениеСсылка.ВидыОперацийИСМП, Неопределено - Вид операции
//Возвращаемое значение:
//  Булево - Истина, если по виду продукции и виду операции требуется контролировать статусы
Функция КонтролироватьСтатусыКодовМаркировки(ВидПродукцииТоварнаяГруппа, Операция = Неопределено) Экспорт
	
	ЭлементКонструктора = ПредопределенноеЗначение(
		"Справочник.ЭлементыКонструктораВидовПродукцииИС.КонтролироватьСтатусыКодовМаркировки");
	СвязанныйЭлемент = КонструкторИСОбщегоНазначенияКлиентСервер.ЗначениеАтрибутаЭлементаКонструктора(
		"СвязанныйЭлемент", ЭлементКонструктора, ВидПродукцииТоварнаяГруппа, Операция);
	
	Если ЗначениеЗаполнено(СвязанныйЭлемент) Тогда
		ДатыНачалаУчета = КонструкторИСОбщегоНазначенияКлиентСервер.ЗначенияЭлементаКонструктораПоВидуПродукции(
			СвязанныйЭлемент, ВидПродукцииТоварнаяГруппа);
		#Если Клиент Или ВебКлиент Или МобильноеПриложениеКлиент Или МобильныйКлиент Тогда
			ДатаСеанса = НачалоДня(ОбщегоНазначенияКлиент.ДатаСеанса());
		#Иначе
			ДатаСеанса = НачалоДня(ТекущаяДатаСеанса());
		#КонецЕсли
		Для Каждого ДатаНачалаУчета Из ДатыНачалаУчета Цикл
			Если ЗначениеЗаполнено(ДатаНачалаУчета) Тогда
				Если ДатаСеанса >= НачалоДня(ДатаНачалаУчета) Тогда
					Возврат Истина;
				КонецЕсли;
			КонецЕсли;
		КонецЦикла;
		
		ЗначенияЭлементаКонструктора = КонструкторИСОбщегоНазначенияКлиентСервер.ЗначенияЭлементаКонструктора(
			ЭлементКонструктора,
			ВидыПродукции(ВидПродукцииТоварнаяГруппа),
			Операция);
		
		Если ЗначенияЭлементаКонструктора.ЗначениеПользователя = Неопределено Тогда
			ВыключенДоДатыДействияСвязанногоЭлемента = КонструкторИСОбщегоНазначенияКлиентСервер.ЗначениеАтрибутаЭлементаКонструктора(
				"ВыключенДоДатыДействияСвязанногоЭлемента", ЭлементКонструктора, ВидПродукцииТоварнаяГруппа, Операция) = Истина;
			Если ВыключенДоДатыДействияСвязанногоЭлемента Тогда
				Возврат Ложь;
			Иначе
				Возврат Истина;
			КонецЕсли;
		Иначе
			Возврат ЗначенияЭлементаКонструктора.ЗначениеПользователя;
		КонецЕсли;
		
	Иначе
		
		Возврат ЭлементКонструктораСодержитЗначение(
			ЭлементКонструктора,
			ВидПродукцииТоварнаяГруппа,
			Операция);
		
	КонецЕсли;
	
КонецФункции

