Функция ЭлементКонструктораДляОпределенияДоступныхВидовПродукции(Объект = Неопределено) Экспорт
	
	Ссылка = Неопределено;
	ПолноеИмя = Неопределено;
	Если Объект <> Неопределено
		И ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(Объект, "Ссылка") Тогда
		Ссылка = Объект.Ссылка;
	ИначеЕсли Объект <> Неопределено
		И ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(Объект, "ПолноеИмя") Тогда
		ПолноеИмя = Объект.ПолноеИмя;
	КонецЕсли;
	
	#Если Сервер Или ВнешнееСоединение Или ТолстыйКлиентОбычноеПриложение Или ТолстыйКлиентУправляемоеПриложение Тогда
	Если ТипЗнч(Ссылка) = Тип("РегистрСведенийНаборЗаписей.ВскрытыеПотребительскиеУпаковкиИС") Тогда
		ПолноеИмя = "РегистрСведений.ВскрытыеПотребительскиеУпаковкиИС";
	КонецЕсли;
	#КонецЕсли
	
	Если ПолноеИмя = "РегистрСведений.ВскрытыеПотребительскиеУпаковкиИС" Тогда
		Результат = ПредопределенноеЗначение(
			"Справочник.ЭлементыКонструктораВидовПродукцииИС.ЧастичноеВыбытие");
	ИначеЕсли ПолноеИмя = "АгрегацияКодовМаркировкиИСМП" 
		Или (Объект <> Неопределено
			И ТипЗнч(Ссылка) = Тип("ДокументСсылка.МаркировкаТоваровИСМП")
			И ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(Объект, "Операция")
			И Объект.Операция = ПредопределенноеЗначение("Перечисление.ВидыОперацийИСМП.Агрегация")) Тогда
		Результат = Новый Массив;
		Результат.Добавить(
			ПредопределенноеЗначение(
				"Справочник.ЭлементыКонструктораВидовПродукцииИС.АгрегацияЧерезГИСМТ"));
		Результат.Добавить(
			ПредопределенноеЗначение(
				"Справочник.ЭлементыКонструктораВидовПродукцииИС.АгрегацияЧерезСУЗ"));
	ИначеЕсли ТипЗнч(Ссылка) = Тип("ДокументСсылка.ПодключениеКегаКОборудованиюРозливаИСМП") Тогда
		Результат = Новый Массив;
		Результат.Добавить(
			ПредопределенноеЗначение(
				"Справочник.ЭлементыКонструктораВидовПродукцииИС.ПоддерживаетсяПодключениеКОборудованиюРозлива"));
		Результат.Добавить(
			ПредопределенноеЗначение(
				"Справочник.ЭлементыКонструктораВидовПродукцииИС.ЧастичноеВыбытие"));
	КонецЕсли;
	
	Если Результат = Неопределено
		И ОбщегоНазначенияИСКлиентСерверПовтИсп.ЭтоРасширеннаяВерсияГосИС() Тогда
		#Если Клиент Или ТонкийКлиент Или ВебКлиент Или МобильноеПриложениеКлиент Или МобильныйКлиент Тогда
			МодульКонструкторИСМПКлиентСервер = ОбщегоНазначенияКлиент.ОбщийМодуль("КонструкторИСМПКлиентСервер");
		#Иначе
			МодульКонструкторИСМПКлиентСервер = ОбщегоНазначенияИСПовтИсп.ОбщийМодуль("КонструкторИСМПКлиентСервер");
		#КонецЕсли
		Результат = МодульКонструкторИСМПКлиентСервер.ЭлементКонструктораДляОпределенияДоступныхВидовПродукции(Объект);
	КонецЕсли;
	
	Если Результат = Неопределено Тогда
		Результат = ПредопределенноеЗначение(
			"Справочник.ЭлементыКонструктораВидовПродукцииИС.ВидыПродукцииГИСМТ");
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ДоступныеВидыПродукции(Объект = Неопределено) Экспорт
	
	ЭлементКонструктораДляОпределенияДоступныхВидовПродукции = ЭлементКонструктораДляОпределенияДоступныхВидовПродукции(Объект);
	
	Если ТипЗнч(ЭлементКонструктораДляОпределенияДоступныхВидовПродукции) = Тип("Массив") Тогда
		Результат = Новый Массив;
		Для Каждого ЭлементКонструктора Из ЭлементКонструктораДляОпределенияДоступныхВидовПродукции Цикл
			ОбщегоНазначенияКлиентСервер.ДополнитьМассив(
				Результат,
				КонструкторИСОбщегоНазначенияКлиентСервер.ВидыПродукцииПоЭлементуКонструктора(ЭлементКонструктора),
				Истина);
		КонецЦикла;
	Иначе
		Результат = КонструкторИСОбщегоНазначенияКлиентСервер.ВидыПродукцииПоЭлементуКонструктора(
			ЭлементКонструктораДляОпределенияДоступныхВидовПродукции);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

