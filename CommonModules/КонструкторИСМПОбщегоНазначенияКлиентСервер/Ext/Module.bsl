// Функция возвращает описание структуры разделенных дат контроля маркируемой продукции
// 	по выбранному или по всем видам маркируемой продукции
// Параметры:
//  ВидМаркируемойПродукции - СправочникСсылка.ВидыПродукцииИС,
//  						  Массив из СправочникСсылка.ВидыПродукцииИС - Виды продукции,
// 
// Возвращаемое значение:
//  Массив Из см. ОбщегоНазначенияИСМПКлиентСервер.ИнициализироватьНастройкуДатРаздельногоКонтроля
Функция ДанныеДатРаздельногоКонтроля(ВидМаркируемойПродукции = Неопределено) Экспорт
	
	МассивНастроек = Новый Массив;
	ВидыПродукции  = Новый Массив;
	
	Если ВидМаркируемойПродукции = Неопределено Тогда
		ВидыПродукции = КонструкторИСОбщегоНазначенияКлиентСервер.ВидыПродукцииИСМП(Истина);
	ИначеЕсли ТипЗнч(ВидМаркируемойПродукции) = Тип("Массив") Тогда
		ВидыПродукции = ВидМаркируемойПродукции;	
	Иначе
		ВидыПродукции.Добавить(ВидМаркируемойПродукции);
	КонецЕсли;
	
	Для Каждого ВидПродукции Из ВидыПродукции Цикл
		
		СтруктураДат = ОбщегоНазначенияИСМПКлиентСервер.ИнициализироватьНастройкуДатРаздельногоКонтроля();
		
		СтруктураДат.ВидПродукции                             = ВидПродукции;
		СтруктураДат.ДатаКонтрольПроизводства                 = ДатаНачалаПроизводства(ВидПродукции);
		СтруктураДат.ДатаКонтрольВыводИзОборота               = ДатаНачалаВыводаИзОборота(ВидПродукции);
		СтруктураДат.ДатаЗапретПродажиНемаркированныхОстатков = ДатаНачалаЗапретаПродажБезМарок(ВидПродукции);
		СтруктураДат.ДатаОптКонтрольОСУ                       = ДатаНачалаОформленияУПДОСУ(ВидПродукции);
		СтруктураДат.ДатаОптКонтрольПоштучно                  = ДатаНачалаОформленияУПДПоштучно(ВидПродукции);
		СтруктураДат.ДатаРозницаЛокальныйРазрешительныйРежим  = ДатаНачалаИспользованияЛокальногоМодуля(ВидПродукции);
		СтруктураДат.ДатаРозницаУведомительныйРежим           = ДатаНачалаРозничныхПродаж(ВидПродукции);
		СтруктураДат.ДатаРозницаРазрешительныйРежим           = ДатаНачалаРазрешительногоРежима(ВидПродукции);
		СтруктураДат.ДатаПрослеживаемостьПеремещенияМеждуМОД  = ДатаНачалаПрослеживаемостиПеремещенияМеждуМОД(ВидПродукции);
		СтруктураДат.ДатаКонтроляРазрешительныхДокументов     = ДатаНачалаКонтроляРазрешительныхДокументов(ВидПродукции);
		
		МассивНастроек.Добавить(СтруктураДат);
		
	КонецЦикла;
	
	Возврат МассивНастроек;
	
КонецФункции

// Функция возвращает описание структуры разделенных дат контроля маркируемой продукции
// 	по выбранному виду маркируемой продукции
// Параметры:
//  ВидМаркируемойПродукции - СправочникСсылка.ВидыПродукцииИС,
//  						  Массив из СправочникСсылка.ВидыПродукцииИС - Виды продукции,
// 
// Возвращаемое значение:
//  см. ОбщегоНазначенияИСМПКлиентСервер.ИнициализироватьНастройкуДатРаздельногоКонтроля
Функция ДатыРаздельногоКонтроляМаркируемойПродукции(ВидМаркируемойПродукции) Экспорт
	
	ДанныеНастроек = ДанныеДатРаздельногоКонтроля(ВидМаркируемойПродукции);
	
	Если ДанныеНастроек.Количество() Тогда
		СтруктураДат = ДанныеНастроек[0];
	Иначе
		СтруктураДат = ОбщегоНазначенияИСМПКлиентСервер.ИнициализироватьНастройкуДатРаздельногоКонтроля();
	КонецЕсли;
	
	Возврат СтруктураДат;
	
КонецФункции

