// Представление частичного выбытия по виду продукции.
// 
// Параметры:
//  ВидПродукции - СправочникСсылка.КлючиВидовПродукцииИС - Вид продукции
//  Падеж - Строка - Падеж для склонения строки (Именительный, Родительный, Винительный)
// Возвращаемое значение:
//  Строка - Представление частичного выбытия по виду продукции
Функция ПредставлениеПродажаЧастичногоВыбытияПоВидуПродукции(ВидПродукции, Падеж = "Именительный") Экспорт
	
	ИмяАтрибута = "ПродажаЧастичноеВыбытие" + Падеж;
	
	Результат = КонструкторИСОбщегоНазначенияКлиентСервер.ЗначениеАтрибутаЭлементаКонструктора(
		ИмяАтрибута,
		ПредопределенноеЗначение(
			"Справочник.ЭлементыКонструктораВидовПродукцииИС.НастройкаПредставлений"),
		ВидПродукции);
		
	Если Не ЗначениеЗаполнено(Результат) Тогда
		Если Падеж = "Родительный" Тогда
			Результат = НСтр("ru = 'продажи части продукции из вскрытой маркируемой потребительской упаковки'");
		ИначеЕсли Падеж = "Винительный" Тогда
			Результат = НСтр("ru = 'продажу части продукции из вскрытой маркируемой потребительской упаковки'");
		Иначе
			Результат = НСтр("ru = 'продажа части продукции из вскрытой маркируемой потребительской упаковки'");
		КонецЕсли;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

