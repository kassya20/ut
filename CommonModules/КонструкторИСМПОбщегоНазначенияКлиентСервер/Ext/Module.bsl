// Функция возвращает признак действия контроля разрешительных документов при обороте марок на указаннную дату
// Возможность оборота регулируется настройкой даты в рабочем месте Интеграция ИС МП (обувь, одежда, табак...)
//  и текущим законодательством.
// 
// Параметры:
//  ВидПродукции - СправочникСсылка.ВидыПродукцииИС - вид маркируемой продукции
//  НаДату       - Неопределено, Дата                 - дата контроля
// 
// Возвращаемое значение:
//  Булево - Истина, если контроль уже вступил в силу
Функция ДействуетКонтрольРазрешительныхДокументов(ВидПродукции, НаДату = Неопределено) Экспорт
	
	Если Не ЗначениеЗаполнено(НаДату) Тогда
		#Если Клиент Или ВебКлиент Или МобильноеПриложениеКлиент Или МобильныйКлиент Тогда
			НаДату = НачалоДня(ОбщегоНазначенияКлиент.ДатаСеанса());
		#Иначе
			НаДату = НачалоДня(ТекущаяДатаСеанса());
		#КонецЕсли
	КонецЕсли;
	
	СтруктураДатКонтроля = ДатыРаздельногоКонтроляМаркируемойПродукции(ВидПродукции);
	ДействуетКонтрольРД  = Ложь;
	
	Если ЗначениеЗаполнено(СтруктураДатКонтроля.ДатаКонтроляРазрешительныхДокументов)
		И СтруктураДатКонтроля.ДатаКонтроляРазрешительныхДокументов <= НаДату Тогда
		ДействуетКонтрольРД = Истина;
	КонецЕсли;
	
	Возврат ДействуетКонтрольРД;
	
КонецФункции

// Возвращает признак необходимости игнорирования проверки кодов маркировки на ККТ
