// Подсистема "ИнтернетПоддержкаПользователей.ПлатежныеСистемы".
// ОбщийМодуль.ПлатежныеСистемыСлужебный.
//
// Серверные процедуры обмена данными с платежной системой:
//  - инициализация параметров подключения;
//  - настройка форм подключения к платежной системе;
//  - работа с настройками оплаты;
//  - обработка прикладных операций;
//  - обработка служебных операций;
//  - обработка регламентных заданий.
//
///////////////////////////////////////////////////////////////////////////////////////////////////////

#Область СлужебныйПрограммныйИнтерфейс

#Область ИнтеграцияСБиблиотекойСтандартныхПодсистем

// См. СтандартныеПодсистемыСервер.ПриОпределенииМетодовРазрешенныхДляВызоваКакПроизвольныйКод
//
Процедура ПриОпределенииМетодовРазрешенныхДляВызоваКакПроизвольныйКод(Методы) Экспорт
	
	Методы.Вставить("ПодсказкиПлатежнойСистемы", Истина);
	Методы.Вставить("ПроверитьПараметрыПодключения", Истина);
	Методы.Вставить("ПроверитьПараметрыПодключенияНового", Истина);
	
КонецПроцедуры

#КонецОбласти

#Область ОбщегоНазначения

// Создает описание результат операции.
//
// Возвращаемое значение:
//  Структура:
//    * КодОшибки - Строка - строковый код возникшей ошибки, который может быть обработан вызывающим методом.
//    * СообщениеОбОшибке - Строка, ФорматированнаяСтрока - сообщение об ошибке для пользователя.
//    * ИнформацияОбОшибке - Строка, ФорматированнаяСтрока - сообщение об ошибке для администратора.
//
Функция НовыйРезультатОперации() Экспорт
	
	Результат = Новый Структура();
	Результат.Вставить("КодОшибки", "");
	Результат.Вставить("СообщениеОбОшибке", "");
	Результат.Вставить("ИнформацияОбОшибке", "");
	
	Возврат Результат;
	
КонецФункции

// Создает описание результата операции СтатусОперации.
//
// Возвращаемое значение:
//  Структура:
//    * КодОшибки - Строка - строковый код возникшей ошибки, который может быть обработан вызывающим методом.
//    * СообщениеОбОшибке  - Строка, ФорматированнаяСтрока - сообщение об ошибке для пользователя.
//    * ИнформацияОбОшибке - Строка, ФорматированнаяСтрока - сообщение об ошибке для администратора.
//    * СтатусОперации - Строка - текущее состояние операции в платежной системе.
//    * ПараметрыОперации - см. НовыйПараметрыОперации
//
Функция НовыйРезультатСтатусОперации() Экспорт
	
	ПараметрыОперации = НовыйПараметрыОперации();
	
	Результат = НовыйРезультатОперации();
	Результат.Вставить("СтатусОперации", "");
	Результат.Вставить("ПараметрыОперации", ПараметрыОперации);
	
	Возврат Результат;
	
КонецФункции

// Создает описание служебного результата операции СтатусОперации.
//
// Возвращаемое значение:
//  Структура - результат операции:
//    * КодОшибки - Строка - строковый код возникшей ошибки, который может быть обработан вызывающим методом.
//    * СообщениеОбОшибке  - Строка, ФорматированнаяСтрока - сообщение об ошибке для пользователя.
//    * ИнформацияОбОшибке - Строка, ФорматированнаяСтрока - сообщение об ошибке для администратора.
//    * СтатусОперации - Строка - текущее состояние операции в платежной системе.
//    * ПараметрыОперации - см. НовыйПараметрыОперации
//    * ОбновитьДатуЗапросаСтатуса - Булево - Истина, если необходимо обновить дату запроса статуса в базе данных.
//        Значение по умолчанию: Ложь.
//
Функция НовыйРезультатСтатусОперацииСлужебный() Экспорт
	
	Результат = НовыйРезультатСтатусОперации();
	Результат.Вставить("ОбновитьДатуЗапросаСтатуса", Ложь);
	
	Возврат Результат;
	
КонецФункции

// Формирует декларативное описание реквизита формы.
//
// Параметры:
//  Имя - Строка - имя реквизита.
//  Синоним - Строка - синоним реквизита.
//  Тип - ОписаниеТипов - тип реквизита.
//
// Возвращаемое значение:
//  Структура:
//    * Имя - Строка - имя реквизита.
//    * Синоним - Строка - синоним реквизита.
//    * Тип - ОписаниеТипов - тип реквизита.
//    * РежимПароля - Булево - признак использования режима пароля.
//    * Подсказка - Строка - текст всплывающей подсказки.
//    * ПроверкаЗаполнения - Булево - режим проверки заполнения.
//    * СвязиПараметровВыбора - ФиксированныйМассив из СвязьПараметраВыбора - связи параметров выбора значений.
//    * ПараметрыВыбора - ФиксированныйМассив из ПараметрВыбора - параметры выбора значений.
//    * НастройкаПодключения - Булево - Истина, если реквизит хранит настройку подключения.
//
Функция НовыйОписаниеРеквизитов(Имя, Синоним, Тип) Экспорт
	
	ПустойМассив = Новый Массив();
	
	Результат = Новый Структура();
	Результат.Вставить("Имя", Имя);
	Результат.Вставить("Синоним", Синоним);
	Результат.Вставить("Тип", Тип);
	Результат.Вставить("РежимПароля", Ложь);
	Результат.Вставить("Подсказка", "");
	Результат.Вставить("ПроверкаЗаполнения", Ложь);
	Результат.Вставить("СвязиПараметровВыбора", Новый ФиксированныйМассив(ПустойМассив));
	Результат.Вставить("ПараметрыВыбора", Новый ФиксированныйМассив(ПустойМассив));
	
	Результат.Вставить(
		"НастройкаПодключения",
		Тип.СодержитТип(
			Тип("СправочникСсылка.НастройкиПодключенияКПлатежнымСистемам")));
	
	Возврат Результат;
	
КонецФункции

// Проверяет, является ли переданное значение ссылкой на справочник с настройками подключения
//  к платежным системам.
//
// Параметры:
//  НастройкаПодключения - Произвольный - значение, которое необходимо проверить.
//
// Возвращаемое значение:
//  Булево - Истина, если переданное значение является ссылкой на справочник 
//   НастройкиПодключенияКПлатежнымСистемам.
//
Функция ЭтоНастройкаПодключения(НастройкаПодключения) Экспорт
	
	Возврат ТипЗнч(НастройкаПодключения) = Тип("СправочникСсылка.НастройкиПодключенияКПлатежнымСистемам");
	
КонецФункции

// Возвращает идентификатор платежного сервиса по перечислению
//
// Параметры:
//  ПлатежныйСервис - ПеречислениеСсылка.ПлатежныеСервисы - значение перечисления.
//
// Возвращаемое значение:
//  Строка - Строковый идентификатор платежной системы.
//
Функция ИдентификаторПлатежногоСервиса(ПлатежныйСервис) Экспорт
	
	Если ПлатежныйСервис = ПредопределенноеЗначение("Перечисление.ПлатежныеСервисы.ОзонПэй") Тогда
		Возврат НастройкиПлатежныхСистемКлиентСервер.ИмяПодсистемыОзонПэй();
	Иначе
		Возврат "";
	КонецЕсли;
	
КонецФункции

#КонецОбласти

#Область ПрикладныеОперации

// См. ПлатежныеСистемы.ВозвратОплаты
//
Функция ВозвратОплаты(ДокументВозврата, ДокументОплаты, НастройкаПодключения, ДополнительныеПараметры) Экспорт
	
	ПроверитьПраваНаВыполнениеОперации();
	
	Результат = НовыйРезультатСтатусОперации();
	
	ПараметрыНастройкиПодключения = Справочники.НастройкиПодключенияКПлатежнымСистемам.ПараметрыНастройкиПодключения(
		НастройкаПодключения);
	
	РезультатПроверки = ПроверитьОбщиеПараметрыОперации(
		ДокументВозврата,
		НастройкаПодключения,
		ПараметрыНастройкиПодключения);
	Если Не ПустаяСтрока(РезультатПроверки.КодОшибки) Тогда
		ЗаполнитьЗначенияСвойств(
			Результат,
			РезультатПроверки,
			"КодОшибки,СообщениеОбОшибке,ИнформацияОбОшибке");
		Возврат Результат;
	КонецЕсли;
	
	ПлатежныеСистемыСобытия.ПриСозданииВозвратаОплаты(
		ДокументВозврата,
		ДокументОплаты,
		ПараметрыНастройкиПодключения,
		ДополнительныеПараметры,
		Результат);
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти

#Область СтатусОперации

// Выполняет получение статуса операции в платежной системе.
// Если терминальный статус операции был загружен ранее, то метод вернет информацию из базы данных, в противном случае
// будет выполнен запрос к сервису платежной системы.
//
// Параметры:
//  ДокументОперации - ОпределяемыйТип.ДокументОперацииПлатежнойСистемы - документ, который отражает операцию в
//    информационной базе.
//  ВремяОжидания - Число - время ожидания терминального статуса в секундах.
//    Если параметр заполнен, то получение статуса будет выполняться в цикле с небольшими задержками между запросами.
//    Значение по умолчанию: 0 (один запрос).
//  ЗапросНаличияСтатуса - Булево - если Истина, будет выполнен запрос наличия статуса.
//
// Возвращаемое значение:
//  см. НовыйРезультатСтатусОперации
//
Функция СтатусОперации(ДокументОперации, ВремяОжидания, ЗапросНаличияСтатуса = Истина) Экспорт
	
	ПроверитьПраваНаВыполнениеОперации();
	
	Результат = НовыйРезультатСтатусОперации();
	СписокСвойствОшибки = "КодОшибки,СообщениеОбОшибке,ИнформацияОбОшибке";
	
	// Чтение сохраненных данных под документу операции
	ПараметрыСтатуса = ПараметрыОпределенияСтатусаОперации(ДокументОперации);
	Если ПараметрыСтатуса = Неопределено Тогда
		ВызватьИсключение СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
			НСтр("ru = 'Данные операции платежной системы по документу %1 не найдены. Обратитесь к администратору.'"),
			Строка(ДокументОперации));
	ИначеЕсли ПустаяСтрока(ПараметрыСтатуса.ИдентификаторОплаты) Тогда
		ВызватьИсключение СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
			НСтр("ru = 'По документу %1 отсутствует информация о выполнении операции в платежной системе.
				|Необходимо повторно выполнить операцию.'"),
			Строка(ДокументОперации));
	КонецЕсли;
	
	// Если ранее был получен терминальный статус, то вернем его
	Если ТерминальныйСтатус(ПараметрыСтатуса.СтатусОперации) Тогда
		
		Результат.СтатусОперации = ПараметрыСтатуса.СтатусОперации;
		ЗаполнитьЗначенияСвойств(
			Результат.ПараметрыОперации,
			ПараметрыСтатуса,
			"ИдентификаторОперации,ИдентификаторОплаты,ДатаОперации,СуммаОперации");
		Результат.ПараметрыОперации.ТипОперации = ?(ПараметрыСтатуса.Оплата,
			ПлатежныеСистемыКлиентСервер.ТипОперацииОплата(),
			ПлатежныеСистемыКлиентСервер.ТипОперацииВозврат());
		
		Возврат Результат;
		
	КонецЕсли;
	
	// Подготовка параметров настройки подключения
	ПараметрыНастройкиПодключения = Справочники.НастройкиПодключенияКПлатежнымСистемам.ПараметрыНастройкиПодключения(
		ПараметрыСтатуса.НастройкаПодключения);
	
	// Проверка общих параметров подключения
	РезультатПроверки = ПроверитьОбщиеПараметрыОперации(
		ДокументОперации,
		ПараметрыСтатуса.НастройкаПодключения,
		ПараметрыНастройкиПодключения);
	Если Не ПустаяСтрока(РезультатПроверки.КодОшибки) Тогда
		ЗаполнитьЗначенияСвойств(Результат, РезультатПроверки, СписокСвойствОшибки);
		Результат.СтатусОперации = НастройкиПлатежныхСистемКлиентСервер.СтатусОперацииОшибка();
		Возврат Результат;
	КонецЕсли;
	
	ПараметрыВызова  = НастройкиПлатежныхСистемСлужебный.НовыйИтеративныйВызовОперации(ВремяОжидания);
	ПоследняяПопытка = (ПараметрыСтатуса.Оплата
		И ПараметрыСтатуса.ДатаДействияСсылки <> Дата(1, 1, 1)
		И (ПараметрыСтатуса.ДатаДействияСсылки + 600) < ТекущаяУниверсальнаяДата());
	Если ПоследняяПопытка Тогда
		// При окончании срока действия платежной ссылки, выполняется проверка статуса операции и регистрация отмены
		// динамической ссылки в ИБ, если операция так и не была завершена.
		ПараметрыВызова.МаксимальноеКоличествоЗапросов = 1;
	КонецЕсли;
	
	ВыполненВызов = Ложь;
	
	Пока НастройкиПлатежныхСистемСлужебный.ВозможенВызовОперации(ПараметрыВызова) Цикл
		
		РезультатПроверки = НовыйРезультатСтатусОперацииСлужебный();
		ПлатежныеСистемыСобытия.ПриПолученииСтатусаОперации(
			ПараметрыСтатуса,
			ПараметрыНастройкиПодключения,
			ЗапросНаличияСтатуса,
			РезультатПроверки);
		
		ВыполненВызов = Истина;
		
		Если Не ПустаяСтрока(РезультатПроверки.КодОшибки) Тогда
			ЗаполнитьЗначенияСвойств(Результат, РезультатПроверки, СписокСвойствОшибки);
			Результат.СтатусОперации = НастройкиПлатежныхСистемКлиентСервер.СтатусОперацииОшибка();
			Возврат Результат;
		КонецЕсли;
		
		Если РезультатПроверки.ОбновитьДатуЗапросаСтатуса Тогда
			ПараметрыСтатуса.ДатаЗапросаСтатуса = ТекущаяУниверсальнаяДата();
		КонецЕсли;
		
		Если ТерминальныйСтатус(РезультатПроверки.СтатусОперации) Тогда
			Прервать;
		КонецЕсли;
		
	КонецЦикла;
	
	Если Не ВыполненВызов Тогда
		Результат.КодОшибки = НастройкиПлатежныхСистемСлужебный.КодОшибкиНеизвестнаяОшибка();
		Результат.СообщениеОбОшибке = НСтр(
			"ru = 'Не удалось получить статус операции за отведенное время. Повторите попытку.'");
		Результат.ИнформацияОбОшибке = НСтр(
			"ru = 'Не удалось получить статус операции за отведенное время. Повторите попытку.'");
		Возврат Результат;
	КонецЕсли;
	
	ЗаполнитьЗначенияСвойств(Результат, РезультатПроверки);
	
	Если ПоследняяПопытка
		И Результат.СтатусОперации = НастройкиПлатежныхСистемКлиентСервер.СтатусОперацииВыполняется() Тогда
		
		Результат.СтатусОперации = НастройкиПлатежныхСистемКлиентСервер.СтатусОперацииОтменена();
		
	КонецЕсли;
	
	ДанныеОперации = НовыйОбновляемыеДанныеОперации();
	ДанныеОперации.СтатусОперации = Результат.СтатусОперации;
	ДанныеОперации.ИдентификаторОперации = Результат.ПараметрыОперации.ИдентификаторОперации;
	ДанныеОперации.ДатаОперации = Результат.ПараметрыОперации.ДатаОперации;
	ДанныеОперации.СуммаОперации = Результат.ПараметрыОперации.СуммаОперации;
	Если РезультатПроверки.ОбновитьДатуЗапросаСтатуса Тогда
		ДанныеОперации.ДатаЗапросаСтатуса = ПараметрыСтатуса.ДатаЗапросаСтатуса;
	КонецЕсли;
	
	РегистрыСведений.ИдентификаторыПлатежныхСистем.ЗаписатьДанныеОперации(ДокументОперации, ДанныеОперации);
	
	Возврат Результат;
	
КонецФункции

// Получает данные для определения статуса выполнения операции в платежной системе.
//
// Параметры:
//  ДокументОперации - ОпределяемыйТип.ДокументОперацииПлатежнойСистемы - документ отражающий операцию в информационной
//    базе.
//
// Возвращаемое значение:
//  Неопределено - данные операции не найдены.
//  Структура:
//    * Идентификатор - Строка - внутренний идентификатор операции.
//    * ИдентификаторОперации - Строка -идентификатор операции в платежной системе.
//    * ИдентификаторОплаты - Строка - идентификатор оплаты в платежной системе.
//    * Оплата - Булево - Истина, если тип операции "Оплата", Ложь - "Возврат".
//    * СтатусОперации - Строка - статус операции в платежной системе.
//    * ДатаДействияСсылки - Дата - дата действия платежной ссылки в UTC.
//    * НастройкаПодключения - СправочникСсылка.НастройкиПодключенияКПлатежнымСистемам - настройка подключения к
//        сервису.
//    * ДатаЗапросаСтатуса - Дата - дата последней операции получения статуса в UTC.
//
Функция ПараметрыОпределенияСтатусаОперации(ДокументОперации) Экспорт
	
	ПараметрыСтатуса = РегистрыСведений.ИдентификаторыПлатежныхСистем.ПараметрыОпределенияСтатусаОперации(
		ДокументОперации);
	
	Если ПараметрыСтатуса = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Результат = Новый Структура();
	Результат.Вставить("Идентификатор", ПараметрыСтатуса.Идентификатор);
	Результат.Вставить("ИдентификаторОперации", ПараметрыСтатуса.ИдентификаторОперации);
	Результат.Вставить("ИдентификаторОплаты", ПараметрыСтатуса.ИдентификаторОплаты);
	Результат.Вставить("Оплата", ПараметрыСтатуса.Оплата);
	Результат.Вставить("СтатусОперации", ПараметрыСтатуса.СтатусОперации);
	Результат.Вставить("ДатаОперации", ПараметрыСтатуса.ДатаОперации);
	Результат.Вставить("СуммаОперации", ПараметрыСтатуса.СуммаОперации);
	Результат.Вставить("ДатаДействияСсылки", ПараметрыСтатуса.ДатаДействияСсылки);
	Результат.Вставить("НастройкаПодключения", ПараметрыСтатуса.НастройкаПодключения);
	Результат.Вставить("ДатаЗапросаСтатуса", ПараметрыСтатуса.ДатаЗапросаСтатуса);
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти

#Область ДанныеОперации

// Формирует данные операции по документу.
//
// Параметры:
//  ДокументОперации - ОпределяемыйТип.ДокументОперацииПлатежнойСистемы - документ, который отражает операцию в
//    информационной базе.
//
// Возвращаемое значение:
//  ВыборкаИзРезультатаЗапроса:
//    * ИдентификаторОперации - Строка - идентификатор операции в платежной системе.
//    * ИдентификаторОплаты - Строка - идентификатор оплаты в платежной системе.
//    * СтатусОперации - Строка - текущее состояние операции.
//    * ДатаОперации - Дата - фактическая дата операции в UTC.
//    * СуммаОперации - Число - фактическая сумма операции по документу.
//    * НастройкаПодключения - СправочникСсылка.НастройкиПодключенияКПлатежнымСистемам - настройка подключения к
//        сервису.
//    * ПлатежнаяСсылка - Строка - адрес страницы по которой выполняется оплата.
//    * ДатаДействияСсылки - Дата - дата действия платежной ссылки в UTC.
//
Функция ДанныеОперации(ДокументОперации) Экспорт
	
	ДанныеОперации = РегистрыСведений.ИдентификаторыПлатежныхСистем.ДанныеОперации(ДокументОперации);
	Если ДанныеОперации = Неопределено Тогда
		ВызватьИсключение СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
			НСтр("ru = 'Данные операции платежной системы по документу %1 не найдены. Обратитесь к администратору.'"),
			Строка(ДокументОперации));
	КонецЕсли;
	
	Возврат ДанныеОперации;
	
КонецФункции

// Формирует данные операций по документам. В результат попадает информация только о найденных документах.
//
// Параметры:
//  ДокументыОпераций - ОпределяемыйТип.ДокументОперацииПлатежнойСистемы,
//    Массив Из ОпределяемыйТип.ДокументОперацииПлатежнойСистемы - документ или массив документов, отражающие
//    операцию в информационной базе.
//
// Возвращаемое значение:
//  РезультатЗапроса - данные операций, содержащие следующие поля:
//    * ДокументыОпераций - ОпределяемыйТип.ДокументОперацииПлатежнойСистемы - документ, отражающий
//        операцию в информационной базе.
//    * Идентификатор - Строка - внутренний идентификатор операции.
//    * ИдентификаторОплаты - Строка - идентификатор оплаты в платежной системе.
//    * ИдентификаторОперации - Строка - идентификатор операции в платежной системе.
//    * СтатусОперации - Строка - статус операции в платежной системе.
//    * ДатаОперации - Дата - фактическая дата операции в UTC.
//    * СуммаОперации - Число - фактическая сумма операции.
//    * НастройкаПодключения - СправочникСсылка.НастройкиПодключенияКПлатежнымСистемам - настройка подключения к
//        сервису.
//    * ПлатежнаяСсылка - Строка - адрес страницы по которой выполняется оплата.
//    * ДатаДействияСсылки - Дата - дата действия платежной ссылки в UTC.
//    * СпособОплаты - Строка - способ оплаты. Доступные значения определяются методами
//        общего модуля ПлатежныеСистемыКлиентСервер.
//
Функция ДанныеОпераций(ДокументыОпераций) Экспорт
	
	Возврат РегистрыСведений.ИдентификаторыПлатежныхСистем.ДанныеОпераций(ДокументыОпераций);
	
КонецФункции

// Формирует описание обновляемых данных регистра сведений ИдентификаторыПлатежныхСистем.
// Изначально все ключи имеют тип Неопределено. Если при вызове метода см. ЗаписатьДанныеОперации ключ будет с типом
// Неопределено, то обновление данных этого ключа выполняться не будет.
//
// Возвращаемое значение:
//  Структура:
//    * ИдентификаторОплаты - Неопределено, Строка - идентификатор оплаты в платежной системе.
//    * ИдентификаторОперации - Неопределено, Строка - идентификатор операции в платежной системе.
//    * СтатусОперации - Неопределено, Строка - статус операции.
//    * ДатаОперации - Неопределено, Дата - фактическая дата операции в UTC.
//    * СуммаОперации - Неопределено, Число - фактическая сумма операции.
//    * ПлатежнаяСсылка - Неопределено, Строка - адрес страницы по которой выполняется оплата.
//    * ДатаДействияСсылки - Неопределено, Дата - дата действия платежной ссылки в UTC.
//    * ДатаЗапросаСтатуса - Неопределено, Дата - дата последней операции получения статуса.
//    * СпособОплаты - Неопределено, Строка - способ оплаты. Доступные значения определяются методами
//        общего модуля ПлатежныеСистемыКлиентСервер.
//
Функция НовыйОбновляемыеДанныеОперации() Экспорт
	
	Результат = Новый Структура();
	Результат.Вставить("ИдентификаторОплаты", Неопределено);
	Результат.Вставить("ИдентификаторОперации", Неопределено);
	Результат.Вставить("СтатусОперации", Неопределено);
	Результат.Вставить("ДатаОперации", Неопределено);
	Результат.Вставить("СуммаОперации", Неопределено);
	Результат.Вставить("ПлатежнаяСсылка", Неопределено);
	Результат.Вставить("ДатаДействияСсылки", Неопределено);
	Результат.Вставить("ДатаЗапросаСтатуса", Неопределено);
	Результат.Вставить("СпособОплаты", Неопределено);
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти

#Область ЖурналРегистрации

// Добавляет запись в журнал регистрации с указанием имени события подсистемы платежных систем.
//
// Параметры:
//  Сообщение - Строка - комментарий к записи журнала регистрации.
//  Ошибка - Булево - если Истина, то будет установлен уровень журнала регистрации "Ошибка".
//    Значение по умолчанию: Ложь.
//
Процедура ЗаписатьИнформациюВЖурналРегистрации(Сообщение, Ошибка = Ложь) Экспорт
	
	УровеньЖурнала = ?(
		Ошибка,
		УровеньЖурналаРегистрации.Ошибка,
		УровеньЖурналаРегистрации.Информация);	// УровеньЖурналаРегистрации
	
	ЗаписьЖурналаРегистрации(
		ПлатежныеСистемыКлиентСервер.ИмяСобытияЖурналаРегистрации(
			ОбщегоНазначения.КодОсновногоЯзыка()),
		УровеньЖурнала,
		,
		,
		Лев(Сообщение, 5120));
	
КонецПроцедуры

#КонецОбласти

#Область ИнтеграцияПодсистемИнтернетПоддержкиПользователей

#Область ОбщиеНастройкиПлатежныхСистем

// Формирует дерево для формы общих настроек платежных систем
// 
// Параметры:
//  Дерево - ДеревоЗначений - дерево, которое необходимо заполнить.
//    см. НастройкиПлатежныхСистемСлужебный.НовыйДеревоНастроек.
//  ПараметрыДерева - Структура - параметры вывода дерева.
//    см. НастройкиПлатежныхСистемСлужебный.НовыйПараметрыДерева.
//  ИмяПодсистемы - Строка - Имя подсистемы, которую нужно вывести.
//
Процедура ПриФормированииДереваПоПодсистеме(
		Дерево,
		ПараметрыДерева,
		ИмяПодсистемы) Экспорт
	
	ОписаниеПодсистемы = НастройкиПлатежныхСистемПовтИсп.ОписаниеПлатежныхСервисов().Получить(ИмяПодсистемы);
	Если ОписаниеПодсистемы = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Настройки.Ссылка КАК Ссылка,
	|	0 КАК Картинка,
	|	ВЫБОР
	|		КОГДА НЕ Настройки.Используется
	|			ТОГДА ""НеИспользуется""
	|		ИНАЧЕ """"
	|	КОНЕЦ КАК ИдентификаторУсловногоОформления,
	|	ЛОЖЬ КАК ЭтоГруппа
	|ИЗ
	|	Справочник.НастройкиПодключенияКПлатежнымСистемам КАК Настройки
	|ГДЕ
	|	НЕ Настройки.ПометкаУдаления
	|	И &Отбор
	|
	|УПОРЯДОЧИТЬ ПО
	|	Настройки.Наименование";
	
	Отбор = Новый Массив;
		
	Отбор.Добавить("Настройки.ПлатежнаяСистема = &ПлатежнаяСистема");
	Запрос.УстановитьПараметр("ПлатежнаяСистема", ОписаниеПодсистемы.ПлатежныйСервис);
	
	ОбрабатываемыеПараметры = Новый Структура;
	ОбрабатываемыеПараметры.Вставить("Отбор", Неопределено);
	
	Если ТипЗнч(ПараметрыДерева.ПараметрыПодсистемы) = Тип("Структура")
		Или ТипЗнч(ПараметрыДерева.ПараметрыПодсистемы) = Тип("ФиксированнаяСтруктура") Тогда
		ЗаполнитьЗначенияСвойств(ОбрабатываемыеПараметры, ПараметрыДерева.ПараметрыПодсистемы);
	КонецЕсли;
	
	// Произвольные отборы
	НастройкиПлатежныхСистемСлужебный.ДополнитьЗапросСтандартнымОтбором(
		Отбор,
		ОбрабатываемыеПараметры.Отбор,
		Запрос);
	
	Если Отбор.Количество() = 0 Тогда
		ТекстЗамены = "ИСТИНА";
	Иначе
		ТекстЗамены = СтрСоединить(Отбор, " И ");
	КонецЕсли;
	
	Запрос.Текст = СтрЗаменить(
		Запрос.Текст,
		"&Отбор",
		ТекстЗамены);

	НастройкиПлатежныхСистемСлужебный.ЗапросВДерево(Запрос, Дерево);
	
	ПараметрыДерева.ВыводитьПодсистему = Истина;
	
	// Условное оформление
	УсловноеОформление = НастройкиПлатежныхСистемСлужебный.НовыйНастройкиУсловногоОформления();
	
	Оформление = НастройкиПлатежныхСистемСлужебный.НовыйПараметрыОформления();
	Оформление.ИмяПараметра = "ЦветТекста";
	Оформление.ЗначениеПараметра = ЦветаСтиля.ТекстЗапрещеннойЯчейкиЦвет;

	Условие = НастройкиПлатежныхСистемСлужебный.НовыйУсловиеОформления();
	Условие.ЛевоеЗначение = "ИдентификаторУсловногоОформления";
	Условие.ВидСравнения = ВидСравненияКомпоновкиДанных.Равно;
	Условие.ПравоеЗначение = "НеИспользуется";
	
	УсловноеОформление.Оформление.Добавить(Оформление);
	УсловноеОформление.Условия.Добавить(Условие);
	УсловноеОформление.ОформляемыеПоля.Добавить("Ссылка");
	
	ПараметрыДерева.УсловноеОформление.Добавить(УсловноеОформление);
	
КонецПроцедуры

// Определяет прикладные настройки подключения к сервису.
//
// Параметры:
//  ПлатежнаяСистема - ПеречислениеСсылка.ПлатежныеСервисы
//
// Возвращаемое значение:
//  Структура - настройки подключения:
//    * ОбъектМетаданных - ОбъектМетаданныхРегистрСведений - объект метаданных регистр сведений, в котором хранятся
//        настройки выполнения оплат. Регистр определяет связь торговой точки платежной системы и аналитики ведения
//        учета в программах 1С. На основании данных регистра должен выполняется поиск настройки подключения при
//        выполнении оплат и возвратов.
//    * ИсключаемыеПоля - Массив из Строка - наименования измерений, ресурсов или реквизитов, которые необходимо скрыть
//        на форме настройки подключения.
//    * ШаблоныНазначений - см. НастройкиПлатежныхСистемСлужебный.НовыйШаблоныНазначений.
//
Функция НастройкиПодключения(Знач ПлатежнаяСистема) Экспорт
	
	ОбъектМетаданных = Неопределено;	// ОбъектМетаданныхРегистрСведений
	ИсключаемыеПоля  = Новый Массив();	// Массив из Строка
	
	Результат = Новый Структура();
	Результат.Вставить("ОбъектМетаданных" , ОбъектМетаданных);
	Результат.Вставить("ИсключаемыеПоля", ИсключаемыеПоля);
	Результат.Вставить("ШаблоныНазначений", НастройкиПлатежныхСистемСлужебный.НовыйШаблоныНазначений());
	
	ПараметрыНастройки = Новый Структура();
	ПараметрыНастройки.Вставить("ПлатежнаяСистема", ПлатежнаяСистема);
	
	ИнтеграцияПодсистемБИП.ПриОпределенииНастроекПодключенияКПлатежнойСистеме(
		ПараметрыНастройки,
		Результат);
	ПлатежныеСистемыПереопределяемый.ПриОпределенииНастроекПодключения(
		ПараметрыНастройки,
		Результат);
	
	Ошибки = Новый Массив;
	
	Если Результат.ОбъектМетаданных = Неопределено Тогда
		Ошибки.Добавить(НСтр("ru = 'Не указан объект метаданных отвечающий за настройку параметров оплаты.'"));
	КонецЕсли;
	
	НастройкиПлатежныхСистемСлужебный.ПроверитьШаблоныНазначений(
		Результат.ШаблоныНазначений,
		Ошибки);

	Если Ошибки.Количество() > 0 Тогда
		ОшибкиПроверки = СтрСоединить(Ошибки, Символы.ПС);
		ВызватьИсключение ОшибкиПроверки;
	КонецЕсли;
	
	//@skip-check constructor-function-return-section
	Возврат Результат;
	
КонецФункции

// Определяет доступность использования функциональности чтения настроек на основании прав доступа пользователя.
//
// Возвращаемое значение:
//  Булево - если Истина, чтение операций доступно.
//
Функция ЧтениеНастроекДоступно() Экспорт
	
	Возврат ПравоДоступа("Чтение", Метаданные.Справочники.НастройкиПодключенияКПлатежнымСистемам);
	
КонецФункции

// Возвращает идентификатор платежной системы для указанной настройки подключения к платежной системе.
// 
// Параметры:
//  НастройкаПодключения - СправочникСсылка.НастройкиПодключенияКПлатежнымСистемам - настройка, для которой нужно
//    получить идентификатор платежной системы.
//  
// Возвращаемое значение:
//  Строка - идентификатор. Допустимые значения: "ОзонПэй". Пустая строка - не удалось определить платежную систему.
//  
Функция ИдентификаторПлатежнойСистемыПоНастройке(НастройкаПодключения) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ВЫБОР
	|		КОГДА НастройкиПодключения.ПлатежнаяСистема = ЗНАЧЕНИЕ(Перечисление.ПлатежныеСервисы.ОзонПэй)
	|			ТОГДА &ОзонПэй
	|		ИНАЧЕ """"
	|	КОНЕЦ КАК ИдентификаторПлатежнойСистемы
	|ИЗ
	|	Справочник.НастройкиПодключенияКПлатежнымСистемам КАК НастройкиПодключения
	|ГДЕ
	|	НастройкиПодключения.Ссылка = &Ссылка";
	
	Запрос.УстановитьПараметр("Ссылка", НастройкаПодключения);
	Запрос.УстановитьПараметр(
		"ОзонПэй",
		НастройкиПлатежныхСистемКлиентСервер.ИмяПодсистемыОзонПэй());
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Выборка.ИдентификаторПлатежнойСистемы;
	КонецЕсли;
	
	Возврат "";
	
КонецФункции

