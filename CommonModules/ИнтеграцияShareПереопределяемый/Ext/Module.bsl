//  	НастройкиФормирования.Контрагент         = ЗначенияРеквизитов.Контрагент;
//  	НастройкиФормирования.ДоговорКонтрагента = ЗначенияРеквизитов.ДоговорКонтрагента;
//  	НастройкиФормирования.ЭтоФорматФНС       = Истина;
//  	
//  	Если ЗначенияРеквизитов.ВидДокумента = "Корректировка" Тогда
//  		ОбщегоНазначения.СообщитьПользователю(СтрШаблон(
//  				НСтр("ru = 'Не поддержана возможность делиться документом по ссылке с видом документа ""%1"".'"),
//  				ЗначенияРеквизитов.ВидДокумента));
//  	КонецЕсли
//  КонецЕсли; .
//
Процедура ЗаполнитьНастройкиФормированияДокумента(СсылкаНаДокумент, НастройкиФормирования) Экспорт
	
	//++ НЕ ГОСИС
	ИнтеграцияShareУТ.ЗаполнитьНастройкиФормированияДокумента(СсылкаНаДокумент, НастройкиФормирования);
	//-- НЕ ГОСИС
	
