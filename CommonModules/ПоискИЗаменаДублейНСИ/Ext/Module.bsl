
#Область ПрограммныйИнтерфейс

// Выполняет поиск дублирующихся записей НСИ на основе активных правил и записывает найденные дубли
// в регистр сведений ДублиНСИКПодтверждению.
//
Процедура ПоискДублейНСИ() Экспорт 
	
	ОбщегоНазначения.ПриНачалеВыполненияРегламентногоЗадания();
	ВыполнитьПоискДублейНСИ();
	
КонецПроцедуры

// Обработчик регламентного задания "ЗаменаДублейНСИ". Заменяет ссылки дублей на оригиналы в базе по данным
// регистра сведений ДублиНСИ. Каждая пара замены обрабатывается отдельно по очереди, чтобы иметь возможность точно
// идентифицировать ошибки, связанные именно с этой заменой.
//
Процедура ЗаменаДублейНСИ() Экспорт
	
	ОбщегоНазначения.ПриНачалеВыполненияРегламентногоЗадания();
	
	ПарыЗамен = РегистрыСведений.ДублиНСИ.ПарыЗамен();
	
	ПараметрыЗамены = ОбщегоНазначения.ПараметрыЗаменыСсылок();
	ПараметрыЗамены.СпособУдаления = "Непосредственно";
	ПараметрыЗамены.ВключатьБизнесЛогику = Ложь;
	
	РазмерПорции = 100;
	ПорцияЗамены = Новый Соответствие;
	Счетчик = 0;
	
	Для Каждого ДубльОригинал Из ПарыЗамен Цикл
		ПорцияЗамены.Вставить(ДубльОригинал.Ключ, ДубльОригинал.Значение);
		Счетчик = Счетчик + 1;
		
		Если Счетчик >= РазмерПорции Тогда
			ОбработатьПорциюЗамены(ПорцияЗамены, ПараметрыЗамены);
			ПорцияЗамены.Очистить();
			Счетчик = 0;
		КонецЕсли;
	КонецЦикла;
	
	Если ПорцияЗамены.Количество() > 0 Тогда
		ОбработатьПорциюЗамены(ПорцияЗамены, ПараметрыЗамены);
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Процедура ОбработатьПорциюЗамены(ПорцияЗамены, ПараметрыЗамены)
	
	ОшибкиЗамены = ОбщегоНазначения.ЗаменитьСсылки(ПорцияЗамены, ПараметрыЗамены);
	Если ОшибкиЗамены.Количество() > 0 Тогда
		РегистрыСведений.ДублиНСИ.ОбновитьИнформациюОбОшибкахЗамены(ОшибкиЗамены);
	КонецЕсли;
	
КонецПроцедуры

// Выполняет поиск новых дублей НСИ по указанному или всем активным правилам.
//
// Параметры:
//   Правило - СправочникСсылка.ПравилаПоискаДублейНСИ - правило для поиска дублей, если не указано - поиск по всем активным правилам.
//
Процедура ВыполнитьПоискДублейНСИ(Правило = Неопределено) Экспорт 
	
	Запрос = Новый Запрос;
	ТекстЗапроса = 
		"ВЫБРАТЬ
		|	ПравилаПоискаДублейНСИ.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.ПравилаПоискаДублейНСИ КАК ПравилаПоискаДублейНСИ
		|ГДЕ
		|	ПравилаПоискаДублейНСИ.Активно
		|	И &ОтборПоПравилу";
	
	Если Правило <> Неопределено Тогда
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "ПравилаПоискаДублейНСИ.Активно", "ИСТИНА");
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&ОтборПоПравилу", "ПравилаПоискаДублейНСИ.Ссылка = &Правило");
		Запрос.УстановитьПараметр("Правило", Правило);
	Иначе
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&ОтборПоПравилу", "ИСТИНА");
	КонецЕсли;
	
	Запрос.Текст = ТекстЗапроса;
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
	
		Запрос = Справочники.ПравилаПоискаДублейНСИ.СформироватьЗапросПоПравилу(Выборка.Ссылка, Ложь);
		ПарыДублей = Запрос.Выполнить().Выгрузить();
		
		РегистрыСведений.ДублиНСИКПодтверждению.ПроверитьДублиНаСоответствиеПравилуПоиска(ПарыДублей, Выборка.Ссылка);
		ПоискИЗаменаДублейНСИПереопределяемый.ПриПоискеДублейНСИ(ПарыДублей, Выборка.Ссылка);
		
		Если ЗначениеЗаполнено(Правило) Тогда
			РассчетМестИспользования = Неопределено;
		Иначе
			РассчетМестИспользования = Ложь;
		КонецЕсли;
		РегистрыСведений.ДублиНСИКПодтверждению.ДобавитьДубли(ПарыДублей, Выборка.Ссылка, РассчетМестИспользования);
		
	КонецЦикла;
	
КонецПроцедуры

// Возвращает таблицу связанных объектов для дополнения информации основного объекта в отчете сравнения дублей.
//
// Возвращаемое значение:
//   ТаблицаЗначений:
//      *СвязанныйОбъект - ОбъектМетаданных - объект метаданных подчиненного объекта.
//      *ПолеСвязи - Строка - имя реквизита, определяющего связь между основным и подчиненным объектом.
//
Функция СвязанныеОбъекты() Экспорт
	
	СвязанныеОбъекты = Новый ТаблицаЗначений;
	СвязанныеОбъекты.Колонки.Добавить("СвязанныйОбъект", Новый ОписаниеТипов("ОбъектМетаданных"));
	СвязанныеОбъекты.Колонки.Добавить("ПолеСвязи", Новый ОписаниеТипов("Строка"));
	
	Возврат СвязанныеОбъекты;
	
КонецФункции

// Возвращает связи объектов с указанием типа поля связи.
//
// Возвращаемое значение:
//   ТаблицаЗначений:
//      * ТипРеквизита - Тип
//      * ИмяРеквизита - Строка
//      * Ключ - Строка
//      * Метаданные - ОбъектМетаданных
//
Функция СвязиОбъектов() Экспорт
	
	СвязиОбъектов = Новый ТаблицаЗначений;
	СвязиОбъектов.Колонки.Добавить("ТипРеквизита", Новый ОписаниеТипов("Тип"));
	СвязиОбъектов.Колонки.Добавить("ИмяРеквизита", Новый ОписаниеТипов("Строка", , Новый КвалификаторыСтроки(0)));
	СвязиОбъектов.Колонки.Добавить("Ключ", Новый ОписаниеТипов("Строка", , Новый КвалификаторыСтроки(0)));
	СвязиОбъектов.Колонки.Добавить("Метаданные", Новый ОписаниеТипов("ОбъектМетаданных"));
	
	Возврат СвязиОбъектов;
	
КонецФункции

// Возвращает реквизиты, исключаемые из отображения при построении отчета о сравнении дублей.
//
// Возвращаемое значение:
//   ТаблицаЗначений:
//      * ИмяРеквизита - Строка - имя реквизита или табличной части.
//      * ИмяТабличнойЧасти - Строка - заполняется, если реквизит расположен в табличной части.
//      * Метаданные - ОбъектМетаданных
//
Функция ИсключенияРеквизитовСравнения() Экспорт
	
	РеквизитыИсключения = Новый ТаблицаЗначений();
	РеквизитыИсключения.Колонки.Добавить("Метаданные", Новый ОписаниеТипов("ОбъектМетаданных"));
	РеквизитыИсключения.Колонки.Добавить("ИмяТабличнойЧасти", Новый ОписаниеТипов("Строка"));
	РеквизитыИсключения.Колонки.Добавить("ИмяРеквизита", Новый ОписаниеТипов("Строка"));
	
	Возврат РеквизитыИсключения;
	
КонецФункции

#КонецОбласти
