#Область ПрограммныйИнтерфейс

// Возвращает фоновое задание на загрузку статусов операций.
// 
// Возвращаемое значение:
//  Структура - Задание на загрузку статусов операций:
// * Статус - Строка - статус фонового задания.
// * ИдентификаторЗадания - Неопределено, УникальныйИдентификатор - идентификатор задания.
// * АдресРезультата - Строка - адрес временного хранилища, в которое будет помещен результат работы процедуры.
// * АдресДополнительногоРезультата - Строка - адрес дополнительного временного хранилища.
// * ИнформацияОбОшибке - Неопределено, ИнформацияОбОшибке - информация об ошибке.
// * КраткоеПредставлениеОшибки - Строка - краткое описание ошибки.
// * ПодробноеПредставлениеОшибки - Строка - подробное описание ошибки
// * Сообщения - ФиксированныйМассив из Строка - список сообщений, сформированный во время выполнения задания.
Функция ЗаданиеНаЗагрузкуСтатусовОпераций() Экспорт

	Возврат ОнлайнЗаказыУТ.ЗаданиеНаЗагрузкуСтатусовОпераций();

КонецФункции

#КонецОбласти

#Область СлужебныйПрограммныйИнтерфейс

// Возвращает признак наличия оплаты документа по платежной ссылке онлайн-заказа.
// 
// Параметры:
//  ДокументЗаказа - ДокументСсылка.ЗаказКлиента - Документ, для которого выполняется проверка.
// 
// Возвращаемое значение:
//  Булево - признак оплаты.
Функция ДокументЗаказаОплачен(ДокументЗаказа) Экспорт

	СхемаЗапроса = Новый СхемаЗапроса;
	ЗапросВыбора = СхемаЗапроса.ПакетЗапросов[0];
	ОператорВыбора = ЗапросВыбора.Операторы[0];
	ОператорВыбора.Источники.Добавить(
		Метаданные.РегистрыСведений.ИдентификаторыОнлайнЗаказов.ПолноеИмя(), "ИдентификаторыОнлайнЗаказов");
	ОператорВыбора.Отбор.Добавить("ИдентификаторыОнлайнЗаказов.ДокументЗаказа = &ДокументЗаказа");
	ОператорВыбора.Отбор.Добавить("ИдентификаторыОнлайнЗаказов.СтатусЗаказа = &СтатусЗаказа");
	ОператорВыбора.ВыбираемыеПоля.Добавить("ДокументЗаказа");
	
	ТекстЗапроса = СхемаЗапроса.ПолучитьТекстЗапроса();
	Запрос = Новый Запрос;
	Запрос.Текст = ТекстЗапроса;
	Запрос.УстановитьПараметр("ДокументЗаказа", ДокументЗаказа);
	Запрос.УстановитьПараметр("СтатусЗаказа", ОнлайнЗаказыСлужебный.СтатусЗаказаОплачен());
	
	УстановитьПривилегированныйРежим(Истина);
	РезультатЗапроса = Запрос.Выполнить();
	УстановитьПривилегированныйРежим(Ложь);
	
	Если Не РезультатЗапроса.Пустой() Тогда
	
		СтруктураПараметров = ДенежныеСредстваСервер.ПараметрыПоТипуРасчетов(
			ДокументЗаказа, Перечисления.ТипыРасчетовСПартнерами.РасчетыСКлиентом);
			
		Если СтруктураПараметров = Неопределено Тогда
			Возврат Ложь;
		КонецЕсли;
		
		СостояниеВзаиморасчетов = ВзаиморасчетыСервер.СостояниеВзаиморасчетов(ДокументЗаказа, СтруктураПараметров);
		
		Если СостояниеВзаиморасчетов.ПроцентОплат = 0 Тогда
			Возврат Ложь;
		Иначе
			Возврат Истина;
		КонецЕсли;
		
	Иначе
		Возврат Ложь;
	КонецЕсли;

КонецФункции

#КонецОбласти