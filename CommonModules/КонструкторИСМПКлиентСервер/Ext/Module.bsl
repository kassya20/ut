//  ВидПродукцииТоварнаяГруппа - СправочникСсылка.КлючиВидовПродукцииИС,
//                               СправочникСсылка.ВидыПродукцииИС,
//                               Массив из СправочникСсылка.ВидыПродукцииИС - Виды продукции,
//                               СправочникСсылка.ТоварныеГруппыГИСМТ - Товарная группа.
//  КодОКЕИ - Строка - Код единицы измерения по ОКЕИ
//  ОперацияПричина - ПеречислениеСсылка.ВидыОперацийИСМП, СправочникСсылка.ПричиныВыводаИзОборотаИСМП - вид операции, причина
//Возвращаемое значение:
//  Булево - Истина, если сырье ГИСМТ поддерживает код ОКЕИ
Функция СырьеПоддерживаетКодОКЕИ(ВидПродукцииТоварнаяГруппа, КодОКЕИ, ОперацияПричина) Экспорт
	
	ЗначениеАтрибута = КонструкторИСОбщегоНазначенияКлиентСервер.ЗначениеАтрибутаЭлементаКонструктора(
		"КодыОКЕИ",
		ПредопределенноеЗначение(
			"Справочник.ЭлементыКонструктораВидовПродукцииИС.СырьеПоддерживаетКодОКЕИ"),
		КонструкторИСМПОбщегоНазначенияКлиентСервер.ВидыПродукции(ВидПродукцииТоварнаяГруппа),
		ОперацияПричина);
	
	Если ЗначениеАтрибута = Неопределено Тогда
		Возврат Ложь;
	КонецЕсли;
	
	КодыЕдиниц = СтрРазделить(ЗначениеАтрибута, ";");
	
	Возврат КодыЕдиниц.Найти(СокрЛП(КодОКЕИ)) <> Неопределено;
	
КонецФункции

