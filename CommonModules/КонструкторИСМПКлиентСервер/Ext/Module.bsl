// Вид продукции ИС МП с возможным, но необязательным указанием даты производства в операциях нанесения КМ
// 
// Параметры:
//  ВидПродукцииТоварнаяГруппа - СправочникСсылка.КлючиВидовПродукцииИС,
//                               СправочникСсылка.ВидыПродукцииИС,
//                               Массив из СправочникСсылка.ВидыПродукцииИС - Виды продукции,
//                               СправочникСсылка.ТоварныеГруппыГИСМТ - Товарная группа.
//  Операция - ПеречислениеСсылка.ВидыОперацийИСМП - Операция,
//           - Массив из ПеречислениеСсылка.ВидыОперацийИСМП.
// 
// Возвращаемое значение:
//  Булево - вид продукции не требует обязательного указания срока годности
Функция ЭтоВидПродукцииСОбязательнымУказаниемДатыПроизводства(ВидПродукцииТоварнаяГруппа, Операция = Неопределено) Экспорт
	
	Возврат КонструкторИСМПОбщегоНазначенияКлиентСервер.ЭлементКонструктораСодержитЗначение(
		ПредопределенноеЗначение(
			"Справочник.ЭлементыКонструктораВидовПродукцииИС.ПроверятьЗаполнениеПоляДатаПроизводства"),
		ВидПродукцииТоварнаяГруппа,
		Операция);
	
КонецФункции

// Признак возможности маркировки остатков.
// 
// Параметры:
//  ВидПродукцииТоварнаяГруппа - СправочникСсылка.КлючиВидовПродукцииИС,
//                               СправочникСсылка.ВидыПродукцииИС,
//                               Массив из СправочникСсылка.ВидыПродукцииИС - Виды продукции,
//                               СправочникСсылка.ТоварныеГруппыГИСМТ - Товарная группа.
// Возвращаемое значение:
//  Булево - Доступность маркировки остатков товаров.
Функция ВидПродукцииПодлежитМаркировкеОстатков(ВидПродукцииТоварнаяГруппа) Экспорт
	
	ЭлементКонструктора = ПредопределенноеЗначение(
			"Справочник.ЭлементыКонструктораВидовПродукцииИС.МаркировкаОстатков");
	ВидыПродукции = КонструкторИСМПОбщегоНазначенияКлиентСервер.ВидыПродукции(ВидПродукцииТоварнаяГруппа);
	Подлежит =  КонструкторИСОбщегоНазначенияКлиентСервер.ЗначенияЭлементаКонструктораПоВидуПродукции(
		ЭлементКонструктора,
		ВидыПродукции);
	
	Если Подлежит Тогда
		
		#Если Клиент Или ВебКлиент Или МобильноеПриложениеКлиент Или МобильныйКлиент Тогда
			ДатаСеанса = НачалоДня(ОбщегоНазначенияКлиент.ДатаСеанса());
		#Иначе
			ДатаСеанса = НачалоДня(ТекущаяДатаСеанса());
		#КонецЕсли
		
		Если ТипЗнч(ВидыПродукции) = Тип("Массив") Тогда
			ВидыПродукцииПроверкиПоДате = ВидыПродукции;
		Иначе
			ВидыПродукцииПроверкиПоДате = Новый Массив;
			ВидыПродукцииПроверкиПоДате.Добавить(ВидыПродукции);
		КонецЕсли;
		
		ПодлежитПоВидамПродукции = Ложь;
		Для Каждого ВидПродукции Из ВидыПродукцииПроверкиПоДате Цикл
			
			ДатаНачала = КонструкторИСОбщегоНазначенияКлиентСервер.ЗначениеАтрибутаЭлементаКонструктора(
				"ДатаНачала", ЭлементКонструктора, ВидПродукции);
			ДатаОкончания = КонструкторИСОбщегоНазначенияКлиентСервер.ЗначениеАтрибутаЭлементаКонструктора(
				"ДатаОкончания", ЭлементКонструктора, ВидПродукции);
			
			ПодлежитПоДате = Истина;
			Если ЗначениеЗаполнено(ДатаНачала)
				И ДатаСеанса < ДатаНачала Тогда
				ПодлежитПоДате = Ложь;
			КонецЕсли;
			Если ЗначениеЗаполнено(ДатаОкончания)
				И ДатаСеанса > ДатаОкончания Тогда
				ПодлежитПоДате = Ложь;
			КонецЕсли;
			
			Если ПодлежитПоДате Тогда
				ПодлежитПоВидамПродукции = Истина;
				Прервать;
			КонецЕсли;
			
		КонецЦикла;
		
		Подлежит = ПодлежитПоВидамПродукции;
		
	КонецЕсли;
	
	Возврат Подлежит;
	
КонецФункции

