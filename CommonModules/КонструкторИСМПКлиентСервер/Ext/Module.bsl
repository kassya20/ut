// Возвращает элемент конструктора для определения доступных видов продукции
//
// Параметры:
//  Объект - Структура - Структура со свойствами:
//   * Ссылка - ДокументСсылка
//   * ОСУ - Булево.
// 
// Возвращаемое значение:
//  СправочникСсылка.ЭлементыКонструктораВидовПродукцииИС,
//  Массив из СправочникСсылка.ЭлементыКонструктораВидовПродукцииИС.
//
Функция ЭлементКонструктораДляОпределенияДоступныхВидовПродукции(Объект) Экспорт
	
	Результат = Неопределено;
	Ссылка    = Неопределено;
	Если Объект <> Неопределено
		И ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(Объект, "Ссылка") Тогда
		Ссылка = Объект.Ссылка;
	КонецЕсли;
	
	Если ТипЗнч(Ссылка) = Тип("ДокументСсылка.ВозвратВОборотИСМП") Тогда
		Результат = ПредопределенноеЗначение(
			"Справочник.ЭлементыКонструктораВидовПродукцииИС.ПолеВидВозврата");
	ИначеЕсли ТипЗнч(Ссылка) = Тип("ДокументСсылка.ВыводИзОборотаИСМП") Тогда
		Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(Объект, "ОСУ") И Объект.ОСУ Тогда
			Результат = ПредопределенноеЗначение(
					"Справочник.ЭлементыКонструктораВидовПродукцииИС.ПричиныВыводаИзОборотаОСУ");
		Иначе
			Результат = ПредопределенноеЗначение(
				"Справочник.ЭлементыКонструктораВидовПродукцииИС.ПричиныВыводаИзОборотаПоштучно");
		КонецЕсли;
	ИначеЕсли ТипЗнч(Ссылка) = Тип("ДокументСсылка.СписаниеКодовМаркировкиИСМП") Тогда
		Результат = Новый Массив;
		Результат.Добавить(ПредопределенноеЗначение(
			"Справочник.ЭлементыКонструктораВидовПродукцииИС.СписаниеЧерезГИСМТ"));
		Результат.Добавить(ПредопределенноеЗначение(
			"Справочник.ЭлементыКонструктораВидовПродукцииИС.СписаниеЧерезГИСМТОбщийДокумент"));
		Результат.Добавить(ПредопределенноеЗначение(
			"Справочник.ЭлементыКонструктораВидовПродукцииИС.СписаниеЧерезСУЗ"));
		Результат.Добавить(ПредопределенноеЗначение(
			"Справочник.ЭлементыКонструктораВидовПродукцииИС.СписаниеЧерезСУЗМех"));
	ИначеЕсли ТипЗнч(Ссылка) = Тип("ДокументСсылка.ПеремаркировкаТоваровИСМП") Тогда
		Результат = ПредопределенноеЗначение(
				"Справочник.ЭлементыКонструктораВидовПродукцииИС.Перемаркировка");
	ИначеЕсли ТипЗнч(Ссылка) = Тип("ДокументСсылка.ОтгрузкаТоваровИСМП") Тогда
		Результат = Новый Массив;
		Результат.Добавить(ПредопределенноеЗначение(
			"Справочник.ЭлементыКонструктораВидовПродукцииИС.ОперацияОтгрузкаАгент"));
		Результат.Добавить(ПредопределенноеЗначение(
			"Справочник.ЭлементыКонструктораВидовПродукцииИС.ОперацияОтгрузкаКомиссия"));
		Результат.Добавить(ПредопределенноеЗначение(
			"Справочник.ЭлементыКонструктораВидовПродукцииИС.ОперацияОтгрузкаПродажа"));
		Результат.Добавить(ПредопределенноеЗначение(
			"Справочник.ЭлементыКонструктораВидовПродукцииИС.ОперацияОтгрузкаВЕАЭСПриОСУ"));
		Результат.Добавить(ПредопределенноеЗначение(
			"Справочник.ЭлементыКонструктораВидовПродукцииИС.ОперацияОтгрузкаЕАЭССПризнаниемКИ"));
	ИначеЕсли ТипЗнч(Ссылка) = Тип("ДокументСсылка.ПриемкаТоваровИСМП") Тогда
		Результат = ПредопределенноеЗначение(
				"Справочник.ЭлементыКонструктораВидовПродукцииИС.ПриемкаТоваров");
	ИначеЕсли ТипЗнч(Ссылка) = Тип("ДокументСсылка.УточнениеСведенийОКодахМаркировкиИСМП") Тогда
		Результат = Новый Массив;
		Результат.Добавить(ПредопределенноеЗначение(
			"Справочник.ЭлементыКонструктораВидовПродукцииИС.КорректировкаСведенийКМ"));
		Результат.Добавить(ПредопределенноеЗначение(
			"Справочник.ЭлементыКонструктораВидовПродукцииИС.КорректировкаСведенийКМСрокГодности"));
		Результат.Добавить(ПредопределенноеЗначение(
			"Справочник.ЭлементыКонструктораВидовПродукцииИС.КорректировкаСведенийКМСрокГодностиВСД"));
		Результат.Добавить(ПредопределенноеЗначение(
			"Справочник.ЭлементыКонструктораВидовПродукцииИС.КорректировкаСведенийКМФактическийВес"));
	
	ИначеЕсли ТипЗнч(Ссылка) = Тип("ДокументСсылка.ПеремещениеМеждуМОДИСМП") Тогда
		Результат = ПредопределенноеЗначение(
				"Справочник.ЭлементыКонструктораВидовПродукцииИС.ПеремещениеМеждуМОД");
	ИначеЕсли ТипЗнч(Ссылка) = Тип("ДокументСсылка.РазрешениеНаОтгрузкуИСМП") Тогда
		Результат = ПредопределенноеЗначение(
				"Справочник.ЭлементыКонструктораВидовПродукцииИС.РазрешениеНаОтгрузку");
	ИначеЕсли ТипЗнч(Ссылка) = Тип("ДокументСсылка.ОтчетИСМП") Тогда
		Результат = Новый Массив;
		Результат.Добавить(ПредопределенноеЗначение(
			"Справочник.ЭлементыКонструктораВидовПродукцииИС.ОперацияЗагрузкаСведенийОбОтклонениях"));
		Результат.Добавить(ПредопределенноеЗначение(
			"Справочник.ЭлементыКонструктораВидовПродукцииИС.ОперацияЗагрузкаСпискаКИНаБалансе"));
	ИначеЕсли ТипЗнч(Ссылка) = Тип("ДокументСсылка.ЗаказНаЭмиссиюКодовМаркировкиСУЗ") Тогда
		Результат = Новый Массив;
		Результат.Добавить(ПредопределенноеЗначение(
			"Справочник.ЭлементыКонструктораВидовПродукцииИС.ПолеСпособВводаВОборот"));
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ЭлементКонструктораДляОпределенияДоступныхВидовПродукцииПоПараметрам(Параметры) Экспорт
	
	Если ТипЗнч(Параметры.Ссылка) = Тип("ДокументСсылка.ВыводИзОборотаИСМП")
		И Параметры.ЕАЭС Тогда
		Результат = ПредопределенноеЗначение(
			"Справочник.ЭлементыКонструктораВидовПродукцииИС.ПричинаВыводаИзОборотаТрансграничнаяПродажаВСтраныЕАЭС");
	ИначеЕсли ТипЗнч(Параметры.Ссылка) = Тип("ДокументСсылка.ОтгрузкаТоваровИСМП") Тогда
		Результат = Новый Массив;
			Результат.Добавить(ПредопределенноеЗначение(
				"Справочник.ЭлементыКонструктораВидовПродукцииИС.ОперацияОтгрузкаВЕАЭСПриОСУ"));
			Результат.Добавить(ПредопределенноеЗначение(
				"Справочник.ЭлементыКонструктораВидовПродукцииИС.ОперацияОтгрузкаЕАЭССПризнаниемКИ"));
		Если Не Параметры.ЕАЭС Тогда
			Результат = ОбщегоНазначенияКлиентСервер.РазностьМассивов(
				ЭлементКонструктораДляОпределенияДоступныхВидовПродукции(Параметры),
				Результат);
		КонецЕсли;
	Иначе
		Результат = КонструкторИСМПОбщегоНазначенияКлиентСервер.ЭлементКонструктораДляОпределенияДоступныхВидовПродукции(Параметры);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ПоддерживаетсяЧастичноеВыбытиеПриВыводеИзОборота(ВидПродукцииТоварнаяГруппа, ПричинаВывода) Экспорт
	
	Возврат КонструкторИСМПОбщегоНазначенияКлиентСервер.ЭлементКонструктораСодержитЗначение(
		ПредопределенноеЗначение(
			"Справочник.ЭлементыКонструктораВидовПродукцииИС.ЧастичноеВыбытиеПриВыводеИзОборота"),
			КонструкторИСМПОбщегоНазначенияКлиентСервер.ВидыПродукции(ВидПродукцииТоварнаяГруппа),
			ПричинаВывода);
	
КонецФункции

// Определяет, нужно ли использовать документ AGGREGATION при агрегации наборов.
//
// Параметры:
//  ВидПродукцииТоварнаяГруппа - СправочникСсылка.КлючиВидовПродукцииИС,
//                               СправочникСсылка.ВидыПродукцииИС,
//                               Массив из СправочникСсылка.ВидыПродукцииИС - Виды продукции,
//                               СправочникСсылка.ТоварныеГруппыГИСМТ - Товарная группа.
// Возвращаемое значение:
//  Булево - Истина, если использовать AGGREGATION, Ложь - использовать стандартный SETS_AGGREGATION.
Функция АгрегироватьНаборыКакЛогистическиеУпаковки(ВидПродукцииТоварнаяГруппа) Экспорт
	
	Возврат КонструкторИСОбщегоНазначенияКлиентСервер.ЗначенияЭлементаКонструктораПоВидуПродукции(
		ПредопределенноеЗначение(
			"Справочник.ЭлементыКонструктораВидовПродукцииИС.АгрегироватьНаборыКакЛогистическиеУпаковки"),
			КонструкторИСМПОбщегоНазначенияКлиентСервер.ВидыПродукции(ВидПродукцииТоварнаяГруппа));
	
КонецФункции

