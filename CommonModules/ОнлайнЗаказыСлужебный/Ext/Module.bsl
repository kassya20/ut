// Определяет способ оплаты по указанной настройке подключения или платежному сервису.
// Если параметр ПлатежныйСервис заполнен, то способ оплаты определяется по нему. Если нет, то по параметру
// НастройкаПодключения.
// 
// Параметры:
//  ПлатежныйСервис - Строка - идентификатор платежного сервиса. Доступные значения определены в методе
//                             СпособОплатыПоИдентификатору.
//                  - ПеречислениеСсылка.ПлатежныеСервисы - для подсистемы ПлатежныеСервисы.
//                  - Неопределено - платежный сервис будет определен на основе параметра НастройкаПодключения.
//  НастройкаПодключения - СправочникСсылка.НастройкиПодключенияКСистемеБыстрыхПлатежей,
//    СправочникСсылка.НастройкиПодключенияКИнтернетЭквайрингу,
//    СправочникСсылка.НастройкиПодключенияКПлатежнымСистемам - настройка подключения к платежной системе, которую
//      нужно добавить в настройку подключения к Онлайн-заказам.
//  
// Возвращаемое значение:
//  Неопределено - не удалось определить способ оплаты.
//  ПеречислениеСсылка.СпособыОплатыОнлайнЗаказов - способ оплаты для указанной настройки или платежного сервиса.
//
Функция СпособОплатыПоНастройке(ПлатежныйСервис, НастройкаПодключения)
	
	СпособОплаты = Неопределено;
	
	Если Не ЗначениеЗаполнено(ПлатежныйСервис) Тогда
		// Определяем по настройке подключения
		Если ОбщегоНазначения.ПодсистемаСуществует("ИнтернетПоддержкаПользователей.ИнтернетЭквайринг") Тогда
			МодульИнтернетЭквайрингСлужебный = ОбщегоНазначения.ОбщийМодуль("ИнтернетЭквайрингСлужебный");
			Если МодульИнтернетЭквайрингСлужебный.ЭтоНастройкаПодключения(НастройкаПодключения) Тогда
				Возврат Перечисления.СпособыОплатыОнлайнЗаказов.Эквайринг;
			КонецЕсли;
		КонецЕсли;
		
		Если ОбщегоНазначения.ПодсистемаСуществует("ИнтернетПоддержкаПользователей.СистемаБыстрыхПлатежей.БазоваяФункциональностьСБП") Тогда
			МодульСистемаБыстрыхПлатежейСлужебный = ОбщегоНазначения.ОбщийМодуль("СистемаБыстрыхПлатежейСлужебный");
			Если МодульСистемаБыстрыхПлатежейСлужебный.ЭтоНастройкаПодключения(НастройкаПодключения) Тогда
				ВариантНастройки = МодульСистемаБыстрыхПлатежейСлужебный.ИдентификаторВариантаНастройкиПоСсылке(НастройкаПодключения);
				Если ВариантНастройки = "b2b" Тогда
					Возврат Перечисления.СпособыОплатыОнлайнЗаказов.СБПb2b;
				ИначеЕсли ВариантНастройки = "c2b" Тогда
					Возврат Перечисления.СпособыОплатыОнлайнЗаказов.СБПb2b;
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
		
		Если ОбщегоНазначения.ПодсистемаСуществует("ИнтернетПоддержкаПользователей.ПлатежныеСистемы.БазоваяФункциональностьПлатежныхСистем") Тогда
			МодульПлатежныеСистемыСлужебный = ОбщегоНазначения.ОбщийМодуль("ПлатежныеСистемыСлужебный");
			Если МодульПлатежныеСистемыСлужебный.ЭтоНастройкаПодключения(НастройкаПодключения)
				И ОбщегоНазначения.ПодсистемаСуществует("ИнтернетПоддержкаПользователей.НастройкиПлатежныхСистем") Тогда
				ИдентификаторПлатежнойСистемы = МодульПлатежныеСистемыСлужебный.ИдентификаторПлатежнойСистемыПоНастройке(
					НастройкаПодключения);
				МодульНастройкиПлатежныхСистемКлиентСервер = ОбщегоНазначения.ОбщийМодуль("НастройкиПлатежныхСистемКлиентСервер");
				Если ИдентификаторПлатежнойСистемы = МодульНастройкиПлатежныхСистемКлиентСервер.ИмяПодсистемыОзонПэй() Тогда
					Возврат Перечисления.СпособыОплатыОнлайнЗаказов.ОзонПэй;
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
	
	ИначеЕсли ТипЗнч(ПлатежныйСервис) = Тип("Строка") Тогда
	
		Попытка
			СпособОплаты = СпособОплатыПоИдентификатору(ПлатежныйСервис);
		Исключение
			СпособОплаты = Неопределено;
		КонецПопытки;
	
	Иначе
		
		// Проверяем по перечислению ПлатежныеСервисы
		Если ОбщегоНазначения.ПодсистемаСуществует("ИнтернетПоддержкаПользователей.ПлатежныеСистемы.БазоваяФункциональностьПлатежныхСистем") Тогда
			МодульПлатежныеСистемыСлужебный = ОбщегоНазначения.ОбщийМодуль("ПлатежныеСистемыСлужебный");
			Если МодульПлатежныеСистемыСлужебный.ЭтоНастройкаПодключения(НастройкаПодключения)
				И ОбщегоНазначения.ПодсистемаСуществует("ИнтернетПоддержкаПользователей.НастройкиПлатежныхСистем") Тогда
				ИдентификаторПлатежнойСистемы = МодульПлатежныеСистемыСлужебный.ИдентификаторПлатежногоСервиса(ПлатежныйСервис);
				МодульНастройкиПлатежныхСистемКлиентСервер = ОбщегоНазначения.ОбщийМодуль("НастройкиПлатежныхСистемКлиентСервер");
				Если ИдентификаторПлатежнойСистемы = МодульНастройкиПлатежныхСистемКлиентСервер.ИмяПодсистемыОзонПэй() Тогда
					Возврат Перечисления.СпособыОплатыОнлайнЗаказов.ОзонПэй;
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
	
	КонецЕсли;
	
	Возврат СпособОплаты;
	
КонецФункции

#КонецОбласти

#Область ОбновлениеИнформационнойБазы

// Заполняет новые реквизиты справочника "НастройкиПодключенияКОнлайнЗаказам"
// при переходе на версию 2.8.4.
//
// Параметры:
//  Параметры - Структура - параметры обновления.
//
Процедура ОбновитьПризнакиИспользованияНастроекОплатФискализации(Параметры) Экспорт
	
	Если Не ОбщегоНазначения.ДоступноИспользованиеРазделенныхДанных() Тогда
		Возврат;
	КонецЕсли;
	
	НачатьТранзакцию();
	
	Попытка
		
		Блокировка = Новый БлокировкаДанных;
		Блокировка.Добавить("Справочник.НастройкиПодключенияКОнлайнЗаказам");
		Блокировка.Заблокировать();
		
		ТекстЗапроса = Новый Массив;
		
		ТекстЗапроса.Добавить(
			"ВЫБРАТЬ РАЗЛИЧНЫЕ
			|	НастройкиПодключенияКОнлайнЗаказамНастройкиОплаты.Ссылка КАК Ссылка
			|ПОМЕСТИТЬ ВТ_НастройкиОнлайнЗаказов
			|ИЗ
			|	Справочник.НастройкиПодключенияКОнлайнЗаказам.НастройкиОплаты КАК НастройкиПодключенияКОнлайнЗаказамНастройкиОплаты
			|ГДЕ
			|	НЕ НастройкиПодключенияКОнлайнЗаказамНастройкиОплаты.Используется");
		
		Если ОбщегоНазначения.ПодсистемаСуществует("ИнтернетПоддержкаПользователей.ОблачныеКассы") Тогда
			ТекстЗапроса.Добавить(
				"
				|ОБЪЕДИНИТЬ ВСЕ
				|
				|ВЫБРАТЬ
				|	НастройкиПодключенияКОнлайнЗаказам.Ссылка
				|ИЗ
				|	Справочник.НастройкиПодключенияКОнлайнЗаказам КАК НастройкиПодключенияКОнлайнЗаказам
				|ГДЕ
				|	НЕ НастройкиПодключенияКОнлайнЗаказам.НастройкаПодключенияКОблачнойКассе.Ссылка ЕСТЬ NULL");
		КонецЕсли;
		
		ТекстЗапроса.Добавить(
			";
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ РАЗЛИЧНЫЕ
			|	ВТ_НастройкиОнлайнЗаказов.Ссылка КАК Ссылка
			|ИЗ
			|	ВТ_НастройкиОнлайнЗаказов КАК ВТ_НастройкиОнлайнЗаказов");
		
		
		Запрос = Новый Запрос;
		Запрос.Текст = СтрСоединить(ТекстЗапроса, Символы.ПС);
		
		РезультатЗапроса = Запрос.Выполнить();
		ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
		
		Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
			
			НастройкаОбъект = ВыборкаДетальныеЗаписи.Ссылка.ПолучитьОбъект();
			НастройкаОбъект.Заблокировать();
			
			Для Каждого НастройкаОплаты Из НастройкаОбъект.НастройкиОплаты Цикл
				НастройкаОплаты.Используется = Истина;
			КонецЦикла;
			
			ОбновлениеИнформационнойБазы.ЗаписатьДанные(
				НастройкаОбъект,
				Ложь,
				Истина);
			
		КонецЦикла;
		
		ЗафиксироватьТранзакцию();
		
	Исключение
		ОтменитьТранзакцию();
		ВызватьИсключение ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
	КонецПопытки;
	
КонецПроцедуры

#КонецОбласти

#КонецОбласти
