//См. Справочники.НастройкиПодключенияКОнлайнЗаказам.НоваяНастройкаПодключения
//
Функция НоваяНастройкаПодключения(
		Организация,
		НастройкиОплат,
		НастройкаОблачнойКассы = Неопределено) Экспорт
	
	Если Не НастройкаОнлайнЗаказовДоступна() Тогда
		ВызватьИсключение НСтр("ru = 'Нарушение прав доступа. Пользователю запрещено создание настроек подключения Онлайн-заказов.
			|Обратитесь к администратору.'");
	КонецЕсли;
	
	Возврат Справочники.НастройкиПодключенияКОнлайнЗаказам.НоваяНастройкаПодключения(
		Организация,
		НастройкиОплат,
		НастройкаОблачнойКассы);
	
КонецФункции

//См. Справочники.НастройкиПодключенияКОнлайнЗаказам.ВключитьНастройку
//
Функция ВключитьНастройкуПодключения(НастройкаПодключения) Экспорт
	
	Если Не НастройкаОнлайнЗаказовДоступна() Тогда
		ВызватьИсключение НСтр("ru = 'Нарушение прав доступа. Пользователю запрещено изменение настроек подключения Онлайн-заказов.
			|Обратитесь к администратору.'");
	КонецЕсли;
	
	Возврат Справочники.НастройкиПодключенияКОнлайнЗаказам.ВключитьНастройку(
		НастройкаПодключения);
	
КонецФункции

// Выполняет обновление настройки подключения онлайн-заказов.
//
// Параметры:
//  НастройкаПодключения - СправочникСсылка.НастройкиПодключенияКОнлайнЗаказам - настройка выполнения операции.
//  НастроитьВнешнийВид - Булево - признак обновления внешнего вида страницы в сервисе.
//  РезультатОбработки - Структура - Результат обработки изменения использования настройки оплаты.
//
// Возвращаемое значение:
//  Структура - результат обновления настройки страницы онлайн-заказов:
//    * КодОшибки - Строка - строковый код возникшей ошибки, который
//      может быть обработан вызывающим методом:
//        - <Пустая строка> - получение URL заказа выполнено успешно;
//        - "НеверныйФорматЗапроса" - передан некорректный запрос или настройка подключения;
//        - "НеверныйЛогинИлиПароль" - некорректный логин/пароль ИПП;
//        - "СервисВременноНеДоступен" - временная недоступность сервиса;
//        - "ПревышеноКоличествоПопыток" - превышено количество попыток
//          обращения к сервису с некорректным логином и паролем;
//        - "ОшибкаПодключения" - ошибка при подключении к сервису;
//        - "ОшибкаСервиса" - внутренняя ошибка сервиса;
//    * СообщениеОбОшибке  - Строка, ФорматированнаяСтрока - сообщение об ошибке для пользователя;
//    * ИнформацияОбОшибке - Строка, ФорматированнаяСтрока - сообщение об ошибке для администратора.
//
Функция ОбновитьНастройку(
	НастройкаПодключения,
	НастроитьВнешнийВид = Ложь,
	РезультатОбработки = Неопределено) Экспорт
	
	РезультатОперации = НовыйРезультатОперации();
	
	ПараметрыОперации = ПараметрыОперацииОбновленияНастройки(
		НастройкаПодключения,
		НастроитьВнешнийВид,
		РезультатОбработки);
	
	ПроверитьНастройкиСтраницы(ПараметрыОперации.НастройкиСтраницы);
	
	РезультатОбновления = ОнлайнЗаказыСервис.ОбновлениеНастройки(ПараметрыОперации);
	
	ЗаполнитьЗначенияСвойств(РезультатОперации, РезультатОбновления);
	
	Если ЗначениеЗаполнено(РезультатОперации.КодОшибки) Тогда
		Справочники.НастройкиПодключенияКОнлайнЗаказам.УстановитьОшибкуСинхронизации(
			НастройкаПодключения,
			Истина);
		Возврат РезультатОперации;
	КонецЕсли;
	
	РезультатОбновленияФайла = ОбновлениеФайлаСтраницы(
		ПараметрыОперации);
	ЗаполнитьЗначенияСвойств(РезультатОперации, РезультатОбновленияФайла);
	
	Если ЗначениеЗаполнено(РезультатОперации.КодОшибки) Тогда
		Справочники.НастройкиПодключенияКОнлайнЗаказам.УстановитьОшибкуСинхронизации(
			НастройкаПодключения,
			Истина);
	Иначе
		Справочники.НастройкиПодключенияКОнлайнЗаказам.УстановитьОшибкуСинхронизации(
			НастройкаПодключения,
			Ложь);
	КонецЕсли;
	
	Возврат РезультатОперации;
	
КонецФункции

// Выполняет отзыв неиспользуемых токенов подсистемы и обновление настройки подключения онлайн-заказов.
//
// Параметры:
//  НастройкаПодключения - СправочникСсылка.НастройкиПодключенияКОнлайнЗаказам - настройка выполнения операции.
//  НастроитьВнешнийВид - Булево - признак обновления внешнего вида страницы в сервисе.
//  РезультатОбработки - Структура - Результат обработки изменения использования настройки оплаты.
//
// Возвращаемое значение:
//  Структура - результат обновления настройки страницы онлайн-заказов:
//    * КодОшибки - Строка - строковый код возникшей ошибки, который
//      может быть обработан вызывающим методом:
//        - <Пустая строка> - получение URL заказа выполнено успешно;
//        - "НеверныйФорматЗапроса" - передан некорректный запрос или настройка подключения;
//        - "НеверныйЛогинИлиПароль" - некорректный логин/пароль ИПП;
//        - "СервисВременноНеДоступен" - временная недоступность сервиса;
//        - "ПревышеноКоличествоПопыток" - превышено количество попыток
//          обращения к сервису с некорректным логином и паролем;
//        - "ОшибкаПодключения" - ошибка при подключении к сервису;
//        - "ОшибкаСервиса" - внутренняя ошибка сервиса;
//    * СообщениеОбОшибке  - Строка, ФорматированнаяСтрока - сообщение об ошибке для пользователя;
//    * ИнформацияОбОшибке - Строка, ФорматированнаяСтрока - сообщение об ошибке для администратора.
//
Функция ОбновитьНастройкуСОтзывомТокенов(
	НастройкаПодключения,
	НеиспользуемыеНастройки,
	НастроитьВнешнийВид = Ложь,
	РезультатОбработки = Неопределено) Экспорт
	
	РезультатОперации = НовыйРезультатОперации();
	
	РезультатОтзываТокенов = ОтозватьНеиспользуемыеТокеныНастройкиПодключения(НеиспользуемыеНастройки);
	
	Если ЗначениеЗаполнено(РезультатОтзываТокенов.КодОшибки) Тогда
		Справочники.НастройкиПодключенияКОнлайнЗаказам.УстановитьОшибкуСинхронизации(
			НастройкаПодключения,
			Истина);
		Возврат РезультатОперации;
	КонецЕсли;
	
	Возврат ОбновитьНастройку(
		НастройкаПодключения,
		НастроитьВнешнийВид,
		РезультатОбработки);
	
КонецФункции

// Выполняет ревизию токенов подсистемы и обновление настройки подключения онлайн-заказов.
//
// Параметры:
//  НастройкаПодключения - СправочникСсылка.НастройкиПодключенияКОнлайнЗаказам - настройка выполнения операции.
//  НастроитьВнешнийВид - Булево - признак обновления внешнего вида страницы в сервисе.
//  РезультатОбработки - Структура - Результат обработки изменения использования настройки оплаты.
//
// Возвращаемое значение:
//  Структура - результат обновления настройки страницы онлайн-заказов:
//    * КодОшибки - Строка - строковый код возникшей ошибки, который
//      может быть обработан вызывающим методом:
//        - <Пустая строка> - получение URL заказа выполнено успешно;
//        - "НеверныйФорматЗапроса" - передан некорректный запрос или настройка подключения;
//        - "НеверныйЛогинИлиПароль" - некорректный логин/пароль ИПП;
//        - "СервисВременноНеДоступен" - временная недоступность сервиса;
//        - "ПревышеноКоличествоПопыток" - превышено количество попыток
//          обращения к сервису с некорректным логином и паролем;
//        - "ОшибкаПодключения" - ошибка при подключении к сервису;
//        - "ОшибкаСервиса" - внутренняя ошибка сервиса;
//    * СообщениеОбОшибке  - Строка, ФорматированнаяСтрока - сообщение об ошибке для пользователя;
//    * ИнформацияОбОшибке - Строка, ФорматированнаяСтрока - сообщение об ошибке для администратора.
//
Функция ОбновитьНастройкуСРевизиейТокенов(
	НастройкаПодключения,
	НастроитьВнешнийВид = Ложь,
	РезультатОбработки = Неопределено) Экспорт
	
	РезультатОперации = НовыйРезультатОперации();
	
	РезультатРевизииТокенов = ПровестиРевизиюТокеновСервиса();
	
	Если ЗначениеЗаполнено(РезультатРевизииТокенов.КодОшибки) Тогда
		Справочники.НастройкиПодключенияКОнлайнЗаказам.УстановитьОшибкуСинхронизации(
			НастройкаПодключения,
			Истина);
		Возврат РезультатОперации;
	КонецЕсли;
	
	Возврат ОбновитьНастройку(
		НастройкаПодключения,
		НастроитьВнешнийВид,
		РезультатОбработки);
	
КонецФункции

// Выполняет обновление настроек подключения к онлайн-заказам.
// Параметры:
//  НастройкиПодключения - Массив Из СправочникСсылка.НастройкиПодключенияКОнлайнЗаказам
//
// Возвращаемое значение:
//  Структура - результат обновления настройки страницы онлайн-заказов:
//    * НеобработанныеНастройки - Массив Из СправочникСсылка.НастройкиПодключенияКОнлайнЗаказам -
//      содержит перечень настроек по которым не удалось выполнить обновление настроек в сервисе.
//    * КодОшибки - Строка - строковый код возникшей ошибки, который
//      может быть обработан вызывающим методом:
//        - <Пустая строка> - получение URL заказа выполнено успешно;
//        - "НеверныйФорматЗапроса" - передан некорректный запрос или настройка подключения;
//        - "НеверныйЛогинИлиПароль" - некорректный логин/пароль ИПП;
//        - "СервисВременноНеДоступен" - временная недоступность сервиса;
//        - "ПревышеноКоличествоПопыток" - превышено количество попыток
//          обращения к сервису с некорректным логином и паролем;
//        - "ОшибкаПодключения" - ошибка при подключении к сервису;
//        - "ОшибкаСервиса" - внутренняя ошибка сервиса;
//    * СообщениеОбОшибке  - Строка, ФорматированнаяСтрока - сообщение об ошибке для пользователя;
//    * ИнформацияОбОшибке - Строка, ФорматированнаяСтрока - сообщение об ошибке для администратора.
//
Функция ОбновлениеНастроекПодключения(НастройкиПодключения) Экспорт
	
	РезультатОперации = НовыйРезультатОперации();
	РезультатОперации.Вставить("НеобработанныеНастройки", Новый Массив);
	НеобработанныеНастройки = Новый Массив;
	
	Для Каждого НастройкаПодключения Из НастройкиПодключения Цикл
		
		ПараметрыОперации = ПараметрыОперацииОбновленияНастройки(НастройкаПодключения, Ложь, Неопределено);
		Если Не ПустаяСтрока(ПараметрыОперации.КодОшибки) Тогда
			ЗаполнитьЗначенияСвойств(
				РезультатОперации,
				ПараметрыОперации,
				"КодОшибки, СообщениеОбОшибке, ИнформацияОбОшибке");
			НеобработанныеНастройки.Добавить(НастройкаПодключения);
			Справочники.НастройкиПодключенияКОнлайнЗаказам.УстановитьОшибкуСинхронизации(
				НастройкаПодключения,
				Истина);
			Продолжить;
		КонецЕсли;
		
		РезультатВыполнения = ОнлайнЗаказыСервис.ОбновлениеНастройки(ПараметрыОперации);
		
		Если Не ПустаяСтрока(РезультатВыполнения.КодОшибки) Тогда
			ЗаполнитьЗначенияСвойств(РезультатОперации, РезультатВыполнения);
			НеобработанныеНастройки.Добавить(НастройкаПодключения);
			Справочники.НастройкиПодключенияКОнлайнЗаказам.УстановитьОшибкуСинхронизации(
				НастройкаПодключения,
				Истина);
		Иначе
			Справочники.НастройкиПодключенияКОнлайнЗаказам.УстановитьОшибкуСинхронизации(
				НастройкаПодключения,
				Ложь);
		КонецЕсли;
		
	КонецЦикла;
	
	РезультатОперации.НеобработанныеНастройки = НеобработанныеНастройки;
	
	Возврат РезультатОперации;
	
КонецФункции

// Выполняет формирование настроек подключения онлайн-заказов для передачи в сервис.
// Параметры:
//  НастройкаПодключения - СправочникСсылка.НастройкиПодключенияКОнлайнЗаказам - настройка подключения,
//    для которой формируются параметры.
//  НастроитьВнешнийВид - Булево - признак создания новой настройки в сервисе.
//  РезультатОбработки - Структура - Результат обработки изменения использования настройки подключения
//    (оплаты или облачной кассы).
//
// Возвращаемое значение:
//  Структура - результат обновления настройки страницы онлайн-заказов:
//    * НастройкаПодключения - СправочникСсылка.НастройкиПодключенияКОнлайнЗаказам - настройка подключения,
//      обновляемая в сервисе;
//    * НастройкиСтраницы - Структура, Неопределено - содержит настройки внешнего вида страницы онлайн-заказов.
//      Неопределено - если не новая настройка.
//    * ТокенСПБc2b - Строка - Токен подключения, используемый для оплаты СБП c2b;
//    * ТокенСПБb2b - Строка - Токен подключения, используемый для оплаты СБП b2b;
//    * ТокенИнтернетЭквайринг - Строка - Токен подключения, используемый для оплаты по карте;
//    * ТокенОзонПэй - Строка - Токен подключения, используемый для оплаты через Озон Пэй;
//    * ТокенОблачнаяКасса - Строка - Токен подключения облачной кассы;
//    * КодОшибки - Строка - строковый код возникшей ошибки;
//    * СообщениеОбОшибке  - Строка, ФорматированнаяСтрока - сообщение об ошибке для пользователя;
//    * ИнформацияОбОшибке - Строка, ФорматированнаяСтрока - сообщение об ошибке для администратора.
//
Функция ПараметрыОперацииОбновленияНастройки(
	НастройкаПодключения,
	НастроитьВнешнийВид,
	РезультатОбработки)
	
	ПараметрыОперации = Новый Структура;
	ПараметрыОперации.Вставить("НастройкаПодключения", НастройкаПодключения);
	ПараметрыОперации.Вставить("НастройкиСтраницы", Неопределено);
	ПараметрыОперации.Вставить("ТокенСПБc2b", "");
	ПараметрыОперации.Вставить("ТокенСПБb2b", "");
	ПараметрыОперации.Вставить("ТокенИнтернетЭквайринг", "");
	ПараметрыОперации.Вставить("ТокенОзонПэй", "");
	ПараметрыОперации.Вставить("ТокенОблачнаяКасса", "");
	ПараметрыОперации.Вставить("КодОшибки ", "");
	ПараметрыОперации.Вставить("СообщениеОбОшибке ", "");
	ПараметрыОперации.Вставить("ИнформацияОбОшибке ", "");
	
	ЗначенияРеквизитовОбъекта = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(
		НастройкаПодключения,
		"Используется,НастройкаПодключенияКОблачнойКассе,Организация");
	
	Если НастроитьВнешнийВид Тогда
		
		НастройкиСтраницы = НовыйНастройкиСтраницы();
		
		ИнтеграцияПодсистемБИП.ПриНастройкеВнешнегоВида(
			ЗначенияРеквизитовОбъекта.Организация,
			НастройкиСтраницы);
		ОнлайнЗаказыПереопределяемый.ПриНастройкеВнешнегоВида(
			ЗначенияРеквизитовОбъекта.Организация,
			НастройкиСтраницы);
		
		ПараметрыОперации.НастройкиСтраницы = НастройкиСтраницы;
		
	КонецЕсли;
	
	// Для неиспользуемой настройки обнуляем токены, нет необходимости их получать.
	Если Не ЗначенияРеквизитовОбъекта.Используется Тогда
		Возврат ПараметрыОперации;
	КонецЕсли;
	
	НастройкиОплат = Справочники.НастройкиПодключенияКОнлайнЗаказам.ИспользуемыеНастройкиОплат(НастройкаПодключения);
	
	Для Каждого НастройкаОплаты Из НастройкиОплат Цикл
		
		ЗаполнитьТокен(
			ПараметрыОперации,
			РезультатОбработки,
			ИдентификаторВидаТокенаПриемОплат(),
			НастройкаОплаты.Значение,
			НастройкаОплаты.Ключ);
		
	КонецЦикла;
	
	Если ЗначениеЗаполнено(ЗначенияРеквизитовОбъекта.НастройкаПодключенияКОблачнойКассе) Тогда
		ЗаполнитьТокен(
			ПараметрыОперации,
			РезультатОбработки,
			ИдентификаторВидаТокенаОблачнаяКасса(),
			ЗначенияРеквизитовОбъекта.НастройкаПодключенияКОблачнойКассе,
			Перечисления.СпособыОплатыОнлайнЗаказов.ПустаяСсылка());
	КонецЕсли;
	
	Возврат ПараметрыОперации;
	
КонецФункции

// Выполняет заполнение токена.
// Параметры:
//  ПараметрыОперации - Структура - результат обновления настройки страницы онлайн-заказов:
//    * НастройкаПодключения - СправочникСсылка.НастройкиПодключенияКОнлайнЗаказам - настройка подключения,
//      обновляемая в сервисе;
//    * ТокенСПБc2b - Строка - Токен подключения, используемый для оплаты СБП c2b;
//    * ТокенСПБb2b - Строка - Токен подключения, используемый для оплаты СБП b2b;
//    * ТокенИнтернетЭквайринг - Строка - Токен подключения, используемый для оплаты по карте;
//    * ТокенОзонПэй - Строка - Токен подключения, используемый для оплаты через Озон Пэй;
//    * ТокенОблачнаяКасса - Строка - Токен подключения облачной кассы;
//    * КодОшибки - Строка - строковый код возникшей ошибки;
//    * СообщениеОбОшибке  - Строка, ФорматированнаяСтрока - сообщение об ошибке для пользователя;
//    * ИнформацияОбОшибке - Строка, ФорматированнаяСтрока - сообщение об ошибке для администратора.
//  РезультатОбработки - Структура - Результат обработки изменения использования настройки подключения
//    (оплаты или облачной кассы).
//  ВидТокена - Строка - Вид получаемого токена.
//  НастройкаПодключения - Произвольный - настройка подключения для которой выполняется получение токена.
//  СпособОплаты - ПеречислениеСсылка.СпособыОплатыОнлайнЗаказов - способ оплаты для которого выполняется получение токена.
//
Процедура ЗаполнитьТокен(
	ПараметрыОперации,
	РезультатОбработки,
	ВидТокена,
	НастройкаПодключения,
	СпособОплаты)
	
	РезультатОперации = НовыйРезультатОперации();
	РезультатОперации.Вставить("Токен", Неопределено);
	
	Если РезультатОбработки <> Неопределено
		И НастройкаПодключения = РезультатОбработки.НастройкаПодключения Тогда
		
		РезультатОперации.Токен = РезультатОбработки.Токен;
		
	Иначе
		ОнлайнЗаказыСобытия.ПриПолученииТокена(
			РезультатОперации,
			ВидТокена,
			НастройкаПодключения,
			СпособОплаты);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(РезультатОперации.КодОшибки) Тогда
		ЗаполнитьЗначенияСвойств(
			ПараметрыОперации,
			РезультатОперации,
			"КодОшибки, СообщениеОбОшибке, ИнформацияОбОшибке");
		Возврат;
	ИначеЕсли РезультатОперации.Токен = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если ВидТокена = ИдентификаторВидаТокенаОблачнаяКасса() Тогда
		ПараметрыОперации.ТокенОблачнаяКасса = РезультатОперации.Токен;
	ИначеЕсли СпособОплаты = Перечисления.СпособыОплатыОнлайнЗаказов.СБПc2b Тогда
		ПараметрыОперации.ТокенСПБc2b = РезультатОперации.Токен;
	ИначеЕсли СпособОплаты = Перечисления.СпособыОплатыОнлайнЗаказов.СБПb2b Тогда
		ПараметрыОперации.ТокенСПБb2b = РезультатОперации.Токен;
	ИначеЕсли СпособОплаты = Перечисления.СпособыОплатыОнлайнЗаказов.Эквайринг Тогда
		ПараметрыОперации.ТокенИнтернетЭквайринг = РезультатОперации.Токен;
	ИначеЕсли СпособОплаты = Перечисления.СпособыОплатыОнлайнЗаказов.ОзонПэй Тогда
		ПараметрыОперации.ТокенОзонПэй = РезультатОперации.Токен;
	КонецЕсли;
	
КонецПроцедуры

// Выполняет получение URL для перехода к настройке внешнего вида страницы онлайн-заказов.
// Параметры:
// НастройкаПодключения - СправочникСсылка.НастройкиПодключенияКОнлайнЗаказам -
// настройка выполнения операции.
//
// Возвращаемое значение:
//  Структура - результат получения URL:
//    * URLНастройкиПодключения - Строка - URL для перехода к настройке внешнего вида страницы онлайн-заказов.
//    * КодОшибки - Строка - строковый код возникшей ошибки, который
//      может быть обработан вызывающим методом:
//        - <Пустая строка> - получение URL заказа выполнено успешно;
//        - "НеверныйФорматЗапроса" - передан некорректный запрос или настройка подключения;
//        - "НеверныйЛогинИлиПароль" - некорректный логин/пароль ИПП;
//        - "СервисВременноНеДоступен" - временная недоступность сервиса;
//        - "ПревышеноКоличествоПопыток" - превышено количество попыток
//          обращения к сервису с некорректным логином и паролем;
//        - "ОшибкаПодключения" - ошибка при подключении к сервису;
//        - "ОшибкаСервиса" - внутренняя ошибка сервиса;
//    * СообщениеОбОшибке  - Строка, ФорматированнаяСтрока - сообщение об ошибке для пользователя;
//    * ИнформацияОбОшибке - Строка, ФорматированнаяСтрока - сообщение об ошибке для администратора.
//
Функция URLНастройкиПодключения(НастройкаПодключения) Экспорт
	
	Возврат ОнлайнЗаказыСервис.URLНастройкиПодключения(НастройкаПодключения);
	
КонецФункции

// Выполняет отзыв токена по переданному способу и настройке подключения.
//
// Параметры:
//  ВидТокена - Строка - вид токена.
//  НастройкаПодключения - Произвольный - настройка подключения способа оплаты,
//    по которой осуществляется отзыв токена.
//  СпособОплаты - ПеречислениеСсылка.СпособыОплатыОнлайнЗаказов - Способ оплаты для которого получается токен.
//
// Возвращаемое значение:
//  см. ОнлайнЗаказыСлужебный.НовыйРезультатОперации
//
Функция ОтозватьТокенНастройкиПодключения(ВидТокена, НастройкаПодключения, СпособОплаты)
	
	РезультатОперации = НовыйРезультатОперации();
	ОнлайнЗаказыСобытия.ПриОтключенииТокена(
		РезультатОперации,
		ВидТокена,
		НастройкаПодключения,
		СпособОплаты);
	
	Возврат РезультатОперации;
	
КонецФункции

// Выполняет создание/получение токена данных оплат по переданному способу и настройке подключения.
//
// Параметры:
//  НеиспользуемыеНастройки - Массив Из Соответствие - неиспользуемые настройки:
//    * Ключ - ПеречислениеСсылка.СпособыОплатыОнлайнЗаказов - Способ оплаты для которого получается токен;
//    * Значение - Произвольный - настройки подключения способа оплаты, по которой осуществляется отзыв токена.
//
// Возвращаемое значение:
//  см. ОнлайнЗаказыСлужебный.НовыйРезультатОперации
//
Функция ОтозватьНеиспользуемыеТокеныНастройкиПодключения(НеиспользуемыеНастройки) Экспорт
	
	РезультатОперации = НовыйРезультатОперации();
	
	Для Каждого НастройкиПоВидуТокена Из НеиспользуемыеНастройки Цикл
		
		Для Каждого НеиспользуемаяНастройка Из НастройкиПоВидуТокена.Значение Цикл
			
			РезультатОтзыва = НовыйРезультатОперации();
			ОнлайнЗаказыСобытия.ПриОтключенииТокена(
				РезультатОтзыва,
				НастройкиПоВидуТокена.Ключ,
				НеиспользуемаяНастройка.Значение,
				НеиспользуемаяНастройка.Ключ);
			
			Если ЗначениеЗаполнено(РезультатОтзыва.СообщениеОбОшибке) Тогда
				РезультатОперации.КодОшибки = "ОшибкаОтзываТокенов";
				РезультатОперации.СообщениеОбОшибке
					= НСтр("ru = 'Возникли ошибки при отзыве токенов. Подробности в журнале регистрации.'");
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЦикла;
	
	Возврат РезультатОперации;
	
КонецФункции

Функция ПровестиРевизиюТокеновСервиса()
	
	РезультатОперации = НовыйРезультатОперации();
	
	ОнлайнЗаказыСобытия.ПриРевизииТокенов(
		РезультатОперации,
		Справочники.НастройкиПодключенияКОнлайнЗаказам.ИспользуемыеНастройки());
		
	Возврат РезультатОперации;
	
КонецФункции

// Формирует новое описание настроек страницы онлайн-заказов
//
// Возвращаемое значение:
//  Структура - описание настроек страницы:
//    * ЦветФона - Строка - цвет фона страницы в формате HEX.
//    * ЦветПлашки - Строка - цвет плашки на странице в формате HEX.
//    * ЦветШрифта - Строка - цвет шрифтов на странице в формате HEX.
//    * ПоказыватьСостав - Булево - признак отображения товарного наполнения на странице заказа.
//    * КонтактнаяИнформация - Структура - содержит контактную информацию предприятия:
//      ** Адрес - Строка - адрес предприятия, отображаемый на странице заказа.
//      ** ВремяРаботы - Строка - время работы предприятия, отображаемое на странице заказа.
//      ** ЭлектроннаяПочта - Массив из Строка - перечень электронной почты предприятия, отображаемый на странице заказа.
//      ** НомераТелефонов - Массив из Строка - перечень номеров телефонов предприятия, отображаемый на странице заказа.
//      ** АдресВКонтакте - Строка - адрес ВКонтакте, отображаемый на странице заказа.
//      ** АдресВТелеграме - Строка - адрес в Телеграме, отображаемый на странице заказа.
//      ** АдресВMAX - Строка - адрес в MAX, отображаемый на странице заказа.
//    * Логотип - Структура - данные логотипа
//      ** ДанныеФайла - ДвоичныеДанные - содержит данные логотипа;
//      ** Расширение - Строка - расширение логотипа;
//
Функция НовыйНастройкиСтраницы()
	
	Результат = Новый Структура;
	
	Логотип = Новый Структура;
	Логотип.Вставить("Расширение", "");
	Логотип.Вставить("ДанныеФайла", Неопределено);
	
	КонтактнаяИнформация = Новый Структура;
	КонтактнаяИнформация.Вставить("Адрес", "");
	КонтактнаяИнформация.Вставить("ВремяРаботы", "");
	КонтактнаяИнформация.Вставить("ЭлектроннаяПочта", "");
	КонтактнаяИнформация.Вставить("НомераТелефонов", "");
	КонтактнаяИнформация.Вставить("АдресВКонтакте", "");
	КонтактнаяИнформация.Вставить("АдресВТелеграме", "");
	КонтактнаяИнформация.Вставить("АдресВMAX", "");
	
	Результат.Вставить("ЦветФона", "");
	Результат.Вставить("ЦветПлашки", "");
	Результат.Вставить("ЦветШрифта", "");
	Результат.Вставить("ПоказыватьСостав", Истина);
	Результат.Вставить("КонтактнаяИнформация", КонтактнаяИнформация);
	Результат.Вставить("Логотип", Логотип);
	
	Возврат Результат;
	
КонецФункции

// Выполняет анализ заполненности контактной информации в переданных настройках страницы онлайн-заказов
//
// Параметры:
//  НастройкиСтраницы - Структура - настройки контактной информации страницы:
//    * Адрес - Строка - адрес предприятия, отображаемый на странице заказа.
//    * ВремяРаботы - Строка - время работы предприятия, отображаемое на странице заказа.
//    * ЭлектроннаяПочта - Массив из Строка - перечень электронной почты предприятия, отображаемый на странице заказа.
//    * НомераТелефонов - Массив из Строка - перечень номеров телефонов предприятия, отображаемый на странице заказа.
//    * АдресВКонтакте - Строка - адрес ВКонтакте, отображаемый на странице заказа.
//    * АдресВТелеграме - Строка - адрес ВТелеграме, отображаемый на странице заказа.
//
// Возвращаемое значение:
//  Булево - признак заполненности контактных данных.
//
Функция КонтактныеДанныеСтраницыЗаполнены(НастройкиСтраницы) Экспорт
	
	Если НастройкиСтраницы = Неопределено Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Если Не ПустаяСтрока(НастройкиСтраницы.Адрес)
		Или Не ПустаяСтрока(НастройкиСтраницы.ВремяРаботы)
		Или Не ПустаяСтрока(НастройкиСтраницы.АдресВКонтакте)
		Или Не ПустаяСтрока(НастройкиСтраницы.АдресВТелеграме) Тогда
		Возврат Истина;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(НастройкиСтраницы.ЭлектроннаяПочта)
		Или ЗначениеЗаполнено(НастройкиСтраницы.НомераТелефонов) Тогда
		Возврат Истина;
	КонецЕсли;
	
	Возврат Ложь;
	
КонецФункции

// Выполняет обновление файла страницы онлайн-заказов.
// Параметры:
//  ПараметрыОперации - Структура - параметры операции
//  ТипФайла - Строка - Идентификатор типа файла
//
// Возвращаемое значение:
//  Структура - результат обновления настройки страницы онлайн-заказов:
//    * КодОшибки - Строка - строковый код возникшей ошибки, который
//      может быть обработан вызывающим методом:
//        - <Пустая строка> - получение URL заказа выполнено успешно;
//        - "НеверныйФорматЗапроса" - передан некорректный запрос или настройка подключения;
//        - "НеверныйЛогинИлиПароль" - некорректный логин/пароль ИПП;
//        - "СервисВременноНеДоступен" - временная недоступность сервиса;
//        - "ПревышеноКоличествоПопыток" - превышено количество попыток
//          обращения к сервису с некорректным логином и паролем;
//        - "ОшибкаПодключения" - ошибка при подключении к сервису;
//        - "ОшибкаСервиса" - внутренняя ошибка сервиса;
//    * СообщениеОбОшибке  - Строка, ФорматированнаяСтрока - сообщение об ошибке для пользователя;
//    * ИнформацияОбОшибке - Строка, ФорматированнаяСтрока - сообщение об ошибке для администратора.
//
Функция ОбновлениеФайлаСтраницы(ПараметрыОперации, ТипФайла = "logo")
	
	РезультатОперации = НовыйРезультатОперации();
	
	НастройкиСтраницы = ПараметрыОперации.НастройкиСтраницы;
	
	Если НастройкиСтраницы = Неопределено
		Или Не ЗначениеЗаполнено(НастройкиСтраницы.Логотип.ДанныеФайла) Тогда
		Возврат РезультатОперации;
	КонецЕсли;
	
	ПараметрыОперацииОбновленияФайла = Новый Структура;
	ПараметрыОперацииОбновленияФайла.Вставить(
		"НастройкаПодключения",
		ПараметрыОперации.НастройкаПодключения);
	ПараметрыОперацииОбновленияФайла.Вставить(
		"ДанныеФайла",
		НастройкиСтраницы.Логотип.ДанныеФайла);
	ПараметрыОперацииОбновленияФайла.Вставить(
		"РасширениеФайла",
		НастройкиСтраницы.Логотип.Расширение);
	ПараметрыОперацииОбновленияФайла.Вставить(
		"ТипФайла",
		ТипФайла);
	
	Возврат ОнлайнЗаказыСервис.ОбновлениеФайлаСтраницы(
		ПараметрыОперацииОбновленияФайла);
	
КонецФункции

// Производит валидацию параметров обновления страницы.
//
// Параметры:
//  НастройкиСтраницы - Структура - настройки страницы.
//
Процедура ПроверитьНастройкиСтраницы(НастройкиСтраницы)
	
	Если НастройкиСтраницы = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ЭлектроннаяПочтаКОтправке = СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(
		НастройкиСтраницы.КонтактнаяИнформация.ЭлектроннаяПочта,
		",");
	
	Для Каждого ЭлектроннаяПочта Из ЭлектроннаяПочтаКОтправке Цикл
		
		Если Не ОбщегоНазначенияКлиентСервер.АдресЭлектроннойПочтыСоответствуетТребованиям(
			СокрЛП(ЭлектроннаяПочта)) Тогда
			
			ВызватьИсключение СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
				НСтр("ru = 'Передан невалидный email - %1.'"),
				ЭлектроннаяПочта);
			
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

// Формирует параметры выбора настройки подключения по способу оплаты.
//
// Параметры:
