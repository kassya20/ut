// Возвращает ошибки данных заполнения онлайн-заказа.
//
// Параметры:
//  ДанныеЗаказа - Структура - данные онлайн-заказа см. ОнлайнЗаказыСлужебный.ДанныеЗаказаНаОплатуПоДокументу
//
// Возвращаемое значение:
//  Массив из Строка - перечень ошибок данных для создания/обновления онлайн-заказа
//
Функция ОшибкиВалидацииЗаказа(ДанныеЗаказа)
	
	ОшибкиВалидации = Новый Массив;
	
	Если ДанныеЗаказа.ОбщиеПараметрыЗаказа.СрокЖизни <= ТекущаяДатаСеанса() Тогда
		ОшибкиВалидации.Добавить(НСтр("ru = 'Срок жизни заказа меньше текущей даты.'"));
	КонецЕсли;
	
	Если ДанныеЗаказа.Товары.Количество() = 0 Тогда
		ОшибкиВалидации.Добавить(НСтр("ru = 'Заказ не содержит строк с товарами.'"));
	КонецЕсли;
	
	Если ДанныеЗаказа.Товары.Итог("СуммаСоСкидкой") <= 0 Тогда
		ОшибкиВалидации.Добавить(НСтр("ru = 'Сумма заказа должна быть больше ноля.'"));
	КонецЕсли;
	
	Возврат ОшибкиВалидации;
	
КонецФункции

#КонецОбласти

#Область ДанныеЗаказов

// Выполняет загрузку статусов онлайн-заказов, по которым было
// отложено получение результата.
//
// Параметры:
//  ДокументыЗаказов - Массив Из ОпределяемыйТип.ДокументОнлайнЗаказаБИП - документы в информационной базе,
//   являющиеся основанием для заказа.
//
// Возвращаемое значение:
//  Соответствие Из КлючИЗначение - данные онлайн-заказов:
//    * Ключ - ОпределяемыйТип.ДокументОнлайнЗаказаБИП - документ основание онлайн-заказа.
//    * Значение - Структура, Неопределено - Данные онлайн-заказа, Неопределено в случае, если онлайн-заказ не был создан:
//      ** СтатусЗаказа - Строка - Статус онлайн-заказа, может принимать следующие значения:
//        - "Выполняется" - подтверждение оплаты не получено;
//        - "Отменен" - онлайн-заказ отменен;
//        - "Выполнен" - онлайн-заказ оплачен;
//        - "Ошибка" - не удалось выполнить проверку оплаты из-за ошибки;
//      ** ПараметрыЗаказа - Структура - дополнительные данные по заказу:
//        *** URLЗаказа - Строка - URL онлайн-заказа;
//        *** СпособОплаты - Строка - Идентификатор способа оплаты, пустая если СтатусЗаказа <> "Выполнен".
//            Может принимать следующие значения: "СБПc2b", "СБПb2b", "Наличные", "ПоРеквизитам", "Эквайринг",
//            "ОзонПэй", "Прочее".
//        *** СуммаОплаты - Число - Сумма оплаты онлайн-заказа, пустая если СтатусЗаказа <> "Выполнен".
//
Функция ДанныеЗаказов(ДокументыЗаказов) Экспорт
	
	ДанныеЗаказов = Новый Соответствие;
	
	ДанныеКеша = РегистрыСведений.ИдентификаторыОнлайнЗаказов.ДанныеЗаказов(ДокументыЗаказов);
	
	Для Каждого ДокументЗаказа Из ДокументыЗаказов Цикл
		
		ДанныеКешаПоДокументу = ДанныеКеша.Получить(ДокументЗаказа);
		
		Если ДанныеКешаПоДокументу = Неопределено Тогда
			ДанныеЗаказов.Вставить(ДокументЗаказа, Неопределено);
		Иначе
			
			ПараметрыЗаказа = Новый Структура;
			ПараметрыЗаказа.Вставить("URLЗаказа", ДанныеКешаПоДокументу.URLЗаказа);
			ПараметрыЗаказа.Вставить(
				"СпособОплаты",
				ИдентификаторПоСпособуОплаты(ДанныеКешаПоДокументу.СпособОплаты));
			ПараметрыЗаказа.Вставить("СуммаОплаты", ДанныеКешаПоДокументу.СуммаОплаты);
			
			ДанныеЗаказа = Новый Структура;
			ДанныеЗаказа.Вставить("ПараметрыЗаказа", ПараметрыЗаказа);
			ДанныеЗаказа.Вставить(
				"СтатусЗаказа",
				ИдентификаторСтатусаЗаказа(ДанныеКешаПоДокументу.СтатусЗаказа));
			
			ДанныеЗаказов.Вставить(ДокументЗаказа, ДанныеЗаказа);
			
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат ДанныеЗаказов;
	
КонецФункции

// Возвращает публичные данные онлайн-заказа по переданному URL.
//
// Параметры:
//  URLЗаказа - Строка - ссылка на онлайн-заказ.
//
// Возвращаемое значение:
//  Структура - результат получения данных онлайн-заказа:
//    * ПараметрыShare - Структура - Параметры онлайн-заказа в сервисе Share:
//      ** URL - Строка - URL документа онлайн-заказа в сервисе Share, пустая строка в случае если документ не создан;
//      ** ИнформацияОбОшибке - Устарело. Следует использовать ИнформацияОбОшибке верхнего уровня.
//    * ПараметрыОплат - Структура - Содержит описание видов оплат с их параметрами:
//      ** ПоРеквизитам - Структура, Неопределено - Содержит описание реквизитов для оплаты.
//         Неопределено в случае если данные оплат по реквизитам не переданы или отключены в настройке оплат:
//        *** ДанныеQR - Строка - Содержит реквизиты оплаты в формате УФЭБС.
//        *** Представление - Строка - Представление реквизитов оплат в текстовом виде.
//    * ИнформацияОбОшибке - Строка, ФорматированнаяСтрока - сообщение об ошибке для администратора.
//
Функция ПубличныеДанныеЗаказа(URLЗаказа) Экспорт
	
	ПубличныеДанныеЗаказа = НовыйОписаниеПубличныхДанныхЗаказа();
	
	Если Не ОнлайнЗаказыКлиентСервер.ЭтоURLСервиса(URLЗаказа) Тогда
		Возврат ПубличныеДанныеЗаказа;
	КонецЕсли;
	
	ИдентификаторЗаказа = ИдентификаторЗаказаИзURL(URLЗаказа);
	
	Если ПустаяСтрока(ИдентификаторЗаказа) Тогда
		Возврат ПубличныеДанныеЗаказа;
	КонецЕсли;
	
	ИдентификаторыЗаказов = Новый Массив;
	ИдентификаторыЗаказов.Добавить(ИдентификаторЗаказа);
	
	РезультатВызова = ПубличныеДанныеЗаказов(ИдентификаторыЗаказов);
	
	Если ЗначениеЗаполнено(РезультатВызова.ИнформацияОбОшибке) Тогда
		ПубличныеДанныеЗаказа.ИнформацияОбОшибке = РезультатВызова.ИнформацияОбОшибке;
		ПубличныеДанныеЗаказа.ПараметрыShare.URL = РезультатВызова.ИнформацияОбОшибке;
		Возврат ПубличныеДанныеЗаказа;
	КонецЕсли;
	
	ДанныеЗаказа = РезультатВызова.ДанныеЗаказов.Получить(ИдентификаторЗаказа);
	
	Если ДанныеЗаказа <> Неопределено Тогда
		ЗаполнитьЗначенияСвойств(
			ПубличныеДанныеЗаказа,
			ДанныеЗаказа);
	КонецЕсли;
	
	Возврат ПубличныеДанныеЗаказа;
	
КонецФункции

// Возвращает публичные данные онлайн-заказов по их идентификаторам.
//
// Параметры:
//  ИдентификаторыЗаказов - Массив Из Строка - идентификаторы онлайн-заказов.
//
// Возвращаемое значение:
//  Структура - результат получения данных онлайн-заказа:
//    * ДанныеЗаказов - Соответствие - Содержит публичные данные онлайн-заказов:
//      ** Ключ - Строка - Идентификатор онлайн-заказа
//      ** Значение - Структура - Содержит публичные данные онлайн-заказа
//        *** URL - Строка - URL документа онлайн-заказа в сервисе Share, пустая строка в случае если документ не создан;
//    * ИнформацияОбОшибке - Строка, ФорматированнаяСтрока - сообщение об ошибке для администратора.
//
Функция ПубличныеДанныеЗаказов(ИдентификаторыЗаказов)
	
	ПараметрыОперации = Новый Структура;
	ПараметрыОперации.Вставить("ИдентификаторыЗаказов", ИдентификаторыЗаказов);
	
	Возврат ОнлайнЗаказыСервис.ПолучениеПубличнойИнформацииПоЗаказам(ПараметрыОперации);
	
КонецФункции

Функция ИдентификаторПоСпособуОплаты(СпособОплаты)
	
	Если СпособОплаты = Перечисления.СпособыОплатыОнлайнЗаказов.СБПc2b Тогда
		Возврат "СБПc2b";
	ИначеЕсли СпособОплаты = Перечисления.СпособыОплатыОнлайнЗаказов.СБПb2b Тогда
		Возврат "СБПb2b";
	ИначеЕсли СпособОплаты = Перечисления.СпособыОплатыОнлайнЗаказов.Наличные Тогда
		Возврат "Наличные";
	ИначеЕсли СпособОплаты = Перечисления.СпособыОплатыОнлайнЗаказов.ПоРеквизитам Тогда
		Возврат "ПоРеквизитам";
	ИначеЕсли СпособОплаты = Перечисления.СпособыОплатыОнлайнЗаказов.Эквайринг Тогда
		Возврат "Эквайринг";
	ИначеЕсли СпособОплаты = Перечисления.СпособыОплатыОнлайнЗаказов.ОзонПэй Тогда
		Возврат "ОзонПэй";
	Иначе
		Возврат "Прочее";
	КонецЕсли
	
КонецФункции

Функция ИдентификаторСтатусаЗаказа(СтатусЗаказа)
	
	Если СтатусЗаказа = СтатусЗаказаОплачен() Тогда
		Возврат "Выполнен";
	ИначеЕсли СтатусЗаказа = ОнлайнЗаказыКлиентСервер.СтатусЗаказаВыполняется()
		Или СтатусЗаказа = ОнлайнЗаказыКлиентСервер.СтатусЗаказаВыполняетсяОплата()
		Или СтатусЗаказа = ОнлайнЗаказыКлиентСервер.СтатусЗаказаНеАктивен() Тогда
		Возврат "Выполняется";
	ИначеЕсли СтатусЗаказа = ОнлайнЗаказыКлиентСервер.СтатусЗаказаИстекСрокЖизни() Тогда
		Возврат "Отменен";
	ИначеЕсли СтатусЗаказа = ОнлайнЗаказыКлиентСервер.СтатусЗаказаОшибка()
		Или СтатусЗаказа = ОнлайнЗаказыКлиентСервер.СтатусЗаказаОшибкаСервиса() Тогда
		Возврат "Ошибка";
	КонецЕсли
	
КонецФункции

// Получает ссылку на перечисление СпособыОплатыОнлайнЗаказов по строковому идентификатору. Если значение входного
//   параметра не входит в список допустимых, то будет вызвано исключение.
// 
// Параметры:
//  ИдентификаторСпособаОплаты - Строка - строковое представление, по которому нужно получить ссылку. Допустимые
//    значения: "СБПc2b", "СБПb2b", "ИнтернетЭквайринг", "ОзонПэй".
//  
//  Возвращаемое значение:
//    ПеречислениеСсылка.СпособыОплатыОнлайнЗаказов - найденная ссылка.
//
Функция СпособОплатыПоИдентификатору(ИдентификаторСпособаОплаты) Экспорт
	
	Если ИдентификаторСпособаОплаты = "СБПc2b" Тогда
		Возврат Перечисления.СпособыОплатыОнлайнЗаказов.СБПc2b;
	ИначеЕсли ИдентификаторСпособаОплаты = "СБПb2b" Тогда
		Возврат Перечисления.СпособыОплатыОнлайнЗаказов.СБПb2b;
	ИначеЕсли ИдентификаторСпособаОплаты = "ИнтернетЭквайринг" Тогда
		Возврат Перечисления.СпособыОплатыОнлайнЗаказов.Эквайринг;
	ИначеЕсли ИдентификаторСпособаОплаты = "ОзонПэй" Тогда
		Возврат Перечисления.СпособыОплатыОнлайнЗаказов.ОзонПэй;
	КонецЕсли;
	
	ВызватьИсключение (НСтр("ru = 'Передан неизвестный идентификатор способа оплаты.'"));
	
КонецФункции

// Формирует новое описание публичных данных онлайн-заказа.
//
// Возвращаемое значение:
//  Структура - публичные данные онлайн-заказа:
//    * ПараметрыShare - Структура - Параметры онлайн-заказа в сервисе Share:
//      ** URL - Строка - URL документа онлайн-заказа в сервисе Share, пустая строка в случае если документ не создан;
//      ** ИнформацияОбОшибке - Устарело. Следует использовать ИнформацияОбОшибке верхнего уровня.
//    * ПараметрыОплат - Структура - Содержит описание видов оплат с их параметрами:
//      ** ПоРеквизитам - Структура, Неопределено - Содержит описание реквизитов для оплаты.
//         Неопределено в случае если данные оплат по реквизитам не переданы или отключены в настройке оплат:
//        *** ДанныеQR - Строка - Содержит реквизиты оплаты в формате УФЭБС.
//        *** Представление - Строка - Представление реквизитов оплат в текстовом виде.
//    * ИнформацияОбОшибке - Строка, ФорматированнаяСтрока - сообщение об ошибке для администратора.
//
Функция НовыйОписаниеПубличныхДанныхЗаказа() Экспорт
	
	ПубличныеДанныеЗаказа = Новый Структура;
	
	ПараметрыShare = Новый Структура;
	ПараметрыShare.Вставить("URL", "");
	ПараметрыShare.Вставить("ИнформацияОбОшибке", "");
	
	ПараметрыОплатПоРеквизитам = Новый Структура;
	ПараметрыОплатПоРеквизитам.Вставить("ДанныеQR", "");
	ПараметрыОплатПоРеквизитам.Вставить("Представление", "");
	
	ПараметрыОплат = Новый Структура;
	ПараметрыОплат.Вставить("ПоРеквизитам", ПараметрыОплатПоРеквизитам);
	
	ПубличныеДанныеЗаказа.Вставить("ПараметрыShare", ПараметрыShare);
	ПубличныеДанныеЗаказа.Вставить("ПараметрыОплат", ПараметрыОплат);
	ПубличныеДанныеЗаказа.Вставить("ИнформацияОбОшибке", "");
	
	Возврат ПубличныеДанныеЗаказа;
	
КонецФункции

Функция ИдентификаторЗаказаИзURL(Знач URLЗаказа)
	
	URLЗаказа = СокрЛП(URLЗаказа);
	
	ПозицияСимвола = Макс(
		СтрНайти(URLЗаказа, "/", НаправлениеПоиска.СКонца),
		СтрНайти(URLЗаказа, "=", НаправлениеПоиска.СКонца));
	
	Если ПозицияСимвола > 0 Тогда
		
		Возврат Сред(
			URLЗаказа,
			ПозицияСимвола + 1,
			СтрДлина(URLЗаказа) - ПозицияСимвола);
		
	Иначе
		Возврат "";
	КонецЕсли;
	
КонецФункции

#КонецОбласти

#Область ПечатныеФормыЗаказа

Функция ПечатныеФормыЗаказа(ДокументЗаказа) Экспорт
	
	ПечатныеФормы = НовыйОписаниеТаблицыПечатныхФорм();
	ИнтеграцияПодсистемБИП.ПриОпределенииПечатныхФормЗаказа(ДокументЗаказа, ПечатныеФормы);
	ОнлайнЗаказыПереопределяемый.ПриОпределенииПечатныхФормЗаказа(ДокументЗаказа, ПечатныеФормы);
	
	Возврат ПечатныеФормы;
	
КонецФункции

Функция НовыйОписаниеТаблицыПечатныхФорм()
	
	ПечатныеФормы = Новый ТаблицаЗначений;
	
	ПечатныеФормы.Колонки.Добавить(
		"Идентификатор",
		Новый ОписаниеТипов(
			"Строка",
			,
			,
			,
			Новый КвалификаторыСтроки(50)));
	ПечатныеФормы.Колонки.Добавить(
		"Представление",
		Новый ОписаниеТипов(
			"Строка",
			,
			,
			,
			Новый КвалификаторыСтроки(100)));
			
	ПечатныеФормы.Колонки.Добавить(
		"ФорматСохранения",
		Новый ОписаниеТипов("ТипФайлаТабличногоДокумента"));
			
	ПечатныеФормы.Колонки.Добавить(
		"ИмяФайлаВТранслите",
		Новый ОписаниеТипов("Булево"));
		
	ПечатныеФормы.Колонки.Добавить(
		"ПодписьИПечать",
		Новый ОписаниеТипов("Булево"));
	
	Возврат ПечатныеФормы;
	
КонецФункции

#КонецОбласти

