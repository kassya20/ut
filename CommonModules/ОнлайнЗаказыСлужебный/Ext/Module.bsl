////////////////////////////////////////////////////////////////////////////////
// Подсистема "ИнтернетПоддержкаПользователей.ОнлайнЗаказы".
// ОбщийМодуль.ОнлайнЗаказыСлужебный.
//
// Серверные процедуры настройки и выполнения обмена данными с онлайн-заказами:
//  - настройка использования подключения к онлайн-заказам;
//  - проверка доступности функциональности на основании ролей пользователя;
//  - инициализация параметров подключения;
//  - обработчики интеграции с Библиотекой стандартных подсистем;
//  - обработчики интеграции с Библиотекой технологии сервиса;
//  - подготовка и обработка ответов сервиса;
//  - обработка ошибок сервиса;
//  - формирование и настройка шаблонов сообщений;
//  - алгоритмы настройки формы "Интернет-поддержка и сервисы".
//
////////////////////////////////////////////////////////////////////////////////

#Область СлужебныйПрограммныйИнтерфейс

#Область ИнтеграцияСБиблиотекойСтандартныхПодсистем

#Область БСПБазоваяФункциональность

// Интеграция с подсистемой СтандартныеПодсистемы.БазоваяФункциональность.
//
Процедура ПриЗаполненииРазрешенийНаДоступКВнешнимРесурсам(ЗапросыРазрешений) Экспорт
	
	НовыеРазрешения = Новый Массив;
	МодульРаботаВБезопасномРежиме = ОбщегоНазначения.ОбщийМодуль("РаботаВБезопасномРежиме");
	
	Разрешение = МодульРаботаВБезопасномРежиме.РазрешениеНаИспользованиеИнтернетРесурса(
		"HTTPS",
		ОнлайнЗаказыКлиентСервер.ХостСервисаОбменаДанными(),
		443,
		НСтр("ru = 'Сервис онлайн-заказов'"));
	НовыеРазрешения.Добавить(Разрешение);
	
	ЗапросыРазрешений.Добавить(МодульРаботаВБезопасномРежиме.ЗапросНаИспользованиеВнешнихРесурсов(НовыеРазрешения));
	
КонецПроцедуры

// См. СтандартныеПодсистемыСервер.ПриОпределенииМетодовРазрешенныхДляВызоваКакПроизвольныйКод
//
Процедура ПриОпределенииМетодовРазрешенныхДляВызоваКакПроизвольныйКод(Методы) Экспорт
	
	Методы.Вставить("АктивироватьЗаказСПодготовкойВложений", Истина);
	Методы.Вставить("АктуализироватьURLShare", Истина);
	Методы.Вставить("ВключитьНастройкуПодключения", Истина);
	Методы.Вставить("ДеактивироватьЗаказ", Истина);
	Методы.Вставить("ЗагрузкаСтатусовОнлайнЗаказов", Истина);
	Методы.Вставить("НоваяНастройкаПодключения", Истина);
	Методы.Вставить("НовыйЗаказ", Истина);
	Методы.Вставить("ОбновитьЗаказСВложениями", Истина);
	Методы.Вставить("ОбновитьНастройку", Истина);
	Методы.Вставить("ОбновитьНастройкуСОтзывомТокенов", Истина);
	Методы.Вставить("ОбновитьНастройкуСРевизиейТокенов", Истина);
	Методы.Вставить("ОбновитьПризнакиИспользованияНастроекОплатФискализации");
	Методы.Вставить("ОбновлениеНастроекПодключения", Истина);
	Методы.Вставить("ОтозватьНеиспользуемыеТокеныНастройкиПодключения", Истина);
	Методы.Вставить("ОтправитьВложения", Истина);
	Методы.Вставить("ПривязатьНастройкуПлатежнойСистемы", Истина);
	Методы.Вставить("СтатусЗаказа", Истина);
	
КонецПроцедуры

#КонецОбласти

#Область БСППодключаемыеКоманды

// См. ПодключаемыеКомандыПереопределяемый.ПриОпределенииКомандПодключенныхКОбъекту.
//
Процедура ПриОпределенииКомандПодключенныхКОбъекту(
		НастройкиФормы,
		Источники,
		ПодключенныеОтчетыИОбработки,
		Команды) Экспорт
	
	Если Не ОнлайнЗаказыДоступны() Тогда
		Возврат;
	КонецЕсли;
	
	НастройкиПодключаемыхКоманд = НастройкиПодключаемыхКоманд();
	
	ТипыОбъектов = Новый Массив;
	Для Каждого ПолноеИмя Из НастройкиПодключаемыхКоманд.ИменаОснованийЗаказа Цикл
		Менеджер = ОбщегоНазначения.МенеджерОбъектаПоПолномуИмени(ПолноеИмя);
		ТипыОбъектов.Добавить(ТипЗнч(Менеджер.ПустаяСсылка()));
	КонецЦикла;
	Если Не ЗначениеЗаполнено(ТипыОбъектов) Тогда
		Возврат;
	КонецЕсли;
	
	ТипПараметра = Новый ОписаниеТипов(ТипыОбъектов);
	
	ПараметрыКоманды = НастройкиПодключаемыхКоманд.ПараметрыКоманды;
	
	Команда = Команды.Добавить();
	Если ЗначениеЗаполнено(ПараметрыКоманды.Вид) Тогда
		Команда.Вид = ПараметрыКоманды.Вид;
	Иначе
		Команда.Вид = "ОнлайнЗаказы";
	КонецЕсли;
	Команда.Идентификатор = "ОнлайнЗаказы";
	Если ЗначениеЗаполнено(ПараметрыКоманды.Представление) Тогда
		Команда.Представление = ПараметрыКоманды.Представление;
	Иначе
		Команда.Представление = НСтр("ru = 'Онлайн-заказ'");
	КонецЕсли;
	Команда.Важность = "Обычное";
	Команда.Порядок = 52;
	Команда.ОтображениеКнопки = ОтображениеКнопки.Картинка;
	Если ЗначениеЗаполнено(ПараметрыКоманды.Картинка) Тогда
		Команда.Картинка = ПараметрыКоманды.Картинка;
	Иначе
		Команда.Картинка = БиблиотекаКартинок.ЛоготипОнлайнЗаказы;
	КонецЕсли;
	Команда.ТипПараметра = ТипПараметра;
	Команда.Назначение = ПараметрыКоманды.Назначение;
	Команда.ИзменяетВыбранныеОбъекты = Ложь;
	Команда.МножественныйВыбор = Ложь;
	Команда.РежимЗаписи = "Записывать";
	Команда.Обработчик = "ОнлайнЗаказыКлиент.Подключаемый_ОткрытьФормуURLЗаказа";
	
КонецПроцедуры

// См. ПодключаемыеКомандыПереопределяемый.ПриОпределенииВидовПодключаемыхКоманд.
//
Процедура ПриОпределенииВидовПодключаемыхКоманд(ВидыПодключаемыхКоманд) Экспорт
	
	Вид = ВидыПодключаемыхКоманд.Добавить();
	Вид.Имя = "ОнлайнЗаказы";
	Вид.ИмяПодменю = "ПодменюОнлайнЗаказы";
	Вид.Заголовок = НСтр("ru = 'Онлайн-заказ'");
	Вид.Картинка = БиблиотекаКартинок.ЛоготипОнлайнЗаказы;
	Вид.Отображение = ОтображениеКнопки.Картинка;
	Вид.ВидГруппыФормы = ВидГруппыФормы.Подменю;
	
КонецПроцедуры

// См. ПодключаемыеКомандыПереопределяемый.ПриОпределенииСоставаНастроекПодключаемыхОбъектов.
//
Процедура ПриОпределенииСоставаНастроекПодключаемыхОбъектов(НастройкиПрограммногоИнтерфейса) Экспорт
	
	Настройка = НастройкиПрограммногоИнтерфейса.Добавить();
	Настройка.Ключ = "ДобавитьКомандыОнлайнЗаказы";
	Настройка.ОписаниеТипов = Новый ОписаниеТипов("Булево");
	Настройка.ВидыПодключаемыхОбъектов = "Отчет, Обработка";
	
КонецПроцедуры

#КонецОбласти

#Область ОбновлениеИнформационнойБазы

// См. ОбновлениеИнформационнойБазыБСП.ПриДобавленииОбработчиковОбновления
//
Процедура ПриДобавленииОбработчиковОбновления(Обработчики) Экспорт
	
	Обработчик = Обработчики.Добавить();
	Обработчик.Версия              = "2.8.4.25";
	Обработчик.Процедура           = "ОнлайнЗаказыСлужебный.ОбновитьПризнакиИспользованияНастроекОплатФискализации";
	Обработчик.ОбщиеДанные         = Ложь;
	Обработчик.НачальноеЗаполнение = Ложь;
	Обработчик.Комментарий         = НСтр("ru='Установка признака использования оплат в настройках подключения'");
	Обработчик.РежимВыполнения     = "Отложенно";
	Обработчик.БлокируемыеОбъекты  = "Справочник.НастройкиПодключенияКОнлайнЗаказам.ФормаЭлемента";
	Обработчик.ПроцедураПроверки   = "ОбновлениеИнформационнойБазы.ДанныеОбновленыНаНовуюВерсиюПрограммы";
	Обработчик.Идентификатор       = Новый УникальныйИдентификатор("c9f2d6e8-a1cf-4040-a225-01b1c41557c0");
	
КонецПроцедуры

#КонецОбласти

#Область УправлениеДоступом

// См. УправлениеДоступомПереопределяемый.ПриЗаполненииВидовОграниченийПравОбъектовМетаданных.
//
Процедура ПриЗаполненииВидовОграниченийПравОбъектовМетаданных(Описание) Экспорт
	
	Описание = Описание + "
	|Справочник.НастройкиПодключенияКОнлайнЗаказам.Чтение.Организации
	|Справочник.НастройкиПодключенияКОнлайнЗаказам.Изменение.Организации
	|РегистрСведений.ИдентификаторыОнлайнЗаказов.Чтение.Организации
	|РегистрСведений.ИдентификаторыОнлайнЗаказов.Изменение.Организации
	|";
	
КонецПроцедуры

// См. УправлениеДоступомПереопределяемый.ПриЗаполненииСписковСОграничениемДоступа
Процедура ПриЗаполненииСписковСОграничениемДоступа(Списки) Экспорт
	
	Списки.Вставить(Метаданные.Справочники.НастройкиПодключенияКОнлайнЗаказам, Истина);
	Списки.Вставить(Метаданные.РегистрыСведений.ИдентификаторыОнлайнЗаказов, Истина);
	
КонецПроцедуры

#КонецОбласти

#КонецОбласти

#Область ТехнологияСервисаОчередьЗаданий

// См. ОчередьЗаданийПереопределяемый.ПриОпределенииПсевдонимовОбработчиков
//
Процедура ПриОпределенииПсевдонимовОбработчиков(СоответствиеИменПсевдонимам) Экспорт
	
	СоответствиеИменПсевдонимам.Вставить(
		Метаданные.РегламентныеЗадания.ЗагрузкаСтатусовОнлайнЗаказов.ИмяМетода);
	
КонецПроцедуры

#КонецОбласти

#Область БазоваяФункциональностьБИП

// Вызывается при изменении логина и пароля пользователя ИПП в
// информационной базе из всех контекстов использования библиотеки.
//
Процедура ПриИзмененииДанныхАутентификации(Логин) Экспорт
	
	Если ЗначениеЗаполнено(Логин) Тогда
		Если Справочники.НастройкиПодключенияКОнлайнЗаказам.ЕстьНастройкиПодключения() Тогда
			ДобавитьЗаданиеЗагрузкаСтатусовЗаказов();
		КонецЕсли;
	Иначе
		УдалитьЗаданияЗагрузкаСтатусовЗаказов();
	КонецЕсли;
	
КонецПроцедуры

// Заполняет описание используемых в подсистеме хостов сервисов Интернет-поддержки.
//
// Параметры:
//  ХостыСервисовИнтернетПоддержки - Соответствие - хост и название используемого сервиса.
//
Процедура ПриЗаполненииХостовСервисовИнтернетПоддержки(
		ХостыСервисовИнтернетПоддержки) Экспорт
	
	ХостыСервисовИнтернетПоддержки.Вставить(
		ОнлайнЗаказыКлиентСервер.ХостСервисаОбменаДанными(),
		НСтр("ru = 'Онлайн-заказы'"));
	
КонецПроцедуры

#КонецОбласти

#Область НастройкиПрограммы

// Возвращает параметры окружения панели администрирования БИП.
//
// Возвращаемое значение:
//  Структура:
//    * ОнлайнЗаказыДоступны - Булево
//    * НастройкаОнлайнЗаказовДоступна - Булево
//
Функция ПараметрыОкруженияФормыИнтернетПоддержкаИСервисы() Экспорт
	
	Результат = Новый Структура();
	Результат.Вставить("ОнлайнЗаказыДоступны", ОнлайнЗаказы.ОнлайнЗаказыДоступны());
	Результат.Вставить("НастройкаОнлайнЗаказовДоступна", ОнлайнЗаказы.НастройкаОнлайнЗаказовДоступна());
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти

#Область НастройкиПодключения

// Возвращает признак существования настроек подключения, в которых указана переданная настройка подключения.
//
// Параметры:
//  НастройкаОплаты - СправочникСсылка.НастройкиПодключенияКСистемеБыстрыхПлатежей,
//    СправочникСсылка.НастройкиПодключенияКИнтернетЭквайрингу,
//    СправочникСсылка.НастройкиПодключенияКПлатежнымСистемам - искомая настройка подключения.
//
// Возвращаемое значение:
//  Булево - признак наличия настроек.
//
Функция СуществуютНастройкиПоНастройкеОплаты(НастройкаОплаты) Экспорт
	
	Возврат Справочники.НастройкиПодключенияКОнлайнЗаказам.СуществуютНастройкиПоНастройкеОплаты(
		НастройкаОплаты);
	
КонецФункции

// Определяет перечень введенных настроек онлайн-заказов по переданной настройке оплаты и организации.
//
// Параметры:
//  НастройкаОплаты - СправочникСсылка.НастройкиПодключенияКСистемеБыстрыхПлатежей,
//    СправочникСсылка.НастройкиПодключенияКСистемеБыстрыхПлатежей - настройка подключения к платежной системе.
//  Организация - ОпределяемыйТип.Организация, Неопределено - Организация по которой выполняется запрос,
//    Неопределено если отбор по организации не нужен.
//  БезОшибокСинхронизации - Булево - В случае Истина будут отобраны настройки без ошибок в синхронизации,
//    в случае Ложь отбор не накладывается.
//
// Возвращаемое значение:
//  Массив Из Справочник.НастройкиПодключенияКОнлайнЗаказам - перечень настроек.
//
Функция НастройкиПодключенияПоНастройкеОплаты(НастройкаОплаты, Организация, БезОшибокСинхронизации) Экспорт
	
	Возврат Справочники.НастройкиПодключенияКОнлайнЗаказам.НастройкиПодключенияПоНастройкеОплаты(
		НастройкаОплаты,
		Организация,
		БезОшибокСинхронизации);
		
КонецФункции

// Возвращает признак существования настроек онлайн-заказов с заполненными зависимыми настройками.
//
// Возвращаемое значение:
//  Булево - признак заполненности зависимых настроек (способов оплат, облачная касса).
//
Функция ЕстьЗаполненныеЗависимыеНастройки() Экспорт
	
	Возврат Справочники.НастройкиПодключенияКОнлайнЗаказам.ЕстьЗаполненныеЗависимыеНастройки();
	
КонецФункции

// Выполняет привязку настройки подключение к платежным система к настройке подключения к Онлайн-заказам.
// Если у настройки Онлайн-заказов уже используется настройка подключения такого же типа, то она будет заменена.
// 
// Параметры:
//  НастройкаОнлайнЗаказов - СправочникСсылка.НастройкиПодключенияКОнлайнЗаказам - настройка подключения к
//    Онлайн-заказам, к которой нужно добавить новую настройку подключения.
//  НастройкаПодключения - СправочникСсылка.НастройкиПодключенияКСистемеБыстрыхПлатежей,
//    СправочникСсылка.НастройкиПодключенияКИнтернетЭквайрингу,
//    СправочникСсылка.НастройкиПодключенияКПлатежнымСистемам - настройка подключения к платежной системе, которую
//      нужно добавить в настройку подключения к Онлайн-заказам.
//  ПлатежныйСервис - Строка - идентификатор платежного сервиса. Доступные значения определены в методе
//                             СпособОплатыПоИдентификатору.
//                  - ПеречислениеСсылка.ПлатежныеСервисы - для подсистемы ПлатежныеСервисы.
//                  - Неопределено - платежный сервис будет определен на основе параметра НастройкаПодключения.
//  
// Возвращаемое значение:
//  См. НовыйРезультатОперации.
//
Функция ПривязатьНастройкуПлатежнойСистемы(
		НастройкаОнлайнЗаказов,
		НастройкаПодключения,
		ПлатежныйСервис = Неопределено) Экспорт
	
	Результат = НовыйРезультатОперации();
		
	Если Не ЗначениеЗаполнено(НастройкаОнлайнЗаказов) Тогда
		Результат.КодОшибки = КодОшибкиНеверныйФорматЗапроса();
		Результат.СообщениеОбОшибке = НСтр("ru = 'Не указана настройка подключения к Онлайн-заказам.'");
		Результат.ИнформацияОбОшибке = Результат.СообщениеОбОшибке;
		Возврат Результат;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(НастройкаПодключения) Тогда
		Результат.КодОшибки = КодОшибкиНеверныйФорматЗапроса();
		Результат.СообщениеОбОшибке = НСтр("ru = 'Не указана настройка подключения к платежной системе.'");
		Результат.ИнформацияОбОшибке = Результат.СообщениеОбОшибке;
		Возврат Результат;
	КонецЕсли;
	
	СпособОплаты = СпособОплатыПоНастройке(ПлатежныйСервис, НастройкаПодключения);
	
	Если Не ЗначениеЗаполнено(СпособОплаты) Тогда
		Результат.КодОшибки = КодОшибкиНеверныйФорматЗапроса();
		Результат.СообщениеОбОшибке = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
			НСтр("ru = 'Не удалось определить способ оплаты:
				|Настройка подключения - %1
				|Платежный сервис - %2'"),
			НастройкаПодключения,
			ПлатежныйСервис);
		Результат.ИнформацияОбОшибке = Результат.СообщениеОбОшибке;
		Возврат Результат;
	КонецЕсли;
	
	НачатьТранзакцию();
	
	Попытка
		
		Блокировка = Новый БлокировкаДанных;
		ЭлементБлокировки = Блокировка.Добавить("Справочник.НастройкиПодключенияКОнлайнЗаказам");
		ЭлементБлокировки.УстановитьЗначение("Ссылка", НастройкаОнлайнЗаказов);
		ЭлементБлокировки.Режим = РежимБлокировкиДанных.Исключительный;
		Блокировка.Заблокировать();
		
		НастройкаОнлайнЗаказовОбъект = НастройкаОнлайнЗаказов.ПолучитьОбъект();
		НастройкаОнлайнЗаказовОбъект.Заблокировать();
		НастройкаОнлайнЗаказовОбъект.Используется = Истина;
		
		Отбор = Новый Структура;
		Отбор.Вставить("СпособОплаты", СпособОплаты);
		
		УдаленнаяНастройкаОплаты = Новый Структура;
		
		НайденныеЗначения = НастройкаОнлайнЗаказовОбъект.НастройкиОплаты.НайтиСтроки(Отбор);
		
		Для Каждого НайденноеЗначение Из НайденныеЗначения Цикл
			УдаленнаяНастройкаОплаты.Вставить("СпособОплаты", НайденноеЗначение.СпособОплаты);
			УдаленнаяНастройкаОплаты.Вставить("НастройкаПодключения", НайденноеЗначение.НастройкаПодключения);
			НастройкаОнлайнЗаказовОбъект.НастройкиОплаты.Удалить(НайденноеЗначение);
		КонецЦикла;
		
		Если ЗначениеЗаполнено(УдаленнаяНастройкаОплаты) Тогда
			РезультатОтзыва = ОтозватьТокенНастройкиПодключения(
				ИдентификаторВидаТокенаПриемОплат(),
				УдаленнаяНастройкаОплаты.НастройкаПодключения,
				УдаленнаяНастройкаОплаты.СпособОплаты);
				
			Если ЗначениеЗаполнено(РезультатОтзыва.КодОшибки) Тогда
				ВызватьИсключение НСтр("ru = 'Не удалось отозвать существующий токен.'");
			КонецЕсли;
		КонецЕсли;
		
		НастройкаОплаты = НастройкаОнлайнЗаказовОбъект.НастройкиОплаты.Добавить();
		НастройкаОплаты.СпособОплаты = СпособОплаты;
		НастройкаОплаты.НастройкаПодключения = НастройкаПодключения;
		
		НастройкаОнлайнЗаказовОбъект.Записать();
		
		РезультатОбновления = ОбновитьНастройку(НастройкаОнлайнЗаказов);
		
		Если ЗначениеЗаполнено(РезультатОбновления.КодОшибки) Тогда
			ВызватьИсключение НСтр("ru = 'Не удалось обновить настройку в сервисе.'");
		КонецЕсли;
		
		ЗафиксироватьТранзакцию();
		
	Исключение
		
		ОтменитьТранзакцию();
		
		Результат.КодОшибки = КодОшибкиНеизвестнаяОшибка();
		Результат.СообщениеОбОшибке = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
				НСтр("ru = 'Ошибка привязки настроек:
					|%1'"),
				ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
		Результат.ИнформацияОбОшибке = Результат.СообщениеОбОшибке;
		Возврат Результат;
		
	КонецПопытки;
	
	Возврат Результат;
		
КонецФункции

#КонецОбласти

#Область ШаблоныСообщений

// См. ШаблоныСообщенийПереопределяемый.ПриПодготовкеШаблонаСообщения.
//
Процедура ПриПодготовкеШаблонаСообщения(
		Реквизиты,
		Вложения,
		НазначениеШаблона,
		ДополнительныеПараметры) Экспорт
	
	Если ПустаяСтрока(НазначениеШаблона) Тогда
		Возврат;
	КонецЕсли;
	
	Если Не ЭтоДокументОнлайнЗаказов(НазначениеШаблона) Тогда
		Возврат;
	КонецЕсли;
	
	ПараметрыОтправкиСообщений = НовыйПараметрыОтправкиСообщений();
	ПриОпределенииПараметровОтправкиСообщений(ПараметрыОтправкиСообщений);
	
	НовыйРеквизит = Реквизиты.Добавить();
	НовыйРеквизит.Имя = "ПредставлениеСсылкиОнлайнЗаказа";
	НовыйРеквизит.Представление = НСтр("ru = 'Ссылка на онлайн-заказ'");
	
	НовыйРеквизит = Реквизиты.Добавить();
	НовыйРеквизит.Имя = "СуммаОнлайнЗаказа";
	НовыйРеквизит.Представление = НСтр("ru = 'Сумма онлайн-заказа'");
	
КонецПроцедуры

// См. ШаблоныСообщенийПереопределяемый.ПриФормированииСообщения.
//
Процедура ПриФормированииСообщения(
		Сообщение,
		НазначениеШаблона,
		ПредметСообщения,
		ПараметрыШаблона) Экспорт
	
	Если ПустаяСтрока(НазначениеШаблона) Тогда 
		Возврат;
	КонецЕсли;
	
	Если Не ЭтоДокументОнлайнЗаказов(НазначениеШаблона) Тогда
		Возврат;
	КонецЕсли;
	
	Если Сообщение.ЗначенияРеквизитов["СуммаОнлайнЗаказа"] = Неопределено
		И Сообщение.ЗначенияРеквизитов["ПредставлениеСсылкиОнлайнЗаказа"] = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ПараметрыСообщения = ДанныеЗаполненияШаблона(
		ПредметСообщения,
		Сообщение);
	
	Если Сообщение.ЗначенияРеквизитов["СуммаОнлайнЗаказа"] <> Неопределено
			И ПараметрыСообщения.СуммаОнлайнЗаказа <> Неопределено Тогда
		Сообщение.ЗначенияРеквизитов["СуммаОнлайнЗаказа"] = ПараметрыСообщения.СуммаОнлайнЗаказа;
	КонецЕсли;
	
	Если ПараметрыСообщения.ПредставлениеСсылкиОнлайнЗаказа <> Неопределено Тогда
		ЗаполнитьПредставлениеСсылки(
			Сообщение,
			ПараметрыШаблона,
			ПараметрыСообщения.ПредставлениеСсылкиОнлайнЗаказа);
	КонецЕсли;
	
КонецПроцедуры

