// @strict-types

#Область СлужебныеПроцедурыИФункции

#Область Черновик

// Параметры:
//  Доверенность - СправочникСсылка.МЧД003
//  АдресДанных - Строка
//  ИдентификаторФормы - УникальныйИдентификатор
// 
// Возвращаемое значение:
//  См. ДлительныеОперации.ВыполнитьФункцию
Функция ЗаписатьЧерновикВЦентрЭДОВФоне(Знач Доверенность, Знач АдресДанных, Знач ИдентификаторФормы) Экспорт
	
	ПараметрыВыполненияВФоне = ДлительныеОперации.ПараметрыВыполненияФункции(ИдентификаторФормы);
	
	ДанныеФайлаМЧД = ПолучитьИзВременногоХранилища(АдресДанных);
	
	// См. МашиночитаемыеДоверенностиИнтеграцияЦентраЭДО.ЗаписатьЧерновикВЦентрЭДО
	ДлительнаяОперация = ДлительныеОперации.ВыполнитьФункцию(ПараметрыВыполненияВФоне,
		"МашиночитаемыеДоверенностиИнтеграцияЦентраЭДО.ЗаписатьЧерновикВЦентрЭДО",
		Доверенность, ДанныеФайлаМЧД);
	
	Возврат ДлительнаяОперация;
	
КонецФункции

#КонецОбласти

#Область ВыгрузитьВЦентрЭДО

// Параметры:
//  Доверенности - Массив из ОпределяемыйТип.МашиночитаемаяДоверенность
//  ИдентификаторФормы - Неопределено,УникальныйИдентификатор
// 
// Возвращаемое значение:
//  - Неопределено
//  - См. ДлительныеОперации.ВыполнитьФункцию
Функция ВыгрузитьВФонеДляЕдинственнойУчетнойЗаписиЦентраЭДО(Знач Доверенности, Знач ИдентификаторФормы) Экспорт
	
	УчетнаяЗаписьЦентраЭДО = ИнтеграцияЦентраЭДО.ЕдинственнаяУчетнаяЗаписьЦентраЭДО();
	Если Не ЗначениеЗаполнено(УчетнаяЗаписьЦентраЭДО) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Возврат ВыгрузитьВФоне(ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(УчетнаяЗаписьЦентраЭДО),
		Доверенности, ИдентификаторФормы);
	
КонецФункции

// Параметры:
//  УчетныеЗаписиЦентровЭДО - Массив из СправочникСсылка.УчетныеЗаписиЦентровЭДО
//  Доверенности - Массив из ОпределяемыйТип.МашиночитаемаяДоверенность
//  ИдентификаторФормы - УникальныйИдентификатор
// 
// Возвращаемое значение:
//  См. ДлительныеОперации.ВыполнитьФункцию
Функция ВыгрузитьВФоне(Знач УчетныеЗаписиЦентровЭДО, Знач Доверенности, Знач ИдентификаторФормы) Экспорт
	
	ПараметрыВыполненияВФоне = ДлительныеОперации.ПараметрыВыполненияФункции(ИдентификаторФормы);
	
	// См. МашиночитаемыеДоверенностиИнтеграцияЦентраЭДО.ВыгрузитьВЦентрЭДО
	ДлительнаяОперация = ДлительныеОперации.ВыполнитьФункцию(ПараметрыВыполненияВФоне,
		"МашиночитаемыеДоверенностиИнтеграцияЦентраЭДО.ВыгрузитьВЦентрЭДО",
		УчетныеЗаписиЦентровЭДО, Доверенности);
	
	Возврат ДлительнаяОперация;
	
КонецФункции

#КонецОбласти

#КонецОбласти
