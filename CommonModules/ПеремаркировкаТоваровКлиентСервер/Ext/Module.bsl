// Определяет допустимый способ ввода в оборот при перемаркировке
//
// Параметры:
//  ВидПродукцииТоварнаяГруппа - СправочникСсылка.КлючиВидовПродукцииИС,
//                               СправочникСсылка.ВидыПродукцииИС,
//                               Массив из СправочникСсылка.ВидыПродукцииИС - Виды продукции,
//                               СправочникСсылка.ТоварныеГруппыГИСМТ - Товарная группа.
// Возвращаемое значение:
//  ПеречислениеСсылка.СпособыВводаВОборотСУЗ - способ ввода в оборот.
Функция СпособВводаВОборотПриПеремаркировке(ВидПродукцииТоварнаяГруппа) Экспорт
	
	Результат = Неопределено;
	
	Способы = КонструкторИСОбщегоНазначенияКлиентСервер.ЗначенияЭлементаКонструктораПоВидуПродукции(
		ПредопределенноеЗначение(
			"Справочник.ЭлементыКонструктораВидовПродукцииИС.СпособВводаВОборотПриПеремаркировке"),
		КонструкторИСМПОбщегоНазначенияКлиентСервер.ВидыПродукции(ВидПродукцииТоварнаяГруппа));
	
	Если Способы.Количество() > 0 Тогда
		Результат = Способы[0];
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

