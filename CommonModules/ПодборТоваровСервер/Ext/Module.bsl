	Если ЭтоФормаПодбораВДокументыЗакупки Тогда
		ПараметрыУсловногоОформления = НоменклатураСервер.НовыеПараметрыУсловногоОформленияЕдиницИзмерения();
		ПараметрыУсловногоОформления.ИмяПоляЕдиницаИзмерения = "СписокСтандартныйПоискНоменклатураПартнера";
		ПараметрыУсловногоОформления.ПутьКПолюУпаковка = "СписокНоменклатура.Упаковка";
		НоменклатураСервер.УстановитьУсловноеОформлениеЕдиницИзмерения(Форма, ПараметрыУсловногоОформления);
		
		ПараметрыУсловногоОформления = НоменклатураСервер.НовыеПараметрыУсловногоОформленияЕдиницИзмерения();
		ПараметрыУсловногоОформления.ИмяПоляЕдиницаИзмерения = "СписокРасширенныйПоискНоменклатураПартнера";
		ПараметрыУсловногоОформления.ПутьКПолюУпаковка = "СписокНоменклатура.Упаковка";
		НоменклатураСервер.УстановитьУсловноеОформлениеЕдиницИзмерения(Форма, ПараметрыУсловногоОформления);
	КонецЕсли;
	
	//

	Элемент = УсловноеОформление.Элементы.Добавить();
	
	ПолеЭлемента = Элемент.Поля.Элементы.Добавить();
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(Элементы.ВидНоменклатуры.Имя);

	ОтборЭлемента = Элемент.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ОтборЭлемента.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("ИспользоватьФильтры");
	ОтборЭлемента.ВидСравнения = ВидСравненияКомпоновкиДанных.Равно;
	ОтборЭлемента.ПравоеЗначение = Истина;

	ОтборЭлемента = Элемент.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ОтборЭлемента.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("ВидНоменклатуры");
	ОтборЭлемента.ВидСравнения = ВидСравненияКомпоновкиДанных.НеЗаполнено;
	Элемент.Оформление.УстановитьЗначениеПараметра("ОтметкаНезаполненного", Истина);

	//

	Элемент = УсловноеОформление.Элементы.Добавить();

	ПолеЭлемента = Элемент.Поля.Элементы.Добавить();
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(Элементы.ОтборЦенаОт.Имя);

	ПолеЭлемента = Элемент.Поля.Элементы.Добавить();
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(Элементы.ОтборЦенаДо.Имя);

	ОтборЭлемента = Элемент.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ОтборЭлемента.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("ОтборЦенаОт");
	ОтборЭлемента.ВидСравнения = ВидСравненияКомпоновкиДанных.Больше;
	ОтборЭлемента.ПравоеЗначение = Новый ПолеКомпоновкиДанных("ОтборЦенаДо");

	ОтборЭлемента = Элемент.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ОтборЭлемента.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("ОтборЦенаДо");
	ОтборЭлемента.ВидСравнения = ВидСравненияКомпоновкиДанных.Больше;
	ОтборЭлемента.ПравоеЗначение = 0;

	Элемент.Оформление.УстановитьЗначениеПараметра("ЦветФона", ЦветаСтиля.ПолеСОшибкойФон);
	
КонецПроцедуры	

// Возвращает владельца характеристик номенклатуры. В зависимости от настроек
// вида номенклатуры это может быть либо вид номенклатуры, либо номенклатура.
//
// Параметры:
//	Номенклатура - СправочникСсылка.Номенклатура - номенклатура
//
// Возвращаемое значение:
//	СправочникСсылка.Номенклатура, СправочникСсылка.ВидыНоменклатуры, Неопределено - 
//
Функция ВладелецХарактеристикНоменклатуры(Номенклатура)
	
	Реквизиты = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Номенклатура, "ВидНоменклатуры,ИспользованиеХарактеристик,ВладелецХарактеристик");
	
	Если Реквизиты.ИспользованиеХарактеристик = Перечисления.ВариантыИспользованияХарактеристикНоменклатуры.ОбщиеДляВидаНоменклатуры Тогда
		Возврат Реквизиты.ВидНоменклатуры;
	ИначеЕсли Реквизиты.ИспользованиеХарактеристик = Перечисления.ВариантыИспользованияХарактеристикНоменклатуры.ИндивидуальныеДляНоменклатуры Тогда
		Возврат Номенклатура;
	ИначеЕсли Реквизиты.ИспользованиеХарактеристик = Перечисления.ВариантыИспользованияХарактеристикНоменклатуры.ОбщиеСДругимВидомНоменклатуры Тогда
		Возврат Реквизиты.ВладелецХарактеристик;
	Иначе
		Возврат Неопределено;
	КонецЕсли;
	
КонецФункции

#КонецОбласти

#Область ПроцедурыИФункцииФормированияТекстовЗапросов

// Возвращает текст запроса для динамического списка формы подбора.
//
// Параметры:
// 	Форма - ФормаКлиентскогоПриложения - форма подбора
// 	ТипСписка - Строка - тип списка формы подбора
//
// Возвращаемое значение:
// 	Строка - текст запроса списка формы подбора
//
Функция ТекстЗапросаСпискаФормыПодбора(Форма, ТипСписка)
	
	ПараметрыПостроения = ПодборТоваровКлиентСервер.НовыйПараметрыПостроенияЗапросаСписка();
	ПараметрыПостроения.ТипСписка = ТипСписка;
	ПараметрыПостроения.ТолькоВНаличии = Форма.ТолькоВНаличии;
	ПараметрыПостроения.НесколькоСкладов = Форма.Склады.Количество() > 1;
	ПараметрыПостроения.РежимПодбораБезСуммовыхПараметров = Форма.РежимПодбораБезСуммовыхПараметров;
	ПараметрыПостроения.ОтображатьОстаткиНаСкладах = Форма.ОтображатьОстаткиНаСкладах;
	ПараметрыПостроения.ЕстьКурсыВБудущем = ЕстьЗначенияКурсовВалютПозжеДатыПодбора(Форма.Дата);
	
	Если Форма.ИспользоватьХарактеристикиНоменклатуры Тогда
		
		ВариантыНавигацииСХарактеристиками = Новый Массив;
		ВариантыНавигацииСХарактеристиками.Добавить(Перечисления.ВариантыНавигацииВФормахНоменклатуры.ПоСвойствам);
		ВариантыНавигацииСХарактеристиками.Добавить(Перечисления.ВариантыНавигацииВФормахНоменклатуры.ПоВидамИСвойствам);
		ВариантыНавигацииСХарактеристиками.Добавить(Перечисления.ВариантыНавигацииВФормахНоменклатуры.ПоВидам);
		
		Если Форма.ИспользоватьФильтры
			И ЗначениеЗаполнено(Форма.ВидНоменклатуры)
			И ВариантыНавигацииСХарактеристиками.Найти(Форма.ВариантНавигации) <> Неопределено Тогда
			
			ВидНоменклатурыОтбор = Форма.ВидНоменклатуры; // СправочникСсылка.ВидыНоменклатуры
			ИспользованиеХарактеристик = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(
				ВидНоменклатурыОтбор,
				"ИспользованиеХарактеристик");
			
			Если ИспользованиеХарактеристик <>
				Перечисления.ВариантыИспользованияХарактеристикНоменклатуры.НеИспользовать Тогда
				
				ПараметрыПостроения.ИспользоватьХарактеристикиНоменклатуры = Истина;
				
			КонецЕсли;
			
		Иначе
			ПараметрыПостроения.ИспользоватьХарактеристикиНоменклатуры = Истина;
		КонецЕсли;
		
	КонецЕсли;
	
	Если ПодборТоваровКлиентСервер.ЭтоФормаПодбораВДокументыПродажи(Форма.КодФормы) Тогда
		
		ПараметрыПостроения.ТипФормы = "ПодборВДокументыПродажи";
		ПараметрыПостроения.ЭтоПартнер = ПраваПользователяПовтИсп.ЭтоПартнер();
		ПараметрыПостроения.ИспользуетсяЦенообразование25 = Форма.ИспользуетсяЦенообразование25;
		ПараметрыПостроения.ВариантРасчетаЦен = Форма.ВариантРасчетаЦен;
		ПараметрыПостроения.РежимОтбораПоАссортименту = Форма.РежимОтбораПоАссортименту;
		ПараметрыПостроения.НеИспользоватьВидыЦенПоУсловиюПродаж = Форма.НеИспользоватьВидыЦенПоУсловиюПродаж;
		ПараметрыПостроения.НесколькоВидовЦен = Форма.ВидыЦен.Количество() > 1;
		ПараметрыПостроения.ОтображатьОстаткиПоНазначению = ЗначениеЗаполнено(Форма.ОтборПоНазначениюТекущий);
		ПараметрыПостроения.ОтображатьОстаткиКонтролируемойПартии = ЗначениеЗаполнено(Форма.КонтролируемаяПартия);
		ПараметрыПостроения.ЕстьЦеныВБудущем = Форма.ЕстьЦеныВБудущем;
		
		Если Форма.ОтборПоТипуНоменклатуры.НайтиПоЗначению(Перечисления.ТипыНоменклатуры.Набор) <> Неопределено
			Или Форма.ОтборПоТипуНоменклатуры.Количество() = 0 Тогда
			
			ПараметрыПостроения.ИспользоватьКомплекты = ПолучитьФункциональнуюОпцию("ИспользоватьНаборы");
			
		КонецЕсли;
		
	ИначеЕсли ПодборТоваровКлиентСервер.ЭтоФормаПодбораВДокументыЗакупки(Форма.КодФормы) Тогда
		
		ВариантРасчетаЦенПоставщика = "ЦеныПоСоглашению";
		
		Если ЗначениеЗаполнено(Форма.Объект.Соглашение) Тогда
			Форма.ВидЦеныПоставщика = Форма.Объект.Соглашение.ВидЦеныПоставщика;
		Иначе
			ВариантРасчетаЦенПоставщика = "БезЦен";
		КонецЕсли;
		
		ПараметрыПостроения.ТипФормы = "ПодборВДокументыЗакупки";
		ПараметрыПостроения.ВариантРасчетаЦенПоставщика = ВариантРасчетаЦенПоставщика;
		ПараметрыПостроения.ЕстьЦеныНоменклатурыПоставщиковВБудущем = Форма.ЕстьЦеныНоменклатурыПоставщиковВБудущем;
		
	Иначе
		
		ВызватьИсключение НСтр("ru = 'Ошибка при открытии формы подбора'");
		
	КонецЕсли;
	
	ШаблонТекстЗапроса = СформироватьТекстЗапросаСпискаФормыПодбора(ПараметрыПостроения);
	
	//++ Локализация
	ИнтеграцияСМаркетплейсамиСерверЛокализация.ДополнитьТекстЗапросаДляМаркетплейсов(Форма, ШаблонТекстЗапроса, ТипСписка);
	Если ПодборТоваровКлиентСервер.ЭтоФормаПодбораВДокументыПродажи(Форма.КодФормы)
		И ТипСписка = "СписокНоменклатура" Тогда
		ПараметрыОтбора = ИнтеграцияИСУТ.ПараметрыОтбораНоменклатурыПоВидуПродукции(Форма);
		Если ПараметрыОтбора <> Неопределено Тогда
			// переопределение СКД для выбора номенклатуры с указанным видом продукции
			ИнтеграцияИСУТ.ПереопределитьТекстЗапросаДинамическогоСпискаНоменклатурыДляОтбораПоВидуПродукции(
				ШаблонТекстЗапроса, ПараметрыОтбора.ВидыПродукцииИС);
			ИнтеграцияИСУТ.УстановитьОтборНоменклатурыПоВидуПродукцииИС(
				Форма, ПараметрыОтбора.ВидыПродукцииИС, ПараметрыОтбора.ВидСравненияОтбора);
		Иначе
			ЭлементОтбора = ОбщегоНазначенияКлиентСервер.НайтиЭлементОтбораПоПредставлению(
				ОбщегоНазначенияУТКлиентСервер.ПолучитьОтборДинамическогоСписка(Форма.СписокНоменклатура).Элементы,
				"ОтборВидПродукцииИС");
			Если ЭлементОтбора <> Неопределено Тогда
				Если ТипЗнч(ЭлементОтбора.ПравоеЗначение) = Тип("СписокЗначений") Тогда
					ИнтеграцияИСУТ.ПереопределитьТекстЗапросаДинамическогоСпискаНоменклатурыДляОтбораПоВидуПродукции(
						ШаблонТекстЗапроса, ЭлементОтбора.ПравоеЗначение.ВыгрузитьЗначения());
				Иначе
					ИнтеграцияИСУТ.ПереопределитьТекстЗапросаДинамическогоСпискаНоменклатурыДляОтбораПоВидуПродукции(
						ШаблонТекстЗапроса, ЭлементОтбора.ПравоеЗначение);
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	//-- Локализация
	
	Возврат СокрЛП(ШаблонТекстЗапроса);
	
КонецФункции

// Выполняет построение запроса для списков номенклатуры и характеристик.
//
// Параметры:
// 	ПараметрыПостроенияЗапроса - см. ПодборТоваровКлиентСервер.НовыйПараметрыПостроенияЗапросаСписка
//
// Возвращаемое значение:
// 	Строка
//
Функция СформироватьТекстЗапросаСпискаФормыПодбора(ПараметрыПостроенияЗапроса) Экспорт
	
	Если ПараметрыПостроенияЗапроса.ТипФормы = "ПодборВДокументыПродажи" Тогда
		
		Если ПараметрыПостроенияЗапроса.ЭтоПартнер Тогда
			
			ПараметрыПостроенияЗапроса.ШаблонЗапроса =
			"ВЫБРАТЬ
			|	&ТекстПоляОбщиеПоля,
			|	&ТекстПоляУпаковка КАК Упаковка,
			|	&ТекстПоляВидЦены КАК ВидЦены,
			|	&ТекстПоляЦена КАК Цена
			|ИЗ
			|	#ОсновнаяТаблица
			|ГДЕ
			|	&ТекстОбщееУсловие";
			
			СформироватьТекстЗапросаВнешниеПользователи(ПараметрыПостроенияЗапроса);
			
		ИначеЕсли ПараметрыПостроенияЗапроса.РежимОтбораПоАссортименту Тогда
			
			ПараметрыПостроенияЗапроса.ШаблонЗапроса =
			"ВЫБРАТЬ
			|	&ТекстПоляОбщиеПоля,
			|	&ТекстПоляУпаковка КАК Упаковка,
			|	&ТекстПоляЦена КАК Цена,
			|	&ТекстПоляВНаличииОстаток КАК ВНаличииОстаток,
			|	&ТекстПоляВНаличииВБазовыхЕдиницах КАК ВНаличииВБазовыхЕдиницах,
			|	&ТекстПоляДоступноеКоличество КАК Доступно
			|ИЗ
			|	#ОсновнаяТаблица
			|ГДЕ
			|	&ТекстОбщееУсловие";
			
			СформироватьТекстЗапросаАссортимент(ПараметрыПостроенияЗапроса);
			
		Иначе
			
			ПараметрыПостроенияЗапроса.ШаблонЗапроса =
			"ВЫБРАТЬ
			|	&ТекстПоляОбщиеПоля,
			|	&ТекстПоляУпаковка КАК Упаковка,
			|	&ТекстПоляВидЦены КАК ВидЦены,
			|	&ТекстПоляЦена КАК Цена,
			|	&ТекстПоляВНаличииОстаток КАК ВНаличииОстаток,
			|	&ТекстПоляВНаличииВБазовыхЕдиницах КАК ВНаличииВБазовыхЕдиницах,
			|	&ТекстПоляДоступноеКоличество КАК Доступно
			|ИЗ
			|	#ОсновнаяТаблица
			|ГДЕ
			|	&ТекстОбщееУсловие";
			
			СформироватьТекстЗапросаПоПараметрамСоглашенияСКлиентом(ПараметрыПостроенияЗапроса);
			
		КонецЕсли;
		
	ИначеЕсли ПараметрыПостроенияЗапроса.ТипФормы = "ПодборВДокументыЗакупки" Тогда
		
		Если ПараметрыПостроенияЗапроса.ТипСписка = "СписокНоменклатураПартнера" Тогда
			
			ПараметрыПостроенияЗапроса.ШаблонЗапроса =
			"ВЫБРАТЬ
			|	&ТекстПоляОбщиеПоля,
			|	&ТекстПоляЦена КАК Цена,
			|	&ТекстПоляВидЦеныПоставщика КАК ВидЦеныПоставщика
			|ИЗ
			|	#ОсновнаяТаблица
			|ГДЕ
			|	&ТекстОбщееУсловие";
			
		ИначеЕсли ПараметрыПостроенияЗапроса.ТипСписка = "СписокНоменклатура"
			Или ПараметрыПостроенияЗапроса.ТипСписка = "СписокХарактеристики" Тогда
			
			ПараметрыПостроенияЗапроса.ШаблонЗапроса =
			"ВЫБРАТЬ
			|	&ТекстПоляОбщиеПоля,
			|	&ТекстПоляУпаковка КАК Упаковка,
			|	&ТекстПоляЦена КАК Цена,
			|	&ТекстПоляВалюта КАК Валюта,
			|	&ТекстПоляВНаличииОстаток КАК ВНаличииОстаток,
			|	&ТекстПоляВНаличииВБазовыхЕдиницах КАК ВНаличииВБазовыхЕдиницах,
			|	&ТекстПоляДоступноеКоличество КАК Доступно
			|ИЗ
			|	#ОсновнаяТаблица
			|ГДЕ
			|	&ТекстОбщееУсловие";
			
		КонецЕсли;
		
		СформироватьТекстЗапросаПоПараметрамСоглашенияСПоставщиком(ПараметрыПостроенияЗапроса);
		
	КонецЕсли;
	
	ДополнитьЗапросВременнымиТаблицами(ПараметрыПостроенияЗапроса);
	ВыполнитьЗаменыШаблоновВТекстеЗапроса(ПараметрыПостроенияЗапроса);
	
	ТекстЗапроса = ПараметрыПостроенияЗапроса.ШаблонЗапроса;
	
	Возврат ТекстЗапроса;
	
КонецФункции

// Дополняет шаблон запроса текстом создания временных таблиц.
//
// Параметры:
// 	ПараметрыПостроенияЗапроса - см. ПодборТоваровКлиентСервер.НовыйПараметрыПостроенияЗапросаСписка
//
Процедура ДополнитьЗапросВременнымиТаблицами(ПараметрыПостроенияЗапроса)
	
	ТекстыВременныхТаблиц = Новый Массив();
	
	Для Каждого ИмяВременнойТаблицы Из ПараметрыПостроенияЗапроса.ВременныеТаблицы Цикл
		
		Если ИмяВременнойТаблицы = "ТаблицаКурсовВалют"
			Или ИмяВременнойТаблицы = "ОбщаяТаблицаКурсовВалют" Тогда
			
			ТекстВременнойТаблицы = ТекстВременнойТаблицыКурсыВалют(
				ПараметрыПостроенияЗапроса,
				ИмяВременнойТаблицы = "ТаблицаКурсовВалют");
			
		ИначеЕсли ИмяВременнойТаблицы = "Ассортимент" Тогда
			
			ТекстВременнойТаблицы = ТекстВременнойТаблицыАссортимент(
				ПараметрыПостроенияЗапроса);
			
		Иначе
			ТекстВременнойТаблицы = "";
		КонецЕсли;
		
		ТекстВременнойТаблицы = СтрЗаменить(ТекстВременнойТаблицы,
			"ИмяВременнойТаблицы",
			ИмяВременнойТаблицы);
			
		Если ЗначениеЗаполнено(ТекстВременнойТаблицы) Тогда
			ТекстыВременныхТаблиц.Добавить(ТекстВременнойТаблицы);
		КонецЕсли;
		
	КонецЦикла;
	
	Если ТекстыВременныхТаблиц.Количество() Тогда
	
		ПараметрыПостроенияЗапроса.ШаблонЗапроса =
			СтрСоединить(ТекстыВременныхТаблиц, ОбщегоНазначения.РазделительПакетаЗапросов())
			+ ОбщегоНазначения.РазделительПакетаЗапросов()
			+ ПараметрыПостроенияЗапроса.ШаблонЗапроса;
		
	КонецЕсли;
	
КонецПроцедуры

// Выполняет построение запроса для списков номенклатуры и характеристик в режиме внешнего пользователя.
//
// Параметры:
// 	ПараметрыПостроенияЗапроса - см. ПодборТоваровКлиентСервер.НовыйПараметрыПостроенияЗапросаСписка
//
Процедура СформироватьТекстЗапросаВнешниеПользователи(ПараметрыПостроенияЗапроса)
	
	Если Не ЗначениеЗаполнено(ПараметрыПостроенияЗапроса.ШаблонЗапроса) Тогда
		Возврат;
	КонецЕсли;
	
	ЗаменыТекста = ПараметрыПостроенияЗапроса.ЗаменыТекста;
	
	ПараметрыПостроенияЗапроса.ВременныеТаблицы.Добавить("ТаблицаКурсовВалют");
	ПараметрыПостроенияЗапроса.ВременныеТаблицы.Добавить("ОбщаяТаблицаКурсовВалют");
	
	Если ПараметрыПостроенияЗапроса.ТипСписка = "СписокНоменклатура"
		И ПараметрыПостроенияЗапроса.ИспользуетсяЦенообразование25
		Или ПараметрыПостроенияЗапроса.ТипСписка = "СписокХарактеристики" Тогда
		
		ЗаменыТекста.Вставить("&ТекстПоляУпаковка",
			"ВЫБОР
			|	КОГДА ЕСТЬNULL(ИндивидуальныеЦеныНоменклатуры.Цена, 0) > 0
			|		ТОГДА ЕСТЬNULL(ИндивидуальныеЦеныНоменклатуры.Упаковка, ЗНАЧЕНИЕ(Справочник.УпаковкиЕдиницыИзмерения.ПустаяСсылка))
			|	ИНАЧЕ ЕСТЬNULL(ЦеныНоменклатуры.Упаковка, ЗНАЧЕНИЕ(Справочник.УпаковкиЕдиницыИзмерения.ПустаяСсылка))
			|КОНЕЦ");
		
		ЗаменыТекста.Вставить("&ТекстПоляВидЦены",
			"ВЫБОР
			|	КОГДА ЕСТЬNULL(ИндивидуальныеЦеныНоменклатуры.Цена, 0) > 0
			|		ТОГДА ИндивидуальныеЦеныНоменклатуры.ВидЦены
			|	ИНАЧЕ ЕСТЬNULL(ЦеныНоменклатуры.ВидЦены, ЗНАЧЕНИЕ(Справочник.ВидыЦен.ПустаяСсылка))
			|КОНЕЦ");
		
		ЗаменыТекста.Вставить("&ТекстПоляЦена",
			"ВЫРАЗИТЬ(ВЫБОР
			|	КОГДА ЕСТЬNULL(ИндивидуальныеЦеныНоменклатуры.Цена, 0) > 0
			|		ТОГДА ИндивидуальныеЦеныНоменклатуры.Цена
			|		* ВЫБОР
			|			КОГДА &Валюта <> ИндивидуальныеЦеныНоменклатуры.Валюта
			|				ТОГДА ВЫБОР
			|					КОГДА ЕСТЬNULL(КурсыСрезПоследнихВалютаИндивидуальныеЦены.КурсЗнаменатель, 0) > 0
			|					И ЕСТЬNULL(КурсыСрезПоследнихВалютаИндивидуальныеЦены.КурсЧислитель, 0) > 0
			|					И ЕСТЬNULL(КурсыСрезПоследнихВалютаДокумента.КурсЗнаменатель, 0) > 0
			|					И ЕСТЬNULL(КурсыСрезПоследнихВалютаДокумента.КурсЧислитель, 0) > 0
			|						ТОГДА КурсыСрезПоследнихВалютаИндивидуальныеЦены.КурсЧислитель
			|							* КурсыСрезПоследнихВалютаДокумента.КурсЗнаменатель
			|							/ (КурсыСрезПоследнихВалютаДокумента.КурсЧислитель
			|							* КурсыСрезПоследнихВалютаИндивидуальныеЦены.КурсЗнаменатель)
			|					ИНАЧЕ 0
			|				КОНЕЦ
			|			ИНАЧЕ 1
			|		КОНЕЦ
			|	ИНАЧЕ ЦеныНоменклатуры.Цена
			|	* ВЫБОР
			|		КОГДА &Валюта <> ЦеныНоменклатуры.Валюта
			|			ТОГДА ВЫБОР
			|				КОГДА ЕСТЬNULL(КурсыСрезПоследнихВалютаЦены.КурсЗнаменатель, 0) > 0
			|				И ЕСТЬNULL(КурсыСрезПоследнихВалютаЦены.КурсЧислитель, 0) > 0
			|				И ЕСТЬNULL(КурсыСрезПоследнихВалютаДокумента.КурсЗнаменатель, 0) > 0
			|				И ЕСТЬNULL(КурсыСрезПоследнихВалютаДокумента.КурсЧислитель, 0) > 0
			|					ТОГДА КурсыСрезПоследнихВалютаЦены.КурсЧислитель
			|						* КурсыСрезПоследнихВалютаДокумента.КурсЗнаменатель
			|						/ (КурсыСрезПоследнихВалютаДокумента.КурсЧислитель
			|						* КурсыСрезПоследнихВалютаЦены.КурсЗнаменатель)
			|				ИНАЧЕ 0
			|			КОНЕЦ
			|		ИНАЧЕ 1
			|	КОНЕЦ
			|КОНЕЦ КАК ЧИСЛО(31,2))");
		
	Иначе
		
		ЗаменыТекста.Вставить("&ТекстПоляУпаковка",
			"ВЫБОР
			|	КОГДА ЕСТЬNULL(СоглашениеТовары.Упаковка, ЗНАЧЕНИЕ(Справочник.УпаковкиЕдиницыИзмерения.ПустаяСсылка))
			|	<> ЗНАЧЕНИЕ(Справочник.УпаковкиЕдиницыИзмерения.ПустаяСсылка)
			|		ТОГДА СоглашениеТовары.Упаковка
			|	ИНАЧЕ ЕСТЬNULL(ЦеныНоменклатуры.Упаковка, ЗНАЧЕНИЕ(Справочник.УпаковкиЕдиницыИзмерения.ПустаяСсылка))
			|КОНЕЦ");
		
		ЗаменыТекста.Вставить("&ТекстПоляВидЦены",
			"ВЫБОР
			|	КОГДА ЕСТЬNULL(СоглашениеТовары.Цена, 0) > 0
			|		ТОГДА ЗНАЧЕНИЕ(Справочник.ВидыЦен.ПустаяСсылка)
			|	КОГДА СоглашениеТовары.ВидЦены <> ЗНАЧЕНИЕ(Справочник.ВидыЦен.ПустаяСсылка)
			|	И СоглашениеТовары.ВидЦены ЕСТЬ НЕ NULL
			|		ТОГДА СоглашениеТовары.ВидЦены
			|	КОГДА (СоглашениеТовары.ВидЦены = ЗНАЧЕНИЕ(Справочник.ВидыЦен.ПустаяСсылка)
			|		ИЛИ СоглашениеТовары.ВидЦены ЕСТЬ NULL)
			|	И СоглашениеЦеновыеГруппы.ВидЦен ЕСТЬ НЕ NULL
			|	И СоглашениеЦеновыеГруппы.ВидЦен <> ЗНАЧЕНИЕ(Справочник.ВидыЦен.ПустаяСсылка)
			|		ТОГДА СоглашениеЦеновыеГруппы.ВидЦен
			|	КОГДА (СоглашениеТовары.ВидЦены = ЗНАЧЕНИЕ(Справочник.ВидыЦен.ПустаяСсылка)
			|		ИЛИ СоглашениеТовары.ВидЦены ЕСТЬ NULL)
			|	И (СоглашениеЦеновыеГруппы.ВидЦен ЕСТЬ NULL
			|		ИЛИ СоглашениеЦеновыеГруппы.ВидЦен = ЗНАЧЕНИЕ(Справочник.ВидыЦен.ПустаяСсылка))
			|	И СоглашениеШапка.ВидЦен <> ЗНАЧЕНИЕ(Справочник.ВидыЦен.ПустаяСсылка)
			|		ТОГДА СоглашениеШапка.ВидЦен
			|КОНЕЦ");
		
		ЗаменыТекста.Вставить("&ТекстПоляЦена",
			"ВЫРАЗИТЬ(ВЫБОР
			|	КОГДА ЕСТЬNULL(СоглашениеТовары.Цена, 0) > 0
			|		ТОГДА СоглашениеТовары.Цена
			|		* ВЫБОР
			|			КОГДА &Валюта <> СоглашениеТовары.Ссылка.Валюта
			|				ТОГДА ВЫБОР
			|					КОГДА ЕСТЬNULL(КурсыСрезПоследнихВалютаСоглашения.КурсЗнаменатель, 0) > 0
			|					И ЕСТЬNULL(КурсыСрезПоследнихВалютаСоглашения.КурсЧислитель, 0) > 0
			|					И ЕСТЬNULL(КурсыСрезПоследнихВалютаДокумента.КурсЗнаменатель, 0) > 0
			|					И ЕСТЬNULL(КурсыСрезПоследнихВалютаДокумента.КурсЧислитель, 0) > 0
			|						ТОГДА КурсыСрезПоследнихВалютаСоглашения.КурсЧислитель
			|							* КурсыСрезПоследнихВалютаДокумента.КурсЗнаменатель
			|							/ (КурсыСрезПоследнихВалютаДокумента.КурсЧислитель
			|							* КурсыСрезПоследнихВалютаСоглашения.КурсЗнаменатель)
			|					ИНАЧЕ 0
			|				КОНЕЦ
			|			ИНАЧЕ 1
			|		КОНЕЦ
			|	КОГДА ВЫБОР
			|		КОГДА ЕСТЬNULL(СоглашениеТовары.Цена, 0) > 0
			|			ТОГДА ЗНАЧЕНИЕ(Справочник.ВидыЦен.ПустаяСсылка)
			|		КОГДА СоглашениеТовары.ВидЦены <> ЗНАЧЕНИЕ(Справочник.ВидыЦен.ПустаяСсылка)
			|		И СоглашениеТовары.ВидЦены ЕСТЬ НЕ NULL
			|			ТОГДА СоглашениеТовары.ВидЦены
			|		КОГДА (СоглашениеТовары.ВидЦены = ЗНАЧЕНИЕ(Справочник.ВидыЦен.ПустаяСсылка)
			|			ИЛИ СоглашениеТовары.ВидЦены ЕСТЬ NULL)
			|		И СоглашениеЦеновыеГруппы.ВидЦен ЕСТЬ НЕ NULL
			|		И СоглашениеЦеновыеГруппы.ВидЦен <> ЗНАЧЕНИЕ(Справочник.ВидыЦен.ПустаяСсылка)
			|			ТОГДА СоглашениеЦеновыеГруппы.ВидЦен
			|		КОГДА (СоглашениеТовары.ВидЦены = ЗНАЧЕНИЕ(Справочник.ВидыЦен.ПустаяСсылка)
			|			ИЛИ СоглашениеТовары.ВидЦены ЕСТЬ NULL)
			|		И (СоглашениеЦеновыеГруппы.ВидЦен ЕСТЬ NULL
			|			ИЛИ СоглашениеЦеновыеГруппы.ВидЦен = ЗНАЧЕНИЕ(Справочник.ВидыЦен.ПустаяСсылка))
			|		И СоглашениеШапка.ВидЦен <> ЗНАЧЕНИЕ(Справочник.ВидыЦен.ПустаяСсылка)
			|			ТОГДА СоглашениеШапка.ВидЦен
			|	КОНЕЦ <> ЗНАЧЕНИЕ(Справочник.ВидыЦен.ПустаяСсылка)
			|	И ЕСТЬNULL(ЦеныНоменклатуры.Цена, 0) > 0
			|		ТОГДА ЦеныНоменклатуры.Цена
			|		* ВЫБОР
			|			КОГДА &Валюта <> ЦеныНоменклатуры.Валюта
			|				ТОГДА ВЫБОР
			|					КОГДА ЕСТЬNULL(КурсыСрезПоследнихВалютаЦены.КурсЗнаменатель, 0) > 0
			|					И ЕСТЬNULL(КурсыСрезПоследнихВалютаЦены.КурсЧислитель, 0) > 0
			|					И ЕСТЬNULL(КурсыСрезПоследнихВалютаДокумента.КурсЗнаменатель, 0) > 0
			|					И ЕСТЬNULL(КурсыСрезПоследнихВалютаДокумента.КурсЧислитель, 0) > 0
			|						ТОГДА КурсыСрезПоследнихВалютаЦены.КурсЧислитель
			|							* КурсыСрезПоследнихВалютаДокумента.КурсЗнаменатель
			|							/ (КурсыСрезПоследнихВалютаДокумента.КурсЧислитель
			|							* КурсыСрезПоследнихВалютаЦены.КурсЗнаменатель)
			|					ИНАЧЕ 0
			|				КОНЕЦ
			|			ИНАЧЕ 1
			|		КОНЕЦ
			|	ИНАЧЕ 0
			|КОНЕЦ КАК ЧИСЛО(31,2))");
		
	КонецЕсли;
	
	Если ПараметрыПостроенияЗапроса.ТипСписка = "СписокНоменклатура" Тогда
		
		Если ПараметрыПостроенияЗапроса.ИспользуетсяЦенообразование25 Тогда
			
			ЗаменыТекста.Вставить("#ОсновнаяТаблица",
				ТекстТаблицыОсновнаяТаблицаСправочника(ПараметрыПостроенияЗапроса) +
				"
				|		ЛЕВОЕ СОЕДИНЕНИЕ &ТаблицаЦеныНоменклатурыПредприятия КАК ЦеныНоменклатуры
				|		ПО СправочникНоменклатура.Ссылка = ЦеныНоменклатуры.Номенклатура
				|
				|		ЛЕВОЕ СОЕДИНЕНИЕ &ТаблицаИндивидуальныеЦеныНоменклатуры КАК ИндивидуальныеЦеныНоменклатуры
				|		ПО СправочникНоменклатура.Ссылка = ИндивидуальныеЦеныНоменклатуры.Номенклатура
				|
				|		ЛЕВОЕ СОЕДИНЕНИЕ ОбщаяТаблицаКурсовВалют КАК КурсыСрезПоследнихВалютаИндивидуальныеЦены
				|		ПО ИндивидуальныеЦеныНоменклатуры.Валюта = КурсыСрезПоследнихВалютаИндивидуальныеЦены.Валюта
				|
				|		ЛЕВОЕ СОЕДИНЕНИЕ ОбщаяТаблицаКурсовВалют КАК КурсыСрезПоследнихВалютаЦены
				|		ПО ЦеныНоменклатуры.Валюта = КурсыСрезПоследнихВалютаЦены.Валюта
				|
				|		ЛЕВОЕ СОЕДИНЕНИЕ ТаблицаКурсовВалют КАК КурсыСрезПоследнихВалютаДокумента
				|		ПО ИСТИНА");
			
			ЗаменыТекста.Вставить("&ТекстОбщееУсловие",
				ТекстОтборОбщееУсловие(ПараметрыПостроенияЗапроса, "И &ОтборНоменклатурыПоЦене25"));
			
		Иначе
			
			ЗаменыТекста.Вставить("#ОсновнаяТаблица",
				ТекстТаблицыОсновнаяТаблицаСправочника(ПараметрыПостроенияЗапроса) +
				"
				|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.СоглашенияСКлиентами КАК СоглашениеШапка
				|		ПО СоглашениеШапка.Ссылка = &Соглашение
				|
				|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.СоглашенияСКлиентами.Товары КАК СоглашениеТовары
				|		ПО СоглашениеТовары.Ссылка = &Соглашение
				|		И СправочникНоменклатура.Ссылка = СоглашениеТовары.Номенклатура
				|		И СоглашениеТовары.Характеристика = ЗНАЧЕНИЕ(Справочник.ХарактеристикиНоменклатуры.ПустаяСсылка)
				|		
				|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.СоглашенияСКлиентами.ЦеновыеГруппы КАК СоглашениеЦеновыеГруппы
				|		ПО СоглашениеШапка.Ссылка = СоглашениеЦеновыеГруппы.Ссылка
				|		И СправочникНоменклатура.ЦеноваяГруппа = СоглашениеЦеновыеГруппы.ЦеноваяГруппа
				|
				|		ЛЕВОЕ СОЕДИНЕНИЕ &ТаблицаЦеныНоменклатурыПредприятия КАК ЦеныНоменклатуры
				|		ПО СправочникНоменклатура.Ссылка = ЦеныНоменклатуры.Номенклатура
				|		И ЦеныНоменклатуры.ВидЦены =
				|			ВЫБОР
				|				КОГДА ЕСТЬNULL(СоглашениеТовары.Цена, 0) > 0
				|					ТОГДА ЗНАЧЕНИЕ(Справочник.ВидыЦен.ПустаяСсылка)
				|				КОГДА СоглашениеТовары.ВидЦены <> ЗНАЧЕНИЕ(Справочник.ВидыЦен.ПустаяСсылка)
				|				И СоглашениеТовары.ВидЦены ЕСТЬ НЕ NULL
				|					ТОГДА СоглашениеТовары.ВидЦены
				|				КОГДА (СоглашениеТовары.ВидЦены = ЗНАЧЕНИЕ(Справочник.ВидыЦен.ПустаяСсылка)
				|					ИЛИ СоглашениеТовары.ВидЦены ЕСТЬ NULL)
				|				И СоглашениеЦеновыеГруппы.ВидЦен ЕСТЬ НЕ NULL
				|				И СоглашениеЦеновыеГруппы.ВидЦен <> ЗНАЧЕНИЕ(Справочник.ВидыЦен.ПустаяСсылка)
				|					ТОГДА СоглашениеЦеновыеГруппы.ВидЦен
				|				КОГДА (СоглашениеТовары.ВидЦены = ЗНАЧЕНИЕ(Справочник.ВидыЦен.ПустаяСсылка)
				|					ИЛИ СоглашениеТовары.ВидЦены ЕСТЬ NULL)
				|				И (СоглашениеЦеновыеГруппы.ВидЦен ЕСТЬ NULL
				|					ИЛИ СоглашениеЦеновыеГруппы.ВидЦен = ЗНАЧЕНИЕ(Справочник.ВидыЦен.ПустаяСсылка))
				|				И СоглашениеШапка.ВидЦен <> ЗНАЧЕНИЕ(Справочник.ВидыЦен.ПустаяСсылка)
				|					ТОГДА СоглашениеШапка.ВидЦен
				|			КОНЕЦ
				|
				|		ЛЕВОЕ СОЕДИНЕНИЕ ОбщаяТаблицаКурсовВалют КАК КурсыСрезПоследнихВалютаСоглашения
				|		ПО СоглашениеТовары.Ссылка.Валюта = КурсыСрезПоследнихВалютаСоглашения.Валюта
				|
				|		ЛЕВОЕ СОЕДИНЕНИЕ ОбщаяТаблицаКурсовВалют КАК КурсыСрезПоследнихВалютаЦены
				|		ПО ЦеныНоменклатуры.Валюта = КурсыСрезПоследнихВалютаЦены.Валюта
				|
				|		ЛЕВОЕ СОЕДИНЕНИЕ ТаблицаКурсовВалют КАК КурсыСрезПоследнихВалютаДокумента
				|		ПО ИСТИНА");
			
			ЗаменыТекста.Вставить("&ТекстОбщееУсловие",
				ТекстОтборОбщееУсловие(ПараметрыПостроенияЗапроса, "И &ОтборНоменклатурыПоЦене20"));
			
		КонецЕсли;
			
	ИначеЕсли ПараметрыПостроенияЗапроса.ТипСписка = "СписокХарактеристики" Тогда
		
		Если ПараметрыПостроенияЗапроса.ИспользуетсяЦенообразование25 Тогда
			
			ЗаменыТекста.Вставить("#ОсновнаяТаблица",
				ТекстТаблицыОсновнаяТаблицаСправочника(ПараметрыПостроенияЗапроса) +
				"
				|		ЛЕВОЕ СОЕДИНЕНИЕ &ТаблицаЦеныНоменклатурыПредприятия КАК ЦеныНоменклатуры
				|		ПО ЦеныНоменклатуры.ХарактеристикаЦО =
				|			ВЫБОР
				|				КОГДА ВЫРАЗИТЬ(&ВидНоменклатуры КАК Справочник.ВидыНоменклатуры).НастройкиКлючаЦенПоХарактеристике =
				|				ЗНАЧЕНИЕ(Перечисление.ВариантОтбораДляКлючаЦен.НеИспользовать)
				|					ТОГДА ЗНАЧЕНИЕ(Справочник.ХарактеристикиНоменклатурыДляЦенообразования.ПустаяСсылка)
				|				ИНАЧЕ ХарактеристикиНоменклатуры.ХарактеристикаНоменклатурыДляЦенообразования
				|			КОНЕЦ
				|
				|		ЛЕВОЕ СОЕДИНЕНИЕ &ТаблицаИндивидуальныеЦеныНоменклатуры КАК ИндивидуальныеЦеныНоменклатуры
				|		ПО ИндивидуальныеЦеныНоменклатуры.ХарактеристикаЦО =
				|			ВЫБОР
				|				КОГДА ВЫРАЗИТЬ(&ВидНоменклатуры КАК Справочник.ВидыНоменклатуры).НастройкиКлючаЦенПоХарактеристике =
				|				ЗНАЧЕНИЕ(Перечисление.ВариантОтбораДляКлючаЦен.НеИспользовать)
				|					ТОГДА ЗНАЧЕНИЕ(Справочник.ХарактеристикиНоменклатурыДляЦенообразования.ПустаяСсылка)
				|				ИНАЧЕ ХарактеристикиНоменклатуры.ХарактеристикаНоменклатурыДляЦенообразования
				|			КОНЕЦ
				|
				|		ЛЕВОЕ СОЕДИНЕНИЕ ОбщаяТаблицаКурсовВалют КАК КурсыСрезПоследнихВалютаИндивидуальныеЦены
				|		ПО ИндивидуальныеЦеныНоменклатуры.Валюта = КурсыСрезПоследнихВалютаИндивидуальныеЦены.Валюта
				|
				|		ЛЕВОЕ СОЕДИНЕНИЕ ОбщаяТаблицаКурсовВалют КАК КурсыСрезПоследнихВалютаЦены
				|		ПО ЦеныНоменклатуры.Валюта = КурсыСрезПоследнихВалютаЦены.Валюта
				|
				|		ЛЕВОЕ СОЕДИНЕНИЕ ТаблицаКурсовВалют КАК КурсыСрезПоследнихВалютаДокумента
				|		ПО ИСТИНА");
			
			ЗаменыТекста.Вставить("&ТекстОбщееУсловие", ТекстОтборОбщееУсловие(ПараметрыПостроенияЗапроса));
			
		Иначе
			
			ЗаменыТекста.Вставить("#ОсновнаяТаблица",
				ТекстТаблицыОсновнаяТаблицаСправочника(ПараметрыПостроенияЗапроса) +
				"
				|		ЛЕВОЕ СОЕДИНЕНИЕ &ТаблицаЦеныНоменклатурыПредприятия КАК ЦеныНоменклатуры
				|		ПО ЦеныНоменклатуры.Характеристика = ХарактеристикиНоменклатуры.Ссылка
				|
				|		ЛЕВОЕ СОЕДИНЕНИЕ &ТаблицаИндивидуальныеЦеныНоменклатуры КАК ИндивидуальныеЦеныНоменклатуры
				|		ПО ИндивидуальныеЦеныНоменклатуры.ХарактеристикаЦО =
				|			ВЫБОР
				|				КОГДА ВЫРАЗИТЬ(&ВидНоменклатуры КАК Справочник.ВидыНоменклатуры).НастройкиКлючаЦенПоХарактеристике =
				|				ЗНАЧЕНИЕ(Перечисление.ВариантОтбораДляКлючаЦен.НеИспользовать)
				|					ТОГДА ЗНАЧЕНИЕ(Справочник.ХарактеристикиНоменклатурыДляЦенообразования.ПустаяСсылка)
				|				ИНАЧЕ ХарактеристикиНоменклатуры.ХарактеристикаНоменклатурыДляЦенообразования
				|			КОНЕЦ
				|
				|		ЛЕВОЕ СОЕДИНЕНИЕ ОбщаяТаблицаКурсовВалют КАК КурсыСрезПоследнихВалютаИндивидуальныеЦены
				|		ПО ИндивидуальныеЦеныНоменклатуры.Валюта = КурсыСрезПоследнихВалютаИндивидуальныеЦены.Валюта
				|
				|		ЛЕВОЕ СОЕДИНЕНИЕ ОбщаяТаблицаКурсовВалют КАК КурсыСрезПоследнихВалютаЦены
				|		ПО ЦеныНоменклатуры.Валюта = КурсыСрезПоследнихВалютаЦены.Валюта
				|
				|		ЛЕВОЕ СОЕДИНЕНИЕ ТаблицаКурсовВалют КАК КурсыСрезПоследнихВалютаДокумента
				|		ПО ИСТИНА");
			
			ЗаменыТекста.Вставить("&ТекстОбщееУсловие", ТекстОтборОбщееУсловие(ПараметрыПостроенияЗапроса));
			
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

// Выполняет построение запроса для списков номенклатуры и характеристик в режиме отбора по ассортименту.
//
// Параметры:
// 	ПараметрыПостроенияЗапроса - см. ПодборТоваровКлиентСервер.НовыйПараметрыПостроенияЗапросаСписка
//
Процедура СформироватьТекстЗапросаАссортимент(ПараметрыПостроенияЗапроса)
	
	Если Не ЗначениеЗаполнено(ПараметрыПостроенияЗапроса.ШаблонЗапроса) Тогда
		Возврат;
	КонецЕсли;
	
	ЗаменыТекста = ПараметрыПостроенияЗапроса.ЗаменыТекста;
	
	ПараметрыПостроенияЗапроса.ВременныеТаблицы.Добавить("ТаблицаКурсовВалют");
	ПараметрыПостроенияЗапроса.ВременныеТаблицы.Добавить("ОбщаяТаблицаКурсовВалют");
	
	ПараметрыПостроенияЗапроса.ВременныеТаблицы.Добавить("Ассортимент");
	
	ЗаменыТекста.Вставить("&ТекстПоляУпаковка",
		"ЦеныНоменклатуры.Упаковка");
	
	ЗаменыТекста.Вставить("&ТекстПоляЦена",
		"ВЫРАЗИТЬ(ЕСТЬNULL(ЦеныНоменклатуры.Цена, 0)
		|	* ВЫБОР
		|		КОГДА &Валюта <> ЦеныНоменклатуры.Валюта
		|			ТОГДА ВЫБОР
		|				КОГДА ЕСТЬNULL(КурсыСрезПоследнихВалютаЦены.КурсЗнаменатель, 0) > 0
		|				И ЕСТЬNULL(КурсыСрезПоследнихВалютаЦены.КурсЧислитель, 0) > 0
		|				И ЕСТЬNULL(КурсыСрезПоследнихВалютаДокумента.КурсЗнаменатель, 0) > 0
		|				И ЕСТЬNULL(КурсыСрезПоследнихВалютаДокумента.КурсЧислитель, 0) > 0
		|					ТОГДА КурсыСрезПоследнихВалютаЦены.КурсЧислитель
		|						* КурсыСрезПоследнихВалютаДокумента.КурсЗнаменатель
		|						/ (КурсыСрезПоследнихВалютаДокумента.КурсЧислитель
		|						* КурсыСрезПоследнихВалютаЦены.КурсЗнаменатель)
		|				ИНАЧЕ 0
		|			КОНЕЦ
		|		ИНАЧЕ 1
		|	КОНЕЦ КАК ЧИСЛО(31,2))");
	
	ЗаменыТекста.Вставить("&ТекстПоляВНаличииОстаток",
		"ВЫРАЗИТЬ(&ВсеОстаткиВНаличии / ЕСТЬNULL(&ТекстЗапросаКоэффициентУпаковки1, 1) КАК ЧИСЛО(15, 3))");
	
	ЗаменыТекста.Вставить("&ТекстПоляДоступноеКоличество",
		"ВЫРАЗИТЬ(&ВсеОстаткиДоступно / ЕСТЬNULL(&ТекстЗапросаКоэффициентУпаковки1, 1) КАК ЧИСЛО(15, 3))");
	
	Если ПараметрыПостроенияЗапроса.ТипСписка = "СписокНоменклатура" Тогда
		
		Если ПараметрыПостроенияЗапроса.ИспользуетсяЦенообразование25 Тогда
			
			УсловиеПоВерсииЦенообразования =
				"ЦеныНоменклатуры.Номенклатура = СправочникНоменклатура.Ссылка
				|И ЦеныНоменклатуры.ХарактеристикаЦО = ЗНАЧЕНИЕ(Справочник.ХарактеристикиНоменклатурыДляЦенообразования.ПустаяСсылка)";
			
		Иначе
			
			УсловиеПоВерсииЦенообразования =
				"ЦеныНоменклатуры.Номенклатура = СправочникНоменклатура.Ссылка";
			
		КонецЕсли;
		
		ТекстОсновнаяТаблица =
			ТекстТаблицыОсновнаяТаблицаСправочника(ПараметрыПостроенияЗапроса) +
			ТекстСоединенияСТаблицейОстатков(ПараметрыПостроенияЗапроса) +
			"
			|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Ассортимент КАК Ассортимент
			|		ПО СправочникНоменклатура.Ссылка = Ассортимент.Номенклатура
			|		И Ассортимент.РазрешеныПродажи
			|
			|		ЛЕВОЕ СОЕДИНЕНИЕ &ТаблицаЦеныНоменклатурыПредприятия КАК ЦеныНоменклатуры
			|		ПО СправочникНоменклатура.Ссылка = ЦеныНоменклатуры.Номенклатура
			|		И &УсловиеПоВерсииЦенообразования
			|		И Ассортимент.ВидЦены = ЦеныНоменклатуры.ВидЦены
			|
			|		ЛЕВОЕ СОЕДИНЕНИЕ ОбщаяТаблицаКурсовВалют КАК КурсыСрезПоследнихВалютаЦены
			|		ПО ЦеныНоменклатуры.Валюта = КурсыСрезПоследнихВалютаЦены.Валюта
			|
			|		ЛЕВОЕ СОЕДИНЕНИЕ ТаблицаКурсовВалют КАК КурсыСрезПоследнихВалютаДокумента
			|		ПО ИСТИНА";
		
		ЗаменыТекста.Вставить("&ТекстОбщееУсловие", ТекстОтборОбщееУсловие(ПараметрыПостроенияЗапроса));
		
	Иначе
		
		Если ПараметрыПостроенияЗапроса.ИспользуетсяЦенообразование25 Тогда
			
			УсловиеПоВерсииЦенообразования =
				"ЦеныНоменклатуры.Номенклатура = &Номенклатура
				|И ЦеныНоменклатуры.ХарактеристикаЦО =
				|	ВЫБОР
				|		КОГДА ВЫРАЗИТЬ(&ВидНоменклатуры КАК Справочник.ВидыНоменклатуры).НастройкиКлючаЦенПоХарактеристике =
				|		ЗНАЧЕНИЕ(Перечисление.ВариантОтбораДляКлючаЦен.НеИспользовать)
				|			ТОГДА ЗНАЧЕНИЕ(Справочник.ХарактеристикиНоменклатурыДляЦенообразования.ПустаяСсылка)
				|		ИНАЧЕ ХарактеристикиНоменклатуры.ХарактеристикаНоменклатурыДляЦенообразования
				|	КОНЕЦ";
			
		Иначе
			
			УсловиеПоВерсииЦенообразования =
				"ЦеныНоменклатуры.Номенклатура = &Номенклатура
				|И ЦеныНоменклатуры.Характеристика = ХарактеристикиНоменклатуры.Ссылка";
			
		КонецЕсли;
		
		ТекстОсновнаяТаблица =
			ТекстТаблицыОсновнаяТаблицаСправочника(ПараметрыПостроенияЗапроса) +
			ТекстСоединенияСТаблицейОстатков(ПараметрыПостроенияЗапроса) +
			"
			|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Ассортимент КАК Ассортимент
			|		ПО Ассортимент.РазрешеныПродажи
			|
			|		ЛЕВОЕ СОЕДИНЕНИЕ &ТаблицаЦеныНоменклатурыПредприятия КАК ЦеныНоменклатуры
			|		ПО &УсловиеПоВерсииЦенообразования
			|
			|		ЛЕВОЕ СОЕДИНЕНИЕ ОбщаяТаблицаКурсовВалют КАК КурсыСрезПоследнихВалютаЦены
			|		ПО ЦеныНоменклатуры.Валюта = КурсыСрезПоследнихВалютаЦены.Валюта
			|
			|		ЛЕВОЕ СОЕДИНЕНИЕ ТаблицаКурсовВалют КАК КурсыСрезПоследнихВалютаДокумента
			|		ПО ИСТИНА";
		
		ЗаменыТекста.Вставить("&ТекстОбщееУсловие", ТекстОтборОбщееУсловие(ПараметрыПостроенияЗапроса));
		
	КонецЕсли;
	
	ТекстОсновнаяТаблица = СтрЗаменить(ТекстОсновнаяТаблица,
		"&УсловиеПоВерсииЦенообразования",
		УсловиеПоВерсииЦенообразования);
	
	ЗаменыТекста.Вставить("#ОсновнаяТаблица", ТекстОсновнаяТаблица);
	
КонецПроцедуры

// Выполняет построение запроса для списков номенклатуры и характеристик по параметрам соглашения с клиентом.
//
// Параметры:
// 	ПараметрыПостроенияЗапроса - см. ПодборТоваровКлиентСервер.НовыйПараметрыПостроенияЗапросаСписка
//
Процедура СформироватьТекстЗапросаПоПараметрамСоглашенияСКлиентом(ПараметрыПостроенияЗапроса)
	
	Если Не ЗначениеЗаполнено(ПараметрыПостроенияЗапроса.ШаблонЗапроса) Тогда
		Возврат;
	КонецЕсли;
	
	Варианты = Перечисления.ВариантыРасчетаЦенПоСоглашениямСКлиентами;
	ЗаменыТекста = ПараметрыПостроенияЗапроса.ЗаменыТекста;
	
	Если ПараметрыПостроенияЗапроса.ВариантРасчетаЦен <> Варианты.БезЦен Тогда
		
		ПараметрыПостроенияЗапроса.ВременныеТаблицы.Добавить("ТаблицаКурсовВалют");
		ПараметрыПостроенияЗапроса.ВременныеТаблицы.Добавить("ОбщаяТаблицаКурсовВалют");
		
	КонецЕсли;
	
	Если ПараметрыПостроенияЗапроса.ВариантРасчетаЦен = Варианты.БезЦен Тогда
		
		ЗаменыТекста.Вставить("&ТекстПоляУпаковка", "ЗНАЧЕНИЕ(Справочник.УпаковкиЕдиницыИзмерения.ПустаяСсылка)");
		ЗаменыТекста.Вставить("&ТекстПоляВидЦены", "ЗНАЧЕНИЕ(Справочник.ВидыЦен.ПустаяСсылка)");
		ЗаменыТекста.Вставить("&ТекстПоляЦена", "0");
		ЗаменыТекста.Вставить("&ТекстПоляВНаличииОстаток", "ВЫРАЗИТЬ(&ВсеОстаткиВНаличии КАК ЧИСЛО(15, 3))");
		ЗаменыТекста.Вставить("&ТекстПоляДоступноеКоличество", "ВЫРАЗИТЬ(&ВсеОстаткиДоступно КАК ЧИСЛО(15, 3))");
		
		ЗаменыТекста.Вставить("#ОсновнаяТаблица",
			ТекстТаблицыОсновнаяТаблицаСправочника(ПараметрыПостроенияЗапроса)
			+ ТекстСоединенияСТаблицейОстатков(ПараметрыПостроенияЗапроса));
		
		ЗаменыТекста.Вставить("&ТекстОбщееУсловие", ТекстОтборОбщееУсловие(ПараметрыПостроенияЗапроса));
		
	ИначеЕсли ПараметрыПостроенияЗапроса.ИспользуетсяЦенообразование25 Тогда
		
		Если ПараметрыПостроенияЗапроса.ВариантРасчетаЦен = Варианты.ВидЦенВШапке Тогда
			
			ЗаменыТекста.Вставить("&ТекстПоляУпаковка",
				"ЕСТЬNULL(ЦеныНоменклатуры.Упаковка, ЗНАЧЕНИЕ(Справочник.УпаковкиЕдиницыИзмерения.ПустаяСсылка))");
			ЗаменыТекста.Вставить("&ТекстПоляВидЦены", "&ВидыЦен");
			ЗаменыТекста.Вставить("&ТекстПоляЦена",
				"ВЫРАЗИТЬ(ЕСТЬNULL(ЦеныНоменклатуры.Цена, 0)
				|	* ВЫБОР
				|		КОГДА &Валюта <> ЦеныНоменклатуры.Валюта
				|			ТОГДА ВЫБОР
				|				КОГДА ЕСТЬNULL(КурсыСрезПоследнихВалютаЦены.КурсЗнаменатель, 0) > 0
				|				И ЕСТЬNULL(КурсыСрезПоследнихВалютаЦены.КурсЧислитель, 0) > 0
				|				И ЕСТЬNULL(КурсыСрезПоследнихВалютаДокумента.КурсЗнаменатель, 0) > 0
				|				И ЕСТЬNULL(КурсыСрезПоследнихВалютаДокумента.КурсЧислитель, 0) > 0
				|					ТОГДА КурсыСрезПоследнихВалютаЦены.КурсЧислитель
