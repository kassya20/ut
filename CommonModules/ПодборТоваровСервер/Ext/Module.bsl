					|								ТОГДА КурсыСрезПоследнихВалютаСоглашения.КурсЧислитель * КурсыСрезПоследнихВалютаДокумента.КурсЗнаменатель / (КурсыСрезПоследнихВалютаДокумента.КурсЧислитель * КурсыСрезПоследнихВалютаСоглашения.КурсЗнаменатель)
					|							ИНАЧЕ 0
					|						КОНЕЦ
					|				ИНАЧЕ 1
					|			КОНЕЦ
					|	КОГДА ВЫБОР
					|				КОГДА ЕСТЬNULL(СоглашениеТовары.Цена, 0) > 0
					|					ТОГДА ЗНАЧЕНИЕ(Справочник.ВидыЦен.ПустаяСсылка)
					|				КОГДА СоглашениеТовары.ВидЦены <> ЗНАЧЕНИЕ(Справочник.ВидыЦен.ПустаяСсылка)
					|						И СоглашениеТовары.ВидЦены ЕСТЬ НЕ NULL 
					|					ТОГДА СоглашениеТовары.ВидЦены
					|				КОГДА (СоглашениеТовары.ВидЦены = ЗНАЧЕНИЕ(Справочник.ВидыЦен.ПустаяСсылка)
					|						ИЛИ СоглашениеТовары.ВидЦены ЕСТЬ NULL )
					|						И СоглашениеЦеновыеГруппы.ВидЦен ЕСТЬ НЕ NULL 
					|						И СоглашениеЦеновыеГруппы.ВидЦен <> ЗНАЧЕНИЕ(Справочник.ВидыЦен.ПустаяСсылка)
					|					ТОГДА СоглашениеЦеновыеГруппы.ВидЦен
					|				КОГДА (СоглашениеТовары.ВидЦены = ЗНАЧЕНИЕ(Справочник.ВидыЦен.ПустаяСсылка)
					|						ИЛИ СоглашениеТовары.ВидЦены ЕСТЬ NULL )
					|						И (СоглашениеЦеновыеГруппы.ВидЦен ЕСТЬ NULL 
					|							ИЛИ СоглашениеЦеновыеГруппы.ВидЦен = ЗНАЧЕНИЕ(Справочник.ВидыЦен.ПустаяСсылка))
					|						И СоглашениеШапка.ВидЦен <> ЗНАЧЕНИЕ(Справочник.ВидыЦен.ПустаяСсылка)
					|					ТОГДА СоглашениеШапка.ВидЦен
					|			КОНЕЦ <> ЗНАЧЕНИЕ(Справочник.ВидыЦен.ПустаяСсылка)
					|			И ЕСТЬNULL(ЦеныНоменклатуры.Цена, 0) > 0
					|		ТОГДА ЦеныНоменклатуры.Цена * ВЫБОР
					|				КОГДА &Валюта <> ЦеныНоменклатуры.Валюта
					|					ТОГДА ВЫБОР
					|							КОГДА ЕСТЬNULL(КурсыСрезПоследнихВалютаЦены.КурсЗнаменатель, 0) > 0
					|									И ЕСТЬNULL(КурсыСрезПоследнихВалютаЦены.КурсЧислитель, 0) > 0
					|									И ЕСТЬNULL(КурсыСрезПоследнихВалютаДокумента.КурсЗнаменатель, 0) > 0
					|									И ЕСТЬNULL(КурсыСрезПоследнихВалютаДокумента.КурсЧислитель, 0) > 0
					|								ТОГДА КурсыСрезПоследнихВалютаЦены.КурсЧислитель * КурсыСрезПоследнихВалютаДокумента.КурсЗнаменатель / (КурсыСрезПоследнихВалютаДокумента.КурсЧислитель * КурсыСрезПоследнихВалютаЦены.КурсЗнаменатель)
					|							ИНАЧЕ 0
					|						КОНЕЦ
					|				ИНАЧЕ 1
					|			КОНЕЦ
					|	ИНАЧЕ 0
					|КОНЕЦ КАК ЧИСЛО(31,2))");
				ЗаменыТекста.Вставить("&ТекстПоляВНаличииОстаток",
					"ВЫРАЗИТЬ(&ВсеОстаткиВНаличии / ЕСТЬNULL(&ТекстЗапросаКоэффициентУпаковки1, 1) КАК ЧИСЛО(15, 3))");
				ЗаменыТекста.Вставить("&ТекстПоляДоступноеКоличество",
					"ВЫРАЗИТЬ(&ВсеОстаткиДоступно / ЕСТЬNULL(&ТекстЗапросаКоэффициентУпаковки1, 1) КАК ЧИСЛО(15, 3))");
				
				ТекстОсновнаяТаблица =
					ТекстТаблицыОсновнаяТаблицаСправочника(ПараметрыПостроенияЗапроса)
					+ ТекстСоединенияСТаблицейОстатков(ПараметрыПостроенияЗапроса);
				
				ТекстОбщиеСоединения =
					"
					|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.СоглашенияСКлиентами КАК СоглашениеШапка
					|		ПО СоглашениеШапка.Ссылка = &Соглашение
					|
					|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.СоглашенияСКлиентами.Товары КАК СоглашениеТовары
					|		ПО СоглашениеТовары.Ссылка = &Соглашение
					|		И &Номенклатура = СоглашениеТовары.Номенклатура
					|		И СоглашениеТовары.Характеристика = ХарактеристикиНоменклатуры.Ссылка
					|
					|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.СоглашенияСКлиентами.ЦеновыеГруппы КАК СоглашениеЦеновыеГруппы
					|		ПО СоглашениеЦеновыеГруппы.Ссылка = &Соглашение
					|		И СоглашениеЦеновыеГруппы.ЦеноваяГруппа = &ЦеноваяГруппа
					|
					|		ЛЕВОЕ СОЕДИНЕНИЕ &ТаблицаЦеныНоменклатурыПредприятия КАК ЦеныНоменклатуры
					|		ПО ЦеныНоменклатуры.Характеристика = ХарактеристикиНоменклатуры.Ссылка
					|		И &ДополнительноеУсловиеСоединенияПоЦенам
					|		
					|		ЛЕВОЕ СОЕДИНЕНИЕ ОбщаяТаблицаКурсовВалют КАК КурсыСрезПоследнихВалютаСоглашения
					|		ПО СоглашениеТовары.Ссылка.Валюта = КурсыСрезПоследнихВалютаСоглашения.Валюта
					|
					|		ЛЕВОЕ СОЕДИНЕНИЕ ОбщаяТаблицаКурсовВалют КАК КурсыСрезПоследнихВалютаЦены
					|		ПО ЦеныНоменклатуры.Валюта = КурсыСрезПоследнихВалютаЦены.Валюта
					|
					|		ЛЕВОЕ СОЕДИНЕНИЕ ТаблицаКурсовВалют КАК КурсыСрезПоследнихВалютаДокумента
					|		ПО ИСТИНА";
				
				ДополнительноеУсловиеСоединенияПоЦенам =
					"(ЦеныНоменклатуры.ВидЦены = ВЫБОР
					|	КОГДА ЕСТЬNULL(СоглашениеТовары.Цена, 0) > 0
					|		ТОГДА ЗНАЧЕНИЕ(Справочник.ВидыЦен.ПустаяСсылка)
					|	КОГДА СоглашениеТовары.ВидЦены <> ЗНАЧЕНИЕ(Справочник.ВидыЦен.ПустаяСсылка)
					|	И СоглашениеТовары.ВидЦены ЕСТЬ НЕ NULL 
					|		ТОГДА СоглашениеТовары.ВидЦены
					|	КОГДА (СоглашениеТовары.ВидЦены = ЗНАЧЕНИЕ(Справочник.ВидыЦен.ПустаяСсылка)
					|	ИЛИ СоглашениеТовары.ВидЦены ЕСТЬ NULL )
					|	И СоглашениеЦеновыеГруппы.ВидЦен ЕСТЬ НЕ NULL 
					|	И СоглашениеЦеновыеГруппы.ВидЦен <> ЗНАЧЕНИЕ(Справочник.ВидыЦен.ПустаяСсылка)
					|		ТОГДА СоглашениеЦеновыеГруппы.ВидЦен
					|	КОГДА (СоглашениеТовары.ВидЦены = ЗНАЧЕНИЕ(Справочник.ВидыЦен.ПустаяСсылка)
					|	ИЛИ СоглашениеТовары.ВидЦены ЕСТЬ NULL )
					|	И (СоглашениеЦеновыеГруппы.ВидЦен ЕСТЬ NULL 
					|	ИЛИ СоглашениеЦеновыеГруппы.ВидЦен = ЗНАЧЕНИЕ(Справочник.ВидыЦен.ПустаяСсылка))
					|	И СоглашениеШапка.ВидЦен <> ЗНАЧЕНИЕ(Справочник.ВидыЦен.ПустаяСсылка)
					|		ТОГДА СоглашениеШапка.ВидЦен
					|КОНЕЦ)";
				
			КонецЕсли;
			
			ТекстОбщееУсловие = ТекстОтборОбщееУсловие(ПараметрыПостроенияЗапроса);
			
		КонецЕсли;
		
		ТекстОбщиеСоединения = СтрЗаменить(ТекстОбщиеСоединения,
			"&ДополнительноеУсловиеСоединенияПоЦенам",
			ДополнительноеУсловиеСоединенияПоЦенам);
		
		ЗаменыТекста.Вставить("#ОсновнаяТаблица",
			ТекстОсновнаяТаблица
			+ ТекстОбщиеСоединения);
		
		ЗаменыТекста.Вставить("&ТекстОбщееУсловие",
			ТекстОбщееУсловие + СтрШаблон("
				|{ГДЕ
				|	%1 КАК Цена}",
				ЗаменыТекста.Получить("&ТекстПоляЦена")));
		
	КонецЕсли;
	
КонецПроцедуры

// Выполняет построение запроса для списков номенклатуры и характеристик по параметрам соглашения с поставщиком.
//
// Параметры:
// 	ПараметрыПостроенияЗапроса - см. ПодборТоваровКлиентСервер.НовыйПараметрыПостроенияЗапросаСписка
//
Процедура СформироватьТекстЗапросаПоПараметрамСоглашенияСПоставщиком(ПараметрыПостроенияЗапроса)
	
	Если Не ЗначениеЗаполнено(ПараметрыПостроенияЗапроса.ШаблонЗапроса) Тогда
		Возврат;
	КонецЕсли;
	
	ЗаменыТекста = ПараметрыПостроенияЗапроса.ЗаменыТекста;
	
	Если ПараметрыПостроенияЗапроса.ВариантРасчетаЦенПоставщика = "БезЦен" Тогда
		
		Если ПараметрыПостроенияЗапроса.ТипСписка = "СписокНоменклатураПартнера" Тогда
			
			ЗаменыТекста.Вставить("&ТекстПоляЦена", "0");
			ЗаменыТекста.Вставить("&ТекстПоляВидЦеныПоставщика", "ЗНАЧЕНИЕ(Справочник.ВидыЦенПоставщиков.ПустаяСсылка)");
			
			ЗаменыТекста.Вставить("#ОсновнаяТаблица",
				"Справочник.НоменклатураКонтрагентов КАК СправочникНоменклатураКонтрагентов
				|		
				|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК НоменклатураСпр
				|		ПО СправочникНоменклатураКонтрагентов.Номенклатура = НоменклатураСпр.Ссылка");
			
			ЗаменыТекста.Вставить("&ТекстОбщееУсловие", "&ОтборНоменклатурыКонтрагентовПоГруппе");
			
		ИначеЕсли ПараметрыПостроенияЗапроса.ТипСписка = "СписокНоменклатура"
			Или ПараметрыПостроенияЗапроса.ТипСписка = "СписокХарактеристики" Тогда
			
			ЗаменыТекста.Вставить("&ТекстПоляУпаковка", "ЗНАЧЕНИЕ(Справочник.УпаковкиЕдиницыИзмерения.ПустаяСсылка)");
			ЗаменыТекста.Вставить("&ТекстПоляЦена", "0");
			ЗаменыТекста.Вставить("&ТекстПоляВалюта", "ЗНАЧЕНИЕ(Справочник.Валюты.ПустаяСсылка)");
			ЗаменыТекста.Вставить("&ТекстПоляВНаличииОстаток", "ВЫРАЗИТЬ(&ВсеОстаткиВНаличии КАК ЧИСЛО(15, 3))");
			ЗаменыТекста.Вставить("&ТекстПоляДоступноеКоличество", "ВЫРАЗИТЬ(&ВсеОстаткиДоступно КАК ЧИСЛО(15, 3))");
			
			Если ПараметрыПостроенияЗапроса.ТипСписка = "СписокНоменклатура" Тогда
				
				ЗаменыТекста.Вставить("#ОсновнаяТаблица",
					ТекстТаблицыОсновнаяТаблицаСправочника(ПараметрыПостроенияЗапроса)
					+ ТекстСоединенияСТаблицейОстатков(ПараметрыПостроенияЗапроса));
				
				ЗаменыТекста.Вставить("&ТекстОбщееУсловие", ТекстОтборОбщееУсловие(ПараметрыПостроенияЗапроса));
				
			Иначе
				
				ЗаменыТекста.Вставить("#ОсновнаяТаблица",
					ТекстТаблицыОсновнаяТаблицаСправочника(ПараметрыПостроенияЗапроса)
					+ ТекстСоединенияСТаблицейОстатков(ПараметрыПостроенияЗапроса));
				
				ЗаменыТекста.Вставить("&ТекстОбщееУсловие", ТекстОтборОбщееУсловие(ПараметрыПостроенияЗапроса));
				
			КонецЕсли;
			
		КонецЕсли;
		
	ИначеЕсли ПараметрыПостроенияЗапроса.ВариантРасчетаЦенПоставщика = "ЦеныПоСоглашению" Тогда
		
		ПараметрыПостроенияЗапроса.ВременныеТаблицы.Добавить("ТаблицаКурсовВалют");
		ПараметрыПостроенияЗапроса.ВременныеТаблицы.Добавить("ОбщаяТаблицаКурсовВалют");
		
		Если ПараметрыПостроенияЗапроса.ТипСписка = "СписокНоменклатураПартнера" Тогда
			
			ЗаменыТекста.Вставить("&ТекстПоляЦена",
				"ВЫРАЗИТЬ(ЕСТЬNULL(ЦеныНоменклатурыПоставщиков.Цена, 0)
				|	* ВЫБОР
				|		КОГДА &Валюта <> ЦеныНоменклатурыПоставщиков.Валюта
				|			ТОГДА ВЫБОР
				|				КОГДА ЕСТЬNULL(КурсыСрезПоследнихВалютаЦены.КурсЗнаменатель, 0) > 0
				|				И ЕСТЬNULL(КурсыСрезПоследнихВалютаЦены.КурсЧислитель, 0) > 0
				|				И ЕСТЬNULL(КурсыСрезПоследнихВалютаДокумента.КурсЗнаменатель, 0) > 0
				|				И ЕСТЬNULL(КурсыСрезПоследнихВалютаДокумента.КурсЧислитель, 0) > 0
				|				ТОГДА КурсыСрезПоследнихВалютаЦены.КурсЧислитель
				|					* КурсыСрезПоследнихВалютаДокумента.КурсЗнаменатель
				|					/ (КурсыСрезПоследнихВалютаДокумента.КурсЧислитель
				|					* КурсыСрезПоследнихВалютаЦены.КурсЗнаменатель)
				|			ИНАЧЕ 0
				|		КОНЕЦ
				|	ИНАЧЕ 1
				|КОНЕЦ КАК ЧИСЛО(31,2))");
			
			ЗаменыТекста.Вставить("&ТекстПоляВидЦеныПоставщика", "ЦеныНоменклатурыПоставщиков.ВидЦеныПоставщика");
			
			ЗаменыТекста.Вставить("#ОсновнаяТаблица",
				"Справочник.НоменклатураКонтрагентов КАК СправочникНоменклатураКонтрагентов
				|
				|		ЛЕВОЕ СОЕДИНЕНИЕ &ТаблицаЦеныНоменклатурыПоставщиков КАК ЦеныНоменклатурыПоставщиков
				|		ПО ЦеныНоменклатурыПоставщиков.Номенклатура = СправочникНоменклатураКонтрагентов.Номенклатура
				|		И ЦеныНоменклатурыПоставщиков.Характеристика = СправочникНоменклатураКонтрагентов.Характеристика
				|		И ЦеныНоменклатурыПоставщиков.ВидЦеныПоставщика = &ВидЦеныПоставщика
				|
				|		ЛЕВОЕ СОЕДИНЕНИЕ ОбщаяТаблицаКурсовВалют КАК КурсыСрезПоследнихВалютаЦены
				|		ПО КурсыСрезПоследнихВалютаЦены.Валюта = ЦеныНоменклатурыПоставщиков.Валюта
				|
				|		ЛЕВОЕ СОЕДИНЕНИЕ ТаблицаКурсовВалют КАК КурсыСрезПоследнихВалютаДокумента
				|		ПО ИСТИНА
				|
				|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК НоменклатураСпр
				|		ПО СправочникНоменклатураКонтрагентов.Номенклатура = НоменклатураСпр.Ссылка");
			
			ЗаменыТекста.Вставить("&ТекстОбщееУсловие", "&ОтборНоменклатурыКонтрагентовПоГруппе");
			
		ИначеЕсли ПараметрыПостроенияЗапроса.ТипСписка = "СписокНоменклатура"
			Или ПараметрыПостроенияЗапроса.ТипСписка = "СписокХарактеристики" Тогда
			
			ЗаменыТекста.Вставить("&ТекстПоляУпаковка",
				"ЕСТЬNULL(ЦеныНоменклатурыПоставщиков.Упаковка, ЗНАЧЕНИЕ(Справочник.УпаковкиЕдиницыИзмерения.ПустаяСсылка))");
			
			ЗаменыТекста.Вставить("&ТекстПоляЦена",
				"ВЫРАЗИТЬ((ВЫРАЗИТЬ(ЕСТЬNULL(ЦеныНоменклатурыПоставщиков.Цена, 0) КАК ЧИСЛО(31,2)))
				|	* ВЫБОР
				|		КОГДА &Валюта <> ЦеныНоменклатурыПоставщиков.Валюта
				|			ТОГДА ВЫБОР
				|				КОГДА ЕСТЬNULL(КурсыСрезПоследнихВалютаЦены.КурсЗнаменатель, 0) > 0
				|				И ЕСТЬNULL(КурсыСрезПоследнихВалютаЦены.КурсЧислитель, 0) > 0
				|				И ЕСТЬNULL(КурсыСрезПоследнихВалютаДокумента.КурсЗнаменатель, 0) > 0
				|				И ЕСТЬNULL(КурсыСрезПоследнихВалютаДокумента.КурсЧислитель, 0) > 0
				|				ТОГДА КурсыСрезПоследнихВалютаЦены.КурсЧислитель
				|					* КурсыСрезПоследнихВалютаДокумента.КурсЗнаменатель
				|					/ (КурсыСрезПоследнихВалютаДокумента.КурсЧислитель
				|					* КурсыСрезПоследнихВалютаЦены.КурсЗнаменатель)
				|			ИНАЧЕ 0
				|		КОНЕЦ
				|	ИНАЧЕ 1
				|КОНЕЦ КАК ЧИСЛО(31,2))");
			
			ЗаменыТекста.Вставить("&ТекстПоляВалюта",
				"ЕСТЬNULL(ЦеныНоменклатурыПоставщиков.Валюта, ЗНАЧЕНИЕ(Справочник.Валюты.ПустаяСсылка))");
			
			ЗаменыТекста.Вставить("&ТекстПоляВНаличииОстаток",
				"ВЫРАЗИТЬ(&ВсеОстаткиВНаличии / ЕСТЬNULL(&ТекстЗапросаКоэффициентУпаковки2, 1) КАК ЧИСЛО(15, 3))");
			
			ЗаменыТекста.Вставить("&ТекстПоляДоступноеКоличество",
				"ВЫРАЗИТЬ(&ВсеОстаткиДоступно / ЕСТЬNULL(&ТекстЗапросаКоэффициентУпаковки2, 1) КАК ЧИСЛО(15, 3))");
			
			Если ПараметрыПостроенияЗапроса.ТипСписка = "СписокНоменклатура" Тогда
				
				ЗаменыТекста.Вставить("#ОсновнаяТаблица",
					ТекстТаблицыОсновнаяТаблицаСправочника(ПараметрыПостроенияЗапроса) +
					"
					|		ЛЕВОЕ СОЕДИНЕНИЕ &ТаблицаЦеныНоменклатурыПоставщиков КАК ЦеныНоменклатурыПоставщиков
					|		ПО ЦеныНоменклатурыПоставщиков.Номенклатура = СправочникНоменклатура.Ссылка
					|		И ЦеныНоменклатурыПоставщиков.ВидЦеныПоставщика = &ВидЦеныПоставщика
					|
					|		ЛЕВОЕ СОЕДИНЕНИЕ ОбщаяТаблицаКурсовВалют КАК КурсыСрезПоследнихВалютаЦены
					|		ПО КурсыСрезПоследнихВалютаЦены.Валюта = ЦеныНоменклатурыПоставщиков.Валюта
					|
					|		ЛЕВОЕ СОЕДИНЕНИЕ ТаблицаКурсовВалют КАК КурсыСрезПоследнихВалютаДокумента
					|		ПО ИСТИНА
					|" +
					ТекстСоединенияСТаблицейОстатков(ПараметрыПостроенияЗапроса));
				
				ЗаменыТекста.Вставить("&ТекстОбщееУсловие", ТекстОтборОбщееУсловие(ПараметрыПостроенияЗапроса));
				
			Иначе
				
				ЗаменыТекста.Вставить("#ОсновнаяТаблица",
					ТекстТаблицыОсновнаяТаблицаСправочника(ПараметрыПостроенияЗапроса) +
					"
					|		ЛЕВОЕ СОЕДИНЕНИЕ &ТаблицаЦеныНоменклатурыПоставщиков КАК ЦеныНоменклатурыПоставщиков
					|		ПО ЦеныНоменклатурыПоставщиков.Характеристика = ХарактеристикиНоменклатуры.Ссылка
					|		И ЦеныНоменклатурыПоставщиков.ВидЦеныПоставщика = &ВидЦеныПоставщика
					|
					|		ЛЕВОЕ СОЕДИНЕНИЕ ОбщаяТаблицаКурсовВалют КАК КурсыСрезПоследнихВалютаЦены
					|		ПО КурсыСрезПоследнихВалютаЦены.Валюта = ЦеныНоменклатурыПоставщиков.Валюта
					|
					|		ЛЕВОЕ СОЕДИНЕНИЕ ТаблицаКурсовВалют КАК КурсыСрезПоследнихВалютаДокумента
					|		ПО ИСТИНА
					|" +
					ТекстСоединенияСТаблицейОстатков(ПараметрыПостроенияЗапроса));
				
				ЗаменыТекста.Вставить("&ТекстОбщееУсловие", ТекстОтборОбщееУсловие(ПараметрыПостроенияЗапроса));
				
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

#Область ЗаменыСтрок

// Выполняет замены шаблонов в тексте запроса динамического списка.
//
// Параметры:
// 	ПараметрыПостроенияЗапроса - см. ПодборТоваровКлиентСервер.НовыйПараметрыПостроенияЗапросаСписка
//
Процедура ВыполнитьЗаменыШаблоновВТекстеЗапроса(ПараметрыПостроенияЗапроса)
	
	// 1) замены, накопленные в ходе построения шаблона, содержат шаблоны полей выборки, выражений и условий
	Для Каждого ЭлементСоответствия Из ПараметрыПостроенияЗапроса.ЗаменыТекста Цикл
		
		ПараметрыПостроенияЗапроса.ШаблонЗапроса = СтрЗаменить(
			ПараметрыПостроенияЗапроса.ШаблонЗапроса,
			ЭлементСоответствия.Ключ,
			ЭлементСоответствия.Значение);
		
	КонецЦикла;
	
	// 2) замены полей выборки, содержат в себе шаблоны выражений и условий
	Если ПараметрыПостроенияЗапроса.ТипСписка = "СписокНоменклатура" Тогда
		ТекстПоляОбщиеПоля = ТекстПолейВыборкиСписокНоменклатура();
	ИначеЕсли ПараметрыПостроенияЗапроса.ТипСписка = "СписокХарактеристики" Тогда
		ТекстПоляОбщиеПоля = ТекстПолейВыборкиСписокХарактеристики(ПараметрыПостроенияЗапроса);
	ИначеЕсли ПараметрыПостроенияЗапроса.ТипСписка = "СписокНоменклатураПартнера" Тогда
		ТекстПоляОбщиеПоля = ТекстПолейВыборкиСписокНоменклатураПартнера();
	КонецЕсли;
	
	ПараметрыПостроенияЗапроса.ШаблонЗапроса = СтрЗаменить(
		ПараметрыПостроенияЗапроса.ШаблонЗапроса,
		"&ТекстПоляОбщиеПоля",
		ТекстПоляОбщиеПоля);
	
	// 3) замены выражений и условий
	ПараметрыПостроенияЗапроса.ШаблонЗапроса = СтрЗаменить(
		ПараметрыПостроенияЗапроса.ШаблонЗапроса,
		"&ПодзапросОстаткиТоваров",
		ТекстПодзапросаОстаткиТоваров(ПараметрыПостроенияЗапроса));
	
	ПараметрыПостроенияЗапроса.ШаблонЗапроса = СтрЗаменить(
		ПараметрыПостроенияЗапроса.ШаблонЗапроса,
		"&ТаблицаЦеныНоменклатурыПредприятия",
		ТекстТаблицыЦеныНоменклатурыПредприятия(ПараметрыПостроенияЗапроса));
	
	ПараметрыПостроенияЗапроса.ШаблонЗапроса = СтрЗаменить(
		ПараметрыПостроенияЗапроса.ШаблонЗапроса,
		"&ТаблицаЦеныНоменклатурыПоставщиков",
		ТекстТаблицыЦеныНоменклатурыПоставщиков(ПараметрыПостроенияЗапроса));
	
	ПараметрыПостроенияЗапроса.ШаблонЗапроса = СтрЗаменить(
		ПараметрыПостроенияЗапроса.ШаблонЗапроса,
		"&ТаблицаИндивидуальныеЦеныНоменклатуры",
		ТекстТаблицыИндивидуальныеЦеныНоменклатуры(ПараметрыПостроенияЗапроса));
	
	ПараметрыПостроенияЗапроса.ШаблонЗапроса = СтрЗаменить(
		ПараметрыПостроенияЗапроса.ШаблонЗапроса,
		"&ОтборНоменклатурыПоГруппе",
		"НЕ СправочникНоменклатура.ЭтоГруппа");
	
	ПараметрыПостроенияЗапроса.ШаблонЗапроса = СтрЗаменить(
		ПараметрыПостроенияЗапроса.ШаблонЗапроса,
		"&ОтборНоменклатурыКонтрагентовПоГруппе",
		"НЕ СправочникНоменклатураКонтрагентов.ЭтоГруппа");
	
	ПараметрыПостроенияЗапроса.ШаблонЗапроса = СтрЗаменить(
		ПараметрыПостроенияЗапроса.ШаблонЗапроса,
		"&ЦеныНоменклатурыПоставщиковСрезПоследнихНаДату",
		?(ПараметрыПостроенияЗапроса.ЕстьЦеныНоменклатурыПоставщиковВБудущем,
			"&Дата",
			""));
	
	ПараметрыПостроенияЗапроса.ШаблонЗапроса = СтрЗаменить(
		ПараметрыПостроенияЗапроса.ШаблонЗапроса,
		"&ТекстПоляВНаличииВБазовыхЕдиницах",
		"&ВсеОстаткиВНаличии");
	
	ПараметрыПостроенияЗапроса.ШаблонЗапроса = СтрЗаменить(
		ПараметрыПостроенияЗапроса.ШаблонЗапроса,
		"&ОтборНоменклатурыПоЦене20",
		ТекстОтборНоменклатурыПоЦене20(ПараметрыПостроенияЗапроса));
	
	ПараметрыПостроенияЗапроса.ШаблонЗапроса = СтрЗаменить(
		ПараметрыПостроенияЗапроса.ШаблонЗапроса,
		"&ОтборНоменклатурыПоЦене25",
		ТекстОтборНоменклатурыПоЦене25(ПараметрыПостроенияЗапроса));
	
	ПараметрыПостроенияЗапроса.ШаблонЗапроса = СтрЗаменить(
		ПараметрыПостроенияЗапроса.ШаблонЗапроса,
		"&ВариантРасчетаЦеныНабора",
		?(ПараметрыПостроенияЗапроса.ИспользоватьКомплекты,
			"ВариантыКомплектацииНоменклатуры.ВариантРасчетаЦеныНабора",
			"ЗНАЧЕНИЕ(Перечисление.ВариантыРасчетаЦенНаборов.ПустаяСсылка)"));
	
	ПараметрыПостроенияЗапроса.ШаблонЗапроса = СтрЗаменить(
		ПараметрыПостроенияЗапроса.ШаблонЗапроса,
		"&НаборСодержитТовары",
		?(ПараметрыПостроенияЗапроса.ИспользоватьКомплекты,
			"ВариантыКомплектацииНоменклатуры.СодержитТовары",
			"ЛОЖЬ"));
	
	ПараметрыПостроенияЗапроса.ШаблонЗапроса = СтрЗаменить(
		ПараметрыПостроенияЗапроса.ШаблонЗапроса,
		"&НаборСодержитУслуги",
		?(ПараметрыПостроенияЗапроса.ИспользоватьКомплекты,
			"ВариантыКомплектацииНоменклатуры.СодержитУслуги",
			"ЛОЖЬ"));
	
	ПараметрыПостроенияЗапроса.ШаблонЗапроса = СтрЗаменить(
		ПараметрыПостроенияЗапроса.ШаблонЗапроса,
		"И &ОтборНоменклатурыПоСегменту",
		"{ГДЕ
		|	(1 В
		|		(ВЫБРАТЬ ПЕРВЫЕ 1
		|			1
		|		ИЗ
		|			РегистрСведений.НоменклатураСегмента КАК Сегменты
		|		ГДЕ
		|			Сегменты.Номенклатура = СправочникНоменклатура.Ссылка
		|			И Сегменты.Сегмент = &СегментНоменклатуры))}");
	
	ПараметрыПостроенияЗапроса.ШаблонЗапроса = СтрЗаменить(
		ПараметрыПостроенияЗапроса.ШаблонЗапроса,
		"&ОтборХарактеристикПоВладельцу",
		"ХарактеристикиНоменклатуры.Владелец = &ВладелецХарактеристик");
	
	ПараметрыПостроенияЗапроса.ШаблонЗапроса = СтрЗаменить(
		ПараметрыПостроенияЗапроса.ШаблонЗапроса,
		"И &ОтборХарактеристикПоСегменту",
		"{ГДЕ
		|	(1 В
		|		(ВЫБРАТЬ ПЕРВЫЕ 1
		|			1
		|		ИЗ
		|			РегистрСведений.НоменклатураСегмента КАК Сегменты
		|		ГДЕ
		|			Сегменты.Характеристика = ХарактеристикиНоменклатуры.Ссылка
		|			И Сегменты.Номенклатура = &НоменклатураСегмента
		|			И Сегменты.Сегмент = &СегментНоменклатуры))}");
	
	ПараметрыПостроенияЗапроса.ШаблонЗапроса = СтрЗаменить(
		ПараметрыПостроенияЗапроса.ШаблонЗапроса,
		"&ВсеОстаткиВНаличии", "ЕСТЬNULL(ВсеОстатки.ВНаличии, 0)");
	
	ПараметрыПостроенияЗапроса.ШаблонЗапроса = СтрЗаменить(
		ПараметрыПостроенияЗапроса.ШаблонЗапроса,
		"&ВсеОстаткиДоступно",
		"ЕСТЬNULL(ВсеОстатки.Доступно, 0)");
	
	ПараметрыПостроенияЗапроса.ШаблонЗапроса = СтрЗаменить(
		ПараметрыПостроенияЗапроса.ШаблонЗапроса,
		"&ТекстЗапросаКоэффициентУпаковки1",
		Справочники.УпаковкиЕдиницыИзмерения.ТекстЗапросаКоэффициентаУпаковки(
			"ЦеныНоменклатуры.Упаковка",
			"ЦеныНоменклатуры.Номенклатура"));
	
	ПараметрыПостроенияЗапроса.ШаблонЗапроса = СтрЗаменить(
		ПараметрыПостроенияЗапроса.ШаблонЗапроса,
		"&ТекстЗапросаКоэффициентУпаковки2",
		Справочники.УпаковкиЕдиницыИзмерения.ТекстЗапросаКоэффициентаУпаковки(
			"ЦеныНоменклатурыПоставщиков.Упаковка",
			"ЦеныНоменклатурыПоставщиков.Номенклатура"));
	
	ПараметрыПостроенияЗапроса.ШаблонЗапроса = СтрЗаменить(
		ПараметрыПостроенияЗапроса.ШаблонЗапроса,
		"&ТекстЗапросаКоэффициентУпаковки3",
		Справочники.УпаковкиЕдиницыИзмерения.ТекстЗапросаКоэффициентаУпаковки(
			"ИндивидуальныеЦеныНоменклатуры.Упаковка",
			"ИндивидуальныеЦеныНоменклатуры.Номенклатура"));
	
	ПараметрыПостроенияЗапроса.ШаблонЗапроса = СтрЗаменить(
		ПараметрыПостроенияЗапроса.ШаблонЗапроса,
		"&ТекстЗапросаКоэффициентУпаковки4",
		Справочники.УпаковкиЕдиницыИзмерения.ТекстЗапросаКоэффициентаУпаковки(
			"СоглашениеТовары.Упаковка",
			"СоглашениеТовары.Номенклатура"));
	
КонецПроцедуры

// Возвращает текст полей выборки из справочника Номенклатура.
//
// Возвращаемое значение:
// 	Строка
//
Функция ТекстПолейВыборкиСписокНоменклатура()
	
	Результат =
	"СправочникНоменклатура.Ссылка КАК Ссылка,
	|СправочникНоменклатура.Артикул КАК Артикул,
	|СправочникНоменклатура.Код КАК Код,
	|СправочникНоменклатура.Наименование КАК Наименование,
	|СправочникНоменклатура.ПометкаУдаления КАК ПометкаУдаления,
	|СправочникНоменклатура.Родитель КАК Родитель,
	|СправочникНоменклатура.ЭтоГруппа КАК ЭтоГруппа,
	|СправочникНоменклатура.Ссылка КАК Номенклатура,
	|СправочникНоменклатура.Ссылка КАК ЭлементСписка,
	|СправочникНоменклатура.ВидНоменклатуры КАК ВидНоменклатуры,
	|СправочникНоменклатура.ТипНоменклатуры КАК ТипНоменклатуры,
	|ВЫБОР
	|	КОГДА СправочникНоменклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Набор)
	|		ТОГДА ЕСТЬNULL(&ВариантРасчетаЦеныНабора, ЗНАЧЕНИЕ(Перечисление.ВариантыРасчетаЦенНаборов.ПустаяСсылка))
	|	ИНАЧЕ ЗНАЧЕНИЕ(Перечисление.ВариантыРасчетаЦенНаборов.ПустаяСсылка)
	|КОНЕЦ КАК ВариантРасчетаЦеныНабора,
	|&НаборСодержитТовары КАК СодержитТовары,
	|&НаборСодержитУслуги КАК СодержитУслуги,
	|СправочникНоменклатура.ЕдиницаИзмерения КАК ЕдиницаИзмерения,
	|СправочникНоменклатура.ЦеноваяГруппа КАК ЦеноваяГруппа,
	|СправочникНоменклатура.Качество КАК Качество,
	|СправочникНоменклатура.ИспользованиеХарактеристик КАК ИспользованиеХарактеристик,
	|ВЫБОР
	|	КОГДА СправочникНоменклатура.ТипНоменклатуры В
	|	(ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Товар), ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.МногооборотнаяТара))
	|		ТОГДА ИСТИНА
	|	КОГДА СправочникНоменклатура.ТипНоменклатуры В
	|	(ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Набор))
	|	И ЕСТЬNULL(&НаборСодержитТовары, ЛОЖЬ)
	|	И НЕ ЕСТЬNULL(&НаборСодержитУслуги, ЛОЖЬ)
	|		ТОГДА ИСТИНА
	|	ИНАЧЕ ЛОЖЬ
	|КОНЕЦ КАК ЭтоТовар,
	|ВЫБОР
	|	КОГДА СправочникНоменклатура.ТипНоменклатуры В
	|	(ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Услуга), ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Работа))
	|		ТОГДА ИСТИНА
	|	КОГДА СправочникНоменклатура.ТипНоменклатуры В
	|	(ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Набор))
	|	И ЕСТЬNULL(&НаборСодержитУслуги, ЛОЖЬ)
	|	И НЕ ЕСТЬNULL(&НаборСодержитТовары, ЛОЖЬ)
	|		ТОГДА ИСТИНА
	|	ИНАЧЕ ЛОЖЬ
	|КОНЕЦ КАК ЭтоУслуга,
	|ВЫБОР
	|	КОГДА СправочникНоменклатура.ИспользованиеХарактеристик =
	|	ЗНАЧЕНИЕ(Перечисление.ВариантыИспользованияХарактеристикНоменклатуры.ОбщиеДляВидаНоменклатуры)
	|		ТОГДА СправочникНоменклатура.ВидНоменклатуры
	|	КОГДА СправочникНоменклатура.ИспользованиеХарактеристик =
	|	ЗНАЧЕНИЕ(Перечисление.ВариантыИспользованияХарактеристикНоменклатуры.ИндивидуальныеДляНоменклатуры)
	|		ТОГДА СправочникНоменклатура.Ссылка
	|	КОГДА СправочникНоменклатура.ИспользованиеХарактеристик =
	|	ЗНАЧЕНИЕ(Перечисление.ВариантыИспользованияХарактеристикНоменклатуры.ОбщиеСДругимВидомНоменклатуры)
	|		ТОГДА СправочникНоменклатура.ВладелецХарактеристик
	|	ИНАЧЕ Неопределено
	|КОНЕЦ КАК ВладелецХарактеристик,
	|ВЫБОР
	|	КОГДА СправочникНоменклатура.ИспользованиеХарактеристик =
	|	ЗНАЧЕНИЕ(Перечисление.ВариантыИспользованияХарактеристикНоменклатуры.НеИспользовать)
	|		ТОГДА ЛОЖЬ
	|	ИНАЧЕ ИСТИНА
	|КОНЕЦ КАК ХарактеристикиИспользуются,
	|ВЫБОР
	|	КОГДА СправочникНоменклатура.ЭтоГруппа
	|		ТОГДА ВЫБОР
	|			КОГДА СправочникНоменклатура.ПометкаУдаления
	|				ТОГДА 13
	|			ИНАЧЕ 12
	|		КОНЕЦ
	|	ИНАЧЕ ВЫБОР
	|		КОГДА СправочникНоменклатура.ЕстьТоварыДругогоКачества
	|			ТОГДА 4 + ВЫБОР
	|				КОГДА СправочникНоменклатура.ПометкаУдаления
	|					ТОГДА 1
	|				ИНАЧЕ 0
	|			КОНЕЦ + ВЫБОР
	|				КОГДА СправочникНоменклатура.ИспользованиеХарактеристик =
	|				ЗНАЧЕНИЕ(Перечисление.ВариантыИспользованияХарактеристикНоменклатуры.НеИспользовать)
	|					ТОГДА 0
	|				ИНАЧЕ 2
	|			КОНЕЦ
	|		ИНАЧЕ -1 + ВЫБОР
	|			КОГДА СправочникНоменклатура.ПометкаУдаления
	|				ТОГДА 1
	|			ИНАЧЕ 0
	|		КОНЕЦ + ВЫБОР
	|			КОГДА СправочникНоменклатура.ИспользованиеХарактеристик =
	|			ЗНАЧЕНИЕ(Перечисление.ВариантыИспользованияХарактеристикНоменклатуры.НеИспользовать)
	|				ТОГДА 1
	|			ИНАЧЕ 3
	|		КОНЕЦ
	|	КОНЕЦ
	|КОНЕЦ КАК ИндексКартинки";
	
	Возврат Результат;
	
КонецФункции

// Возвращает текст полей выборки из справочника Характеристика.
//
// Параметры:
// 	ПараметрыПостроенияЗапроса - см. ПодборТоваровКлиентСервер.НовыйПараметрыПостроенияЗапросаСписка
//
// Возвращаемое значение:
// 	Строка
//
Функция ТекстПолейВыборкиСписокХарактеристики(ПараметрыПостроенияЗапроса)
	
	Если ПараметрыПостроенияЗапроса.ИспользуетсяЦенообразование25 Тогда
		
		Результат =
		"ХарактеристикиНоменклатуры.Ссылка КАК Ссылка,
		|ХарактеристикиНоменклатуры.Ссылка КАК Характеристика,
		|ХарактеристикиНоменклатуры.ПометкаУдаления КАК ПометкаУдаления,
		|ИСТИНА КАК ХарактеристикиИспользуются,
		|ВЫРАЗИТЬ(&Номенклатура КАК Справочник.Номенклатура) КАК Номенклатура,
		|ВЫРАЗИТЬ(&ТипНоменклатуры КАК Перечисление.ТипыНоменклатуры) КАК ТипНоменклатуры,
		|ВЫБОР
		|	КОГДА ВЫРАЗИТЬ(&ВидНоменклатуры КАК Справочник.ВидыНоменклатуры).НастройкиКлючаЦенПоХарактеристике =
		|	ЗНАЧЕНИЕ(Перечисление.ВариантОтбораДляКлючаЦен.НеИспользовать)
		|		ТОГДА ЗНАЧЕНИЕ(Справочник.ХарактеристикиНоменклатурыДляЦенообразования.ПустаяСсылка)
		|	ИНАЧЕ ХарактеристикиНоменклатуры.ХарактеристикаНоменклатурыДляЦенообразования
		|КОНЕЦ КАК ХарактеристикаЦО,
		|ВЫБОР КОГДА &ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Набор) ТОГДА
		|	ЕСТЬNULL(&ВариантРасчетаЦеныНабора, ЗНАЧЕНИЕ(Перечисление.ВариантыРасчетаЦенНаборов.ПустаяСсылка))
		|ИНАЧЕ
		|	ЗНАЧЕНИЕ(Перечисление.ВариантыРасчетаЦенНаборов.ПустаяСсылка)
		|КОНЕЦ КАК ВариантРасчетаЦеныНабора,
		|&НаборСодержитТовары КАК СодержитТовары,
		|&НаборСодержитУслуги КАК СодержитУслуги,
		|ВЫРАЗИТЬ(&ВидНоменклатуры КАК Справочник.ВидыНоменклатуры) КАК ВидНоменклатуры,
		|ВЫРАЗИТЬ(&ЕдиницаИзмерения КАК Справочник.УпаковкиЕдиницыИзмерения) КАК ЕдиницаИзмерения,
		|&ВладелецХарактеристик,
		|ВЫБОР
		|	КОГДА ХарактеристикиНоменклатуры.ПометкаУдаления
		|		ТОГДА 1
		|	ИНАЧЕ 0
		|КОНЕЦ КАК ИндексКартинки";
		
	Иначе
		
		Результат =
		"ХарактеристикиНоменклатуры.Ссылка КАК Ссылка,
		|ХарактеристикиНоменклатуры.Ссылка КАК Характеристика,
		|ХарактеристикиНоменклатуры.ПометкаУдаления КАК ПометкаУдаления,
		|ИСТИНА КАК ХарактеристикиИспользуются,
		|ВЫРАЗИТЬ(&Номенклатура КАК Справочник.Номенклатура) КАК Номенклатура,
		|ВЫРАЗИТЬ(&ТипНоменклатуры КАК Перечисление.ТипыНоменклатуры) КАК ТипНоменклатуры,
		|ВЫБОР КОГДА &ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Набор) ТОГДА
		|	ЕСТЬNULL(&ВариантРасчетаЦеныНабора, ЗНАЧЕНИЕ(Перечисление.ВариантыРасчетаЦенНаборов.ПустаяСсылка))
		|ИНАЧЕ
		|	ЗНАЧЕНИЕ(Перечисление.ВариантыРасчетаЦенНаборов.ПустаяСсылка)
		|КОНЕЦ КАК ВариантРасчетаЦеныНабора,
		|&НаборСодержитТовары КАК СодержитТовары,
		|&НаборСодержитУслуги КАК СодержитУслуги,
		|ВЫРАЗИТЬ(&ВидНоменклатуры КАК Справочник.ВидыНоменклатуры) КАК ВидНоменклатуры,
		|ВЫРАЗИТЬ(&ЕдиницаИзмерения КАК Справочник.УпаковкиЕдиницыИзмерения) КАК ЕдиницаИзмерения,
		|&ВладелецХарактеристик,
		|ВЫБОР
		|	КОГДА ХарактеристикиНоменклатуры.ПометкаУдаления
		|		ТОГДА 1
		|	ИНАЧЕ 0
		|КОНЕЦ КАК ИндексКартинки";
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Возвращает текст полей выборки из справочника НоменклатураКонтрагентов.
