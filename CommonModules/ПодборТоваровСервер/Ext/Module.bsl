//
Функция ТекстПолейВыборкиСписокНоменклатураПартнера()
	
	Результат =
	"СправочникНоменклатураКонтрагентов.ПометкаУдаления КАК ПометкаУдаления,
	|СправочникНоменклатураКонтрагентов.Предопределенный КАК Предопределенный,
	|СправочникНоменклатураКонтрагентов.Владелец КАК Владелец,
	|СправочникНоменклатураКонтрагентов.Родитель КАК Родитель,
	|СправочникНоменклатураКонтрагентов.ЭтоГруппа КАК ЭтоГруппа,
	|СправочникНоменклатураКонтрагентов.Наименование КАК Наименование,
	|СправочникНоменклатураКонтрагентов.Номенклатура КАК Номенклатура,
	|СправочникНоменклатураКонтрагентов.Номенклатура.ТипНоменклатуры КАК ТипНоменклатуры,
	|СправочникНоменклатураКонтрагентов.Номенклатура.ИспользованиеХарактеристик КАК ИспользованиеХарактеристик,
	|СправочникНоменклатураКонтрагентов.Номенклатура.НаименованиеПолное КАК НаименованиеПолное,
	|СправочникНоменклатураКонтрагентов.Характеристика КАК Характеристика,
	|НоменклатураСпр.ЕдиницаИзмерения КАК ЕдиницаИзмерения,
	|ВЫБОР
	|	КОГДА НоменклатураСпр.ЕдиницаИзмерения ЕСТЬ NULL
	|		ТОГДА СправочникНоменклатураКонтрагентов.Упаковка
	|	ИНАЧЕ ВЫБОР
	|		КОГДА НоменклатураСпр.ЕдиницаИзмерения = СправочникНоменклатураКонтрагентов.Упаковка
	|			ТОГДА ЗНАЧЕНИЕ(Справочник.УпаковкиЕдиницыИзмерения.ПустаяСсылка)
	|		ИНАЧЕ СправочникНоменклатураКонтрагентов.Упаковка
	|	КОНЕЦ
	|КОНЕЦ КАК Упаковка,
	|СправочникНоменклатураКонтрагентов.Артикул КАК Артикул,
	|СправочникНоменклатураКонтрагентов.Код КАК Код,
	|СправочникНоменклатураКонтрагентов.Ссылка КАК Ссылка,
	|ВЫБОР
	|	КОГДА СправочникНоменклатураКонтрагентов.Номенклатура.ИспользованиеХарактеристик =
	|	ЗНАЧЕНИЕ(Перечисление.ВариантыИспользованияХарактеристикНоменклатуры.НеИспользовать)
	|		ТОГДА ЛОЖЬ
	|	ИНАЧЕ ИСТИНА
	|КОНЕЦ КАК ХарактеристикиИспользуются,
	|ВЫБОР
	|	КОГДА СправочникНоменклатураКонтрагентов.Номенклатура.ТипНоменклатуры В
	|	(ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Товар), ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.МногооборотнаяТара))
	|		ТОГДА ИСТИНА
	|	ИНАЧЕ ЛОЖЬ
	|КОНЕЦ КАК ЭтоТовар,
	|ВЫБОР
	|	КОГДА СправочникНоменклатураКонтрагентов.Номенклатура.ТипНоменклатуры В
	|	(ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Услуга), ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Работа))
	|		ТОГДА ИСТИНА
	|	ИНАЧЕ ЛОЖЬ
	|КОНЕЦ КАК ЭтоУслуга,
	|ВЫБОР
	|	КОГДА СправочникНоменклатураКонтрагентов.ЭтоГруппа
	|		ТОГДА ВЫБОР
	|				КОГДА СправочникНоменклатураКонтрагентов.ПометкаУдаления
	|					ТОГДА 13
	|				ИНАЧЕ 12
	|			КОНЕЦ
	|КОНЕЦ КАК ИндексКартинки";
	
	Возврат Результат;
	
КонецФункции

// Возвращает текст условия по ценообразованию 2.0.
//
// Параметры:
// 	ПараметрыПостроенияЗапроса - см. ПодборТоваровКлиентСервер.НовыйПараметрыПостроенияЗапросаСписка
//
// Возвращаемое значение:
// 	Строка
//
Функция ТекстОтборНоменклатурыПоЦене20(ПараметрыПостроенияЗапроса)
	
	Возврат ?(ПараметрыПостроенияЗапроса.РежимПодбораБезСуммовыхПараметров,
		"ИСТИНА",
		"ВЫБОР
		|	КОГДА СправочникНоменклатура.ИспользованиеХарактеристик =
		|	ЗНАЧЕНИЕ(Перечисление.ВариантыИспользованияХарактеристикНоменклатуры.НеИспользовать)
		|		ТОГДА ЛОЖЬ
		|	ИНАЧЕ ИСТИНА
		|КОНЕЦ
		|ИЛИ ВЫБОР
		|	КОГДА ЕСТЬNULL(СоглашениеТовары.Цена, 0) > 0
		|		ТОГДА СоглашениеТовары.Цена
		|			* ВЫБОР
		|				КОГДА &Валюта <> СоглашениеТовары.Ссылка.Валюта
		|					ТОГДА ВЫБОР
		|						КОГДА ЕСТЬNULL(КурсыСрезПоследнихВалютаСоглашения.КурсЗнаменатель, 0) > 0
		|						И ЕСТЬNULL(КурсыСрезПоследнихВалютаСоглашения.КурсЧислитель, 0) > 0
		|						И ЕСТЬNULL(КурсыСрезПоследнихВалютаДокумента.КурсЗнаменатель, 0) > 0
		|						И ЕСТЬNULL(КурсыСрезПоследнихВалютаДокумента.КурсЧислитель, 0) > 0
		|							ТОГДА КурсыСрезПоследнихВалютаСоглашения.КурсЧислитель
		|								* КурсыСрезПоследнихВалютаДокумента.КурсЗнаменатель
		|								/ (КурсыСрезПоследнихВалютаДокумента.КурсЧислитель
		|								* КурсыСрезПоследнихВалютаСоглашения.КурсЗнаменатель)
		|						ИНАЧЕ 0
		|					КОНЕЦ
		|				ИНАЧЕ 1
		|			КОНЕЦ
		|	КОГДА ВЫБОР
		|		КОГДА ЕСТЬNULL(СоглашениеТовары.Цена, 0) > 0
		|			ТОГДА ЗНАЧЕНИЕ(Справочник.ВидыЦен.ПустаяСсылка)
		|		КОГДА СоглашениеТовары.ВидЦены <> ЗНАЧЕНИЕ(Справочник.ВидыЦен.ПустаяСсылка)
		|		И СоглашениеТовары.ВидЦены ЕСТЬ НЕ NULL
		|			ТОГДА СоглашениеТовары.ВидЦены
		|		КОГДА (СоглашениеТовары.ВидЦены = ЗНАЧЕНИЕ(Справочник.ВидыЦен.ПустаяСсылка)
		|			ИЛИ СоглашениеТовары.ВидЦены ЕСТЬ NULL)
		|		И СоглашениеЦеновыеГруппы.ВидЦен ЕСТЬ НЕ NULL
		|		И СоглашениеЦеновыеГруппы.ВидЦен <> ЗНАЧЕНИЕ(Справочник.ВидыЦен.ПустаяСсылка)
		|			ТОГДА СоглашениеЦеновыеГруппы.ВидЦен
		|		КОГДА (СоглашениеТовары.ВидЦены = ЗНАЧЕНИЕ(Справочник.ВидыЦен.ПустаяСсылка)
		|			ИЛИ СоглашениеТовары.ВидЦены ЕСТЬ NULL)
		|		И (СоглашениеЦеновыеГруппы.ВидЦен ЕСТЬ NULL
		|			ИЛИ СоглашениеЦеновыеГруппы.ВидЦен = ЗНАЧЕНИЕ(Справочник.ВидыЦен.ПустаяСсылка))
		|		И СоглашениеШапка.ВидЦен <> ЗНАЧЕНИЕ(Справочник.ВидыЦен.ПустаяСсылка)
		|			ТОГДА СоглашениеШапка.ВидЦен
		|	КОНЕЦ <> ЗНАЧЕНИЕ(Справочник.ВидыЦен.ПустаяСсылка) И ЕСТЬNULL(ЦеныНоменклатуры.Цена, 0) > 0
		|		ТОГДА ЦеныНоменклатуры.Цена * ВЫБОР
		|			КОГДА &Валюта <> ЦеныНоменклатуры.Валюта
		|				ТОГДА ВЫБОР
		|					КОГДА ЕСТЬNULL(КурсыСрезПоследнихВалютаЦены.КурсЗнаменатель, 0) > 0
		|					И ЕСТЬNULL(КурсыСрезПоследнихВалютаЦены.КурсЧислитель, 0) > 0
		|					И ЕСТЬNULL(КурсыСрезПоследнихВалютаДокумента.КурсЗнаменатель, 0) > 0
		|					И ЕСТЬNULL(КурсыСрезПоследнихВалютаДокумента.КурсЧислитель, 0) > 0
		|						ТОГДА КурсыСрезПоследнихВалютаЦены.КурсЧислитель
		|							* КурсыСрезПоследнихВалютаДокумента.КурсЗнаменатель
		|							/ (КурсыСрезПоследнихВалютаДокумента.КурсЧислитель
		|							* КурсыСрезПоследнихВалютаЦены.КурсЗнаменатель)
		|					ИНАЧЕ 0
		|				КОНЕЦ
		|			ИНАЧЕ 1
		|		КОНЕЦ
		|	ИНАЧЕ 0
		|КОНЕЦ <> 0
		|ИЛИ &ВариантРасчетаЦеныНабора =
		|ЗНАЧЕНИЕ(Перечисление.ВариантыРасчетаЦенНаборов.РассчитываетсяИзЦенКомплектующих)");
	
КонецФункции

// Возвращает текст общего условия.
//
// Параметры:
// 	ПараметрыПостроенияЗапроса - см. ПодборТоваровКлиентСервер.НовыйПараметрыПостроенияЗапросаСписка
// 	ДополнительноеУсловие - Строка
//
// Возвращаемое значение:
// 	Строка
//
Функция ТекстОтборОбщееУсловие(ПараметрыПостроенияЗапроса, ДополнительноеУсловие = "")
	
	Если ПараметрыПостроенияЗапроса.ТипСписка = "СписокНоменклатура" Тогда
		
		Результат =
			"&ОтборНоменклатурыПоГруппе
			|И &ОтборНоменклатурыПоСегменту";
	Иначе
		
		Результат =
			"&ОтборХарактеристикПоВладельцу
			|И &ОтборХарактеристикПоСегменту";
		
	КонецЕсли;
	
	Возврат Результат
		+ ?(ЗначениеЗаполнено(ДополнительноеУсловие),
			Символы.ПС + ДополнительноеУсловие,
			"");
	
КонецФункции

// Возвращает текст условия по ценообразованию 2.5.
//
// Параметры:
// 	ПараметрыПостроенияЗапроса - см. ПодборТоваровКлиентСервер.НовыйПараметрыПостроенияЗапросаСписка
//
// Возвращаемое значение:
// 	Строка
//
Функция ТекстОтборНоменклатурыПоЦене25(ПараметрыПостроенияЗапроса)
	
	Возврат ?(ПараметрыПостроенияЗапроса.РежимПодбораБезСуммовыхПараметров,
		"ИСТИНА",
		"ВЫБОР
		|	КОГДА СправочникНоменклатура.ИспользованиеХарактеристик =
		|	ЗНАЧЕНИЕ(Перечисление.ВариантыИспользованияХарактеристикНоменклатуры.НеИспользовать)
		|		ТОГДА ЛОЖЬ
		|	ИНАЧЕ ИСТИНА
		|КОНЕЦ ИЛИ ВЫБОР
		|	КОГДА ЕСТЬNULL(ИндивидуальныеЦеныНоменклатуры.Цена, 0) > 0
		|		ТОГДА ИндивидуальныеЦеныНоменклатуры.Цена * ВЫБОР
		|			КОГДА &Валюта <> ИндивидуальныеЦеныНоменклатуры.Валюта
		|				ТОГДА ВЫБОР
		|					КОГДА ЕСТЬNULL(КурсыСрезПоследнихВалютаИндивидуальныеЦены.КурсЗнаменатель, 0) > 0
		|					И ЕСТЬNULL(КурсыСрезПоследнихВалютаИндивидуальныеЦены.КурсЧислитель, 0) > 0
		|					И ЕСТЬNULL(КурсыСрезПоследнихВалютаДокумента.КурсЗнаменатель, 0) > 0
		|					И ЕСТЬNULL(КурсыСрезПоследнихВалютаДокумента.КурсЧислитель, 0) > 0
		|						ТОГДА КурсыСрезПоследнихВалютаИндивидуальныеЦены.КурсЧислитель
		|							* КурсыСрезПоследнихВалютаДокумента.КурсЗнаменатель
		|							/ (КурсыСрезПоследнихВалютаДокумента.КурсЧислитель
		|							* КурсыСрезПоследнихВалютаИндивидуальныеЦены.КурсЗнаменатель)
		|					ИНАЧЕ 0
		|				КОНЕЦ
		|			ИНАЧЕ 1
		|		КОНЕЦ
		|	ИНАЧЕ ЦеныНоменклатуры.Цена * ВЫБОР
		|		КОГДА &Валюта <> ЦеныНоменклатуры.Валюта
		|			ТОГДА ВЫБОР
		|				КОГДА ЕСТЬNULL(КурсыСрезПоследнихВалютаЦены.КурсЗнаменатель, 0) > 0
		|				И ЕСТЬNULL(КурсыСрезПоследнихВалютаЦены.КурсЧислитель, 0) > 0
		|				И ЕСТЬNULL(КурсыСрезПоследнихВалютаДокумента.КурсЗнаменатель, 0) > 0
		|				И ЕСТЬNULL(КурсыСрезПоследнихВалютаДокумента.КурсЧислитель, 0) > 0
		|					ТОГДА КурсыСрезПоследнихВалютаЦены.КурсЧислитель
		|						* КурсыСрезПоследнихВалютаДокумента.КурсЗнаменатель
		|						/ (КурсыСрезПоследнихВалютаДокумента.КурсЧислитель
		|						* КурсыСрезПоследнихВалютаЦены.КурсЗнаменатель)
		|					ИНАЧЕ 0
		|				КОНЕЦ
		|			ИНАЧЕ 1
		|		КОНЕЦ
		|	КОНЕЦ <> 0
		|ИЛИ &ВариантРасчетаЦеныНабора =
		|ЗНАЧЕНИЕ(Перечисление.ВариантыРасчетаЦенНаборов.РассчитываетсяИзЦенКомплектующих)");
	
КонецФункции

// Возвращает текст таблицы справочника Номенклатура или ХарактеристикиНоменклатуры с вариантами комплектации.
//
// Параметры:
// 	ПараметрыПостроенияЗапроса - см. ПодборТоваровКлиентСервер.НовыйПараметрыПостроенияЗапросаСписка
//
// Возвращаемое значение:
// 	Строка
//
Функция ТекстТаблицыОсновнаяТаблицаСправочника(ПараметрыПостроенияЗапроса)
	
	Если ПараметрыПостроенияЗапроса.ТипСписка = "СписокНоменклатура" Тогда
		
		Результат =
			"Справочник.Номенклатура КАК СправочникНоменклатура"
				+ ?(ПараметрыПостроенияЗапроса.ИспользоватьКомплекты,
				"
				|
				|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ВариантыКомплектацииНоменклатуры КАК ВариантыКомплектацииНоменклатуры
				|		ПО ВариантыКомплектацииНоменклатуры.Владелец = СправочникНоменклатура.Ссылка
				|		И ВариантыКомплектацииНоменклатуры.Характеристика = ЗНАЧЕНИЕ(Справочник.ХарактеристикиНоменклатуры.ПустаяСсылка)
				|		И ВариантыКомплектацииНоменклатуры.Основной",
				"");
		
	Иначе
		
		Результат =
			"Справочник.ХарактеристикиНоменклатуры КАК ХарактеристикиНоменклатуры"
				+ ?(ПараметрыПостроенияЗапроса.ИспользоватьКомплекты,
				"
				|
				|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ВариантыКомплектацииНоменклатуры КАК ВариантыКомплектацииНоменклатуры
				|		ПО ВариантыКомплектацииНоменклатуры.Владелец = &Номенклатура
				|		И ХарактеристикиНоменклатуры.Ссылка = ВариантыКомплектацииНоменклатуры.Характеристика
				|		И ВариантыКомплектацииНоменклатуры.Основной",
				"");
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Возвращает текст таблицы индивидуальных цен номенклатуры.
//
// Параметры:
// 	ПараметрыПостроенияЗапроса - см. ПодборТоваровКлиентСервер.НовыйПараметрыПостроенияЗапросаСписка
//
// Возвращаемое значение:
// 	Строка
//
Функция ТекстТаблицыИндивидуальныеЦеныНоменклатуры(ПараметрыПостроенияЗапроса)
	
	ТекстТаблицы =
	"РегистрСведений.ЦеныНоменклатуры25.СрезПоследних(&УсловиеОтбораПоДате, ВидЦены = &ВидЦенИндивидуальный
	|			И &УсловиеПоТипуСписка
	|			И СерияЦО = ЗНАЧЕНИЕ(Справочник.СерииНоменклатурыДляЦенообразования.ПустаяСсылка)
	|			И УпаковкаЦО = ЗНАЧЕНИЕ(Справочник.УпаковкиЕдиницыИзмерения.ПустаяСсылка) {Номенклатура.* КАК Номенклатура}
	|			{Номенклатура.Родитель.* КАК Родитель} {Номенклатура.ВидНоменклатуры.* КАК ВидНоменклатуры})";
	
	УсловиеОтбораПоДате = ?(ПараметрыПостроенияЗапроса.ЕстьЦеныВБудущем,
		"КОНЕЦПЕРИОДА(&Дата, День)",
		"");
	
	ТекстТаблицы = СтрЗаменить(ТекстТаблицы,
		"&УсловиеОтбораПоДате",
		УсловиеОтбораПоДате);
	
	УсловиеПоТипуСписка = ?(ПараметрыПостроенияЗапроса.ТипСписка = "СписокНоменклатура",
		"ХарактеристикаЦО = ЗНАЧЕНИЕ(Справочник.ХарактеристикиНоменклатурыДляЦенообразования.ПустаяСсылка)",
		"Номенклатура = &Номенклатура");
	
	ТекстТаблицы = СтрЗаменить(ТекстТаблицы,
		"&УсловиеПоТипуСписка",
		УсловиеПоТипуСписка);
	
	Возврат ТекстТаблицы;
	
КонецФункции

// Возвращает текст таблицы цен номенклатуры предприятия.
//
// Параметры:
// 	ПараметрыПостроенияЗапроса - см. ПодборТоваровКлиентСервер.НовыйПараметрыПостроенияЗапросаСписка
//
// Возвращаемое значение:
// 	Строка
//
Функция ТекстТаблицыЦеныНоменклатурыПредприятия(ПараметрыПостроенияЗапроса)
	
	Если ПараметрыПостроенияЗапроса.ИспользуетсяЦенообразование25 Тогда
		
		ТекстТаблицы =
		"РегистрСведений.ЦеныНоменклатуры25.СрезПоследних(&УсловиеОтбораПоДате, &УсловиеОтбораПоВидуЦен
		|			И &УсловиеПоТипуСписка
		|			И СерияЦО = ЗНАЧЕНИЕ(Справочник.СерииНоменклатурыДляЦенообразования.ПустаяСсылка)
		|			И УпаковкаЦО = ЗНАЧЕНИЕ(Справочник.УпаковкиЕдиницыИзмерения.ПустаяСсылка) {Номенклатура.* КАК Номенклатура}
		|			{Номенклатура.Родитель.* КАК Родитель} {Номенклатура.ВидНоменклатуры.* КАК ВидНоменклатуры})";
		
		УсловиеОтбораПоДате = ?(ПараметрыПостроенияЗапроса.ЕстьЦеныВБудущем,
			"КОНЕЦПЕРИОДА(&Дата, День)",
			"");
		
		ТекстТаблицы = СтрЗаменить(ТекстТаблицы,
			"&УсловиеОтбораПоДате",
			УсловиеОтбораПоДате);
		
		Если ПараметрыПостроенияЗапроса.НеИспользоватьВидыЦенПоУсловиюПродаж Тогда
			
			УсловиеОтбораПоВидуЦен =
				?(ПараметрыПостроенияЗапроса.НесколькоВидовЦен,
				"ВидЦены В (&ВидыЦен)",
				"ВидЦены = &ВидыЦен");
			
		Иначе
			УсловиеОтбораПоВидуЦен = "ВидЦены = &ВидЦенОсновной";
		КонецЕсли;
		
		ТекстТаблицы = СтрЗаменить(ТекстТаблицы,
			"&УсловиеОтбораПоВидуЦен",
			УсловиеОтбораПоВидуЦен);
		
		УсловиеПоТипуСписка = ?(ПараметрыПостроенияЗапроса.ТипСписка = "СписокНоменклатура",
			"ХарактеристикаЦО = ЗНАЧЕНИЕ(Справочник.ХарактеристикиНоменклатурыДляЦенообразования.ПустаяСсылка)",
			"Номенклатура = &Номенклатура");
		
		ТекстТаблицы = СтрЗаменить(ТекстТаблицы,
			"&УсловиеПоТипуСписка",
			УсловиеПоТипуСписка);
		
	Иначе
		
		ТекстТаблицы =
		"РегистрСведений.ЦеныНоменклатуры.СрезПоследних(&УсловиеОтбораПоДате, &УсловиеОтбораПоВидуЦен
		|		И &УсловиеПоТипуСписка {Номенклатура.* КАК Номенклатура} {Номенклатура.Родитель.* КАК Родитель}
		|			{Номенклатура.ВидНоменклатуры.* КАК ВидНоменклатуры})";
		
		УсловиеОтбораПоДате = ?(ПараметрыПостроенияЗапроса.ЕстьЦеныВБудущем,
			"КОНЕЦПЕРИОДА(&Дата, День)",
			"");
		
		ТекстТаблицы = СтрЗаменить(ТекстТаблицы,
			"&УсловиеОтбораПоДате",
			УсловиеОтбораПоДате);
		
		УсловиеОтбораПоВидуЦен =
			?(ПараметрыПостроенияЗапроса.НесколькоВидовЦен,
			"ВидЦены В (&ВидыЦен)",
			"ВидЦены = &ВидыЦен");
		
		ТекстТаблицы = СтрЗаменить(ТекстТаблицы,
			"&УсловиеОтбораПоВидуЦен",
			УсловиеОтбораПоВидуЦен);
		
		УсловиеПоТипуСписка = ?(ПараметрыПостроенияЗапроса.ТипСписка = "СписокНоменклатура",
			"Характеристика = ЗНАЧЕНИЕ(Справочник.ХарактеристикиНоменклатуры.ПустаяСсылка)",
			"Номенклатура = &Номенклатура");
		
		ТекстТаблицы = СтрЗаменить(ТекстТаблицы,
			"&УсловиеПоТипуСписка",
			УсловиеПоТипуСписка);
		
	КонецЕсли;
	
	Возврат ТекстТаблицы;
	
КонецФункции

// Возвращает текст таблицы цен номенклатуры поставщиков.
//
// Параметры:
// 	ПараметрыПостроенияЗапроса - см. ПодборТоваровКлиентСервер.НовыйПараметрыПостроенияЗапросаСписка
//
// Возвращаемое значение:
// 	Строка
//
Функция ТекстТаблицыЦеныНоменклатурыПоставщиков(ПараметрыПостроенияЗапроса)
	
	ТекстТаблицы =
	"РегистрСведений.ЦеныНоменклатурыПоставщиков.СрезПоследних(&ЦеныНоменклатурыПоставщиковСрезПоследнихНаДату,
	|			ВидЦеныПоставщика = &ВидЦеныПоставщика
	|			И &УсловиеПоТипуСписка {Номенклатура.* КАК Номенклатура} {Номенклатура.Родитель.* КАК Родитель}
	|			{Номенклатура.ВидНоменклатуры.* КАК ВидНоменклатуры})";
	
	Если ПараметрыПостроенияЗапроса.ТипСписка = "СписокНоменклатураПартнера" Тогда
		
		УсловиеПоТипуСписка = "ИСТИНА";
		
	ИначеЕсли ПараметрыПостроенияЗапроса.ТипСписка = "СписокНоменклатура" Тогда
		
		УсловиеПоТипуСписка = "Характеристика = ЗНАЧЕНИЕ(Справочник.ХарактеристикиНоменклатуры.ПустаяСсылка)";
		
	ИначеЕсли ПараметрыПостроенияЗапроса.ТипСписка = "СписокХарактеристики" Тогда
		
		УсловиеПоТипуСписка = "Номенклатура = &Номенклатура";
		
	КонецЕсли;
	
	ТекстТаблицы = СтрЗаменить(ТекстТаблицы,
		"&УсловиеПоТипуСписка",
		УсловиеПоТипуСписка);
	
	Возврат ТекстТаблицы;
	
КонецФункции

// Возвращает текст подзапроса к остаткам товаров.
//
// Параметры:
// 	ПараметрыПостроенияЗапроса - см. ПодборТоваровКлиентСервер.НовыйПараметрыПостроенияЗапросаСписка
//
// Возвращаемое значение:
// 	Строка
//
Функция ТекстПодзапросаОстаткиТоваров(ПараметрыПостроенияЗапроса)
	
	ТекстПодзапроса =
	"ВЫБРАТЬ
	|	&ТекстПоляГруппировки КАК ПолеСоединения,
	|	СУММА(ТаблицаРаспределение.ВНаличии) КАК ВНаличии,
	|	СУММА(ТаблицаРаспределение.Доступно) КАК Доступно
	|ИЗ
	|	РегистрСведений.ДоступныеОстаткиТоваров КАК ТаблицаРаспределение
	|ГДЕ
	|	&ТекстОтбораПоСкладам
	|	И ТаблицаРаспределение.Назначение = &Назначение
	|	И ТаблицаРаспределение.КонтролируемаяПартия = &КонтролируемаяПартия
	|	И &ТекстОстаткиНаСкладах
	|	И &ТекстОтбораПоНоменклатуре
	|{ГДЕ
	|	ТаблицаРаспределение.Номенклатура.* КАК Номенклатура,
	|	ТаблицаРаспределение.Номенклатура.ВидНоменклатуры.* КАК ВидНоменклатуры,
	|	ТаблицаРаспределение.Номенклатура.Родитель.* КАК Родитель,
	|	ТаблицаРаспределение.Характеристика.* КАК Характеристика,
	|	ТаблицаРаспределение.Склад.* КАК Склад}
	|СГРУППИРОВАТЬ ПО
	|	&ТекстПоляГруппировки";
	
	Если ПараметрыПостроенияЗапроса.ТипСписка = "СписокНоменклатура"
		Или ПараметрыПостроенияЗапроса.ТипСписка = "СписокНоменклатураПартнера" Тогда
		
		ТекстПоляГруппировки = "ТаблицаРаспределение.Номенклатура";
		ТекстОтбораПоНоменклатуре = "ИСТИНА";
		
	ИначеЕсли ПараметрыПостроенияЗапроса.ТипСписка = "СписокХарактеристики" Тогда
		
		ТекстПоляГруппировки = "ТаблицаРаспределение.Характеристика";
		ТекстОтбораПоНоменклатуре = "ТаблицаРаспределение.Номенклатура = &Номенклатура";
		
	КонецЕсли;
	
	// поле группировки
	ТекстПодзапроса = СтрЗаменить(ТекстПодзапроса,
		"&ТекстПоляГруппировки",
		ТекстПоляГруппировки);
	
	// текст условия
	ТекстПодзапроса = СтрЗаменить(ТекстПодзапроса,
		"&ТекстОтбораПоНоменклатуре",
		ТекстОтбораПоНоменклатуре);
		
	// текст отбора по складам
	ТекстОтбораПоСкладам = ?(ПараметрыПостроенияЗапроса.НесколькоСкладов,
		"ТаблицаРаспределение.Склад В (&Склад)",
		"ТаблицаРаспределение.Склад = &Склад");
	
	ТекстПодзапроса = СтрЗаменить(ТекстПодзапроса,
		"&ТекстОтбораПоСкладам",
		ТекстОтбораПоСкладам);
		
	// текст условия по назначению
	Если Не ПараметрыПостроенияЗапроса.ОтображатьОстаткиПоНазначению Тогда
		
		ТекстПодзапроса = СтрЗаменить(ТекстПодзапроса,
			"&Назначение",
			"ЗНАЧЕНИЕ(Справочник.Назначения.ПустаяСсылка)");
		
	КонецЕсли;
	
	// текст условия по контролируемой партии
	Если Не ПараметрыПостроенияЗапроса.ОтображатьОстаткиКонтролируемойПартии Тогда
		
		ТекстПодзапроса = СтрЗаменить(ТекстПодзапроса,
			"&КонтролируемаяПартия",
			"ЗНАЧЕНИЕ(Справочник.КонтролируемыеПартии.ПустаяСсылка)");
		
	КонецЕсли;
	
	// условие по отображению остатков
	ТекстОстаткиНаСкладах = ?(ПараметрыПостроенияЗапроса.ОтображатьОстаткиНаСкладах,
		"ИСТИНА",
		"ЛОЖЬ");
	
	ТекстПодзапроса = СтрЗаменить(ТекстПодзапроса,
		"&ТекстОстаткиНаСкладах",
		ТекстОстаткиНаСкладах);
	
	Возврат СтрШаблон("(%1)", ТекстПодзапроса);
	
КонецФункции

// Возвращает текст соединения с таблицей остатков товаров.
//
// Параметры:
// 	ПараметрыПостроенияЗапроса - см. ПодборТоваровКлиентСервер.НовыйПараметрыПостроенияЗапросаСписка
//
// Возвращаемое значение:
// 	Строка
//
Функция ТекстСоединенияСТаблицейОстатков(ПараметрыПостроенияЗапроса)
	
	Если ПараметрыПостроенияЗапроса.ТипСписка = "СписокНоменклатура" Тогда
		
		Результат =
			?(ПараметрыПостроенияЗапроса.ТолькоВНаличии,
				"
				|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ &ПодзапросОстаткиТоваров КАК ВсеОстатки
				|		ПО СправочникНоменклатура.Ссылка = ВсеОстатки.ПолеСоединения",
				"
				|		ЛЕВОЕ СОЕДИНЕНИЕ &ПодзапросОстаткиТоваров КАК ВсеОстатки
				|		ПО СправочникНоменклатура.Ссылка = ВсеОстатки.ПолеСоединения");
		
	Иначе
		
		Результат =
			?(ПараметрыПостроенияЗапроса.ТолькоВНаличии,
				"
				|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ &ПодзапросОстаткиТоваров КАК ВсеОстатки
				|		ПО ХарактеристикиНоменклатуры.Ссылка = ВсеОстатки.ПолеСоединения",
				"
				|		ЛЕВОЕ СОЕДИНЕНИЕ &ПодзапросОстаткиТоваров КАК ВсеОстатки
				|		ПО ХарактеристикиНоменклатуры.Ссылка = ВсеОстатки.ПолеСоединения")
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Возвращает текст создания временной таблицы с курсами валют.
//
// Параметры:
// 	ПараметрыПостроенияЗапроса - см. ПодборТоваровКлиентСервер.НовыйПараметрыПостроенияЗапросаСписка
// 	ОтборПоВалюте - Булево
//
// Возвращаемое значение:
// 	Строка
//
Функция ТекстВременнойТаблицыКурсыВалют(ПараметрыПостроенияЗапроса, ОтборПоВалюте)
	
	ТекстВременнойТаблицы =
	"ВЫБРАТЬ
	|	ТаблицаКурсов.Валюта КАК Валюта,
	|	ТаблицаКурсов.КурсЧислитель КАК КурсЧислитель,
	|	ТаблицаКурсов.КурсЗнаменатель КАК КурсЗнаменатель
	|ПОМЕСТИТЬ ИмяВременнойТаблицы
	|ИЗ
	|	РегистрСведений.ОтносительныеКурсыВалют.СрезПоследних(&УсловиеОтбораПоДате, БазоваяВалюта = &БазоваяВалюта
	|		И &УсловиеОтбораПоВалюте) КАК ТаблицаКурсов";
	
	УсловиеОтбораПоДате = ?(ПараметрыПостроенияЗапроса.ЕстьКурсыВБудущем,
		"КОНЕЦПЕРИОДА(&Дата, ДЕНЬ)",
		"");
	
	ТекстВременнойТаблицы = СтрЗаменить(ТекстВременнойТаблицы,
		"&УсловиеОтбораПоДате",
		УсловиеОтбораПоДате);
	
	ТекстВременнойТаблицы = СтрЗаменить(ТекстВременнойТаблицы,
		"&УсловиеОтбораПоВалюте",
		?(ОтборПоВалюте,
			"Валюта = &Валюта",
			"ИСТИНА {Валюта.* КАК Валюта}"));
	
	Возврат ТекстВременнойТаблицы;
	
КонецФункции

// Возвращает текст создания временной таблицы с данными ассортимента.
//
// Параметры:
// 	ПараметрыПостроенияЗапроса - см. ПодборТоваровКлиентСервер.НовыйПараметрыПостроенияЗапросаСписка
//
// Возвращаемое значение:
// 	Строка
//
Функция ТекстВременнойТаблицыАссортимент(ПараметрыПостроенияЗапроса)
	
	ТекстВременнойТаблицы =
	"ВЫБРАТЬ
	|	Ассортимент.Номенклатура КАК Номенклатура,
	|	Ассортимент.ВидЦены КАК ВидЦены,
	|	Ассортимент.РазрешеныПродажи КАК РазрешеныПродажи
	|ПОМЕСТИТЬ ИмяВременнойТаблицы
	|ИЗ
	|	РегистрСведений.Ассортимент.СрезПоследних(КОНЕЦПЕРИОДА(&Дата, ДЕНЬ), ОбъектПланирования = &ОбъектПланирования
	|	И &УсловиеПоТипуСписка) КАК Ассортимент
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Номенклатура,
	|	ВидЦены";
	
	УсловиеПоТипуСписка = ?(ПараметрыПостроенияЗапроса.ТипСписка = "СписокНоменклатура",
		"ИСТИНА {(Номенклатура).* КАК Номенклатура}",
		"Номенклатура = &Номенклатура");
	
	ТекстВременнойТаблицы = СтрЗаменить(ТекстВременнойТаблицы,
		"&УсловиеПоТипуСписка",
		УсловиеПоТипуСписка);
	
	Возврат ТекстВременнойТаблицы;
	
КонецФункции

