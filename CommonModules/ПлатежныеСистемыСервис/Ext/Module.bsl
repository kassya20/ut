///////////////////////////////////////////////////////////////////////////////////////////////////////
// Подсистема "ИнтернетПоддержкаПользователей.ПлатежныеСистемы.БазоваяФункциональностьПлатежныхСистем".
// ОбщийМодуль.ПлатежныеСистемыСервис.
// 
// Серверные процедуры обмена данными с платежными системами через сервис Интернет-поддержки:
//  - отправка запроса в сервис Интернет-поддержки и конструкторы параметров запроса;
//  - обработка ответов с преобразованием данных;
//  - методы получения URL операции;
//  - методы получения параметров аутентификации;
//  - запрос и отзыв токена сервиса Интернет-поддержки.
//
///////////////////////////////////////////////////////////////////////////////////////////////////////

#Область СлужебныйПрограммныйИнтерфейс

#Область ОбщегоНазначения

// Формирует описание параметров выполнения операции к сервису методом POST.
//
// Параметры:
//  Адрес - Строка - относительный адрес операции в сервисе.
//  ДанныеЗапроса - Структура - данные запроса в формате Структура.
//
// Возвращаемое значение:
//  Структура:
//    * method - Строка - http метод "POST".
//    * path - Строка - относительный адрес операции в сервисе. Заполняется по входному параметру Адрес.
//    * requestHeaders - Соответствие из КлючИЗначение - список заголовков запроса:
//        ** Ключ - Строка
//        ** Значение - Строка
//    * uriVariables - Соответствие из КлючИЗначение - список параметров URI:
//        ** Ключ - Строка - имя параметра в поле "path".
//        ** Значение - Строка - значение подмены.
//    * queryParams - Соответствие из КлючИЗначение - список параметров запроса:
//        ** Ключ - Строка
//        ** Значение - Массив из Строка, Строка
//    * requestBodyJsonObject - Неопределено - данные запроса отсутствуют.
//                            - Структура - данные запроса в формате Структура. Заполняется по входному параметру
//        ДанныеЗапроса.
//
Функция НовыйПараметрыОперацииСервисаPOST(Адрес, ДанныеЗапроса) Экспорт
	
	Результат = НовыйПараметрыОперацииСервисаGET(Адрес);
	Результат.method = "POST";
	
	Результат.requestHeaders.Вставить("Content-Type", "application/json");
	Результат.Вставить("requestBodyJsonObject", ДанныеЗапроса);
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти

#Область ВызовОпераций

// Выполняет вызов операции сервиса платежной системы через сервис Интернет-поддержки.
//
// Параметры:
//  ИдентификаторПлатежнойСистемы - Строка - идентификатор платежной системы.
//  КореньАдресаИнтеграции - Строка - первая часть адресной строки для вызова метода интеграции с сервисом.
//  ДанныеДляОбработки - Структура - данные которые будут сериализованы в JSON и отправлены в сервис Интернет-поддержки.
//  ТекстОшибки - Строка - текст пояснения ошибки, который будет выведен в шапке текста ошибки в выходном поле
//    ИнформацияОбОшибке. В случае ошибки, сформированный текст будет записан в журнал регистрации с уровнем Ошибка.
//  ТекстЛога - Строка - текст пояснения лога, который будет вставлен в шапку текста лога и записан в журнал
//    регистрации с уровнем Информация.
//  ПовторитьЕслиОшибка - Булево - если Истина то, в случае ошибок, запрос сервиса будет повторятся до 6 итераций.
//
// Возвращаемое значение:
//  Структура:
//    * КодОшибки - Строка - строковый код возникшей ошибки.
//        Возможные значения см. НастройкиПлатежныхСистемСлужебный.ПереопределитьКодОшибкиСервиса.
//    * СообщениеОбОшибке - Строка, ФорматированнаяСтрока - сообщение об ошибке для пользователя.
//    * ИнформацияОбОшибке - Строка, ФорматированнаяСтрока - сообщение об ошибке для администратора.
//    * КодСостояния - Число - код состояния ответа сервиса платежной системы.
//    * ДанныеОтвета - Неопределено - ошибка выполнения операции.
//                   - Соответствие Из КлючИЗначение - данные ответа сервиса платежной системы.
//    * ИдентификаторЗапроса - Строка - идентификатор отправляемого запроса (X-Correlation-ID).
//
Функция ВыполнитьОперациюСервиса(
		ИдентификаторПлатежнойСистемы,
		КореньАдресаИнтеграции,
		ДанныеДляОбработки,
		ТекстОшибки,
		ТекстЛога,
		ПовторитьЕслиОшибка = Ложь) Экспорт
	
	Результат = ПлатежныеСистемыСлужебный.НовыйРезультатОперации();
	Результат.Вставить("КодСостояния", 0);
	Результат.Вставить("ДанныеОтвета", Неопределено);
	Результат.Вставить("ИдентификаторЗапроса", "");
	
	СписокСвойствОшибки = "КодОшибки,СообщениеОбОшибке,ИнформацияОбОшибке";
	
	БазовыйАдрес = ИдентификаторПлатежнойСистемы;
	Если ЗначениеЗаполнено(КореньАдресаИнтеграции) Тогда
		БазовыйАдрес = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
			"%1/%2",
			КореньАдресаИнтеграции,
			ИдентификаторПлатежнойСистемы);
	КонецЕсли;
	
	URLОперации = URLОперацииСервиса(
		СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
			"/%1/authorized/v1/request/execute-rest-operation-call",
			БазовыйАдрес));
	
	АутентификацииИПП = ПараметрыАутентификацииИПП(URLОперации);
	Если Не ПустаяСтрока(АутентификацииИПП.КодОшибки) Тогда
		ЗаполнитьЗначенияСвойств(Результат, АутентификацииИПП, СписокСвойствОшибки);
		Возврат Результат;
	КонецЕсли;
	
	ПараметрыЗапроса = НовыйПараметрыЗапроса("POST");
	ПараметрыЗапроса.Заголовки.Вставить("Authorization", АутентификацииИПП.Аутентификация);
	
	ПараметрыЗапроса.ДанныеДляОбработки = ОбщегоНазначения.ЗначениеВJSON(ДанныеДляОбработки);
	
	Результат.ИдентификаторЗапроса = ПараметрыЗапроса.Заголовки.Получить("X-Correlation-ID");
	
	Если ПовторитьЕслиОшибка Тогда
		РезультатОперации = ВыполнитьОперациюСПовтором(
			URLОперации,
			ПараметрыЗапроса);
	Иначе
		РезультатОперации = ИнтернетПоддержкаПользователей.ЗагрузитьСодержимоеИзИнтернет(
			URLОперации,
			,
			,
			ПараметрыЗапроса);
	КонецЕсли;
	
	// Обработка ответа сервиса Интернет-поддержки
	Если ПустаяСтрока(РезультатОперации.КодОшибки) Тогда
		
		ДанныеОтвета = ДанныеОтветаОперации(РезультатОперации.Содержимое);
		Если ПустаяСтрока(ДанныеОтвета.КодОшибки) Тогда
			ЗаполнитьЗначенияСвойств(Результат, ДанныеОтвета, "КодСостояния,ДанныеОтвета");
		Иначе
			ЗаполнитьЗначенияСвойств(Результат, ДанныеОтвета, СписокСвойствОшибки);
			ИнформацияОбОшибке = Результат.ИнформацияОбОшибке;
		КонецЕсли;
		
	Иначе
		
		Результат.КодСостояния = РезультатОперации.КодСостояния;
		Результат.КодОшибки = НастройкиПлатежныхСистемСлужебный.ПереопределитьКодОшибкиСервиса(
			РезультатОперации.КодСостояния);
		Результат.СообщениеОбОшибке = НастройкиПлатежныхСистемСлужебный.ПереопределитьСообщениеПользователю(
			Результат.КодОшибки,
			РезультатОперации.Содержимое,
			РезультатОперации.КодСостояния);
		
		ИнформацияОбОшибке = РезультатОперации.ИнформацияОбОшибке;
		
	КонецЕсли;
	
	// Логирование результата запроса
	Если Не ПустаяСтрока(ТекстЛога) Тогда
		
		ШаблонЛогирования = НСтр("ru = '%1
			|Платежная система: %2
			|%3 %4 (%5)
			|X-Correlation-ID: %6
			|
			|%7'");
		
		ПлатежныеСистемыСлужебный.ЗаписатьИнформациюВЖурналРегистрации(
			СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
				ШаблонЛогирования,
				ТекстЛога,
				ИдентификаторПлатежнойСистемы,
				ДанныеДляОбработки.method,
				ДанныеДляОбработки.path,
				Результат.КодСостояния,
				ПараметрыЗапроса.Заголовки["X-Correlation-ID"],
				РезультатОперации.Содержимое));
		
	КонецЕсли;
	
	// Обработка ошибки
	Если Не ПустаяСтрока(Результат.КодОшибки) Тогда
		
		ШаблонОшибки = НСтр("ru = '%1
			|%2
			|
			|Техническая информация об ошибке:
			|Платежная система: %3
			|URL: %4 %5
			|Код ошибки: %6
			|X-Correlation-ID: %7
			|Подробная информация:
			|%8'");
		
		Результат.ИнформацияОбОшибке = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
			ШаблонОшибки,
			ТекстОшибки,
			Результат.СообщениеОбОшибке,
			ИдентификаторПлатежнойСистемы,
			ДанныеДляОбработки.method,
			ДанныеДляОбработки.path,
			Результат.КодОшибки,
			ПараметрыЗапроса.Заголовки["X-Correlation-ID"],
			ИнформацияОбОшибке);
		
		ПлатежныеСистемыСлужебный.ЗаписатьИнформациюВЖурналРегистрации(Результат.ИнформацияОбОшибке, Истина);
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

#Область ОбщегоНазначения

// Описание нового объекта параметров запроса.
//
// Параметры:
//  Метод - Строка - http метод "GET" или "POST".
//    Значение по умолчанию: GET.
//
// Возвращаемое значение:
//  Структура:
//    * Метод - Строка - http метод "GET" или "POST".
//    * Заголовки - Соответствие из КлючИЗначение - заголовки запроса.
//        Для каждого нового объекта добавляется ключ X-Correlation-ID с уникальным идентификатором запроса и
//        заполняется X-Program-Nick именем программы в сервиса Интернет-поддержки.
//        Для каждого нового объекта с методом POST добавляется ключ Content-Type со значением application/json:
//          ** Ключ - Строка
//          ** Значение - Строка
//    * ФорматОтвета - Число - определяет формат возврата содержимого ответа операции:
//        0 - имя файла ответа;
//        1 - как строка (формат ответа по умолчанию);
//        2 - как двоичные данные.
//    * НастройкиПрокси - см. ПолучениеФайловИзИнтернета.НастройкиПроксиНаСервере
//    * Таймаут - Число - количество секунд ожидания завершения запроса.
//    * ФорматДанныхДляОбработки - Число - формат отправки данных:
//        0 - имя файла;
//        1 - как строка (формат ответа по умолчанию);
//        2 - как двоичные данные.
//    * ДанныеДляОбработки - Неопределено - данные для обработки не инициализированы.
//                         - Строка - данные для отправки методов передаваемые методом POST.
//
Функция НовыйПараметрыЗапроса(Метод = "GET")
	
	ИдентификаторЗапроса = Строка(
		Новый УникальныйИдентификатор());
	ИдентификаторПрограммы = ИнтернетПоддержкаПользователей.ИмяПрограммы();
	
	Заголовки = Новый Соответствие();
	Заголовки.Вставить("X-Correlation-ID", ИдентификаторЗапроса);
	Заголовки.Вставить("X-Program-Nick", ИдентификаторПрограммы);
	
	Если Метод = "POST" Тогда
		Заголовки.Вставить("Content-Type", "application/json");
	КонецЕсли;

	ДанныеДляОбработки = Неопределено;	// Неопределено, Строка
	НастройкиПрокси = ПолучениеФайловИзИнтернета.НастройкиПроксиНаСервере();
	
	Результат = Новый Структура();
	Результат.Вставить("Метод", Метод);
	Результат.Вставить("Заголовки", Заголовки);
	Результат.Вставить("ФорматОтвета", 1);
	Результат.Вставить("НастройкиПрокси", НастройкиПрокси);
	Результат.Вставить("Таймаут", 30);
	Результат.Вставить("ФорматДанныхДляОбработки", 1);
	Результат.Вставить("ДанныеДляОбработки", ДанныеДляОбработки);
	
	Возврат Результат;
	
КонецФункции

// Формирует описание параметров выполнения операции к сервису методом GET.
//
// Параметры:
//  Адрес - Строка - относительный адрес операции в сервисе.
//
// Возвращаемое значение:
//  Структура:
//    * method - Строка - http метод "GET".
//    * path - Строка - относительный адрес операции в сервисе. Заполняется по входному параметру Адрес.
//    * requestHeaders - Соответствие из КлючИЗначение - список заголовков запроса:
//        ** Ключ - Строка
//        ** Значение - Строка
//    * uriVariables - Соответствие из КлючИЗначение - список параметров URI:
//        ** Ключ - Строка - имя параметра в поле "path".
//        ** Значение - Строка - значение подмены.
//    * queryParams - Соответствие из КлючИЗначение - список параметров запроса:
//        ** Ключ - Строка
//        ** Значение - Массив из Строка, Строка
//
Функция НовыйПараметрыОперацииСервисаGET(Адрес)
	
	Заголовки = Новый Соответствие();
	ПараметрыURI = Новый Соответствие();
	ПараметрыЗапроса = Новый Соответствие();
	
	Результат = Новый Структура();
	Результат.Вставить("method", "GET");
	Результат.Вставить("path", Адрес);
	Результат.Вставить("requestHeaders", Заголовки);
	Результат.Вставить("uriVariables", ПараметрыURI);
	Результат.Вставить("queryParams", ПараметрыЗапроса);
	
	Возврат Результат;
	
КонецФункции

// Выполняет вызов операции в 6 итераций. Повторные вызовы операции требуются
// для случаев, когда результат выполнения вызова не определен.
// Между вызовами добавляется пауза, чтобы не нагружать сервис банка.
//
// Паузы между вызовами:
// - между 2-м и 3-м вызовом делается пауза 3 секунды;
// - между 3-м и 4-м вызовом делается пауза 10 секунд;
// - между 4-м и 5-м вызовом делается пауза 15 секунд;
// - между 5-м и 6-м вызовом делается пауза 15 секунд; 
// 
// Параметры:
//  URLОперации - Строка - URL вызываемой операции.
//  ПараметрыЗапроса - Структура, Неопределено - уточняющие параметры запроса.
//    см. ИнтернетПоддержкаПользователей.ЗагрузитьСодержимоеИзИнтернет
// 
// Возвращаемое значение:
//  см. ИнтернетПоддержкаПользователей.ЗагрузитьСодержимоеИзИнтернет
//
Функция ВыполнитьОперациюСПовтором(URLОперации, ПараметрыЗапроса)
	
	КоличествоОпераций = 0;
	Пока КоличествоОпераций <= 5 Цикл
		
		РезультатОтправки = ИнтернетПоддержкаПользователей.ЗагрузитьСодержимоеИзИнтернет(
			URLОперации,
			,
			,
			ПараметрыЗапроса);
		
		Если РезультатОтправки.КодСостояния < 500
			И РезультатОтправки.КодСостояния <> 0 Тогда
			Прервать;
		КонецЕсли;
		
		// Перед выполнением повторного вызова при работе в модели
		// сервиса необходимо получить новый тикет.
		Если ОбщегоНазначения.РазделениеВключено() Тогда
			
			АутентификацииИПП = ПараметрыАутентификацииИПП(URLОперации);
			Если Не ПустаяСтрока(АутентификацииИПП.КодОшибки) Тогда
				Прервать;
			КонецЕсли;
			
			ПараметрыЗапроса.Заголовки.Вставить("Authorization", АутентификацииИПП.Аутентификация);
			
		КонецЕсли;
		
		КоличествоОпераций = КоличествоОпераций + 1;
		
		Если КоличествоОпераций = 2 Тогда
			ИнтернетПоддержкаПользователей.Пауза(3);
		ИначеЕсли КоличествоОпераций = 3 Тогда
			ИнтернетПоддержкаПользователей.Пауза(5);
		ИначеЕсли КоличествоОпераций = 4 Тогда
			ИнтернетПоддержкаПользователей.Пауза(10);
		ИначеЕсли КоличествоОпераций = 5 Тогда
			ИнтернетПоддержкаПользователей.Пауза(15);
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат РезультатОтправки;
	
КонецФункции

#КонецОбласти

#Область ПараметрыПодключения

// Определяет URL для вызова сервиса интеграции с платежными системами.
//
// Параметры:
//  Операция - Строка - путь к ресурсу.
//
// Возвращаемое значение:
//  Строка
//
Функция URLОперацииСервиса(Операция)
	
	Возврат "https://"
		+ НастройкиПлатежныхСистемСлужебный.ХостСервисаОбменаДанными()
		+ "/api"
		+ Операция;
	
КонецФункции

// Определяет URL для получения ресурсов.
//
// Параметры:
//  Операция - Строка - путь к ресурсу.
//
// Возвращаемое значение:
//  Строка
//
Функция URLРесурсов(Операция)
	
	Возврат "https://"
		+ НастройкиПлатежныхСистемСлужебный.ХостСервисаОбменаДанными()
		+ "/resources"
		+ Операция;
	
КонецФункции

// Формирует строку с идентификатором платежной системы для подстановки в адресную строку запроса к сервису.
//
// Параметры:
//  НастройкаПодключения - СправочникСсылка.НастройкиПодключенияКПлатежнымСистемам - настройка подключения, с помощью
//    которой выполняется запрос.
//
// Возвращаемое значение:
//  Строка - идентификатор платежной системы.
//
Функция БазовыйАдресПлатежнойСистемыПоНастройке(НастройкаПодключения)
	
	ПлатежнаяСистема = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(
		НастройкаПодключения,
		"ПлатежнаяСистема");
		
	РезультатОперации = "";
	
	ПлатежныеСистемыСобытия.ПриОпределенииБазовогоАдресаПлатежнойСистемы(
		ПлатежнаяСистема,
		РезультатОперации);

	Возврат РезультатОперации;

КонецФункции

// Загружает из сервиса описание платежной системы.
// 
// Возвращаемое значение:
//  Соответствие Из КлючИЗначение - описания платежных систем:
//    * Ключ - ПеречислениеСсылка.ПлатежныеСервисы - платежная система.
//    * Значение - Структура - описание платежной системы:
//      ** Описание - Строка - описание для первой страницы мастера.
//      ** Подключение - Строка - подсказка для страницы ввода параметров.
// 
Функция ОписанияПлатежныхСистем() Экспорт
	
	Результат = Новый Соответствие;

	URLОперации = URLРесурсов("/templates/servicesDescription.json");
	
	ПараметрыЗапроса = Новый Структура("ФорматОтвета", 1);
	// Вызов операции сервиса.
	РезультатОтправки = ИнтернетПоддержкаПользователей.ЗагрузитьСодержимоеИзИнтернет(
		URLОперации,
		,
		,
		ПараметрыЗапроса);
	
	Если Не ПустаяСтрока(РезультатОтправки.КодОшибки) Тогда
		
		КодОшибки = НастройкиПлатежныхСистемСлужебный.ПереопределитьКодОшибкиСервиса(
			РезультатОтправки.КодСостояния);
		СообщениеОбОшибке = НастройкиПлатежныхСистемСлужебный.ПереопределитьСообщениеПользователю(
			КодОшибки,
			РезультатОтправки.Содержимое,
			РезультатОтправки.КодСостояния);
		
		ИнформацияОбОшибке = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
			НСтр("ru = 'Не удалось получить описание платежных систем.
				|
				|%1
				|
				|Техническая информация об ошибке:
				|При получении описаний платежных систем сервис вернул ошибку.
				|URL: %2
				|Код ошибки: %3
				|Подробная информация:
				|%4'"),
			СообщениеОбОшибке,
			URLОперации,
			РезультатОтправки.КодОшибки,
			РезультатОтправки.ИнформацияОбОшибке);
		
		ПлатежныеСистемыСлужебный.ЗаписатьИнформациюВЖурналРегистрации(
			ИнформацияОбОшибке,
			Истина);
		
		Возврат Результат;
		
	КонецЕсли;
	
	Попытка
		РезультатЧтения = ОбщегоНазначения.JSONВЗначение(
			РезультатОтправки.Содержимое); // Соответствие Из КлючИЗначение
	Исключение
		
		ИнформацияОбОшибке = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
			НСтр("ru = 'Не удалось получить описание платежных систем.
				|
				|%1
				|
				|Техническая информация об ошибке:
				|URL: %2
				|Ответ сервиса: %3
				|ТекстОшибки:
				|%4'"),
			НСтр("ru = 'Не удалось прочитать JSON. Формат ответа сервиса не соответствует ожидаемому.'"),
			URLОперации,
			РезультатОтправки.Содержимое,
			ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
		
		ПлатежныеСистемыСлужебный.ЗаписатьИнформациюВЖурналРегистрации(
			ИнформацияОбОшибке,
			Истина);
		
		Возврат Результат;
		
	КонецПопытки;
	
	ПолученноеОписание = РезультатЧтения.Получить("services"); // Массив Из Соответствие
	Если ТипЗнч(ПолученноеОписание) <> Тип("Массив") Тогда
		Возврат Результат;
	КонецЕсли;

	ИдентификаторОзонПэй = "-";
	Если ОбщегоНазначения.ПодсистемаСуществует("ИнтернетПоддержкаПользователей.ПлатежныеСистемы.ОзонПэй") Тогда
		МодульОзонПэйСервис = ОбщегоНазначения.ОбщийМодуль("ОзонПэйСервис");
		ИдентификаторОзонПэй = МодульОзонПэйСервис.ИдентификаторПлатежнойСистемы();
	КонецЕсли;
		
	Для Каждого Описание Из ПолученноеОписание Цикл // Соответствие Из КлючИЗначение
		
		ИдентификаторСервиса = Описание.Получить("id");
		
		Если ИдентификаторСервиса = ИдентификаторОзонПэй Тогда
			ОписаниеСервиса = Новый Структура;
			ОписаниеСервиса.Вставить(
				"Описание",
				ПолучитьОписание(Описание, "description"));
			
			ОписаниеСервиса.Вставить(
				"Подключение",
				ПолучитьОписание(Описание, "settingsDescription"));
					
			Результат.Вставить(
				Перечисления.ПлатежныеСервисы.ОзонПэй,
				ОписаниеСервиса);
				
		КонецЕсли;
		
	КонецЦикла;
		
	Возврат Результат;
	
КонецФункции

// Формирует описание из полученного значения
// 
// Параметры:
//  ПолученноеОписание - Соответствие Из КлючИЗначение - полученное из сервиса описание.
//  ИмяПараметра - Строка - имя поля в ПолученноеОписание.
// 
// Возвращаемое значение:
//  Строка, ФорматированнаяСтрока - результат разбора полученного значения.
// 
Функция ПолучитьОписание(ПолученноеОписание, ИмяПараметра)
	
	ИсходноеОписание = ПолученноеОписание.Получить(ИмяПараметра);
	Если ТипЗнч(ИсходноеОписание) <> Тип("Строка")
		Или ПустаяСтрока(ИсходноеОписание) Тогда
		Возврат "";
	КонецЕсли;
	
	Возврат СтроковыеФункции.ФорматированнаяСтрока(ИсходноеОписание);
	
КонецФункции

#КонецОбласти

#Область Аутентификация

// Возвращает данные аутентификации в сервисах Интернет-поддержки.
//
// Параметры:
//  URLОперации -Строка - URL запроса, для которой получаются данные аутентификации.
//
// Возвращаемое значение:
//  Структура - структура, содержащая результаты определения параметров аутентификации пользователя Интернет-поддержки:
//    * КодОшибки - Строка - строковый код возникшей ошибки.
//        Список ошибок:
//          "" - операция выполнена успешно.
//          см. НастройкиПлатежныхСистемСлужебный.КодОшибкиНеверныйЛогинИлиПароль - ошибка получения данных аутентификации.
//    * СообщениеОбОшибке - Строка, ФорматированнаяСтрока - сообщение об ошибке для пользователя.
//    * ИнформацияОбОшибке - Строка, ФорматированнаяСтрока - сообщение об ошибке для администратора.
//    * Аутентификация - Строка - строка аутентификации для использования в заголовке запроса.
//
Функция ПараметрыАутентификацииИПП(URLОперации)
	
	УстановитьПривилегированныйРежим(Истина);
	
	Результат = ПлатежныеСистемыСлужебный.НовыйРезультатОперации();
	Результат.Вставить("Аутентификация", "");
	
	Если ОбщегоНазначения.РазделениеВключено() Тогда
		
		МодульИнтернетПоддержкаПользователейВМоделиСервиса =
			ОбщегоНазначения.ОбщийМодуль("ИнтернетПоддержкаПользователейВМоделиСервиса");
		РезультатПолученияТикета =
			МодульИнтернетПоддержкаПользователейВМоделиСервиса.ТикетАутентификацииНаПорталеПоддержки(URLОперации);
		
		Если ПустаяСтрока(РезультатПолученияТикета.КодОшибки) Тогда
			Результат.Аутентификация = ИнтернетПоддержкаПользователей.ЗаголовокBearerАутентификации(
				РезультатПолученияТикета.Тикет);
		Иначе
			
			Результат.КодОшибки = НастройкиПлатежныхСистемСлужебный.КодОшибкиНеверныйЛогинИлиПароль();
			Результат.СообщениеОбОшибке = РезультатПолученияТикета.СообщениеОбОшибке;
			Результат.ИнформацияОбОшибке = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
				НСтр("ru = 'Ошибка выполнения запроса %1.
					|Не удалось получить тикет аутентификации Интернет-поддержки.
					|%2'"),
				URLОперации,
				РезультатПолученияТикета.ИнформацияОбОшибке);
			
			ПлатежныеСистемыСлужебный.ЗаписатьИнформациюВЖурналРегистрации(Результат.ИнформацияОбОшибке, Истина);
			
		КонецЕсли;
		
	Иначе
		
		ПараметрыАутентификации = ИнтернетПоддержкаПользователей.ДанныеАутентификацииПользователяИнтернетПоддержки();
		Если ПараметрыАутентификации = Неопределено Тогда
			
			Результат.КодОшибки = НастройкиПлатежныхСистемСлужебный.КодОшибкиНеверныйЛогинИлиПароль();
			Результат.СообщениеОбОшибке  = НСтр(
				"ru = 'Для работы с сервисом необходимо подключить Интернет-поддержку пользователей.'");
			Результат.ИнформацияОбОшибке = НСтр(
				"ru = 'Не заполнены данные аутентификации Интернет-поддержки пользователей.'");
			
			ПлатежныеСистемыСлужебный.ЗаписатьИнформациюВЖурналРегистрации(Результат.ИнформацияОбОшибке, Истина);
			
		Иначе
			Результат.Аутентификация = ИнтернетПоддержкаПользователей.ЗаголовокБазовойСхемыАутентификации(
				ПараметрыАутентификации.Логин,
				ПараметрыАутентификации.Пароль);
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Формирует данные аутентификации в платежной системе.
//
// Параметры:
//  НастройкаПодключения - СправочникСсылка.НастройкиПодключенияКПлатежнымСистемам - настройки подключения к сервису.
//
// Возвращаемое значение:
//  Структура:
//    * ПлатежнаяСистема - ПеречислениеСсылка.ПлатежныеСервисы - платежная система, для который выполняется получение
//        данных аутентификации.
//    * ДанныеАутентификации - Неопределено, Произвольный - данные аутентификации. Неопределено, если данные не найдены
//
Функция ПараметрыАутентификацииПлатежнойСистемы(НастройкаПодключения)
	
	Результат = ПлатежныеСистемыСлужебный.НовыйРезультатОперации();
	Результат.Вставить("ПлатежнаяСистема", Перечисления.ПлатежныеСервисы.ПустаяСсылка());
	Результат.Вставить("ДанныеАутентификации", Неопределено);
	
	УстановитьПривилегированныйРежим(Истина);
	
	ДанныеХранилища = ОбщегоНазначения.ПрочитатьДанныеИзБезопасногоХранилища(НастройкаПодключения);
	
	УстановитьПривилегированныйРежим(Ложь);
	
	Если ТипЗнч(ДанныеХранилища) = Тип("Структура") Тогда
		
		Результат.ДанныеАутентификации = ДанныеХранилища;
		Результат.ДанныеАутентификации.Удалить("Служебный_ДанныеТокенов");
		
	КонецЕсли;
	
	Результат.ПлатежнаяСистема = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(
		НастройкаПодключения,
		"ПлатежнаяСистема");
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти

#Область ОбработкаОтветов

// Выполняет обработку ответа сервиса Интернет-поддержки и возвращает данные полученные из сервиса платежной системы.
//
// Параметры:
//  ТелоОтвета - Строка - содержимое ответа сервиса Интернет-поддержки.
//
// Возвращаемое значение:
//  Структура:
//    * КодОшибки - Строка - строковый код возникшей ошибки.
//        Возможные значения:
//          "" - ответ прочитан успешно
//          см. НастройкиПлатежныхСистемСлужебный.КодОшибкиОшибкаСервиса - ошибка чтения ответа.
//    * СообщениеОбОшибке - Строка, ФорматированнаяСтрока - сообщение об ошибке для пользователя.
//    * ИнформацияОбОшибке - Строка, ФорматированнаяСтрока - сообщение об ошибке для администратора.
//    * КодСостояния - Число - код состояния ответа из сервиса платежной системы.
//    * ДанныеОтвета - Неопределено - ошибка чтения ответа сервиса Интернет-поддержки.
//                   - Соответствие Из КлючИЗначение - данные ответа из сервиса платежной системы.
//
Функция ДанныеОтветаОперации(ТелоОтвета)
	
	Результат = ПлатежныеСистемыСлужебный.НовыйРезультатОперации();
	Результат.Вставить("КодСостояния", 0);
	Результат.Вставить("ДанныеОтвета", Неопределено);
	
	// Ожидаемый формат ответа:
	// {
	//   "responseStatus": 0,
	//   "responseBodyJsonObject": {}
	// }
	
	Попытка
		ОбработкаОтвета = ОбщегоНазначения.JSONВЗначение(ТелоОтвета);
	Исключение
		
		Результат.КодОшибки = НастройкиПлатежныхСистемСлужебный.КодОшибкиОшибкаСервиса();
		Результат.СообщениеОбОшибке = НСтр("ru = 'Ошибка чтения ответа сервиса Портала 1С:ИТС'");
		Результат.ИнформацияОбОшибке = ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
		
		Возврат Результат;
		
	КонецПопытки;
	
	Результат.КодСостояния = ОбработкаОтвета.Получить("responseStatus");
	Результат.ДанныеОтвета = ОбработкаОтвета.Получить("responseBodyJsonObject");
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти

#Область ВызовОперацийТокенаАутентификацииСервиса

// Получает токен для аутентификации в сервисе payment-gateway.
//
// Параметры:
//  НастройкаПодключения - СправочникСсылка.НастройкиПодключенияКПлатежнымСистемам - настройка подключения к платежной
//    системе.
//  ИдентификаторТокена - Строка - уникальный идентификатор токена;
//  ИмяСервиса - Строка - имя сервиса для которого выпускается токен.
//  ДополнительныеПараметры - Неопределено, Соответствие Из КлючИЗначение - дополнительные параметры настройки
//    подключения. Если значение не задано, то дополнительные параметры будут получены из базы.
//
// Возвращаемое значение:
//  Структура - получения данных аутентификации:
//    * Токен - Строка, Неопределено - идентификатор, по которому выполняется оплата;
//    * КодОшибки - Строка - строковый код возникшей ошибки, который может быть обработан вызывающим методом;
//    * СообщениеОбОшибке  - Строка, ФорматированнаяСтрока - сообщение об ошибке для пользователя;
//    * ИнформацияОбОшибке - Строка, ФорматированнаяСтрока - сообщение об ошибке для администратора.
//
Функция ОперацияЗапросТокенаАутентификацииСервиса(
	НастройкаПодключения,
	ИдентификаторТокена,
	ИмяСервиса,
	Знач ДополнительныеПараметры = Неопределено) Экспорт
	
	ПлатежныеСистемыСлужебный.ЗаписатьИнформациюВЖурналРегистрации(
		НСтр("ru = 'Получение токена в сервисе payment-gateway.'"),
		Ложь);
	
	РезультатОперации = ПлатежныеСистемыСлужебный.НовыйРезультатОперации();
	РезультатОперации.Вставить("Токен", Неопределено);
	
	URLОперации = URLОперацииСервиса(
		СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
			"/%1/authorized/supportive-api/%2/tokens/request",
			БазовыйАдресПлатежнойСистемыПоНастройке(НастройкаПодключения),
			ИмяСервиса));

	СписокСвойствОшибки = "КодОшибки,СообщениеОбОшибке,ИнформацияОбОшибке";
	АутентификацииИПП = ПараметрыАутентификацииИПП(URLОперации);
	Если Не ПустаяСтрока(АутентификацииИПП.КодОшибки) Тогда
		ЗаполнитьЗначенияСвойств(РезультатОперации, АутентификацииИПП, СписокСвойствОшибки);
		Возврат РезультатОперации;
	КонецЕсли;
	
	ПараметрыАутентификации = ПараметрыАутентификацииПлатежнойСистемы(НастройкаПодключения);
	
	ПараметрыЗапросаJSON = tokens_request(
		ПараметрыАутентификации,
		ИдентификаторТокена);
	
	ПараметрыЗапроса = НовыйПараметрыЗапроса("POST");
	ПараметрыЗапроса.Заголовки.Вставить("Authorization", АутентификацииИПП.Аутентификация);
	ПараметрыЗапроса.ДанныеДляОбработки = ПараметрыЗапросаJSON;
	
	// Вызов операции сервиса.
	РезультатОтправки = ИнтернетПоддержкаПользователей.ЗагрузитьСодержимоеИзИнтернет(
		URLОперации,
		,
		,
		ПараметрыЗапроса);
	
	Если Не ПустаяСтрока(РезультатОтправки.КодОшибки) Тогда
		
		РезультатОперации.КодОшибки = НастройкиПлатежныхСистемСлужебный.ПереопределитьКодОшибкиСервиса(
			РезультатОтправки.КодСостояния);
		РезультатОперации.СообщениеОбОшибке = НастройкиПлатежныхСистемСлужебный.ПереопределитьСообщениеПользователю(
				РезультатОперации.КодОшибки,
				РезультатОтправки.Содержимое,
				РезультатОтправки.КодСостояния);
		
		РезультатОперации.ИнформацияОбОшибке = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
			НСтр("ru = 'Не удалось получить токен аутентификации в сервисе.
				|
				|%1
				|
				|Техническая информация об ошибке:
				|При получении токена сервис вернул ошибку.
				|URL: %2
				|Код ошибки: %3
				|X-Correlation-ID: %4
				|Подробная информация:
				|%5'"),
			РезультатОперации.СообщениеОбОшибке,
			URLОперации,
			РезультатОтправки.КодОшибки,
			ПараметрыЗапроса.Заголовки.Получить("X-Correlation-ID"),
			РезультатОтправки.ИнформацияОбОшибке);
		
		ПлатежныеСистемыСлужебный.ЗаписатьИнформациюВЖурналРегистрации(
			Строка(РезультатОперации.ИнформацияОбОшибке),
			Истина);
		
		Возврат РезультатОперации;
		
	КонецЕсли;
	
	ДанныеТокена = ПрочитатьДанные_tokens_request(РезультатОтправки.Содержимое);
	
	РезультатОперации.Токен = ДанныеТокена.Токен;
	
	ПлатежныеСистемыСлужебный.ЗаписатьИнформациюВЖурналРегистрации(
		НСтр("ru = 'Завершено получение токена.'"),
		Ложь);
	
	Возврат РезультатОперации;
	
КонецФункции

// Формирует параметры запроса для операции
// ​/authorized/supportive-api/%1/tokens/request
//
Функция tokens_request(
		ПараметрыАутентификации,
		ИдентификаторТокена)
	
	ЗаписьДанныхСообщения = Новый ЗаписьJSON;
	ЗаписьДанныхСообщения.УстановитьСтроку();
	ЗаписьДанныхСообщения.ЗаписатьНачалоОбъекта();
	
	ПлатежныеСистемыСобытия.ПриПодготовкеЗапроса_tokens_request(
		ПараметрыАутентификации,
		ЗаписьДанныхСообщения);
	
	ЗаписьДанныхСообщения.ЗаписатьИмяСвойства("clientTokenId");
	ЗаписьДанныхСообщения.ЗаписатьЗначение(ИдентификаторТокена);
	
	ЗаписьДанныхСообщения.ЗаписатьКонецОбъекта();
	
	Возврат ЗаписьДанныхСообщения.Закрыть();
	
КонецФункции

// Разбирает отчет сервиса на запрос получения токена
//
// Параметры:
//  ТелоJSON - Строка - тело ответа сервиса.
//
// Возвращаемое значение:
//  Структура - результат запроса токена:
//   * Токен - Строка, Неопределено - токен.
// 
Функция ПрочитатьДанные_tokens_request(ТелоJSON)
	
	//	{
	//  "serviceToken": "string",
	//}
	
	РезультатЧтения = ОбщегоНазначения.JSONВЗначение(ТелоJSON); // Соответствие Из КлючИЗначение
	
	Результат = Новый Структура;
	
	Результат.Вставить("Токен", РезультатЧтения.Получить("serviceToken"));
	
	Возврат Результат;
	
КонецФункции

// Выполняет отзыв токенов аутентификации в сервисе payment-gateway.
//
// Параметры:
//  НастройкаПодключения - СправочникСсылка.НастройкиПодключенияКПлатежнымСистемам - настройка подключения к платежной
//    системе.
//  ИдентификаторыТокенов - Массив Из Строка - идентификаторы токенов для деактивации.
//  ИмяСервиса - Строка - имя сервиса для которого выпускается токен.
//
// Возвращаемое значение:
//  Структура - получения данных аутентификации:
//    *КодОшибки - Строка - строковый код возникшей ошибки, который
//     может быть обработан вызывающим методом;
//    *СообщениеОбОшибке  - Строка, ФорматированнаяСтрока - сообщение об ошибке для пользователя;
//    *ИнформацияОбОшибке - Строка, ФорматированнаяСтрока - сообщение об ошибке для администратора.
//
Функция ОперацияОтзывТокеновАутентификацииСервиса(
		НастройкаПодключения,
		ИдентификаторыТокенов,
		ИмяСервиса) Экспорт
	
	ПлатежныеСистемыСлужебный.ЗаписатьИнформациюВЖурналРегистрации(
		НСтр("ru = 'Отзыв токена в сервисе payment-gateway.'"),
		Ложь);
	
	РезультатОперации = ПлатежныеСистемыСлужебный.НовыйРезультатОперации();

	URLОперации = URLОперацииСервиса(
		СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
			"/%1/authorized/supportive-api/%2/tokens/revoke",
			БазовыйАдресПлатежнойСистемыПоНастройке(НастройкаПодключения),
			ИмяСервиса));

	СписокСвойствОшибки = "КодОшибки,СообщениеОбОшибке,ИнформацияОбОшибке";
	АутентификацииИПП = ПараметрыАутентификацииИПП(URLОперации);
	Если Не ПустаяСтрока(АутентификацииИПП.КодОшибки) Тогда
		ЗаполнитьЗначенияСвойств(РезультатОперации, АутентификацииИПП, СписокСвойствОшибки);
		Возврат РезультатОперации;
	КонецЕсли;
	
	ПараметрыЗапросаJSON = tokens_revoke(
		ИдентификаторыТокенов);
	
	ПараметрыЗапроса = НовыйПараметрыЗапроса("POST");
	ПараметрыЗапроса.Заголовки.Вставить("Authorization", АутентификацииИПП.Аутентификация);
	ПараметрыЗапроса.ДанныеДляОбработки = ПараметрыЗапросаJSON;
	
	// Вызов операции сервиса.
	РезультатОтправки = ИнтернетПоддержкаПользователей.ЗагрузитьСодержимоеИзИнтернет(
		URLОперации,
		,
		,
		ПараметрыЗапроса);
	
	Если Не ПустаяСтрока(РезультатОтправки.КодОшибки) Тогда
		
		РезультатОперации.КодОшибки = НастройкиПлатежныхСистемСлужебный.ПереопределитьКодОшибкиСервиса(
			РезультатОтправки.КодСостояния);
		РезультатОперации.СообщениеОбОшибке = НастройкиПлатежныхСистемСлужебный.ПереопределитьСообщениеПользователю(
			РезультатОперации.КодОшибки,
			РезультатОтправки.Содержимое,
			РезультатОтправки.КодСостояния);
		
		РезультатОперации.ИнформацияОбОшибке = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
			НСтр("ru = 'Не удалось получить токен аутентификации в сервисе.
				|
				|%1
				|
				|Техническая информация об ошибке:
				|При получении токена сервис вернул ошибку.
				|URL: %2
				|Код ошибки: %3
				|X-Correlation-ID: %4
				|Подробная информация:
				|%5'"),
			РезультатОперации.СообщениеОбОшибке,
			URLОперации,
			РезультатОтправки.КодОшибки,
			ПараметрыЗапроса.Заголовки.Получить("X-Correlation-ID"),
			РезультатОтправки.ИнформацияОбОшибке);
		
		ПлатежныеСистемыСлужебный.ЗаписатьИнформациюВЖурналРегистрации(
			Строка(РезультатОперации.ИнформацияОбОшибке),
			Истина);
		
		Возврат РезультатОперации;
		
	КонецЕсли;
	
	ПлатежныеСистемыСлужебный.ЗаписатьИнформациюВЖурналРегистрации(
		НСтр("ru = 'Отзыв токенов завершен.'"),
		Ложь);

	Возврат РезультатОперации;
	
КонецФункции

// Формирует параметры запроса для операции
// ​/isl​/acquiring​/authorized​/supportive-api​/{serviceNick}​/tokens​/revoke
//
Функция tokens_revoke(ИдентификаторыТокенов)
	
	ЗаписьДанныхСообщения = Новый ЗаписьJSON;
	ЗаписьДанныхСообщения.УстановитьСтроку();
	ЗаписьДанныхСообщения.ЗаписатьНачалоОбъекта();
	
	ЗаписьДанныхСообщения.ЗаписатьИмяСвойства("clientTokenIds");
	
	ЗаписьДанныхСообщения.ЗаписатьНачалоМассива();
	
	Для Каждого ИдентификаторТокена Из ИдентификаторыТокенов Цикл
		ЗаписьДанныхСообщения.ЗаписатьЗначение(ИдентификаторТокена);
	КонецЦикла;
	
	ЗаписьДанныхСообщения.ЗаписатьКонецМассива();
	
	ЗаписьДанныхСообщения.ЗаписатьКонецОбъекта();
	
	Возврат ЗаписьДанныхСообщения.Закрыть();
	
КонецФункции

