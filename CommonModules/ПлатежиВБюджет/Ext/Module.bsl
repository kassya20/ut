
#Область ПрограммныйИнтерфейс

// Проверяет наличие дублей УИН в документах
//
// Параметры:
//	ИдентификаторПлатежа - Строка - Проверяемый идентификатор платежа
//	Ссылка - ДокументСсылка - Проверяемый документ.
//
// Возвращаемое значение:
//   Массив из Структура - Массив описаний ошибок (пустой, если дубли не найдены):
//     * ТекстОшибки - Строка - Текст сообщения об ошибке со списком документов-дублей
//     * ИмяПоля - Строка - Имя поля, к которому относится ошибка (ИдентификаторПлатежа)
//
Функция ПроверитьДублиУИН(ИдентификаторПлатежа, Ссылка) Экспорт
	
	Результат = Новый Массив;
	
	Если ПлатежиВБюджетКлиентСервер.АдминистраторНачисленияФССП(ИдентификаторПлатежа) Тогда
		Возврат Результат;
	КонецЕсли;
	
	Дубли = ДублиУИН(ИдентификаторПлатежа, Ссылка);
	Если Дубли.Количество() = 0 Тогда
		Возврат Результат;
	КонецЕсли;
	
	ШаблонТекста = НСтр("ru = 'Возможно, уникальный идентификатор платежа указан ошибочно.
    	|
        |[ГдеЕщеУказанЭтотИдентификатор]
        |
        |Одинаковые идентификаторы следует указывать только при частичной оплате.'");
	
	Если Дубли.Количество() = 1 Тогда
			
		ГдеЕщеУказанЭтотИдентификатор = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
			НСтр("ru = 'Этот же идентификатор платежа указан в другом документе:
				|%1.'"),
			Дубли[0]);
			
	ИначеЕсли Дубли.Количество() = 2 Тогда
			
		ГдеЕщеУказанЭтотИдентификатор = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
			НСтр("ru = 'Этот же идентификатор платежа указан в других документах:
				|- %1
				|- %2.'"), 
			Дубли[0], 
			Дубли[1]);
			
	ИначеЕсли Дубли.Количество() = 3 Тогда
		
		ГдеЕщеУказанЭтотИдентификатор = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
			НСтр("ru = 'Этот же идентификатор платежа указан в других документах:
				|- %1
				|- %2
				|- %3.'"),
			Дубли[0], 
			Дубли[1], 
			Дубли[2]);
			
	Иначе
		
		ТекстЕщеДокументов = СтроковыеФункцииКлиентСервер.ЧислоЦифрамиПредметИсчисленияПрописью(
			Дубли.Количество() - 2, 
			НСтр("ru = 'более ранний документ, более ранних документа, более ранних документов'"));
			
		ГдеЕщеУказанЭтотИдентификатор = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
			НСтр("ru = 'Этот же идентификатор платежа указан в других документах:
				|- %1
				|- %2
				|  и еще %3.'"),
			Дубли[0], 
			Дубли[1],
			ТекстЕщеДокументов);
			
	КонецЕсли;
	
	ПараметрыТекста = Новый Структура;
	ПараметрыТекста.Вставить("ГдеЕщеУказанЭтотИдентификатор", ГдеЕщеУказанЭтотИдентификатор);
	
	ТекстОшибки = СтроковыеФункцииКлиентСервер.ВставитьПараметрыВСтроку(ШаблонТекста, ПараметрыТекста);
	
	ОписаниеОшибки = Новый Структура;
	ОписаниеОшибки.Вставить("ТекстОшибки", ТекстОшибки);
	ОписаниеОшибки.Вставить("ИмяПоля",     "ИдентификаторПлатежа");
	
	Результат.Добавить(ОписаниеОшибки);
	
	Возврат Результат;
	
КонецФункции

// Устанавливает надпись реквизитов платежа в бюджет
//
// Параметры:
//    Форма - ФормаКлиентскогоПриложения - форма, из которой вызвана функция.
//
Процедура УстановитьНадписьРеквизитовПлатежаВБюджет(Форма) Экспорт
	
	Объект = Форма.Объект;
	
	Если СокрЛП(Объект.КодБК) <> "" Тогда
		КБК = СокрЛП(Объект.КодБК);
	Иначе
		КБК = НСтр("ru = '<КБК не указан>'");
	КонецЕсли;
	
	Если СокрЛП(Объект.КодОКАТО) <> "" Тогда
		КодТерритории = СокрЛП(Объект.КодОКАТО);
	Иначе
		
		КодТерритории = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
			НСтр("ru = '<%1 не указан>'"),
			?(Объект.Дата >= Форма.ДатаНачалаПримененияПриказа107н Или Не ЗначениеЗаполнено(Объект.Дата), НСтр("ru='ОКТМО'"), НСтр("ru='ОКАТО'")));
		
	КонецЕсли;
	
	Если ПлатежиВБюджетКлиентСервер.РеквизитЗаполнен(Объект.СтатусСоставителя) Тогда
		СтатусСоставителя = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
			НСтр("ru = 'Статус: %1'"),
			Объект.СтатусСоставителя);
	Иначе
		СтатусСоставителя = НСтр("ru = '<Статус: не указан>'");
	КонецЕсли;
	
	Форма.НадписьРеквизитыПлатежаВБюджет = КБК + "; "
		+ КодТерритории + "; "
		+ СтатусСоставителя + "; "
		+ Объект.ПоказательОснования + "; ";
		
	Если Объект.ВидПеречисленияВБюджет = Перечисления.ВидыПеречисленийВБюджет.НалоговыйПлатеж
		Или Объект.ВидПеречисленияВБюджет = Перечисления.ВидыПеречисленийВБюджет.ТаможенныйПлатеж Тогда
		Форма.НадписьРеквизитыПлатежаВБюджет = Форма.НадписьРеквизитыПлатежаВБюджет
			+ Объект.ПоказательПериода + "; "
			+ Объект.ПоказательНомера + "; "
			+ Объект.ПоказательДаты + "; ";
	ИначеЕсли Форма.ПрименениеПриказа58н Тогда
		Форма.НадписьРеквизитыПлатежаВБюджет = Форма.НадписьРеквизитыПлатежаВБюджет
			+ Объект.ПоказательНомера + "; "
			+ Объект.ПоказательДаты + "; ";
	ИначеЕсли Объект.СтатусСоставителя = "03"
		Или Объект.СтатусСоставителя = "19"
		Или Объект.СтатусСоставителя = "20"
		Или Объект.СтатусСоставителя = "24"
		Тогда
		Форма.НадписьРеквизитыПлатежаВБюджет = Форма.НадписьРеквизитыПлатежаВБюджет
			+ Объект.ПоказательНомера + "; ";
	КонецЕсли;
	
	Форма.НадписьРеквизитыПлатежаВБюджет = Форма.НадписьРеквизитыПлатежаВБюджет + ?(Не Форма.ПрименениеПриказа126н, Объект.ПоказательТипа + "; ", "");
	
	Отказ = Ложь; МассивНепроверяемыхРеквизитов = Новый Массив; ФлагОбменСБанками = Истина; ОшибкиЗаполнения = "";
	
	ТекущийОбъект = Форма.РеквизитФормыВЗначение("Объект");
	ДенежныеСредстваСерверЛокализация.ПроверитьЗаполнениеНалоговыхРеквизитов(ТекущийОбъект, Отказ, МассивНепроверяемыхРеквизитов, ФлагОбменСБанками, ОшибкиЗаполнения);
	
	Если ЗначениеЗаполнено(ОшибкиЗаполнения) Тогда
		Форма.Элементы.НадписьРеквизитыПлатежаВБюджет.ЦветТекста = ЦветаСтиля.РезультатПроблемаЦвет;
		Форма.Элементы.НадписьРеквизитыПлатежаВБюджет.Подсказка = ОшибкиЗаполнения;
	Иначе
		Форма.Элементы.НадписьРеквизитыПлатежаВБюджет.ЦветТекста = ЦветаСтиля.ГиперссылкаЦвет;
		Форма.Элементы.НадписьРеквизитыПлатежаВБюджет.Подсказка = "";
	КонецЕсли;
	
КонецПроцедуры

#Область ЕдиныйНалоговыйПлатеж

// Возвращает признак использования Единого налогового платежа
//
// Параметры:
//	Организация - СправочникСсылка.Организации - проверяемая организация
//	Период - Дата - дата проверки
//	
// Возвращаемое значение:
//	Булево - признак использования ЕНП.
//
Функция ИспользуетсяЕдиныйНалоговыйПлатеж(Организация, Период) Экспорт
	
	Если ПлатежиВБюджетКлиентСервер.ДействуетФедеральныйЗакон263ФЗ(Период) Тогда
		Возврат Истина;
	КонецЕсли;
	
	// Федеральный закон от 29.11.2021 № 379-ФЗ "О внесении изменений в часть первую Налогового кодекса
	// Российской Федерации" устанавливает что с 1 июля по 31 декабря 2022 года (включительно) организации
	// и индивидуальные предприниматели вправе применять особый порядок уплаты налогов посредством перечисления
	// в бюджетную систему Российской Федерации единого налогового платежа.
	
	ДатаНачалаЭксперимента = '20220701';
	Если Период < ДатаНачалаЭксперимента Тогда
		Возврат Ложь;
	КонецЕсли;
	
	ПараметрыУчетнойПолитики = НастройкиНалоговУчетныхПолитик.ДействующиеПараметрыНалоговУчетныхПолитикНаДату(
		"НастройкиСистемыНалогообложения", Организация, Период);
	Возврат ПараметрыУчетнойПолитики.ПлательщикЕНП;
	
КонецФункции

// Проверяет корректность указания типа налога и выводит предупреждение
//
// Параметры:
//    Форма - ФормаКлиентскогоПриложения - форма, из которой вызвана функция
//    ДатаПлатежа - Дата - дата платежа.
//
Процедура ПроверитьКорректностьЗаполненияПлатежаВБюджет(Форма, Знач ДатаПлатежа) Экспорт
	
	Объект = Форма.Объект;
	Элементы = Форма.Элементы;
	
	Элементы.ГруппаТипНалога.ЦветФона = Новый Цвет;
	Элементы.ТипНалога.ОтображениеПодсказки = ОтображениеПодсказки.Авто;
	Элементы.ТипНалога.Подсказка = "";
	
	
	Если Не ИспользуетсяЕдиныйНалоговыйПлатеж(Объект.Организация, ДатаПлатежа) Тогда
		Возврат;
	КонецЕсли;
	
	ЕстьОшибкаРеквизитовПолучателя = Ложь;
	
	
	ДоступныеВидыНалоговВзносов = Новый Массив;
	ДоступныеВидыНалоговВзносов.Добавить(Справочники.ВидыНалоговВзносов.ПустаяСсылка());
	ДоступныеВидыНалоговВзносов.Добавить(Справочники.ВидыНалоговВзносов.ПрочиеНалогиИСборы);
	ОбщегоНазначенияКлиентСервер.ДополнитьМассив(ДоступныеВидыНалоговВзносов,
		ЕдиныйНалоговыйСчет.ВидыНалоговУплачиваемыеОтдельно(ДатаПлатежа));
	
	Если ДоступныеВидыНалоговВзносов.Найти(Объект.ТипНалога) = Неопределено ИЛИ ЕстьОшибкаРеквизитовПолучателя Тогда
		ТекстПодсказки = НСтр(
			"ru = 'С 1 января 2023 года уплату любых налогов необходимо в обязательном порядке осуществлять посредством единого налогового платежа на единый налоговый счет.
			|Проверьте корректность заполнения реквизитов.'"); // https://www.nalog.gov.ru/rn77/ens/
		Элементы.ГруппаТипНалога.ЦветФона = ЦветаСтиля.ПолеСОшибкойФон;
		Элементы.ТипНалога.ОтображениеПодсказки = ОтображениеПодсказки.ОтображатьСнизу;
		Элементы.ТипНалога.Подсказка = ТекстПодсказки;
	КонецЕсли;
	
КонецПроцедуры

// Устарела. Следует использовать ЕдиныйНалоговыйСчет.ВидыНалоговУплачиваемыеОтдельно
// Проверяет использование регламентированного учета в рассчитываемом периоде.
//
// Возвращаемое значение:
//	Массив - массив налогов, уплачиваемых отдельно
//
Функция ТипыНалоговУплачиваемыеОтдельно() Экспорт
	
	ВидыНалоговВзносов = Новый Массив;
	ВидыНалоговВзносов.Добавить(Справочники.ВидыНалоговВзносов.ЕдиныйНалоговыйПлатеж);
	ВидыНалоговВзносов.Добавить(Справочники.ВидыНалоговВзносов.ФССНС);
	
	Возврат ВидыНалоговВзносов;
	
КонецФункции

#КонецОбласти

// Устанавливает реквизиты платежа в бюджет по умолчанию.
// 
// Параметры:
//  ДокументОбъект - ДокументОбъект.СписаниеБезналичныхДенежныхСредств, ДокументОбъект.ЗаявкаНаРасходованиеДенежныхСредств -
//                   объект, в котором заполняются реквизиты платежа в бюджет.
//
Процедура РеквизитыПлатежаВБюджетПоУмолчанию(ДокументОбъект) Экспорт

	ДатаДокумента = ?(ДокументОбъект.Дата = Дата('00010101'), ТекущаяДатаСеанса(), ДокументОбъект.Дата);
	
	ПараметрыПлатежа = ПараметрыПлатежаДляЗаполнения();
	ПараметрыПлатежа.Дата = ДатаДокумента;
	ПараметрыПлатежа.ВидПлатежа = ДокументОбъект.ВидПеречисленияВБюджет;
	ПараметрыПлатежа.ТипНалога = ДокументОбъект.ТипНалога;
	ПараметрыПлатежа.КодБК = ДокументОбъект.КодБК;
	
	ЗаполняемыеРеквизиты = ЗаполняемыеРеквизитыОбъекта();
	
	Если СтрДлина(ДокументОбъект.ИННПлательщика) = 5
		И ДокументОбъект.ВидПеречисленияВБюджет = Перечисления.ВидыПеречисленийВБюджет.НалоговыйПлатеж Тогда
		ЗаполняемыеРеквизиты.КПППлательщика = "";
	КонецЕсли;
	
	ЗаполнитьБюджетныеРеквизитыПоУмолчанию(ДокументОбъект, ЗаполняемыеРеквизиты, ПараметрыПлатежа);

КонецПроцедуры

#КонецОбласти

#Область СлужебныйПрограммныйИнтерфейс

// Проверяет корректность заполнения реквизитов плательщика (ИНН, КПП, текст плательщика)
// и формирует массив описаний найденных ошибок.
//
// Параметры:
//   ДокументОбъект - ДокументОбъект, ДанныеФормыСтруктура - документ, содержащий проверяемые реквизиты плательщика
//   РеквизитыПлательщика - см. ДенежныеСредстваСерверЛокализация.ОписаниеРеквизитовСтороныДляПроверки
//   ВыводитьСообщение - Булево - признак необходимости вывода сообщений пользователю об ошибках
//   Отказ - Булево - признак отмены проведения документа (используется при выводе сообщений)
//
// Возвращаемое значение:
//   Массив из Строка - массив текстовых описаний найденных ошибок заполнения
//
Функция ОшибкиЗаполненияРеквизитовПлательщика(ДокументОбъект, РеквизитыПлательщика, ВыводитьСообщение, Отказ = Ложь) Экспорт

	ОшибкиЗаполнения = ДенежныеСредстваСерверЛокализация.ОшибкиЗаполненияРеквизитовПлательщикаПолучателя(Истина, ДокументОбъект, РеквизитыПлательщика, Ложь, Отказ);
	ИНН = СокрЛП(РеквизитыПлательщика.ИНН);
	КПП = СокрЛП(РеквизитыПлательщика.КПП);
	
	Если СтрДлина(РеквизитыПлательщика.Наименование) > 160 Тогда
		ОшибкиЗаполнения.Добавить(НСтр("ru = 'Наименование плательщика превышает 160 символов'"));
	КонецЕсли;
	
	Если ПустаяСтрока(ИНН) Тогда
		ОшибкиЗаполнения.Добавить(НСтр("ru = 'Поле ""ИНН"" плательщика не заполнено'"));
	КонецЕсли;
	
	Если ПустаяСтрока(КПП) Тогда
		ОшибкиЗаполнения.Добавить(НСтр("ru = 'Поле ""КПП"" плательщика не заполнено'"));
	КонецЕсли;
	
	ДатаПроверки = ДокументОбъект.Дата;
	
	Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(ДокументОбъект, "ПроведеноБанком")
		И ДокументОбъект.ПроведеноБанком Тогда
		ДатаПроверки = ДокументОбъект.ДатаПроведенияБанком;
	КонецЕсли;
	
	ДополнитьОшибкиИННКПППлательщикаПоОбъекту(ОшибкиЗаполнения, ДокументОбъект, ДатаПроверки, ИНН, КПП);
	
	Если ВыводитьСообщение Тогда
		
		Для Каждого ТекстОшибки Из ОшибкиЗаполнения Цикл
			ОбщегоНазначения.СообщитьПользователю(ТекстОшибки, , "НадписьРеквизитыПлательщика", , Отказ);
		КонецЦикла;
		
	КонецЕсли;
	
	Возврат ОшибкиЗаполнения;

КонецФункции

// Проверяет корректность заполнения реквизитов получателя платежа
//
// Параметры:
//   ДокументОбъект - ДокументОбъект - документ, для которого выполняется проверка
//   РеквизитыПолучателя - см. ДенежныеСредстваСерверЛокализация.ОписаниеРеквизитовСтороныДляПроверки
//   ВыводитьСообщение - Булево - признак необходимости вывода сообщений пользователю об ошибках
//   Отказ - Булево - признак отказа при проведении документа
//
// Возвращаемое значение:
//   Массив из Строка - список сообщений об ошибках
//
Функция ОшибкиЗаполненияРеквизитовПолучателя(ДокументОбъект, РеквизитыПолучателя, ВыводитьСообщение, Отказ = Ложь) Экспорт

	ОшибкиЗаполнения = ДенежныеСредстваСерверЛокализация.ОшибкиЗаполненияРеквизитовПлательщикаПолучателя(Ложь, ДокументОбъект, РеквизитыПолучателя, Ложь, Отказ);
	ИНН = СокрЛП(РеквизитыПолучателя.ИНН);
	КПП = СокрЛП(РеквизитыПолучателя.КПП);
	
	Если СтрДлина(РеквизитыПолучателя.Наименование) > 160 Тогда
		ОшибкиЗаполнения.Добавить(НСтр("ru = 'Наименование получателя превышает 160 символов'"));
	КонецЕсли;
	
	Если ПустаяСтрока(ИНН) Тогда
		ОшибкиЗаполнения.Добавить(НСтр("ru = 'Поле ""ИНН"" получателя не заполнено'"));
	КонецЕсли;
	
	Если ПустаяСтрока(КПП) Тогда
		ОшибкиЗаполнения.Добавить(НСтр("ru = 'Поле ""КПП"" получателя не заполнено'"));
	КонецЕсли;
	
	Если РеквизитыПолучателя.ЮрФизЛицо = Перечисления.ЮрФизЛицо.ЮрЛицо 
		И СтрДлина(КПП) <> 9 Тогда
		ОшибкиЗаполнения.Добавить(НСтр("ru = 'КПП получателя должен содержать 9 символов'"));
	КонецЕсли;
	
	Если ВыводитьСообщение Тогда
		
		Для Каждого ТекстОшибки Из ОшибкиЗаполнения Цикл
			ОбщегоНазначения.СообщитьПользователю(ТекстОшибки, , "НадписьРеквизитыПолучателя", , Отказ);
		КонецЦикла;
		
	КонецЕсли;
	
	Возврат ОшибкиЗаполнения;

КонецФункции

// Дополняет список ошибок заполнения данными о некорректном сочетании ИНН, КПП и статуса плательщика.
//
// Параметры:
//   ОшибкиЗаполнения - Массив из Строка - коллекция для добавления обнаруженных ошибок
//   Объект - ДокументОбъект.ЗаявкаНаРасходованиеДенежныхСредств, ДокументОбъект.СписаниеБезналичныхДенежныхСредств, Структура - 
//            объект с данными о платеже
//   Дата - Дата - дата для определения действующих нормативных документов
//   ИНН - Строка - ИНН плательщика
//   КПП - Строка - КПП плательщика
Процедура ДополнитьОшибкиИННКПППлательщикаПоОбъекту(ОшибкиЗаполнения, Объект, Дата, ИНН, КПП) Экспорт

	ЭтоЮрЛицо = СтрДлина(ИНН) = 10;
	ЭтоФизЛицо = СтрДлина(ИНН) = 12;
	ЭтоИнЮрЛицо = СтрДлина(ИНН) = 5;
	ПустойИНН = ИНН = "0";
	
	ЕНП = Объект.ТипНалога = Справочники.ВидыНалоговВзносов.ЕдиныйНалоговыйПлатеж
		Или ПлатежиВБюджетКлиентСервер.ЭтоЕдиныйНалоговыйПлатеж(Объект.КодБК);
	
	ДействуетПриказ58н = ПлатежиВБюджетКлиентСервер.ДействуетПриказ58н_202604(Дата);
	
	Если Не ЭтоИнЮрЛицо И Не ПустойИНН 
		И (ИНН <> "" Или ЭтоЮрЛицо) Тогда
		
		ТекстОшибки = "";
		
		Если Не РегламентированныеДанныеКлиентСервер.ИННСоответствуетТребованиям(ИНН, ЭтоЮрЛицо, ТекстОшибки) Тогда
			ОшибкиЗаполнения.Добавить(СтрЗаменить(ТекстОшибки, НСтр("ru = 'ИНН'"), НСтр("ru = 'ИНН плательщика'")));
		КонецЕсли;
		
	КонецЕсли;
	
	Если ЭтоФизЛицо И КПП <> "0" Тогда
		ОшибкиЗаполнения.Добавить(НСтр("ru = 'КПП плательщика может принимать только значение ""0""'"));
	КонецЕсли;
	
	Если ДействуетПриказ58н И ЭтоЮрЛицо И КПП <> "0" И ЕНП Тогда
		ОшибкиЗаполнения.Добавить(НСтр("ru = 'КПП плательщика может принимать только значение ""0""'"));
	КонецЕсли;
	
	Если ЭтоЮрЛицо И СтрДлина(КПП) <> 9 И Не ЕНП Тогда
		ОшибкиЗаполнения.Добавить(НСтр("ru = 'КПП плательщика должен содержать 9 символов'"));
	КонецЕсли;
	
	Если ДействуетПриказ58н И ЭтоИнЮрЛицо И КПП <> "0" И СтрДлина(КПП) <> 9 И Не ЕНП Тогда
		ОшибкиЗаполнения.Добавить(НСтр("ru = 'КПП плательщика должен содержать 9 символов или значение ""0""'"));
	КонецЕсли;
	
	Если ДействуетПриказ58н И ПустойИНН И КПП <> "0" Тогда
		ОшибкиЗаполнения.Добавить(НСтр("ru = 'КПП плательщика должен быть заполнен значением ""0"" или заполнен ИНН плательщика'"));
	КонецЕсли;
	
	Если (Объект.СтатусСоставителя = "06"
		Или Объект.СтатусСоставителя = "07")
		И Не ЭтоЮрЛицо Тогда
		ОшибкиЗаполнения.Добавить(НСтр("ru = 'ИНН плательщика для выбранного статуса плательщика должен содержать 10 символов'"));
	КонецЕсли;
	
	// Указан статус физлица
	Если (Объект.СтатусСоставителя = "03"
		Или Объект.СтатусСоставителя = "04"
		Или Объект.СтатусСоставителя = "16"
		Или Объект.СтатусСоставителя = "17"
		Или Объект.СтатусСоставителя = "19"
		Или Объект.СтатусСоставителя = "20"
		Или Объект.СтатусСоставителя = "24")
		И Не ЭтоФизЛицо
		И Не ПустойИНН Тогда
		ОшибкиЗаполнения.Добавить(НСтр("ru = 'ИНН плательщика для выбранного статуса плательщика должен содержать 12 символов или ""0""'"));
	КонецЕсли;
	
	// Указан статус для иностранного лица
	Если Объект.СтатусСоставителя = "13"
		И Не ЭтоИнЮрЛицо
		И Не ПустойИНН Тогда
		ОшибкиЗаполнения.Добавить(НСтр("ru = 'ИНН плательщика для выбранного статуса плательщика должен содержать 5 символов или ""0""'"));
	КонецЕсли;
	
	Если Объект.СтатусСоставителя = "30"
		И Не ПустойИНН Тогда
		ОшибкиЗаполнения.Добавить(НСтр("ru = 'ИНН плательщика для выбранного статуса плательщика должен иметь значение ""0""'"));
	КонецЕсли;
	
	// Указан статус для юрлица
	Если (Объект.СтатусСоставителя = "06"
		Или Объект.СтатусСоставителя = "07"
		Или Объект.СтатусСоставителя = "34"
		Или Объект.СтатусСоставителя = "05"
		Или Объект.СтатусСоставителя = "32")
		И ЭтоЮрЛицо
		И СтрДлина(КПП) <> 9 Тогда
		ОшибкиЗаполнения.Добавить(НСтр("ru = 'КПП плательщика для выбранного статуса плательщика должен содержать 9 символов'"));
	КонецЕсли;

КонецПроцедуры

// Возвращает значения реквизитов платежа в бюджет по умолчанию в соответствии с видом платежа и действующим приказом на указанную дату.
//
// Параметры:
//   Дата - Дата - дата, на которую определяется действующий нормативный документ
//   ВидПлатежа - ПеречислениеСсылка.ВидыПеречисленийВБюджет - вид перечисления в бюджет
//   КодБК - Строка - код бюджетной классификации
//   ТипНалога - СправочникСсылка.ВидыНалоговВзносов - тип налога или взноса
//
// Возвращаемое значение:
//   - Структура - значения реквизитов платежа и параметры заполнения в зависимости от вида платежа и действующего приказа:
//     * ДанныеЗаполнения - Структура - значения реквизитов платежа по умолчанию:
//       ** КПППлательщика - Строка - КПП плательщика.
//       ** КодОКАТО - Строка - код по ОКАТО.
//       ** СтатусСоставителя - Строка - статус составителя.
//       ** ПоказательОснования - Строка - показатель основания.
//       ** ПоказательПериода - Строка - показатель периода.
//       ** ПоказательНомера - Строка - показатель номера.
//       ** ПоказательДаты - Строка - показатель даты.
//       ** ПоказательТипа - Строка - показатель типа.
//     * НеизменныеРеквизиты - Массив из Строка - реквизиты, которые заполняются безусловно значениями по умолчанию.
//
Функция ЗначенияРеквизитовПлатежаВБюджетПоУмолчанию(Дата, ВидПлатежа, КодБК, ТипНалога) Экспорт

	ЗначенияПоУмолчанию = Неопределено;
	ДействуетПриказ58н_202604 = ПлатежиВБюджетКлиентСервер.ДействуетПриказ58н_202604(Дата);
	ДействуетПриказ199н_202302 = ПлатежиВБюджетКлиентСервер.ДействуетПриказ199н_202302(Дата);
	ДействуетПриказ199н_202401 = ПлатежиВБюджетКлиентСервер.ДействуетПриказ199н_202401(Дата);
	ДействуетПриказ126н = ПлатежиВБюджетКлиентСервер.ДействуетПриказ126н(Дата);
	
	ЭтоЕНП = Ложь;
	
	Если ЗначениеЗаполнено(КодБК)
		И СокрЛП(КодБК) <> "0" Тогда
		ЭтоЕНП = ПлатежиВБюджетКлиентСервер.ЭтоЕдиныйНалоговыйПлатеж(КодБК);
	Иначе
		ЭтоЕНП = ВидПлатежа = Перечисления.ВидыПеречисленийВБюджет.НалоговыйПлатеж
			И ТипНалога = Справочники.ВидыНалоговВзносов.ЕдиныйНалоговыйПлатеж;
	КонецЕсли;
	
	Если ЭтоЕНП Тогда
		
		Если ДействуетПриказ58н_202604 Тогда
			ЗначенияПоУмолчанию = РеквизитыЕдиногоНалоговогоПлатежа58н();
		ИначеЕсли ДействуетПриказ199н_202302 Тогда
			ЗначенияПоУмолчанию = РеквизитыЕдиногоНалоговогоПлатежа199н_202302();
		Иначе
			ЗначенияПоУмолчанию = РеквизитыНалоговыхПлатежей();
		КонецЕсли;
			
	ИначеЕсли ПлатежиВБюджетКлиентСервер.ЭтоПлатежВНалоговыйОрган(ВидПлатежа, КодБК) Тогда
		
		Если ДействуетПриказ58н_202604 Тогда
			ЗначенияПоУмолчанию = РеквизитыПрочихНалоговыхПлатежей58н();
		Иначе
			ЗначенияПоУмолчанию = РеквизитыПлатежейВНалоговыеОрганы199н_202302();
		КонецЕсли;
		
	ИначеЕсли ПлатежиВБюджетКлиентСервер.ЭтоПлатежВТаможенныйОрган(ВидПлатежа, КодБК) Тогда
		
		Если ДействуетПриказ58н_202604 Тогда
			ЗначенияПоУмолчанию = РеквизитыТаможенныхПлатежей58н();
		Иначе
			ЗначенияПоУмолчанию = РеквизитыТаможенныхПлатежей();
		КонецЕсли;
		
	Иначе
		
		Если ДействуетПриказ58н_202604 Тогда
			ЗначенияПоУмолчанию = РеквизитыПрочихПлатежей58н();
		ИначеЕсли ДействуетПриказ199н_202401 Тогда
			ЗначенияПоУмолчанию = РеквизитыПрочихПлатежей199н_202401();
		ИначеЕсли ДействуетПриказ199н_202302 Тогда
			ЗначенияПоУмолчанию = РеквизитыПрочихПлатежей199н_202302();
		ИначеЕсли ДействуетПриказ126н Тогда
			ЗначенияПоУмолчанию = РеквизитыПрочихПлатежей126н();
		Иначе
			ЗначенияПоУмолчанию = РеквизитыПрочихПлатежей();
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат ЗначенияПоУмолчанию;

КонецФункции

// Заполняет показатели бюджетного платежа на основании данных аналогичного предыдущего платежа.
//
// Параметры:
//   Объект - ДанныеФормыСтруктура, ФормаКлиентскогоПриложения - заполняемый объект бюджетного платежа
//   Дата - Дата - дата для определения доступных статусов
//   ПараметрыПоиска - Структура - параметры для поиска аналогичного платежа
//
Процедура ЗаполнитьПоказателиОбъектаПоПодобномуБюджетномуПлатежу(Объект, Дата, ПараметрыПоиска) Экспорт

	РеквизитыПоследнегоПлатежа = РеквизитыАналогичногоБюджетногоПлатежа(ПараметрыПоиска);
	
	Если ЗначениеЗаполнено(РеквизитыПоследнегоПлатежа.КодБК) Тогда
		Объект.КодБК = РеквизитыПоследнегоПлатежа.КодБК;
	КонецЕсли;
	
	СписокСтатусов = ПлатежиВБюджетКлиентСервер.ДоступныеСтатусыПлательщикаПоВидуПлатежа(
		Объект.ВидПеречисленияВБюджет, Объект.КодБК, Дата);
	
	Если ЗначениеЗаполнено(РеквизитыПоследнегоПлатежа.СтатусСоставителя)
		И СписокСтатусов.НайтиПоЗначению(РеквизитыПоследнегоПлатежа.СтатусСоставителя) <> Неопределено Тогда
		Объект.СтатусСоставителя = РеквизитыПоследнегоПлатежа.СтатусСоставителя;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(РеквизитыПоследнегоПлатежа.КодОКАТО) Тогда
		Объект.КодОКАТО = РеквизитыПоследнегоПлатежа.КодОКАТО;
	КонецЕсли;
	
	Если Объект.ВидПеречисленияВБюджет = Перечисления.ВидыПеречисленийВБюджет.ТаможенныйПлатеж
		И ЗначениеЗаполнено(РеквизитыПоследнегоПлатежа.ПоказательПериода) Тогда
		Объект.ПоказательПериода = РеквизитыПоследнегоПлатежа.ПоказательПериода;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(РеквизитыПоследнегоПлатежа.ПоказательОснования) Тогда
		Объект.ПоказательОснования = РеквизитыПоследнегоПлатежа.ПоказательОснования;
	КонецЕсли;

КонецПроцедуры

// Возвращает структуру с параметрами для поиска аналогичного платежа в бюджет, инициализированную пустыми значениями.
//
// Возвращаемое значение:
//   Структура:
//     * Контрагент - СправочникСсылка.Контрагенты - контрагент
//     * БанковскийСчетКонтрагента - СправочникСсылка.БанковскиеСчетаКонтрагентов - банковский счет контрагента
//     * Организация - СправочникСсылка.Организации - организация
//     * БанковскийСчет - СправочникСсылка.БанковскиеСчетаОрганизаций - банковский счет организации
//     * ВидПеречисленияВБюджет - ПеречислениеСсылка.ВидыПеречисленийВБюджет - вид перечисления в бюджет
//     * ХозяйственнаяОперация - ПеречислениеСсылка.ХозяйственныеОперации - хозяйственная операция
//     * ТипНалога - СправочникСсылка.ВидыНалоговВзносов - тип налога или взноса
//
Функция ПараметрыПоискаАналогичногоПлатежаВБюджет() Экспорт

	Результат = Новый Структура;
	Результат.Вставить("Контрагент",				Справочники.Контрагенты.ПустаяСсылка());
	Результат.Вставить("БанковскийСчетКонтрагента",	Справочники.БанковскиеСчетаКонтрагентов.ПустаяСсылка());
	Результат.Вставить("Организация",				Справочники.Организации.ПустаяСсылка());
	Результат.Вставить("БанковскийСчет",			Справочники.БанковскиеСчетаОрганизаций.ПустаяСсылка());
	Результат.Вставить("ВидПеречисленияВБюджет",	Перечисления.ВидыПеречисленийВБюджет.ПустаяСсылка());
	Результат.Вставить("ХозяйственнаяОперация",		Перечисления.ХозяйственныеОперации.ПустаяСсылка());
	Результат.Вставить("ТипНалога",					Справочники.ВидыНалоговВзносов.ПустаяСсылка());
	
	Возврат Результат;

КонецФункции

// Возвращает текст назначения платежа с учетом реквизитов платежа в бюджет и реквизитов плательщика.
//
// Параметры:
//   ДокументОбъект - ДокументОбъект.СписаниеБезналичныхДенежныхСредств, ДокументОбъект.ЗаявкаНаРасходованиеДенежныхСредств - 
//                    документ оплаты в бюджет
//   ТекстНазначения - Строка - исходный текст назначения платежа.
//   ВключитьТекстНДС - Булево - признак включения текста НДС в назначение платежа.
//
// Возвращаемое значение:
//   Строка - измененное назначение платежа
Функция НазначениеПлатежаОплатыВБюджет(ДокументОбъект, ТекстНазначения, ВключитьТекстНДС) Экспорт

	Результат = ТекстНазначения;
	
	Если ЭтоПеречислениеЕНП(ДокументОбъект)
		И ПлатежиВБюджетКлиентСервер.ДействуетПриказ58н_202604(ДокументОбъект.Дата) Тогда
		Результат = НСтр("ru = 'ЕНП.'");
		ВключитьТекстНДС = Ложь;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ДокументОбъект.Организация) Тогда
		
		РеквизитыВладельцаСчета = ДенежныеСредстваСерверЛокализация.ДанныеПлательщика(
			ДокументОбъект.Организация, ДокументОбъект.БанковскийСчет, ДокументОбъект.Дата, ДокументОбъект.ПеречислениеВБюджет);
		
		Если РеквизитыВладельцаСчета.ИННПлательщика <> СокрЛП(ДокументОбъект.ИННПлательщика) Тогда
			
			Если СокрЛП(ДокументОбъект.ИННПлательщика) = "0" Тогда
				ТекстПлательщика = НСтр("ru = '...'");
			Иначе
				ТекстПлательщика = НаименованиеПлательщикаПоИННКПП(
