	Результат.Вставить("ПоказательОснования", "ПоказательОснования");
	Результат.Вставить("ПоказательПериода", "ПоказательПериода");
	Результат.Вставить("ПоказательНомера", "ПоказательНомера");
	Результат.Вставить("ПоказательДаты", "ПоказательДаты");
	Результат.Вставить("ПоказательТипа", "ПоказательТипа");
	
	Возврат Результат;
	
КонецФункции

// Возвращает структуру с параметрами платежа для заполнения со значениями по умолчанию.
//
// Возвращаемое значение:
//   Структура:
//     * Дата - Дата - дата платежа
//     * ВидПлатежа - ПеречислениеСсылка.ВидыПеречисленийВБюджет - вид платежа
//     * ТипНалога - СправочникСсылка.ВидыНалоговВзносов - тип налога
//     * КодБК - Строка - код бюджетной классификации
//
Функция ПараметрыПлатежаДляЗаполнения() Экспорт

	Результат = Новый Структура;
	Результат.Вставить("Дата", Дата('00010101'));
	Результат.Вставить("ВидПлатежа", Перечисления.ВидыПеречисленийВБюджет.ПустаяСсылка());
	Результат.Вставить("ТипНалога", Справочники.ВидыНалоговВзносов.ПустаяСсылка());
	Результат.Вставить("КодБК", "");
	
	Возврат Результат;

КонецФункции

// Возвращает признак того, что документ является перечислением единого налогового платежа.
//
// Параметры:
//   ДокументОбъект - ДанныеФормыСтруктура, ДокументОбъект.ЗаявкаНаРасходованиеДенежныхСредств, ДокументОбъект.СписаниеБезналичныхДенежныхСредств -
//                    проверяемый документ
//
// Возвращаемое значение:
//   Булево - Истина, если документ является перечислением ЕНП
Функция ЭтоПеречислениеЕНП(ДокументОбъект) Экспорт

	Возврат ДокументОбъект.ВидПеречисленияВБюджет = Перечисления.ВидыПеречисленийВБюджет.НалоговыйПлатеж
		И (ДокументОбъект.ТипНалога = Справочники.ВидыНалоговВзносов.ЕдиныйНалоговыйПлатеж
		Или ПлатежиВБюджетКлиентСервер.ЭтоЕдиныйНалоговыйПлатеж(ДокументОбъект.КодБК));

КонецФункции

#КонецОбласти

