				Если ПустаяСтрока(ТекстПлательщика) Тогда
					ТекстПлательщика = НСтр("ru = '...'");
				КонецЕсли;
				
			КонецЕсли;
			
			КПП = ?(ПустаяСтрока(РеквизитыВладельцаСчета.КПППлательщика), "0", РеквизитыВладельцаСчета.КПППлательщика);
			Результат = СтрШаблон(НСтр("ru = '%1//%2//%3//%4'"), 
				РеквизитыВладельцаСчета.ИННПлательщика, КПП, ТекстПлательщика, Результат);
			
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Результат;

КонецФункции

// Заполняет реквизиты объекта платежа в бюджет значениями по умолчанию с учетом неизменяемых реквизитов.
//
// Параметры:
//   Объект - ФормаКлиентскогоПриложения, ДанныеФормыСтруктура, ДокументОбъект.ЗаявкаНаРасходованиеДенежныхСредств, ДокументОбъект.СписаниеБезналичныхДенежныхСредств - 
//            объект платежа в бюджет
//   ЗаполняемыеРеквизиты - см. ЗаполняемыеРеквизитыОбъекта.
//   ПараметрыПлатежа - см. ПараметрыПлатежаДляЗаполнения.
//
Процедура ЗаполнитьБюджетныеРеквизитыПоУмолчанию(Объект, ЗаполняемыеРеквизиты, ПараметрыПлатежа) Экспорт

	ЗначенияПоУмолчанию = ЗначенияРеквизитовПлатежаВБюджетПоУмолчанию(
		ПараметрыПлатежа.Дата, ПараметрыПлатежа.ВидПлатежа, ПараметрыПлатежа.КодБК, ПараметрыПлатежа.ТипНалога);
	
	// значения реквизитов по умолчанию
	ДанныеЗаполнения = ЗначенияПоУмолчанию.ДанныеЗаполнения;
	// реквизиты, которые не редактируются или заполняются безусловно
	НеизменныеРеквизиты = ЗначенияПоУмолчанию.НеизменныеРеквизиты;
	
	Для Каждого ТекущийРеквизит Из ЗаполняемыеРеквизиты Цикл
		
		Если ТекущийРеквизит.Значение = "" Тогда
			Продолжить;
		КонецЕсли;
		
		Если НеизменныеРеквизиты.Найти(ТекущийРеквизит.Ключ) = Неопределено Тогда
			
			Если Не ПустаяСтрока(ДанныеЗаполнения[ТекущийРеквизит.Ключ])
				И Не ЗначениеЗаполнено(Объект[ТекущийРеквизит.Значение]) Тогда
				Объект[ТекущийРеквизит.Значение] = ДанныеЗаполнения[ТекущийРеквизит.Ключ];
			КонецЕсли;
			
		Иначе
			Объект[ТекущийРеквизит.Значение] = ДанныеЗаполнения[ТекущийРеквизит.Ключ];
		КонецЕсли;
		
	КонецЦикла;

КонецПроцедуры

// Возвращает соответствие имен заполняемых реквизитов объекта и их значений
//
// Возвращаемое значение:
//   Соответствие из КлючИЗначение:
//   * Ключ - Строка - наименование бюджетного реквизита (не меняется), 
//   * Значение - Строка - имя реквизита в объекте.
//
Функция ЗаполняемыеРеквизитыОбъекта() Экспорт

	Результат = Новый Соответствие();
	Результат.Вставить("КПППлательщика", "КПППлательщика");
