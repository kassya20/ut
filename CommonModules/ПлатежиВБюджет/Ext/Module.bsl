Функция РеквизитыАналогичногоБюджетногоПлатежа(Отбор)

	Результат = Новый Структура;
	Результат.Вставить("СтатусСоставителя", "");
	Результат.Вставить("КодБК", "");
	Результат.Вставить("КодОКАТО", "");
	Результат.Вставить("ПоказательПериода", "");
	Результат.Вставить("ПоказательОснования", "");
	
	Если Не ЗначениеЗаполнено(Отбор.Контрагент)
		Или Не ЗначениеЗаполнено(Отбор.Организация) Тогда
		Возврат Результат;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	ДанныеДокумента.СтатусСоставителя КАК СтатусСоставителя,
		|	ДанныеДокумента.КодБК КАК КодБК,
		|	ДанныеДокумента.КодОКАТО КАК КодОКАТО,
		|	ДанныеДокумента.ПоказательПериода КАК ПоказательПериода,
		|	ДанныеДокумента.ПоказательОснования КАК ПоказательОснования
		|ИЗ
		|	Документ.СписаниеБезналичныхДенежныхСредств КАК ДанныеДокумента
		|ГДЕ
		|	ДанныеДокумента.Контрагент = &Контрагент
		|	И (ДанныеДокумента.БанковскийСчетКонтрагента = &БанковскийСчетКонтрагента
		|			ИЛИ &БанковскийСчетКонтрагента = НЕОПРЕДЕЛЕНО)
		|	И ДанныеДокумента.Организация = &Организация
		|	И (ДанныеДокумента.БанковскийСчет = &БанковскийСчет
		|			ИЛИ &БанковскийСчет = НЕОПРЕДЕЛЕНО)
		|	И ДанныеДокумента.Проведен
		|	И ДанныеДокумента.ПроведеноБанком
		|	И ДанныеДокумента.ПеречислениеВБюджет
		|	И ДанныеДокумента.ВидПеречисленияВБюджет = &ВидПеречисленияВБюджет
		|	И ДанныеДокумента.ХозяйственнаяОперация = &ХозяйственнаяОперация
		|	И (ДанныеДокумента.ТипНалога = &ТипНалога
		|			ИЛИ &ТипНалога = НЕОПРЕДЕЛЕНО)
		|
		|УПОРЯДОЧИТЬ ПО
		|	ДанныеДокумента.Дата УБЫВ";
	
	Запрос.УстановитьПараметр("Контрагент", Отбор.Контрагент);
	Запрос.УстановитьПараметр("Организация", Отбор.Организация);
	Запрос.УстановитьПараметр("ХозяйственнаяОперация", Отбор.ХозяйственнаяОперация);
	Запрос.УстановитьПараметр("ВидПеречисленияВБюджет", Отбор.ВидПеречисленияВБюджет);
	Запрос.УстановитьПараметр("БанковскийСчет", 
		?(ЗначениеЗаполнено(Отбор.БанковскийСчет), Отбор.БанковскийСчет, Неопределено));
	Запрос.УстановитьПараметр("БанковскийСчетКонтрагента", 
		?(ЗначениеЗаполнено(Отбор.БанковскийСчетКонтрагента), Отбор.БанковскийСчетКонтрагента, Неопределено));
	Запрос.УстановитьПараметр("ТипНалога", 
		?(ЗначениеЗаполнено(Отбор.ТипНалога), Отбор.ТипНалога, Неопределено));
	
	УстановитьПривилегированныйРежим(Истина);
	РезультатЗапроса = Запрос.Выполнить();
	УстановитьПривилегированныйРежим(Ложь);
	
	Если Не РезультатЗапроса.Пустой() Тогда
		
		Выборка = РезультатЗапроса.Выбрать();
		
		Если Выборка.Следующий() Тогда
			
			Результат.СтатусСоставителя = 	Выборка.СтатусСоставителя;
			Результат.КодБК = 				Выборка.КодБК;
			Результат.КодОКАТО = 			Выборка.КодОКАТО;
			Результат.ПоказательПериода = 	Выборка.ПоказательПериода;
			Результат.ПоказательОснования = Выборка.ПоказательОснования;
			
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Результат;

КонецФункции

Функция НаименованиеПлательщикаПоИННКПП(Период, ИНН, КПП)
	
	Результат = "";
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	Контрагенты.Ссылка КАК Контрагент,
		|	Контрагенты.КПП КАК КПП,
		|	Контрагенты.НаименованиеПолное КАК Наименование
		|ПОМЕСТИТЬ КонтрагентыПоИНН
		|ИЗ
		|	Справочник.Контрагенты КАК Контрагенты
		|ГДЕ
		|	Контрагенты.ИНН = &ИНН
		|	И НЕ Контрагенты.ПометкаУдаления
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	КонтрагентыПоИНН.Контрагент КАК Контрагент,
		|	КонтрагентыИсторияНаименований.СокращенноеНаименование КАК ЗначениеРеквизита,
		|	КонтрагентыИсторияНаименований.Период КАК Период,
		|	0 КАК Признак
		|ПОМЕСТИТЬ ИсторияРеквизитов
		|ИЗ
		|	КонтрагентыПоИНН КАК КонтрагентыПоИНН
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Контрагенты.ИсторияНаименований КАК КонтрагентыИсторияНаименований
		|		ПО КонтрагентыПоИНН.Контрагент = КонтрагентыИсторияНаименований.Ссылка
		|ГДЕ
		|	ЕСТЬNULL(КонтрагентыИсторияНаименований.Период, ДАТАВРЕМЯ(1, 1, 1)) <= &Дата
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	КонтрагентыПоИНН.Контрагент КАК Контрагент,
		|	КонтрагентыИсторияКПП.КПП КАК ЗначениеРеквизита,
		|	КонтрагентыИсторияКПП.Период КАК Период,
		|	1 КАК Признак
		|ИЗ
		|	КонтрагентыПоИНН КАК КонтрагентыПоИНН
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Контрагенты.ИсторияКПП КАК КонтрагентыИсторияКПП
		|		ПО КонтрагентыПоИНН.Контрагент = КонтрагентыИсторияКПП.Ссылка
		|ГДЕ
		|	ЕСТЬNULL(КонтрагентыИсторияКПП.Период, ДАТАВРЕМЯ(1, 1, 1)) <= &Дата
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ИсторияРеквизитов.Контрагент КАК Контрагент,
		|	ИсторияРеквизитов.Признак КАК Признак,
		|	МАКСИМУМ(ИсторияРеквизитов.Период) КАК Период
		|ПОМЕСТИТЬ ДанныеКонтрагентовНаДату
		|ИЗ
		|	ИсторияРеквизитов КАК ИсторияРеквизитов
		|
		|СГРУППИРОВАТЬ ПО
		|	ИсторияРеквизитов.Контрагент,
		|	ИсторияРеквизитов.Признак
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ИсторияРеквизитов.Контрагент КАК Контрагент,
		|	ИсторияРеквизитов.ЗначениеРеквизита КАК ЗначениеРеквизита,
		|	ИсторияРеквизитов.Признак КАК Признак
		|ПОМЕСТИТЬ АктуальноеДанныеКонтрагентов
		|ИЗ
		|	ИсторияРеквизитов КАК ИсторияРеквизитов
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ДанныеКонтрагентовНаДату КАК ДанныеКонтрагентовНаДату
		|		ПО ИсторияРеквизитов.Контрагент = ДанныеКонтрагентовНаДату.Контрагент
		|			И ИсторияРеквизитов.Период = ДанныеКонтрагентовНаДату.Период
		|			И ИсторияРеквизитов.Признак = ДанныеКонтрагентовНаДату.Признак
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	КонтрагентыПоИНН.Контрагент КАК Контрагент,
		|	ЕСТЬNULL(ИсторияНаименований.ЗначениеРеквизита, КонтрагентыПоИНН.Наименование) КАК Наименование,
		|	ЕСТЬNULL(ИсторияКПП.ЗначениеРеквизита, КонтрагентыПоИНН.КПП) КАК КПП
		|ИЗ
		|	КонтрагентыПоИНН КАК КонтрагентыПоИНН
		|		ЛЕВОЕ СОЕДИНЕНИЕ АктуальноеДанныеКонтрагентов КАК ИсторияНаименований
		|		ПО КонтрагентыПоИНН.Контрагент = ИсторияНаименований.Контрагент
		|			И (ИсторияНаименований.Признак = 0)
		|		ЛЕВОЕ СОЕДИНЕНИЕ АктуальноеДанныеКонтрагентов КАК ИсторияКПП
		|		ПО КонтрагентыПоИНН.Контрагент = ИсторияКПП.Контрагент
		|			И (ИсторияКПП.Признак = 1)
		|
		|УПОРЯДОЧИТЬ ПО
		|	Контрагент";
	
	Запрос.УстановитьПараметр("Дата", Период);
	Запрос.УстановитьПараметр("ИНН", ИНН);
	
	РезультатЗапроса = Запрос.Выполнить().Выгрузить();
	
	Если РезультатЗапроса.Количество() <> 0 Тогда
		
		Отбор = Новый Структура;
		Отбор.Вставить("КПП", КПП);
	
		НайденныеСтроки = РезультатЗапроса.НайтиСтроки(Отбор);
	
		Если НайденныеСтроки.Количество() >= 1 Тогда
			Результат = НайденныеСтроки[0].Наименование;
		Иначе
			Результат = РезультатЗапроса[0].Наименование;
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти
