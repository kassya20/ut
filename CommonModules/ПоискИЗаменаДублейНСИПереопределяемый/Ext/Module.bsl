	|		И Номенклатура.ВидНоменклатуры.ИспользоватьСерии = Номенклатура1.ВидНоменклатуры.ИспользоватьСерии
	|		И Номенклатура.ВидНоменклатуры.ОсобенностьУчета = Номенклатура1.ВидНоменклатуры.ОсобенностьУчета
	|		И Номенклатура.ЕдиницаИзмерения = Номенклатура1.ЕдиницаИзмерения
	|		И Номенклатура.Принципал = Номенклатура1.Принципал
	|		И Номенклатура.Контрагент = Номенклатура1.Контрагент
	|		И Номенклатура.ГруппаФинансовогоУчета = Номенклатура1.ГруппаФинансовогоУчета
	|		И Номенклатура.Качество = Номенклатура1.Качество
	|
	|ОБЪЕДИНИТЬ
	|
	|ВЫБРАТЬ
	|	Номенклатура.Ссылка КАК Ссылка,
	|	Номенклатура1.Ссылка КАК Ссылка1
	|ИЗ
	|	Справочник.Номенклатура КАК Номенклатура
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК Номенклатура1
	|		ПО (Номенклатура.Ссылка < Номенклатура1.Ссылка)
	|			И Номенклатура.НаименованиеПолное = Номенклатура1.НаименованиеПолное
	|ГДЕ
	|	Номенклатура.НаименованиеПолное <> """"
	|	И Номенклатура.ВидНоменклатуры.ТипНоменклатуры = Номенклатура1.ВидНоменклатуры.ТипНоменклатуры
	|		И Номенклатура.ВидНоменклатуры.ИспользованиеХарактеристик = Номенклатура1.ВидНоменклатуры.ИспользованиеХарактеристик
	|		И Номенклатура.ВидНоменклатуры.ИспользоватьСерии = Номенклатура1.ВидНоменклатуры.ИспользоватьСерии
	|		И Номенклатура.ВидНоменклатуры.ОсобенностьУчета = Номенклатура1.ВидНоменклатуры.ОсобенностьУчета
	|		И Номенклатура.ЕдиницаИзмерения = Номенклатура1.ЕдиницаИзмерения
	|		И Номенклатура.Принципал = Номенклатура1.Принципал
	|		И Номенклатура.Контрагент = Номенклатура1.Контрагент
	|		И Номенклатура.ГруппаФинансовогоУчета = Номенклатура1.ГруппаФинансовогоУчета
	|		И Номенклатура.Качество = Номенклатура1.Качество";
	Возврат ТекстЗапроса;
КонецФункции

Функция ТекстЗапроса_ПравилаПоискаДублей_Партнеры_СовпадаетНаименование()
	ТекстЗапроса = 
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Партнер1.Ссылка КАК Партнер,
	|	Партнер2.Ссылка КАК Дубль
	|ИЗ
	|	Справочник.Партнеры КАК Партнер1
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Партнеры КАК Партнер2
	|		ПО Партнер1.Ссылка < Партнер2.Ссылка
	|			И Партнер1.Наименование = Партнер2.Наименование
	|			И Партнер1.ЮрФизЛицо = Партнер2.ЮрФизЛицо
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Партнеры.КонтактнаяИнформация КАК КИ1
	|		ПО КИ1.Ссылка = Партнер1.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Партнеры.КонтактнаяИнформация КАК КИ2
	|		ПО КИ2.Ссылка = Партнер2.Ссылка
	|ГДЕ
	|	(КИ1.Ссылка ЕСТЬ NULL
	|			ИЛИ (КИ1.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыКонтактнойИнформации.Телефон)
	|					И КИ2.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыКонтактнойИнформации.Телефон)
	|					И КИ1.НомерТелефона <> """"
	|					И КИ1.НомерТелефона = КИ2.НомерТелефона
	|				ИЛИ КИ1.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыКонтактнойИнформации.АдресЭлектроннойПочты)
	|					И КИ2.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыКонтактнойИнформации.АдресЭлектроннойПочты)
	|					И КИ1.АдресЭП <> """"
	|					И КИ1.АдресЭП = КИ2.АдресЭП
	|				ИЛИ КИ1.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыКонтактнойИнформации.Адрес)
	|					И КИ2.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыКонтактнойИнформации.Адрес)
	|					И (КИ1.Представление <> """"
	|							И КИ1.Представление = КИ2.Представление)))
	|
	|ОБЪЕДИНИТЬ
	|
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Партнер1.Ссылка КАК Партнер,
	|	Партнер2.Ссылка КАК Дубль
	|ИЗ
	|	Справочник.Партнеры КАК Партнер1
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Партнеры КАК Партнер2
	|		ПО Партнер1.Ссылка < Партнер2.Ссылка
	|			И Партнер1.НаименованиеПолное = Партнер2.НаименованиеПолное
	|			И Партнер1.ЮрФизЛицо = Партнер2.ЮрФизЛицо
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Партнеры.КонтактнаяИнформация КАК КИ1
	|		ПО КИ1.Ссылка = Партнер1.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Партнеры.КонтактнаяИнформация КАК КИ2
	|		ПО КИ2.Ссылка = Партнер2.Ссылка
	|ГДЕ
	|	Партнер1.НаименованиеПолное <> """"
	|	И (КИ1.Ссылка ЕСТЬ NULL
	|			ИЛИ (КИ1.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыКонтактнойИнформации.Телефон)
	|					И КИ2.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыКонтактнойИнформации.Телефон)
	|					И КИ1.НомерТелефона <> """"
	|					И КИ1.НомерТелефона = КИ2.НомерТелефона
