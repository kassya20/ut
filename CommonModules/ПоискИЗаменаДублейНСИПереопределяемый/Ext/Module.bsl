Функция ТекстЗапроса_ПравилаПоискаДублей_Контрагенты_СовпадаетНаименованиеИКонтактнаяИнформация()
	ТекстЗапроса = 
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Контрагент1.Ссылка КАК Контрагент,
	|	Контрагент2.Ссылка КАК Дубль
	|ИЗ
	|	Справочник.Контрагенты КАК Контрагент1
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Контрагенты КАК Контрагент2
	|		ПО Контрагент1.Ссылка < Контрагент2.Ссылка
	|			И Контрагент1.Наименование = Контрагент2.Наименование
	|			И Контрагент1.ЮридическоеФизическоеЛицо = Контрагент2.ЮридическоеФизическоеЛицо
	|			И Контрагент1.ЮрФизЛицо = Контрагент2.ЮрФизЛицо
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Контрагенты.КонтактнаяИнформация КАК КИ1
	|		ПО КИ1.Ссылка = Контрагент1.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Контрагенты.КонтактнаяИнформация КАК КИ2
	|		ПО КИ2.Ссылка = Контрагент2.Ссылка
	|ГДЕ
	|	(КИ1.Ссылка ЕСТЬ NULL
	|			ИЛИ (КИ1.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыКонтактнойИнформации.Телефон)
	|					И КИ2.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыКонтактнойИнформации.Телефон)
	|					И КИ1.НомерТелефона <> """"
	|					И КИ1.НомерТелефона = КИ2.НомерТелефона
	|				ИЛИ КИ1.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыКонтактнойИнформации.АдресЭлектроннойПочты)
	|					И КИ2.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыКонтактнойИнформации.АдресЭлектроннойПочты)
	|					И КИ1.АдресЭП <> """"
	|					И КИ1.АдресЭП = КИ2.АдресЭП
	|				ИЛИ КИ1.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыКонтактнойИнформации.Адрес)
	|					И КИ2.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыКонтактнойИнформации.Адрес)
	|					И (КИ1.Представление <> """"
	|							И КИ1.Представление = КИ2.Представление)))
	|
	|ОБЪЕДИНИТЬ
	|
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Контрагент1.Ссылка КАК Контрагент,
	|	Контрагент2.Ссылка КАК Дубль
	|ИЗ
	|	Справочник.Контрагенты КАК Контрагент1
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Контрагенты КАК Контрагент2
	|		ПО Контрагент1.Ссылка < Контрагент2.Ссылка
	|			И Контрагент1.НаименованиеПолное = Контрагент2.НаименованиеПолное
	|			И Контрагент1.ЮридическоеФизическоеЛицо = Контрагент2.ЮридическоеФизическоеЛицо
	|			И Контрагент1.ЮрФизЛицо = Контрагент2.ЮрФизЛицо
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Контрагенты.КонтактнаяИнформация КАК КИ1
	|		ПО КИ1.Ссылка = Контрагент1.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Контрагенты.КонтактнаяИнформация КАК КИ2
	|		ПО КИ2.Ссылка = Контрагент2.Ссылка
	|ГДЕ
	|	Контрагент1.НаименованиеПолное <> """"
	|	И (КИ1.Ссылка ЕСТЬ NULL
	|			ИЛИ (КИ1.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыКонтактнойИнформации.Телефон)
	|					И КИ2.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыКонтактнойИнформации.Телефон)
	|					И КИ1.НомерТелефона <> """"
	|					И КИ1.НомерТелефона = КИ2.НомерТелефона
	|				ИЛИ КИ1.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыКонтактнойИнформации.АдресЭлектроннойПочты)
	|					И КИ2.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыКонтактнойИнформации.АдресЭлектроннойПочты)
	|					И КИ1.АдресЭП <> """"
	|					И КИ1.АдресЭП = КИ2.АдресЭП
	|				ИЛИ КИ1.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыКонтактнойИнформации.Адрес)
	|					И КИ2.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыКонтактнойИнформации.Адрес)
	|					И (КИ1.Представление <> """"
	|							И КИ1.Представление = КИ2.Представление)))";
	Возврат ТекстЗапроса;
КонецФункции

Функция ТекстЗапроса_ПравилаПоискаДублей_Контрагенты_СовпадаетНомерБанковскогоСчета()
	ТекстЗапроса = 
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	БанковскиеСчетаКонтрагентов.Владелец КАК Владелец,
	|	БанковскиеСчетаКонтрагентов1.Владелец КАК Владелец1
	|ИЗ
	|	Справочник.БанковскиеСчетаКонтрагентов КАК БанковскиеСчетаКонтрагентов
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.БанковскиеСчетаКонтрагентов КАК БанковскиеСчетаКонтрагентов1
	|		ПО БанковскиеСчетаКонтрагентов.Владелец <> БанковскиеСчетаКонтрагентов1.Владелец
	|ГДЕ
	|	ВЫБОР 
	|		КОГДА НЕ БанковскиеСчетаКонтрагентов.Банк = ЗНАЧЕНИЕ(Справочник.КлассификаторБанков.ПустаяСсылка) 
	|			ТОГДА БанковскиеСчетаКонтрагентов.Банк = БанковскиеСчетаКонтрагентов1.Банк
	|		ИНАЧЕ БанковскиеСчетаКонтрагентов.БИКБанка = БанковскиеСчетаКонтрагентов1.БИКБанка
	|			И БанковскиеСчетаКонтрагентов.СВИФТБанка = БанковскиеСчетаКонтрагентов1.СВИФТБанка
	|	КОНЕЦ
	|	И БанковскиеСчетаКонтрагентов.НомерСчета = БанковскиеСчетаКонтрагентов1.НомерСчета
	|	И БанковскиеСчетаКонтрагентов.Владелец ССЫЛКА Справочник.Контрагенты
	|	И БанковскиеСчетаКонтрагентов1.Владелец ССЫЛКА Справочник.Контрагенты";
	Возврат ТекстЗапроса;
КонецФункции

Функция ТекстЗапроса_ПравилаПоискаДублей_Контрагенты_СовпадаетРегистрационныйИлиНалоговыйНомерНерезидента()
	ТекстЗапроса = 
	"ВЫБРАТЬ
	|	Контрагенты.Ссылка КАК Ссылка,
	|	Контрагенты1.Ссылка КАК Ссылка1
	|ИЗ
	|	Справочник.Контрагенты КАК Контрагенты
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Контрагенты КАК Контрагенты1
	|		ПО Контрагенты.Ссылка < Контрагенты1.Ссылка
	|ГДЕ
	|	 (Контрагенты.НалоговыйНомер <> """"
	|		И Контрагенты1.НалоговыйНомер <> """"
	|		И Контрагенты.НалоговыйНомер = Контрагенты1.НалоговыйНомер)
	|	ИЛИ (Контрагенты.РегистрационныйНомер <> """"
	|		И Контрагенты1.РегистрационныйНомер <> """"
	|		И Контрагенты.РегистрационныйНомер = Контрагенты1.РегистрационныйНомер)
	|	И Контрагенты.ЮрФизЛицо = ЗНАЧЕНИЕ(Перечисление.ЮрФизЛицо.ЮрЛицоНеРезидент)
	|	И Контрагенты1.ЮрФизЛицо = ЗНАЧЕНИЕ(Перечисление.ЮрФизЛицо.ЮрЛицоНеРезидент)";
	Возврат ТекстЗапроса;
КонецФункции

