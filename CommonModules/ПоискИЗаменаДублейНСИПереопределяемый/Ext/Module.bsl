Функция ОбъектМетаданныхПоставляемогоПравила(ИмяПредопределенныхДанных) 
	Соответствие = Новый Соответствие;
	Соответствие.Вставить("Справочник_Номенклатура_ПоНастройкамУникальностиВидаНоменклатуры", "Справочник.Номенклатура");
	Соответствие.Вставить("Справочник_ХарактеристикиНоменклатуры_ПоНастройкамУникальностиВидаНоменклатуры", "Справочник.ХарактеристикиНоменклатуры");
	Соответствие.Вставить("Справочник_Контрагенты_СовпадаетИННКПП", "Справочник.Контрагенты");
	Соответствие.Вставить("Справочник_Партнеры_СовпадаетКонтактнаяИнформация", "Справочник.Партнеры");
	Соответствие.Вставить("Справочник_Контрагенты_СовпадаетКонтактнаяИнформацияИНеЗаполненИНН", "Справочник.Контрагенты");
	Соответствие.Вставить("Справочник_Номенклатура_СовпадаетНаименование", "Справочник.Номенклатура");
	Соответствие.Вставить("Справочник_Партнеры_СовпадаетНаименование", "Справочник.Партнеры");
	Соответствие.Вставить("Справочник_ХарактеристикиНоменклатуры_СовпадаетНаименование", "Справочник.ХарактеристикиНоменклатуры");
	Соответствие.Вставить("Справочник_Контрагенты_СовпадаетНаименованиеИКонтактнаяИнформация", "Справочник.Контрагенты");
	Соответствие.Вставить("Справочник_Контрагенты_СовпадаетНомерБанковскогоСчета", "Справочник.Контрагенты");
	Соответствие.Вставить("Справочник_Контрагенты_СовпадаетРегистрационныйИлиНалоговыйНомерНерезидента", "Справочник.Контрагенты");
	ИмяТипа = Соответствие[ИмяПредопределенныхДанных]; 
	Если ИмяТипа = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;
	Идентификатор = ОбщегоНазначения.ИдентификаторОбъектаМетаданных(ИмяТипа);
	Возврат Идентификатор;
КонецФункции

#КонецОбласти
