// Устанавливает видимость элемента "Вид периода" в зависимости от настроек отчета.
//
// Параметры:
//	Элемент - Подменю командной панели - Элемент формы "Вид периода"
//	Отчет - ОтчетОбъект - Отчет
//
Процедура УправлениеВидимостьюВидПериода(Элемент, Отчет) Экспорт
	
	ЭтоКонецМесяца = КонецДня(Отчет.КонецПериода) = КонецМесяца(Отчет.КонецПериода);
	Элемент.Видимость = ЭтоКонецМесяца;
	
КонецПроцедуры

// Переопределяет строку с представлением периода.
//
// Параметры:
//	ТекстПериод - Строка - Текст представления периода.
//	НачалоПериода - Дата - Начало периода.
//	КонецПериода - Дата - Конец периода.
//	ТолькоДаты - Булево - Если Ложь, то возвращаемая строка включает предлог "за".
//	ВидПериода - Число - Вид периода. Если конец периода не задан или не является концом года, параметр игнорируется.
//
Процедура ПереопределитьПредставлениеПериода(ТекстПериод, НачалоПериода = '00010101', КонецПериода = '00010101', ВидПериода = 0) Экспорт
	
	ВидыПериода = БухгалтерскиеОтчетыКлиентСервер.ВидыПериода();
	
	Если ЗначениеЗаполнено(КонецПериода) И КонецПериода >= НачалоПериода
		И ВидПериода = ВидыПериода.МежотчетныйПериод И КонецДня(КонецПериода) = КонецМесяца(КонецПериода)
		И КонецДня(КонецПериода) <> КонецГода(КонецПериода)Тогда
		
		ТекстПериод = " " + НСтр("ru = 'за'")+ " ";
		ТекстПериод = ТекстПериод + СтрШаблон(НСтр("ru = 'межотчетный период %1-%2 г.'"), 
			Формат(КонецПериода, НСтр("ru = 'ДФ=''ММММ'''")), Формат(КонецМесяца(КонецПериода) + 1, НСтр("ru = 'ДФ=''ММММ гггг'''")));
			
	КонецЕсли;
	
КонецПроцедуры


#КонецОбласти