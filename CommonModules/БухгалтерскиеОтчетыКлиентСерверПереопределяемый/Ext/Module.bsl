#Область ПрограммныйИнтерфейс

// Позволяет скорректировать состав отчетов, фактически реализованных в прикладном решении
// и использующих возможности подсистемы СправкиРасчеты.
//
// Параметры:
//  ИменаОтчетов - Массив - Модифицируемый параметр: имена отчетов.
//
Процедура УстановитьИспользуемыеСправкиРасчеты(ИменаОтчетов) Экспорт

	ИменаОтчетов.Добавить("СправкаРасчетНалогаНаПрибыльОтОперацийРезультатКоторыхНеВключаетсяВПрибыль");
		
КонецПроцедуры

// Проверяет нужен ли для переданного типа сложный подбор.
//
// Параметры:
//  ТипЭлемента  - Тип - что нужно проверить.
//  СложныйПодбор - возвращаемое значение. Истина, если нужна сложная обработка подбора; Ложь - в противном случае.
//
Процедура ЭтоТипЭлементаСоСложнымПодбором(ТипЭлемента, СложныйПодбор) Экспорт

	Если ТипЭлемента = БухгалтерскийУчетКлиентСерверПереопределяемый.ТипЗначенияБанковскогоСчетаОрганизации() Тогда
		
		СложныйПодбор = Истина;
		
	КонецЕсли;

КонецПроцедуры

// Инициализирует коды дополнительных аналитик для бухгалтерских отчетов.
//
//	Возвращаемое значение:
//		Массив из Структура - содержит следующие свойства:
//			* Код - Строка - односимвольный код, любой кроме номеров субконто: 1, 2, 3;
//			* Наименование - Строка - Имя свойства;
//			* Представление - Строка.
//			* Тип - Тип.
//
Функция ДополнительныеАналитикиБухгалтерскихОтчетов() Экспорт
	
	ПараметрыСтрокой = "Код, Наименование, Представление, Тип";
	ДополнительныеАналитики = Новый Массив;

	
	Возврат ДополнительныеАналитики;
	
КонецФункции

// Дополняет список видов субконто дополнительной аналитикой.
//
// Параметры:
//  СписокВидовСубконто  - СписокЗначений из Строка - Возвращаемый параметр: дополняемый список, см. БухгалтерскиеОтчетыКлиент.ТабличноеПолеПоСчетамПредставлениеНачалоВыбора.
//  СтрокаПоСубконто     - Строка.
//  Индекс               - Число.
//
// Возвращаемое значение:
//  Булево - Список был дополнен
//
Функция ДополнитьСписокВидовСубконто(СписокВидовСубконто, СтрокаПоСубконто, Индекс) Экспорт
	ДополнительныеАналитикиБухгалтерскихОтчетов = ДополнительныеАналитикиБухгалтерскихОтчетов();
	ИндексСубконто = Сред(СтрокаПоСубконто, Индекс*2, 1);
	ИспользованиеСубконто = ?(Сред(СтрокаПоСубконто, Индекс * 2 - 1, 1) = "+", Истина, Ложь);
	ЭтоДополнительнаяАналитика = Ложь;
	Для Каждого ДополнительнаяАналитика Из ДополнительныеАналитикиБухгалтерскихОтчетов Цикл
		Если ИндексСубконто = ДополнительнаяАналитика.Код Тогда
			СписокВидовСубконто.Добавить("Кор" + ДополнительнаяАналитика.Наименование, ДополнительнаяАналитика.Представление, ИспользованиеСубконто);
			ЭтоДополнительнаяАналитика = Истина;
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
	Возврат ЭтоДополнительнаяАналитика;
КонецФункции	

// Дополняет строку по субконто элементом списка, если он является дополнительной аналитикой.
//
// Параметры:
//  СтрокаПоСубконто     - Строка - Возвращаемый параметр
//  ЭлементСписка        - ЭлементСпискаЗначений.
//
// Возвращаемое значение:
//  Булево - Список был дополнен
//
Функция ДополнитьСтрокуПоСубконто(СтрокаПоСубконто, ЭлементСписка) Экспорт
	ДополнительныеАналитикиБухгалтерскихОтчетов = ДополнительныеАналитикиБухгалтерскихОтчетов();
	ЭтоДополнительнаяАналитика = Ложь;
	Для Каждого ДополнительнаяАналитика Из ДополнительныеАналитикиБухгалтерскихОтчетов Цикл
		Если ЭлементСписка.Значение = "Кор" + ДополнительнаяАналитика.Наименование Тогда
			СтрокаПоСубконто = СтрокаПоСубконто + ДополнительнаяАналитика.Код;
			ЭтоДополнительнаяАналитика = Истина;
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
	Возврат ЭтоДополнительнаяАналитика;
КонецФункции
#КонецОбласти

