#Область ПакетнаяОбработкаТабличнойЧасти

// Формирует структуру действий для обработки табличной части при изменении количества упаковок.
// 
// Параметры:
//  ЦенаВключаетНДС - Булево - Одноименный реквизит объекта.
// 
// Возвращаемое значение:
//  Структура - Действия при изменении количества:
// * ПересчитатьКоличествоЕдиниц - Неопределено - Свойство, подключающее действие пересчета упаковок в единицы.
//
// * ПересчитатьСумму - Неопределено - Свойство, подключающее действие пересчета суммы.
// * ПересчитатьСуммуНДС - см. ПакетнаяОбработкаТабличнойЧастиКлиентСервер.ПараметрыПересчетаСуммыНДСВСтрокеТЧ.
// * ПересчитатьСуммуСНДС - см. ПакетнаяОбработкаТабличнойЧастиКлиентСервер.ПараметрыПересчетаСуммыНДСВСтрокеТЧ.
Функция ДействияПриИзмененииКоличества(ЦенаВключаетНДС) Экспорт
	
	Действия = Новый Структура;
	Действия.Вставить("ПересчитатьКоличествоЕдиниц", Неопределено);
	ОбщегоНазначенияКлиентСервер.ДополнитьСтруктуру(Действия, ДействияПересчетаСуммы(ЦенаВключаетНДС), Истина);
	
	//@skip-check constructor-function-return-section -- При дополнении структуры не распознаются свойства.
	Возврат Действия;
	
КонецФункции

// Формирует структуру действий для заполнения вида цены и зависимых свойств.
// 
// Параметры:
//  Объект -  
//  - ДанныеФормыСтруктура:
//  	* Дата - Дата
//  	* Организация - СправочникСсылка.Организации
//  	* ЦенаВключаетНДС - Булево
//  	* Валюта - СправочникСсылка.Валюты
//  - ДокументОбъект.ЗаявкаНаЗакупку 
// 
// Возвращаемое значение:
//  Структура - Действия заполнения цены:
// * ЗаполнитьУсловияЗакупок - см. ПакетнаяОбработкаТабличнойЧастиКлиентСервер.ПолучитьСтруктуруЗаполненияЦеныЗакупкиВСтрокеТЧ.
//
// * ПересчитатьСумму - Неопределено - Свойство, подключающее действие пересчета суммы.
// * ПересчитатьСуммуНДС - см. ПакетнаяОбработкаТабличнойЧастиКлиентСервер.ПараметрыПересчетаСуммыНДСВСтрокеТЧ.
// * ПересчитатьСуммуСНДС - см. ПакетнаяОбработкаТабличнойЧастиКлиентСервер.ПараметрыПересчетаСуммыНДСВСтрокеТЧ.
Функция ДействияЗаполненияВидаЦены(Объект) Экспорт

	Действия = Новый Структура;
	
	ПараметрыЗаполнения = ПакетнаяОбработкаТабличнойЧастиКлиентСервер.ПолучитьСтруктуруЗаполненияЦеныЗакупкиВСтрокеТЧ(Объект);
	ПараметрыЗаполнения.ИспользоватьСоглашениеИзТаблицы = Истина;
	ПараметрыЗаполнения.ЦенаВключаетНДС = Объект.ЦенаВключаетНДС;
	Действия.Вставить("ЗаполнитьУсловияЗакупок", ПараметрыЗаполнения);
	
	ОбщегоНазначенияКлиентСервер.ДополнитьСтруктуру(Действия, ДействияПересчетаСуммы(Объект.ЦенаВключаетНДС), Истина);
	
	//@skip-check constructor-function-return-section -- При дополнении структуры не распознаются свойства.
	Возврат Действия;
		
КонецФункции

// Формирует структуру действий для заполнения цены и зависимых свойств.
// 
// Параметры:
//  Объект -  
//  - ДанныеФормыСтруктура:
//  	* Дата - Дата
//  	* Организация - СправочникСсылка.Организации
//  	* ЦенаВключаетНДС - Булево
//  	* Валюта - СправочникСсылка.Валюты
//  - ДокументОбъект.ЗаявкаНаЗакупку
// 
// Возвращаемое значение:
//  Структура - Действия заполнения цены:
// * ЗаполнитьЦенуЗакупки - см. ПакетнаяОбработкаТабличнойЧастиКлиентСервер.ПолучитьСтруктуруЗаполненияЦеныЗакупкиВСтрокеТЧ.
//
// * ПересчитатьСумму - Неопределено - Свойство, подключающее действие пересчета суммы.
// * ПересчитатьСуммуНДС - см. ПакетнаяОбработкаТабличнойЧастиКлиентСервер.ПараметрыПересчетаСуммыНДСВСтрокеТЧ.
// * ПересчитатьСуммуСНДС - см. ПакетнаяОбработкаТабличнойЧастиКлиентСервер.ПараметрыПересчетаСуммыНДСВСтрокеТЧ.
Функция ДействияЗаполненияЦены(Объект) Экспорт

	Действия = Новый Структура;
	
	ПараметрыЗаполнения = ПакетнаяОбработкаТабличнойЧастиКлиентСервер.ПолучитьСтруктуруЗаполненияЦеныЗакупкиВСтрокеТЧ(Объект);
