#Область СлужебныеПроцедурыИФункции

Функция НастройкиПользователяЭлементовКонструктора() Экспорт
	
	Результат = Новый Соответствие;
	
	ЭлементыКонструктора = Новый Массив;
	ЭлементыКонструктора.Добавить(ПредопределенноеЗначение(
		"Справочник.ЭлементыКонструктораВидовПродукцииИС.КонтролироватьСтатусыКодовМаркировки"));
	ЭлементыКонструктора.Добавить(ПредопределенноеЗначение(
		"Справочник.ЭлементыКонструктораВидовПродукцииИС.КонтролироватьВладельцевКодовМаркировки"));
	ЭлементыКонструктора.Добавить(ПредопределенноеЗначение(
		"Справочник.ЭлементыКонструктораВидовПродукцииИС.ИгнорироватьРезультатыПроверкиКодовМаркировкиНаККТ"));
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ЭлементыКонструктора", ЭлементыКонструктора);
	Запрос.Текст = СтрШаблон(
	"%1
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЗначенияПользователя.ЭлементКонструктора КАК ЭлементКонструктора,
	|	ПРЕДСТАВЛЕНИЕ(ЗначенияПользователя.ВидПродукции) КАК ВидПродукцииПредставление,
	|	ПРЕДСТАВЛЕНИЕ(ЗначенияПользователя.Значение) КАК ЗначениеПредставление,
	|	ЗначенияПользователя.ПометкаУдаления
	|ИЗ
	|	РегистрСведений.ЗначенияПользователяЭлементовКонструктораВидовПродукцииИС КАК ЗначенияПользователя
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВидыПродукции КАК ВидыПродукции
	|		ПО ВидыПродукции.ВидПродукции = ЗначенияПользователя.ВидПродукции
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.ЗначенияЭлементовКонструктораВидовПродукцииИС КАК Значения
	|		ПО ЗначенияПользователя.ЭлементКонструктора = Значения.ЭлементКонструктора
	|		И ЗначенияПользователя.ВидПродукции = Значения.ВидПродукции
	|		И ЗначенияПользователя.Значение = Значения.Значение
	|ГДЕ
	|	ЗначенияПользователя.ЭлементКонструктора В (&ЭлементыКонструктора)
	|	И ЗначенияПользователя.ПометкаУдаления
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ЗначенияПользователя.ЭлементКонструктора,
	|	ПРЕДСТАВЛЕНИЕ(ЗначенияПользователя.ВидПродукции) КАК ВидПродукцииПредставление,
	|	ПРЕДСТАВЛЕНИЕ(ЗначенияПользователя.Значение) КАК ЗначениеПредставление,
	|	ЗначенияПользователя.ПометкаУдаления
	|ИЗ
	|	РегистрСведений.ЗначенияПользователяЭлементовКонструктораВидовПродукцииИС КАК ЗначенияПользователя
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВидыПродукции КАК ВидыПродукции
	|		ПО ВидыПродукции.ВидПродукции = ЗначенияПользователя.ВидПродукции
	|ГДЕ
	|	ЗначенияПользователя.ЭлементКонструктора В (&ЭлементыКонструктора)
	|	И НЕ ЗначенияПользователя.ПометкаУдаления
	|ИТОГИ
	|ПО
	|	ЭлементКонструктора",
	Справочники.ВидыПродукцииИС.ТекстЗапросаСОтборомПоПодсистеме(
		КонструкторИСОбщегоНазначенияКлиентСервер.СуффиксПодсистемыМаркировкиДляКлючаВидовПродукции(),
		"ВидыПродукции"));
	
	КоличествоЭлементовДляВывода = 3;
	ВыборкаЭлементКонструктора = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	Пока ВыборкаЭлементКонструктора.Следующий() Цикл
		КоличествоЭлементов = 0;
		МассивПредставлений = Новый Массив;
		Выборка = ВыборкаЭлементКонструктора.Выбрать();
		Пока Выборка.Следующий() Цикл
			Если КоличествоЭлементов <= КоличествоЭлементовДляВывода Тогда
				Если Выборка.ПометкаУдаления Тогда
					ТекстНачала = НСтр("ru = 'Исключая'");
				Иначе
					ТекстНачала = НСтр("ru = 'Включая'");
				КонецЕсли;
				МассивПредставлений.Добавить(
					СтрШаблон("%1: %2 - %3",
					ТекстНачала,
					Выборка.ВидПродукцииПредставление,
					Выборка.ЗначениеПредставление));
			КонецЕсли;
			КоличествоЭлементов = КоличествоЭлементов + 1;
		КонецЦикла;
		Если КоличествоЭлементов > КоличествоЭлементовДляВывода + 1 Тогда
			МассивПредставлений[КоличествоЭлементовДляВывода] =
				СтрШаблон(НСтр("ru = '+ еще %1'"),
					КоличествоЭлементов - КоличествоЭлементовДляВывода);
		КонецЕсли;
		Результат.Вставить(ВыборкаЭлементКонструктора.ЭлементКонструктора,
			СтрСоединить(МассивПредставлений, Символы.ПС));
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Функция ДопустимыеВидыОпераций() Экспорт
	
	ПараметрыКонтроля = НастройкаПараметровСканированияСлужебныйКлиентСерверПовтИсп.ПараметрыКонтроля();
	
	ВозвращаемоеЗначние = Новый Соответствие();
	Для Каждого КлючИЗначение Из ПараметрыКонтроля Цикл
		ВозвращаемоеЗначние.Вставить(КлючИЗначение.Значение, Новый Массив);
	КонецЦикла;
	
	ЭлементыКонструктора = Новый Массив;
	ЭлементыКонструктора.Добавить(Справочники.ЭлементыКонструктораВидовПродукцииИС.КонтролироватьСтатусыКодовМаркировки);
	ЭлементыКонструктора.Добавить(Справочники.ЭлементыКонструктораВидовПродукцииИС.КонтролироватьВладельцевКодовМаркировки);
	ЭлементыКонструктора.Добавить(Справочники.ЭлементыКонструктораВидовПродукцииИС.ИгнорироватьРезультатыПроверкиКодовМаркировкиНаККТ);
	
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ
		|	ДоступныеЗначенияЭлементовКонструктораВидовПродукцииИС.ЭлементКонструктора,
		|	ДоступныеЗначенияЭлементовКонструктораВидовПродукцииИС.Значение
		|ИЗ
		|	РегистрСведений.ДоступныеЗначенияЭлементовКонструктораВидовПродукцииИС КАК
		|		ДоступныеЗначенияЭлементовКонструктораВидовПродукцииИС
		|ГДЕ
		|	ДоступныеЗначенияЭлементовКонструктораВидовПродукцииИС.ЭлементКонструктора В (&ЭлементыКонструктора)
		|	И НЕ ДоступныеЗначенияЭлементовКонструктораВидовПродукцииИС.ПометкаУдаления
		|	И ДоступныеЗначенияЭлементовКонструктораВидовПродукцииИС.Значение ССЫЛКА Перечисление.ВидыОперацийИСМП";
	
	Запрос.УстановитьПараметр("ЭлементыКонструктора", ЭлементыКонструктора);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		Если Выборка.ЭлементКонструктора = Справочники.ЭлементыКонструктораВидовПродукцииИС.КонтролироватьСтатусыКодовМаркировки Тогда
			ВозвращаемоеЗначние[ПараметрыКонтроля.ПараметрыКонтроляСтатусов].Добавить(Выборка.Значение);
		ИначеЕсли Выборка.ЭлементКонструктора = Справочники.ЭлементыКонструктораВидовПродукцииИС.КонтролироватьВладельцевКодовМаркировки Тогда
			ВозвращаемоеЗначние[ПараметрыКонтроля.ПараметрыКонтроляВладельцев].Добавить(Выборка.Значение);
		ИначеЕсли Выборка.ЭлементКонструктора = Справочники.ЭлементыКонструктораВидовПродукцииИС.ИгнорироватьРезультатыПроверкиКодовМаркировкиНаККТ Тогда
			ВозвращаемоеЗначние[ПараметрыКонтроля.ПараметрыИгнорированияПроверкиККТ].Добавить(Выборка.Значение);
		КонецЕсли;
	КонецЦикла;
	
	Возврат ВозвращаемоеЗначние;
	
КонецФункции

#КонецОбласти