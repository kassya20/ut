
#Область ПрограммныйИнтерфейс

// Открывает форму ввода входящей платежной ссылки СБП.
// 
// Параметры:
//  Форма - ФормаКлиентскогоПриложения - форма документа, для ввода ссылки СБП
//  Документ - ДокументСсылка - Документ входящей платежной ссылки, в котором вводится ссылка СБП.
//
Процедура НачатьВводВходящейПлатежнойСсылки(Форма, Документ) Экспорт
	
	ВидКонтрагента = ОбщегоНазначенияУТВызовСервера.ЗначениеРеквизитаОбъекта(Форма.Контрагент, "ЮрФизЛицо");
	ДанныеДокумента = Новый Структура;
	ДанныеДокумента.Вставить("Организация", Форма.Организация);
	ДанныеДокумента.Вставить("БанковскийСчетОрганизации", Форма.БанковскийСчет);
	ДанныеДокумента.Вставить("ПорядокРасчетов", Форма.ПорядокРасчетов);
	ДанныеДокумента.Вставить("ФормаОплаты", Форма.ФормаОплаты);
	ДанныеДокумента.Вставить("ЭтоЗаказ", Форма.ЭтоЗаказ);
	ДанныеДокумента.Вставить("Контрагент", Форма.Контрагент);
	ДанныеДокумента.Вставить("БанковскийСчетКонтрагента", Форма.БанковскийСчетКонтрагента);
	ДанныеДокумента.Вставить("ВидКонтрагента", ВидКонтрагента);
	ДанныеДокумента.Вставить("Склад", Форма.ТСП);
	
	ЕстьОшибки = Ложь;
	СистемаБыстрыхПлатежейУТВызовСервера.ПроверитьДанныеДокументаДляВводаПлатежнойСсылки(ДанныеДокумента, ЕстьОшибки);
	
	Если ЕстьОшибки Тогда
		Возврат;
	КонецЕсли;
	
	ПараметрыВвода = НовыйПараметрыВводаПлатежнойСсылки();
	ЗаполнитьЗначенияСвойств(ПараметрыВвода, ДанныеДокумента);
	ПараметрыВвода.Форма = Форма;
	ПараметрыВвода.Документ = Документ;
	
	ОткрытьВводПлатежнойСсылки(ПараметрыВвода);
	
КонецПроцедуры

// Возвращает структуру параметров ввода платежной ссылки.
// 
// Возвращаемое значение:
//  Структура - Новый параметры ввода платежной ссылки:
// * Форма - Неопределено, ФормаКлиентскогоПриложения - форма документа.
// * Документ - Неопределено, ДокументСсылка - документ ввода платежной ссылки СБП.
// * ПлатежнаяСсылка - Строка - платежная ссылка СБП.
// * Организация - Неопределено, СправочникСсылка.Организации - организация, по которой выполняется поиск настройки подключения.
// * БанковскийСчетОрганизации - Неопределено, СправочникСсылка.БанковскиеСчетаОрганизаций - банковский счет организации, по которому выполняется поиск настройки подключения.
// * Склад - Неопределено, СправочникСсылка.Склады - склад, по которому выполняется поиск настройки подключения.
// * ВидКонтрагента - Неопределено, ПеречислениеСсылка.ЮрФизЛицо - вид контрагента, по которому выполняется поиск настройки подключения.
// * Контрагент - Неопределено, СправочникСсылка.Контрагенты - контрагент.
// * БанковскийСчетКонтрагента - Неопределено, СправочникСсылка.БанковскиеСчетаКонтрагентов - банковский счет контрагента.
// * ТекстОшибки - Неопределено, Строка - сообщение об ошибке.
Функция НовыйПараметрыВводаПлатежнойСсылки() Экспорт

	Результат = Новый Структура;
	Результат.Вставить("Форма", Неопределено);
	Результат.Вставить("Документ", Неопределено);
	Результат.Вставить("ПлатежнаяСсылка", "");
	Результат.Вставить("Организация", Неопределено);
	Результат.Вставить("БанковскийСчетОрганизации", Неопределено);
	Результат.Вставить("Склад", Неопределено);
	Результат.Вставить("ВидКонтрагента", Неопределено);
	Результат.Вставить("Контрагент", Неопределено);
	Результат.Вставить("БанковскийСчетКонтрагента", Неопределено);
	Результат.Вставить("ТекстОшибки", Неопределено);
	
	Возврат Результат;

КонецФункции

// Возвращает структуру параметров для получения настроек подключения.
// 
// Возвращаемое значение:
//  Структура - параметры получения настроек подключения:
// * ОтборНастроек - Структура:
//   ** Организация - Неопределено - организация в настройке.
//   ** БанковскийСчетОрганизации - Неопределено - банковский счет организации настройки.
//   ** Склад - Неопределено - склад (магазин) настройки.
//   ** ВидКонтрагента - Неопределено - вид контрагента настройки.
// * ОповещениеПослеПолученияНастройки - Неопределено, ОписаниеОповещения - оповещение после получения настройки.
Функция НовыйПараметрыПолученияНастроекПодключения() Экспорт

	ОтборНастроек = Новый Структура;
	ОтборНастроек.Вставить("Организация", Неопределено);
	ОтборНастроек.Вставить("БанковскийСчетОрганизации", Неопределено);
	ОтборНастроек.Вставить("Склад", Неопределено);
	ОтборНастроек.Вставить("ВидКонтрагента", Неопределено);
	
	Результат = Новый Структура;
	Результат.Вставить("ОтборНастроек", ОтборНастроек);
	Результат.Вставить("ОповещениеПослеПолученияНастройки", Неопределено);
	
	Возврат Результат;

КонецФункции

// Открывает форму ввода платежной ссылки по настройке.
// 
// Параметры:
//  ПараметрыВвода - см. НовыйПараметрыВводаПлатежнойСсылки.
Процедура ОткрытьВводПлатежнойСсылки(ПараметрыВвода) Экспорт

	ОписаниеОповещения = Новый ОписаниеОповещения("ВвестиВходящуюПлатежнуюСсылку", ЭтотОбъект, ПараметрыВвода);
	ОписаниеОповещенияОбОшибке = Новый ОписаниеОповещения("ВывестиОшибкуПолученияНастроек", ЭтотОбъект);
	
	ПараметрыОтбораНастроек = НовыйПараметрыПолученияНастроекПодключения();
	Отбор = ПараметрыОтбораНастроек.ОтборНастроек;
	Отбор.Организация = ПараметрыВвода.Организация;
	Отбор.БанковскийСчетОрганизации = ПараметрыВвода.БанковскийСчетОрганизации;
	Отбор.Склад = ПараметрыВвода.Склад;
	Отбор.ВидКонтрагента = ПараметрыВвода.ВидКонтрагента;
	ПараметрыОтбораНастроек.ОповещениеПослеПолученияНастройки = ОписаниеОповещения;
	
	ПолучитьНастройкиПодключения(ПараметрыОтбораНастроек, ПараметрыВвода, ОписаниеОповещенияОбОшибке);

КонецПроцедуры

// Получает настройки подключения СБП.
// 
// Параметры:
//  ПараметрыПолученияНастроек - см. НовыйПараметрыПолученияНастроекПодключения.
//  ПараметрыИсточника - см. НовыйПараметрыВводаПлатежнойСсылки.
//  ОповещениеОбОшибке - Неопределено, ОписаниеОповещения - Оповещение в случае ошибки.
Процедура ПолучитьНастройкиПодключения(ПараметрыПолученияНастроек, ПараметрыИсточника, ОповещениеОбОшибке) Экспорт

	ПараметрыНастроек = 
		СистемаБыстрыхПлатежейУТВызовСервера.ДоступныеНастройкиПодключения(ПараметрыПолученияНастроек.ОтборНастроек);
	
	Если ПараметрыНастроек.НастройкиПодключения <> Неопределено
		И ПараметрыНастроек.НастройкиПодключения.Количество() = 1 Тогда
		ВыполнитьОбработкуОповещения(ПараметрыПолученияНастроек.ОповещениеПослеПолученияНастройки, ПараметрыНастроек.НастройкиПодключения[0]);
	ИначеЕсли ПараметрыНастроек.НастройкиПодключения <> Неопределено
		И ПараметрыНастроек.НастройкиПодключения.Количество() > 1 Тогда
		СистемаБыстрыхПлатежейКлиент.ПоказатьВыборНастройки(
			ПараметрыПолученияНастроек.ОповещениеПослеПолученияНастройки, ПараметрыНастроек.НастройкиПодключения, ПараметрыИсточника.Форма);
	ИначеЕсли ПараметрыНастроек.НастройкиПодключения = Неопределено Тогда
		
		Если ОповещениеОбОшибке <> Неопределено Тогда
			ВыполнитьОбработкуОповещения(ОповещениеОбОшибке, ОповещениеОбОшибке.ДополнительныеПараметры);
		КонецЕсли;
		
	ИначеЕсли ПараметрыНастроек.ДоступноПодключение Тогда
		
		ДополнительныеНастройки = ПараметрыНастроек.ДополнительныеНастройки;
		
		ПараметрыИсточника.Вставить("БИК", ДополнительныеНастройки.БИК);
		ПараметрыИсточника.Вставить("ОтборУчастников", ДополнительныеНастройки.ОтборУчастников);
		ПараметрыИсточника.Вставить("ВариантНастройки", ДополнительныеНастройки.ВариантНастройки);
		ПараметрыИсточника.Вставить("ДополнительныеНастройки", ДополнительныеНастройки.ДополнительныеПараметры);
		ПараметрыИсточника.Вставить("ПараметрыПолученияНастроек", ПараметрыПолученияНастроек);
		
		ОбработкаЗавершения = Новый ОписаниеОповещения(
			"ПолучитьОтветНаСозданиеНовойНастройки",
			ЭтотОбъект,
			ПараметрыИсточника);
		
		ТекстВопроса = НСтр("ru='Настройка подключения к Системе быстрых платежей не
			|найдена, необходимо создать новую настройку.
			|Создать сейчас?'");
		
		ПоказатьВопрос(ОбработкаЗавершения, ТекстВопроса, РежимДиалогаВопрос.ДаНет);
		
	КонецЕсли;

КонецПроцедуры

// Возвращает данные заполнения по платежной ссылке.
// 
// Параметры:
//  Форма - ФормаКлиентскогоПриложения - форма.
//  НастройкаПодключения - СправочникСсылка.НастройкиПодключенияКСистемеБыстрыхПлатежей - Настройка подключения.
//  ПлатежнаяСсылка - Строка - Платежная ссылка.
//  ОповещениеОПолучении - ОписаниеОповещения - оповещение после завершения фонового задания.
//
Процедура ПолучитьДанныеЗаполненияПоПлатежнойСсылке(Форма, НастройкаПодключения, ПлатежнаяСсылка, ОповещениеОПолучении) Экспорт

	ПараметрыПроцедуры = Новый Структура;
	ПараметрыПроцедуры.Вставить("НастройкаПодключения", НастройкаПодключения);
	ПараметрыПроцедуры.Вставить("ПлатежнаяСсылка", ПлатежнаяСсылка);
	
	ФоновоеЗадание = СистемаБыстрыхПлатежейУТВызовСервера.ЗаданиеНаПолучениеДанныхПоПлатежнойСсылке(ПараметрыПроцедуры);
	ПараметрыОжидания = ДлительныеОперацииКлиент.ПараметрыОжидания(Форма);
	ДлительныеОперацииКлиент.ОжидатьЗавершение(ФоновоеЗадание, ОповещениеОПолучении, ПараметрыОжидания);

КонецПроцедуры

// Начинает загрузку статусов операций.
// 
// Параметры:
//  Форма - ФормаКлиентскогоПриложения - Форма обработки.
//  ПараметрыЗавершения - см. ДенежныеСредстваКлиентЛокализация.НовыеПараметрыЗагрузкиИзСервиса
Процедура НачатьЗагрузкуСтатусовОпераций(Форма, ПараметрыЗавершения) Экспорт

	ФоновоеЗадание = СистемаБыстрыхПлатежейУТВызовСервера.ЗаданиеНаЗагрузкуСтатусовОпераций();
	ПараметрыОжидания = ДлительныеОперацииКлиент.ПараметрыОжидания(Форма);
	ПараметрыОжидания.ВыводитьСообщения = Истина;
	
	ОповещениеОПолучении = Новый ОписаниеОповещения(
		"ОбработкаПолученияОперацийЗавершение", Форма, ПараметрыЗавершения);
	ДлительныеОперацииКлиент.ОжидатьЗавершение(ФоновоеЗадание, ОповещениеОПолучении, ПараметрыОжидания);

КонецПроцедуры

// Начало обновления статуса оплаты по документу.
// 
// Параметры:
//  Форма - ФормаКлиентскогоПриложения - Форма документа.
//  ИсходныеПараметры - Структура:
//  *ДокументСсылка - ДокументСсылка - ссылка на документ.
Процедура НачатьОбновлениеСтатусаОплатыПоДокументу(Форма, ИсходныеПараметры) Экспорт

	ДополнительныеПараметры = Новый Структура;
	ДополнительныеПараметры.Вставить("Форма", Форма);
	ДополнительныеПараметры.Вставить("Документ", ИсходныеПараметры.ДокументСсылка);
	ОповещениеОПолучении = Новый ОписаниеОповещения("ОбновитьСтатусОплатыСБППоДокументуЗавершение", ЭтотОбъект, ДополнительныеПараметры);
	
	ФоновоеЗадание = СистемаБыстрыхПлатежейУТВызовСервера.ЗаданиеНаОбновлениеСтатусаОплатыПоДокументу(ИсходныеПараметры);
	ПараметрыОжидания = ДлительныеОперацииКлиент.ПараметрыОжидания(Форма);
	ПараметрыОжидания.ВыводитьСообщения = Истина;
	ДлительныеОперацииКлиент.ОжидатьЗавершение(ФоновоеЗадание, ОповещениеОПолучении, ПараметрыОжидания);

КонецПроцедуры

// Выполняет проверку наличия оплаты СБП.
// 
// Параметры:
//  Форма - ФормаКлиентскогоПриложения - Форма документа, в котором выполняется проверка.
//  ДокументСсылка - ДокументСсылка - ссылка на документ, в котором выполняется проверка.
//  Контрагент - СправочникСсылка.Контрагенты - плательщик в документе.
//
Процедура ПроверитьОплатуСБП(Форма, ДокументСсылка, Контрагент) Экспорт

	ВыполненаОплата = СистемаБыстрыхПлатежейУТВызовСервера.ЕстьТекущаяОплатаПлатежнойСсылкиСБП(ДокументСсылка, Контрагент);
	
	Если ВыполненаОплата Тогда
		Оповестить("ЗачтенаОплата", ДокументСсылка);
	Иначе
		Форма.ПодключитьОбработчикОжидания("Подключаемый_ПроверкаОплатыСБП", 1, Истина);
	КонецЕсли;

КонецПроцедуры

#КонецОбласти

#Область СлужебныйПрограммныйИнтерфейс

// Открывает форму ввода входящей платежной ссылки с параметрами ввода.
// 
// Параметры:
//  НастройкаПодключения - Неопределено, СправочникСсылка.НастройкиПодключенияКСистемеБыстрыхПлатежей - настройка подключения.
//  ДополнительныеПараметры - см. НовыйПараметрыВводаПлатежнойСсылки
Процедура ВвестиВходящуюПлатежнуюСсылку(НастройкаПодключения, ДополнительныеПараметры) Экспорт

	Если НастройкаПодключения = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ПараметрыОткрытия = Новый Структура;
	ПараметрыОткрытия.Вставить("Документ", ДополнительныеПараметры.Документ);
	ПараметрыОткрытия.Вставить("НастройкаПодключения", НастройкаПодключения);
	ПараметрыОткрытия.Вставить("Контрагент", ДополнительныеПараметры.Контрагент);
	ПараметрыОткрытия.Вставить("БанковскийСчетКонтрагента", ДополнительныеПараметры.БанковскийСчетКонтрагента);
	ПараметрыОткрытия.Вставить("ПлатежнаяСсылка", ДополнительныеПараметры.ПлатежнаяСсылка);
	
	ОповещениеОЗакрытии = Новый ОписаниеОповещения(
		"ВвестиВходящуюПлатежнуюСсылкуЗавершение", ЭтотОбъект, ДополнительныеПараметры);
	
	ОткрытьФорму(
		"ОбщаяФорма.ВводВходящейПлатежнойСсылкиСБП",
		ПараметрыОткрытия,
		ДополнительныеПараметры.Форма, , , ,
		ОповещениеОЗакрытии,
		РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);

КонецПроцедуры

// Обрабатывает ответ на создание новой настройки подключения к СБП.
// 
// Параметры:
//  Ответ - КодВозвратаДиалога - ответ на создание новой настройки
//  ДополнительныеПараметры - см. НовыйПараметрыВводаПлатежнойСсылки
Процедура ПолучитьОтветНаСозданиеНовойНастройки(Ответ, ДополнительныеПараметры) Экспорт

	Если Ответ = КодВозвратаДиалога.Да Тогда
		
		ОписаниеОповещения = Новый ОписаниеОповещения(
			"ПослеПодключенияСистемыБыстрыхПлатежей",
			ЭтотОбъект,
			ДополнительныеПараметры);
		
		ПараметрыПодключения = СистемаБыстрыхПлатежейКлиент.НовыйПараметрыПодключения(
			ДополнительныеПараметры.БИК,
			ДополнительныеПараметры.ОтборУчастников, ,
			ДополнительныеПараметры.ВариантНастройки);
		
		СистемаБыстрыхПлатежейКлиент.ПодключитьСистемуБыстрыхПлатежей(
			ПараметрыПодключения,
			ОписаниеОповещения,
			ДополнительныеПараметры.ДополнительныеНастройки);
		
	КонецЕсли;

КонецПроцедуры

Процедура ПослеПодключенияСистемыБыстрыхПлатежей(Результат, ДополнительныеПараметры) Экспорт

	Если Результат = Истина Тогда
		ОписаниеОповещенияОбОшибке = Новый ОписаниеОповещения("ВывестиОшибкуПолученияНастроек", ЭтотОбъект);
		ПолучитьНастройкиПодключения(ДополнительныеПараметры.ПараметрыПолученияНастроек, ДополнительныеПараметры, ОписаниеОповещенияОбОшибке);
	КонецЕсли;

КонецПроцедуры

// Вызывает обработку данных после ввода входящей платежной ссылки.
// 
// Параметры:
//  Результат - Неопределено, Структура - данные ссылки:
//   * ТипСсылки - Строка - тип Функциональной ссылки СБП.
//   * СуммаОплаты - Число, Неопределено - сумма оплаты указанная получателем платежа.
//   * Наименование - Строка - сокращенное наименование ЮЛ или ИП - получателя платежа.
//   * ИНН - Строка - ИНН ЮЛ или ИП - получателя платежа.
//   * СчетПолучателя - Строка - счет получателя платежа.
//   * БИК - Строка - БИК банка, в котором открыт счет получателя платежа.
//   * НаименованиеМагазина - Строка - торговое наименование магазина или торговой точки.
//   * АдресМагазина - Строка - фактический адрес магазина или торговой точки.
//   * ОблагаетсяНДС - Булево - Информация о взимании НДС.
//   * СуммаНДС - Строка, Неопределено - сумма НДС. 
//   * НазначениеПлатежа - Строка - Назначение платежа.
//   * ИдентификаторОплаты - Строка - уникальный Идентификатор платежа.
//  ДополнительныеПараметры - см. НовыйПараметрыВводаПлатежнойСсылки
Процедура ВвестиВходящуюПлатежнуюСсылкуЗавершение(Результат, ДополнительныеПараметры) Экспорт

	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Форма = ДополнительныеПараметры.Форма; // ФормаКлиентскогоПриложения
	
	Оповещение = Новый ОписаниеОповещения("ПослеВводаПлатежнойСсылкиСБП", Форма);
	ВыполнитьОбработкуОповещения(Оповещение, Результат);

КонецПроцедуры

Процедура ВывестиОшибкуПолученияНастроек(Результат, ДополнительныеПараметры) Экспорт

	ТекстСообщения = НСтр("ru = 'Не обнаружены настройки подключения к СБП'");
	ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения);

КонецПроцедуры

Процедура ОбновитьСтатусОплатыСБППоДокументуЗавершение(РезультатФоновогоЗадания, ДополнительныеПараметры) Экспорт

	Результат = ПолучитьИзВременногоХранилища(РезультатФоновогоЗадания.АдресРезультата);
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если Результат.Количество() = 0 Тогда
		
		Шаблон = НСтр("ru = 'По документу %2 не определена платежная ссылка для проверки статуса оплаты.'");
		ТекстСообщения = СтрШаблон(Шаблон, ДополнительныеПараметры.Документ);
		ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения);
		Возврат;
		
	КонецЕсли;
	
	ИмяСобытия = "";
	
	Для Каждого СтрокаРезультата Из Результат Цикл
		
		Если ЗначениеЗаполнено(СтрокаРезультата.КодОшибки) Тогда
			
			Шаблон = НСтр("ru = 'Не удалось проверить статус оплаты по документу %1:
							|%2.'");
			ТекстСообщения = СтрШаблон(Шаблон, СтрокаРезультата.Документ, СтрокаРезультата.СообщениеОбОшибке);
			ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения);
			Продолжить;
			
		КонецЕсли;
		
		Если СтрокаРезультата.СтатусОперации = "Выполнена" Тогда
			
			Если СтрокаРезультата.ВариантНастройки = ПредопределенноеЗначение("Перечисление.ВариантыНастройкиСБП.b2b") Тогда
				ИмяСобытия = "Запись_ПоступлениеБезналичныхДенежныхСредств";
			Иначе
				ИмяСобытия = "Запись_ОперацияПоПлатежнойКарте"
			КонецЕсли;
		
		ИначеЕсли СтрокаРезультата.СтатусОперации = "Выполняется" Тогда
			
			Шаблон = НСтр("ru = 'Платежная ссылка по документу %1 еще не оплачена.'");
			ТекстСообщения = СтрШаблон(Шаблон, СтрокаРезультата.Документ);
			ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения);
			
		ИначеЕсли СтрокаРезультата.СтатусОперации = "Отменена" Тогда
			
			Шаблон = НСтр("ru = 'Истек срок жизни платежной ссылки по документу %1.'");
			ТекстСообщения = СтрШаблон(Шаблон, СтрокаРезультата.Документ);
			ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения);
			
		КонецЕсли;
		
	КонецЦикла;
	
	ПоказатьОповещениеПользователя( , , НСтр("ru = 'Обновление статусов оплаты завершено'"));
	
	Если Не ПустаяСтрока(ИмяСобытия) Тогда
		Оповестить(ИмяСобытия);
		Оповестить("ИзмененСтатусСБП");
	КонецЕсли;

КонецПроцедуры

#КонецОбласти
