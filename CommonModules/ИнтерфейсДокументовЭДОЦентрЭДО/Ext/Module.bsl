// @strict-types

#Область СлужебныйПрограммныйИнтерфейс

#Область ПросмотрФайлаЭлектронногоДокумента

// Параметры:
//  ИдентификаторДокументаЭДО - Строка
// 
// Возвращаемое значение:
// - Неопределено
// - См. ДанныеФайлаИнформацииОтправителяВФорматеСервиса
Функция ДанныеФайлаИнформацииОтправителяДокумента(ИдентификаторДокументаЭДО) Экспорт
	
	ЭлектронныйДокумент = ЭлектронныеДокументыЭДОЦентрЭДО.ДокументПоИдентификатору(ИдентификаторДокументаЭДО);

	Если Не ЗначениеЗаполнено(ЭлектронныйДокумент) Тогда
		Возврат Неопределено;
	КонецЕсли;

	ДанныеФайла = ЛегкийИнтерфейсДокументовЭДО.ДанныеФайлаИнформацииОтправителяДокумента(ЭлектронныйДокумент,
		Новый УникальныйИдентификатор());
		
	Возврат ДанныеФайлаИнформацииОтправителяВФорматеСервиса(ДанныеФайла);
	
КонецФункции

#КонецОбласти // ПросмотрФайлаЭлектронногоДокумента

#Область ПросмотрДокумента

// Возвращает сформированные файлы с визуализацией документа ЭДО.
//
// Параметры:
//  ДанныеДокументаЭДО - Структура:
//  * Идентификатор     - Строка
//  * Отправитель       - Структура:
//  ** ИНН              - Строка
//  ** КПП              - Строка
//  * Получатель        - Структура:
//  ** ИНН              - Строка
//  ** КПП              - Строка
//  * Договор           - Структура:
//  ** Наименование     - Строка
//  ** Номер            - Строка
//  ** Дата             - См. ОбщегоНазначенияБЭД.ДатаВФорматеISO
//  * ВидДокумента      - Структура:
//  ** Наименование     - Строка
//  ** ТипДокумента     - Строка
//  * ИдентификаторОтправителя - Строка
//  * ИдентификаторПолучателя - Строка
//  * Формат            - Строка - формат, в который конвертируются учетные данные.
//  * УчетныеДанные     - Структура:
//  ** Данные           - Структура - учетные данные для конвертации.
//  ** Формат           - Строка - формат учетных данных.
//  ПараметрыВизуализации - Структура:
//  * ВыводитьДопДанные - Булево
//  * ВыводитьБанковскиеРеквизиты - Булево
//  * ВыводитьКопияВерна - Булево
//  * ПодсказкаQRКода - Строка
//  * ПубличнаяСсылкаQRКода - Строка
// 
// Возвращаемое значение:
//  Структура:
//  * ФайлыДокумента - Структура:
//  ** Идентификатор - Строка
//  ** Ошибки - Неопределено - при формировании без ошибок.
//            - Массив из Строка
//  ** ОсновнойФайл - Неопределено - при наличии ошибок.
//                  - Структура:
//                    *** ИмяФайла - Строка
//                    *** Данные - Строка - двоичные данные в формате base64.
//  ** ДополнительныйФайл - Неопределено - при наличии ошибок или отсутствии соответствующих учетных данных.
//                        - Структура:
//                          *** ИмяФайла - Строка
//                          *** Данные - Строка - двоичные данные в формате base64.
//  * Визуализация - Неопределено
//                 - См. ВизуализацияФайловДокументаЭДО
//  * ДанныеИзСодержанияФайла - Неопределено
//                            - См. ДанныеИзСодержанияФайлаВФорматеСервиса
//
Функция СформироватьФайлыИВизуализациюДокументаЭДО(ДанныеДокументаЭДО, ПараметрыВизуализации) Экспорт
	
	Результат = Новый Структура;
	Результат.Вставить("ФайлыДокумента", Новый Структура);
	Результат.Вставить("Визуализация", Неопределено);
	Результат.Вставить("ДанныеИзСодержанияФайла", Неопределено);
	
	ДанныеДокументовЭДО = ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(ДанныеДокументаЭДО);
	РезультатыФормирования = ЭлектронныеДокументыЭДОЦентрЭДО.СформироватьФайлыДокументовЭДО(ДанныеДокументовЭДО);
	РезультатФормирования = РезультатыФормирования[0];
	Результат.ФайлыДокумента = РезультатФормирования;
	
	Если ЗначениеЗаполнено(РезультатФормирования.Ошибки) Тогда
		Возврат Результат;
	КонецЕсли;
	
	ФайлыДокумента = Новый Массив; // Массив Из Структура
	ФайлыДокумента.Добавить(РезультатФормирования.ОсновнойФайл);
	Если ЗначениеЗаполнено(РезультатФормирования.ДополнительныйФайл) Тогда
		ФайлыДокумента.Добавить(РезультатФормирования.ДополнительныйФайл);
	КонецЕсли;
	
	Результат.Визуализация = ВизуализацияЭДОЦентрЭДО.ВизуализацияФайловДокументаЭДО(ФайлыДокумента,
		ДанныеДокументаЭДО.ВидДокумента, ДанныеДокументаЭДО.Формат, ПараметрыВизуализации);
		
	Результат.ДанныеИзСодержанияФайла = ДанныеИзСодержанияФайлаВФорматеСервиса(
		РезультатФормирования.ОсновнойФайл);
	
	Возврат Результат;
	
КонецФункции

// Возвращает двоичные данные проштампованного файла информации отправителя документа ЭДО.
// 
// Параметры:
//  ИдентификаторДокументаЭДО - Строка
// 
// Возвращаемое значение:
//  - Неопределено
//  - См. ПредставлениеФайлаДокументаЭДОВФорматеСервиса
Функция ПредставлениеФайлаДокументаЭДО(ИдентификаторДокументаЭДО) Экспорт

	ЭлектронныйДокумент = ЭлектронныеДокументыЭДОЦентрЭДО.ДокументПоИдентификатору(ИдентификаторДокументаЭДО);
	Если Не ЗначениеЗаполнено(ЭлектронныйДокумент) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	СообщениеЭДО = ЭлектронныеДокументыЭДО.СообщениеОтправителя(ЭлектронныйДокумент);
		
	Попытка
		РезультатШтампирования = Документы.СообщениеЭДО.ПроштампованныйФайл(СообщениеЭДО);
	Исключение
		РезультатШтампирования = Неопределено;
		ИнтерфейсДокументовЭДО.ЗаписатьОшибкуВизуализацииPDFВЖурналРегистрации(ИнформацияОбОшибке());
		Возврат Неопределено;
	КонецПопытки;
	
	Возврат ПредставлениеФайлаДокументаЭДОВФорматеСервиса(РезультатШтампирования);
	
КонецФункции

#КонецОбласти // ПросмотрДокумента

#КонецОбласти // СлужебныйПрограммныйИнтерфейс

#Область СлужебныеПроцедурыИФункции

#Область ПросмотрДокумента

// @skip-check property-return-type, invocation-parameter-type-intersect, dynamic-access-method-not-found, statement-type-change
// 
// Параметры:
//  ДанныеФайла - Структура:
//  * ИмяФайла - Строка
//  * Данные - Строка - двоичные данные в формате base64.
// 
// Возвращаемое значение:
// - Неопределено
// - Структура:
// * НомерДокумента - Строка 
// * ДатаДокумента - См. ОбщегоНазначенияБЭД.ДатаВФорматеISO
// * СуммаДокумента - Число
// * ТипРегламента - Строка
// * СуммаНДСДокумента - Число
// * СтавкаНДСДокумента - Строка
// * ВалютаДокумента - Строка
Функция ДанныеИзСодержанияФайлаВФорматеСервиса(ДанныеФайла)
	
	ОписаниеФайла = РаботаСФайламиБЭД.НовоеОписаниеФайла();
	ОписаниеФайла.ИмяФайла = ДанныеФайла.ИмяФайла;
	ОписаниеФайла.ДвоичныеДанные = Base64Значение(ДанныеФайла.Данные);
	
	СодержаниеФайла = ФорматыЭДО.ПрочитатьСодержаниеДокумента(ОписаниеФайла);
	
	Если Не ЗначениеЗаполнено(СодержаниеФайла) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	ДанныеИзСодержания = Новый Структура;
	ДанныеИзСодержания.Вставить("НомерДокумента", "");
	ДанныеИзСодержания.Вставить("ДатаДокумента", "");
	ДанныеИзСодержания.Вставить("СуммаДокумента", 0);
	ДанныеИзСодержания.Вставить("ТипРегламента", "");
	ДанныеИзСодержания.Вставить("СуммаНДСДокумента", 0);
	ДанныеИзСодержания.Вставить("СтавкаНДСДокумента", "");
	ДанныеИзСодержания.Вставить("ВалютаДокумента", "");
	
	ДанныеИзСодержания.НомерДокумента = СодержаниеФайла.НомерДокумента;
	ДанныеИзСодержания.ДатаДокумента = ОбщегоНазначенияБЭД.ДатаВФорматеISO(СодержаниеФайла.ДатаДокумента);
	ДанныеИзСодержания.СуммаДокумента = СодержаниеФайла.СуммаДокумента;
	ДанныеИзСодержания.ТипРегламента = ОбщегоНазначения.ИмяЗначенияПеречисления(СодержаниеФайла.ТипРегламента);
	ДанныеИзСодержания.СуммаНДСДокумента = СодержаниеФайла.СуммаНДСДокумента;
	ДанныеИзСодержания.СтавкаНДСДокумента = СодержаниеФайла.СтавкаНДСДокумента;
	ДанныеИзСодержания.ВалютаДокумента = СодержаниеФайла.ВалютаДокумента;
	
	Возврат ДанныеИзСодержания;
	
КонецФункции

// Параметры:
//  РезультатШтампирования - См. Документы.СообщениеЭДО.ПроштампованныйФайл
// 
// Возвращаемое значение:
//  Структура:
// * ПредставлениеДокумента - Строка
// * ТекстОшибки - Строка
Функция ПредставлениеФайлаДокументаЭДОВФорматеСервиса(РезультатШтампирования)
	
	ПредставлениеФайлаВФорматеСервиса = Новый Структура("ПредставлениеДокумента, ТекстОшибки", "", "");
	Если РезультатШтампирования.ПредставлениеДокумента <> Неопределено Тогда
		ПредставлениеФайлаВФорматеСервиса.ПредставлениеДокумента = Base64Строка(
			РезультатШтампирования.ПредставлениеДокумента);
	КонецЕсли;
	ПредставлениеФайлаВФорматеСервиса.ТекстОшибки = РезультатШтампирования.ТекстОшибки;
	
	Возврат ПредставлениеФайлаВФорматеСервиса;
	
КонецФункции

#КонецОбласти // ПросмотрДокумента

#Область ПросмотрФайлаЭлектронногоДокумента

// Параметры:
//  РезультатПолученияДанныхФайла - См. ЛегкийИнтерфейсДокументовЭДО.НовыйРезультатПолученияДанныхФайлаИнформацииОтправителя
// 
// Возвращаемое значение:
//  - Неопределено
//  - См. НовыеДанныеФайлаИнформацииОтправителяВФорматеСервиса
Функция ДанныеФайлаИнформацииОтправителяВФорматеСервиса(РезультатПолученияДанныхФайла)
	
	ДанныеФайла = РезультатПолученияДанныхФайла.ДанныеФайла; // См. ЛегкийИнтерфейсДокументовЭДО.НовыеДанныеФайлаИнформацииОтправителя

	Если Не ЗначениеЗаполнено(ДанныеФайла) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	ДанныеФайлаВФорматеСервиса = НовыеДанныеФайлаИнформацииОтправителяВФорматеСервиса();
	ДанныеФайлаВФорматеСервиса.Данные = Base64Строка(ДанныеФайла.ДвоичныеДанные);
	ДанныеФайлаВФорматеСервиса.ИмяФайла = ДанныеФайла.ИмяФайла;
	ДанныеФайлаВФорматеСервиса.ПомеченНаУдаление = ДанныеФайла.ПомеченНаУдаление;
	Возврат ДанныеФайлаВФорматеСервиса;
	
КонецФункции

#КонецОбласти // ПросмотрФайлаЭлектронногоДокумента

#Область ПросмотрФайлаЭлектронногоДокумента

// Возвращаемое значение:
//  Структура:
// * Данные - Строка - двоичные данные в формате base64.
// * ИмяФайла - Строка
// * ПомеченНаУдаление - Булево
Функция НовыеДанныеФайлаИнформацииОтправителяВФорматеСервиса()
	ДанныеФайла = Новый Структура;
	ДанныеФайла.Вставить("Данные", "");
	ДанныеФайла.Вставить("ИмяФайла", "");
	ДанныеФайла.Вставить("ПомеченНаУдаление", Ложь);
	Возврат ДанныеФайла;
КонецФункции

#КонецОбласти // ПросмотрФайлаЭлектронногоДокумента

#КонецОбласти // СлужебныеПроцедурыИФункции