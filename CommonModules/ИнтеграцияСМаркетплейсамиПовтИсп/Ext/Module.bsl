#Область СлужебныйПрограммныйИнтерфейс

// Определяет, является ли символ разделителем.
//
// Параметры:
//   Символ          - Строка - проверяемый символ;
//   РазделителиСлов - Строка - символы разделителей. Если параметр не указан, то 
//                              разделителем считаются все символы, не являющиеся цифрами, 
//                              латинскими и кириллическими буквами, а также знаком подчеркивания.
//
// Возвращаемое значение:
//   Булево - Истина, если символ с кодом КодСимвола является разделителем.
//
Функция ЭтоРазделительСлов(Символ, РазделителиСлов = Неопределено) Экспорт
	
	Возврат СтроковыеФункцииКлиентСервер.ЭтоРазделительСлов(КодСимвола(Символ), РазделителиСлов);
	
КонецФункции

// Возвращает краткое представление торговой площадки.
//
// Параметры:
//   ВидМаркетплейса - ПеречислениеСсылка.ВидыМаркетплейсов - вид торговой площадки.
//
// Возвращаемое значение:
//   Строка - краткое представление вида торговой площадки.
//
Функция ПредставлениеВидаТорговойПлощадки(ВидМаркетплейса) Экспорт

	Возврат ИнтеграцияСМаркетплейсамиКлиентСервер.ПредставлениеВидаТорговойПлощадки(ВидМаркетплейса);

КонецФункции

// Определяет данные авторизации сервиса.
//
// Параметры:
//   УчетнаяЗапись   - СправочникСсылка.УчетныеЗаписиМаркетплейсов - учетная запись подключения к сервису.
//   ВидМаркетплейса - Неопределено, ПеречислениеСсылка.ВидыМаркетплейсов - вид торговой площадки.
//
// Возвращаемое значение:
//   Неопределено, Произвольный - данные авторизации в зависимости от вида торговой площадки.
//
Функция ПолучитьДанныеАвторизации(УчетнаяЗапись, ВидМаркетплейса = Неопределено) Экспорт

	Если ВидМаркетплейса = Неопределено Тогда
		ВидМаркетплейса = ИнтеграцияСМаркетплейсамиПовтИсп.ВидМаркетплейсаУчетнойЗаписи(УчетнаяЗапись);
	КонецЕсли;
	
	Если ИнтеграцияСМаркетплейсамиКлиентСервер.ЭтоOzon(ВидМаркетплейса) Тогда
		ДанныеАвторизации = ИнтеграцияСМаркетплейсомOzonСервер.ПолучитьДанныеАвторизации(УчетнаяЗапись);
		
	ИначеЕсли ИнтеграцияСМаркетплейсамиКлиентСервер.ЭтоЯндексМаркет(ВидМаркетплейса) Тогда
		ДанныеАвторизации = ИнтеграцияСЯндексМаркетСервер.ДанныеАвторизацииПоУчетнойЗаписи(УчетнаяЗапись);
	Иначе
		ДанныеАвторизации = Неопределено;
	КонецЕсли;

	Возврат ДанныеАвторизации;

КонецФункции

// Определяет вид маркетплейса переданной учетной записи.
// 
// Параметры:
//  УчетнаяЗапись - см. ИнтеграцияСМаркетплейсамиВызовСервера.ВидМаркетплейсаУчетнойЗаписи.УчетнаяЗапись
// 
// Возвращаемое значение:
//  См. ИнтеграцияСМаркетплейсамиВызовСервера.ВидМаркетплейсаУчетнойЗаписи
//
Функция ВидМаркетплейсаУчетнойЗаписи(УчетнаяЗапись) Экспорт

	Возврат ИнтеграцияСМаркетплейсамиВызовСервера.ВидМаркетплейсаУчетнойЗаписи(УчетнаяЗапись);

КонецФункции

// Определяет разрешен ли метод для вызова как произвольный код.
// 
// Параметры:
//  ИмяМодуля - Строка - Имя модуля
//  ИмяМетода - Строка - Имя метода
// 
// Возвращаемое значение:
//  Строка, Неопределено - Строка - полное имя разрешенного метода; Неопределено - метод запрещен.
Функция МетодРазрешенДляВызоваКакПроизвольныйКод(ИмяМодуля, ИмяМетода) Экспорт
	
	Методы = Новый Соответствие;
	
	Если ИмяМодуля = ИнтеграцияСМаркетплейсамиСИ.ИмяМодуля() Тогда
		ИнтеграцияСМаркетплейсамиСИ.ПриОпределенииМетодовРазрешенныхДляВызоваКакПроизвольныйКод(Методы);
	Иначе
		Возврат Неопределено;
	КонецЕсли;
	
	Если Методы[ИмяМетода] = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Возврат СтрШаблон("%1.%2", ИмяМодуля, ИмяМетода);

КонецФункции

#КонецОбласти
