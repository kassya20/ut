#Область ЭлементыКонструктораВидовПродукции

// Функция проверяет, доступен ли указанный формат обмена с СУЗ для вида продукции.
// 
// Параметры:
//  ФорматОбмена - ПеречислениеСсылка.ВерсииФорматаОбменаСУЗ
//  ВидПродукцииТоварнаяГруппа - СправочникСсылка.ТоварныеГруппыГИСМТ - Товарная группа,
//                               СправочникСсылка.ВидыПродукцииИС - Вид продукции,
//                               Массив из СправочникСсылка.ВидыПродукцииИС.
// Возвращаемое значение:
//  Булево - доступность поля.
Функция ПоддерживаетсяФорматОбменаСУЗ(ФорматОбмена, ВидПродукцииТоварнаяГруппа) Экспорт

	Возврат ФорматОбмена = ПредопределенноеЗначение("Перечисление.ВерсииФорматаОбменаСУЗ.V3")
		Или КонструкторИСОбщегоНазначенияКлиентСервер.ЗначенияЭлементаКонструктораПоВидуПродукции(
			ПредопределенноеЗначение(
				"Справочник.ЭлементыКонструктораВидовПродукцииИС.ПоддерживаетсяФорматаОбменаСУЗНижеV3"),
			КонструкторИСМПОбщегоНазначенияКлиентСервер.ВидыПродукции(ВидПродукцииТоварнаяГруппа))

КонецФункции

// Функция проверяет, требуется ли подписание заказа на эмиссию.
// 
// Параметры:
//  ВидПродукцииТоварнаяГруппа - СправочникСсылка.ТоварныеГруппыГИСМТ - Товарная группа,
//                               СправочникСсылка.ВидыПродукцииИС - Вид продукции,
//                               Массив из СправочникСсылка.ВидыПродукцииИС.
//  ФорматОбмена - ПеречислениеСсылка.ВерсииФорматаОбменаСУЗ
// 
// Возвращаемое значение:
//  Булево - требуется подписание.
Функция ТребуетсяПодписание(ВидПродукцииТоварнаяГруппа, ФорматОбмена) Экспорт

	Возврат ФорматОбмена = ПредопределенноеЗначение("Перечисление.ВерсииФорматаОбменаСУЗ.V3")
		Или КонструкторИСОбщегоНазначенияКлиентСервер.ЗначенияЭлементаКонструктораПоВидуПродукции(
			ПредопределенноеЗначение(
				"Справочник.ЭлементыКонструктораВидовПродукцииИС.ТребуетсяПодписаниеЗаказаНаЭмиссиюСУЗНижеV3"),
			КонструкторИСМПОбщегоНазначенияКлиентСервер.ВидыПродукции(ВидПродукцииТоварнаяГруппа))

КонецФункции

