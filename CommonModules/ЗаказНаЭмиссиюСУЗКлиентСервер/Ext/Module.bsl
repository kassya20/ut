// Доступные способы ввода в оборот для указанного вида продукции.
// 
// Параметры:
//  ВидПродукцииТоварнаяГруппа - СправочникСсылка.ТоварныеГруппыГИСМТ - Товарная группа,
//                               СправочникСсылка.ВидыПродукцииИС - Вид продукции,
//                               Массив из СправочникСсылка.ВидыПродукцииИС.
// 
// Возвращаемое значение:
//  Массив из ОпределяемыйТип.ЗначениеЭлементаКонструктораВидовПродукцииИС - доступные способы ввода в оборот.
Функция ДоступныеСпособыВводаВОборот(ВидПродукцииТоварнаяГруппа) Экспорт
	
	ДоступныеЗначения = Новый Массив;
	
	Для Каждого Элемент Из КонструкторИСОбщегоНазначенияКлиентСервер.ЗначенияЭлементаКонструктораПоВидуПродукции(
		ПредопределенноеЗначение(
			"Справочник.ЭлементыКонструктораВидовПродукцииИС.ПолеСпособВводаВОборот"),
		КонструкторИСМПОбщегоНазначенияКлиентСервер.ВидыПродукции(ВидПродукцииТоварнаяГруппа)) Цикл
		
		Если ТипЗнч(Элемент) = Тип("ПеречислениеСсылка.СпособыВводаВОборотСУЗ")
			И (Элемент <> ПредопределенноеЗначение("Перечисление.СпособыВводаВОборотСУЗ.МаркировкаОстатков")
				Или КонструкторИСМПКлиентСервер.ВидПродукцииПодлежитМаркировкеОстатков(ВидПродукцииТоварнаяГруппа)) Тогда
			ДоступныеЗначения.Добавить(Элемент);
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат ДоступныеЗначения;
	
