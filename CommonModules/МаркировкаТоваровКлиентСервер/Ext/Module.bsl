#Область ПрограммныйИнтерфейс

// Функция проверяет, доступен ли отчет о нанесении для указанного вида продукции/товарной группы.
// 
// Параметры:
//  ВидПродукцииТоварнаяГруппа - СправочникСсылка.ТоварныеГруппыГИСМТ - Товарная группа,
//                               СправочникСсылка.ВидыПродукцииИС - Вид продукции,
//                               Массив из СправочникСсылка.ВидыПродукцииИС.
//                               Если не указано - проверяется наличие операции в конфигурации.
// 
// Возвращаемое значение:
//  Булево - Истина, если для вида продукции доступна операция отчета о нанесении
Функция ДоступенОтчетОНанесении(ВидПродукцииТоварнаяГруппа = Неопределено) Экспорт
	
	Если ВидПродукцииТоварнаяГруппа = Неопределено Тогда
		
		Возврат КонструкторИСОбщегоНазначенияКлиентСервер.ВидыПродукцииПоЭлементуКонструктора(
			ПредопределенноеЗначение(
				"Справочник.ЭлементыКонструктораВидовПродукцииИС.ОперацияОтчетОНанесенииКодовМаркировки")).Количество();
		
	Иначе
		
		Возврат КонструкторИСОбщегоНазначенияКлиентСервер.ЗначенияЭлементаКонструктораПоВидуПродукции(
			ПредопределенноеЗначение(
				"Справочник.ЭлементыКонструктораВидовПродукцииИС.ОперацияОтчетОНанесенииКодовМаркировки"),
			КонструкторИСМПОбщегоНазначенияКлиентСервер.ВидыПродукции(ВидПродукцииТоварнаяГруппа));
		
	КонецЕсли;
	
КонецФункции

// Функция проверяет, подлежит ли товарная группа обязательной маркировке и вводу в оборот.
// 
// Параметры:
//  ВидПродукцииТоварнаяГруппа - СправочникСсылка.ТоварныеГруппыГИСМТ - Товарная группа,
//                               СправочникСсылка.ВидыПродукцииИС - Вид продукции,
//                               Массив из СправочникСсылка.ВидыПродукцииИС.
// 
// Возвращаемое значение:
//  Булево - Истина, если товарная группа подлежит обязательной маркировке и вводу в оборот
Функция ТоварнаяГруппаПодлежитВводуВОборот(ВидПродукцииТоварнаяГруппа) Экспорт
	
	Возврат
		МаркировкаТоваровКлиентСервер.ДоступноПроизводствоВнеЕАЭС(ВидПродукцииТоварнаяГруппа)
		Или МаркировкаТоваровКлиентСервер.ДоступнаОперацияВводВОборотПроизводствоРФ(ВидПродукцииТоварнаяГруппа)
		Или МаркировкаТоваровКлиентСервер.ДоступенИмпортСФТС(ВидПродукцииТоварнаяГруппа)
		Или МаркировкаТоваровКлиентСервер.ДоступнаОперацияИмпортСФТСМех(ВидПродукцииТоварнаяГруппа)
		Или МаркировкаТоваровКлиентСервер.ДоступнаОперацияПодтверждениеПоступленияКИЗ(ВидПродукцииТоварнаяГруппа)
		Или МаркировкаТоваровКлиентСервер.ДоступнаОперацияВводВОборотПроизводствоРФПоДоговору(ВидПродукцииТоварнаяГруппа)
		Или МаркировкаТоваровКлиентСервер.ДоступнаОперацияВводВОборотПроизводствоРФПоДоговоруНаСторонеЗаказчика(ВидПродукцииТоварнаяГруппа)
		Или МаркировкаТоваровКлиентСервер.ДоступноПолучениеПродукцииОтФизическихЛиц(ВидПродукцииТоварнаяГруппа)
		Или МаркировкаТоваровКлиентСервер.ДоступнаОперацияВводВОборотТрансграничнаяТорговля(ВидПродукцииТоварнаяГруппа)
		Или КонструкторИСМПКлиентСервер.ВидПродукцииПодлежитМаркировкеОстатков(ВидПродукцииТоварнаяГруппа);
	
КонецФункции

#КонецОбласти

