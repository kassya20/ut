			"Справочник.ЭлементыКонструктораВидовПродукцииИС.ДатаПроизводстваВСУЗСУказаниемЧасовогоПояса"),
		ВидПродукцииТоварнаяГруппа,
		Операция);
	
КонецФункции

#КонецОбласти

Функция ТекущаяОперацияПоДальнейшемуДействию(Операция, ОперацияНанесения, ДальнейшееДействие) Экспорт
	
	ТекущаяОперация = Операция;
	Если ДальнейшееДействие = ПредопределенноеЗначение("Перечисление.ДальнейшиеДействияПоВзаимодействиюИСМП.ПередайтеОтчет")
		Или ДальнейшееДействие = ПредопределенноеЗначение("Перечисление.ДальнейшиеДействияПоВзаимодействиюИСМП.ПередайтеОтчетСИсправлениями") Тогда
		Если ЗначениеЗаполнено(ОперацияНанесения) Тогда
			ТекущаяОперация = ОперацияНанесения;
		КонецЕсли;
	ИначеЕсли ДальнейшееДействие = ПредопределенноеЗначение("Перечисление.ДальнейшиеДействияПоВзаимодействиюИСМП.ВыполнитеАгрегацию")
		Или ДальнейшееДействие = ПредопределенноеЗначение("Перечисление.ДальнейшиеДействияПоВзаимодействиюИСМП.ВыполнитеАгрегациюСИсправлениями") Тогда
		ТекущаяОперация = ПредопределенноеЗначение("Перечисление.ВидыОперацийИСМП.Агрегация");
	КонецЕсли;
	
	Возврат ТекущаяОперация;
	
КонецФункции

Функция ДоступнаОперацияВводВОборотСырьяОстатки(ВидПродукцииТоварнаяГруппа = Неопределено) Экспорт
	
	Если ВидПродукцииТоварнаяГруппа = Неопределено Тогда
		
		Возврат КонструкторИСОбщегоНазначенияКлиентСервер.ВидыПродукцииПоЭлементуКонструктора(
			ПредопределенноеЗначение(
				"Справочник.ЭлементыКонструктораВидовПродукцииИС.ВводВОборотСырьяОстатки")).Количество();
		
	Иначе
		
		Возврат КонструкторИСОбщегоНазначенияКлиентСервер.ЗначенияЭлементаКонструктораПоВидуПродукции(
			ПредопределенноеЗначение(
				"Справочник.ЭлементыКонструктораВидовПродукцииИС.ВводВОборотСырьяОстатки"),
			КонструкторИСМПОбщегоНазначенияКлиентСервер.ВидыПродукции(ВидПродукцииТоварнаяГруппа));
		
	КонецЕсли;
	
КонецФункции

