Функция КоличествоЗнаковТНВЭД(ВидПродукцииТоварнаяГруппа) Экспорт
	
	Результат = КонструкторИСОбщегоНазначенияКлиентСервер.ЗначенияЭлементаКонструктораПоВидуПродукции(
		ПредопределенноеЗначение(
			"Справочник.ЭлементыКонструктораВидовПродукцииИС.КоличествоЗнаковТНВЭДДляПередачиГИСМТ"),
		КонструкторИСМПОбщегоНазначенияКлиентСервер.ВидыПродукции(ВидПродукцииТоварнаяГруппа));
	
	Если Результат.Количество() = 0 Тогда
		Возврат 2;
	Иначе
		Возврат Результат[0];
	КонецЕсли;
	
КонецФункции

