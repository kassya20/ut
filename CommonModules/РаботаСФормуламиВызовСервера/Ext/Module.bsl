#Область ПрограммныйИнтерфейс

// Функция значение параметра по имени.
//
// Параметры:
// 	ТекстРасчета - Строка - вычисляемая формула
// 	ЗначениеЗамены - Произвольный - параметр, для которого будет вычисляться формула
//
// Возвращаемое значение:
// 	Произвольный
//
Функция ПроверитьФормулуЗапроса(ТекстРасчета, ЗначениеЗамены) Экспорт
	
	Запрос = Новый Запрос();
	Запрос.УстановитьПараметр("Параметр", ЗначениеЗамены);
	
	//@skip-check bsl-ql-hub
	Запрос.Текст = СтрЗаменить(
		"ВЫБРАТЬ ПолеШаблон ИЗ ТаблицаШаблон",
		"ПолеШаблон ИЗ ТаблицаШаблон",
		СтрЗаменить(ТекстРасчета, Строка(ЗначениеЗамены), "&Параметр"));
	
	Выборка = Запрос.Выполнить().Выбрать();
	Выборка.Следующий();
	
	Возврат Выборка.Получить(0);
	
КонецФункции

// Получает текст расчета.
//
// Параметры:
// 	ТекстРасчета - Строка - вычисляемая формула
// 	Операнды - Массив Из Строка - массив операндов
// 	ЗначениеЗамены - Произвольный - параметр, для которого будет вычисляться формула
// 	ТипыОперандов - Соответствие Из Строка - типы операндов
//
Процедура ПолучитьТекстРасчета(ТекстРасчета, Операнды, ЗначениеЗамены, ТипыОперандов = Неопределено) Экспорт
	
	ТипыОперандов = ?(ТипыОперандов = Неопределено, Новый Соответствие, ТипыОперандов);
	
	Для Каждого Операнд Из Операнды Цикл
		
		ЗначениеДляПодстановки = Неопределено;
		
		ТипОперанда = ТипыОперандов.Получить(Операнд);
		Если ЗначениеЗаполнено(ТипОперанда) Тогда
			
			Если ТипОперанда.СодержитТип(Тип("Дата")) Тогда
				
				ЗначениеДляПодстановки = "Дата(1, 1, 1)";
				
			ИначеЕсли ТипОперанда.СодержитТип(Тип("Число")) Тогда
				
				ГенераторСлучайныхЧисел = Новый ГенераторСлучайныхЧисел();
				ЗначениеДляПодстановки = Формат(ГенераторСлучайныхЧисел.СлучайноеЧисло(1, 1000), "ЧГ=")
				
			ИначеЕсли ТипОперанда.СодержитТип(Тип("Булево")) Тогда
				
				ЗначениеДляПодстановки = "Ложь";
				
			ИначеЕсли ТипОперанда.СодержитТип(Тип("Строка")) Тогда
				
				ЗначениеДляПодстановки = """1""";
				
			Иначе
				
				ОписаниеТипов = Новый ОписаниеТипов(ТипОперанда);
				ЗначениеДляПодстановки = Строка(ОписаниеТипов.ПривестиЗначение(1));
				
			КонецЕсли;
			
		КонецЕсли;
		
		Если Не ЗначениеЗаполнено(ЗначениеДляПодстановки) Тогда
			ЗначениеДляПодстановки = ЗначениеЗамены;
		КонецЕсли;
		
		ТекстРасчета = СтрЗаменить(
			ТекстРасчета,
			РаботаСФормуламиКлиентСервер.ПолучитьТекстОперандаДляВставки(Операнд),
			ЗначениеДляПодстановки);
		
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти