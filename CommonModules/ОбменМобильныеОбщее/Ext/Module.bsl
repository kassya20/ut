
#Область ПрограммныйИнтерфейс

// Функция формирует пакет обмена, который будет отправлен узлу "УзелОбмена" 
//
// Параметры:
//  УзелОбмена - ПланОбменаСсылка - узел плана обмена "мобильные", с которым осуществляется обмен
//
// Возвращаемое значение:
//  ХранилищеЗначения - сформированный пакет, помещенный в хранилище значения
Функция СформироватьПакетОбмена(УзелОбмена) Экспорт
	
	ИмяФайлаXML = СформироватьXML(УзелОбмена);
	Пакет = Новый ДвоичныеДанные(ИмяФайлаXML);
	ХЗ = Новый ХранилищеЗначения(Пакет);
	Возврат ХЗ;
	
КонецФункции

// Процедура вносит в информационную базу данные, которые присланы из узла "УзелОбмена" 
//
// Параметры:
//  УзелОбмена - ПланОбменаСсылка - узел плана обмена "мобильные", с которым осуществляется обмен
//  ДанныеОбмена - ХранилищеЗначения - пакет обмена полученный из узла УзелОбмена, помещен в ХранилищеЗначения
//
Процедура ПринятьПакетОбмена(УзелОбмена, ДанныеОбмена) Экспорт
	
	ИмяФайла = ПолучитьИмяВременногоФайла("xml");
	ДвоичныеДанные = ДанныеОбмена.Получить(); // ДвоичныеДанные
	ДвоичныеДанные.Записать(ИмяФайла);
	
	УстановитьПривилегированныйРежим(Истина);
	ЧтениеXML = Новый ЧтениеXML;
	ЧтениеXML.ОткрытьФайл(ИмяФайла,,,"UTF-8");
	ЧтениеСообщения = ПланыОбмена.СоздатьЧтениеСообщения();
	ЧтениеСообщения.НачатьЧтение(ЧтениеXML);
	ПланыОбмена.УдалитьРегистрациюИзменений(ЧтениеСообщения.Отправитель, ЧтениеСообщения.НомерПринятого);
	
	МассивПриходныхОрдеров = Новый Массив;
	МассивОтборовРазмещений = Новый Массив;
	МассивРасходныхОрдеров = Новый Массив;
	МассивПересчетов = Новый Массив;
	
	ЦентральныйУзелОбмена = ПланыОбмена.Мобильные.НайтиПоКоду("001");
	
	Пока ВозможностьЧтенияXML(ЧтениеXML) Цикл
		ИмяОбъекта = ЧтениеXML.Имя;
		Данные = ОбменМобильныеПереопределяемый.ПрочитатьДанные(ЧтениеXML);
		Если НЕ Данные = Неопределено Тогда
			Если УзелОбмена <> ЦентральныйУзелОбмена И ПланыОбмена.ИзменениеЗарегистрировано(ЧтениеСообщения.Отправитель, Данные) Тогда
#Если Не МобильныйАвтономныйСервер Тогда
				ИмяСобытияЖурналРегистрации = НСтр("ru = 'Объект, принятый из автономной конфигурации, не был записан, так как был изменен в центральной базе'", ОбщегоНазначения.КодОсновногоЯзыка());
				ЗаписьЖурналаРегистрации(ИмяСобытияЖурналРегистрации, УровеньЖурналаРегистрации.Ошибка,,Данные.Ссылка);
#КонецЕсли
				Продолжить;
			КонецЕсли;
			
			Данные.ОбменДанными.Отправитель = ЧтениеСообщения.Отправитель;
			Данные.ОбменДанными.Загрузка = Истина;
			
			Попытка
				ЗаблокироватьДанныеДляРедактирования(Данные.Ссылка);
			Исключение
#Если Не МобильныйАвтономныйСервер Тогда
				ПодробноеПредставлениеОшибки = ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
				ИмяСобытияЖурналРегистрации = НСтр("ru = 'Не удалось записать данные, принятые из автономной конфигурации, так как в момент записи объект был заблокирован'", ОбщегоНазначения.КодОсновногоЯзыка());
				ЗаписьЖурналаРегистрации(ИмяСобытияЖурналРегистрации, УровеньЖурналаРегистрации.Ошибка,,Данные.Ссылка,ПодробноеПредставлениеОшибки);
#КонецЕсли
				Продолжить;
			КонецПопытки;
			
			МожноПровести = МобильноеРабочееМестоКладовщика.ЕстьРеквизитИлиСвойствоОбъекта(Данные, "Проведен");
			
			Попытка
				Данные.Записать();
				
				Если МожноПровести Тогда
					Если ТипЗнч(Данные) = Тип("ДокументОбъект.ПриходныйОрдерНаТовары") Тогда
						МассивПриходныхОрдеров.Добавить(Данные.Ссылка);
					ИначеЕсли ТипЗнч(Данные) = Тип("ДокументОбъект.ОтборРазмещениеТоваров") Тогда
						МассивОтборовРазмещений.Добавить(Данные.Ссылка);
					ИначеЕсли ТипЗнч(Данные) = Тип("ДокументОбъект.РасходныйОрдерНаТовары") Тогда
						МассивРасходныхОрдеров.Добавить(Данные.Ссылка);
					ИначеЕсли ТипЗнч(Данные) = Тип("ДокументОбъект.ПересчетТоваров") Тогда
						МассивПересчетов.Добавить(Данные.Ссылка);
					КонецЕсли; 
				КонецЕсли;
			Исключение
#Если Не МобильныйАвтономныйСервер Тогда
				ПодробноеПредставлениеОшибки = ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
				ИмяСобытияЖурналРегистрации = НСтр("ru = 'Не удалось записать данные, принятые из автономной конфигурации'", ОбщегоНазначения.КодОсновногоЯзыка());
				ЗаписьЖурналаРегистрации(ИмяСобытияЖурналРегистрации, УровеньЖурналаРегистрации.Ошибка,,Данные.Ссылка,ПодробноеПредставлениеОшибки);
#КонецЕсли
			КонецПопытки;
			РазблокироватьДанныеДляРедактирования(Данные.Ссылка);
		КонецЕсли;
		
	КонецЦикла;
	
	МассивыДокументов = Новый Структура;
	МассивыДокументов.Вставить("ПриходныеОрдера", МассивПриходныхОрдеров);
	МассивыДокументов.Вставить("ОтборыРазмещения", МассивОтборовРазмещений);
	МассивыДокументов.Вставить("РасходныеОрдера", МассивРасходныхОрдеров);
	МассивыДокументов.Вставить("Пересчеты", МассивПересчетов);
	
	ЧтениеСообщения.ЗакончитьЧтение();
	ЧтениеXML.Закрыть();
	
	Если УзелОбмена <> ЦентральныйУзелОбмена Тогда
		ВыполнитьПроведениеДокументов(МассивыДокументов);
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Процедура на основании анализа типа данных заменяет их на данные, удаляющие
// информацию из узла в котором их не должно быть
//
// Параметры:
//  Данные - Объект, набор записей,... который нужно преобразовать
//
Процедура УдалениеДанных(Данные) 
	
	// Получаем объект описания метаданного, соответствующий данным
	ОбъектМетаданных = ?(ТипЗнч(Данные) = Тип("УдалениеОбъекта"), Данные.Ссылка.Метаданные(), Данные.Метаданные());
	// Проверяем тип, интересуют только те типы, которые реализованы на мобильной платформе
	Если Метаданные.Справочники.Содержит(ОбъектМетаданных)
		ИЛИ Метаданные.Документы.Содержит(ОбъектМетаданных) Тогда
		
		// Перенос удаления объекта для объектных
		Данные = Новый УдалениеОбъекта(Данные.Ссылка);
		
	ИначеЕсли Метаданные.РегистрыСведений.Содержит(ОбъектМетаданных)
		ИЛИ Метаданные.РегистрыНакопления.Содержит(ОбъектМетаданных)
		ИЛИ Метаданные.Последовательности.Содержит(ОбъектМетаданных) Тогда
		
		// Очищаем данные
		Данные.Очистить();
		
	КонецЕсли;	
	
КонецПроцедуры

Функция СформироватьXML(УзелОбмена)
	
	УстановитьПривилегированныйРежим(Истина);
	ЗаписьXML = Новый ЗаписьXML;
	
	ИмяФайла = ПолучитьИмяВременногоФайла("xml");
	ЗаписьXML.ОткрытьФайл(ИмяФайла, "UTF-8");
	
	ЗаписьXML.ЗаписатьОбъявлениеXML();
	
	ЗаписьСообщения = ПланыОбмена.СоздатьЗаписьСообщения();
	ЗаписьСообщения.НачатьЗапись(ЗаписьXML, УзелОбмена);
	
	ЗаписьXML.ЗаписатьСоответствиеПространстваИмен("xsi", "http://www.w3.org/2001/XMLSchema-instance");
	ЗаписьXML.ЗаписатьСоответствиеПространстваИмен("v8",  "http://v8.1c.ru/data");
	
	ТипДанныхУдаления = Тип("УдалениеОбъекта");
	
	ЦентральныйУзел = Истина;
	Если УзелОбмена <> ПланыОбмена.Мобильные.НайтиПоКоду("001") Тогда
		ЦентральныйУзел = Ложь;
		ДатаНачалаВыгрузкиДокументов = МобильноеРабочееМестоКладовщика.ЗначениеРеквизитаОбъекта(УзелОбмена, "ДатаНачалаВыгрузкиДокументов");
	КонецЕсли;
	ВыборкаИзменений = ПланыОбмена.ВыбратьИзменения(УзелОбмена, ЗаписьСообщения.НомерСообщения);
	Пока ВыборкаИзменений.Следующий() Цикл
		
		Данные = ВыборкаИзменений.Получить();
		
		// Если перенос данных не нужен, то, возможно, необходимо записать удаление данных
		Если НЕ ОбменМобильныеПереопределяемый.НуженПереносДанных(Данные, УзелОбмена) Тогда
			
			// Получаем значение с возможным удалением данных
			УдалениеДанных(Данные); 
			
		КонецЕсли;
		
		Если Не ЦентральныйУзел И МобильноеРабочееМестоКладовщика.ЕстьРеквизитИлиСвойствоОбъекта(Данные, "Проведен") Тогда
			Если Данные.Дата < ДатаНачалаВыгрузкиДокументов Тогда
				Продолжить;
			КонецЕсли;
		КонецЕсли;
		
		// Записываем данные в сообщение
		ОбменМобильныеПереопределяемый.ЗаписатьДанные(ЗаписьXML, Данные);
		
	КонецЦикла;
	
	ЗаписьСообщения.ЗакончитьЗапись();
	
	ЗаписьXML.Закрыть();
	
	Возврат ИмяФайла;
	
КонецФункции

// Процедура выполняет проведение документов, принятых из автономной конфигурации, в основной базе
//
// Параметры:
//  МассивыДокументов - Структура - структура, содержащая в себе массивы документов по типам
//
Процедура ВыполнитьПроведениеДокументов(МассивыДокументов)
	
#Если Не МобильныйАвтономныйСервер Тогда
	Для Каждого МассивДокументов Из МассивыДокументов Цикл
		Для Каждого ДокументСсылка Из МассивДокументов.Значение Цикл
			
			Попытка
				ЗаблокироватьДанныеДляРедактирования(ДокументСсылка);
			Исключение
				ПодробноеПредставлениеОшибки = ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
				ИмяСобытияЖурналРегистрации = НСтр("ru = 'Не удалось провести документ, принятый из автономной конфигурации, так как в момент проведения объект был заблокирован'", ОбщегоНазначения.КодОсновногоЯзыка());
				ЗаписьЖурналаРегистрации(ИмяСобытияЖурналРегистрации, УровеньЖурналаРегистрации.Ошибка,,ДокументСсылка,ПодробноеПредставлениеОшибки);
				Продолжить;
			КонецПопытки;
			
			Данные = ДокументСсылка.ПолучитьОбъект();
			
			Попытка
				Данные.Записать(РежимЗаписиДокумента.Проведение);
			Исключение
				ПодробноеПредставлениеОшибки = ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
				ИмяСобытияЖурналРегистрации = НСтр("ru = 'Невозможно провести документ, принятый из автономной конфигурации'", ОбщегоНазначения.КодОсновногоЯзыка());
				ЗаписьЖурналаРегистрации(ИмяСобытияЖурналРегистрации, УровеньЖурналаРегистрации.Ошибка,,ДокументСсылка,ПодробноеПредставлениеОшибки);
			КонецПопытки;
			
			РазблокироватьДанныеДляРедактирования(ДокументСсылка);
			
		КонецЦикла;
	КонецЦикла;
#КонецЕсли
	
КонецПроцедуры

#КонецОбласти