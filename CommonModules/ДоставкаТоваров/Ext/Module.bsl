Функция ТекстЗапросаКонтроляКоличестваСборкиПоРейсу(ВыражениеДопустимоеОтклонение, КонтролироватьОтклонениеМерныхТоваров)
	
	ТекстЗапроса =
	"ВЫБРАТЬ
	|	ОборотыКСборкеПоРейсу.Распоряжение КАК Распоряжение,
	|	ОборотыКСборкеПоРейсу.Номенклатура КАК Номенклатура,
	|	ОборотыКСборкеПоРейсу.Характеристика КАК Характеристика,
	|	ОборотыКСборкеПоРейсу.Серия КАК Серия,
	|	ОборотыКСборкеПоРейсу.ЕдиницаИзмерения КАК ЕдиницаИзмерения,
	|	ОборотыКСборкеПоРейсу.Назначение КАК Назначение,
	|	ОборотыКСборкеПоРейсу.Рейс КАК Рейс,
	|	-1 * (ОборотыКСборкеПоРейсу.КСборкеОборот - ЕСТЬNULL(ОборотыСборкиПоОрдеру.ЗапланированаСборкаОборот, 0)
	|		- ЕСТЬNULL(ОборотыСборкиПоОрдеру.СобираетсяОборот, 0) - ЕСТЬNULL(ОборотыСборкиПоОрдеру.СобраноОборот, 0)) КАК Превышение
	|ИЗ
	|	ВТ_ОборотыКСборкеПоРейсу КАК ОборотыКСборкеПоРейсу
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ОборотыСборкиПоОрдеру КАК ОборотыСборкиПоОрдеру
	|			ПО ОборотыКСборкеПоРейсу.Распоряжение = ОборотыСборкиПоОрдеру.Распоряжение
	|				И ОборотыКСборкеПоРейсу.Номенклатура = ОборотыСборкиПоОрдеру.Номенклатура
	|				И ОборотыКСборкеПоРейсу.Характеристика = ОборотыСборкиПоОрдеру.Характеристика
	|				И ОборотыКСборкеПоРейсу.Серия = ОборотыСборкиПоОрдеру.Серия
	|				И ОборотыКСборкеПоРейсу.Назначение = ОборотыСборкиПоОрдеру.Назначение
	|				И ОборотыКСборкеПоРейсу.Рейс = ОборотыСборкиПоОрдеру.Рейс
	|		ЛЕВОЕ СОЕДИНЕНИЕ ДопустимыеОтклоненияОстатковДоставки КАК ДопустимыеОтклоненияОстатковДоставки ПО ИСТИНА
	|ГДЕ
	|	ОборотыКСборкеПоРейсу.КСборкеОборот - ЕСТЬNULL(ОборотыСборкиПоОрдеру.ЗапланированаСборкаОборот, 0)
	|		- ЕСТЬNULL(ОборотыСборкиПоОрдеру.СобираетсяОборот, 0) - ЕСТЬNULL(ОборотыСборкиПоОрдеру.СобраноОборот, 0) + &ВыражениеДопустимоеОтклонение < 0
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ОборотыСборкиПоОрдеру.Распоряжение КАК Распоряжение,
	|	ОборотыСборкиПоОрдеру.Номенклатура КАК Номенклатура,
	|	ОборотыСборкиПоОрдеру.Характеристика КАК Характеристика,
	|	ОборотыСборкиПоОрдеру.Серия КАК Серия,
	|	ОборотыСборкиПоОрдеру.Номенклатура.ЕдиницаИзмерения КАК ЕдиницаИзмерения,
	|	ОборотыСборкиПоОрдеру.Назначение КАК Назначение,
	|	ОборотыСборкиПоОрдеру.Рейс КАК Рейс,
	|	-1 * (0 - ОборотыСборкиПоОрдеру.ЗапланированаСборкаОборот
	|		- ОборотыСборкиПоОрдеру.СобираетсяОборот - ОборотыСборкиПоОрдеру.СобраноОборот) КАК Превышение
	|ИЗ
	|	ВТ_ОборотыСборкиПоОрдеру КАК ОборотыСборкиПоОрдеру
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ОборотыКСборкеПоРейсу КАК ОборотыКСборкеПоРейсу
	|			ПО ОборотыСборкиПоОрдеру.Распоряжение = ОборотыКСборкеПоРейсу.Распоряжение
	|				И ОборотыСборкиПоОрдеру.Номенклатура = ОборотыКСборкеПоРейсу.Номенклатура
	|				И ОборотыСборкиПоОрдеру.Характеристика = ОборотыКСборкеПоРейсу.Характеристика
	|				И ОборотыСборкиПоОрдеру.Серия = ОборотыКСборкеПоРейсу.Серия
	|				И ОборотыСборкиПоОрдеру.Назначение = ОборотыКСборкеПоРейсу.Назначение
	|				И ОборотыСборкиПоОрдеру.Рейс = ОборотыКСборкеПоРейсу.Рейс
	|ГДЕ
	|	ОборотыКСборкеПоРейсу.КСборкеОборот ЕСТЬ NULL
	|	И (ОборотыСборкиПоОрдеру.ЗапланированаСборкаОборот + ОборотыСборкиПоОрдеру.СобираетсяОборот + ОборотыСборкиПоОрдеру.СобраноОборот) > 0";
	
	Если КонтролироватьОтклонениеМерныхТоваров Тогда
		
		СоединениеДопустимыеОтклонения =
		"ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ДопустимыеОтклоненияКСборке КАК ДопустимыеОтклоненияОстатковДоставки
		|ПО ОборотыКСборкеПоРейсу.Распоряжение = ДопустимыеОтклоненияОстатковДоставки.Распоряжение
		|	И ОборотыКСборкеПоРейсу.Номенклатура = ДопустимыеОтклоненияОстатковДоставки.Номенклатура
		|	И ОборотыКСборкеПоРейсу.Характеристика = ДопустимыеОтклоненияОстатковДоставки.Характеристика
		|	И ОборотыКСборкеПоРейсу.Серия = ДопустимыеОтклоненияОстатковДоставки.Серия
		|	И ОборотыКСборкеПоРейсу.Назначение = ДопустимыеОтклоненияОстатковДоставки.Назначение";
		
	Иначе
		
		СоединениеДопустимыеОтклонения = "";
		
	КонецЕсли;
	
	ТекстЗапроса = СтрЗаменить(
		ТекстЗапроса,
		"ЛЕВОЕ СОЕДИНЕНИЕ ДопустимыеОтклоненияОстатковДоставки КАК ДопустимыеОтклоненияОстатковДоставки ПО ИСТИНА",
		СоединениеДопустимыеОтклонения);
	
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&ВыражениеДопустимоеОтклонение", ВыражениеДопустимоеОтклонение);
	
	Возврат ТекстЗапроса;
	
КонецФункции

Функция ТекстЗапросаКонтроляСтатусовРейса(ВыражениеДопустимоеОтклонение, КонтролироватьОтклонениеМерныхТоваров)
	
	Если НЕ КонтролироватьОтклонениеМерныхТоваров Тогда
		
		ТекстЗапроса =
		"ВЫБРАТЬ
		|	ДоставкаОбороты.Распоряжение КАК Распоряжение,
		|	ДоставкаОбороты.Рейс КАК Рейс,
		|	ДоставкаОбороты.Отправитель КАК Отправитель,
		|	ДоставкаОбороты.Номенклатура КАК Номенклатура,
		|	ДоставкаОбороты.Номенклатура.ЕдиницаИзмерения КАК ЕдиницаИзмерения,
		|	ДоставкаОбороты.Характеристика КАК Характеристика,
		|	ДоставкаОбороты.Серия КАК Серия,
		|	(ДоставкаОбороты.СобраноОборот - ДоставкаОбороты.КСборкеОборот) КАК Превышение
		|ИЗ
		|	РегистрНакопления.Доставка.Обороты(
		|			,
		|			,
		|			,
		|			Плечо = 1
		|				И ТипДоставки = ЗНАЧЕНИЕ(Перечисление.ТипыДоставки.Исходящая)
		|				И Отправитель В
		|					(ВЫБРАТЬ
		|						Склады.Склад КАК Склад
		|					ИЗ
		|						ВТ_Склады КАК Склады)
		|				И (Распоряжение, Рейс, Номенклатура, Характеристика, Серия) В
		|					(ВЫБРАТЬ
		|						Таблица.Распоряжение КАК Распоряжение,
		|						Таблица.Рейс КАК Рейс,
		|						Таблица.Номенклатура КАК Номенклатура,
		|						Таблица.Характеристика КАК Характеристика,
		|						Таблица.Серия КАК Серия
		|					ИЗ
		|						ДвиженияДоставкаИзменение КАК Таблица)) КАК ДоставкаОбороты
		|ГДЕ
		|	ДоставкаОбороты.КСборкеОборот <> ДоставкаОбороты.СобраноОборот
		|	И (ДоставкаОбороты.ВПутиОборот > 0
		|			ИЛИ ДоставкаОбороты.ДоставленоОборот > 0)";
		
	Иначе
		
		ТекстЗапроса =
		"ВЫБРАТЬ
		|	ОборотыКСборкеПоРейсу.Распоряжение КАК Распоряжение,
		|	ОборотыКСборкеПоРейсу.Номенклатура КАК Номенклатура,
		|	ОборотыКСборкеПоРейсу.Характеристика КАК Характеристика,
		|	ОборотыКСборкеПоРейсу.Серия КАК Серия,
		|	ОборотыКСборкеПоРейсу.ЕдиницаИзмерения КАК ЕдиницаИзмерения,
		|	ОборотыКСборкеПоРейсу.Назначение КАК Назначение,
		|	ОборотыКСборкеПоРейсу.Рейс КАК Рейс,
		|	(ЕСТЬNULL(ОборотыСборкиПоОрдеру.СобраноОборот, 0) - ОборотыКСборкеПоРейсу.КСборкеОборот) КАК Превышение
		|ИЗ
		|	ВТ_ОборотыКСборкеПоРейсу КАК ОборотыКСборкеПоРейсу
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ОборотыСборкиПоОрдеру КАК ОборотыСборкиПоОрдеру
		|			ПО ОборотыКСборкеПоРейсу.Распоряжение = ОборотыСборкиПоОрдеру.Распоряжение
		|				И ОборотыКСборкеПоРейсу.Номенклатура = ОборотыСборкиПоОрдеру.Номенклатура
		|				И ОборотыКСборкеПоРейсу.Характеристика = ОборотыСборкиПоОрдеру.Характеристика
		|				И ОборотыКСборкеПоРейсу.Серия = ОборотыСборкиПоОрдеру.Серия
		|				И ОборотыКСборкеПоРейсу.Назначение = ОборотыСборкиПоОрдеру.Назначение
		|				И ОборотыКСборкеПоРейсу.Рейс = ОборотыСборкиПоОрдеру.Рейс
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ДопустимыеОтклоненияКСборке КАК ДопустимыеОтклоненияОстатковДоставки
		|			ПО ОборотыКСборкеПоРейсу.Распоряжение = ДопустимыеОтклоненияОстатковДоставки.Распоряжение
		|				И ОборотыКСборкеПоРейсу.Номенклатура = ДопустимыеОтклоненияОстатковДоставки.Номенклатура
		|				И ОборотыКСборкеПоРейсу.Характеристика = ДопустимыеОтклоненияОстатковДоставки.Характеристика
		|				И ОборотыКСборкеПоРейсу.Серия = ДопустимыеОтклоненияОстатковДоставки.Серия
		|				И ОборотыКСборкеПоРейсу.Назначение = ДопустимыеОтклоненияОстатковДоставки.Назначение
		|ГДЕ
		|	((ОборотыКСборкеПоРейсу.КСборкеОборот - ЕСТЬNULL(ОборотыСборкиПоОрдеру.СобраноОборот, 0)) > &ВыражениеДопустимоеОтклонение
		|		ИЛИ ЕСТЬNULL(ОборотыСборкиПоОрдеру.ЗапланированаСборкаОборот, 0) <> 0
		|		ИЛИ ЕСТЬNULL(ОборотыСборкиПоОрдеру.СобираетсяОборот, 0) <> 0)
		|	И (ОборотыКСборкеПоРейсу.ВПутиОборот > 0
		|		ИЛИ ОборотыКСборкеПоРейсу.ДоставленоОборот > 0)";
		
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&ВыражениеДопустимоеОтклонение", ВыражениеДопустимоеОтклонение);
		
	КонецЕсли;
	
	Возврат ТекстЗапроса;
	
КонецФункции

Функция ПредставленияПолейРезультатовКонтроля(СтрокаОшибки)
	
	Результат = Новый Структура;
	
	Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(СтрокаОшибки, "Назначение") Тогда
		
		ПредставлениеНоменклатуры = НоменклатураКлиентСервер.ПредставлениеНоменклатуры(
			СтрокаОшибки.Номенклатура, СтрокаОшибки.Характеристика,, СтрокаОшибки.Серия, СтрокаОшибки.Назначение);
		
	Иначе
		
		ПредставлениеНоменклатуры = НоменклатураКлиентСервер.ПредставлениеНоменклатуры(
			СтрокаОшибки.Номенклатура, СтрокаОшибки.Характеристика,, СтрокаОшибки.Серия);
		
	КонецЕсли;
	Результат.Вставить("Номенклатура", ПредставлениеНоменклатуры);
	
	ПредставлениеРаспоряжения = Строка(СтрокаОшибки.Распоряжение);
	Результат.Вставить("Распоряжение", ПредставлениеРаспоряжения);
	
	Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(СтрокаОшибки, "Отправитель") Тогда
		ПредставлениеОтправителя = Строка(СтрокаОшибки.Отправитель);
	Иначе
		ПредставлениеОтправителя = "";
	КонецЕсли;
	Результат.Вставить("Отправитель", ПредставлениеОтправителя);
	
	ПредставлениеПревышение = Строка(СтрокаОшибки.Превышение);
	Результат.Вставить("Превышение", ПредставлениеПревышение);
	
	ПредставлениеЕдиницаИзмерения = Строка(СтрокаОшибки.ЕдиницаИзмерения);
	Результат.Вставить("ЕдиницаИзмерения", ПредставлениеЕдиницаИзмерения);
	
	Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(СтрокаОшибки, "Организация") Тогда
		ПредставлениеОрганизации = Строка(СтрокаОшибки.Организация);
	Иначе
		ПредставлениеОрганизации = "";
	КонецЕсли;
	Результат.Вставить("Организация", ПредставлениеОрганизации);
	
	Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(СтрокаОшибки, "Получатель") Тогда
		ПредставлениеПолучателя = Строка(СтрокаОшибки.Получатель);
	Иначе
		ПредставлениеПолучателя = "";
	КонецЕсли;
	Результат.Вставить("Получатель", ПредставлениеПолучателя);
	
	Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(СтрокаОшибки, "Рейс") Тогда
		ПредставлениеРейса = Строка(СтрокаОшибки.Рейс);
	Иначе
		ПредставлениеРейса = "";
	КонецЕсли;
	Результат.Вставить("Рейс", ПредставлениеРейса);
	
	Возврат Результат;
	
КонецФункции

