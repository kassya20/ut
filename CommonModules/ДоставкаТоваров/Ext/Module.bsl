// Определяет заголовки элементов настройки доставки по настройкам системы
// 
// Параметры:
//  Форма - см. Справочник.Склады.Форма.ФормаЭлемента
//
Процедура УстановитьНастройкиЭлементовФормыСклада(Форма) Экспорт
	
	Если НЕ ДоставкаТоваровКлиентСервер.ИспользуетсяДоставка() Тогда
		Возврат;
	КонецЕсли;
	
	Элементы = Форма.Элементы;
	
	Если ДоставкаТоваровКлиентСервер.ИспользуетсяДоставка20() Тогда
		
		ЗаголовокСборкаПланируетсяДоставкой = НСтр("ru = 'Собирать товары в порядке доставки'");
		ЗаголовокДоставкаСборкаНезависимо = НСтр("ru = 'Порядок отбора товаров не зависит от порядка доставки'");
		
		ПодсказкаСборкаПланируетсяДоставкой = НСтр("ru = 'Если распоряжением на отгрузку предусмотрена доставка, то расходные ордера можно будет создать только после включения распоряжения в задание на перевозку.'");
		ПодсказкаДоставкаСборкаНезависимо = НСтр("ru = 'Расходные ордера создаются без учета заданий на перевозку. Если распоряжение на отгрузку предусматривает доставку, то нужно будет перед отгрузкой указать в ордере задание на перевозку.'");
		
	Иначе
		
		ЗаголовокСборкаПланируетсяДоставкой = НСтр("ru = 'Сборка осуществляется после планирования доставки'");
		ЗаголовокДоставкаСборкаНезависимо = НСтр("ru = 'Доставка и сборка планируются независимо'");
		
		ПодсказкаСборкаПланируетсяДоставкой = НСтр("ru = 'Сборка осуществляется после того, как распоряжение на доставку включено в рейс, планирующийся к погрузке. Расходный ордер связан с рейсом.'");
		ПодсказкаДоставкаСборкаНезависимо = НСтр("ru = 'Расходные ордера создаются без учета рейса. Сборка и планирование доставки происходит независимо. Расходный ордер и рейс не связаны.'");
		
	КонецЕсли;
	
	Элементы.ПорядокУказанияЗаданияНаПеревозку1.СписокВыбора[0].Представление = ЗаголовокСборкаПланируетсяДоставкой;
	Элементы.ПорядокУказанияЗаданияНаПеревозку2.СписокВыбора[0].Представление = ЗаголовокДоставкаСборкаНезависимо;
	
	Элементы.ПорядокУказанияЗаданияНаПеревозку1.РасширеннаяПодсказка.Заголовок = ПодсказкаСборкаПланируетсяДоставкой;
	Элементы.ПорядокУказанияЗаданияНаПеревозку2.РасширеннаяПодсказка.Заголовок = ПодсказкаДоставкаСборкаНезависимо;
	
КонецПроцедуры

