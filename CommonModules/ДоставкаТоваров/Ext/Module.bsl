// @strict-types

#Область ПрограммныйИнтерфейс

// Настройки проверки использования реквизитов доставки.
// Пустое имя поля означает, что в объекта не используется.
//
// Возвращаемое значение:
//  Структура:
// * ДокументОбъект - ДокументОбъект, Неопределено - проверяемый объект доставки (обязательно к заполнению)
// * СкладыДоставки - Массив из СправочникСсылка.Склады - склады, которые используются для оформления доставки
// * ВладелецТочекДоставки - СправочникСсылка.Партнеры, СправочникСсылка.Склады, Неопределено - владелец точек доставки документа
// * ТребуетсяДоставка - Булево - требуется в целом перевозка
// * ВидПланированияДоставкиИмяПоля - Строка - имя поля с адресом доставки, если не задано должно быть указано значение в ВидПланированияДоставкиБезусловный
// * ВидПланированияДоставкиБезусловный - ПеречислениеСсылка.ВидыПланированияДоставки  - значение (обязательное), если не задано ВидПланированияДоставкиИмяПоля
// * СпособУказанияДоставкиИмяПоля - Строка - имя поля способа указания доставки, если не задано должно быть указано значение в СпособУказанияДоставкиБезусловный
// * СпособУказанияДоставкиБезусловный - ПеречислениеСсылка.СпособыУказанияДоставки - значение (обязательное), если не задано СпособУказанияДоставкиИмяПоля
// * СпособДоставкиИмяПоля - Строка - имя поля способа доставки, если не задано должно быть указано значение в СпособУказанияДоставкиБезусловный
// * СпособДоставкиБезусловный - ПеречислениеСсылка.СпособыДоставки25 - значение, если не задано СпособДоставкиИмяПоля
// * ВремяДоставкиСИмяПоля - Строка - имя поля времени доставки с
// * ВремяДоставкиПоИмяПоля - Строка - имя поля времени доставки по
// * ТочкаДоставкиИмяПоля - Строка - имя поля точки доставки 
// * ЗонаДоставкиИмяПоля - Строка  - имя поля зоны доставки
// * ПеревозчикИмяПоля - Строка - имя поля перевозчика
// * ДоставкаДоПеревозчикаИмяПоля - Строка - имя поля доставки до перевозчика, если не задано должно быть указано значение в ДоставкаДоПеревозчикаБезусловный
// * ДоставкаДоПеревозчикаБезусловный - Булево - значение, если не задано ДоставкаДоПеревозчикаИмяПоля
// * ТочкаДоставкиПеревозчикаИмяПоля - Строка - имя поля точки доставки до перевозчика
// * ЗонаДоставкиПеревозчикаИмяПоля - Строка - имя поля зоны доставки перевозчика
// * АдресДоставкиИмяПоля - Строка - имя поля с адресом доставки
// * ДополнительнаяИнформацияПоДоставкеИмяПоля - Строка - Имя поля дополнительной информации к перевозке, может быть пустым
// * ОсобыеУсловияПеревозкиИмяПоля - Строка - Имя поля признака особых условий перевозки
// * ОсобыеУсловияПеревозкиОписаниеИмяПоля - Строка - Имя поля описания особых условий перевозки
// * ТоварыКДоставкеИмяТаблицы - Строка - имя табличной части товаров к доставке
// * ТаблицаТоваровДоставки - см. НоваяТаблицаТоваровДоставки
// * НакладнаяПоЗаказам - Булево - Применяется для доставки 2.0
//
Функция НовыеНастройкиПроверкиИспользованияРеквизитовДоставки() Экспорт
	
	НовыеНастройки = Новый Структура;
	
	НовыеНастройки.Вставить("ДокументОбъект", Неопределено);
	НовыеНастройки.Вставить("СкладыДоставки", Новый Массив);
	НовыеНастройки.Вставить("ВладелецТочекДоставки", Неопределено);
	
	НовыеНастройки.Вставить("ТребуетсяДоставка", Ложь);
	
	НовыеНастройки.Вставить("ВидПланированияДоставкиИмяПоля", "ВидПланированияДоставки");
	НовыеНастройки.Вставить("ВидПланированияДоставкиБезусловный", Перечисления.ВидыПланированияДоставки.ПустаяСсылка());
	НовыеНастройки.Вставить("СпособУказанияДоставкиИмяПоля", "СпособУказанияДоставки");
	НовыеНастройки.Вставить("СпособУказанияДоставкиБезусловный", Перечисления.СпособыУказанияДоставки.ПустаяСсылка());
	НовыеНастройки.Вставить("СпособДоставкиИмяПоля", "СпособДоставки25");
	НовыеНастройки.Вставить("СпособДоставкиБезусловный", Перечисления.СпособыДоставки25.ПустаяСсылка());
	
	НовыеНастройки.Вставить("ВремяДоставкиСИмяПоля", "ВремяДоставкиС");
	НовыеНастройки.Вставить("ВремяДоставкиПоИмяПоля", "ВремяДоставкиПо");
	
	НовыеНастройки.Вставить("ТочкаДоставкиИмяПоля", "ТочкаДоставки");
	НовыеНастройки.Вставить("ЗонаДоставкиИмяПоля", "ЗонаДоставки");
	
	НовыеНастройки.Вставить("ПеревозчикИмяПоля", "ПеревозчикПартнер");
	НовыеНастройки.Вставить("ДоставкаДоПеревозчикаИмяПоля", "ДоставкаДоПеревозчика");
	НовыеНастройки.Вставить("ДоставкаДоПеревозчикаБезусловный", Ложь);
	НовыеНастройки.Вставить("ТочкаДоставкиПеревозчикаИмяПоля", "ТочкаДоставкиПеревозчика");
	НовыеНастройки.Вставить("ЗонаДоставкиПеревозчикаИмяПоля", "ЗонаДоставкиПеревозчика");
	
	НовыеНастройки.Вставить("АдресДоставкиИмяПоля", "АдресДоставки");
	НовыеНастройки.Вставить("ДополнительнаяИнформацияПоДоставкеИмяПоля", "ДополнительнаяИнформацияПоДоставке");
	НовыеНастройки.Вставить("ОсобыеУсловияПеревозкиИмяПоля", "ОсобыеУсловияПеревозки");
	НовыеНастройки.Вставить("ОсобыеУсловияПеревозкиОписаниеИмяПоля", "ОсобыеУсловияПеревозкиОписание");
	
	НовыеНастройки.Вставить("ТоварыКДоставкеИмяТаблицы", "ТоварыКДоставке");
	НовыеНастройки.Вставить("ТаблицаТоваровДоставки", НоваяТаблицаТоваровДоставки());
	
	// Данные для доставки 2.0
	НовыеНастройки.Вставить("НакладнаяПоЗаказам", Ложь);
	
	Возврат НовыеНастройки;
	
КонецФункции

// Выполняет проверку корректности заполнения данных доставки по переданным настройкам
//
// Параметры:
//  Настройки - см. НовыеНастройкиПроверкиИспользованияРеквизитовДоставки
//  МассивНепроверяемыхРеквизитов - Массив из Строка - Массив имен непроверяемых реквизитов для дозаполнения
//  Отказ - Булево - 
//
Процедура ПроверитьЗаполнениеДанныхДоставки(Настройки, МассивНепроверяемыхРеквизитов, Отказ) Экспорт
	
	Если ДоставкаТоваровКлиентСервер.ИспользуетсяДоставка20() Тогда 
		
		ПроверитьЗаполнениеРеквизитовДоставки(
			Настройки.ДокументОбъект,
			МассивНепроверяемыхРеквизитов,
			Отказ,
			Настройки.НакладнаяПоЗаказам);
		
		Возврат;
		
	КонецЕсли;
	
	// Для совместимости с Доставка 2.0 требуется сохранить платформенную проверку,
	// а для Доставки 2.5 используется другой алгоритм
	МассивНепроверяемыхРеквизитов.Добавить(Настройки.ПеревозчикИмяПоля);
	МассивНепроверяемыхРеквизитов.Добавить(Настройки.ОсобыеУсловияПеревозкиОписаниеИмяПоля);
	
	Если Не ДоставкаТоваровКлиентСервер.ИспользуетсяДоставка() Тогда
		
		МассивНепроверяемыхРеквизитов.Добавить(Настройки.АдресДоставкиИмяПоля);
		Возврат;
		
	КонецЕсли;
	
	Объект = Настройки.ДокументОбъект; // ДокументОбъект
	
	Если Настройки.ТребуетсяДоставка Тогда
		
		Если ПустаяСтрока(Настройки.ВидПланированияДоставкиИмяПоля) Тогда
			ВидПланированияДоставки = Настройки.ВидПланированияДоставкиБезусловный;
		Иначе
			ВидПланированияДоставки = Объект[Настройки.ВидПланированияДоставкиИмяПоля]; // ПеречислениеСсылка.ВидыПланированияДоставки
		КонецЕсли;
		
		Если ПустаяСтрока(Настройки.СпособУказанияДоставкиИмяПоля) Тогда
			СпособУказанияДоставки = Настройки.СпособУказанияДоставкиБезусловный;
		Иначе
			СпособУказанияДоставки = Объект[Настройки.СпособУказанияДоставкиИмяПоля]; // ПеречислениеСсылка.СпособыУказанияДоставки
		КонецЕсли;
		
		Если СпособУказанияДоставки = Перечисления.СпособыУказанияДоставки.НаВесьДокумент Тогда
			
			МассивНепроверяемыхРеквизитов.Добавить(Настройки.АдресДоставкиИмяПоля);
			
		КонецЕсли;
		
		Если СпособУказанияДоставки = Перечисления.СпособыУказанияДоставки.НаВесьДокумент Тогда
			
			Если ПустаяСтрока(Настройки.СпособДоставкиИмяПоля) Тогда
				СпособДоставки = Настройки.СпособДоставкиБезусловный;
			Иначе
				СпособДоставки = Объект[Настройки.СпособДоставкиИмяПоля]; // ПеречислениеСсылка.СпособыДоставки25
			КонецЕсли;
			
			Если СпособДоставки.Пустая() Тогда
				
				ТекстОшибки = ОбщегоНазначенияКлиентСервер.ТекстОшибкиЗаполнения(,, НСтр("ru = 'Способ доставки'"));
				ОбщегоНазначения.СообщитьПользователю(
					ТекстОшибки,
					Объект,
					"ТребуетсяДоставка",
					,
					Отказ);
				
				КонецЕсли;
				
		КонецЕсли;
		
		Если ВидПланированияДоставки = Перечисления.ВидыПланированияДоставки.ОтдельнымДокументом Тогда
			
			ПроверитьОбновитьДанныеТочкиЗоныДоставки(СпособУказанияДоставки, Настройки, Ложь, Истина, Истина, Отказ);
			ОтключитьПроверкуЗаполненияОбязательныхПолейДанныхДоставки(МассивНепроверяемыхРеквизитов, Настройки);
			
		Иначе
			
			ПроверитьОбновитьДанныеПолейДоставки(Настройки, Отказ, Истина);
			
		КонецЕсли;
		
		// Прочие сведения проверяются всегда, независимо от вида планирования доставки
		ПроверитьОбновитьСведенияДанныхДоставкиПоСкладам(Настройки, Отказ);
		ПроверитьПересечениеКлиентаИПеревозчика(Настройки, СпособУказанияДоставки, Отказ);
		
	Иначе
		
		ОтключитьПроверкуЗаполненияОбязательныхПолейДанныхДоставки(МассивНепроверяемыхРеквизитов, Настройки);
		
	КонецЕсли;
	
КонецПроцедуры

// Выполняет проверку корректности заполнения данных доставки по переданным настройкам
//
// Параметры:
//  Настройки - см. НовыеНастройкиПроверкиИспользованияРеквизитовДоставки
//  Отказ - Булево - 
//
Процедура ОчиститьНеиспользуемыеПоляДоставки(Настройки, Отказ) Экспорт
	
	Если ДоставкаТоваровКлиентСервер.ИспользуетсяДоставка20() Тогда
		Возврат;
	КонецЕсли;
	
	СкладыСведенияДоставкиИмяТаблицы = "СкладыСведенияДоставки";
	
	Объект = Настройки.ДокументОбъект; // ДокументОбъект
	
	Если Настройки.ТребуетсяДоставка Тогда
		
		Если ПустаяСтрока(Настройки.СпособУказанияДоставкиИмяПоля) Тогда
			СпособУказанияДоставки = Настройки.СпособУказанияДоставкиБезусловный;
		Иначе
			СпособУказанияДоставки = Объект[Настройки.СпособУказанияДоставкиИмяПоля]; // ПеречислениеСсылка.СпособыУказанияДоставки
		КонецЕсли;
		
		Если ПустаяСтрока(Настройки.СпособДоставкиИмяПоля) Тогда
			СпособДоставки = Настройки.СпособДоставкиБезусловный;
		Иначе
			СпособДоставки = Объект[Настройки.СпособДоставкиИмяПоля]; // ПеречислениеСсылка.СпособыДоставки25
		КонецЕсли;
		
		#Область Перевозчик
		Если ПустаяСтрока(Настройки.ДоставкаДоПеревозчикаИмяПоля) Тогда
			ДоставкаДоПеревозчика = Настройки.ДоставкаДоПеревозчикаБезусловный;
		Иначе
			ДоставкаДоПеревозчика = Объект[Настройки.ДоставкаДоПеревозчикаИмяПоля]; // Булево
		КонецЕсли;
		
		Если (СпособДоставки = Перечисления.СпособыДоставки25.НашимиСилами
				И НЕ ДоставкаДоПеревозчика)
			ИЛИ СпособДоставки = Перечисления.СпособыДоставки25.НашКурьер
			ИЛИ СпособДоставки = Перечисления.СпособыДоставки25.Самовывоз
			ИЛИ СпособДоставки = Перечисления.СпособыДоставки25.ОпределяетСлужбаДоставки
			ИЛИ СпособУказанияДоставки = Перечисления.СпособыУказанияДоставки.ПоСтрокам Тогда
			
			Если НЕ ПустаяСтрока(Настройки.ПеревозчикИмяПоля) Тогда
				Объект[Настройки.ПеревозчикИмяПоля] = Справочники.Партнеры.ПустаяСсылка();
			КонецЕсли;
			
			Если НЕ ПустаяСтрока(Настройки.ТочкаДоставкиПеревозчикаИмяПоля) Тогда
				Объект[Настройки.ТочкаДоставкиПеревозчикаИмяПоля] = Справочники.ТочкиДоставки.ПустаяСсылка();
			КонецЕсли;
			
			Если НЕ ПустаяСтрока(Настройки.ЗонаДоставкиПеревозчикаИмяПоля) Тогда
				Объект[Настройки.ЗонаДоставкиПеревозчикаИмяПоля] = Справочники.ЗоныДоставки.ПустаяСсылка();
			КонецЕсли;
			
		КонецЕсли;
		#КонецОбласти
		
		Если НЕ ПустаяСтрока(Настройки.ОсобыеУсловияПеревозкиИмяПоля)
			И НЕ Объект[Настройки.ОсобыеУсловияПеревозкиИмяПоля] Тогда
			
			Если НЕ ПустаяСтрока(Настройки.ОсобыеУсловияПеревозкиОписаниеИмяПоля) Тогда
				Объект[Настройки.ОсобыеУсловияПеревозкиОписаниеИмяПоля] = "";
			КонецЕсли;
			
		КонецЕсли;
		
		Если СпособУказанияДоставки = Перечисления.СпособыУказанияДоставки.НаВесьДокумент
			И НЕ ПустаяСтрока(Настройки.ТоварыКДоставкеИмяТаблицы) Тогда
			
			// Данные внутри таблицы обрабатываются в рамках метода проверки/обновления полей
			ТаблицаТоварыКДоставке = Объект[Настройки.ТоварыКДоставкеИмяТаблицы]; // ТабличнаяЧасть
			ТаблицаТоварыКДоставке.Очистить();
			
		КонецЕсли;
		
	Иначе
		
		Если НЕ ПустаяСтрока(Настройки.ВидПланированияДоставкиИмяПоля) Тогда
			Объект[Настройки.ВидПланированияДоставкиИмяПоля] = Перечисления.ВидыПланированияДоставки.ПустаяСсылка();
		КонецЕсли;
		
		Если НЕ ПустаяСтрока(Настройки.СпособУказанияДоставкиИмяПоля) Тогда
			Объект[Настройки.СпособУказанияДоставкиИмяПоля] = Перечисления.СпособыУказанияДоставки.ПустаяСсылка();
		КонецЕсли;
		
		Если НЕ ПустаяСтрока(Настройки.СпособДоставкиИмяПоля) Тогда
			Объект[Настройки.СпособДоставкиИмяПоля] = Перечисления.СпособыДоставки25.ПустаяСсылка();
		КонецЕсли;
		
		Если НЕ ПустаяСтрока(Настройки.ВремяДоставкиСИмяПоля) Тогда
			Объект[Настройки.ВремяДоставкиСИмяПоля] = Дата(1, 1, 1, 0, 0, 0);
		КонецЕсли;
		
		Если НЕ ПустаяСтрока(Настройки.ВремяДоставкиПоИмяПоля) Тогда
			Объект[Настройки.ВремяДоставкиПоИмяПоля] = Дата(1, 1, 1, 0, 0, 0);
		КонецЕсли;
		
		Если НЕ ПустаяСтрока(Настройки.ТочкаДоставкиИмяПоля) Тогда
			Объект[Настройки.ТочкаДоставкиИмяПоля] = Справочники.ТочкиДоставки.ПустаяСсылка();
		КонецЕсли;
		
		Если НЕ ПустаяСтрока(Настройки.ЗонаДоставкиИмяПоля) Тогда
			Объект[Настройки.ЗонаДоставкиИмяПоля] = Справочники.ЗоныДоставки.ПустаяСсылка();
		КонецЕсли;
		
		#Область Перевозчик
		Если НЕ ПустаяСтрока(Настройки.ПеревозчикИмяПоля) Тогда
			Объект[Настройки.ПеревозчикИмяПоля] = Справочники.Партнеры.ПустаяСсылка();
		КонецЕсли;
		
		Если НЕ ПустаяСтрока(Настройки.ДоставкаДоПеревозчикаИмяПоля) Тогда
			Объект[Настройки.ДоставкаДоПеревозчикаИмяПоля] = Ложь;
		КонецЕсли;
		
		Если НЕ ПустаяСтрока(Настройки.ТочкаДоставкиПеревозчикаИмяПоля) Тогда
			Объект[Настройки.ТочкаДоставкиПеревозчикаИмяПоля] = Справочники.ТочкиДоставки.ПустаяСсылка();
		КонецЕсли;
		
		Если НЕ ПустаяСтрока(Настройки.ЗонаДоставкиПеревозчикаИмяПоля) Тогда
			Объект[Настройки.ЗонаДоставкиПеревозчикаИмяПоля] = Справочники.ЗоныДоставки.ПустаяСсылка();
		КонецЕсли;
		#КонецОбласти
		
		Если НЕ ПустаяСтрока(Настройки.ДополнительнаяИнформацияПоДоставкеИмяПоля) Тогда
			Объект[Настройки.ДополнительнаяИнформацияПоДоставкеИмяПоля] = "";
		КонецЕсли;
		
		Если НЕ ПустаяСтрока(Настройки.ОсобыеУсловияПеревозкиИмяПоля) Тогда
			Объект[Настройки.ОсобыеУсловияПеревозкиИмяПоля] = Ложь;
		КонецЕсли;
		
		Если НЕ ПустаяСтрока(Настройки.ОсобыеУсловияПеревозкиОписаниеИмяПоля) Тогда
			Объект[Настройки.ОсобыеУсловияПеревозкиОписаниеИмяПоля] = "";
		КонецЕсли;
		
		Если НЕ ПустаяСтрока(Настройки.ТоварыКДоставкеИмяТаблицы) Тогда
			
			ТаблицаТоварыКДоставке = Объект[Настройки.ТоварыКДоставкеИмяТаблицы]; // ТабличнаяЧасть
			ТаблицаТоварыКДоставке.Очистить();
			
		КонецЕсли;
		
		ТаблицаСкладыСведенияДоставки = Объект[СкладыСведенияДоставкиИмяТаблицы]; // ТабличнаяЧасть
		ТаблицаСкладыСведенияДоставки.Очистить();
		
	КонецЕсли;
	
КонецПроцедуры

// Выполняет обновление сведений точек доставки (если не заполнены их данные)
//
// Параметры:
//  Настройки - см. НовыеНастройкиПроверкиИспользованияРеквизитовДоставки
