Функция ТекстЗапросаПервичныеНазначенияДоставкиДляМерных()
	
	ТекстЗапроса =
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ИзмененияМерныхТоваров.Распоряжение КАК Распоряжение,
	|	ВЫБОР
	|		КОГДА ИзмененияМерныхТоваров.ДокументПланирования ССЫЛКА Документ.ЗаказНаДоставку
	|			ТОГДА НЕОПРЕДЕЛЕНО
	|		ИНАЧЕ ИзмененияМерныхТоваров.ДокументПланирования
	|	КОНЕЦ КАК ДокументПланирования,
	|	ИзмененияМерныхТоваров.Номенклатура КАК Номенклатура,
	|	ИзмененияМерныхТоваров.Характеристика КАК Характеристика,
	|	ИзмененияМерныхТоваров.Серия КАК Серия,
	|	ИзмененияМерныхТоваров.КодСтроки КАК КодСтроки,
	|	ЕСТЬNULL(ДоставкаПоДокументуПланирования.Назначение, ДоставкаБезДокументаПланирования.Назначение) КАК Назначение
	|ПОМЕСТИТЬ ВТ_ПервичныеНазначенияДоставкиДляМерных
	|ИЗ
	|	(ВЫБРАТЬ РАЗЛИЧНЫЕ
	|		ДвиженияДоставкаИзменение.Распоряжение КАК Распоряжение,
	|		ДвиженияДоставкаИзменение.ДокументПланирования КАК ДокументПланирования,
	|		ДвиженияДоставкаИзменение.Номенклатура КАК Номенклатура,
	|		ДвиженияДоставкаИзменение.Характеристика КАК Характеристика,
	|		ДвиженияДоставкаИзменение.Серия КАК Серия,
	|		ДвиженияДоставкаИзменение.КодСтроки КАК КодСтроки
	|	ИЗ
	|		ДвиженияДоставкаИзменение КАК ДвиженияДоставкаИзменение
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК СправочникНоменклатура
	|			ПО ДвиженияДоставкаИзменение.Номенклатура = СправочникНоменклатура.Ссылка
	|	ГДЕ
	|		СправочникНоменклатура.ЕдиницаИзмерения.ТипИзмеряемойВеличины В(&МерныеТипыЕдиницИзмерений)) КАК ИзмененияМерныхТоваров
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.Доставка КАК ДоставкаПоДокументуПланирования
	|		ПО ИзмененияМерныхТоваров.Распоряжение = ДоставкаПоДокументуПланирования.Распоряжение
	|			И ИзмененияМерныхТоваров.КодСтроки = ДоставкаПоДокументуПланирования.КодСтроки
	|			И (НЕ ИзмененияМерныхТоваров.ДокументПланирования ССЫЛКА Документ.ЗаказНаДоставку)
	|			И ИзмененияМерныхТоваров.ДокументПланирования = ДоставкаПоДокументуПланирования.ДокументПланирования
	|			И (ДоставкаПоДокументуПланирования.ПервичнаяЗапись = ИСТИНА)
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.Доставка КАК ДоставкаБезДокументаПланирования
	|		ПО ИзмененияМерныхТоваров.Распоряжение = ДоставкаБезДокументаПланирования.Распоряжение
	|			И ИзмененияМерныхТоваров.КодСтроки = ДоставкаБезДокументаПланирования.КодСтроки
	|			И (ИзмененияМерныхТоваров.ДокументПланирования ССЫЛКА Документ.ЗаказНаДоставку)
	|			И (ДоставкаБезДокументаПланирования.ДокументПланирования = НЕОПРЕДЕЛЕНО)
	|			И (ДоставкаБезДокументаПланирования.ПервичнаяЗапись = ИСТИНА)
	|ГДЕ
	|	(ДоставкаПоДокументуПланирования.Назначение ЕСТЬ НЕ NULL 
	|			ИЛИ ДоставкаБезДокументаПланирования.Назначение ЕСТЬ НЕ NULL )";
	
	Возврат ТекстЗапроса;
	
КонецФункции

Функция ТекстЗапросаДопустимыеОтклоненияКРейсу()
	
	ТекстЗапроса =
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ТоварыКОтгрузкеОбороты.ДокументОтгрузки КАК Распоряжение,
	|	ТоварыКОтгрузкеОбороты.Номенклатура КАК Номенклатура,
	|	ТоварыКОтгрузкеОбороты.Характеристика КАК Характеристика,
	|	ТоварыКОтгрузкеОбороты.Серия КАК Серия,
	|	ТоварыКОтгрузкеОбороты.Назначение КАК Назначение,
	|	ТоварыКОтгрузкеОбороты.КОтгрузкеПриход КАК КОтгрузкеПриход,
	|	ВЫРАЗИТЬ(ТоварыКОтгрузкеОбороты.КОтгрузкеПриход * &ДопустимоеОтклонениеОтгрузкиПриемкиМерныхТоваров / 100 КАК ЧИСЛО(15, 3)) КАК ДопустимоеОтклонение
	|ПОМЕСТИТЬ ВТ_ДопустимыеОтклоненияКРейсу
	|ИЗ
	|	РегистрНакопления.ТоварыКОтгрузке.Обороты(
	|			,
	|			,
	|			,
	|			(ДокументОтгрузки, Номенклатура, Характеристика, Назначение, Серия) В
	|					(ВЫБРАТЬ
	|						ПервичныеНазначенияДоставки.Распоряжение,
	|						ПервичныеНазначенияДоставки.Номенклатура,
	|						ПервичныеНазначенияДоставки.Характеристика,
	|						ПервичныеНазначенияДоставки.Назначение,
	|						ПервичныеНазначенияДоставки.Серия
	|					ИЗ
	|						ВТ_ПервичныеНазначенияДоставкиДляМерных КАК ПервичныеНазначенияДоставки)) КАК ТоварыКОтгрузкеОбороты
	|";
	
	Возврат ТекстЗапроса;
	
КонецФункции

Функция ТекстЗапросаКонтроляДоставки(ПроверяемоеВыражение, УчитыватьДокументыПланирования, ВыражениеДопустимоеОтклонение, КонтролироватьОтклонениеМерныхТоваров)
	
	ТекстЗапроса =
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ДоставкаОбороты.Организация КАК Организация,
	|	ДоставкаОбороты.ТипДоставки КАК ТипДоставки,
	|	ДоставкаОбороты.ДатаОтгрузки КАК ДатаОтгрузки,
	|	ДоставкаОбороты.СпособДоставки КАК СпособДоставки,
	|	ДоставкаОбороты.Отправитель КАК Отправитель,
	|	ДоставкаОбороты.ТочкаОтправителя КАК ТочкаОтправителя,
	|	ДоставкаОбороты.ЗонаОтправителя КАК ЗонаОтправителя,
	|	ДоставкаОбороты.Получатель КАК Получатель,
	|	ДоставкаОбороты.ТочкаПолучателя КАК ТочкаПолучателя,
	|	ДоставкаОбороты.ЗонаПолучателя КАК ЗонаПолучателя,
	|	ДоставкаОбороты.Распоряжение КАК Распоряжение,
	|	&ПолеДокументПланирования КАК ДокументПланирования,
	|	ДоставкаОбороты.Номенклатура КАК Номенклатура,
	|	ДоставкаОбороты.Характеристика КАК Характеристика,
	|	ДоставкаОбороты.Серия КАК Серия,
	|	ДоставкаОбороты.КодСтроки КАК КодСтроки,
	|	ДоставкаОбороты.Плечо КАК Плечо,
	|	ДоставкаОбороты.Перевозчик КАК Перевозчик,
	|	-1 * (&ПроверяемоеВыражение) КАК Превышение,
	|	ДоставкаОбороты.Номенклатура.ЕдиницаИзмерения КАК ЕдиницаИзмерения
	|ИЗ
	|	РегистрНакопления.Доставка.Обороты(
	|			,
	|			,
	|			,
	|			(Организация, ТипДоставки, ДатаОтгрузки, СпособДоставки,
	|			Отправитель, ТочкаОтправителя, ЗонаОтправителя,
	|			Получатель, ТочкаПолучателя, ЗонаПолучателя,
	|			&ОтборОборотыДокументПланирования, Распоряжение,
	|			Номенклатура, Характеристика, Серия, КодСтроки, Плечо, Перевозчик) В
	|				(ВЫБРАТЬ
	|					Таблица.Организация КАК Организация,
	|					Таблица.ТипДоставки КАК ТипДоставки,
	|					Таблица.ДатаОтгрузки КАК ДатаОтгрузки,
	|					Таблица.СпособДоставки КАК СпособДоставки,
	|					Таблица.Отправитель КАК Отправитель,
	|					Таблица.ТочкаОтправителя КАК ТочкаОтправителя,
	|					Таблица.ЗонаОтправителя КАК ЗонаОтправителя,
	|					Таблица.Получатель КАК Получатель,
	|					Таблица.ТочкаПолучателя КАК ТочкаПолучателя,
	|					Таблица.ЗонаПолучателя КАК ЗонаПолучателя,
	|					&ОтборИзменениеДокументПланирования КАК ДокументПланирования,
	|					Таблица.Распоряжение КАК Распоряжение,
	|					Таблица.Номенклатура КАК Номенклатура,
	|					Таблица.Характеристика КАК Характеристика,
	|					Таблица.Серия КАК Серия,
	|					Таблица.КодСтроки КАК КодСтроки,
	|					Таблица.Плечо КАК Плечо,
	|					Таблица.Перевозчик КАК Перевозчик
	|				ИЗ
	|					ДвиженияДоставкаИзменение КАК Таблица)) КАК ДоставкаОбороты
	|		ЛЕВОЕ СОЕДИНЕНИЕ &ДопустимыеОтклоненияОстатковДоставки КАК ДопустимыеОтклоненияОстатковДоставки ПО ИСТИНА
	|ГДЕ
	|	&ПроверяемоеВыражение + &ВыражениеДопустимоеОтклонение < 0";
	
	Если УчитыватьДокументыПланирования Тогда
		
		ПолеДокументПланирования = "ДоставкаОбороты.ДокументПланирования";
		ОтборОборотыДокументПланирования = "ДокументПланирования";
		ОтборИзменениеДокументПланирования = "Таблица.ДокументПланирования";
		
	Иначе
		
		ПолеДокументПланирования = "НЕОПРЕДЕЛЕНО";
		ОтборОборотыДокументПланирования = "НЕОПРЕДЕЛЕНО";
		ОтборИзменениеДокументПланирования = "НЕОПРЕДЕЛЕНО";
		
	КонецЕсли;
	
	Если КонтролироватьОтклонениеМерныхТоваров
	   И УчитыватьДокументыПланирования Тогда
		
		СоединениеДопустимыеОтклонения =
		"ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ПервичныеНазначенияДоставкиДляМерных КАК ПервичныеНазначенияДоставкиПоДокументуПланирования
		|ПО ДоставкаОбороты.Распоряжение = ПервичныеНазначенияДоставкиПоДокументуПланирования.Распоряжение
		|	И ДоставкаОбороты.Номенклатура = ПервичныеНазначенияДоставкиПоДокументуПланирования.Номенклатура
		|	И ДоставкаОбороты.Характеристика = ПервичныеНазначенияДоставкиПоДокументуПланирования.Характеристика
		|	И ДоставкаОбороты.Серия = ПервичныеНазначенияДоставкиПоДокументуПланирования.Серия
		|	И ДоставкаОбороты.КодСтроки = ПервичныеНазначенияДоставкиПоДокументуПланирования.КодСтроки
		|	И (НЕ ДоставкаОбороты.ДокументПланирования ССЫЛКА Документ.ЗаказНаДоставку)
		|	И ДоставкаОбороты.ДокументПланирования = ПервичныеНазначенияДоставкиПоДокументуПланирования.ДокументПланирования
		|ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ПервичныеНазначенияДоставкиДляМерных КАК ПервичныеНазначенияДоставкиБезДокументаПланирования
		|ПО ДоставкаОбороты.Распоряжение = ПервичныеНазначенияДоставкиБезДокументаПланирования.Распоряжение
		|	И ДоставкаОбороты.Номенклатура = ПервичныеНазначенияДоставкиБезДокументаПланирования.Номенклатура
		|	И ДоставкаОбороты.Характеристика = ПервичныеНазначенияДоставкиБезДокументаПланирования.Характеристика
		|	И ДоставкаОбороты.Серия = ПервичныеНазначенияДоставкиБезДокументаПланирования.Серия
		|	И ДоставкаОбороты.КодСтроки = ПервичныеНазначенияДоставкиБезДокументаПланирования.КодСтроки
		|	И ДоставкаОбороты.ДокументПланирования ССЫЛКА Документ.ЗаказНаДоставку
		|	И ПервичныеНазначенияДоставкиБезДокументаПланирования.ДокументПланирования = НЕОПРЕДЕЛЕНО
		|ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ДопустимыеОтклоненияКРейсу КАК ДопустимыеОтклоненияОстатковДоставки
		|ПО ДоставкаОбороты.Распоряжение = ДопустимыеОтклоненияОстатковДоставки.Распоряжение
		|	И ДоставкаОбороты.Номенклатура = ДопустимыеОтклоненияОстатковДоставки.Номенклатура
		|	И ДоставкаОбороты.Характеристика = ДопустимыеОтклоненияОстатковДоставки.Характеристика
		|	И ДоставкаОбороты.Серия = ДопустимыеОтклоненияОстатковДоставки.Серия
		|	И ЕСТЬNULL(ПервичныеНазначенияДоставкиПоДокументуПланирования.Назначение, ПервичныеНазначенияДоставкиБезДокументаПланирования.Назначение) = ДопустимыеОтклоненияОстатковДоставки.Назначение";
		
	ИначеЕсли КонтролироватьОтклонениеМерныхТоваров Тогда
		
		СоединениеДопустимыеОтклонения =
		"ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ПервичныеНазначенияДоставкиДляМерных КАК ПервичныеНазначенияДоставки
		|ПО ДоставкаОбороты.Распоряжение = ПервичныеНазначенияДоставки.Распоряжение
		|	И ДоставкаОбороты.Номенклатура = ПервичныеНазначенияДоставки.Номенклатура
		|	И ДоставкаОбороты.Характеристика = ПервичныеНазначенияДоставки.Характеристика
		|	И ДоставкаОбороты.Серия = ПервичныеНазначенияДоставки.Серия
		|	И ДоставкаОбороты.КодСтроки = ПервичныеНазначенияДоставки.КодСтроки
		|ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ДопустимыеОтклоненияКРейсу КАК ДопустимыеОтклоненияОстатковДоставки
		|ПО ПервичныеНазначенияДоставки.Распоряжение = ДопустимыеОтклоненияОстатковДоставки.Распоряжение
		|	И ПервичныеНазначенияДоставки.Номенклатура = ДопустимыеОтклоненияОстатковДоставки.Номенклатура
		|	И ПервичныеНазначенияДоставки.Характеристика = ДопустимыеОтклоненияОстатковДоставки.Характеристика
		|	И ПервичныеНазначенияДоставки.Серия = ДопустимыеОтклоненияОстатковДоставки.Серия
		|	И ПервичныеНазначенияДоставки.Назначение = ДопустимыеОтклоненияОстатковДоставки.Назначение";
		
	Иначе
		
		СоединениеДопустимыеОтклонения = "";
		
	КонецЕсли;
	
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&ПолеДокументПланирования", ПолеДокументПланирования);
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&ОтборОборотыДокументПланирования", ОтборОборотыДокументПланирования);
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&ОтборИзменениеДокументПланирования", ОтборИзменениеДокументПланирования);
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&ПроверяемоеВыражение", ПроверяемоеВыражение);
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&ВыражениеДопустимоеОтклонение", ВыражениеДопустимоеОтклонение);
	
	ТекстЗапроса = СтрЗаменить(
		ТекстЗапроса,
		"ЛЕВОЕ СОЕДИНЕНИЕ &ДопустимыеОтклоненияОстатковДоставки КАК ДопустимыеОтклоненияОстатковДоставки ПО ИСТИНА",
		СоединениеДопустимыеОтклонения);
	
	Возврат ТекстЗапроса;
	
КонецФункции

Функция ТекстЗапросаКонтроляПараметрыСклада()
	
	ТекстЗапроса =
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Склады.Ссылка КАК Склад
	|ПОМЕСТИТЬ ВТ_Склады
	|ИЗ
	|	Справочник.Склады КАК Склады
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ДвиженияДоставкаИзменение КАК ДвиженияДоставкаИзменение
	|		ПО Склады.Ссылка = ДвиженияДоставкаИзменение.Отправитель
	|			И Склады.ИспользоватьОрдернуюСхемуПриОтгрузке
	|			И Склады.НачинатьОтгрузкуПослеФормированияЗаданияНаПеревозку";
	
	Возврат ТекстЗапроса;
	
КонецФункции

Функция ТекстЗапросаДопустимыеОтклоненияКСборке()
	
	ТекстЗапроса =
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ТоварыКОтгрузкеОбороты.ДокументОтгрузки КАК Распоряжение,
	|	ТоварыКОтгрузкеОбороты.Номенклатура КАК Номенклатура,
	|	ТоварыКОтгрузкеОбороты.Характеристика КАК Характеристика,
	|	ТоварыКОтгрузкеОбороты.Серия КАК Серия,
	|	ТоварыКОтгрузкеОбороты.Назначение КАК Назначение,
	|	ТоварыКОтгрузкеОбороты.КОтгрузкеПриход КАК КОтгрузкеПриход,
	|	ВЫРАЗИТЬ(ТоварыКОтгрузкеОбороты.КОтгрузкеПриход * &ДопустимоеОтклонениеОтгрузкиПриемкиМерныхТоваров / 100 КАК ЧИСЛО(15, 3)) КАК ДопустимоеОтклонение
	|ПОМЕСТИТЬ ВТ_ДопустимыеОтклоненияКСборке
	|ИЗ
	|	РегистрНакопления.ТоварыКОтгрузке.Обороты(
	|			,
	|			,
	|			,
	|			(ДокументОтгрузки, Номенклатура, Характеристика, Назначение, Серия) В
	|					(ВЫБРАТЬ
	|						Таблица.Распоряжение,
	|						Таблица.Номенклатура,
	|						Таблица.Характеристика,
	|						Таблица.Назначение,
	|						Таблица.Серия
	|					ИЗ
	|						ВТ_ПервичныеЗаписиДоставки КАК Таблица)
	|			И Номенклатура.ЕдиницаИзмерения.ТипИзмеряемойВеличины В (&МерныеТипыЕдиницИзмерений)) КАК ТоварыКОтгрузкеОбороты
	|";
	
	Возврат ТекстЗапроса;
	
КонецФункции

Функция ТекстЗапросаПервичныеЗаписиДоставки()
	
	ТекстЗапроса =
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Доставка.Распоряжение КАК Распоряжение,
	|	Доставка.ДокументПланирования КАК ДокументПланирования,
	|	Доставка.Номенклатура КАК Номенклатура,
	|	Доставка.Характеристика КАК Характеристика,
	|	Доставка.Серия КАК Серия,
	|	Доставка.КодСтроки КАК КодСтроки,
	|	ДвиженияДоставкаИзменение.Рейс КАК Рейс,
	|	Доставка.Назначение КАК Назначение
	|ПОМЕСТИТЬ ВТ_ПервичныеЗаписиДоставки
	|ИЗ
	|	ДвиженияДоставкаИзменение КАК ДвиженияДоставкаИзменение
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_Склады КАК Склады
	|		ПО ДвиженияДоставкаИзменение.Отправитель = Склады.Склад
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрНакопления.Доставка КАК Доставка
	|		ПО ДвиженияДоставкаИзменение.Распоряжение = Доставка.Распоряжение
	|			И ДвиженияДоставкаИзменение.Номенклатура = Доставка.Номенклатура
	|			И ДвиженияДоставкаИзменение.Характеристика = Доставка.Характеристика
	|			И ДвиженияДоставкаИзменение.Серия = Доставка.Серия
	|			И Доставка.ПервичнаяЗапись = ИСТИНА
