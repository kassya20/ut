Функция ШаблонЗапросаДоставка()
	
	ТекстыШаблонов = Новый Массив; // Массив Из Строка
	
	// Сторно по сравнению с предыдущим уровнем планирования доставки
	
	ТаблицаИсточник = "ВТСравнениеТекущегоУровняСПредыдущим";
	
	Шаблон = ШаблонЗапросаСторноТ1ПоДокументуПланирования();
	Шаблон = СтрЗаменить(Шаблон, "&ТаблицаИсточник", ТаблицаИсточник);
	ТекстыШаблонов.Добавить(Шаблон);
	
	Шаблон = ШаблонЗапросаСторноТ1БезДокументаПланирования();
	Шаблон = СтрЗаменить(Шаблон, "&ТаблицаИсточник", ТаблицаИсточник);
	ТекстыШаблонов.Добавить(Шаблон);
	
	Шаблон = ШаблонЗапросаНовыеПараметрыТ2ПоДокументуПланирования();
	Шаблон = СтрЗаменить(Шаблон, "&ТаблицаИсточник", ТаблицаИсточник);
	ТекстыШаблонов.Добавить(Шаблон);
	
	Шаблон = ШаблонЗапросаНовыеПараметрыТ2БезДокументаПланирования();
	Шаблон = СтрЗаменить(Шаблон, "&ТаблицаИсточник", ТаблицаИсточник);
	ТекстыШаблонов.Добавить(Шаблон);
	
	// Сторно по сравнению со следующим уровнем планирования доставки
	
	ТаблицаИсточник = "ВТСравнениеТекущегоУровняСоСледующим";
	
	Шаблон = ШаблонЗапросаСторноТ1ПоДокументуПланирования();
	Шаблон = СтрЗаменить(Шаблон, "&ТаблицаИсточник", ТаблицаИсточник);
	ТекстыШаблонов.Добавить(Шаблон);
	
	Шаблон = ШаблонЗапросаСторноТ1БезДокументаПланирования();
	Шаблон = СтрЗаменить(Шаблон, "&ТаблицаИсточник", ТаблицаИсточник);
	ТекстыШаблонов.Добавить(Шаблон);
	
	Шаблон = ШаблонЗапросаНовыеПараметрыТ2ПоДокументуПланирования();
	Шаблон = СтрЗаменить(Шаблон, "&ТаблицаИсточник", ТаблицаИсточник);
	ТекстыШаблонов.Добавить(Шаблон);
	
	Шаблон = ШаблонЗапросаНовыеПараметрыТ2БезДокументаПланирования();
	Шаблон = СтрЗаменить(Шаблон, "&ТаблицаИсточник", ТаблицаИсточник);
	ТекстыШаблонов.Добавить(Шаблон);
	
	// Движения текущего регистратора
	
	ДополнитьШаблонАктуальнымиДвижениями(ТекстыШаблонов);
	
	ШаблонЗапросаДоставка = СтрСоединить(ТекстыШаблонов, ОбщегоНазначения.ТекстОбъединитьВсе()) + "
		|
		|УПОРЯДОЧИТЬ ПО
		|	НомерСтроки,
		|	Плечо";
	
	Возврат ШаблонЗапросаДоставка;
	
КонецФункции

Процедура ДополнитьШаблонАктуальнымиДвижениями(ТекстыШаблонов)
	
	ДополнительныеПоляСторно =
	"ЛОЖЬ КАК ЭтоКонечноеПлечо,
	|0 КАК НомерМинимальногоПлеча,
	|ЛОЖЬ КАК ПервичнаяЗапись,
	|ДАТАВРЕМЯ(1, 1, 1) КАК ПервичнаяДатаОтгрузки,
	|ЗНАЧЕНИЕ(Справочник.Назначения.ПустаяСсылка) КАК Назначение";
	
	ПодставитьДополнительныеПоляВШаблоны(ТекстыШаблонов, ДополнительныеПоляСторно);
	
	// Дополнительные поля в шаблоне размещаются между полями Упаковка и КДоставке
	
	ШаблонАктуальныеДвиженияТекущегоРегистратора =
	"ВЫБРАТЬ
	|	&Ссылка КАК Регистратор,
	|	НЕОПРЕДЕЛЕНО КАК СторнируемыйДокументПланирования,
	|	ТаблицаДанных.НомерСтроки КАК НомерСтроки,
	|	ТаблицаДанных.Период КАК Период,
	|	ТаблицаДанных.Организация КАК Организация,
	|	ТаблицаДанных.ТипДоставки КАК ТипДоставки,
	|	ТаблицаДанных.ДатаОтгрузки КАК ДатаОтгрузки,
	|	ТаблицаДанных.СпособДоставки КАК СпособДоставки,
	|	ТаблицаДанных.Перевозчик КАК Перевозчик,
	|	ТаблицаДанных.Отправитель КАК Отправитель,
	|	ТаблицаДанных.ТочкаОтправителя КАК ТочкаОтправителя,
	|	ТаблицаДанных.ЗонаОтправителя КАК ЗонаОтправителя,
	|	ТаблицаДанных.Получатель КАК Получатель,
	|	ТаблицаДанных.ТочкаПолучателя КАК ТочкаПолучателя,
	|	ТаблицаДанных.ЗонаПолучателя КАК ЗонаПолучателя,
	|	ТаблицаДанных.Распоряжение КАК Распоряжение,
	|	ТаблицаДанных.Рейс КАК Рейс,
	|	ТаблицаДанных.Номенклатура КАК Номенклатура,
	|	ТаблицаДанных.Характеристика КАК Характеристика,
	|	ТаблицаДанных.Серия КАК Серия,
	|	ТаблицаДанных.КодСтроки КАК КодСтроки,
	|	ТаблицаДанных.ДокументПланирования КАК ДокументПланирования,
	|	ТаблицаДанных.Плечо КАК Плечо,
	|	ТаблицаДанных.Упаковка КАК Упаковка,
	|	ТаблицаДанных.ЭтоКонечноеПлечо КАК ЭтоКонечноеПлечо,
	|	ТаблицаДанных.НомерМинимальногоПлеча КАК НомерМинимальногоПлеча,
	|	ТаблицаДанных.ПервичнаяЗапись КАК ПервичнаяЗапись,
	|	ТаблицаДанных.ПервичнаяДатаОтгрузки КАК ПервичнаяДатаОтгрузки,
	|	ТаблицаДанных.Назначение КАК Назначение,
	|	ТаблицаДанных.КДоставке КАК КДоставке,
	|	ТаблицаДанных.КРейсу КАК КРейсу,
	|	ТаблицаДанных.ВРейсе КАК ВРейсе,
	|	ТаблицаДанных.ВПути КАК ВПути,
	|	ТаблицаДанных.Доставлено КАК Доставлено,
	|	ТаблицаДанных.Отменено КАК Отменено,
	|	ТаблицаДанных.КСборке КАК КСборке,
