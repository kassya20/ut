Функция ШаблонЗапросаКонтрольИзмененияПолей()
	
	ШаблонЗапроса =
	"ВЫБРАТЬ
	|	КонтрольПолей.Распоряжение КАК Распоряжение,
	|	КонтрольПолей.КодСтроки КАК КодСтроки,
	|	КонтрольПолей.ДокументПланирования КАК ДокументПланирования,
	|	КонтрольПолей.РегистраторТ1 КАК РегистраторТ1,
	|	КонтрольПолей.РегистраторТ2 КАК РегистраторТ2,
	|	МАКСИМУМ(КонтрольПолей.ИзменилсяКонечныйПолучатель) КАК ИзменилсяКонечныйПолучатель,
	|	МАКСИМУМ(КонтрольПолей.ИзменилсяНачальныйОтправитель) КАК ИзменилсяНачальныйОтправитель
	|ПОМЕСТИТЬ ТаблицаНазначение
	|ИЗ
	|	(ВЫБРАТЬ
	|		Т1.Распоряжение КАК Распоряжение,
	|		Т1.КодСтроки КАК КодСтроки,
	|		Т1.ДокументПланирования КАК ДокументПланирования,
	|		Т1.Регистратор КАК РегистраторТ1,
	|		Т2.Регистратор КАК РегистраторТ2,
	|		(Т1.Получатель <> Т2.Получатель) КАК ИзменилсяКонечныйПолучатель,
	|		ЛОЖЬ КАК ИзменилсяНачальныйОтправитель
	|	ИЗ
	|		&ТаблицаИсточникТ1 КАК Т1
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ &ТаблицаИсточникТ2 КАК Т2
	|			ПО Т1.Распоряжение = Т2.Распоряжение
	|				И Т1.КодСтроки = Т2.КодСтроки
	|				И Т1.ДокументПланирования = Т2.ДокументПланирования
	|				И Т1.ЭтоКонечноеПлечо
	|				И Т2.ЭтоКонечноеПлечо
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ
	|		Т2.Распоряжение КАК Распоряжение,
	|		Т2.КодСтроки КАК КодСтроки,
	|		Т2.ДокументПланирования КАК ДокументПланирования,
	|		Т1.Регистратор КАК РегистраторТ1,
	|		Т2.Регистратор КАК РегистраторТ2,
	|		ЛОЖЬ КАК ИзменилсяКонечныйПолучатель,
	|		(Т1.Отправитель <> Т2.Отправитель) КАК ИзменилсяНачальныйОтправитель
	|	ИЗ
	|		&ТаблицаИсточникТ2 КАК Т2
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ &ТаблицаИсточникТ1 КАК Т1
	|			ПО Т2.Распоряжение = Т1.Распоряжение
	|				И Т2.КодСтроки = Т1.КодСтроки
	|				И Т2.ДокументПланирования = Т1.ДокументПланирования
	|				И Т2.НомерМинимальногоПлеча > 0
	|				И Т2.НомерМинимальногоПлеча = Т1.Плечо) КАК КонтрольПолей
	|
	|СГРУППИРОВАТЬ ПО
	|	КонтрольПолей.Распоряжение,
	|	КонтрольПолей.КодСтроки,
	|	КонтрольПолей.ДокументПланирования,
	|	КонтрольПолей.РегистраторТ1,
	|	КонтрольПолей.РегистраторТ2";
	
	Возврат ШаблонЗапроса;
	
КонецФункции

