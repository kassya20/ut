КонецФункции

#Область РаботаСАдресамиДоставки

Функция ТекстЗапросаВладельцевДляСозданияТочекДоставки()
	
	ТекстЗапроса =
	"ВЫБРАТЬ
	|	СкладыКИ.Ссылка КАК Ссылка,
	|	КОЛИЧЕСТВО(*) КАК КоличествоАдресов
	|ПОМЕСТИТЬ ВТ_АдресаВладельцев
	|ИЗ
	|	Справочник.Склады.КонтактнаяИнформация КАК СкладыКИ
	|ГДЕ
	|	НЕ СкладыКИ.Ссылка.ЭтоГруппа
	|	И СкладыКИ.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыКонтактнойИнформации.Адрес)
	|	И ДЛИНАСТРОКИ(СОКРЛП(СкладыКИ.Представление)) > 0
	|СГРУППИРОВАТЬ ПО
	|	СкладыКИ.Ссылка
	|ИМЕЮЩИЕ
	|	КОЛИЧЕСТВО(*) > 0
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ПартнерыКИ.Ссылка КАК Ссылка,
	|	КОЛИЧЕСТВО(*) КАК КоличествоАдресов
	|ИЗ
	|	Справочник.Партнеры.КонтактнаяИнформация КАК ПартнерыКИ
	|ГДЕ
	|	ПартнерыКИ.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыКонтактнойИнформации.Адрес)
	|	И ДЛИНАСТРОКИ(СОКРЛП(ПартнерыКИ.Представление)) > 0
	|СГРУППИРОВАТЬ ПО
	|	ПартнерыКИ.Ссылка
	|ИМЕЮЩИЕ
	|	КОЛИЧЕСТВО(*) > 0
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ ПЕРВЫЕ 100
	|	АдресаВладельцев.Ссылка КАК Ссылка
	|ИЗ
	|	ВТ_АдресаВладельцев КАК АдресаВладельцев
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ТочкиДоставки КАК ТочкиДоставки
	|		ПО АдресаВладельцев.Ссылка = ТочкиДоставки.Владелец
	|ГДЕ
	|	ТочкиДоставки.Ссылка ЕСТЬ NULL
	|
	|УПОРЯДОЧИТЬ ПО
	|	Ссылка";
	
	Возврат ТекстЗапроса;
	
КонецФункции

// Параметры:
//  ВладелецТочкиДоставки - СправочникСсылка.Склады
//                        - СправочникСсылка.Партнеры
//
Процедура СоздатьТочкиДоставкиПоВладельцу(ВладелецТочкиДоставки)
	
	Если Не ОбщегоНазначения.СсылкаСуществует(ВладелецТочкиДоставки) Тогда
		Возврат;
	КонецЕсли;
	
	ПространствоБлокировки = ОбщегоНазначения.ИмяТаблицыПоСсылке(ВладелецТочкиДоставки);
	
	НачатьТранзакцию();
	Попытка
		
		Блокировка = Новый БлокировкаДанных();
		ЭлементБлокировки = Блокировка.Добавить(ПространствоБлокировки);
		ЭлементБлокировки.УстановитьЗначение("Ссылка", ВладелецТочкиДоставки);
		ЭлементБлокировки = Блокировка.Добавить("Справочник.ТочкиДоставки");
		ЭлементБлокировки.УстановитьЗначение("Владелец", ВладелецТочкиДоставки);
		Блокировка.Заблокировать();
		
		ДанныеТочекДоставки = ДанныеТочекДоставкиВладельца(ВладелецТочкиДоставки);
		Для Каждого ДанныеТочки Из ДанныеТочекДоставки Цикл
			
			ОбновитьСоздатьТочкуДоставки(ВладелецТочкиДоставки, ДанныеТочки, Истина);
			
		КонецЦикла;
		
		ЗафиксироватьТранзакцию();
		
	Исключение
		
		ОтменитьТранзакцию();
		
		ПредставлениеОшибки = ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
		ЗаписатьОшибкуСозданияТочекДоставкиВЖурнал(ПредставлениеОшибки, ВладелецТочкиДоставки);
		
	КонецПопытки;
	
КонецПроцедуры

Функция ДанныеТочекДоставкиВладельца(ВладелецТочкиДоставки)
	
	Если ТипЗнч(ВладелецТочкиДоставки) = Тип("СправочникСсылка.Склады") Тогда
		
		ТекстЗапроса = ТекстЗапросаАдресовСклад();
		ВидКИ = Справочники.ВидыКонтактнойИнформации.АдресСклада;
		
	ИначеЕсли ТипЗнч(ВладелецТочкиДоставки) = Тип("СправочникСсылка.Партнеры") Тогда
		
		ТекстЗапроса = ТекстЗапросаАдресовПартнер();
		ВидКИ = Справочники.ВидыКонтактнойИнформации.АдресПартнера;
		
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = ТекстЗапроса;
	Запрос.УстановитьПараметр("Владелец", ВладелецТочкиДоставки);
	Запрос.УстановитьПараметр("ВидКИ", ВидКИ);
	
	ДанныеКИ = Запрос.Выполнить().Выгрузить();
	ДанныеАдресов = ДанныеАдресовПоДаннымКонтактнойИнформации(ДанныеКИ);
	
	Отбор = Новый Структура("Основной", Истина);
	ОсновныеАдреса = ДанныеАдресов.НайтиСтроки(Отбор);
	НесколькоОсновныхАдресов = (ОсновныеАдреса.Количество() > 1);
	
	ДанныеТочекДоставки = НовыеДанныеТочекДоставки();
	
	Для Каждого ДанныеАдреса Из ДанныеАдресов Цикл
		
		ДанныеТочки = ДанныеТочекДоставки.Добавить();
		ДанныеТочки.НесколькоОсновныхАдресов = НесколькоОсновныхАдресов;
		
		Если НесколькоОсновныхАдресов Тогда
			
			ОсновнойАдрес = Ложь;
			
		Иначе
			
			ОсновнойАдрес = ДанныеАдреса.Основной;
			
		КонецЕсли;
		
		Если НЕ ОсновнойАдрес Тогда
			
			ДанныеАдреса.ЗонаДоставки = Справочники.ЗоныДоставки.ПустаяСсылка();
			
		КонецЕсли;
		
		ЗаполнитьДанныеТочкиДоставкиДаннымиАдреса(ДанныеТочки, ДанныеАдреса, ОсновнойАдрес);
		ПроверитьЗаполнитьПредставлениеАдреса(ДанныеТочки);
		
	КонецЦикла;
	
	Возврат ДанныеТочекДоставки;
	
КонецФункции

Процедура ПроверитьЗаполнитьПредставлениеАдреса(ДанныеТочкиДоставки)
	
	Если ПустаяСтрока(ДанныеТочкиДоставки.Адрес) Тогда
		
		Источник = "";
		
		Если НЕ ПустаяСтрока(ДанныеТочкиДоставки.АдресЗначение) Тогда
			
			Источник = ДанныеТочкиДоставки.АдресЗначение;
			
		ИначеЕсли НЕ ПустаяСтрока(ДанныеТочкиДоставки.АдресЗначенияПолей) Тогда
			
			Источник = ДанныеТочкиДоставки.АдресЗначенияПолей;
			
		КонецЕсли;
		
		Если НЕ ПустаяСтрока(Источник) Тогда
			
			ДанныеТочкиДоставки.Адрес = УправлениеКонтактнойИнформацией.ПредставлениеКонтактнойИнформации(Источник);
			
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

Функция ТекстЗапросаАдресовСклад()
	
	ТекстЗапроса =
	"ВЫБРАТЬ
	|	КонтактнаяИнформация.Представление КАК Представление,
	|	КонтактнаяИнформация.Значение КАК Значение,
	|	КонтактнаяИнформация.ЗначенияПолей КАК ЗначенияПолей,
	|	КонтактнаяИнформация.Вид КАК Вид
	|ИЗ
	|	Справочник.Склады.КонтактнаяИнформация КАК КонтактнаяИнформация
	|ГДЕ
	|	КонтактнаяИнформация.Ссылка = &Владелец
	|	И КонтактнаяИнформация.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыКонтактнойИнформации.Адрес)
	|	И СОКРЛП(КонтактнаяИнформация.Представление) <> """"";
	
	Возврат ТекстЗапроса;
	
КонецФункции

Функция ТекстЗапросаАдресовПартнер()
	
	ТекстЗапроса =
	"ВЫБРАТЬ
	|	КонтактнаяИнформация.Представление КАК Представление,
	|	КонтактнаяИнформация.Значение КАК Значение,
	|	КонтактнаяИнформация.ЗначенияПолей КАК ЗначенияПолей,
	|	КонтактнаяИнформация.Ссылка.ЗонаДоставки КАК ЗонаДоставки,
	|	КонтактнаяИнформация.Вид КАК Вид
	|ИЗ
	|	Справочник.Партнеры.КонтактнаяИнформация КАК КонтактнаяИнформация
	|ГДЕ
	|	КонтактнаяИнформация.Ссылка = &Владелец
	|	И КонтактнаяИнформация.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыКонтактнойИнформации.Адрес)
	|	И СОКРЛП(КонтактнаяИнформация.Представление) <> """"";
	
