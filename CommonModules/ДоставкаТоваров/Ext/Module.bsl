	Расписание.ПериодПовтораДней = 1;
	Расписание.ПериодПовтораВТечениеДня = 10;
	
	ПараметрыЗадания.Вставить("Расписание", Расписание);
	
	РегламентныеЗаданияСервер.ДобавитьЗадание(ПараметрыЗадания);
	
КонецПроцедуры

Процедура ОтключитьПроверкуЗаполненияОбязательныхПолейДанныхДоставки(МассивНепроверяемыхРеквизитов, Знач Настройки)
	
	// Сведения о складах проверяются всегда, если требуется доставка
	
	МассивНепроверяемыхРеквизитов.Добавить(Настройки.АдресДоставкиИмяПоля);
	МассивНепроверяемыхРеквизитов.Добавить(Настройки.ПеревозчикИмяПоля);
	МассивНепроверяемыхРеквизитов.Добавить(Настройки.ОсобыеУсловияПеревозкиОписаниеИмяПоля);
	
КонецПроцедуры

// Параметры:
//  Настройки - см. НовыеНастройкиПроверкиИспользованияРеквизитовДоставки
//  Отказ  - Булево
//  ВыводитьОшибкиЗаполнения - Булево - признак необходимости выводить ошибки заполнения
//  ОбновитьДанные - Булево - указывает на необходимость записи обновленных данных в таблицу
//
Процедура ПроверитьОбновитьДанныеПолейДоставки(Настройки, Отказ, ВыводитьОшибкиЗаполнения, ОбновитьДанные = Ложь)
	
	Если ОбновитьДанные Тогда
		ОчиститьНеиспользуемыеПоляДоставки(Настройки, Отказ);
	КонецЕсли;
	
	Объект = Настройки.ДокументОбъект; // ДокументОбъект
	
	Если ПустаяСтрока(Настройки.СпособУказанияДоставкиИмяПоля) Тогда
		СпособУказанияДоставки = Настройки.СпособУказанияДоставкиБезусловный;
	Иначе
		СпособУказанияДоставки = Объект[Настройки.СпособУказанияДоставкиИмяПоля]; // ПеречислениеСсылка.СпособыУказанияДоставки
	КонецЕсли;
	
	Если ПустаяСтрока(Настройки.ВидПланированияДоставкиИмяПоля) Тогда
		ВидПланированияДоставки = Настройки.ВидПланированияДоставкиБезусловный;
	Иначе
		ВидПланированияДоставки = Объект[Настройки.ВидПланированияДоставкиИмяПоля]; // ПеречислениеСсылка.ВидыПланированияДоставки
	КонецЕсли;
	
	ТолькоСброс = (ВидПланированияДоставки = Перечисления.ВидыПланированияДоставки.ОтдельнымДокументом);
	
	ПроверитьОбновитьДанныеПолейДоставкиШапка(СпособУказанияДоставки, Настройки, ОбновитьДанные, ТолькоСброс, ВыводитьОшибкиЗаполнения, Отказ);
	ПроверитьОбновитьДанныеПолейДоставкиТаблица(СпособУказанияДоставки, Настройки, ОбновитьДанные, ТолькоСброс, ВыводитьОшибкиЗаполнения, Отказ);
	
КонецПроцедуры

Процедура ПроверитьОбновитьДанныеПолейДоставкиШапка(Знач СпособУказанияДоставки, Знач Настройки, Знач ОбновитьДанные, Знач ТолькоСброс, Знач ВыводитьОшибкиЗаполнения, Отказ)
	
	Если СпособУказанияДоставки <> Перечисления.СпособыУказанияДоставки.НаВесьДокумент Тогда
		Возврат;
	КонецЕсли;
	
	Объект = Настройки.ДокументОбъект; // ДокументОбъект
	
	ПроверитьОбновитьДанныеТочкиЗоныДоставки(СпособУказанияДоставки, Настройки, ОбновитьДанные, ТолькоСброс, ВыводитьОшибкиЗаполнения, Отказ);
	
	Если ПустаяСтрока(Настройки.СпособДоставкиИмяПоля) Тогда
		СпособДоставки = Настройки.СпособДоставкиБезусловный;
	Иначе
		СпособДоставки = Объект[Настройки.СпособДоставкиИмяПоля]; // ПеречислениеСсылка.СпособыДоставки25
	КонецЕсли;
		
	Если ВыводитьОшибкиЗаполнения Тогда
		
		ПроверитьДанныеПолейДоставкиШапкаСведенияПеревозчика(Настройки, СпособДоставки, Объект, Отказ);
		
		Если НЕ ПустаяСтрока(Настройки.ОсобыеУсловияПеревозкиИмяПоля)
			И Объект[Настройки.ОсобыеУсловияПеревозкиИмяПоля] Тогда
			
			Если НЕ ЗначениеЗаполнено(Объект[Настройки.ОсобыеУсловияПеревозкиОписаниеИмяПоля]) Тогда
				
				ТекстОшибки = ОбщегоНазначенияКлиентСервер.ТекстОшибкиЗаполнения(,, НСтр("ru = 'Описание особых условий перевозки'"));
				ОбщегоНазначения.СообщитьПользователю(
					ТекстОшибки,
					Объект,
					"ТребуетсяДоставка",
					,
					Отказ);
				
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

Процедура ПроверитьОбновитьДанныеТочкиЗоныДоставки(Знач СпособУказанияДоставки, Знач Настройки, Знач ОбновитьДанные, Знач ТолькоСброс, Знач ВыводитьОшибкиЗаполнения, Отказ)
	
	Если СпособУказанияДоставки <> Перечисления.СпособыУказанияДоставки.НаВесьДокумент Тогда
		Возврат;
	КонецЕсли;
	
	Объект = Настройки.ДокументОбъект; // ДокументОбъект
	
	ТочкаДоставки = Объект[Настройки.ТочкаДоставкиИмяПоля]; // СправочникСсылка.ТочкиДоставки
	ЗонаДоставки = Объект[Настройки.ЗонаДоставкиИмяПоля]; // СправочникСсылка.ЗоныДоставки
	
	ДанныеТочкиДоставки = Справочники.ТочкиДоставки.СведенияТочкиДоставкиОсновная(Настройки.ВладелецТочекДоставки);
	ТочкаДоставкиЗадана = Истина;
	ЗонаДоставкиЗадана = Истина;
	
	ВладельцыТочекДоставки = Новый Соответствие;
	Если НЕ ДанныеТочкиДоставки.ТочкаДоставки.Пустая() Тогда
		ВладельцыТочекДоставки[ДанныеТочкиДоставки.ТочкаДоставки] = Настройки.ВладелецТочекДоставки;
	КонецЕсли;
	ВладельцыТочекДоставки[ТочкаДоставки] = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ТочкаДоставки, "Владелец");
	
	ПроверитьОбновитьДанныеПоТочкеДоставки(
		ДанныеТочкиДоставки,
		ВладельцыТочекДоставки,
		ТочкаДоставки,
		ТочкаДоставкиЗадана,
		ЗонаДоставки,
		ЗонаДоставкиЗадана,
		ОбновитьДанные,
		ТолькоСброс);
	
	Если ОбновитьДанные Тогда
		
		Объект[Настройки.ТочкаДоставкиИмяПоля] = ТочкаДоставки;
		Объект[Настройки.ЗонаДоставкиИмяПоля] = ЗонаДоставки;
		
	КонецЕсли;
	
	Если НЕ ТочкаДоставкиЗадана
		И ВыводитьОшибкиЗаполнения Тогда
		
		ТекстОшибки = ОбщегоНазначенияКлиентСервер.ТекстОшибкиЗаполнения(,, НСтр("ru = 'Точка доставки'"));
		ОбщегоНазначения.СообщитьПользователю(
			ТекстОшибки,
			Объект,
			"ТребуетсяДоставка",
			,
			Отказ);
		
	КонецЕсли;
	
	Если НЕ ЗонаДоставкиЗадана
		И ВыводитьОшибкиЗаполнения Тогда
		
		ТекстОшибки = ОбщегоНазначенияКлиентСервер.ТекстОшибкиЗаполнения(,, НСтр("ru = 'Зона доставки'"));
		ОбщегоНазначения.СообщитьПользователю(
			ТекстОшибки,
			Объект,
			"ТребуетсяДоставка",
			,
			Отказ);
		
	КонецЕсли;
	
КонецПроцедуры

Процедура ПроверитьДанныеПолейДоставкиШапкаСведенияПеревозчика(Знач Настройки, Знач СпособДоставки, Знач Объект, Отказ)

	Если ПустаяСтрока(Настройки.ДоставкаДоПеревозчикаИмяПоля) Тогда
		ДоставкаДоПеревозчика = Настройки.ДоставкаДоПеревозчикаБезусловный;
	Иначе
		ДоставкаДоПеревозчика = Объект[Настройки.ДоставкаДоПеревозчикаИмяПоля]; // Булево
	КонецЕсли;
	
	Если (СпособДоставки = Перечисления.СпособыДоставки25.НашимиСилами
			И ДоставкаДоПеревозчика)
		ИЛИ СпособДоставки = Перечисления.СпособыДоставки25.СиламиПеревозчика Тогда
		
		Если НЕ ЗначениеЗаполнено(Объект[Настройки.ПеревозчикИмяПоля]) Тогда
			
			ТекстОшибки = ОбщегоНазначенияКлиентСервер.ТекстОшибкиЗаполнения(,, НСтр("ru = 'Перевозчик'"));
			ОбщегоНазначения.СообщитьПользователю(
				ТекстОшибки,
				Объект,
				"ТребуетсяДоставка",
				,
				Отказ);
			
		КонецЕсли;
		
	КонецЕсли;
	
	Если (СпособДоставки = Перечисления.СпособыДоставки25.НашимиСилами
		И ДоставкаДоПеревозчика) Тогда
		
		Если НЕ ЗначениеЗаполнено(Объект[Настройки.ТочкаДоставкиПеревозчикаИмяПоля]) Тогда
			
			ТекстОшибки = ОбщегоНазначенияКлиентСервер.ТекстОшибкиЗаполнения(,, НСтр("ru = 'Точка доставки перевозчика'"));
			ОбщегоНазначения.СообщитьПользователю(
				ТекстОшибки,
				Объект,
				"ТребуетсяДоставка",
				,
				Отказ);
			
		КонецЕсли;
		
		Если НЕ ЗначениеЗаполнено(Объект[Настройки.ЗонаДоставкиПеревозчикаИмяПоля]) Тогда
			
			ТекстОшибки = ОбщегоНазначенияКлиентСервер.ТекстОшибкиЗаполнения(,, НСтр("ru = 'Зона доставки перевозчика'"));
			ОбщегоНазначения.СообщитьПользователю(
				ТекстОшибки,
				Объект,
				"ТребуетсяДоставка",
				,
				Отказ);
			
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

Процедура ПроверитьОбновитьДанныеПолейДоставкиТаблица(Знач СпособУказанияДоставки, Знач Настройки, Знач ОбновитьДанные, Знач ТолькоСброс, Знач ВыводитьОшибкиЗаполнения, Отказ)
	
	Если СпособУказанияДоставки <> Перечисления.СпособыУказанияДоставки.ПоСтрокам Тогда
		Возврат;
	КонецЕсли;
	
	Объект = Настройки.ДокументОбъект; // ДокументОбъект
	
	ТаблицаТоваровДоставки = Настройки.ТаблицаТоваровДоставки;
	ТочкиДоставкиТаблицы = ТаблицаТоваровДоставки.ВыгрузитьКолонку("ТочкаДоставки"); // Массив из СправочникСсылка.ТочкиДоставки
	ДанныеТочекДоставкиТаблицы = ОбщегоНазначения.ЗначениеРеквизитаОбъектов(ТочкиДоставкиТаблицы, "Владелец");
	ДанныеТочкиДоставкиВладельца = Справочники.ТочкиДоставки.СведенияТочкиДоставкиОсновная(Настройки.ВладелецТочекДоставки);
	
	КлючДанных = ОбщегоНазначенияУТ.КлючДанныхДляСообщенияПользователю(Объект);
	ШаблонОшибкиПоле = НСтр("ru = 'Поле ""%1"" параметров доставки не заполнено для строки %2'");
	ШаблонОшибкиКолонка = НСтр("ru = 'Колонка ""%1"" параметров доставки не заполнена для строки %2'");
	
	Для каждого СтрокаДоставки Из ТаблицаТоваровДоставки Цикл
		
		Если СтрокаДоставки.СпособДоставки = Перечисления.СпособыДоставки25.Самовывоз Тогда
			
			Если ОбновитьДанные Тогда
				СброситьДанныеСтрокиПараметровДоставки(СтрокаДоставки);
			КонецЕсли;
			
			Продолжить;
			
		КонецЕсли;
		
		НомерСтроки = Формат(СтрокаДоставки.НомерСтрокиДокумента, "ЧГ=");
		ПутьКПолю = ОбщегоНазначенияКлиентСервер.ПутьКТабличнойЧасти(
			"Товары", СтрокаДоставки.НомерСтрокиДокумента, "НомерСтроки");
			
		Если СтрокаДоставки.СпособДоставки.Пустая() Тогда
			
			Если ВыводитьОшибкиЗаполнения Тогда
				
				ИмяПоля = НСтр("ru = 'Способ доставки'");
				ПроверитьЗаполнениеПоляТаблицы(СтрокаДоставки.СпособДоставки, ШаблонОшибкиКолонка, ИмяПоля, НомерСтроки, КлючДанных, ПутьКПолю, Отказ);
				
			КонецЕсли;
			
			Продолжить;
			
		КонецЕсли;
		
		#Область ТочкаЗонаДоставки
		ТочкаДоставкиЗадана = Истина;
		ЗонаДоставкиЗадана = Истина;
		
		ПроверитьОбновитьДанныеПоТочкеДоставки(
			ДанныеТочкиДоставкиВладельца,
			ДанныеТочекДоставкиТаблицы,
			СтрокаДоставки.ТочкаДоставки,
			ТочкаДоставкиЗадана,
			СтрокаДоставки.ЗонаДоставки,
			ЗонаДоставкиЗадана,
			ОбновитьДанные,
			ТолькоСброс);
			
		Если НЕ ТочкаДоставкиЗадана
			И ВыводитьОшибкиЗаполнения Тогда
			
			ИмяПоля = НСтр("ru = 'Точка доставки'");
			ПроверитьЗаполнениеПоляТаблицы(Неопределено, ШаблонОшибкиПоле, ИмяПоля, НомерСтроки, КлючДанных, ПутьКПолю, Отказ);
			
		КонецЕсли;
		
		Если НЕ ЗонаДоставкиЗадана
			И ВыводитьОшибкиЗаполнения Тогда
			
			ИмяПоля = НСтр("ru = 'Зона доставки'");
			ПроверитьЗаполнениеПоляТаблицы(Неопределено, ШаблонОшибкиПоле, ИмяПоля, НомерСтроки, КлючДанных, ПутьКПолю, Отказ);
			
		КонецЕсли;
		#КонецОбласти
		
		Если СтрокаДоставки.СпособДоставки = Перечисления.СпособыДоставки25.НашимиСилами Тогда
			
			Если СтрокаДоставки.ДоставкаДоПеревозчика Тогда
				
				Если ВыводитьОшибкиЗаполнения Тогда
					
					ИмяПоля = НСтр("ru = 'Перевозчик'");
					ПроверитьЗаполнениеПоляТаблицы(СтрокаДоставки.Перевозчик, ШаблонОшибкиПоле, ИмяПоля, НомерСтроки, КлючДанных, ПутьКПолю, Отказ);
					
					ИмяПоля = НСтр("ru = 'Точка доставки перевозчика'");
					ПроверитьЗаполнениеПоляТаблицы(СтрокаДоставки.ТочкаДоставкиПеревозчика, ШаблонОшибкиПоле, ИмяПоля, НомерСтроки, КлючДанных, ПутьКПолю, Отказ);
					
					ИмяПоля = НСтр("ru = 'Зона доставки перевозчика'");
					ПроверитьЗаполнениеПоляТаблицы(СтрокаДоставки.ЗонаДоставкиПеревозчика, ШаблонОшибкиПоле, ИмяПоля, НомерСтроки, КлючДанных, ПутьКПолю, Отказ);
					
				КонецЕсли;
				
			Иначе
				
				Если ОбновитьДанные Тогда
					
					СтрокаДоставки.Перевозчик = Справочники.Партнеры.ПустаяСсылка();
					СтрокаДоставки.ТочкаДоставкиПеревозчика = Справочники.ТочкиДоставки.ПустаяСсылка();
					СтрокаДоставки.ЗонаДоставкиПеревозчика = Справочники.ЗоныДоставки.ПустаяСсылка();
					
				КонецЕсли;
				
			КонецЕсли;
			
		КонецЕсли;
		
		Если СтрокаДоставки.СпособДоставки = Перечисления.СпособыДоставки25.СиламиПеревозчика Тогда
			
			Если ВыводитьОшибкиЗаполнения Тогда
				
				ИмяПоля = НСтр("ru = 'Перевозчик'");
				ПроверитьЗаполнениеПоляТаблицы(СтрокаДоставки.Перевозчик, ШаблонОшибкиПоле, ИмяПоля, НомерСтроки, КлючДанных, ПутьКПолю, Отказ);
				
			КонецЕсли;
			
			Если ОбновитьДанные Тогда
				
				СтрокаДоставки.ТочкаДоставкиПеревозчика = Справочники.ТочкиДоставки.ПустаяСсылка();
				СтрокаДоставки.ЗонаДоставкиПеревозчика = Справочники.ЗоныДоставки.ПустаяСсылка();
				
			КонецЕсли;
			
		КонецЕсли;
		
		Если СтрокаДоставки.ОсобыеУсловияПеревозки Тогда
			
			Если ВыводитьОшибкиЗаполнения Тогда
				
				ИмяПоля = НСтр("ru = 'Описание особых условий перевозки'");
				ПроверитьЗаполнениеПоляТаблицы(СтрокаДоставки.ОсобыеУсловияПеревозкиОписание, ШаблонОшибкиПоле, ИмяПоля, НомерСтроки, КлючДанных, ПутьКПолю, Отказ);
				
			КонецЕсли;
			
		Иначе
			
			Если ОбновитьДанные Тогда
				СтрокаДоставки.ОсобыеУсловияПеревозкиОписание = "";
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЦикла;
	
	Если ОбновитьДанные Тогда
		
		ТоварыКДоставке = Объект[Настройки.ТоварыКДоставкеИмяТаблицы]; // ТабличнаяЧасть
		ТоварыКДоставке.Загрузить(ТаблицаТоваровДоставки);
		
	КонецЕсли;
	
КонецПроцедуры

Процедура ПроверитьЗаполнениеПоляТаблицы(ПроверяемоеПоле, ШаблонОшибки, ИмяПоля, НомерСтроки, КлючДанных, ПутьКПолю, Отказ)
	
	Если НЕ ЗначениеЗаполнено(ПроверяемоеПоле) Тогда
		
		ТекстОшибки = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
			ШаблонОшибки,
			ИмяПоля,
			НомерСтроки);
		ОбщегоНазначения.СообщитьПользователю(ТекстОшибки, КлючДанных, ПутьКПолю, "Объект", Отказ);
		
	КонецЕсли;
	
КонецПроцедуры

Процедура СброситьДанныеСтрокиПараметровДоставки(Знач СтрокаДоставки)
	
	СтрокаДоставки.ТочкаДоставки = Справочники.ТочкиДоставки.ПустаяСсылка();
	СтрокаДоставки.ЗонаДоставки = Справочники.ЗоныДоставки.ПустаяСсылка();
	
	СтрокаДоставки.ДоставкаДоПеревозчика = Ложь;
	СтрокаДоставки.Перевозчик = Справочники.Партнеры.ПустаяСсылка();
	СтрокаДоставки.ТочкаДоставкиПеревозчика = Справочники.ТочкиДоставки.ПустаяСсылка();
	СтрокаДоставки.ЗонаДоставкиПеревозчика = Справочники.ЗоныДоставки.ПустаяСсылка();
	
	СтрокаДоставки.ВремяДоставкиС = Дата(1, 1, 1, 0, 0, 0);
	СтрокаДоставки.ВремяДоставкиПо = Дата(1, 1, 1, 0, 0, 0);
	
	СтрокаДоставки.ДополнительнаяИнформацияПоДоставке = "";
	
	СтрокаДоставки.ОсобыеУсловияПеревозки = Ложь;
	СтрокаДоставки.ОсобыеУсловияПеревозкиОписание = "";

КонецПроцедуры

Процедура ПроверитьОбновитьДанныеПоТочкеДоставки(Знач ДанныеТочкиДоставки, Знач ВладельцыТочекДоставки, ТочкаДоставки, ТочкаДоставкиЗадана, ЗонаДоставки, ЗонаДоставкиЗадана, Знач ОбновитьДанные, Знач ТолькоСброс)
	
	ВладелецТекущейТочкиДоставки = ВладельцыТочекДоставки[ТочкаДоставки];
	
	Если ТочкаДоставки.Пустая()
		ИЛИ ДанныеТочкиДоставки.Владелец <> ВладелецТекущейТочкиДоставки Тогда
		
		Если НЕ ЗонаДоставки.Пустая()
			И ДанныеТочкиДоставки.Владелец = ВладелецТекущейТочкиДоставки Тогда
			
			ТочкаДоставкиЗадана = Ложь;
			
		ИначеЕсли ДанныеТочкиДоставки.ТочкаДоставки.Пустая() Тогда
			
			ТочкаДоставкиЗадана = Ложь;
			ЗонаДоставкиЗадана = Ложь;
			
		Иначе
			
			Если ДанныеТочкиДоставки.ЗонаДоставки.Пустая() Тогда
				ЗонаДоставкиЗадана = Ложь;
			КонецЕсли;
			
			Если ОбновитьДанные Тогда
				
				ТочкаДоставки = ДанныеТочкиДоставки.ТочкаДоставки;
				ЗонаДоставки = ДанныеТочкиДоставки.ЗонаДоставки;
				
			КонецЕсли;
			
		КонецЕсли;
		
	Иначе
		
		Если ДанныеТочкиДоставки.Владелец = ВладелецТекущейТочкиДоставки Тогда
			
			Если ЗонаДоставки.Пустая()
				И (ТочкаДоставки <> ДанныеТочкиДоставки.ТочкаДоставки
					ИЛИ ДанныеТочкиДоставки.ЗонаДоставки.Пустая()) Тогда
				
				ЗонаДоставкиЗадана = Ложь;
				
			ИначеЕсли ЗонаДоставки.Пустая()
				И ТочкаДоставки = ДанныеТочкиДоставки.ТочкаДоставки
				И ОбновитьДанные Тогда
				
				ЗонаДоставки = ДанныеТочкиДоставки.ЗонаДоставки;
				
			КонецЕсли;
			
		Иначе
			
			Если ДанныеТочкиДоставки.ТочкаДоставки.Пустая()
				ИЛИ ТолькоСброс Тогда
				
				ТочкаДоставкиЗадана = Ложь;
				ЗонаДоставкиЗадана = Ложь;
				
				Если ОбновитьДанные Тогда
					
					ТочкаДоставки = Справочники.ТочкиДоставки.ПустаяСсылка();
					ЗонаДоставки = Справочники.ЗоныДоставки.ПустаяСсылка();
					
				КонецЕсли;
				
			Иначе
				
				Если ДанныеТочкиДоставки.ЗонаДоставки.Пустая() Тогда
					
					ЗонаДоставкиЗадана = Ложь;
					Если ОбновитьДанные Тогда
						ЗонаДоставки = Справочники.ЗоныДоставки.ПустаяСсылка();
					КонецЕсли;
					
				КонецЕсли;
				
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

// Параметры:
//  СкладыДоставки - Массив из СправочникСсылка.Склады
//  ТаблицаТекущихДанных - ТаблицаЗначений - таблица текущих данных по складам:
//    * Склад - СправочникСсылка.Склады
//    * ТочкаСклада - СправочникСсылка.ТочкиДоставки
//    * ЗонаСклада - СправочникСсылка.ЗоныДоставки
// 
// Возвращаемое значение:
//  Структура - Сформировать данные доставки по складам:
// * ДублиСкладов - ТаблицаЗначений:
//    ** Склад - СправочникСсылка.Склады 
// * ТаблицаСведений - ТаблицаЗначений:
//    ** Склад - СправочникСсылка.Склады
//    ** ТочкаСклада - СправочникСсылка.ТочкиДоставки
//    ** ЗонаСклада - СправочникСсылка.ЗоныДоставки
// 
Функция СформироватьДанныеДоставкиПоСкладам(СкладыДоставки, ТаблицаТекущихДанных)
	
	Результат = Новый Структура;
	
	Запрос = Новый Запрос;
	ТекстЗапроса =
	"ВЫБРАТЬ
	|	ВтТаблицаСведений.Склад КАК Склад,
	|	ВтТаблицаСведений.ТочкаСклада КАК ТочкаСклада,
	|	ВтТаблицаСведений.ЗонаСклада КАК ЗонаСклада
	|ПОМЕСТИТЬ ВтТекущиеСведения
	|ИЗ
	|	&ТаблицаСкладыСведенияДоставки КАК ВтТаблицаСведений
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Склады.Ссылка КАК Склад,
	|	ЕСТЬNULL(ТочкиДоставки.Ссылка, ЗНАЧЕНИЕ(Справочник.ТочкиДоставки.ПустаяСсылка)) КАК ТочкаДоставки,
	|	ЕСТЬNULL(ТочкиДоставки.ЗонаДоставки, ЗНАЧЕНИЕ(Справочник.ЗоныДоставки.ПустаяСсылка)) КАК ЗонаДоставки
	|ПОМЕСТИТЬ ВтДанныеПоСкладам
	|ИЗ
	|	Справочник.Склады КАК Склады
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ТочкиДоставки КАК ТочкиДоставки
	|		ПО Склады.Ссылка = ТочкиДоставки.Владелец
	|			И (ТочкиДоставки.ОсновнаяТочка)
	|ГДЕ
	|	Склады.Ссылка В(&Ссылки)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВтТекущиеСведения.Склад КАК Склад,
	|	1 КАК КоличествоЗаписей
	|ИЗ
	|	ВтТекущиеСведения КАК ВтТекущиеСведения
	|
	|СГРУППИРОВАТЬ ПО
	|	ВтТекущиеСведения.Склад
	|
	|ИМЕЮЩИЕ
	|	КОЛИЧЕСТВО(1) > 1
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВтДанныеПоСкладам.Склад КАК Склад,
	|	ВЫБОР
	|		КОГДА ВтТекущиеСведения.ТочкаСклада ЕСТЬ NULL
	|			ТОГДА ВтДанныеПоСкладам.ТочкаДоставки
	|		КОГДА ВтТекущиеСведения.ТочкаСклада = ЗНАЧЕНИЕ(Справочник.ТочкиДоставки.ПустаяСсылка)
	|			ТОГДА ВтДанныеПоСкладам.ТочкаДоставки
	|		ИНАЧЕ ВтТекущиеСведения.ТочкаСклада
	|	КОНЕЦ КАК ТочкаСклада,
	|	ВЫБОР
	|		КОГДА ВтТекущиеСведения.ЗонаСклада ЕСТЬ NULL
	|			ТОГДА ВтДанныеПоСкладам.ЗонаДоставки
	|		КОГДА ВтТекущиеСведения.ЗонаСклада = ЗНАЧЕНИЕ(Справочник.ЗоныДоставки.ПустаяСсылка)
	|			ТОГДА ЕСТЬNULL((ВЫБОР
	|						КОГДА ВтТекущиеСведения.ТочкаСклада ЕСТЬ NULL
	|							ТОГДА ВтДанныеПоСкладам.ТочкаДоставки
	|						КОГДА ВтТекущиеСведения.ТочкаСклада = ЗНАЧЕНИЕ(Справочник.ТочкиДоставки.ПустаяСсылка)
	|							ТОГДА ВтДанныеПоСкладам.ТочкаДоставки
	|						ИНАЧЕ ВтТекущиеСведения.ТочкаСклада
	|					КОНЕЦ).ЗонаДоставки, ЗНАЧЕНИЕ(Справочник.ТочкиДоставки.ПустаяСсылка))
	|		КОГДА ВтТекущиеСведения.ТочкаСклада ЕСТЬ NULL
	|			ТОГДА ЕСТЬNULL(ВтДанныеПоСкладам.ТочкаДоставки.ЗонаДоставки, ЗНАЧЕНИЕ(Справочник.ТочкиДоставки.ПустаяСсылка))
	|		КОГДА ВтТекущиеСведения.ТочкаСклада = ЗНАЧЕНИЕ(Справочник.ТочкиДоставки.ПустаяСсылка)
	|			ТОГДА ЕСТЬNULL(ВтДанныеПоСкладам.ТочкаДоставки.ЗонаДоставки, ЗНАЧЕНИЕ(Справочник.ТочкиДоставки.ПустаяСсылка))
	|		ИНАЧЕ ВтТекущиеСведения.ЗонаСклада
	|	КОНЕЦ КАК ЗонаСклада
	|ИЗ
	|	ВтДанныеПоСкладам КАК ВтДанныеПоСкладам
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВтТекущиеСведения КАК ВтТекущиеСведения
	|		ПО ВтДанныеПоСкладам.Склад = ВтТекущиеСведения.Склад
	|
	|УПОРЯДОЧИТЬ ПО
	|	Склад";
	Запрос.Текст = ТекстЗапроса;
	Запрос.УстановитьПараметр("Ссылки", СкладыДоставки);
	Запрос.УстановитьПараметр("ТаблицаСкладыСведенияДоставки", ТаблицаТекущихДанных);
	
	МассивРезультатов = Запрос.ВыполнитьПакет();
	КоличествоЗапросов = МассивРезультатов.Количество();
	ДублиСкладов = МассивРезультатов[КоличествоЗапросов - 2].Выгрузить();
	ТаблицаНовыхСведенийСкладов = МассивРезультатов[КоличествоЗапросов - 1].Выгрузить();
	
	Результат.Вставить("ДублиСкладов", ДублиСкладов);
	Результат.Вставить("ТаблицаСведений", ТаблицаНовыхСведенийСкладов);
	
	Возврат Результат;
	
КонецФункции

// Параметры:
//  Настройки - см. НовыеНастройкиПроверкиИспользованияРеквизитовДоставки
//  Отказ  - Булево
//  ОбновитьДанные - Булево - указывает на необходимость записи обновленных данных в таблицу
//  ВыводитьОшибкиЗаполнения - Булево - признак необходимости выводить ошибки заполнения
//
Процедура ПроверитьОбновитьСведенияДанныхДоставкиПоСкладам(Знач Настройки, Отказ, ОбновитьДанные = Ложь, ВыводитьОшибкиЗаполнения = Истина)
	
	СкладыСведенияДоставкиИмяТаблицы = "СкладыСведенияДоставки";
	
	Объект = Настройки.ДокументОбъект; // ДокументОбъект
	СкладыДоставки = ОбщегоНазначенияКлиентСервер.СвернутьМассив(Настройки.СкладыДоставки);
	ОбщегоНазначенияКлиентСервер.УдалитьЗначениеИзМассива(СкладыДоставки, Справочники.Склады.ПустаяСсылка());
	
	ТабличнаяЧастьСведений = Объект[СкладыСведенияДоставкиИмяТаблицы]; // ТабличнаяЧасть
	
	ТаблицаСкладыСведенияДоставки = ТабличнаяЧастьСведений.Выгрузить();
	ДанныеПоСкладам = СформироватьДанныеДоставкиПоСкладам(СкладыДоставки, ТаблицаСкладыСведенияДоставки);
	
	ЕстьДубли = Ложь;
	ШаблонСообщенияДубль = НСтр("ru = 'Для склада ""%1"" обнаружены дубли в записях сведений доставки, обновите настройки доставки.'");
	Для Каждого СтрокаДубля Из ДанныеПоСкладам.ДублиСкладов Цикл
		
		ЕстьДубли = Истина;
		
		Если ВыводитьОшибкиЗаполнения Тогда
			
			ТекстСообщения = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
				ШаблонСообщенияДубль,
				Строка(СтрокаДубля));
			
			ОбщегоНазначения.СообщитьПользователю(
				ТекстСообщения,
				Объект,
				"ТребуетсяДоставка",
				,
				Отказ);
			
		КонецЕсли;
		
	КонецЦикла;
	
	Если НЕ ЕстьДубли
		И ВыводитьОшибкиЗаполнения Тогда
		
		ПроверитьЗаполнениеСведенийСкладов(Объект, ДанныеПоСкладам.ТаблицаСведений, Отказ);
		
	КонецЕсли;
	
	Если НЕ Отказ
		И ОбновитьДанные Тогда
		
		ТабличнаяЧастьСведений.Загрузить(ДанныеПоСкладам.ТаблицаСведений);
		
	КонецЕсли;
	
КонецПроцедуры

Процедура ПроверитьЗаполнениеСведенийСкладов(Знач Объект, Знач ТаблицаСведений, Отказ )
	
	ШаблонСообщенияТочка = НСтр("ru = 'Для склада ""%1"" не указана точка отправки'");
	ШаблонСообщенияЗона = НСтр("ru = 'Для склада ""%1"" не указана зона отправки'");
	
	Для Каждого СтрокаСклада Из ТаблицаСведений Цикл
		
		Если СтрокаСклада.ТочкаСклада.Пустая() Тогда
			
			ТекстСообщения = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
				ШаблонСообщенияТочка,
				Строка(СтрокаСклада.Склад));
			
			ОбщегоНазначения.СообщитьПользователю(
				ТекстСообщения,
				Объект,
				"ТребуетсяДоставка",
				,
				Отказ);
			
		КонецЕсли;
		
		Если СтрокаСклада.ЗонаСклада.Пустая() Тогда
			
			ТекстСообщения = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
				ШаблонСообщенияЗона,
				Строка(СтрокаСклада.Склад));
			
			ОбщегоНазначения.СообщитьПользователю(
				ТекстСообщения,
				Объект,
				"ТребуетсяДоставка",
				,
				Отказ);
			
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

// Параметры:
//  Настройки - см. НовыеНастройкиПроверкиИспользованияРеквизитовДоставки
//  СпособУказанияДоставки - ПеречислениеСсылка.СпособыУказанияДоставки
//  Отказ  - Булево
//
Процедура ПроверитьПересечениеКлиентаИПеревозчика(Настройки, СпособУказанияДоставки, Отказ)
	
	Если НЕ ЗначениеЗаполнено(Настройки.ВладелецТочекДоставки) Тогда
		Возврат;
	КонецЕсли;
	
	Объект = Настройки.ДокументОбъект; // ДокументОбъект
	ПартнерПеревозчик = Объект[Настройки.ПеревозчикИмяПоля]; // СправочникСсылка.Партнеры
	ПредставлениеПартнера = Строка(Настройки.ВладелецТочекДоставки);
	
	Если СпособУказанияДоставки = Перечисления.СпособыУказанияДоставки.НаВесьДокумент Тогда
		
		Если ПустаяСтрока(Настройки.СпособДоставкиИмяПоля) Тогда
			СпособДоставки = Настройки.СпособДоставкиБезусловный;
		Иначе
			СпособДоставки = Объект[Настройки.СпособДоставкиИмяПоля]; // ПеречислениеСсылка.СпособыДоставки25
		КонецЕсли;
		
		Если ПустаяСтрока(Настройки.ДоставкаДоПеревозчикаИмяПоля) Тогда
			ДоставкаДоПеревозчика = Настройки.ДоставкаДоПеревозчикаБезусловный;
		Иначе
			ДоставкаДоПеревозчика = Объект[Настройки.ДоставкаДоПеревозчикаИмяПоля]; // Булево
		КонецЕсли;
		
		Если ЭтоСпособДоставкиСПеревозчиком(СпособДоставки, ДоставкаДоПеревозчика)
			И Настройки.ВладелецТочекДоставки = ПартнерПеревозчик Тогда
			
			ШаблонСообщения = НСтр("ru = 'Совпадают данные получателя и перевозчика (%1), оформление доставки невозможно.'");
			
			ТекстСообщения = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
				ШаблонСообщения,
				ПредставлениеПартнера);
			
			ОбщегоНазначения.СообщитьПользователю(
				ТекстСообщения,
				Объект,
				"ТребуетсяДоставка",
				,
				Отказ);
			
		КонецЕсли;
		
	Иначе
		
		ШаблонСообщения = НСтр("ru = 'Совпадают данные получателя и перевозчика (%1), оформление доставки по строке %2 невозможно.'");
		ТаблицаТоваровДоставки = Настройки.ТаблицаТоваровДоставки;
		КлючДанных = ОбщегоНазначенияУТ.КлючДанныхДляСообщенияПользователю(Объект);
		
		Для каждого СтрокаДоставки Из ТаблицаТоваровДоставки Цикл
			
			Если НЕ (ЭтоСпособДоставкиСПеревозчиком(СтрокаДоставки.СпособДоставки, СтрокаДоставки.ДоставкаДоПеревозчика)
				И Настройки.ВладелецТочекДоставки = СтрокаДоставки.Перевозчик) Тогда
				
				Продолжить;
				
			КонецЕсли;
			
			НомерСтроки = Формат(СтрокаДоставки.НомерСтрокиДокумента, "ЧГ=");
			ПутьКПолю = ОбщегоНазначенияКлиентСервер.ПутьКТабличнойЧасти(
				"Товары", СтрокаДоставки.НомерСтрокиДокумента, "НомерСтроки");
			
			ТекстОшибки = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
				ШаблонСообщения,
				ПредставлениеПартнера,
				НомерСтроки);
			
			ОбщегоНазначения.СообщитьПользователю(ТекстОшибки, КлючДанных, ПутьКПолю, "Объект", Отказ);
			
		КонецЦикла;
		
	КонецЕсли;
	
КонецПроцедуры

Функция ЭтоСпособДоставкиСПеревозчиком(СпособДоставки, ДоставкаДоПеревозчика)
	
	Результат = Истина;
	
	Если СпособДоставки.Пустая()
		ИЛИ СпособДоставки = Перечисления.СпособыДоставки25.Самовывоз
		ИЛИ СпособДоставки = Перечисления.СпособыДоставки25.НашКурьер
		ИЛИ СпособДоставки = Перечисления.СпособыДоставки25.ОпределяетСлужбаДоставки
		ИЛИ (СпособДоставки = Перечисления.СпособыДоставки25.НашимиСилами
			И НЕ ДоставкаДоПеревозчика) Тогда
		
		Результат = Ложь;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Возвращаемое значение:
//  ТаблицаЗначений - Новая таблица товаров доставки:
// * НомерСтрокиДокумента - Число 
// * КодСтроки - Число 
// * Номенклатура - СправочникСсылка.Номенклатура 
// * Характеристика - СправочникСсылка.ХарактеристикиНоменклатуры 
// * Серия - СправочникСсылка.СерииНоменклатуры
// * СпособДоставки - ПеречислениеСсылка.СпособыДоставки25
// * ТочкаДоставки - СправочникСсылка.ТочкиДоставки
// * ЗонаДоставки - СправочникСсылка.ЗоныДоставки
// * ДоставкаДоПеревозчика - Булево
// * Перевозчик - СправочникСсылка.Партнеры
// * ТочкаДоставкиПеревозчика - СправочникСсылка.ТочкиДоставки
// * ЗонаДоставкиПеревозчика - СправочникСсылка.ЗоныДоставки
// * ВремяДоставкиС - Дата
// * ВремяДоставкиПо - Дата
// * ДополнительнаяИнформацияПоДоставке - Строка 
// * ОсобыеУсловияПеревозки - Булево
// * ОсобыеУсловияПеревозкиОписание - Строка
//
Функция НоваяТаблицаТоваровДоставки()
	
	ТипЧисло5 = ОбщегоНазначения.ОписаниеТипаЧисло(5,, ДопустимыйЗнак.Неотрицательный);
	ТипЧисло10 = ОбщегоНазначения.ОписаниеТипаЧисло(10,, ДопустимыйЗнак.Неотрицательный);
	ТипВремя = ОбщегоНазначения.ОписаниеТипаДата(ЧастиДаты.Время);
	ТипСтрока0 = ОбщегоНазначения.ОписаниеТипаСтрока(0);
	ТипБулево = Новый ОписаниеТипов("Булево");
	
	ТипНоменклатура = Новый ОписаниеТипов("СправочникСсылка.Номенклатура");
	ТипХарактеристика = Новый ОписаниеТипов("СправочникСсылка.ХарактеристикиНоменклатуры");
	ТипСерииНоменклатуры = Новый ОписаниеТипов("СправочникСсылка.СерииНоменклатуры");
	ТипСпособДоставки = Новый ОписаниеТипов("ПеречислениеСсылка.СпособыДоставки25");
	ТипПеревозчик = Новый ОписаниеТипов("СправочникСсылка.Партнеры");
	ТипТочкаДоставки = Новый ОписаниеТипов("СправочникСсылка.ТочкиДоставки");
	ТипЗонаДоставки = Новый ОписаниеТипов("СправочникСсылка.ЗоныДоставки");
	
	Таблица = Новый ТаблицаЗначений;
	Таблица.Колонки.Добавить("НомерСтрокиДокумента", ТипЧисло5);
	Таблица.Колонки.Добавить("КодСтроки", ТипЧисло10);
	Таблица.Колонки.Добавить("Номенклатура", ТипНоменклатура);
	Таблица.Колонки.Добавить("Характеристика", ТипХарактеристика);
	Таблица.Колонки.Добавить("Серия", ТипСерииНоменклатуры);
	Таблица.Колонки.Добавить("СпособДоставки", ТипСпособДоставки);
	Таблица.Колонки.Добавить("ТочкаДоставки", ТипТочкаДоставки);
	Таблица.Колонки.Добавить("ЗонаДоставки", ТипЗонаДоставки);
	Таблица.Колонки.Добавить("ДоставкаДоПеревозчика", ТипБулево);
	Таблица.Колонки.Добавить("Перевозчик", ТипПеревозчик);
	Таблица.Колонки.Добавить("ТочкаДоставкиПеревозчика", ТипТочкаДоставки);
	Таблица.Колонки.Добавить("ЗонаДоставкиПеревозчика", ТипЗонаДоставки);
	Таблица.Колонки.Добавить("ВремяДоставкиС", ТипВремя);
	Таблица.Колонки.Добавить("ВремяДоставкиПо", ТипВремя);
	Таблица.Колонки.Добавить("ДополнительнаяИнформацияПоДоставке", ТипСтрока0);
	Таблица.Колонки.Добавить("ОсобыеУсловияПеревозки", ТипБулево);
	Таблица.Колонки.Добавить("ОсобыеУсловияПеревозкиОписание", ТипСтрока0);
	
	Возврат Таблица;
	
КонецФункции

// Параметры:
//  ПроверкаВТранзакции - Булево -
// 
// Возвращаемое значение:
//  Булево -
//
Функция ЕстьОстаткиКОтгрузкеДоЗавершенияПереходаНаДоставку25(ПроверкаВТранзакции = Ложь)
	
	СпособыДоставки = Новый Массив; // Массив из  ПеречислениеСсылка.СпособыДоставки
	СпособыДоставки.Добавить(Перечисления.СпособыДоставки.ДоКлиента);
	СпособыДоставки.Добавить(Перечисления.СпособыДоставки.СиламиПеревозчика);
	СпособыДоставки.Добавить(Перечисления.СпособыДоставки.СиламиПеревозчикаПоАдресу);
	СпособыДоставки.Добавить(Перечисления.СпособыДоставки.КПолучателюОпределяетСлужбаДоставки);
	
	ТекстЗапросаРаспоряжения =
	"ВЫБРАТЬ
	|	СостоянияИРеквизитыДоставки.Распоряжение КАК Распоряжение,
	|	СостоянияИРеквизитыДоставки.Склад КАК Склад,
	|	СостоянияИРеквизитыДоставки.СпособДоставки КАК СпособДоставки
	|ПОМЕСТИТЬ ВТ_Распоряжения
	|ИЗ
	|	РегистрСведений.СостоянияИРеквизитыДоставки КАК СостоянияИРеквизитыДоставки
	|ГДЕ
	|	СостоянияИРеквизитыДоставки.СпособДоставки В(&СпособыДоставки)
	|	И СостоянияИРеквизитыДоставки.Склад.НачинатьОтгрузкуПослеФормированияЗаданияНаПеревозку";
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("СпособыДоставки", СпособыДоставки);
	Запрос.Текст = ТекстЗапросаРаспоряжения;
	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц();
	Запрос.Выполнить();
	
	Если ПроверкаВТранзакции Тогда
		
		ТекстЗапросаБлокируемыеЗначения =
		"ВЫБРАТЬ
		|	Распоряжения.Распоряжение КАК Распоряжение,
		|	Распоряжения.Склад КАК Склад,
		|	Распоряжения.СпособДоставки КАК СпособДоставки
		|ИЗ
		|	ВТ_Распоряжения КАК Распоряжения";
		
		Запрос.Текст = ТекстЗапросаБлокируемыеЗначения;
		РезультатЗапроса = Запрос.Выполнить();
		
		Попытка
			
			Блокировка = Новый БлокировкаДанных();
			
			ЭлементБлокировки = Блокировка.Добавить("РегистрСведений.СостоянияИРеквизитыДоставки");
			ЭлементБлокировки.ИсточникДанных = РезультатЗапроса;
			ЭлементБлокировки.ИспользоватьИзИсточникаДанных("Склад", "Склад");
			ЭлементБлокировки.ИспользоватьИзИсточникаДанных("СпособДоставки", "СпособДоставки");
			ЭлементБлокировки.Режим = РежимБлокировкиДанных.Исключительный;
			
			ЭлементБлокировки = Блокировка.Добавить("РегистрНакопления.ТоварыКОтгрузке");
			ЭлементБлокировки.ИсточникДанных = РезультатЗапроса;
			ЭлементБлокировки.ИспользоватьИзИсточникаДанных("ДокументОтгрузки", "Распоряжение");
			ЭлементБлокировки.Режим = РежимБлокировкиДанных.Исключительный;
			
			Блокировка.Заблокировать();
			
		Исключение
			
			ВызватьИсключение;
			
		КонецПопытки;
		
	КонецЕсли;
	
	ТекстЗапроса =
	"ВЫБРАТЬ
	|	ТоварыКОтгрузкеОстатки.Склад КАК Склад,
	|	ТоварыКОтгрузкеОстатки.КОтгрузкеОстаток КАК КОтгрузкеОстаток
	|ИЗ
	|	РегистрНакопления.ТоварыКОтгрузке.Остатки(, ДокументОтгрузки В
	|		(ВЫБРАТЬ
	|			Распоряжения.Распоряжение КАК ДокументОтгрузки
	|		ИЗ
	|			ВТ_Распоряжения КАК Распоряжения)) КАК ТоварыКОтгрузкеОстатки";
	
	Запрос.Текст = ТекстЗапроса;
	Результат = Запрос.Выполнить();
	
	ЕстьОстатки = НЕ Результат.Пустой();
	
	Возврат ЕстьОстатки;
	
КонецФункции

// Возвращаемое значение:
// Структура - Дополнительные параметры доставки из шапки распоряжения:
// * ВремяДоставкиС - Дата - 
// * ВремяДоставкиПо - Дата - 
// * ДополнительнаяИнформацияПоДоставке - Строка - 
// * ОсобыеУсловияПеревозки - Булево - 
// * ОсобыеУсловияПеревозкиОписание - Строка - 
// * Совпадают - Булево
//
Функция ДопПараметры()
	
	ПустоеВремя = '00010101';
	ПустаяСтрока = "";
	
	ДопПараметры = Новый Структура;
	ДопПараметры.Вставить("Совпадают", Истина);
	ДопПараметры.Вставить("ВремяДоставкиС", ПустоеВремя);
	ДопПараметры.Вставить("ВремяДоставкиПо", ПустоеВремя);
	ДопПараметры.Вставить("ДополнительнаяИнформацияПоДоставке", ПустаяСтрока);
	ДопПараметры.Вставить("ОсобыеУсловияПеревозки", Ложь);
	ДопПараметры.Вставить("ОсобыеУсловияПеревозкиОписание", ПустаяСтрока);
	
	Возврат ДопПараметры;
	
КонецФункции

// Параметры:
//  Объекты - Массив из Произвольный - объекты, которые необходимо сгруппировать.
// 
// Возвращаемое значение:
//  Соответствие из КлючИЗначение:
//  * Ключ - Тип
//  * Значение - Массив из Произвольный
//
Функция ОбъектыПоТипам(Объекты)
	
	ОбъектыПоТипам = Новый Соответствие;
	
	Для Каждого Объект Из Объекты Цикл
		
		ОбъектыТипа = ОбъектыПоТипам[ТипЗнч(Объект)];
		
		Если ОбъектыТипа = Неопределено Тогда
			
			ОбъектыТипа = Новый Массив;
			ОбъектыПоТипам.Вставить(ТипЗнч(Объект), ОбъектыТипа);
			
		КонецЕсли;
		
		ОбъектыТипа.Добавить(Объект);
		
	КонецЦикла;
	
	Возврат ОбъектыПоТипам;
	
КонецФункции

// Возвращаемое значение:
//  ТаблицаЗначений:
// * ЗаказКлиента - ДокументСсылка.ЗаказКлиента -
// * КодСтрокиЗаказа - Число -
// * Номенклатура - СправочникСсылка.Номенклатура - 
// * Характеристика - СправочникСсылка.ХарактеристикиНоменклатуры - 
// * Серия - СправочникСсылка.СерииНоменклатуры - 
// * Количество - Число -
// * КонечнаяТочкаДоставки - СправочникСсылка.ТочкиДоставки - 
//
Функция НовыеДанныеАдресовРаспоряжения()
	
	ТипЗаказ = Метаданные.Документы.РеализацияТоваровУслуг.ТабличныеЧасти.Товары.Реквизиты.ЗаказКлиента.Тип;
	ТипКод = ОбщегоНазначения.ОписаниеТипаЧисло(10, 0, ДопустимыйЗнак.Неотрицательный);
	ТипКоличество = ОбщегоНазначения.ОписаниеТипаЧисло(15, 3);
	
	ДанныеАдресов = Новый ТаблицаЗначений;
	ДанныеАдресов.Колонки.Добавить("ЗаказКлиента", ТипЗаказ);
	ДанныеАдресов.Колонки.Добавить("КодСтрокиЗаказа", ТипКод);
	ДанныеАдресов.Колонки.Добавить("Номенклатура", Новый ОписаниеТипов("СправочникСсылка.Номенклатура"));
	ДанныеАдресов.Колонки.Добавить("Характеристика", Новый ОписаниеТипов("СправочникСсылка.ХарактеристикиНоменклатуры"));
	ДанныеАдресов.Колонки.Добавить("Серия", Новый ОписаниеТипов("СправочникСсылка.СерииНоменклатуры"));
	ДанныеАдресов.Колонки.Добавить("Количество", ТипКоличество);
	ДанныеАдресов.Колонки.Добавить("КонечнаяТочкаДоставки", Новый ОписаниеТипов("СправочникСсылка.ТочкиДоставки"));
	
	Возврат ДанныеАдресов;
	
КонецФункции

Функция ТекстЗапросаДанныхРаспоряженийНаДоставку()
	
	ТекстЗапроса =
	"ВЫБРАТЬ
	|	Товары.Ссылка КАК Ссылка,
