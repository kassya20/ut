КонецФункции

Процедура ЗаписатьОшибкуСозданияТочекДоставкиВЖурнал(ПредставлениеОшибки, ВладелецТочкиДоставки)
	
	ИмяСобытия = НСтр("ru = 'Переход на управление доставкой 2.5'", ОбщегоНазначения.КодОсновногоЯзыка());
	
	ШаблонСообщения = НСтр("ru = 'Не удалось создать точки доставки для %1 по причине:
								 |%2'");
	
	ПредставлениеВладельца = ОбщегоНазначения.ПредметСтрокой(ВладелецТочкиДоставки);
	
	ТекстСообщения = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
		ШаблонСообщения,
		ПредставлениеВладельца,
		ПредставлениеОшибки);
	
	ЗаписьЖурналаРегистрации(
		ИмяСобытия,
		УровеньЖурналаРегистрации.Предупреждение,
		,
		ВладелецТочкиДоставки,
		ТекстСообщения);
	
КонецПроцедуры

// Параметры:
//  ВладелецКонтактнойИнформации - СправочникСсылка.Партнеры, СправочникСсылка.Склады -
//  ПерваяЗапись - Булево -
// 
// Возвращаемое значение:
//  см. ДоставкаТоваров.НовыеДанныеТочекДоставки
//
Функция ДанныеСуществующихТочекДоставки(ВладелецКонтактнойИнформации, ПерваяЗапись)
	
	ДанныеТочекДоставки = НовыеДанныеТочекДоставки();
	
	Если НЕ ПерваяЗапись Тогда
		
		ТекстЗапроса = ТекстЗапросаДанныхТочекДоставки();
		
		Запрос = Новый Запрос;
		Запрос.Текст = ТекстЗапроса;
		Запрос.УстановитьПараметр("Владелец", ВладелецКонтактнойИнформации);
		
		Выборка = Запрос.Выполнить().Выбрать();
		Пока Выборка.Следующий() Цикл
			
			ДанныеТочки = ДанныеТочекДоставки.Добавить();
			ЗаполнитьЗначенияСвойств(ДанныеТочки, Выборка);
			
		КонецЦикла;
		
	КонецЕсли;
	
	Возврат ДанныеТочекДоставки;
	
КонецФункции

Функция ТекстЗапросаДанныхТочекДоставки()
	
	ТекстЗапроса =
	"ВЫБРАТЬ
	|	ТочкиДоставки.Ссылка КАК ТочкаДоставки,
	|	ТочкиДоставки.ОсновнаяТочка КАК ОсновнаяТочка,
	|	ТочкиДоставки.НеИспользуется КАК НеИспользуется,
	|	ТочкиДоставки.Адрес КАК Адрес,
	|	ТочкиДоставки.АдресЗначение КАК АдресЗначение,
	|	ТочкиДоставки.АдресЗначенияПолей КАК АдресЗначенияПолей,
	|	ТочкиДоставки.ИдентификаторПереопределен КАК ИдентификаторПереопределен,
	|	СОКРЛП(ТочкиДоставки.ИдентификаторТочкиДоставки) КАК ИдентификаторТочкиДоставки,
	|	ТочкиДоставки.Наименование КАК Наименование,
	|	ТочкиДоставки.ЗонаДоставки КАК ЗонаДоставки,
	|	СОКРЛП(ТочкиДоставки.ИдентификаторАдреса) КАК ИдентификаторАдреса
	|ИЗ
	|	Справочник.ТочкиДоставки КАК ТочкиДоставки
	|ГДЕ
	|	ТочкиДоставки.Владелец = &Владелец
	|	И НЕ ТочкиДоставки.ПометкаУдаления
	|
	|УПОРЯДОЧИТЬ ПО
	|	ИдентификаторАдреса";
	
	Возврат ТекстЗапроса;
	
КонецФункции

Функция ДанныеОсновнойТочкиДоставки(ДанныеТочекДоставки)
	
	Отбор = Новый Структура;
	Отбор.Вставить("ОсновнаяТочка", Истина);
	
	Строки = ДанныеТочекДоставки.НайтиСтроки(Отбор);
	
	Если Строки.Количество() > 0 Тогда
		
		ДанныеТД = Строки[0];
		
	Иначе
		
		ДанныеТД = Неопределено;
		
	КонецЕсли;
	
	Возврат ДанныеТД;
	
КонецФункции

Функция ДанныеТочкиДоставкиПоДаннымАдреса(ДанныеТДВладельца, ДанныеАдреса)
	
	Если ЗначениеЗаполнено(ДанныеАдреса.Идентификатор) Тогда
		
		ДанныеТД =  ДанныеТочкиДоставкиПоИдентификатору(ДанныеТДВладельца, ДанныеАдреса.Идентификатор);
		
	ИначеЕсли ЗначениеЗаполнено(ДанныеАдреса.Адрес) Тогда
		
		ДанныеТД =  ДанныеТочкиДоставкиПоПредставлению(ДанныеТДВладельца, ДанныеАдреса.Адрес);
		
	Иначе
		
		ДанныеТД = Неопределено;
		
	КонецЕсли;
	
	Возврат ДанныеТД;
	
КонецФункции

Функция ДанныеТочкиДоставкиПоИдентификатору(ДанныеТДВладельца, ИдентификаторАдреса)
	
	ДанныеТД = Неопределено;
	
	Если НЕ ПустаяСтрока(ИдентификаторАдреса) Тогда
		
		Отбор = Новый Структура;
		Отбор.Вставить("ИдентификаторАдреса", ИдентификаторАдреса);
		Отбор.Вставить("ИдентификаторТочкиДоставки", "");
		
		Строки = ДанныеТДВладельца.НайтиСтроки(Отбор);
		
		Если Строки.Количество() = 0 Тогда
			
			Отбор = Новый Структура;
			Отбор.Вставить("ИдентификаторТочкиДоставки", ИдентификаторАдреса);
			
			Строки = ДанныеТДВладельца.НайтиСтроки(Отбор);
			
		КонецЕсли;
		
		Если Строки.Количество() > 0 Тогда
			
			ДанныеТД = Строки[0];
			ДанныеТД.ПодобранаПоИдентификатору = Истина;
			
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат ДанныеТД;
	
КонецФункции

Функция ДанныеТочкиДоставкиПоПредставлению(ДанныеТДВладельца, ПредставлениеАдреса)
	
	ДанныеТД = Неопределено;
	
	Если НЕ ПустаяСтрока(ПредставлениеАдреса) Тогда
		
		Отбор = Новый Структура;
		Отбор.Вставить("Адрес", ПредставлениеАдреса);
		Отбор.Вставить("ИдентификаторАдреса", "");
		Отбор.Вставить("ИдентификаторТочкиДоставки", "");
		
		Строки = ДанныеТДВладельца.НайтиСтроки(Отбор);
		
		Если Строки.Количество() > 0 Тогда
			
			ДанныеТД = Строки[0];
			ДанныеТД.ПодобранаПоАдресу = Истина;
			
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат ДанныеТД;
	
КонецФункции

Процедура ДобавитьДанныеДляИзменения(ДанныеТочекДляИзменения, ДанныеТочки)
	
	ДанныеТД = ДанныеТочекДляИзменения.Добавить();
	ЗаполнитьЗначенияСвойств(ДанныеТД, ДанныеТочки);
	
КонецПроцедуры

Процедура ДобавитьДанныеДляИзмененияНесколькоОсновных(ДанныеКОбработке, ДанныеТочекВладельца, ДанныеОсновногоАдреса, ОсновнаяТДИзменена)
	
	ДанныеСуществующейТД = ДанныеТочкиДоставкиПоДаннымАдреса(ДанныеТочекВладельца, ДанныеОсновногоАдреса);
	
	Если ДанныеСуществующейТД <> Неопределено Тогда
		
		Если ДанныеСуществующейТД.ОсновнаяТочка Тогда
			
			ТребуетсяОбновление = Истина;
			ОсновнаяТДИзменена = Истина;
			
		ИначеЕсли ДанныеСуществующейТД.НеИспользуется Тогда
			
			ТребуетсяОбновление = Истина;
			
		Иначе
			
			ТребуетсяОбновление = Ложь;
			
		КонецЕсли;
		
		Если ТребуетсяОбновление Тогда
			
			ДанныеСуществующейТД.ОсновнаяТочка = Ложь;
			ДанныеСуществующейТД.НеИспользуется = Ложь;
			ДанныеСуществующейТД.НесколькоОсновныхАдресов = Истина;
			
			ДобавитьДанныеДляИзменения(ДанныеКОбработке, ДанныеСуществующейТД);
			
		КонецЕсли;
		
	Иначе
		
		ДанныеТД = ДанныеКОбработке.Добавить();
		ДанныеТД.НесколькоОсновныхАдресов = Истина;
		ЗаполнитьДанныеТочкиДоставкиДаннымиАдреса(ДанныеТД, ДанныеОсновногоАдреса);
		
	КонецЕсли;
	
КонецПроцедуры

Процедура ДобавитьДанныеДляИзмененияОднойОсновной(ДанныеКОбработке, ДанныеТочекВладельца, ДанныеОсновногоАдреса, ДанныеОсновнойТД)
	
	ЭтоАдресОсновнойТД = АдресСоответствуетОсновнойТочкеДоставки(ДанныеОсновногоАдреса, ДанныеОсновнойТД);
	
	Если ЭтоАдресОсновнойТД Тогда
		
		ДанныеОсновнойТД.АктуализацияОсновнойТочки = Истина;
		Если Не АдресаРавны(ДанныеОсновнойТД, ДанныеОсновногоАдреса) Тогда
			
			ЗаполнитьДанныеТочкиДоставкиДаннымиАдреса(ДанныеОсновнойТД, ДанныеОсновногоАдреса, Истина);
			ДобавитьДанныеДляИзменения(ДанныеКОбработке, ДанныеОсновнойТД);
			
		КонецЕсли;
		
	Иначе
		
		ТочкаПоОсновномуАдресу = ДанныеТочкиДоставкиПоДаннымАдреса(ДанныеТочекВладельца, ДанныеОсновногоАдреса);
		
		Если Не ЗначениеЗаполнено(ТочкаПоОсновномуАдресу)
			Или Не ТочкаПоОсновномуАдресу.ОсновнаяТочка Тогда
			
			ДанныеОсновнойТД.ОсновнаяТочка = Ложь;
			ДобавитьДанныеДляИзменения(ДанныеКОбработке, ДанныеОсновнойТД);
			
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

Процедура ЗаполнитьДанныеТочкиДоставкиДаннымиАдреса(ДанныеТД, ДанныеАдреса, Основная = Ложь)
	
	Если Не ЗначениеЗаполнено(ДанныеТД.ТочкаДоставки) Тогда
		
		ЗаполнитьЗначенияСвойств(ДанныеТД, ДанныеАдреса);
		ДанныеТД.Наименование = НаименованиеТочкиДоставкиПоДаннымАдреса(ДанныеАдреса);
		
	Иначе
		
		ЗаполнитьЗначенияСвойств(ДанныеТД, ДанныеАдреса,, "ЗонаДоставки");
		
		Если (ДанныеТД.АктуализацияОсновнойТочки
				И Не ДанныеТД.ИдентификаторПереопределен)
			Или (Не ДанныеТД.НесколькоОсновныхАдресов
				И ДанныеТД.ПодобранаПоИдентификатору) Тогда
			
			ДанныеТД.Наименование = НаименованиеТочкиДоставкиПоДаннымАдреса(ДанныеАдреса);
			
		КонецЕсли;
		
	КонецЕсли;
	
	ДанныеТД.ИдентификаторАдреса = ДанныеАдреса.Идентификатор;
	ДанныеТД.ОсновнаяТочка = Основная;
	Если Основная Тогда
		
		ДанныеТД.НеИспользуется = Ложь;
		
	КонецЕсли;
	
КонецПроцедуры

Функция НаименованиеТочкиДоставкиПоДаннымАдреса(ДанныеАдреса)
	
	Если Не ПустаяСтрока(ДанныеАдреса.АдресЗначение)
		И ЗначениеЗаполнено(ДанныеАдреса.Идентификатор) Тогда
		
		НаименованиеТочкиДоставки = ДоставкаТоваровЛокализация.НаименованиеТочкиДоставкиПоАдресу(
			ДанныеАдреса.Адрес,
			ДанныеАдреса.АдресЗначение,
			Ложь);
		
	Иначе
		
		НаименованиеТочкиДоставки = ДанныеАдреса.Адрес;
		
	КонецЕсли;
	
	Возврат НаименованиеТочкиДоставки;
	
КонецФункции

// Параметры:
//  ДанныеКОбработке - см. НовыеДанныеТочекДоставки
//  ДанныеАдреса - СтрокаТаблицыЗначений из см. НовыеДанныеАдресов
//  ДанныеТочекВладельца - см. НовыеДанныеТочекДоставки
//
Процедура СменитьОсновнуюТочкуДоставки(ДанныеКОбработке, ДанныеАдреса, ДанныеТочекВладельца)
	
	ДанныеСуществующейТД = ДанныеТочкиДоставкиПоДаннымАдреса(ДанныеТочекВладельца, ДанныеАдреса);
	
	Если ДанныеСуществующейТД <> Неопределено Тогда
		
		Если ДанныеСуществующейТД.ИдентификаторПереопределен
			Или Не ПустаяСтрока(ДанныеСуществующейТД.ИдентификаторТочкиДоставки)
			Или Не ДанныеСуществующейТД.ОсновнаяТочка Тогда
			
			ДанныеИзменены = Истина;
			
		Иначе
			
			ДанныеИзменены = Не АдресаРавны(ДанныеСуществующейТД, ДанныеАдреса);
			
		КонецЕсли;
		
		Если ДанныеИзменены Тогда
			
			ДанныеСуществующейТД.ИдентификаторПереопределен = Ложь;
			ДанныеСуществующейТД.ИдентификаторТочкиДоставки = "";
			
			ЗаполнитьДанныеТочкиДоставкиДаннымиАдреса(ДанныеСуществующейТД, ДанныеАдреса, Истина);
			ДобавитьДанныеДляИзменения(ДанныеКОбработке, ДанныеСуществующейТД);
			
		КонецЕсли;
		
	Иначе
		
		ДанныеНовойТД = ДанныеКОбработке.Добавить();
		ЗаполнитьДанныеТочкиДоставкиДаннымиАдреса(ДанныеНовойТД, ДанныеАдреса, Истина);
		
	КонецЕсли;
	
КонецПроцедуры

Функция АдресСоответствуетОсновнойТочкеДоставки(ДанныеАдреса, ДанныеОсновнойТД)
	
	ЭтоАдресОсновнойТочки = Ложь;
	
	Если ЗначениеЗаполнено(ДанныеАдреса.Идентификатор) Тогда
		
		ЭтоАдресОсновнойТочки = (ДанныеАдреса.Идентификатор = ДанныеОсновнойТД.ИдентификаторАдреса);
		
	Иначе
		
		ЭтоАдресОсновнойТочки = (СтрСравнить(ДанныеАдреса.Адрес, ДанныеОсновнойТД.Адрес) = 0);
		
	КонецЕсли;
	
	Возврат ЭтоАдресОсновнойТочки;
	
КонецФункции

Функция КомментарийВерсииТочкиДоставки(НоваяТочка, ДанныеТочки, ПереходНаДоставку25)
	
	Доставка20 = ДоставкаТоваровКлиентСервер.ИспользуетсяДоставка20();
	
	ТекстПереход = НСтр("ru = 'Точка доставки создана при переходе на версию Доставки 2.5'");
	ТекстОсновная = НСтр("ru = 'Точка доставки записана по данным адреса владельца'");
	ТекстОсновная20 = НСтр("ru = 'Точка доставки записана по данным адреса владельца (версия Доставки 2.0)'");
	ТекстСтараяОсновная = НСтр("ru = 'Адрес владельца изменен, не соответствует текущему адресу точки доставки'");
	ТекстСтараяОсновная20 = НСтр("ru = 'Адрес владельца изменен, не соответствует текущему адресу точки доставки (версия Доставки 2.0)'");
	
	КомментарийВерсии = "";
	
	Если ПереходНаДоставку25 Тогда
		
		КомментарийВерсии = ТекстПереход;
		
	ИначеЕсли Доставка20
		И Не ДанныеТочки.НесколькоОсновныхАдресов Тогда
		
		Если НоваяТочка
			Или ДанныеТочки.ПодобранаПоИдентификатору
			Или ДанныеТочки.ПодобранаПоАдресу Тогда
			
			КомментарийВерсии = ТекстОсновная20;
			
		ИначеЕсли Не ДанныеТочки.ОсновнаяТочка Тогда
			
			КомментарийВерсии = ТекстСтараяОсновная20;
			
		КонецЕсли;
		
	ИначеЕсли Не ДанныеТочки.НесколькоОсновныхАдресов Тогда
		
		Если ДанныеТочки.ОсновнаяТочка Тогда
			
			КомментарийВерсии = ТекстОсновная;
			
		Иначе
			
			КомментарийВерсии = ТекстСтараяОсновная;
			
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат КомментарийВерсии;
	
КонецФункции

#КонецОбласти

#Область Проведение

Процедура ОтменитьПроведениеДокументаДоставки(Документ, Знач ИмяРегистра)
	
	Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(Документ, "Исправление")
	   И Документ.Исправление Тогда
		
		ЗапросПредыдущееИсправление = Новый Запрос;
		ТекстЗапроса =
		"ВЫБРАТЬ
		|	ВЫБОР
		|		КОГДА ИсправленияДокументовСрезПоследних.ПоследнийДокументЦепочки <> НЕОПРЕДЕЛЕНО
		|			ТОГДА ИсправленияДокументовСрезПоследних.ПоследнийДокументЦепочки
		|		ИНАЧЕ ИсправленияДокументовСрезПоследних.ИсправляемыйДокумент
		|	КОНЕЦ КАК ПредыдущееИсправление
		|ИЗ
		|	РегистрСведений.ИсправленияДокументов.СрезПоследних(, ИсправляемыйДокумент = &ИсправляемыйДокумент) КАК ИсправленияДокументовСрезПоследних";
		ЗапросПредыдущееИсправление.Текст = ТекстЗапроса;
		ЗапросПредыдущееИсправление.УстановитьПараметр("ИсправляемыйДокумент", Документ.ИсправляемыйДокумент);
		Выборка = ЗапросПредыдущееИсправление.Выполнить().Выбрать();
		Если Выборка.Следующий() Тогда
			ПредыдущееИсправление = Выборка.ПредыдущееИсправление; // ДокументСсылка
		Иначе
			ПредыдущееИсправление = Документ.ИсправляемыйДокумент;
		КонецЕсли;
		ПредыдущийДокумент = ПредыдущееИсправление.ПолучитьОбъект();
		
	КонецЕсли;
	
	Запрос = Новый Запрос;
	ТекстЗапроса =
	"ВЫБРАТЬ
	|	Доставка.Регистратор КАК Регистратор,
	|	Доставка.НомерСтроки КАК НомерСтроки
	|ИЗ
	|	РегистрНакопления.Доставка КАК Доставка
	|ГДЕ
	|	Доставка.СторнируемыйДокументПланирования = &ДокументПланирования
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	Доставка.Регистратор,
	|	Доставка.НомерСтроки
	|ИЗ
	|	РегистрНакопления.Доставка КАК Доставка
	|ГДЕ
	|	Доставка.Регистратор = &ДокументПланирования";
	
	Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(Документ, "Исправление")
	   И Документ.Исправление Тогда
		
		ТекстВыборкиДвиженияПредыдущегоДокумента =
		"ВЫБРАТЬ
		|	Доставка.Регистратор КАК Регистратор,
		|	Доставка.НомерСтроки КАК НомерСтроки
		|ИЗ
		|	РегистрНакопления.Доставка КАК Доставка
		|ГДЕ
		|	Доставка.Регистратор = &ПредыдущееИсправление
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	Доставка.Регистратор КАК Регистратор,
		|	Доставка.НомерСтроки КАК НомерСтроки
		|ИЗ
		|	РегистрНакопления.Доставка КАК Доставка
		|ГДЕ
		|	Доставка.СторнируемыйДокументПланирования = &ПредыдущееИсправление";
		
		Запрос.УстановитьПараметр("ПредыдущееИсправление", ПредыдущееИсправление);
		
		ТекстЗапроса = ТекстЗапроса
			+ ОбщегоНазначенияУТ.РазделительЗапросовВОбъединении()
			+ ТекстВыборкиДвиженияПредыдущегоДокумента;
		
	КонецЕсли;
	
	Запрос.Текст = ТекстЗапроса;
	Запрос.УстановитьПараметр("ДокументПланирования", Документ.Ссылка);
	ТаблицаУдаляемыхЗаписей = Запрос.Выполнить().Выгрузить();
	Регистраторы = ТаблицаУдаляемыхЗаписей.ВыгрузитьКолонку("Регистратор"); // Массив Из ДокументСсылка
	Регистраторы.Добавить(Документ.Ссылка);
	ЕстьДанныеВТаблице = Ложь;
	
	Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(Документ, "Исправление")
	   И Документ.Исправление Тогда
		
		// Переформировываем движения предыдущего документа цепочки исправлений.
		
		ДопПараметры = ПроведениеДокументов.ДопПараметрыИнициализироватьДанныеДокументаДляПроведения();
		ДопПараметры.ДополнительныеСвойства = ПроведениеДокументов.СвойстваДокумента(Документ);
		ДопПараметры.Вставить("ПредыдущееИсправление", Документ.Ссылка);
		ТаблицыДляДвижений = ПроведениеДокументов.ДанныеДокументаДляПроведения(ПредыдущееИсправление, ИмяРегистра, ДопПараметры);
		ИмяТаблицы = "Таблица" + ИмяРегистра;
		ЕстьДанныеВТаблице = ТаблицыДляДвижений.Свойство(ИмяТаблицы);
		
		Если ЕстьДанныеВТаблице Тогда
			
			ТаблицаДанных = ТаблицыДляДвижений[ИмяТаблицы]; // ТаблицаЗначений
			
			Если ТаблицаДанных.Колонки.Найти("Регистратор") = Неопределено Тогда
				
				ТаблицаДанных.Колонки.Добавить("Регистратор");
				ТаблицаДанных.ЗаполнитьЗначения(ПредыдущееИсправление, "Регистратор");
				
			КонецЕсли;
			
		КонецЕсли;
		
		Если ЕстьДанныеВТаблице Тогда
			
			ТаблицаДанных = ТаблицыДляДвижений[ИмяТаблицы]; // ТаблицаЗначений
			РегистраторыАктуальныхДвижений = ТаблицаДанных.ВыгрузитьКолонку("Регистратор"); // Массив Из ДокументСсылка
			ОбщегоНазначенияКлиентСервер.ДополнитьМассив(Регистраторы, РегистраторыАктуальныхДвижений, Истина);
			
		КонецЕсли;
		
	КонецЕсли;
	
	Если ТаблицаУдаляемыхЗаписей.Количество() > 0 Тогда
		
		НаборЗаписейУдаляемый = РегистрыНакопления[ИмяРегистра].СоздатьНаборЗаписей();
		МенеджерВТ = ПроведениеДокументов.МенеджерВременныхТаблицКонтроля(Документ);
		ПроведениеДокументов.УстановитьДопСвойстваРегистра(НаборЗаписейУдаляемый, Документ, МенеджерВТ, Истина);
		НаборЗаписейУдаляемый.ДополнительныеСвойства.Вставить("Регистраторы", Регистраторы);
		НаборЗаписейУдаляемый.ДополнительныеСвойства.Вставить("ФиксироватьИзмененияПослеЗаписи", НЕ ЕстьДанныеВТаблице);
		НаборЗаписейУдаляемый.ДополнительныеСвойства.Вставить("НеОтражатьВБюджетировании", Истина);
		НаборЗаписейУдаляемый.РасширенныеРежимыЗамещения = Истина;
		НаборЗаписейУдаляемый.Отбор.Регистратор.Установить(, Ложь);
		НаборЗаписейУдаляемый.Загрузить(ТаблицаУдаляемыхЗаписей);
		НаборЗаписейУдаляемый.Записать(РежимЗамещения.Удаление);
		
	КонецЕсли;
	
	Если ЕстьДанныеВТаблице Тогда
		
		НаборЗаписейДобавляемый = РегистрыНакопления[ИмяРегистра].СоздатьНаборЗаписей();
		МенеджерВТ = ПроведениеДокументов.МенеджерВременныхТаблицКонтроля(Документ);
		ПроведениеДокументов.УстановитьДопСвойстваРегистра(НаборЗаписейДобавляемый, Документ, МенеджерВТ, Истина);
		НаборЗаписейДобавляемый.ДополнительныеСвойства.Вставить("ФиксироватьИзмененияПослеЗаписи", Истина);
		НаборЗаписейДобавляемый.ДополнительныеСвойства.Вставить("Регистраторы", Регистраторы);
		НаборЗаписейДобавляемый.ДополнительныеСвойства.Вставить("НеОтражатьВБюджетировании", Истина);
		НаборЗаписейДобавляемый.РасширенныеРежимыЗамещения = Истина;
		НаборЗаписейДобавляемый.Отбор.Регистратор.Установить(, Ложь);
		НаборЗаписейДобавляемый.Загрузить(ТаблицаДанных);
		НаборЗаписейДобавляемый.Записать(РежимЗамещения.Добавление);
	
	КонецЕсли;
	
КонецПроцедуры

Функция ПредыдущиеУровниОперации(ТекущийУровеньОперации)
	
	Результат = Новый Массив; // Массив Из Число
	
	Если ТекущийУровеньОперации = 20 Тогда
		
		Результат.Добавить(10);
		
	КонецЕсли;
	
	Если ТекущийУровеньОперации = 30 Тогда
		
		Результат.Добавить(20);
		Результат.Добавить(15);
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция СледующиеУровниОперации(ТекущийУровеньОперации, ЕстьСтрокиТоваровИзменениеТолькоУпаковки = Ложь)
	
	Результат = Новый Массив; // Массив Из Число
	
	Если ТекущийУровеньОперации = 10 Тогда
		
		Результат.Добавить(20);
		
	КонецЕсли;
	
	Если ТекущийУровеньОперации = 15 Тогда
		
		Результат.Добавить(30);
		
	КонецЕсли;
	
	Если ТекущийУровеньОперации = 20
	   И ЕстьСтрокиТоваровИзменениеТолькоУпаковки Тогда
		
		Результат.Добавить(30);
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

