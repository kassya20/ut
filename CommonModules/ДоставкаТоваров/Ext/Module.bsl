	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&ТаблицаДанных", "#" + СинонимТаблицыДокумента);
	
КонецПроцедуры

Процедура ПодставитьДополнительныеПоляВШаблоны(ТекстыШаблонов, ДополнительныеПоля)
	
	Для Индекс = 0 По ТекстыШаблонов.ВГраница() Цикл
		
		ТекстыШаблонов[Индекс] = СтрЗаменить(ТекстыШаблонов[Индекс], "&ДополнительныеПоля", ДополнительныеПоля);
		
	КонецЦикла;
	
КонецПроцедуры

