// Подсистема "ИнтернетПоддержкаПользователей.ПлатежныеСистемы.ОзонПэй".
// ОбщийМодуль.ОзонПэйСлужебный.
//
// Серверные процедуры обмена данными с платежной системой Озон Пэй:
//  - выполнение оплаты и возвратов оплаты;
//  - добавление записи в журнал регистрации.
//
///////////////////////////////////////////////////////////////////////////////////////////////////////

#Область СлужебныйПрограммныйИнтерфейс

#Область НастройкиПодключения

// Формирует декларативное описание реквизитов аутентификации в сервисах Озон Пэй.
//
// Возвращаемое значение:
//  Массив из см. ПлатежныеСистемыСлужебный.НовыйОписаниеРеквизитов
//
Функция РеквизитыНастройкиАутентификации() Экспорт
	
	Результат = Новый Массив();	// Массив из см. ПлатежныеСистемыСлужебный.НовыйОписаниеРеквизитов
	
	// Токен
	ОписаниеРеквизита = ПлатежныеСистемыСлужебный.НовыйОписаниеРеквизитов(
		"Токен",
		НСтр("ru = 'ID токена'"),
		ОбщегоНазначения.ОписаниеТипаСтрока(100));
	ОписаниеРеквизита.РежимПароля = Ложь;
	ОписаниеРеквизита.Подсказка = НСтр("ru = 'ID токена из личного кабинета'");
	ОписаниеРеквизита.ПроверкаЗаполнения = Истина;
	
	Результат.Добавить(ОписаниеРеквизита);
	
	// Секретный ключ
	ОписаниеРеквизита = ПлатежныеСистемыСлужебный.НовыйОписаниеРеквизитов(
		"СекретныйКлюч",
		НСтр("ru = 'Секретный ключ'"),
		ОбщегоНазначения.ОписаниеТипаСтрока(100));
	ОписаниеРеквизита.РежимПароля = Истина;
	ОписаниеРеквизита.Подсказка = НСтр("ru = 'Секретный ключ из личного кабинета'");
	ОписаниеРеквизита.ПроверкаЗаполнения = Истина;
	
	Результат.Добавить(ОписаниеРеквизита);
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти

#Область ОписаниеПодсистемы

// Получает данные подсказки для платежной системе из сервиса.
//
// Параметры:
//  ОписанияПлатежныхСистем - см. ПлатежныеСистемыСервис.ОписанияПлатежныхСистем
// 
// Возвращаемое значение:
//  см. ПлатежныеСистемыСлужебный.ПодсказкиПлатежнойСистемы
//
Функция ПодсказкиПлатежнойСистемы(ОписанияПлатежныхСистем) Экспорт
	
	Результат = ПлатежныеСистемыСлужебный.НовыйРезультатОперации();
	Результат.Вставить("Описание", "");
	Результат.Вставить("Подключение", "");
	
	ОписаниеСистемы = ОписанияПлатежныхСистем.Получить(Перечисления.ПлатежныеСервисы.ОзонПэй);
	Если ОписаниеСистемы = Неопределено Тогда
		ОписаниеСистемы = ОписаниеПоУмолчанию();
	КонецЕсли;
	
	ЗаполнитьЗначенияСвойств(Результат, ОписаниеСистемы);
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти

#Область ПрикладныеОперации

// См. ПлатежныеСистемы.ВозвратОплаты
//
Функция ВозвратОплаты(
		ДокументВозврата,
		ДокументОплаты,
		НастройкаПодключения,
		ДополнительныеПараметры) Экспорт
	
	Результат = ПлатежныеСистемыСлужебный.НовыйРезультатСтатусОперации();
	СписокСвойствОшибки = "КодОшибки,СообщениеОбОшибке,ИнформацияОбОшибке";
	
	ДанныеЗаказа = ДанныеЗаказаНаВозврат(
		ДокументВозврата,
		ДокументОплаты,
		НастройкаПодключения,
		ДополнительныеПараметры);
		
	Если ДанныеЗаказа.КодОшибки = НастройкиПлатежныхСистемСлужебный.КодОшибкиОперацияВыполняется()
		Или ДанныеЗаказа.КодОшибки = НастройкиПлатежныхСистемСлужебный.КодОшибкиОперацияВыполнена() Тогда
		
		ДанныеОперации = ПлатежныеСистемыСлужебный.ДанныеОперации(ДокументВозврата);
		
		Результат.СтатусОперации = ДанныеОперации.СтатусОперации;
		Результат.ПараметрыОперации.ИдентификаторОперации = ДанныеОперации.ИдентификаторОперации;
		Результат.ПараметрыОперации.ИдентификаторОплаты = ДанныеОперации.ИдентификаторОплаты;
		Результат.ПараметрыОперации.ТипОперации = ПлатежныеСистемыКлиентСервер.ТипОперацииВозврат();
		Результат.ПараметрыОперации.ДатаОперации = ДанныеОперации.ДатаОперации;
		Результат.ПараметрыОперации.СуммаОперации = ДанныеОперации.СуммаОперации;
		
		Возврат Результат;
		
	ИначеЕсли Не ПустаяСтрока(ДанныеЗаказа.КодОшибки) Тогда
		ЗаполнитьЗначенияСвойств(Результат, ДанныеЗаказа, СписокСвойствОшибки);
		Возврат Результат;
	КонецЕсли;
	
	РезультатВозврата = ОзонПэйСервис.ВозвратОплаты(ДанныеЗаказа, НастройкаПодключения);
	Если ПустаяСтрока(РезультатВозврата.КодОшибки) Тогда
		
		ЗаполнитьЗначенияСвойств(
			Результат,
			РезультатВозврата,
			"СтатусОперации");
		ЗаполнитьЗначенияСвойств(
			Результат.ПараметрыОперации,
			РезультатВозврата.ПараметрыОперации);
		
		ДанныеОперации = ПлатежныеСистемыСлужебный.НовыйОбновляемыеДанныеОперации();
		ДанныеОперации.СтатусОперации = РезультатВозврата.СтатусОперации;
		ДанныеОперации.ИдентификаторОперации = РезультатВозврата.ПараметрыОперации.ИдентификаторОперации;
		ДанныеОперации.ДатаОперации = РезультатВозврата.ПараметрыОперации.ДатаОперации;
		ДанныеОперации.СуммаОперации = РезультатВозврата.ПараметрыОперации.СуммаОперации;
		
		РегистрыСведений.ИдентификаторыПлатежныхСистем.ЗаписатьДанныеОперации(ДокументВозврата, ДанныеОперации);
		
	Иначе
		ЗаполнитьЗначенияСвойств(
			Результат,
			РезультатВозврата,
			СписокСвойствОшибки);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти

#Область ОнлайнЗаказы

// Выполняет подготовку параметров оплаты заказа для записи в соответствующие подсистемы.
//
// Параметры:
//  ДанныеЗаказа - Структура - Содержит данные заказа:
//    * ИдентификаторЗаказа - Строка - Идентификатор онлайн-заказа;
//    * Статус - Строка - Статус онлайн-заказа;
//    * СуммаЗаказа - Число - Сумма онлайн-заказа;
//    * СпособОплаты - ПеречислениеСсылка.СпособыОплатыОнлайнЗаказов - Способ оплаты онлайн-заказа;
//    * ДатаОплаты - Дата - дата получения данных об оплате сервисом;
//    * КонтрольнаяСумма - Строка - Значение контрольной суммы заказа;
//    * ВерсияКонтрольнойСуммы - Число - Версия расчета контрольной суммы заказа;
//    * ОплатаСБП - Структура, Неопределено - Содержит данные операции СБП, в том случае когда
//      значение Свойства СпособОплаты = Перечисления.СпособыОплатыОнлайнЗаказов.СБПc2b:
//       ** Идентификатор - Строка - идентификатор операции;
//       ** ИдентификаторОплаты - Строка - идентификатор оплаты в СБП;
//       ** ИдентификаторПлатежнойСистемы - Строка - идентификатор оплаты в Системе быстрых платежей;
//       ** ДатаОперации - Дата - фактическая дата оплаты в UTC;
//       ** ИдентификаторМерчанта - Строка - идентификатор мерчанта в Системе быстрых платежей;
//       ** НазначениеПлатежа - Строка - назначение платежа;
//    * ОплатаИнтернетЭквайринг - Структура, Неопределено - Содержит данные операции, в том случае когда
//      значение свойства СпособОплаты = Перечисления.СпособыОплатыОнлайнЗаказов.Эквайринг:
//       ** Идентификатор - Строка - идентификатор операции;
//       ** ИдентификаторОплаты - Строка - идентификатор операции оплаты;
//       ** ИдентификаторОперации - Строка - идентификатор текущей операции;
//       ** ДатаОперации - Дата - фактическая дата оплаты в UTC;
//       ** ИдентификаторМерчанта - Строка - идентификатор мерчанта;
//       ** НазначениеПлатежа - Строка - назначение платежа;
//    * ОплатаОзонПэй - Структура, Неопределено - Содержит данные операции, в том случае когда
//        значение Свойства СпособОплаты = Перечисления.СпособыОплатыОнлайнЗаказов.ОзонПэй:
//       ** Идентификатор - Строка - идентификатор операции;
//       ** ИдентификаторОплаты - Строка - идентификатор операции оплаты;
//       ** ИдентификаторОперации - Строка - идентификатор текущей операции;
//       ** ДатаОперации - Дата - фактическая дата оплаты в UTC;
//       ** СпособОплаты - Строка - способ оплаты. Доступные значения определяются методами
//            общего модуля ПлатежныеСистемыКлиентСервер.
//  НастройкаПодключения - СправочникСсылка.НастройкиПодключенияКПлатежнымСистемам, Неопределено - Настройка
//    подключения указанная в настройке страницы онлайн-заказов, Неопределено в том случае, если настройка не
//    определена.
//  ПараметрыОплаты - Соответствие Из КлючИЗначение - Содержит параметры оплат в разрезе ее способов.
//
Процедура ЗаполнитьПараметрыОплаты(
	ДанныеЗаказа,
	НастройкаПодключения,
	ПараметрыОплаты) Экспорт
	
	ПараметрыОплатыОзонПэй = ЗаполнитьПараметрыОперации(
		ДанныеЗаказа.ОплатаОзонПэй,
		ДанныеЗаказа.СуммаЗаказа,
		НастройкиПлатежныхСистемКлиентСервер.СтатусОперацииВыполнена(),
		НастройкаПодключения);
	
	ПараметрыОплаты.Вставить(
		"ОзонПэй",
		ПараметрыОплатыОзонПэй);
	
КонецПроцедуры

// Выполняет запись данных оплаты заказа.
//
// Параметры:
//  ДокументОперации - ОпределяемыйТип.ДокументОперацииПлатежнойСистемы - документ по которому была выполнена оплата.
//  ПараметрыОперации - см. ЗаполнитьПараметрыОперации.
//  НастройкаПодключения - СправочникСсылка.НастройкиПодключенияКПлатежнымСистемам - настройка подключения, через
//    которую выполняется оплата.
//
Процедура ЗаписатьДанныеОплаты(
		ДокументОперации,
		ПараметрыОперации,
		НастройкаПодключения) Экспорт
	
	РегистрыСведений.ИдентификаторыПлатежныхСистем.НовыйВнутреннийИдентификаторОперации(
		ДокументОперации,
		НастройкаПодключения,
		Истина,
		ПараметрыОперации.ИдентификаторОплаты);

	РегистрыСведений.ИдентификаторыПлатежныхСистем.ЗаписатьДанныеОперации(
		ДокументОперации,
		ПараметрыОперации);

КонецПроцедуры

// Возвращает данные оплат по документам платежей.
//
// Параметры:
//  ДокументыОпераций - Массив Из ОпределяемыйТип.ДокументОперацииИнтернетЭквайринга - документы операций.
//
// Возвращаемое значение:
//  Соответствие Из КлючИЗначение - данные оплат по документам:
//   * Ключ - ОпределяемыйТип.ДокументОперацииИнтернетЭквайринга - документ операции.
//   * Значение - см. ЗаполнитьПараметрыОперации
//
Функция ДанныеОпераций(ДокументыОпераций) Экспорт
	
	ДанныеОпераций = ПлатежныеСистемыСлужебный.ДанныеОпераций(ДокументыОпераций);
	
	Результат = Новый Соответствие;
	
	Выборка = ДанныеОпераций.Выбрать();
	
	Для Каждого ДокументОперации Из ДокументыОпераций Цикл
	
		Если Выборка.НайтиСледующий(Новый Структура("ДокументОперации", ДокументОперации)) = Ложь Тогда

			Результат.Вставить(
				ДокументОперации,
				Неопределено);
		Иначе
			
			ПараметрыОперации = ЗаполнитьПараметрыОперации(
				Выборка,
				Выборка.СуммаОперации,
				Выборка.СтатусОперации,
				Выборка.НастройкаПодключения);
			
			Результат.Вставить(
				ДокументОперации,
				ПараметрыОперации);
				
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

#Область ОнлайнЗаказы

// Подготавливает и возвращает параметры операции для передачи в отложенный обработчик.
//
// Параметры:
//  ДанныеОперации - Структура, ВыборкаИзРезультатаЗапроса - Содержит данные операции:
//    * Идентификатор - Строка - идентификатор операции;
//    * ИдентификаторОплаты - Строка - идентификатор операции оплаты;
//    * ИдентификаторОперации - Строка - идентификатор текущей операции;
//    * ДатаОперации - Дата - фактическая дата оплаты в UTC;
//    * СпособОплаты - Строка - способ оплаты.Доступные значения определяются методами
//        общего модуля ПлатежныеСистемыКлиентСервер.
//  СуммаОперации - Число - сумма операции.
//  СтатусОперации - Строка - текущий статус операции.
//  НастройкаПодключения - СправочникСсылка.НастройкиПодключенияКПлатежнымСистемам - настройка подключения.
//
// Возвращаемое значение:
// Структура - Содержит данные операции, в том случае когда
//     СпособОплаты = Перечисления.СпособыОплатыОнлайнЗаказов.ОзонПэй:
//   * НастройкаПодключения - СправочникСсылка.НастройкиПодключенияКПлатежнымСистемам - настройка подключения.
//   * РезультатОбработки - Структура - содержит результаты обработки статуса операции:
//     ** СтатусОперации - Строка - текущее состояние операции оплаты. Возможные значения:
//         - "Выполняется" - подтверждение оплаты не получено;
//         - "Отменена" - оплата по ранее сформированной ссылке невозможна;
//         - "Выполнена" - участник Интернет-эквайринга подтвердил оплату;
//         - "Отклонена" - оплата по ранее сформированной ссылке невозможна;
//         - "Ошибка" - неизвестный статус операции.
//     ** ПараметрыОперации - см. ПлатежныеСистемыСлужебный.НовыйОбновляемыеДанныеОперации.
//     ** СообщениеОбОшибке - Строка - информация об ошибке
//
Функция ЗаполнитьПараметрыОперации(
		ДанныеОперации,
		СуммаОперации,
		СтатусОперации,
		НастройкаПодключения)
	
	ПараметрыОперации = ПлатежныеСистемыСлужебный.НовыйОбновляемыеДанныеОперации();
	
	ПараметрыОперации.ИдентификаторОплаты = ДанныеОперации.ИдентификаторОплаты;
	ПараметрыОперации.ИдентификаторОперации  = ДанныеОперации.ИдентификаторОперации;
	ПараметрыОперации.СтатусОперации = СтатусОперации;
	ПараметрыОперации.СуммаОперации = СуммаОперации;
	ПараметрыОперации.ДатаОперации = ДанныеОперации.ДатаОперации;
	ПараметрыОперации.ДатаЗапросаСтатуса = ТекущаяДатаСеанса();
	ПараметрыОперации.СпособОплаты = ДанныеОперации.СпособОплаты;
	
	РезультатОбработки = Новый Структура;
	РезультатОбработки.Вставить("ПараметрыОперации", ПараметрыОперации);
	РезультатОбработки.Вставить("СообщениеОбОшибке", "");
	РезультатОбработки.Вставить("СтатусОперации",    СтатусОперации);

	ПараметрыОплаты = Новый Структура(
		"НастройкаПодключения, РезультатОбработки",
		НастройкаПодключения,
		РезультатОбработки);
	
	Возврат ПараметрыОплаты;
	
КонецФункции

#КонецОбласти

#Область ВозвратОплаты

// Формирует и заполняет новое описание запроса на возврат оплаты и определяет внутренний идентификатор заказа.
//
// Параметры:
//  ДокументВозврата - ОпределяемыйТип.ДокументОперацииПлатежнойСистемы - документ, который отражает возврат оплаты в
//    информационной базе.
//  ДокументОплаты - ОпределяемыйТип.ДокументОперацииПлатежнойСистемы - документ, который отражает оплату в
//    информационной базе.
//  НастройкаПодключения - СправочникСсылка.НастройкиПодключенияКПлатежнымСистемам - настройка подключения к сервису.
//  ДополнительныеПараметры - Структура, Неопределено - дополнительные настройки формирования заказа на возврат оплаты.
//
// Возвращаемое значение:
//  Структура - содержит результат подготовки заказа на возврат оплаты:
//    * КодОшибки - Строка - строковый код возникшей ошибки.
//        Возможные значения см. НастройкиПлатежныхСистемСлужебный.ПереопределитьКодОшибкиСервиса
//    * СообщениеОбОшибке - Строка, ФорматированнаяСтрока - сообщение об ошибке для пользователя.
//    * ИнформацияОбОшибке - Строка, ФорматированнаяСтрока - сообщение об ошибке для администратора.
//    * ЗаказНаВозврат - Неопределено - ошибка формирования данных заказа на возврат оплаты.
//                     - см. НовыйЗаказНаВозврат
//    * Идентификатор - Строка - внутренний идентификатор заказа на оплату.
//    * ИдентификаторОплаты - Строка - идентификатор операции в платежной системе.
//    * КоличествоПопыток - Число -  количество неудачно выполненных операций.
//
Функция ДанныеЗаказаНаВозврат(
		ДокументВозврата,
		ДокументОплаты,
		НастройкаПодключения,
		ДополнительныеПараметры)
	
	Результат = ПлатежныеСистемыСлужебный.НовыйРезультатОперации();
	Результат.Вставить("ЗаказНаВозврат", Неопределено);
	Результат.Вставить("Идентификатор", "");
	Результат.Вставить("ИдентификаторОплаты", "");
	Результат.Вставить("КоличествоПопыток", 0);
	
	СписокСвойствОшибки = "КодОшибки,СообщениеОбОшибке,ИнформацияОбОшибке";
	ЗаказНаВозврат = НовыйЗаказНаВозврат();
	
	ИнтеграцияПодсистемБИП.ПриФормированииЗаказаНаВозвратОзонПэй(
		ДокументВозврата,
		ЗаказНаВозврат,
		НастройкаПодключения,
		ДополнительныеПараметры);
	ОзонПэйПереопределяемый.ПриФормированииЗаказаНаВозврат(
		ДокументВозврата,
		ЗаказНаВозврат,
		НастройкаПодключения,
		ДополнительныеПараметры);
	
	РезультатПроверки = ПроверитьЗаказНаВозврат(ЗаказНаВозврат);
	Если Не ПустаяСтрока(РезультатПроверки.КодОшибки) Тогда
		ЗаполнитьЗначенияСвойств(Результат, РезультатПроверки, СписокСвойствОшибки);
		Возврат Результат;
	КонецЕсли;
	
	// Определение внутреннего идентификатора операции и сохранение данных операции Озон Пэй выполняется в транзакции.
	НачатьТранзакцию();
	Попытка
		
		// Блокировка используемых данных
		Блокировка = Новый БлокировкаДанных();
		РегистрыСведений.ИдентификаторыПлатежныхСистем.ДобавитьБлокировкуИдентификаторовПлатежнойСистемы(
			Блокировка,
			ДокументВозврата);
		Блокировка.Заблокировать();
		
		ДанныеИдентификаторов = ОпределитьИдентификаторыЗаказаНаВозврат(
			ДокументВозврата,
			ДокументОплаты,
			НастройкаПодключения,
			ЗаказНаВозврат);
		Если ПустаяСтрока(ДанныеИдентификаторов.КодОшибки) Тогда
			
			Результат.ЗаказНаВозврат = ЗаказНаВозврат;
			Результат.Идентификатор = ДанныеИдентификаторов.Идентификатор;
			Результат.ИдентификаторОплаты = ДанныеИдентификаторов.ИдентификаторОплаты;
			Результат.КоличествоПопыток = ДанныеИдентификаторов.КоличествоПопыток;
			
		Иначе
			ЗаполнитьЗначенияСвойств(Результат, ДанныеИдентификаторов, СписокСвойствОшибки);
		КонецЕсли;
		
		ЗафиксироватьТранзакцию();
		
	Исключение
		
		ОтменитьТранзакцию();
		
		ИнформацияОбОшибке = ИнформацияОбОшибке();
		ПлатежнаяСистема   = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(НастройкаПодключения, "ПлатежнаяСистема");
		
		Результат.КодОшибки          = НастройкиПлатежныхСистемСлужебный.КодОшибкиНеизвестнаяОшибка();
		Результат.СообщениеОбОшибке  = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
			НСтр("ru = 'Ошибка определения внутреннего идентификатора.
				|%1'"),
			ОбработкаОшибок.КраткоеПредставлениеОшибки(ИнформацияОбОшибке));
		Результат.ИнформацияОбОшибке = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
			НСтр("ru = 'Ошибка определения внутреннего идентификатора для документа.
				|%1
				|
				|Техническая информация об ошибке:
				|Документ операции: %2
				|Платежная система: %3
				|Подробная информация:
				|%4'"),
			ОбработкаОшибок.КраткоеПредставлениеОшибки(ИнформацияОбОшибке),
			Строка(ДокументВозврата),
			Строка(ПлатежнаяСистема),
			ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке));
		
		ПлатежныеСистемыСлужебный.ЗаписатьИнформациюВЖурналРегистрации(
			Результат.ИнформацияОбОшибке,
			Истина);
		
	КонецПопытки;
	
	Возврат Результат;
	
КонецФункции

// Описание нового объекта заказа на возврат.
// Заполняется в методе см. ОзонПэйПереопределяемый.ПриФормированииЗаказаНаВозврат.
//
// Возвращаемое значение:
//  Структура:
//    * ДатаОперации - Дата - дата операции возврата.
//    * СуммаВозврата - Число - сумма к возврату.
//
Функция НовыйЗаказНаВозврат()
	
	Результат = Новый Структура();
	Результат.Вставить("ДатаОперации" , '00010101');
	Результат.Вставить("СуммаВозврата", 0);
	
	Возврат Результат;
	
КонецФункции

// Производит валидацию параметров заказа на возврат оплаты в платежной системе Озон Пэй.
//
// Параметры:
//  ЗаказНаВозврат - см. НовыйЗаказНаВозврат
//
// Возвращаемое значение:
//   Структура:
//    * КодОшибки - Строка - строковый код возникшей ошибки.
//        Возможные значения:
//          "" - нет ошибок.
//          см. НастройкиПлатежныхСистемСлужебный.КодОшибкиНеверныйФорматЗапроса - заказ на оплату содержит ошибки.
//    * СообщениеОбОшибке - Строка, ФорматированнаяСтрока - сообщение об ошибке для пользователя.
//    * ИнформацияОбОшибке - Строка, ФорматированнаяСтрока - сообщение об ошибке для администратора.
//
Функция ПроверитьЗаказНаВозврат(ЗаказНаВозврат)
	
	Результат = ПлатежныеСистемыСлужебный.НовыйРезультатОперации();
	Ошибки = Новый Массив(); // Массив из Строка
	
	Если Не ЗначениеЗаполнено(ЗаказНаВозврат.ДатаОперации) Тогда
		Ошибки.Добавить(НСтр("ru = '- не заполнено поле ""Дата операции""'"));
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(ЗаказНаВозврат.СуммаВозврата) Тогда
		Ошибки.Добавить(НСтр("ru = '- не заполнено поле ""Сумма возврата""'"));
	КонецЕсли;
	
	Если Ошибки.Количество() > 0 Тогда
		
		Результат.КодОшибки = НастройкиПлатежныхСистемСлужебный.КодОшибкиНеверныйФорматЗапроса();
		Результат.СообщениеОбОшибке  = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
			НСтр("ru = 'Некорректно сформирован заказ на возврат:
				|%1'"),
			СтрСоединить(Ошибки, Символы.ПС));
		Результат.ИнформацияОбОшибке = Результат.СообщениеОбОшибке;
		
		ПлатежныеСистемыСлужебный.ЗаписатьИнформациюВЖурналРегистрации(Результат.ИнформацияОбОшибке, Истина);
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Формирует новые идентификаторы заказа на возврат оплаты или получает существующие.
//
// Параметры:
//  ДокументВозврата - ОпределяемыйТип.ДокументОперацииПлатежнойСистемы - документ, который отражает возврат оплаты в
//    информационной базе.
//  ДокументОплаты - ОпределяемыйТип.ДокументОперацииПлатежнойСистемы - документ, который отражает оплату в
//    информационной базе.
//  НастройкаПодключения - СправочникСсылка.НастройкиПодключенияКПлатежнымСистемам - настройка подключения к сервису.
//  ЗаказНаВозврат - см. НовыйЗаказНаВозврат
//
// Возвращаемое значение:
//  Структура:
//    * КодОшибки - Строка - строковый код возникшей ошибки.
//        Возможные значения см. НастройкиПлатежныхСистемСлужебный.ПереопределитьКодОшибкиСервиса.
//    * СообщениеОбОшибке - Строка, ФорматированнаяСтрока - сообщение об ошибке для пользователя.
//    * ИнформацияОбОшибке - Строка, ФорматированнаяСтрока - сообщение об ошибке для администратора.
//    * Идентификатор - Строка - внутренний идентификатор операции.
//    * ИдентификаторОплаты - Строка - идентификатор оплаты в платежной системе.
//    * ОбновитьДанныеОперации - Булево - Истина, если необходимо обновить данные операции.
//    * КоличествоПопыток - Число - количество неудачно выполненных операций.
//
Функция ОпределитьИдентификаторыЗаказаНаВозврат(
		ДокументВозврата,
		ДокументОплаты,
		НастройкаПодключения,
		ЗаказНаВозврат)
	
	Результат = ПлатежныеСистемыСлужебный.НовыйРезультатОперации();
	Результат.Вставить("Идентификатор"         , "");
	Результат.Вставить("ИдентификаторОплаты"   , "");
	Результат.Вставить("ОбновитьДанныеОперации", Ложь);
	Результат.Вставить("КоличествоПопыток"     , 0);
	
	СписокСвойствОшибки = "КодОшибки,СообщениеОбОшибке,ИнформацияОбОшибке";
	ИдентификаторОплаты = РегистрыСведений.ИдентификаторыПлатежныхСистем.ИдентификаторОплаты(ДокументОплаты);
	ПараметрыСтатуса = ПлатежныеСистемыСлужебный.ПараметрыОпределенияСтатусаОперации(ДокументВозврата);
	
	Если ПустаяСтрока(ИдентификаторОплаты) Тогда
		
		Результат.КодОшибки = НастройкиПлатежныхСистемСлужебный.КодОшибкиНеверныйФорматЗапроса();
		Результат.СообщениеОбОшибке  = НСтр("ru = 'Не найден идентификатор документа оплаты.
			|Обратитесь к администратору.'");
		Результат.ИнформацияОбОшибке = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
			НСтр("ru = 'Не найден идентификатор документа оплаты %1.'"),
			Строка(ДокументОплаты));
		
		ПлатежныеСистемыСлужебный.ЗаписатьИнформациюВЖурналРегистрации(Результат.ИнформацияОбОшибке);
		
		Возврат Результат;
		
	// Если первая итерация или уже получен отрицательный терминальный статус, то дополнительных проверок не требуется.
	ИначеЕсли ПараметрыСтатуса = Неопределено
		Или (Не ПараметрыСтатуса.Оплата
			И ПараметрыСтатуса.СтатусОперации = НастройкиПлатежныхСистемКлиентСервер.СтатусОперацииОтменена()) Тогда
		
		Результат.ОбновитьДанныеОперации = Истина;
		Результат.ИдентификаторОплаты    = ИдентификаторОплаты;
		Результат.Идентификатор = РегистрыСведений.ИдентификаторыПлатежныхСистем.НовыйВнутреннийИдентификаторОперации(
			ДокументВозврата,
			НастройкаПодключения,
			Ложь,
			Результат.ИдентификаторОплаты);
		
		Возврат Результат;
		
	// Если по документу ранее была сформирована оплата, делать по нему возврат запрещено.
	// Необходимо получить статус оплаты, а для возврата сформировать новый документ.
	ИначеЕсли ПараметрыСтатуса.Оплата Тогда
		
		Результат.КодОшибки          = НастройкиПлатежныхСистемСлужебный.КодОшибкиНеверныйФорматЗапроса();
		Результат.СообщениеОбОшибке  = НСтр(
			"ru = 'Для документа ранее был сформирована оплата, создание нового возврата запрещено.'");
		Результат.ИнформацияОбОшибке = Результат.СообщениеОбОшибке;
		
		Возврат Результат;
		
	КонецЕсли;
	
	// На момент разработки, Озон Пэй проверяет идемпотентность только по идентификатору. В связи с этим, если 
	// возврат выполнен успешно, но до получения ответа был разрыв связи, то можно изменить сумму возврата, отправить
	// запрос с тем же идентификатором и получить ответ 200, который относится к предыдущим данным.
	// В связи с этим выполняем анализ актуального статуса заказа в сервисе и проверяем идентичность данных
	// текущего заказа с ранее отправленным данными заказа.
	УстановитьПривилегированныйРежим(Истина);
	АнализИсторическихДанных = АнализИсторическихДанныхВозврата(
		ДокументВозврата,
		НастройкаПодключения,
		ЗаказНаВозврат);
	УстановитьПривилегированныйРежим(Ложь);
	
	// Обновление статуса операции возврата
	РезультатПроверки = ПлатежныеСистемыСлужебный.СтатусОперации(ДокументВозврата, 0, Ложь);
	
	// Заказ на возврат в сервисе отсутствует или операция отменена
	Если РезультатПроверки.КодОшибки = НастройкиПлатежныхСистемСлужебный.КодОшибкиОбъектНеНайден()
		Или РезультатПроверки.СтатусОперации = НастройкиПлатежныхСистемКлиентСервер.СтатусОперацииОтменена() Тогда
		
		Результат.ОбновитьДанныеОперации = Истина;
		Результат.ИдентификаторОплаты = ИдентификаторОплаты;
		Результат.Идентификатор = РегистрыСведений.ИдентификаторыПлатежныхСистем.НовыйВнутреннийИдентификаторОперации(
			ДокументВозврата,
			НастройкаПодключения,
			Ложь,
			Результат.ИдентификаторОплаты,
			Истина);
		
		Возврат Результат;
		
	// Сервис проверки статуса операции вернул ошибку
	ИначеЕсли Не ПустаяСтрока(РезультатПроверки.КодОшибки) Тогда
		
		ЗаполнитьЗначенияСвойств(Результат, РезультатПроверки, СписокСвойствОшибки);
		Возврат Результат;
		
	// Операция возврата оплаты выполнена
	ИначеЕсли АнализИсторическихДанных.ДанныеИдентичны
		И РезультатПроверки.СтатусОперации = НастройкиПлатежныхСистемКлиентСервер.СтатусОперацииВыполнена() Тогда
		
		Результат.КодОшибки = НастройкиПлатежныхСистемСлужебный.КодОшибкиОперацияВыполнена();
		Результат.СообщениеОбОшибке = НСтр("ru = 'Возврат оплаты уже выполнен.'");
		Результат.ИнформацияОбОшибке = Результат.СообщениеОбОшибке;
		
		Возврат Результат;
		
	// Операция возврата оплаты не в терминальном статусе (Выполняется или Ошибка)
	ИначеЕсли АнализИсторическихДанных.ДанныеИдентичны Тогда
		
		Результат.КодОшибки = НастройкиПлатежныхСистемСлужебный.КодОшибкиОперацияВыполняется();
		Результат.СообщениеОбОшибке = НСтр("ru = 'Операция возврата оплаты в процессе выполнения.'");
		Результат.ИнформацияОбОшибке = Результат.СообщениеОбОшибке;
		
		Возврат Результат;
		
	// Обработка ситуаций когда данные текущего заказа отличаются от ранее отправленных
	Иначе
		
		Результат.КодОшибки = НастройкиПлатежныхСистемСлужебный.КодОшибкиНеверныйФорматЗапроса();
		Результат.СообщениеОбОшибке = НСтр(
			"ru = 'Для документа ранее был сформирован возврат с другими данными, создание нового возврата запрещено.'");
		Результат.ИнформацияОбОшибке = Результат.СообщениеОбОшибке;
		
		Возврат Результат;
		
	КонецЕсли;
	
КонецФункции

// Определяет изменение заказа на возврат оплаты.
//
// Параметры:
//  ДокументОперации - ОпределяемыйТип.ДокументОперацииПлатежнойСистемы - документ, который отражает возврат оплаты в
//    информационной базе.
//  НастройкаПодключения - СправочникСсылка.НастройкиПодключенияКПлатежнымСистемам - настройка подключения к сервису.
//  ЗаказНаВозврат - см. ОзонПэйПереопределяемый.ПриФормированииЗаказаНаВозврат.ЗаказНаВозврат
//
// Возвращаемое значение:
//  Структура - содержит результат сравнения заказа на оплату:
//    * ДанныеИдентичны - Булево - признак идентичности заказов.
//
Функция АнализИсторическихДанныхВозврата(
		ДокументОперации,
		НастройкаПодключения,
		ЗаказНаВозврат)
	
	Результат = Новый Структура();
	Результат.Вставить("ДанныеИдентичны", Ложь);
	
	ИсторическиеДанные = ПлатежныеСистемыСлужебный.ДанныеОперации(ДокументОперации);
	
	Результат.ДанныеИдентичны = (ИсторическиеДанные.СуммаОперации = ЗаказНаВозврат.СуммаВозврата
		И Не ИсторическиеДанные.Оплата
		И ИсторическиеДанные.НастройкаПодключения = НастройкаПодключения);
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти

#Область ОписаниеПодсистемы

// Формирует описание настроек подключения по умолчанию.
// 
// Возвращаемое значение:
//  Структура:
//    * Описание - Строка, ФорматированнаяСтрока - текст описания платежной системы.
//    * Подключение - Строка, ФорматированнаяСтрока - текст подсказки о платежной системе.
//    
Функция ОписаниеПоУмолчанию() Экспорт
	
	Результат = Новый Структура;
	
	Результат.Вставить(
		"Описание",
		СтроковыеФункции.ФорматированнаяСтрока(
			НСтр("ru = '<b>Ozon Pay</b> - платежный сервис Озон банка, который позволяет принимать оплату от покупателей за товары и услуги через интернет.
				|
				|<a href=""https://finance.ozon.ru/business/acquiring"">Подробнее о сервисе</a>'")));

	Результат.Вставить(
		"Подключение",
		СтроковыеФункции.ФорматированнаяСтрока(
			НСтр("ru = 'Для подключения к Ozon pay заполните настройки. Получить данные для настройки можно в <a href=""https://finance.ozon.ru/business/auth"">Личном кабинете</a>'")));
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти

#КонецОбласти