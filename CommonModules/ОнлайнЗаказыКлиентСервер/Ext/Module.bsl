////////////////////////////////////////////////////////////////////////////////
// Подсистема "ИнтернетПоддержкаПользователей.ОнлайнЗаказы".
// ОбщийМодуль.ОнлайнЗаказыКлиентСервер.
//
// Клиент-серверные процедуры получения идентификаторов:
//  - получение идентификаторов статусов онлайн-заказов.
//  - получение идентификаторов ошибок данных аутентификации.
//
////////////////////////////////////////////////////////////////////////////////

#Область СлужебныеПроцедурыИФункции

#Область КодыОшибок

// Возвращает код ошибки "НедопустимыйСтатус".
//
// Возвращаемое значение:
//  Строка - код ошибки.
//
Функция КодОшибкиНедопустимыйСтатус() Экспорт
	
	Возврат "НедопустимыйСтатус";
	
КонецФункции

#КонецОбласти

#Область СтатусыОпераций

// Возвращает статус заказа "READY".
//
// Возвращаемое значение:
//  Строка - код состояния.
//
Функция СтатусЗаказаВыполняется() Экспорт
	
	Возврат "READY";
	
КонецФункции

// Возвращает статус заказа "EXPIRED".
//
// Возвращаемое значение:
//  Строка - код состояния.
//
Функция СтатусЗаказаИстекСрокЖизни() Экспорт
	
	Возврат "EXPIRED";
	
КонецФункции

// Возвращает статус заказа "INACTIVE".
//
// Возвращаемое значение:
//  Строка - код состояния.
//
Функция СтатусЗаказаНеАктивен() Экспорт
	
	Возврат "INACTIVE";
	
КонецФункции

// Возвращает статус заказа "PAYMENT_SESSION_IN_PROGRESS".
//
// Возвращаемое значение:
//  Строка - код состояния.
//
Функция СтатусЗаказаВыполняетсяОплата() Экспорт
	
	Возврат "PAYMENT_SESSION_IN_PROGRESS";
	
КонецФункции

// Возвращает статус заказа "ERROR".
// Используется для сложных операций работы с сервисом,
// в случаях когда выполнилась ли часть из запланированных операций сценария.
// После получения данной ошибки предполагается выполнить полный цикл актуализации данных заказа.
//
// Возвращаемое значение:
//  Строка - код состояния.
//
Функция СтатусЗаказаОшибка() Экспорт
	
	Возврат "ERROR";
	
КонецФункции

// Возвращает статус заказа "SERVICE_ERROR".
// Используется для случаев ошибок сервиса, когда пользователю предлагается повторить операцию.
//
// Возвращаемое значение:
//  Строка - код состояния.
//
Функция СтатусЗаказаОшибкаСервиса() Экспорт
	
	Возврат "SERVICE_ERROR";
	
КонецФункции

#КонецОбласти

#Область РаботаССервисом

// Возвращает признак принадлежности преданного URL сервису онлайн-заказов.
//
// Параметры:
//  URL - Строка - URL для проверки.
//
// Возвращаемое значение:
//  Булево - признак принадлежности преданного URL сервису онлайн-заказов.
//
Функция ЭтоURLСервиса(URL) Экспорт
	
	ДанныеURL = ОбщегоНазначенияКлиентСервер.СтруктураURI(URL);
	
	Возврат НРег(ДанныеURL.ИмяСервера) = ХостСервисаОбменаДанными();
	
КонецФункции

// Определяет хост для вызова сервиса онлайн-заказов.
//
// Возвращаемое значение:
//  Строка - хост подключения.
//
Функция ХостСервисаОбменаДанными() Экспорт
	
	
	Возврат "orders.1c.ru";
	
КонецФункции

// Формирует новое описание данных вложений
//
// Возвращаемое значение:
//  Структура - данные вложений.
//
Функция НовыйДанныеВложений() Экспорт
	
	Результат = Новый Структура;
	Результат.Вставить("ПечатныеФормы", Новый Массив);
	Результат.Вставить("ПрисоединенныеФайлы", Новый Массив);
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти

#КонецОбласти

