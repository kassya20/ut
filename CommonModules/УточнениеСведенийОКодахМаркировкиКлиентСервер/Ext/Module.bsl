#Область СлужебныйПрограммныйИнтерфейс

#Область ЭлементыКонструктораВидовПродукции

Функция ДоступныеОперации(ВидПродукцииТоварнаяГруппа) Экспорт
	
	ВидыПродукции = КонструкторИСМПОбщегоНазначенияКлиентСервер.ВидыПродукции(ВидПродукцииТоварнаяГруппа);
	
	ДоступныеОперации = Новый Массив;
	
	Если ОперацияКорректировкаСведенийКМДоступна(ВидыПродукции) Тогда
		Операция = ПредопределенноеЗначение(
			"Перечисление.ВидыОперацийИСМП.КорректировкаСведенийКМ");
		ДоступныеОперации.Добавить(Операция);
	КонецЕсли;
	
	Если ОперацияКорректировкаСведенийКМСрокГодностиВСДДоступна(ВидыПродукции) Тогда
		Операция = ПредопределенноеЗначение(
			"Перечисление.ВидыОперацийИСМП.КорректировкаСведенийКМСрокГодностиВСД");
		ДоступныеОперации.Добавить(Операция);
	КонецЕсли;
	
	Если ОперацияКорректировкаСведенийКМСрокГодностиДоступна(ВидыПродукции) Тогда
		Операция = ПредопределенноеЗначение(
			"Перечисление.ВидыОперацийИСМП.КорректировкаСведенийКМСрокГодности");
		ДоступныеОперации.Добавить(Операция);
	КонецЕсли;
	
	Если ОперацияКорректировкаСведенийКМФактическийВесДоступна(ВидыПродукции) Тогда
		Операция = ПредопределенноеЗначение(
			"Перечисление.ВидыОперацийИСМП.КорректировкаСведенийКМФактическийВес");
		ДоступныеОперации.Добавить(Операция);
	КонецЕсли;
	
	Возврат ДоступныеОперации;
	
КонецФункции

Функция ДоступныеВидыПродукции() Экспорт
	
	ВидыПродукции = Новый Массив;
	
	МассивОпераций = МассивОпераций();
	
	Для Каждого Операция Из МассивОпераций Цикл
		ВидыПродукцииЭлемента = КонструкторИСОбщегоНазначенияКлиентСервер.ВидыПродукцииПоЭлементуКонструктора(Операция);
		ОбщегоНазначенияКлиентСервер.ДополнитьМассив(ВидыПродукции, ВидыПродукцииЭлемента);
	КонецЦикла;
	
	Возврат ВидыПродукции;
	
КонецФункции

Функция ДоступныеТоварныеГруппы() Экспорт
	ВидПродукции = ДоступныеВидыПродукции();
	ТоварныеГруппы = КонструкторИСОбщегоНазначенияКлиентСервер.ЗначенияЭлементаКонструктораПоВидуПродукции(
		ПредопределенноеЗначение(
			"Справочник.ЭлементыКонструктораВидовПродукцииИС.ТоварныеГруппыГИСМТ"),
		ВидПродукции);
	Возврат ТоварныеГруппы;
КонецФункции

