#Область СлужебныеПроцедурыИФункции

Функция МассивОпераций()
	
	МассивОпераций = Новый Массив;
	МассивОпераций.Добавить(ПредопределенноеЗначение("Справочник.ЭлементыКонструктораВидовПродукцииИС.КорректировкаСведенийКМ"));
	МассивОпераций.Добавить(ПредопределенноеЗначение("Справочник.ЭлементыКонструктораВидовПродукцииИС.КорректировкаСведенийКМСрокГодностиВСД"));
	МассивОпераций.Добавить(ПредопределенноеЗначение("Справочник.ЭлементыКонструктораВидовПродукцииИС.КорректировкаСведенийКМСрокГодности"));
	МассивОпераций.Добавить(ПредопределенноеЗначение("Справочник.ЭлементыКонструктораВидовПродукцииИС.КорректировкаСведенийКМФактическийВес"));
	Возврат МассивОпераций;
	
КонецФункции

