#Область СлужебныйПрограммныйИнтерфейс

// Получает сформированный ранее Акт о расхождениях для переданного документа.
// 
// Параметры:
//  Документ         - ДокументСсылка - ссылка на документ, для которого необходимо получить Акт о расхождениях:
//  АктОРасхождениях - ДокументСсылка - ссылка на Акт о расхождениях:
Процедура ПолучитьСформированныйАктОРасхождениях(Документ, АктОРасхождениях) Экспорт
	
	АктОРасхождениях = ИнтеграцияИСМПУТ.СформированныйАктОРасхождениях(Документ);
	
КонецПроцедуры

// Заполняет через третий параметр таблицу товаров документа (для определенного сценария),
//   либо дополняет ее значениями GTIN.
//
// Параметры:
//  Контекст  - ФормаКлиентскогоПриложения, ДокументСсылка - документ, маркируемую продукцию которого необходимо получить.
//  Сценарий  - Число - номер сценария заполнения.
//  ТаблицаПродукции - См. ПроверкаИПодборПродукцииИС.ТаблицаПродукцииДокумента
Процедура ПриОпределенииПродукцииДокумента(Контекст, Сценарий, ТаблицаПродукции) Экспорт
	
	ПроверкаИПодборПродукцииИСМПУТ.ЗаполнитьПродукциюДокумента(Контекст, ТаблицаПродукции, Сценарий);
	
КонецПроцедуры

// Обработать изменения в табличной части Подобранная продукция формы проверки.
// 
// Параметры:
//  Форма - ФормаКлиентскогоПриложения - Форма проверки и подбора:
//   * ПараметрыСканирования - Структура - Параметры сканирования:
//     ** Склад - ОпределяемыйТип.Склад - Склад
//   * ЕГАИС - Булево - доступна проверка продукции ЕГАИС
//   * ИСМП - Булево - доступна проверка продукции ГИСМТ
//  СтрокиПодобраннойПродукции - Соответствие из ДанныеФормыЭлементКоллекции - Строки подобранной продукции
//  Действия - Соответствие из Строка - Требуемые действия (для обработки прикладным решением,
// может содержать элементы ОбработатьИзменениеНоменклатуры, ОбработатьИзменениеКоличества).
//  КэшированныеЗначения - Произвольный - Кэшированные значения
//  ПараметрыУказанияСерий - Произвольный - Параметры указания серий
Процедура ОбработатьПодобраннуюПродукцию(
	Форма, СтрокиПодобраннойПродукции, Действия, КэшированныеЗначения, ПараметрыУказанияСерий) Экспорт
	
	Если Действия["ОбработатьИзменениеНоменклатуры"] = Истина Тогда
		
		ПараметрыУказанияСерийКопия = ОбщегоНазначения.СкопироватьРекурсивно(ПараметрыУказанияСерий, Ложь);
		Поле = ПараметрыУказанияСерийКопия.ИменаПолейДополнительные.Найти("КоличествоПодобрано");
		Если Поле <> Неопределено Тогда
			ПараметрыУказанияСерийКопия.ИменаПолейДополнительные.Удалить(Поле);
		КонецЕсли;
		ИмяТабличнойЧасти = ПроверкаИПодборПродукцииИСМПУТ.ИмяТабличнойЧасти(Форма.ПараметрыСканирования);
		ПараметрыУказанияСерийКопия.ИмяТЧТовары = ИмяТабличнойЧасти;
		ПараметрыУказанияСерийКопия.ИмяТЧСерии = ИмяТабличнойЧасти;
		
		ПроверкаИПодборПродукцииИСМПУТ.ПроверитьДополнитьКолонкиСтрокиПодобраннойПродукции(Форма);
		
		ОбработчикЗаполнитьПризнакМаркируемаяПродукция = "ЗаполнитьПризнакМаркируемаяПродукция";
		ИсточникНастроек = Форма;
		Если ТипЗнч(Форма) = Тип("Структура") Тогда
			ИсточникНастроек = Форма.ПараметрыСканирования;
		КонецЕсли;
		Если Не ИсточникНастроек.ИСМП Тогда
			ОбработчикЗаполнитьПризнакМаркируемаяПродукция = "ЗаполнитьПризнакМаркируемаяПродукцияЕГАИС";
		ИначеЕсли Не ИсточникНастроек.ЕГАИС Тогда
			ОбработчикЗаполнитьПризнакМаркируемаяПродукция = "ЗаполнитьПризнакМаркируемаяПродукцияГИСМТ";
		КонецЕсли;
		
		СтруктураДействий = Новый Структура;
		СтруктураДействий.Вставить("ЗаполнитьПризнакХарактеристикиИспользуются",
			Новый Структура("Номенклатура", "ХарактеристикиИспользуются"));
		СтруктураДействий.Вставить("ЗаполнитьПризнакТипНоменклатуры",
			Новый Структура("Номенклатура", "ТипНоменклатуры"));
		СтруктураДействий.Вставить("ЗаполнитьПризнакТребуетВзвешивания",
			Новый Структура("Номенклатура", "ТребуетВзвешивания"));
		СтруктураДействий.Вставить("ЗаполнитьПризнакПроизвольнаяЕдиницаУчета",
			Новый Структура("Номенклатура", "ПроизвольнаяЕдиницаУчета"));
		СтруктураДействий.Вставить("ЗаполнитьПризнакСкоропортящаясяПродукция",
			Новый Структура("Номенклатура", "СкоропортящаясяПродукция"));
		СтруктураДействий.Вставить(ОбработчикЗаполнитьПризнакМаркируемаяПродукция,
			Новый Структура("Номенклатура", "МаркируемаяПродукция"));
		СтруктураДействий.Вставить("ЗаполнитьВидПродукцииИС",
			Новый Структура("Номенклатура", "ВидПродукции"));
		СтруктураДействий.Вставить("ПроверитьСериюРассчитатьСтатус",
			Новый Структура("Склад, ПараметрыУказанияСерий", Форма.ПараметрыСканирования.Склад, ПараметрыУказанияСерийКопия));
		
		МассивСтрок = Новый Массив;
		Для Каждого ЭлементСоответствия Из СтрокиПодобраннойПродукции Цикл
			МассивСтрок.Добавить(ЭлементСоответствия.Ключ);
		КонецЦикла;
		ПакетнаяОбработкаТабличнойЧастиСервер.ОбработатьСтрокиТЧ(
			МассивСтрок, СтруктураДействий, Форма.ПодобраннаяМаркируемаяПродукция);
	КонецЕсли;
	
КонецПроцедуры

#Область ЗавершениеПроверкиИПодбора

// Вызывается при заверешении проверки и подбора для отражения данных в документе.
// Предназначена для сохранения связей номенклатуры с GTIN, с учетом коээффициентов групповых упаковок. 
// 
// Параметры:
//  ТаблицаОписанияGTIN - см. ПроверкаИПодборПродукцииИС.ПустаяТаблицаОписанияGTIN.
Процедура СохранитьШтрихкодыНоменклатуры(ТаблицаОписанияGTIN) Экспорт
	
	ИнтеграцияИСМПУТ.ЗафиксироватьОписаниеGTIN(ТаблицаОписанияGTIN);
	
КонецПроцедуры

// Отражает результаты проверки и подбора в документе, из которого была вызвана соответствующая форма.
// 
// Параметры:
// 	ПараметрыОкончанияПроверки - Структура
Процедура ЗафиксироватьРезультатПроверкиИПодбора(ПараметрыОкончанияПроверки) Экспорт
	
	ИнтеграцияИСМПУТ.ОтразитьРезультатыСканированияВДокументе(ПараметрыОкончанияПроверки);
	
КонецПроцедуры

#КонецОбласти

#Область ПараметрыИнтеграцииФормыПроверкиИПодбора

// Заполняет специфику интеграции формы проверки и подбора в конкретную форму.
//
// Параметры:
//  Форма - ФормаКлиентскогоПриложения - форма для которой настраиваются параметры интеграции:
//  *Объект - ДокументОбъект
//  ПараметрыИнтеграции - См. ПроверкаИПодборПродукцииИС.ПараметрыИнтеграцииФормПроверкиИПодбора.
//
Процедура ПриОпределенииПараметровИнтеграцииФормыПроверкиИПодбора(Форма, ПараметрыИнтеграции) Экспорт
	
	ЭлементНастроек = ПроверкаИПодборПродукцииИС.ПараметрыИнтеграцииФормПроверкиИПодбора();
	
	Если ПолучитьФункциональнуюОпцию("ИспользоватьПередачиТоваровМеждуОрганизациями") Тогда
		ЭлементНастроек.Вставить("ИспользоватьПередачиТоваровМеждуОрганизациями");
	КонецЕсли;
	
	Если ИнтеграцияИСУТКлиентСервер.ЭтоДокументПоНаименованию(Форма, "РеализацияТоваровУслуг") Тогда
	
		ЭлементНастроек.ИмяРодительскойГруппыФормы                 = "ГруппаТовары";
		ЭлементНастроек.РазмещатьЭлементыИнтерфейса                = Истина;
		ЭлементНастроек.ИспользоватьКолонкуСтатусаПроверкиПодбора  = Истина;
		ЭлементНастроек.ДоступноЧастичноеВыбытие                   = Истина;
		ЭлементНастроек.ИспользоватьБезМаркируемойПродукции        = Истина;
		ЭлементНастроек.БлокироватьТабличнуюЧастьТоварыПриПроверке = Ложь;
		ЭлементНастроек.ИспользоватьСтатусПроверкаЗавершена        = Ложь;
		ЭлементНастроек.ЕстьПравоИзменение                         = ПравоДоступа("Изменение", Форма.Объект.Ссылка.Метаданные());
		ЭлементНастроек.ОтображатьОшибкиПроверкиСредствамиККТ      = Истина;
		ЭлементНастроек.ДоступныОбъемноСортовыеКоды                = Истина;
		ЭлементНастроек.ИспользоватьБезМаркируемойПродукции        = Истина;
		ЭлементНастроек.ИмяКоманднойПанели                         = Форма.Элементы.ТоварыГруппаЗаполнить.Имя;
		
		ПараметрыИнтеграции.Добавить(ЭлементНастроек);
		
	ИначеЕсли ИнтеграцияИСУТКлиентСервер.ЭтоДокументПоНаименованию(Форма, "ВозвратТоваровПоставщику")
		Или ИнтеграцияИСУТКлиентСервер.ЭтоДокументПоНаименованию(Форма, "ОтгрузкаТоваровСХранения")
	Тогда
	
		ЭлементНастроек.ИмяРодительскойГруппыФормы                 = "ГруппаТовары";
		ЭлементНастроек.РазмещатьЭлементыИнтерфейса                = Истина;
		ЭлементНастроек.ИспользоватьКолонкуСтатусаПроверкиПодбора  = Истина;
		ЭлементНастроек.ИспользоватьБезМаркируемойПродукции        = Истина;
		ЭлементНастроек.БлокироватьТабличнуюЧастьТоварыПриПроверке = Ложь;
		ЭлементНастроек.ИспользоватьСтатусПроверкаЗавершена        = Ложь;
		ЭлементНастроек.ЕстьПравоИзменение                         = ПравоДоступа("Изменение", Форма.Объект.Ссылка.Метаданные());
		ЭлементНастроек.ОтображатьОшибкиПроверкиСредствамиККТ      = Истина;
		ЭлементНастроек.ДоступныОбъемноСортовыеКоды                = Истина;
		ЭлементНастроек.ИспользоватьБезМаркируемойПродукции        = Истина;
		ЭлементНастроек.ИмяКоманднойПанели                         = Форма.Элементы.ТоварыГруппаЗаполнить.Имя;
		
		ПараметрыИнтеграции.Добавить(ЭлементНастроек);
		
	ИначеЕсли ИнтеграцияИСУТКлиентСервер.ЭтоДокументПоНаименованию(Форма, "РасходныйОрдерНаТовары") Тогда
	
		ЭлементНастроек.ИмяРодительскойГруппыФормы                 = "ОтгружаемыеТоварыПодменюЗаполнить";
		ЭлементНастроек.РазмещатьЭлементыИнтерфейса                = Истина;
		ЭлементНастроек.ИспользоватьКолонкуСтатусаПроверкиПодбора  = Истина;
		ЭлементНастроек.ИспользоватьБезМаркируемойПродукции        = Истина;
		ЭлементНастроек.БлокироватьТабличнуюЧастьТоварыПриПроверке = Ложь;
		ЭлементНастроек.ИспользоватьСтатусПроверкаЗавершена        = Ложь;
		ЭлементНастроек.ЕстьПравоИзменение                         = ПравоДоступа("Изменение", Форма.Объект.Ссылка.Метаданные());
		
		ЭлементНастроек.ИмяТабличнойЧастиТовары                    = "ОтгружаемыеТовары";
		ЭлементНастроек.ИмяЭлементаФормыТовары                     = "ОтгружаемыеТовары";
		ЭлементНастроек.ИмяСледующейКолонки                        = "ОтгружаемыеТоварыНоменклатураАртикул";
		ЭлементНастроек.ИмяТабличнойЧастиСерии                     = "";
		ЭлементНастроек.ДоступныОбъемноСортовыеКоды                = Истина;
		ЭлементНастроек.ИмяКоманднойПанели                         = Форма.Элементы.ОтгружаемыеТоварыПодменюЗаполнить.Имя;
		
		ПараметрыИнтеграции.Добавить(ЭлементНастроек);
		
	ИначеЕсли ИнтеграцияИСУТКлиентСервер.ЭтоДокументПоНаименованию(Форма, "ОтборРазмещениеТоваров") Тогда
	
		ЭлементНастроек.ИмяРодительскойГруппыФормы                 = "ГруппаТоварыОтбор";
		ЭлементНастроек.РазмещатьЭлементыИнтерфейса                = Истина;
		ЭлементНастроек.ИспользоватьКолонкуСтатусаПроверкиПодбора  = Истина;
		ЭлементНастроек.ИспользоватьБезМаркируемойПродукции        = Истина;
		ЭлементНастроек.БлокироватьТабличнуюЧастьТоварыПриПроверке = Ложь;
		ЭлементНастроек.ИспользоватьСтатусПроверкаЗавершена        = Ложь;
		ЭлементНастроек.ЕстьПравоИзменение                         = ПравоДоступа("Изменение", Форма.Объект.Ссылка.Метаданные());
		
		ЭлементНастроек.ИмяТабличнойЧастиТовары                    = "ТоварыОтбор";
		ЭлементНастроек.ИмяЭлементаФормыТовары                     = "ТоварыОтбор";
		ЭлементНастроек.ИмяСледующейКолонки                        = "ТоварыОтборНоменклатура";
		ЭлементНастроек.ИмяПоследующегоЭлементаФормы               = "ТоварыОтбор";
		ЭлементНастроек.ИмяТабличнойЧастиСерии                     = "";
		ЭлементНастроек.ДоступныОбъемноСортовыеКоды                = Истина;
		ЭлементНастроек.ИмяКоманднойПанели                         = Форма.Элементы.ТоварыОтбор.КоманднаяПанель.Имя;
		
		ПараметрыИнтеграции.Добавить(ЭлементНастроек);
		
	ИначеЕсли ИнтеграцияИСУТКлиентСервер.ЭтоДокументПоНаименованию(Форма, "ПриходныйОрдерНаТовары") Тогда
	
		ЭлементНастроек.ИмяРодительскойГруппыФормы                 = "ЗаполнитьПоРаспоряжению";
		ЭлементНастроек.РазмещатьЭлементыИнтерфейса                = Истина;
		ЭлементНастроек.ИспользоватьКолонкуСтатусаПроверкиПодбора  = Истина;
		ЭлементНастроек.ИспользоватьБезМаркируемойПродукции        = Ложь;
		ЭлементНастроек.БлокироватьТабличнуюЧастьТоварыПриПроверке = Ложь;
		ЭлементНастроек.ИспользоватьСтатусПроверкаЗавершена        = Ложь;
		ЭлементНастроек.ЕстьПравоИзменение                         = ПравоДоступа("Изменение", Форма.Объект.Ссылка.Метаданные());
		
		ЭлементНастроек.ИмяТабличнойЧастиТовары                    = "Товары";
		ЭлементНастроек.ИмяЭлементаФормыТовары                     = "Товары";
		ЭлементНастроек.ИмяСледующейКолонки                        = "ТоварыНоменклатураТипНоменклатуры";
		ЭлементНастроек.ИмяПоследующегоЭлементаФормы               = "ГруппаРежимПросмотраНавигация";
		ЭлементНастроек.ИмяТабличнойЧастиСерии                     = "";
		ЭлементНастроек.ИспользоватьБезМаркируемойПродукции        = Истина;
		ЭлементНастроек.ИмяКоманднойПанели                         = "ЗаполнитьПоРаспоряжению";
		
		ПараметрыИнтеграции.Добавить(ЭлементНастроек);
		
	ИначеЕсли СтрНачинаетсяС(Форма.ИмяФормы,"Документ.КорректировкаРеализации.Форма.ФормаДокументаДоВводаОстатков") Тогда
		
		ЭлементНастроек.ИспользоватьБезМаркируемойПродукции        = Истина;
		ЭлементНастроек.ИмяТабличнойЧастиСерии                     = "";
		ЭлементНастроек.ИмяКоманднойПанели                         = Форма.Элементы.ГруппаТаблицаКорректировкиЗаполнить.Имя;
		
		ПараметрыИнтеграции.Добавить(ЭлементНастроек);
		
	ИначеЕсли ИнтеграцияИСУТКлиентСервер.ЭтоДокументПоНаименованию(Форма, "КорректировкаРеализации") Тогда
		
		ЭлементНастроек.ИмяРодительскойГруппыФормы                 = "ГруппаТовары";
		ЭлементНастроек.РазмещатьЭлементыИнтерфейса                = Истина;
		ЭлементНастроек.ИспользоватьКолонкуСтатусаПроверкиПодбора  = Истина;
		ЭлементНастроек.ДоступноЧастичноеВыбытие                   = Истина;
		ЭлементНастроек.ИспользоватьБезМаркируемойПродукции        = ЗначениеЗаполнено(Форма.Объект.Склад);
		ЭлементНастроек.БлокироватьТабличнуюЧастьТоварыПриПроверке = Ложь;
		ЭлементНастроек.ИспользоватьСтатусПроверкаЗавершена        = Ложь;
		ЭлементНастроек.ИмяТабличнойЧастиСерии                     = "";
		ЭлементНастроек.ЕстьПравоИзменение                         = ПравоДоступа("Изменение", Метаданные.Документы.КорректировкаРеализации);
		ЭлементНастроек.ОтображатьОшибкиПроверкиСредствамиККТ      = Истина;
		ЭлементНастроек.ДоступныОбъемноСортовыеКоды                = Истина;
		ЭлементНастроек.ИмяКоманднойПанели                         = Форма.Элементы.ГруппаТоварыЗаполнить.Имя;
		
