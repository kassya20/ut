		ЭлементНастроек.ИмяПоследующегоЭлементаФормы = "ГруппаРежимПросмотраНавигация";
		ЭлементНастроек.ИмяТабличнойЧастиСерии       = "";
		ЭлементНастроек.ИспользоватьБезМаркируемойПродукции        = Истина;
		
	ИначеЕсли ИнтеграцияИСУТКлиентСервер.ЭтоДокументПоНаименованию(Форма, "ОтборРазмещениеТоваров") Тогда
	
		ПроверкаИПодборПродукцииИСМПУТ.НастроитьРасходныйДокументДляЕГАИС(
			ЭлементНастроек, "ГруппаТоварыОтбор", Метаданные.Документы.ОтборРазмещениеТоваров);
		ЭлементНастроек.ИмяТабличнойЧастиТовары      = "ТоварыОтбор";
		ЭлементНастроек.ИмяЭлементаФормыТовары       = "ТоварыОтбор";
		ЭлементНастроек.ИмяСледующейКолонки          = "ТоварыОтборНоменклатура";
		ЭлементНастроек.ИмяПоследующегоЭлементаФормы = "ТоварыОтбор";
		ЭлементНастроек.ИмяТабличнойЧастиСерии       = "";
		
	ИначеЕсли ИнтеграцияИСУТКлиентСервер.ЭтоДокументПоНаименованию(Форма, "ПеремещениеТоваров") Тогда
		
		ПроверкаИПодборПродукцииИСМПУТ.НастроитьРасходныйДокументДляЕГАИС(
			ЭлементНастроек, "", Метаданные.Документы.ПеремещениеТоваров);
		
	ИначеЕсли ИнтеграцияИСУТКлиентСервер.ЭтоДокументПоНаименованию(Форма, "СборкаТоваров") Тогда
		
		ПроверкаИПодборПродукцииИСМПУТ.НастроитьРасходныйДокументДляЕГАИС(
			ЭлементНастроек, "ГруппаТовары", Метаданные.Документы.СборкаТоваров);
		ЭлементНастроек.ИспользоватьКолонкуСтатусаПроверкиПодбора  = Ложь; //динамически менять при разборке не получится

	ИначеЕсли ИнтеграцияИСУТКлиентСервер.ЭтоДокументПоНаименованию(Форма, "ПередачаТоваровМеждуОрганизациями")
		Или ИнтеграцияИСУТКлиентСервер.ЭтоДокументПоНаименованию(Форма, "ВозвратТоваровМеждуОрганизациями") Тогда
		
		ПроверкаИПодборПродукцииИСМПУТ.НастроитьРасходныйДокументДляЕГАИС(
			ЭлементНастроек, "", Форма.Объект.Ссылка.Метаданные());
		ЭлементНастроек.ИмяТабличнойЧастиСерии       = "";
		


	КонецЕсли;
	
КонецПроцедуры

// Переопределение параметров интеграции ЕГАИС (расположения команды проверки и подбора)
//
// Параметры:
//   Форма                - ФормаКлиентскогоПриложения - прикладная форма для встраивания форматированной строки
//   СтандартнаяОбработка - Булево - стандартная работа с элементами проверки подбора
//   ПараметрыИнтеграции  - Соответствие - автоматически заданные параметры интеграции
//
Процедура ПриОпределенииПараметровИнтеграции(Форма, СтандартнаяОбработка, ПараметрыИнтеграции) Экспорт
	
	Если Форма.ИмяФормы = "Документ.АктОРасхожденияхПослеПриемки.Форма.ФормаДокумента"
		Или Форма.ИмяФормы = "Документ.АктОРасхожденияхПослеОтгрузки.Форма.ФормаДокумента"
		Тогда
			СтандартнаяОбработка = Ложь;
	КонецЕсли;
	
КонецПроцедуры

// Заполняет специфику применения интеграции формы проверки и подбора в конкретную форму.
//
// Параметры:
//  Форма - ФормаКлиентскогоПриложения - форма для которой применяются параметры интеграции.
//
Процедура ПриПримененииПараметровИнтеграцииФормыПроверкиИПодбора(Форма) Экспорт
	
	Возврат;
	
КонецПроцедуры

// Получение организации для складских документов "через точку". 
// Параметры:
// ПроверяемыйДокумент - ДокументСсылка
// Организация - ОпределяемыйТип.Организация - возвращаемое значение.
Процедура ПриОпределенииОрганизации(ПроверяемыйДокумент, Организация) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Параметры.Вставить("ТекДокумент", ПроверяемыйДокумент);
	
	Если ТипЗнч(ПроверяемыйДокумент) = Тип("ДокументСсылка.РасходныйОрдерНаТовары") Тогда
		
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	МАКСИМУМ(РасходныйОрдерНаТоварыТоварыПоРаспоряжениям.Распоряжение.Организация) КАК Организация
		|ИЗ
		|	Документ.РасходныйОрдерНаТовары.ТоварыПоРаспоряжениям КАК РасходныйОрдерНаТоварыТоварыПоРаспоряжениям
		|ГДЕ
		|	РасходныйОрдерНаТоварыТоварыПоРаспоряжениям.Ссылка = &ТекДокумент";
		
	ИначеЕсли ТипЗнч(ПроверяемыйДокумент) = Тип("ДокументСсылка.ПриходныйОрдерНаТовары") Тогда
		
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	МАКСИМУМ(ПредварительныйОтбор.Организация) КАК Организация
		|ИЗ
		|	(ВЫБРАТЬ
		|		МАКСИМУМ(ПриходныйОрдерНаТоварыТовары.ДокументОтгрузки.Организация) КАК Организация
		|	ИЗ
		|		Документ.ПриходныйОрдерНаТовары.Товары КАК ПриходныйОрдерНаТоварыТовары
		|	ГДЕ
		|		ПриходныйОрдерНаТоварыТовары.Ссылка = &ТекДокумент
		|		И
		|			ПриходныйОрдерНаТоварыТовары.Ссылка.СкладскаяОперация = ЗНАЧЕНИЕ(Перечисление.СкладскиеОперации.ВозвратНеПринятыхТоваров)
		|
		|	ОБЪЕДИНИТЬ ВСЕ
		|
		|	ВЫБРАТЬ
		|		ПриходныйОрдерНаТовары.Распоряжение.Организация КАК Организация
		|	ИЗ
		|		Документ.ПриходныйОрдерНаТовары КАК ПриходныйОрдерНаТовары
		|	ГДЕ
		|		ПриходныйОрдерНаТовары.Ссылка = &ТекДокумент
		|		И НЕ
		|			ПриходныйОрдерНаТовары.СкладскаяОперация = ЗНАЧЕНИЕ(Перечисление.СкладскиеОперации.ВозвратНеПринятыхТоваров)) КАК
		|		ПредварительныйОтбор";
		
	ИначеЕсли ТипЗнч(ПроверяемыйДокумент) = Тип("ДокументСсылка.ОтборРазмещениеТоваров") Тогда
		
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	МАКСИМУМ(РасходныйОрдерНаТоварыТоварыПоРаспоряжениям.Распоряжение.Организация) КАК Организация
		|ИЗ
		|	Документ.ОтборРазмещениеТоваров КАК ОтборРазмещениеТоваров
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.РасходныйОрдерНаТовары.ТоварыПоРаспоряжениям КАК РасходныйОрдерНаТоварыТоварыПоРаспоряжениям
		|		ПО ОтборРазмещениеТоваров.Распоряжение = РасходныйОрдерНаТоварыТоварыПоРаспоряжениям.Ссылка
		|ГДЕ
		|	ОтборРазмещениеТоваров.Ссылка = &ТекДокумент";

	Иначе
		Возврат;
	КонецЕсли;

	УстановитьПривилегированныйРежим(Истина);
	Выборка = Запрос.Выполнить().Выбрать();
	УстановитьПривилегированныйРежим(Ложь);
	Если Выборка.Следующий() Тогда
		Организация = Выборка.Организация;
	КонецЕсли;
	
КонецПроцедуры

// Возвращает через третий параметр признак наличия маркируемой продукции.
//
// Параметры:
//  Объект                   - ДанныеФормыСтруктура - объект в котором проходит проверка
//  Коллекция                - Строка - ТЧ с товарами.
//  ЕстьМаркируемаяПродукция - Булево - Исходящий, признак наличия маркируемой продукции.
//
Процедура ЕстьМаркируемаяПродукция(Объект, Коллекция, ЕстьМаркируемаяПродукция) Экспорт
	
	ВидыПродукции = Новый Массив;
	ОбщегоНазначенияКлиентСервер.ДополнитьМассив(ВидыПродукции, КонструкторИСОбщегоНазначенияКлиентСервер.ВидыПродукцииЕГАИСМаркируемые());
	ОбщегоНазначенияКлиентСервер.ДополнитьМассив(ВидыПродукции, КонструкторИСОбщегоНазначенияКлиентСервер.ВидыПродукцииИСМП(Истина));
	
	ПроверкаИПодборПродукцииИСМПУТ.ЕстьМаркируемаяПродукцияВКоллекции(
		Объект[Коллекция],
		ВидыПродукции,
		ЕстьМаркируемаяПродукция);
	
КонецПроцедуры

#КонецОбласти

#Область ПараметрыФормыПроверкиИПодбора

// Вызывается при открытии формы проверки и подбора для явного задания ее параметров, которые не были переданы заранее.
// 
// Параметры:
//  Форма - См. Обработка.ПроверкаИПодборПродукцииИС.Форма.ПроверкаИПодбор
//  ПараметрыСканирования - См. ШтрихкодированиеОбщегоНазначенияИС.ПараметрыСканирования
Процедура ПриЗаполненииПараметровФормыПроверкиИПодбора(Форма, ПараметрыСканирования) Экспорт
	
	ПроверяемыйДокумент = Форма.ПроверяемыйДокумент;
	Запрос = Новый Запрос;
	Запрос.Параметры.Вставить("ТекДокумент", ПроверяемыйДокумент);
	
	Если ТипЗнч(ПроверяемыйДокумент) = Тип("ДокументСсылка.РасходныйОрдерНаТовары") Тогда
		
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	МАКСИМУМ(РасходныйОрдерНаТоварыТоварыПоРаспоряжениям.Распоряжение.Организация) КАК Организация
		|ИЗ
		|	Документ.РасходныйОрдерНаТовары.ТоварыПоРаспоряжениям КАК РасходныйОрдерНаТоварыТоварыПоРаспоряжениям
		|ГДЕ
		|	РасходныйОрдерНаТоварыТоварыПоРаспоряжениям.Ссылка = &ТекДокумент";
		
	ИначеЕсли ТипЗнч(ПроверяемыйДокумент) = Тип("ДокументСсылка.ПриходныйОрдерНаТовары") Тогда
		
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	МАКСИМУМ(ПредварительныйОтбор.Организация) КАК Организация
		|ИЗ
		|	(ВЫБРАТЬ
		|		МАКСИМУМ(ПриходныйОрдерНаТоварыТовары.ДокументОтгрузки.Организация) КАК Организация
		|	ИЗ
		|		Документ.ПриходныйОрдерНаТовары.Товары КАК ПриходныйОрдерНаТоварыТовары
		|	ГДЕ
		|		ПриходныйОрдерНаТоварыТовары.Ссылка = &ТекДокумент
		|		И
		|			ПриходныйОрдерНаТоварыТовары.Ссылка.СкладскаяОперация = ЗНАЧЕНИЕ(Перечисление.СкладскиеОперации.ВозвратНеПринятыхТоваров)
		|
		|	ОБЪЕДИНИТЬ ВСЕ
		|
		|	ВЫБРАТЬ
		|		ПриходныйОрдерНаТовары.Распоряжение.Организация КАК Организация
		|	ИЗ
		|		Документ.ПриходныйОрдерНаТовары КАК ПриходныйОрдерНаТовары
		|	ГДЕ
		|		ПриходныйОрдерНаТовары.Ссылка = &ТекДокумент
		|		И НЕ
		|			ПриходныйОрдерНаТовары.СкладскаяОперация = ЗНАЧЕНИЕ(Перечисление.СкладскиеОперации.ВозвратНеПринятыхТоваров)) КАК
		|		ПредварительныйОтбор";
		
	ИначеЕсли ТипЗнч(ПроверяемыйДокумент) = Тип("ДокументСсылка.ОтборРазмещениеТоваров") Тогда
		
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	МАКСИМУМ(РасходныйОрдерНаТоварыТоварыПоРаспоряжениям.Распоряжение.Организация) КАК Организация
		|ИЗ
		|	Документ.ОтборРазмещениеТоваров КАК ОтборРазмещениеТоваров
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.РасходныйОрдерНаТовары.ТоварыПоРаспоряжениям КАК РасходныйОрдерНаТоварыТоварыПоРаспоряжениям
		|		ПО ОтборРазмещениеТоваров.Распоряжение = РасходныйОрдерНаТоварыТоварыПоРаспоряжениям.Ссылка
		|ГДЕ
		|	ОтборРазмещениеТоваров.Ссылка = &ТекДокумент";

	Иначе
		Возврат;
	КонецЕсли;

	УстановитьПривилегированныйРежим(Истина);
	Выборка = Запрос.Выполнить().Выбрать();
	УстановитьПривилегированныйРежим(Ложь);
	Если Выборка.Следующий() Тогда
		Форма.Организация = Выборка.Организация;
	КонецЕсли;
	
КонецПроцедуры

// Определяет соответствие проверяемому типу документа, результат возвращает через второй параметр.
//
// Параметры:
//  ИмяДокумента    - Строка - Контекст для определения типа документа
//  ЭтоПриобретение - Булево - исходящий признак входящего (загруженного) документа.
Процедура ЭтоДокументПриобретения(ИмяДокумента, ЭтоПриобретение) Экспорт
	
	Если ИмяДокумента = "ПриобретениеТоваровУслуг" Тогда
		ЭтоПриобретение = Истина;
	ИначеЕсли ИмяДокумента = "ПриемкаТоваровНаХранение" Тогда
		ЭтоПриобретение = Истина;
	ИначеЕсли ИмяДокумента = "ПоступлениеТоваровОтХранителя" Тогда
		ЭтоПриобретение = Истина;
	ИначеЕсли ИмяДокумента = "ПоступлениеТоваровОтКлиента" Тогда
		ЭтоПриобретение = Истина;
	ИначеЕсли ИмяДокумента = "ВозвратТоваровОтКлиента" Тогда
		ЭтоПриобретение = Истина;
	ИначеЕсли ИмяДокумента = "КорректировкаПриобретения" Тогда
		ЭтоПриобретение = Истина;
	КонецЕсли;
	
КонецПроцедуры

// Определяет соответствие проверяемому типу документа, результат возвращает через второй параметр.
//
// Параметры:
//  ИмяДокумента - Строка - Контекст для определения типа документа
//  ЭтоАкт       - Булево - исходящий признак акта о расхождениях.
Процедура ЭтоАктОРасхождениях(ИмяДокумента, ЭтоАкт) Экспорт
	
	Если ИмяДокумента = "АктОРасхожденияхПослеОтгрузки" Тогда
		ЭтоАкт = Истина;
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#КонецОбласти