// Дополняет колллекцию доступных видов оплат видом Электронный сертификат ФСС
//
// Параметры:
//  Форма - ФормаКлиентскогоПриложения - Форма документа:
//  * Объект - ДокументОбъект - Основной реквизит формы
//  ДоступныеВидыОплаты - Структура -
//
Процедура ДополнитьДоступныеВидыОплатыВидомЭСФСС(Форма, ДоступныеВидыОплаты)
	
	ВидОплатыДоступен = Ложь;
	Если Форма.ИспользоватьОплатуЭСФСС 
		И Форма.ЭквайринговыеТерминалы.Количество() > 0
		И ТипЗнч(Форма.ПараметрыКассыККМ) = Тип("ФиксированнаяСтруктура")
		И Форма.ПараметрыКассыККМ.ИспользоватьБезПодключенияОборудования = Ложь
		И ЗначениеЗаполнено(Форма.ПараметрыКассыККМ.ИдентификаторУстройства) Тогда
		
		Для Каждого ЭквайринговыйТерминал Из Форма.ЭквайринговыеТерминалы Цикл
			Если ЭквайринговыйТерминал.Значение.ИспользоватьБезПодключенияОборудования = Ложь 
				И ЭквайринговыйТерминал.Значение.ПодключаемоеОборудованиеККТ = Форма.ПараметрыКассыККМ.ИдентификаторУстройства Тогда
				ВидОплатыДоступен = Истина;
				Прервать;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
	ДоступныеВидыОплаты.Вставить("ЭСФСС", ВидОплатыДоступен);
КонецПроцедуры

//-- Локализация

#КонецОбласти
