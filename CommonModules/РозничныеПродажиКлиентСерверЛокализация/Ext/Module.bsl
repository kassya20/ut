// Перечень форм конфигурации, где встроен механизм работы с МРЦ 
// Возвращаемое значение:
//	Массив из Строка - имена форм
Функция ФормыСоВстроеннымМеханизмомМРЦ() Экспорт
	
	Результат = Новый Массив();
	Результат.Добавить("Документ.ЗаказКлиента.Форма.ФормаДокумента");
	Результат.Добавить("Документ.ЗаявкаНаВозвратТоваровОтКлиента.Форма.ФормаДокумента");
	Результат.Добавить("Документ.РеализацияТоваровУслуг.Форма.ФормаДокумента");
	Результат.Добавить("Документ.ЧекККМ.Форма.ФормаДокументаРМК");
	Результат.Добавить("Документ.ЧекККМВозврат.Форма.ФормаДокументаРМК");
	Результат.Добавить("Обработка.ПодборТоваровВДокументПродажи.Форма.Форма");
	Результат.Добавить("Справочник.БонусныеПрограммыЛояльности.Форма.ОплатаБонуснымиБаллами");
	
	Возврат Результат;
	
КонецФункции

