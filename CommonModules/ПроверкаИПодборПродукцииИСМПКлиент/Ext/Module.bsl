
#Область СлужебныйПрограммныйИнтерфейс

#Область ФормаПроверкиИПодбора

#Область ЗаполнениеКодовМаркировкиПоОснованию

Процедура ПриОпределенииВариантовЗаполненияКодовМаркировки(Форма, ВариантыЗаполнения) Экспорт
	
	ПараметрыСканирования = Форма.ПараметрыСканирования;
	ПроверяемыйДокумент   = Форма.ПроверяемыйДокумент;
	
	ВидОперацииИСМП = ПараметрыСканирования.ВидОперацииИСМП;
	Если ПроверкаИПодборПродукцииИСМПКлиентСервер.ЭтоДокументРеализации(Форма.ВладелецФормы)
		Или ИнтеграцияИСМПКлиентСервер.ОперацииУточненияСведенийОКодахМаркировки().Найти(ВидОперацииИСМП) <> Неопределено
		Или ТипЗнч(ПроверяемыйДокумент) = Тип("ДокументСсылка.ВыводИзОборотаИСМП") Тогда
		
		Если Форма.ЕстьПравоЧтениеДокументаМаркировкаТоваров Тогда
			Если МаркировкаТоваровКлиентСервер.ДоступенОтчетОНанесении(ПараметрыСканирования.ДопустимыеВидыПродукции) Тогда
				ВариантыЗаполнения.Добавить("ПоОтчетамОНанесении", НСтр("ru = 'По отчетам о нанесении'"));
			КонецЕсли;
			ВариантыЗаполнения.Добавить("ПоВводуВОборот", НСтр("ru = 'По вводу в оборот'"));
		КонецЕсли;
		
	Иначе
		
		Если Форма.ЕстьПравоЧтениеДокументаЗаказНаЭмиссиюКодовМаркировки Тогда
			Если ИнтеграцияИСМПКлиентСервер.ОперацииСписанияКодовМаркировки().Найти(ВидОперацииИСМП) <> Неопределено Тогда
				ИмяВарианта = "ПоЗаказамНаЭмиссиюВсеБезИерархии";
			ИначеЕсли ИнтеграцияИСМПКлиентСервер.ОперацииНанесенияКодовМаркировки(, Истина).Найти(ВидОперацииИСМП) <> Неопределено
				Или ИнтеграцияИСМПКлиентСервер.ОперацииВводаВОборотКодовМаркировки().Найти(ВидОперацииИСМП) <> Неопределено Тогда
				ИмяВарианта = "ПоЗаказамНаЭмиссиюОтчетОНанесении";
			Иначе
				ИмяВарианта = "ПоЗаказамНаЭмиссиюПоУмолчанию";
			КонецЕсли;
			ВариантыЗаполнения.Добавить(ИмяВарианта, НСтр("ru = 'По заказам на эмиссию'"));
		КонецЕсли;
		
		Если МаркировкаТоваровКлиентСервер.ДоступенОтчетОНанесении(ПараметрыСканирования.ДопустимыеВидыПродукции)
			И ИнтеграцияИСМПКлиентСервер.ОперацииНанесенияКодовМаркировки().Найти(ВидОперацииИСМП) = Неопределено
			И ВидОперацииИСМП <> ПредопределенноеЗначение("Перечисление.ВидыОперацийИСМП.ПодтверждениеПоступленияКИЗ")
			И Форма.ЕстьПравоЧтениеДокументаМаркировкаТоваров Тогда
			ВариантыЗаполнения.Добавить("ПоОтчетамОНанесении", НСтр("ru = 'По отчетам о нанесении'"));
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

Процедура ПриОбработкеВариантаЗаполненияКодовМаркировки(Форма, РезультатВопроса, СтандартнаяОбработка) Экспорт
	
	ПараметрыОповещения = Новый Структура;
	ПараметрыОповещения.Вставить("Форма",             Форма);
	ПараметрыОповещения.Вставить("ВариантЗаполнения", РезультатВопроса);
	
	Если СтрНачинаетсяС(РезультатВопроса, "ПоЗаказамНаЭмиссию") Тогда
		
		СтандартнаяОбработка = Истина;
		
		Если ЗначениеЗаполнено(Форма.ПроверяемыйДокумент) Тогда
			КодыМаркировки = ПроверкаИПодборПродукцииИСМПВызовСервера.КодыМаркировкиПоОснованию(Форма.ПроверяемыйДокумент);
			Если КодыМаркировки.Количество() Тогда
				Оповестить("ЗагрузкаКодовМаркировкиПоОснованию", КодыМаркировки, Форма);
				Возврат;
			КонецЕсли;
		КонецЕсли;
		
		ОповещениеОЗавершении = Новый ОписаниеОповещения(
			"ПослеВыбораЗаказовНаЭмиссию", ЭтотОбъект, ПараметрыОповещения);
		ВыбратьЗаказыНаЭмиссиюДляЗаполненияКодовМаркировки(Форма, ОповещениеОЗавершении);
		
	ИначеЕсли РезультатВопроса = "ПоОтчетамОНанесении" Тогда
		
		СтандартнаяОбработка = Истина;
		ПараметрыЗаполнения = Новый Структура;
		ПараметрыЗаполнения.Вставить("ПоОтчетамОНанесении", Истина);
		
		ОповещениеОЗавершении = Новый ОписаниеОповещения(
			"ПослеВыбораМаркировкиТоваровИСМП", ЭтотОбъект, ПараметрыОповещения);
		ВыбратьМаркировкуТоваровДляЗаполненияКодовМаркировки(Форма, ОповещениеОЗавершении, ПараметрыЗаполнения);
		
	ИначеЕсли РезультатВопроса = "ПоВводуВОборот" Тогда
		
		СтандартнаяОбработка = Истина;
		ПараметрыЗаполнения = Новый Структура;
		ПараметрыЗаполнения.Вставить("ПоОтчетамОНанесении", Ложь);
		
		ОповещениеОЗавершении = Новый ОписаниеОповещения(
			"ПослеВыбораМаркировкиТоваровИСМП", ЭтотОбъект, ПараметрыОповещения);
		ВыбратьМаркировкуТоваровДляЗаполненияКодовМаркировки(Форма, ОповещениеОЗавершении, ПараметрыЗаполнения);
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#КонецОбласти

#Область Проверки

Функция НоменклатураОтличаетсяОтНоменклатурыПроверяемойУпаковки(Форма, ДанныеПроверяемойУпаковки, ДанныеНовойУпаковки) Экспорт
	
	Если ДанныеПроверяемойУпаковки = Неопределено
		Или ДанныеПроверяемойУпаковки = Форма.ДеревоМаркированнойПродукции
		Или ДанныеНовойУпаковки = Неопределено
		Или ДанныеНовойУпаковки = Форма.ДеревоМаркированнойПродукции
		Или Не ЗначениеЗаполнено(ДанныеПроверяемойУпаковки.GTIN)
		Или ДанныеПроверяемойУпаковки.ТипУпаковки = ПредопределенноеЗначение("Перечисление.ТипыУпаковок.МультитоварнаяУпаковка")
		Или ДанныеПроверяемойУпаковки.ВидУпаковки = ПредопределенноеЗначение("Перечисление.ВидыУпаковокИС.Набор") Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ДанныеПроверяемойУпаковки.Номенклатура)
		И ЗначениеЗаполнено(ДанныеНовойУпаковки.Номенклатура) Тогда
		
		Если ДанныеПроверяемойУпаковки.Номенклатура = ДанныеНовойУпаковки.Номенклатура
			И (ДанныеПроверяемойУпаковки.Характеристика = ДанныеНовойУпаковки.Характеристика
				Или Не ЗначениеЗаполнено(ДанныеПроверяемойУпаковки.Характеристика)
					И Не ЗначениеЗаполнено(ДанныеНовойУпаковки.Характеристика)) Тогда
			Возврат Ложь;
		КонецЕсли;
		
		Возврат Истина;
		
	КонецЕсли;
	
	Возврат Ложь;
	
КонецФункции

Функция ПараметрыОткрытияФормыОшибкиСОтличающейсяНоменклатурой(ДанныеПроверяемойУпаковки, ДанныеНовойУпаковки) Экспорт
	
	ЦветГиперссылкиГосИС = Новый Цвет(28, 85, 174);
	
	ПредставлениеСодержимоеУпаковки = ИнтеграцияИСКлиентСервер.ПредставлениеНоменклатуры(
		ДанныеПроверяемойУпаковки.Номенклатура,
		ДанныеПроверяемойУпаковки.Характеристика,,
		ДанныеПроверяемойУпаковки.Серия);
	
	СтрокаШтриховойКод = Новый ФорматированнаяСтрока(
		ДанныеПроверяемойУпаковки.Штрихкод,
		Новый Шрифт(,,,,Истина),
		ЦветГиперссылкиГосИС,,
		"СкопироватьШтриховойКодВБуферОбмена");
	
	ТекстОшибкиФорматированнаяСтрока = Новый ФорматированнаяСтрока(
		НСтр("ru = 'номенклатура упаковок не совпадает.'"), Символы.ПС,
		НСтр("ru = 'В упаковке'"), " ", СтрокаШтриховойКод, " ",
		НСтр("ru = 'может находиться только:'"), " ", ПредставлениеСодержимоеУпаковки);
	
	ПараметрыОткрытияФормы = ШтрихкодированиеИСКлиент.ПараметрыОткрытияФормыНевозможностиДобавленияОтсканированного();
	ЗаполнитьЗначенияСвойств(ПараметрыОткрытияФормы, ДанныеНовойУпаковки);
	ПараметрыОткрытияФормы.ТекстОшибкиФорматированнаяСтрока = ТекстОшибкиФорматированнаяСтрока;
	
	Возврат ПараметрыОткрытияФормы;
	
КонецФункции

Функция ТипыШтрихкодаВГрупповойУпаковкеРазличаются(Форма, ДанныеПроверяемойУпаковки, ДанныеНовойУпаковки) Экспорт
	
	Если ДанныеПроверяемойУпаковки = Неопределено
		Или ДанныеПроверяемойУпаковки = Форма.ДеревоМаркированнойПродукции
		Или ДанныеНовойУпаковки = Неопределено
		Или ДанныеНовойУпаковки = Форма.ДеревоМаркированнойПродукции
		Или ДанныеПроверяемойУпаковки.ВидУпаковки <> ПредопределенноеЗначение("Перечисление.ВидыУпаковокИС.Групповая") Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ДанныеПроверяемойУпаковки.ТипШтрихкода)
		И ЗначениеЗаполнено(ДанныеНовойУпаковки.ТипШтрихкода) Тогда
		
		ТекущийТипШтрихкода = ДанныеНовойУпаковки.ТипШтрихкода;
		
		Для Каждого ВложеннаяСтрокаДерева Из ДанныеПроверяемойУпаковки.ПолучитьЭлементы() Цикл
			
			Если ВложеннаяСтрокаДерева.ТипШтрихкода <> ТекущийТипШтрихкода Тогда
				Возврат Истина;
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЕсли;
	
	Возврат Ложь;
	
КонецФункции

Функция ПараметрыОткрытияФормыОшибкиСОтличающимсяТипомШтрихкода(ДанныеПроверяемойУпаковки, ДанныеНовойУпаковки) Экспорт
	
	ЦветГиперссылкиГосИС = Новый Цвет(28, 85, 174);
	
	СтрокаШтриховойКод = Новый ФорматированнаяСтрока(
		ДанныеПроверяемойУпаковки.Штрихкод,
		Новый Шрифт(,,,,Истина),
		ЦветГиперссылкиГосИС,,
		"СкопироватьШтриховойКодВБуферОбмена");
	
	ТекстОшибкиФорматированнаяСтрока = Новый ФорматированнаяСтрока(
		НСтр("ru = 'Упаковка'"), " ", СтрокаШтриховойКод, " ", Символы.ПС,
		НСтр("ru = 'не может содержать разные шаблоны кодов маркировки.'"));
	
	ПараметрыОткрытияФормы = ШтрихкодированиеИСКлиент.ПараметрыОткрытияФормыНевозможностиДобавленияОтсканированного();
	ЗаполнитьЗначенияСвойств(ПараметрыОткрытияФормы, ДанныеНовойУпаковки);
	ПараметрыОткрытияФормы.ТекстОшибкиФорматированнаяСтрока = ТекстОшибкиФорматированнаяСтрока;
	
	Возврат ПараметрыОткрытияФормы;
	
КонецФункции

Функция НоменклатураНеВходитВСоставНабора(Форма, ДанныеПроверяемойУпаковки, ДанныеНовойУпаковки, КешКомплектующиеНаборов = Неопределено, КомплектующиеНаборов = Неопределено) Экспорт
	
	Если ДанныеПроверяемойУпаковки = Неопределено
		Или ДанныеПроверяемойУпаковки = Форма.ДеревоМаркированнойПродукции
		Или ДанныеНовойУпаковки = Неопределено
		Или ДанныеНовойУпаковки = Форма.ДеревоМаркированнойПродукции
		Или ДанныеПроверяемойУпаковки.ВидУпаковки <> ПредопределенноеЗначение("Перечисление.ВидыУпаковокИС.Набор") Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Если КешКомплектующиеНаборов <> Неопределено Тогда
		
		КешКомплектующиеНаборовСоответствиеХарактеристик = КешКомплектующиеНаборов[ДанныеПроверяемойУпаковки.Номенклатура];
		
		Если КешКомплектующиеНаборовСоответствиеХарактеристик = Неопределено Тогда
			
			КешКомплектующиеНаборовСоответствиеХарактеристик = Новый Соответствие();
			КешКомплектующиеНаборов.Вставить(ДанныеПроверяемойУпаковки.Номенклатура, КешКомплектующиеНаборовСоответствиеХарактеристик);
			
		Иначе
			
			КомплектующиеНаборов = КешКомплектующиеНаборовСоответствиеХарактеристик[ДанныеПроверяемойУпаковки.Характеристика];
			
		КонецЕсли;
		
	Иначе
		
		КешКомплектующиеНаборовСоответствиеХарактеристик = Новый Соответствие();
		
		КешКомплектующиеНаборов = Новый Соответствие();
		КешКомплектующиеНаборов.Вставить(ДанныеПроверяемойУпаковки.Номенклатура, КешКомплектующиеНаборовСоответствиеХарактеристик);
		
	КонецЕсли;
	
	Если КомплектующиеНаборов = Неопределено Тогда
		
		КомплектующиеНаборов = ПроверкаИПодборПродукцииИСМПВызовСервера.КомплектующиеНаборов(
			ДанныеПроверяемойУпаковки.Номенклатура, ДанныеПроверяемойУпаковки.Характеристика, ДанныеПроверяемойУпаковки.GTIN);
		КешКомплектующиеНаборовСоответствиеХарактеристик.Вставить(ДанныеПроверяемойУпаковки.Характеристика, КомплектующиеНаборов);
		
	КонецЕсли;
	
	НоменклатураВходитВСоставНабора = Ложь;
	Если КомплектующиеНаборов.Количество() Тогда
		Для Каждого ЭлементНабора Из КомплектующиеНаборов Цикл
			Если ЭлементНабора.Номенклатура = ДанныеНовойУпаковки.Номенклатура
				И ЭлементНабора.Характеристика = ДанныеНовойУпаковки.Характеристика Тогда
				НоменклатураВходитВСоставНабора = Истина;
				Прервать;
			КонецЕсли;
		КонецЦикла;
	Иначе
		Возврат Ложь;
	КонецЕсли;
	
	Возврат Не НоменклатураВходитВСоставНабора;
	
КонецФункции

Функция ПараметрыОткрытияФормыОшибкиНоменклатураНеВходитВСоставНабора(ДанныеПроверяемойУпаковки, ДанныеНовойУпаковки, КомплектующиеНаборов) Экспорт
	
	ЦветГиперссылкиГосИС = Новый Цвет(28, 85, 174);
	
	СтрокаШтриховойКод = Новый ФорматированнаяСтрока(
		ДанныеПроверяемойУпаковки.Штрихкод,
		Новый Шрифт(,,,,Истина),
		ЦветГиперссылкиГосИС,,
		"СкопироватьШтриховойКодВБуферОбмена");
	
	ЭлементыТекста = Новый Массив;
	
	ЭлементТекстаОшибки = Новый ФорматированнаяСтрока(
		НСтр("ru = 'В упаковке'"), " ", СтрокаШтриховойКод, " ",
		НСтр("ru = 'могут находиться находиться:'"));
	ЭлементыТекста.Добавить(ЭлементТекстаОшибки);
	Для Каждого ЭлементНабора Из КомплектующиеНаборов Цикл
		ЭлементыТекста.Добавить(Символы.ПС);
		ЭлементТекстаОшибки = Новый ФорматированнаяСтрока(
			СтрШаблон("- %1", ИнтеграцияИСКлиентСервер.ПредставлениеНоменклатуры(
				ЭлементНабора.Номенклатура,
				ЭлементНабора.Характеристика)));
		ЭлементыТекста.Добавить(ЭлементТекстаОшибки);
	КонецЦикла;
	
	ПараметрыОткрытияФормы = ШтрихкодированиеИСКлиент.ПараметрыОткрытияФормыНевозможностиДобавленияОтсканированного();
	ЗаполнитьЗначенияСвойств(ПараметрыОткрытияФормы, ДанныеНовойУпаковки);
	ПараметрыОткрытияФормы.ТекстОшибкиФорматированнаяСтрока = Новый ФорматированнаяСтрока(ЭлементыТекста);
	
	Возврат ПараметрыОткрытияФормы;
	
КонецФункции

#КонецОбласти

Функция ЭтоИзменениеЭлементаВГрупповойУпаковке(СтрокаДерева, ДополнительныеПараметры) Экспорт
	
	Если Не ДополнительныеПараметры.Свойство("ПроизвольноеРедактированиеРеквизитов")
			Или Не ДополнительныеПараметры.ПроизвольноеРедактированиеРеквизитов Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Упаковка = СтрокаДерева.ПолучитьРодителя();
	
	Если Упаковка = Неопределено 
		Или (Упаковка.ВидУпаковки <> ПредопределенноеЗначение("Перечисление.ВидыУпаковокИС.Групповая")
			И Упаковка.ВидУпаковки <> ПредопределенноеЗначение("Перечисление.ВидыУпаковокИС.Набор")) Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Возврат Истина;
	
КонецФункции

Процедура ОповеститьОСопоставленииНоменклатурыШтрихкодам(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат <> Неопределено
		И ТипЗнч(Результат) = Тип("Структура")
		И Результат.Свойство("ЗарегистрированныеШтрихкоды")
		И Результат.Свойство("ШтрихкодыНоменклатуры")
		И Результат.Свойство("ФормаВладелец")
		И ЗначениеЗаполнено(Результат.ЗарегистрированныеШтрихкоды) Тогда
		
		ЗарегистрированныеШтрихкоды = Новый Соответствие;
		Для Каждого Строка Из Результат.ЗарегистрированныеШтрихкоды Цикл
			Если РазборКодаМаркировкиИССлужебныйКлиентСерверПовтИсп.ЭтоGTIN(Строка.Штрихкод) Тогда
				ЗарегистрированныеШтрихкоды[Строка.Штрихкод] = Истина;
			КонецЕсли;
		КонецЦикла;
		
		ТоварныеПозицииGTIN = Новый Массив;
		
		Для Каждого Строка Из Результат.ШтрихкодыНоменклатуры Цикл
			
			Если ЗарегистрированныеШтрихкоды[Строка.Штрихкод] = Неопределено
				Или Не ЗначениеЗаполнено(Строка.Номенклатура) Тогда
				Продолжить;
			КонецЕсли;
			
			Данные = Новый Структура;
			Данные.Вставить("Номенклатура",   Строка.Номенклатура);
			Данные.Вставить("Характеристика", Строка.Характеристика);
			Данные.Вставить("GTIN",           ШтрихкодированиеОбщегоНазначенияИСКлиентСервер.GTINПоШтрихкодуEAN(Строка.Штрихкод));
			
			ТоварныеПозицииGTIN.Добавить(Данные);
			
		КонецЦикла;
		
		Если ТоварныеПозицииGTIN.Количество() > 0 Тогда
			
			Оповестить("СопоставлениеНоменклатурыШтрихкодам", ТоварныеПозицииGTIN, Результат.ФормаВладелец);
			
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

Функция ОбновитьПризнакиКонтроляОборотаМарокПоСтроке(Форма, ДанныеСтроки, Сценарий = 0) Экспорт
	
	СтруктураВозврата = Новый Структура("ДействуетКонтрольОборотаМарок, РазрешенОборотНемаркированныхОстатков", Истина, Ложь);
	
	Если Не ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(Форма, "ТаблицаКонтролейДатМаркировкиГосИС") Тогда
		Возврат СтруктураВозврата;
	КонецЕсли;
	
	Если Не ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(ДанныеСтроки, "ВидПродукцииИС") Тогда
		Возврат СтруктураВозврата;
	КонецЕсли;
	
	ВидПродукцииИС = ДанныеСтроки.ВидПродукцииИС;
	
	Если ЗначениеЗаполнено(Сценарий) Тогда
		Контекст = ШтрихкодированиеОбщегоНазначенияИСКлиентСервер.КонтекстФормыСУказаниемСценария(Форма, Сценарий);
	Иначе
		Контекст = Форма;
	КонецЕсли;
	
	ПараметрыСканирования = ШтрихкодированиеОбщегоНазначенияИСКлиент.ПараметрыСканирования(Контекст);
	
	Если КонструкторИСОбщегоНазначенияКлиентСервер.ЭтоПродукцияИСМП(ВидПродукцииИС, Истина) Тогда
		
		ВидОперации   = ПараметрыСканирования.ВидОперацииИСМП;
		ДатаДокумента = ПараметрыСканирования.ДатаДокумента;
		
		Если Не ЗначениеЗаполнено(ДатаДокумента) Тогда
			ДатаДокумента = НачалоДня(ОбщегоНазначенияКлиент.ДатаСеанса());
		КонецЕсли;
		
		ТаблицаДатРазделенногоКонтроля = Форма.ТаблицаКонтролейДатМаркировкиГосИС;
		СтруктураОтбора                = Новый Структура("ВидПродукции", ВидПродукцииИС);
		НастройкиДатКонтроля           = ТаблицаДатРазделенногоКонтроля.НайтиСтроки(СтруктураОтбора);
		
		Если НастройкиДатКонтроля.Количество() Тогда
			СтруктураДатКонтроля = ОбщегоНазначенияИСМПКлиентСервер.ИнициализироватьНастройкуДатРаздельногоКонтроля();
			ЗаполнитьЗначенияСвойств(СтруктураДатКонтроля, НастройкиДатКонтроля[0]);
		Иначе
			СтруктураДатКонтроля = Новый Структура();
		КонецЕсли;
		
		ПроверятьВозможностьОборотаНемаркированныхОстатков = ОбщегоНазначенияИСМПКлиентСерверПовтИсп.ДействуетОборотНемаркированныхОстатковПоРазделеннымДатам(ВидОперации,
			СтруктураДатКонтроля,
			ДатаДокумента);
		
		ДействуетКонтрольОборотаМарок                      = ОбщегоНазначенияИСМПКлиентСерверПовтИсп.ДействуетКонтрольПоРазделеннымДатам(ВидОперации,
			ВидПродукцииИС,
			СтруктураДатКонтроля,
			ДатаДокумента);
			
		СтруктураВозврата.ДействуетКонтрольОборотаМарок         = ДействуетКонтрольОборотаМарок;
		СтруктураВозврата.РазрешенОборотНемаркированныхОстатков = ПроверятьВозможностьОборотаНемаркированныхОстатков;
		
	Иначе
		
		ПроверятьВозможностьОборотаНемаркированныхОстатков = Ложь;
		ДействуетКонтрольОборотаМарок                      = Истина;
		
	КонецЕсли;
	
	Возврат СтруктураВозврата;
	
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

#Область ОткрытиеФормыПроверкиИПодбора

Процедура ПриУстановкеПараметровОткрытияФормыПроверкиИПодбора(Форма, ПараметрыОткрытия) Экспорт
	
	Если ШтрихкодированиеИСКлиентСервер.ЭтоКонтекстОбъекта(Форма, "Документ.МаркировкаТоваровИСМП") Тогда
		ПараметрыОткрытия.ПроверятьНеобходимостьПеремаркировки = Ложь;
		ПараметрыОткрытия.ДоступноСозданиеНовыхУпаковок        = Истина;
		ПараметрыОткрытия.ДопустимыйСпособВводаВОборот         =
			ШтрихкодированиеИСМПКлиентСервер.СпособВводаВОборотСУЗПоВидуОперации(Форма.Объект.Операция, Форма.Объект.ТоварнаяГруппа);
		ПараметрыОткрытия.ДанныеВыбораПоМаркируемойПродукции       = Форма.ДанныеВыбораПоМаркируемойПродукции;
		ПараметрыОткрытия.СохраненВыборПоМаркируемойПродукции      = Форма.СохраненВыборПоМаркируемойПродукции;
		ПараметрыОткрытия.РежимИсправленияОшибокПослеПередачиКодов = Форма.РежимИсправленияОшибокПослеПередачиКодов;
		ОбщиеПараметрыОткрытияФормыПроверкиИПодбора(Форма, ПараметрыОткрытия);
	ИначеЕсли ШтрихкодированиеИСКлиентСервер.ЭтоКонтекстОбъекта(Форма, "Документ.ВыводИзОборотаИСМП") Тогда
		ОбщиеПараметрыОткрытияФормыПроверкиИПодбора(Форма, ПараметрыОткрытия);
	ИначеЕсли ШтрихкодированиеИСКлиентСервер.ЭтоКонтекстОбъекта(Форма, "Документ.СписаниеКодовМаркировкиИСМП") Тогда
		ПараметрыОткрытия.РежимИсправленияОшибокПослеПередачиКодов = Форма.РежимИсправленияОшибокПослеПередачиКодов;
		ОбщиеПараметрыОткрытияФормыПроверкиИПодбора(Форма, ПараметрыОткрытия);
	ИначеЕсли ШтрихкодированиеИСКлиентСервер.ЭтоКонтекстОбъекта(Форма, "Документ.ПеремаркировкаТоваровИСМП") Тогда
		ОбщиеПараметрыОткрытияФормыПроверкиИПодбора(Форма, ПараметрыОткрытия);
	ИначеЕсли ШтрихкодированиеИСКлиентСервер.ЭтоКонтекстОбъекта(Форма, "Документ.ОтгрузкаТоваровИСМП") Тогда
		ОбщиеПараметрыОткрытияФормыПроверкиИПодбора(Форма, ПараметрыОткрытия);
	ИначеЕсли ШтрихкодированиеИСКлиентСервер.ЭтоКонтекстОбъекта(Форма, "Документ.ПриемкаТоваровИСМП") Тогда
		ПараметрыОткрытия.ИмяРеквизитаКонтрагент = "Контрагент";
		ПараметрыОткрытия.ПроверкаЭлектронногоДокумента = Истина;
		ПараметрыОткрытия.РежимПодбораСуществующихУпаковок = Ложь;
		ОбщиеПараметрыОткрытияФормыПроверкиИПодбора(Форма, ПараметрыОткрытия);
	ИначеЕсли ШтрихкодированиеИСКлиентСервер.ЭтоКонтекстОбъекта(Форма, "Документ.УточнениеСведенийОКодахМаркировкиИСМП") Тогда
		ОбщиеПараметрыОткрытияФормыПроверкиИПодбора(Форма, ПараметрыОткрытия);
	ИначеЕсли ШтрихкодированиеИСКлиентСервер.ЭтоКонтекстОбъекта(Форма, "Документ.ОтчетОбИмпортеЕГАИС") Тогда
		ПараметрыОткрытия.ИмяРеквизитаОрганизация             = "";
		ПараметрыОткрытия.ДопустимыйСпособВводаВОборот        = ПредопределенноеЗначение("Перечисление.СпособыВводаВОборотСУЗ.Импорт");
		ПараметрыОткрытия.ДанныеВыбораПоМаркируемойПродукции  = Форма.ДанныеВыбораПоМаркируемойПродукции;
		ПараметрыОткрытия.СохраненВыборПоМаркируемойПродукции = Форма.СохраненВыборПоМаркируемойПродукции;
		ОбщиеПараметрыОткрытияФормыПроверкиИПодбора(Форма, ПараметрыОткрытия);
	ИначеЕсли ШтрихкодированиеИСКлиентСервер.ЭтоКонтекстОбъекта(Форма, "Документ.ОтчетОПроизводствеЕГАИС") Тогда
		Если ПараметрыОткрытия.Сценарий = 0 Тогда
			ПараметрыОткрытия.ИмяРеквизитаОрганизация             = "";
			ПараметрыОткрытия.ДопустимыйСпособВводаВОборот        = ПредопределенноеЗначение("Перечисление.СпособыВводаВОборотСУЗ.Производство");
			ПараметрыОткрытия.ДанныеВыбораПоМаркируемойПродукции  = Форма.ДанныеВыбораПоМаркируемойПродукции;
			ПараметрыОткрытия.СохраненВыборПоМаркируемойПродукции = Форма.СохраненВыборПоМаркируемойПродукции;
			ОбщиеПараметрыОткрытияФормыПроверкиИПодбора(Форма, ПараметрыОткрытия);
		КонецЕсли;
	ИначеЕсли ШтрихкодированиеИСКлиентСервер.ЭтоКонтекстОбъекта(Форма, "Документ.ПеремещениеМеждуМОДИСМП") Тогда
		ПараметрыОткрытия.ДанныеВыбораПоМаркируемойПродукции  = Форма.ДанныеВыбораПоМаркируемойПродукции;
		ПараметрыОткрытия.СохраненВыборПоМаркируемойПродукции = Форма.СохраненВыборПоМаркируемойПродукции;
		ОбщиеПараметрыОткрытияФормыПроверкиИПодбора(Форма, ПараметрыОткрытия);
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

Функция ЕстьРасхожденияПоРезультатамПроверкиИПодбора(ПодобраннаяМаркируемаяПродукция, РазрешенОборотНемаркированныхОстатков = Ложь) Экспорт
	
	Для Каждого СтрокаПодобраннойПродукции Из ПодобраннаяМаркируемаяПродукция Цикл
		
		Если РазрешенОборотНемаркированныхОстатков И 
			(СтрокаПодобраннойПродукции.ИндексКодаМаркировки = 6 Или СтрокаПодобраннойПродукции.ИндексКодаМаркировки = 7) Тогда
			// немаркированные остатки, не подобранные или частично подобранные
			Продолжить;
		КонецЕсли;
		
		Если СтрокаПодобраннойПродукции.Количество <> СтрокаПодобраннойПродукции.КоличествоПодобрано Тогда
			Возврат Истина;
		КонецЕсли;
		
	КонецЦикла;
	 
	Возврат Ложь;
	
КонецФункции

#Область ТипыШтрихкодов

Функция ДоступныеТипыШтрихкодовСтрокой() Экспорт
	
	ДоступныеТипы = Новый СписокЗначений();
	
	ДоступныеТипы.Добавить("GS1128");
	ДоступныеТипы.Добавить("SSCC");
	
	Возврат ДоступныеТипы;
	
КонецФункции

#КонецОбласти

#Область ФормаПроверкиИПодбора

Процедура ОбщиеПараметрыОткрытияФормыПроверкиИПодбора(Форма, ПараметрыОткрытия)
	
	ПараметрыОткрытия.ИмяРеквизитаСклад = "";
	ПараметрыОткрытия.ИСМП = Истина;
	
	Если Форма.РедактированиеФормыНеДоступно Тогда
		ПараметрыОткрытия.РедактированиеФормыНедоступно = Истина;
	Иначе
		ПараметрыОткрытия.РедактированиеФормыНедоступно = НЕ Форма.ПравоИзменения;
	КонецЕсли;
	
КонецПроцедуры

#Область ЗаполнениеКодовМаркировкиПоОснованию

Процедура ВыбратьЗаказыНаЭмиссиюДляЗаполненияКодовМаркировки(Форма, ОповещениеОЗавершении)
	
	ТоварныеГруппы = КонструкторИСОбщегоНазначенияКлиентСервер.ЗначенияЭлементаКонструктораПоВидуПродукции(
		ПредопределенноеЗначение("Справочник.ЭлементыКонструктораВидовПродукцииИС.ТоварныеГруппыГИСМТ"),
		Форма.ДопустимыеВидыПродукции);
	
	СтруктураОтбора = Новый Структура();
	СтруктураОтбора.Вставить("Организация",     Форма.Организация);
	СтруктураОтбора.Вставить("ТоварнаяГруппа",  ТоварныеГруппы);
	СтруктураОтбора.Вставить("СервисПровайдер", ПредопределенноеЗначение("Справочник.СервисПровайдерыСУЗ.ПустаяСсылка"));
	
	Если ЗначениеЗаполнено(Форма.ПроверяемыйДокумент)
		И ТипЗнч(Форма.ПроверяемыйДокумент) = Тип("ДокументСсылка.МаркировкаТоваровИСМП") Тогда
		СпособВводаВОборот = ШтрихкодированиеИСМПКлиентСервер.СпособВводаВОборотСУЗПоВидуОперации(
			ПроверкаИПодборПродукцииИСМПВызовСервера.ОперацияДокументаМаркировкиТоваровов(Форма.ПроверяемыйДокумент),
			ТоварныеГруппы);
		Если ЗначениеЗаполнено(СпособВводаВОборот) Тогда
			СтруктураОтбора.Вставить("СпособВводаВОборот", СпособВводаВОборот);
		КонецЕсли;
	КонецЕсли;
	
	ПараметрыОткрытия = Новый Структура;
	ПараметрыОткрытия.Вставить("Отбор",              СтруктураОтбора);
	ПараметрыОткрытия.Вставить("МножественныйВыбор", Истина);
	ПараметрыОткрытия.Вставить("РежимВыбора",        Истина);
	
	ОткрытьФорму(
		"Документ.ЗаказНаЭмиссиюКодовМаркировкиСУЗ.Форма.ФормаСпискаДокументов",
		ПараметрыОткрытия,
		ЭтотОбъект,
		Форма.УникальныйИдентификатор,,,
		ОповещениеОЗавершении,
		РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	
КонецПроцедуры

Процедура ВыбратьМаркировкуТоваровДляЗаполненияКодовМаркировки(Форма, ОповещениеОЗавершении, ПараметрыЗаполнения)
	
	ТоварныеГруппы = КонструкторИСОбщегоНазначенияКлиентСервер.ЗначенияЭлементаКонструктораПоВидуПродукции(
		ПредопределенноеЗначение("Справочник.ЭлементыКонструктораВидовПродукцииИС.ТоварныеГруппыГИСМТ"),
		Форма.ДопустимыеВидыПродукции);
	
	СтруктураОтбора = Новый Структура();
	СтруктураОтбора.Вставить("Организация",    Форма.Организация);
	СтруктураОтбора.Вставить("ТоварнаяГруппа", ТоварныеГруппы);
	
	Если ПараметрыЗаполнения.ПоОтчетамОНанесении Тогда
		СтруктураОтбора.Вставить("Операция", ИнтеграцияИСМПКлиентСервер.ОперацииНанесенияКодовМаркировки());
		Если ЗначениеЗаполнено(Форма.ПроверяемыйДокумент)
			И ТипЗнч(Форма.ПроверяемыйДокумент) = Тип("ДокументСсылка.МаркировкаТоваровИСМП") Тогда
			СпособВводаВОборот = ШтрихкодированиеИСМПКлиентСервер.СпособВводаВОборотСУЗПоВидуОперации(
				ПроверкаИПодборПродукцииИСМПВызовСервера.ОперацияДокументаМаркировкиТоваровов(Форма.ПроверяемыйДокумент),
				ТоварныеГруппы);
			Если ЗначениеЗаполнено(СпособВводаВОборот) Тогда
				СтруктураОтбора.Вставить("СпособВводаВОборот", СпособВводаВОборот);
			КонецЕсли;
		КонецЕсли;
	Иначе
		СтруктураОтбора.Вставить("Операция", ИнтеграцияИСМПКлиентСервер.ОперацииВводаВОборотКодовМаркировки());
	КонецЕсли;
	
	ПараметрыОткрытия = Новый Структура;
	ПараметрыОткрытия.Вставить("Отбор",              СтруктураОтбора);
	ПараметрыОткрытия.Вставить("МножественныйВыбор", Истина);
	ПараметрыОткрытия.Вставить("РежимВыбора",        Истина);

	ОткрытьФорму(
		"Документ.МаркировкаТоваровИСМП.Форма.ФормаСпискаДокументов",
		ПараметрыОткрытия,
		ЭтотОбъект,
		Форма.УникальныйИдентификатор,,,
		ОповещениеОЗавершении,
		РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	
КонецПроцедуры

Процедура ПослеВыбораЗаказовНаЭмиссию(ВыбранныеЗаказы, ПараметрыОповещения) Экспорт
	
	Если ВыбранныеЗаказы = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	РежимПолученияКодов = СтрЗаменить(ПараметрыОповещения.ВариантЗаполнения, "ПоЗаказамНаЭмиссию", "");
	КодыМаркировки = ПроверкаИПодборПродукцииИСМПВызовСервера.КодыМаркировкиПоЗаказамНаЭмиссию(ВыбранныеЗаказы, РежимПолученияКодов);
	Оповестить("ЗагрузкаКодовМаркировкиПоОснованию", КодыМаркировки, ПараметрыОповещения.Форма);
	
КонецПроцедуры

Процедура ПослеВыбораМаркировкиТоваровИСМП(ВыбранныеДокументы, ПараметрыОповещения) Экспорт
	
	Если ВыбранныеДокументы = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	КодыМаркировки = ПроверкаИПодборПродукцииИСМПВызовСервера.КодыМаркировкиПоМаркировкеТоваров(ВыбранныеДокументы);
	Оповестить("ЗагрузкаКодовМаркировкиПоОснованию", КодыМаркировки, ПараметрыОповещения.Форма);
	
КонецПроцедуры

