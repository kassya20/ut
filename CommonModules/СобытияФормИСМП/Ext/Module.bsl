КонецПроцедуры

#КонецОбласти

#КонецОбласти

#Область ФормыСписковДокументовИСМП

Процедура ЗаполнитьСписокВыбораОрганизацииПоСохраненнымНастройкам(Форма, Знач ЗначениеПрефиксы = Неопределено) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	Если ЗначениеПрефиксы = Неопределено Тогда
		Префиксы = Новый Массив;
		Префиксы.Добавить("Оформлено");
		Префиксы.Добавить("КОформлению");
	Иначе
		Если ТипЗнч(ЗначениеПрефиксы) = Тип("Строка") Тогда
			Префиксы = Новый Массив();
			Префиксы.Добавить(ЗначениеПрефиксы);
		Иначе
			Префиксы = ЗначениеПрефиксы;
		КонецЕсли;
	КонецЕсли;
	
	Для Каждого Значение Из Префиксы Цикл
		Форма.Элементы[Значение + "Организация"].СписокВыбора.Очистить();
		Форма.Элементы[Значение + "Организации"].СписокВыбора.Очистить();
	КонецЦикла;
	
	ПараметрыОтбора = Новый Структура("КлючОбъекта", "ОбщаяФорма.ФормаВыбораСпискаОрганизацийИСМП");
	
	Выборка = ХранилищеНастроекДанныхФорм.Выбрать(ПараметрыОтбора);
	
	Пока Выборка.Следующий() Цикл
		
		Данные = Новый Массив;
		Значение = Выборка.Настройки.Получить("ТаблицаОрганизации");
		Если Значение <> Неопределено Тогда
			
			ПараметрыОтбора = Новый Структура;
			ПараметрыОтбора.Вставить("Выбрана", Истина);
			НайденныеСтроки = Значение.НайтиСтроки(ПараметрыОтбора);
			
			Для Каждого СтрокаТЧ Из НайденныеСтроки Цикл
				Данные.Добавить(СтрокаТЧ.Организация);
			КонецЦикла;
			
			Для Каждого Значение Из Префиксы Цикл
				ЭлементОтбораОрганизация = Форма.Элементы.Найти(Значение + "Организация");
				Если ЭлементОтбораОрганизация <> Неопределено Тогда
					ЭлементОтбораОрганизация.СписокВыбора.Добавить(Данные, СтрСоединить(Данные, "; "));
				КонецЕсли;
		
				ЭлементОтбораОрганизации = Форма.Элементы.Найти(Значение + "Организации");
				Если ЭлементОтбораОрганизации <> Неопределено Тогда
					ЭлементОтбораОрганизации.СписокВыбора.Добавить(Данные, СтрСоединить(Данные, "; "));
				КонецЕсли;
			КонецЦикла;
			
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

// Дорабатывает форму списка документов:
//   * Добавляет необходимые отборы
//   * Скрывает списки к оформлению при необходимости.
//
// Параметры:
//   Форма     - ФормаКлиентскогоПриложения - форма списка документов ИСМП.
//   Настройки - Структура        - (См. ИнтеграцияИС.НастройкиФормыСпискаДокументов).
//             - Неопределено     - будут использованы значения по умолчанию описанные здесь.
//
Процедура ПриСозданииНаСервереФормыСпискаДокументов(Форма, Настройки = Неопределено) Экспорт
	
	Если Настройки = Неопределено Тогда
		Настройки = ИнтеграцияИС.НастройкиФормыСпискаДокументов();
		Настройки.ТипыКОформлению = Метаданные.ОпределяемыеТипы.ДокументыИСМППоддерживающиеСтатусыОформления;
		Настройки.ТипыКОбмену     = Метаданные.ОпределяемыеТипы.ДокументыИСМП;
	КонецЕсли;
	ИнтеграцияИС.ПриСозданииНаСервереФормыСпискаДокументов(Форма, Настройки);
	
КонецПроцедуры

// Добавить элемент для создания.
// 
// Параметры:
//  Приемник - Массив из См. НастройкиСозданияЭлемента
//  ИмяЭлемента - Строка - Имя элемента
//  Подменю - Неопределено - Подменю
//  Заголовок - Строка - Заголовок
Процедура ДобавитьЭлементДляСоздания(Приемник, ИмяЭлемента, Подменю = Неопределено, Заголовок = "") Экспорт
	
	НастройкиСоздания =  НастройкиСозданияЭлемента();
	НастройкиСоздания.ИмяЭлемента = ИмяЭлемента;
	НастройкиСоздания.Подменю     = Подменю;
	НастройкиСоздания.Заголовок   = Заголовок;
	
	Приемник.Добавить(НастройкиСоздания);
	
КонецПроцедуры

// Добавить элемент формы кнопка.
// 
// Параметры:
//  Форма - ФормаКлиентскогоПриложения - форма, из которой выполняется команда.
//  ИмяОперации - Строка - Имя операции
//  ЭлементРодитель - ГруппаФормы - Элемент родитель
//  Заголовок - Строка - Заголовок
//  ДобавитьКартинку - Булево - Добавить картинку
Процедура ДобавитьЭлементФормыКнопка(Форма, ИмяОперации, ЭлементРодитель, Заголовок = "", ДобавитьКартинку = Ложь) Экспорт
	
	Кнопка = Форма.Элементы.Добавить(
		СтрШаблон("Кнопка%1", ИмяОперации),
		Тип("КнопкаФормы"),
		ЭлементРодитель);
	ИмяКоманды = СтрШаблон("Создать%1", ИмяОперации);
	Кнопка.ИмяКоманды = ИмяКоманды;
	Если ПустаяСтрока(Заголовок) Тогда
		Кнопка.Заголовок = Форма.Команды[ИмяКоманды].Заголовок;
	Иначе
		Кнопка.Заголовок = Заголовок;
	КонецЕсли;
	
	Если ДобавитьКартинку Тогда
		Кнопка.Отображение = ОтображениеКнопки.КартинкаИТекст;
		Кнопка.Картинка = БиблиотекаКартинок.СоздатьЭлементСписка;
	КонецЕсли;
	
КонецПроцедуры

// Добавить элемент формы подменю.
// 
// Параметры:
//  Форма - ФормаКлиентскогоПриложения - форма, из которой выполняется команда.
//  ИмяЭлемента - Строка - Имя элемента
//  ЭлементРодитель - ГруппаФормы - родитель
//  Заголовок - Строка - Заголовок
//  ДобавитьКартинку - Булево - Добавить картинку
// 
// Возвращаемое значение:
//  КнопкаФормы
Функция ДобавитьЭлементФормыПодменю(Форма, ИмяЭлемента, ЭлементРодитель, Заголовок, ДобавитьКартинку = Ложь) Экспорт
	
	Подменю = Форма.Элементы.Добавить(ИмяЭлемента,
		Тип("ГруппаФормы"),
		ЭлементРодитель);
	Подменю.Заголовок = Заголовок;
	Подменю.Вид       = ВидГруппыФормы.Подменю;
	
	Если ДобавитьКартинку Тогда
		Подменю.Картинка = БиблиотекаКартинок.СоздатьЭлементСписка;
	КонецЕсли;
	
	Возврат Подменю;
	
КонецФункции

#КонецОбласти

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Процедура ДобавитьОбщиеНастройкиВстраивания(Форма, ПараметрыИнтеграции)
	
	ОбщиеНастройки = СобытияФормИС.ОбщиеПараметрыИнтеграции("СобытияФормИСМП");
	ОбщиеНастройки.Вставить("ВидыПродукции", Новый Массив);
	
	ВидыПродукцииИСМП = КонструкторИСОбщегоНазначенияКлиентСервер.ВидыПродукцииИСМП(Истина);
	
	Если Форма.ИмяФормы = "Документ.ОтчетОбИмпортеЕГАИС.Форма.ФормаДокумента"
		Или Форма.ИмяФормы = "Документ.ОтчетОПроизводствеЕГАИС.Форма.ФормаДокумента" Тогда
		ВидыПродукцииИСМП = КонструкторИСОбщегоНазначенияКлиентСервер.ВидыПродукцииИСМПЕГАИС();
	КонецЕсли;
	
	Для Каждого ВидПродукции Из ВидыПродукцииИСМП Цикл
		ОбщиеНастройки.ВидыПродукции.Добавить(ВидПродукции);
	КонецЦикла;

	ПараметрыИнтеграции.Вставить("ИСМП", ОбщиеНастройки);
	ПараметрыИнтеграции.Вставить("ЦветГиперссылки", ЦветаСтиля.ЦветГиперссылкиГосИС);
	
КонецПроцедуры

// Встраивает реквизит - форматированную строку перехода к ИСМП в прикладные формы
// 
// Параметры:
//   Форма                - ФормаКлиентскогоПриложения - форма в которую происходит встраивание
//   ПараметрыИнтеграции  - Структура        - (См. ПараметрыИнтеграцииИСМП)
//   ДобавляемыеРеквизиты - Массив Из РеквизитФормы - массив реквизитов формы к добавлению
Процедура ДобавитьРеквизитТекстСостояниеИСМП(Форма, ПараметрыИнтеграции, ДобавляемыеРеквизиты)
	
	ПараметрыИнтеграцииИСМП = ПараметрыИнтеграцииГиперссылкиИСМП(Форма);
	
	Если ЗначениеЗаполнено(ПараметрыИнтеграцииИСМП.ИмяРеквизитаФормы) Тогда
		ПараметрыИнтеграции.Вставить("ИСМП.ДокументОснование", ПараметрыИнтеграцииИСМП);
		Реквизит = Новый РеквизитФормы(
			ПараметрыИнтеграцииИСМП.ИмяРеквизитаФормы,
			Новый ОписаниеТипов("ФорматированнаяСтрока"),,
			ПараметрыИнтеграцииИСМП.Заголовок);
		ДобавляемыеРеквизиты.Добавить(Реквизит);
	КонецЕсли;
	
КонецПроцедуры

Процедура ДобавитьЭлементыСверкиКодовИСМП(Форма, ПараметрыИнтеграции, ДобавляемыеРеквизиты)
	
	СтандартнаяОбработка = Ложь;
	СобытияФормИСМППереопределяемый.ПриОпределенииДоступностиИнтеграцииФормыСверкиКодовМаркировки(Форма, СтандартнаяОбработка);
	
	Если СтандартнаяОбработка Тогда
		Если ПравоДоступа("Использование", Метаданные.Обработки.РезультатыСверкиКодовМаркировкиТОРГ2) Тогда
			СверкаКодовМаркировкиИСМП.МодификацияРеквизитовФормы(Форма, ПараметрыИнтеграции, ДобавляемыеРеквизиты);
		КонецЕсли;

	КонецЕсли;
	
КонецПроцедуры

Процедура ДобавитьНастройкиРазделенияДатИСМП(Форма, ПараметрыИнтеграции, ДобавляемыеРеквизиты)
	
	ПроверкаИПодборПродукцииИСМП.ДобавитьНастройкиРазделенияДатИСМП(Форма, ПараметрыИнтеграции, ДобавляемыеРеквизиты);
	
КонецПроцедуры

Процедура ДобавитьЭлементыСоответствияТребованиямГИСМТ(Форма, ПараметрыИнтеграции, ДобавляемыеРеквизиты)
	
	ВстроитьГиперссылку = Ложь;
	СоответствиеТребованиямГИСМТПереопределяемый.ПередОпределениемПараметровИнтеграции(Форма, ВстроитьГиперссылку);
	
	Если ВстроитьГиперссылку Тогда
		СоответствиеТребованиямГИСМТ.МодификацияРеквизитовФормы(Форма, ПараметрыИнтеграции, ДобавляемыеРеквизиты);
	КонецЕсли;
	
КонецПроцедуры

Процедура ДобавитьРеквизитПредставлениеНоменклатурыИСМП(Форма, ПараметрыИнтеграции, ДобавляемыеРеквизиты)
	
	СтандартнаяОбработка = Ложь;
	СобытияФормИСМППереопределяемый.ПриОпределенииДоступностиИнтеграцииПредставлениеНоменклатуры(Форма, СтандартнаяОбработка);
	
	Если СтандартнаяОбработка Тогда
		
		ПараметрыИнтеграцииИСМП = ПараметрыИнтеграцииПредставлениеНоменклатурыИСМП(Форма);
		ПутьКРеквизиту = ПараметрыИнтеграцииИСМП.ИмяТабличнойЧастиТовары;
		Колонка = Новый РеквизитФормы(
			"ПредставлениеНоменклатурыИСМП",
			Новый ОписаниеТипов("Строка"),
			ПутьКРеквизиту,
			НСтр("ru = 'Представление номенклатуры ИС МП'"));
		ДобавляемыеРеквизиты.Добавить(Колонка);
		
		ТипыВидовПродукции = Новый Массив;
		ТипыВидовПродукции.Добавить(Тип("СправочникСсылка.КлючиВидовПродукцииИС"));
		ТипыВидовПродукции.Добавить(Тип("СправочникСсылка.ВидыПродукцииИС"));
		Колонка = Новый РеквизитФормы(
			"ВидПродукцииИС",
			Новый ОписаниеТипов(ТипыВидовПродукции),
			ПутьКРеквизиту, НСтр("ru = 'Вид продукции'"));
		ДобавляемыеРеквизиты.Добавить(Колонка);
		
		ПараметрыИнтеграции.Вставить("ИСМП.ПараметрыИнтеграцииПредставлениеНоменклатуры", ПараметрыИнтеграцииИСМП);
	КонецЕсли;
	
КонецПроцедуры

// Возвращает структуру, заполненную значениями по умолчанию, используемую для интеграции реквизитов ИС МП
//   в прикладные формы конфигураци - потребителя библиотеки ГосИС. Если передана форма - сразу заполняет ее
//   специфику в переопределяемом модуле.
//
// Параметры:
//   Форма - ФормаКлиентскогоПриложения, Неопределено - форма для которой возвращаются параметры интеграции
//
// ВозвращаемоеЗначение:
//   Структура - (См. СобытияФормИС.ПараметрыИнтеграцииДляДокументаОснования).
//
Функция ПараметрыИнтеграцииГиперссылкиИСМП(Форма = Неопределено)
	
	ПараметрыНадписи = СобытияФормИС.ПараметрыИнтеграцииДляДокументаОснования();
	ПараметрыНадписи.Вставить("Ключ",             "ЗаполнениеТекстаДокументаИСМП");
	
	Если Не (Форма = Неопределено) Тогда
		СобытияФормИСМППереопределяемый.ПриОпределенииПараметровИнтеграцииГиперссылкиИСМП(Форма, ПараметрыНадписи);
	КонецЕсли;
	
	Возврат ПараметрыНадписи;
	
КонецФункции

// Возвращает структуру, заполненную значениями по умолчанию, используемую для интеграции реквизитов
//   для формирования представления товара по данным ИС МП в прикладные формы конфигураци -потребителя
//   библиотеки ГосИС. Если передана форма - сразу заполняет ее специфику в переопределяемом модуле.
//
// Параметры:
//   Форма - ФормаКлиентскогоПриложения, Неопределено - форма для которой возвращаются параметры интеграции
//
// Возвращаемое значение:
//   Структура:
//   * ИмяТабличнойЧастиТовары - Строка - имя реквизта на форме 
//   * ИмяКолонкиНоменклатура - Строка - имя колонки Номенклатура для условного оформления
//   * ИмяКолонкиШтрихкод - Строка - имя колонки Штрихкод, поиск по значению для дополнения данными библиотеки
//   * НеизвестныеШтрихкоды - Строка - имя параметра формы, содержащего входищие данные сервиса для формирования представления
//
Функция ПараметрыИнтеграцииПредставлениеНоменклатурыИСМП(Форма = Неопределено)
	
	ПараметрыИнтеграции = Новый Структура;
	
	ПараметрыИнтеграции.Вставить("ИмяТабличнойЧастиТовары",         "ШтрихкодыНоменклатуры");
	ПараметрыИнтеграции.Вставить("ИмяКолонкиНоменклатура",          "Номенклатура");
	ПараметрыИнтеграции.Вставить("ИмяКолонкиШтрихкод",              "Штрихкод");
	ПараметрыИнтеграции.Вставить("ИмяПараметраФормыИсточникДанных", "НеизвестныеШтрихкоды");
	
	Если Форма <> Неопределено Тогда
		СобытияФормИСМППереопределяемый.ПриОпределенииПараметровИнтеграцииПредставлениеНоменклатуры(Форма, ПараметрыИнтеграции);
	КонецЕсли;
	
	Возврат ПараметрыИнтеграции;
	
КонецФункции

Процедура НастроитьВидПродукцииПриСозданииНаСервере(Форма, ДоступныеВидыПродукции) Экспорт
	
	Если Не ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(Форма.Элементы, "ВидПродукции") Тогда
		Возврат;
	КонецЕсли;
	
	Для Каждого ВидПродукции Из ДоступныеВидыПродукции Цикл
		
		Если ОбщегоНазначенияИСПовтИсп.ЭтоПродукцияИСМП(ВидПродукции, Истина)
			И ИнтеграцияИСМПКлиентСерверПовтИсп.ВестиУчетМаркируемойПродукции(ВидПродукции) Тогда
			Форма.Элементы.ВидПродукции.СписокВыбора.Добавить(ВидПродукции, Строка(ВидПродукции));
		КонецЕсли;
		
	КонецЦикла;
	
	Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(Форма.Объект, "ВидПродукции")
		И ЗначениеЗаполнено(Форма.Объект.ВидПродукции)
		И Форма.Элементы.ВидПродукции.СписокВыбора.НайтиПоЗначению(Форма.Объект.ВидПродукции) = Неопределено Тогда
		Форма.Элементы.ВидПродукции.СписокВыбора.Добавить(Форма.Объект.ВидПродукции, Строка(Форма.Объект.ВидПродукции));
	КонецЕсли;
	
	Если Форма.Элементы.ВидПродукции.СписокВыбора.Количество() = 1 Тогда
		Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(Форма.Объект, "ВидПродукции") Тогда
			Форма.Объект.ВидПродукции = Форма.Элементы.ВидПродукции.СписокВыбора[0].Значение;
		Иначе
			Форма.ВидПродукции = Форма.Элементы.ВидПродукции.СписокВыбора[0].Значение;
		КонецЕсли;
		Форма.Элементы.ВидПродукции.Видимость = Ложь;
	КонецЕсли;
	
	Форма.Элементы.ВидПродукции.СписокВыбора.СортироватьПоПредставлению();
	
КонецПроцедуры

Процедура НастроитьТоварнуюГруппуПриСозданииНаСервере(Форма) Экспорт
	
	Если Не ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(Форма.Элементы, "ТоварнаяГруппа") Тогда
		Возврат;
	КонецЕсли;
	
	ПараметрыВыбора = Новый Массив;
	
	ДоступныеТоварныеГруппы = ДоступныеТоварныеГруппы(Форма, ПараметрыВыбора);
	ИспользоватьСписок = ДоступныеТоварныеГруппы.Количество() < 11;
	
	Форма.Элементы.ТоварнаяГруппа.РедактированиеТекста = Истина;
	Форма.Элементы.ТоварнаяГруппа.КнопкаСоздания = Ложь;
	Форма.Элементы.ТоварнаяГруппа.ПараметрыВыбора = Новый ФиксированныйМассив(ПараметрыВыбора);
	Форма.Элементы.ТоварнаяГруппа.СписокВыбора.Очистить();
	
	Если ИспользоватьСписок Тогда
		
		Форма.Элементы.ТоварнаяГруппа.КнопкаВыбора = Ложь;
		Форма.Элементы.ТоварнаяГруппа.РежимВыбораИзСписка = Истина;
		
		ЭтоСписокЗначений = ТипЗнч(ДоступныеТоварныеГруппы) = Тип("СписокЗначений");
		Для Каждого ТоварнаяГруппа Из ДоступныеТоварныеГруппы Цикл
			Если ЭтоСписокЗначений Тогда
				Форма.Элементы.ТоварнаяГруппа.СписокВыбора.Добавить(ТоварнаяГруппа.Значение, ТоварнаяГруппа.Представление);
			Иначе
				Форма.Элементы.ТоварнаяГруппа.СписокВыбора.Добавить(ТоварнаяГруппа, Строка(ТоварнаяГруппа));
			КонецЕсли;
		КонецЦикла;
		
		ВОбъектеЕстьТоварнаяГруппа = ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(Форма.Объект, "ТоварнаяГруппа");
		Если ВОбъектеЕстьТоварнаяГруппа
			И ЗначениеЗаполнено(Форма.Объект.ТоварнаяГруппа)
			И Форма.Элементы.ТоварнаяГруппа.СписокВыбора.НайтиПоЗначению(Форма.Объект.ТоварнаяГруппа) = Неопределено Тогда
			Форма.Элементы.ТоварнаяГруппа.СписокВыбора.Добавить(Форма.Объект.ТоварнаяГруппа, Строка(Форма.Объект.ТоварнаяГруппа));
		КонецЕсли;
		
		Если Форма.Элементы.ТоварнаяГруппа.СписокВыбора.Количество() = 1 Тогда
			Если ВОбъектеЕстьТоварнаяГруппа Тогда
				Форма.Объект.ТоварнаяГруппа = Форма.Элементы.ТоварнаяГруппа.СписокВыбора[0].Значение;
			Иначе
				Форма.ТоварнаяГруппа = Форма.Элементы.ТоварнаяГруппа.СписокВыбора[0].Значение;
			КонецЕсли;
			Форма.Элементы.ТоварнаяГруппа.Видимость = Ложь;
		КонецЕсли;
		
		Форма.Элементы.ТоварнаяГруппа.СписокВыбора.СортироватьПоПредставлению();
	Иначе
		Форма.Элементы.ТоварнаяГруппа.КнопкаВыбора = Истина;
		Форма.Элементы.ТоварнаяГруппа.РежимВыбораИзСписка = Ложь;
	КонецЕсли;
	
КонецПроцедуры

Функция ДоступныеТоварныеГруппы(Форма, ПараметрыВыбора)
	
	Результат = Новый СписокЗначений;
	
	ЭлементКонструктора = КонструкторИСМПОбщегоНазначенияКлиентСервер.ЭлементКонструктораДляОпределенияДоступныхВидовПродукции(Форма.Объект);
	
	ПараметрыВыбора.Добавить(Новый ПараметрВыбора("ЭлементКонструктора", ЭлементКонструктора));
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ЭлементКонструктораДляОпределенияДоступныхВидовПродукции", ЭлементКонструктора);
	Запрос.Текст = Справочники.ТоварныеГруппыГИСМТ.ТекстЗапросаТоварныхГруппСОтборомПоЭлементуКонструктора(11);
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		Результат.Добавить(Выборка.Ссылка, Выборка.Наименование);
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

// Настройки создания элемента.
// 
// Возвращаемое значение:
//  Структура - Настройки создания элемента:
// * ИмяЭлемента - Строка - 
// * Подменю - Строка - 
// * Заголовок - Строка - 
Функция НастройкиСозданияЭлемента()
	
	Результат = Новый Структура;
	Результат.Вставить("ИмяЭлемента", "");
	Результат.Вставить("Подменю", "");
	Результат.Вставить("Заголовок", "");
	
	Возврат Результат;
	
КонецФункции

Процедура УстановитьСвязиПараметровВыбораВидПродукции(Форма, ИмяПоляВвода,
	ПутьКДаннымВидПродукции= "Элементы.Товары.ТекущиеДанные.ВидПродукцииГИСМТ") Экспорт
	
	СвязиПараметровВыбора = ОбщегоНазначения.СкопироватьРекурсивно(
		Форма.Элементы[ИмяПоляВвода].СвязиПараметровВыбора, Ложь);
	СвязиПараметровВыбора.Добавить(
		Новый СвязьПараметраВыбора("Отбор.ВидПродукции",
		ПутьКДаннымВидПродукции,
		РежимИзмененияСвязанногоЗначения.Очищать));
	
	Форма.Элементы[ИмяПоляВвода].СвязиПараметровВыбора = Новый ФиксированныйМассив(СвязиПараметровВыбора);
	
КонецПроцедуры

#КонецОбласти