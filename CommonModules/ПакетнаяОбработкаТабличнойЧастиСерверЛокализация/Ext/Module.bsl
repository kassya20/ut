		ОбработчикиСтрок.Добавить("ЗаполнитьВидПродукцииИС",
		"ПакетнаяОбработкаТабличнойЧастиСервер.ЗаполнитьСлужебныеРеквизитыПоНоменклатуреВСтрокеТЧ");
	
