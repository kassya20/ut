	ТекстыЗапросовВременныхТаблиц.Вставить("ВТЗарегистрироватьИзлишкиНедостачиНаСкладе", ТекстаЗапросаВТЗарегистрироватьИзлишкиНедостачиНаСкладе);

	ШаблонТекстаЗапросаТоварыКОформлениюИзлишковНедостач = 
		"ВЫБРАТЬ
