		|			И ТоварыКОтгрузке.ДокументОтгрузки = ВТТоварыКОформлениюРасходныхОрдеров.ДокументОтгрузки
		|			И ТоварыКОтгрузке.Номенклатура = ВТТоварыКОформлениюРасходныхОрдеров.Номенклатура
		|			И ТоварыКОтгрузке.Характеристика = ВТТоварыКОформлениюРасходныхОрдеров.Характеристика
		|			И ТоварыКОтгрузке.Назначение = ВТТоварыКОформлениюРасходныхОрдеров.Назначение
		|			И ТоварыКОтгрузке.Серия = ВТТоварыКОформлениюРасходныхОрдеров.Серия";
		
		ДопустимоеОтклонениеЗначение = "ВТТоварыКОформлениюРасходныхОрдеров.ДопустимоеОтклонение";
	Иначе
		УсловиеДопустимоеОтклонение = "ИСТИНА";
		СоединениеСВТДопустимыхОтклонений = "";
		СоединениеТоварыКДоставкеСВТДопустимыхОтклонений = "";
		ДопустимоеОтклонениеЗначение = 0;
	КонецЕсли;
	
	ТекстЗапроса = СтрСоединить(ТекстыЗапросов, ОбщегоНазначения.РазделительПакетаЗапросов());
	
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&УсловиеДопустимоеОтклонение", УсловиеДопустимоеОтклонение);
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса,
								",&СоединениеСВТДопустимыхОтклонений КАК Т",
								СоединениеСВТДопустимыхОтклонений);
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса,
								",&СоединениеТоварыКДоставкеСВТДопустимыхОтклонений КАК Т",
								СоединениеТоварыКДоставкеСВТДопустимыхОтклонений);
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&ДопустимоеОтклонениеЗначение", ДопустимоеОтклонениеЗначение);
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВТ;
	Запрос.Текст = ТекстЗапроса;
	
	Запрос.УстановитьПараметр("Склад", Параметры.Склад);
	Запрос.УстановитьПараметр("Получатель", Параметры.Получатель);
	Запрос.УстановитьПараметр("ПустойПолучатель", ПустойПолучательОтправитель());
	Запрос.УстановитьПараметр("ОформлятьСначалаНакладные", ОформлятьСначалаНакладные);
	Запрос.УстановитьПараметр("ПоВсемРаспоряжениям", Параметры.РаспоряженияНаОтгрузку.Количество() = 0);
	Запрос.УстановитьПараметр("РаспоряженияНаОтгрузку", Параметры.РаспоряженияНаОтгрузку);
	Запрос.УстановитьПараметр("ЗаданиеНаПеревозкуЗаполнено", ЗначениеЗаполнено(Параметры.ЗаданиеНаПеревозку));
	Запрос.УстановитьПараметр("ЗаданиеНаПеревозку", Параметры.ЗаданиеНаПеревозку);
	Запрос.УстановитьПараметр("ИспользуетсяДоставка25", ДоставкаТоваровКлиентСервер.ИспользуетсяДоставка25());
	Запрос.УстановитьПараметр("МерныеТипыЕдиницИзмерений",
		Справочники.УпаковкиЕдиницыИзмерения.МерныеТипыЕдиницИзмерений());
	Запрос.УстановитьПараметр("НачинатьОтгрузкуПослеФормированияЗаданияНаПеревозку",
		НачинатьОтгрузкуПослеФормированияЗаданияНаПеревозку);
	Запрос.УстановитьПараметр("ИспользоватьЗаданияНаПеревозкуДляУчетаДоставкиПеревозчиками",
		ПолучитьФункциональнуюОпцию("ИспользоватьЗаданияНаПеревозкуДляУчетаДоставкиПеревозчиками"));
	Запрос.УстановитьПараметр("ДопустимоеОтклонениеОтгрузкиПриемкиМерныхТоваров",
		ДопустимоеОтклонениеОтгрузкиПриемкиМерныхТоваров);
	
	МассивРезультатов	= Запрос.ВыполнитьПакет();
	ГраницаПакетов		= МассивРезультатов.ВГраница();
	
	Если НачинатьОтгрузкуПослеФормированияЗаданияНаПеревозку
		И ДоставкаТоваровКлиентСервер.ИспользуетсяДоставка20() Тогда
		
		ДеревоТоварыКОтгрузке = МассивРезультатов[ГраницаПакетов - 1].Выгрузить(ОбходРезультатаЗапроса.ПоГруппировкам);
		
		РаспределитьТоварыКОтгрузкеПоЗаданиямНаПеревозку(ДеревоТоварыКОтгрузке);
		
		Запрос.Текст = ТекстЗапросаДополненияОтгрузкиПослеФормированияЗаданияНаПеревозку20();
		Запрос.УстановитьПараметр("ТоварыКОтгрузке",
			ТоварыКОтгрузкеДляПереоформленияРасходныхОрдеров(ОбщегоНазначенияУТ.ДанныеДерева(ДеревоТоварыКОтгрузке)));
		
		МассивРезультатов	= Запрос.ВыполнитьПакет();
		ГраницаПакетов		= МассивРезультатов.ВГраница();
		
	КонецЕсли;
	
	ДеревоТоварыКОтгрузке	= МассивРезультатов[ГраницаПакетов - 2].Выгрузить(ОбходРезультатаЗапроса.ПоГруппировкам);
	ТоварыИзрасходованные	= ТаблицаДляВычисленияТоваровОформленияРасходныхОрдеров(
								МассивРезультатов[ГраницаПакетов - 1].Выгрузить(),
								НачинатьОтгрузкуПослеФормированияЗаданияНаПеревозку);
	ТоварыКСборке			= ТаблицаДляВычисленияТоваровОформленияРасходныхОрдеров(
								МассивРезультатов[ГраницаПакетов].Выгрузить());
	
	Если Не (ТоварыКСборке.Количество() = 0
		И ТоварыИзрасходованные.Количество() = 0) Тогда
		
		Отбор			= "Склад, Получатель, ДокументОтгрузки, Номенклатура, Характеристика, Назначение,
							|КонтролируемаяПартия, Серия";
		ОтборПоПериоду	= Отбор + ", ПериодОтгрузки";
		
		ТоварыИзрасходованные.Индексы.Добавить(Отбор);
		ТоварыИзрасходованные.Индексы.Добавить(ОтборПоПериоду);
		
		ТоварыКСборке.Индексы.Добавить(Отбор);
		ТоварыКСборке.Индексы.Добавить(ОтборПоПериоду);
		
		Если НачинатьОтгрузкуПослеФормированияЗаданияНаПеревозку Тогда
			Отбор			= Отбор + ", ЗаданиеНаПеревозку";
			ОтборПоПериоду	= ОтборПоПериоду + ", ЗаданиеНаПеревозку";
			
			ТоварыИзрасходованные.Индексы.Добавить(Отбор);
			ТоварыИзрасходованные.Индексы.Добавить(ОтборПоПериоду);
			
			ТоварыКСборке.Индексы.Добавить(Отбор);
			ТоварыКСборке.Индексы.Добавить(ОтборПоПериоду);
		КонецЕсли;
		
		ВычитаемыеТаблицы = Новый Массив;
		ВычитаемыеТаблицы.Добавить(ТоварыИзрасходованные);
		ВычитаемыеТаблицы.Добавить(ТоварыКСборке);
		
		ВычестьТаблицуИзДерева(ДеревоТоварыКОтгрузке, ВычитаемыеТаблицы, НачинатьОтгрузкуПослеФормированияЗаданияНаПеревозку);
		
	КонецЕсли;
	
	ДанныеДляОформленияРасходныхОрдеров = Новый Структура;
	ДанныеДляОформленияРасходныхОрдеров.Вставить("ДеревоТоварыКОтгрузке", ДеревоТоварыКОтгрузке);
	ДанныеДляОформленияРасходныхОрдеров.Вставить("ТоварыКСборке", ТоварыКСборке);
	
	Возврат ДанныеДляОформленияРасходныхОрдеров;
	
КонецФункции

Процедура ВычислитьТоварыДляОформленияРасходныхОрдеровДоставка25(ДополнительныеПараметры, МенеджерВТ, ТекстыЗапросов)
	
	ДополнительныеПараметры = ОбновлениеИнформационнойБазы.ДополнительныеПараметрыВыборкиДанныхДляОбработки();
	
	ДополнительныеПараметры.ИмяВременнойТаблицы = "ВТЗаблокированоДоставка";
	ОбновлениеИнформационнойБазы.СоздатьВременнуюТаблицуЗначенийЗаблокированныхИзмерений(
		Неопределено,
		"РегистрНакопления.Доставка",
		"Распоряжение",
		МенеджерВТ,
		ДополнительныеПараметры);
	
	ТекстЗапроса =
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ЗаблокированныеДокументы.ДокументОтгрузки КАК ДокументОтгрузки
	|ПОМЕСТИТЬ ЗаблокированныеДокументыОтгрузки
	|ИЗ
	|	(ВЫБРАТЬ
	|		ВТЗаблокированоДоставка.Распоряжение КАК ДокументОтгрузки
	|	ИЗ
	|		ВТЗаблокированоДоставка КАК ВТЗаблокированоДоставка
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ
	|		ВТЗаблокированоТоварыКОтгрузке.ДокументОтгрузки
	|	ИЗ
	|		ВТЗаблокированоТоварыКОтгрузке КАК ВТЗаблокированоТоварыКОтгрузке) КАК ЗаблокированныеДокументы
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ДоставкаОбороты.Распоряжение КАК Распоряжение,
	|	ЕСТЬNULL(ПервичныеДанныеБезЗаказаНаДоставку.ПервичнаяДатаОтгрузки, ПервичныеДанныеПоЗаказуНаДоставку.ПервичнаяДатаОтгрузки) КАК ДатаОтгрузкиПервичная,
	|	ДоставкаОбороты.ДатаОтгрузки КАК ДатаОтгрузкиКонечная,
	|	ВЫБОР
	|		КОГДА РеестрДокументов.Партнер ЕСТЬ NULL
	|			ТОГДА ДоставкаОбороты.Распоряжение
	|		КОГДА РеестрДокументов.Партнер В (&ПустойПолучатель)
	|			ТОГДА ДоставкаОбороты.Распоряжение
	|		ИНАЧЕ РеестрДокументов.Партнер
	|	КОНЕЦ КАК Получатель,
	|	ДоставкаОбороты.Номенклатура КАК Номенклатура,
	|	ДоставкаОбороты.Характеристика КАК Характеристика,
	|	ДоставкаОбороты.Серия КАК Серия,
	|	ЕСТЬNULL(ПервичныеДанныеБезЗаказаНаДоставку.Назначение, ПервичныеДанныеПоЗаказуНаДоставку.Назначение) КАК Назначение,
	|	СУММА(ДоставкаОбороты.КДоставкеОборот) КАК КДоставке
	|ПОМЕСТИТЬ ВтКДоставке
	|ИЗ
	|	РегистрНакопления.Доставка.Обороты(
	|			,
	|			,
	|			,
	|			Отправитель = &Склад
	|				И (Распоряжение В (&РаспоряженияНаОтгрузку)
	|					ИЛИ &ПоВсемРаспоряжениям)
	|				И НЕ Распоряжение В
	|						(ВЫБРАТЬ
	|							ЗаблокированныеДокументыОтгрузки.ДокументОтгрузки
	|						ИЗ
	|							ЗаблокированныеДокументыОтгрузки КАК ЗаблокированныеДокументыОтгрузки)
	|				И СпособДоставки <> ЗНАЧЕНИЕ(Перечисление.СпособыДоставки25.Самовывоз)
	|				И Плечо = 1) КАК ДоставкаОбороты
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.Доставка КАК ПервичныеДанныеБезЗаказаНаДоставку
	|		ПО ДоставкаОбороты.Распоряжение = ПервичныеДанныеБезЗаказаНаДоставку.Распоряжение
	|			И (НЕ ДоставкаОбороты.ДокументПланирования ССЫЛКА Документ.ЗаказНаДоставку)
	|			И ДоставкаОбороты.ДокументПланирования = ПервичныеДанныеБезЗаказаНаДоставку.ДокументПланирования
	|			И ДоставкаОбороты.КодСтроки = ПервичныеДанныеБезЗаказаНаДоставку.КодСтроки
	|			И (ПервичныеДанныеБезЗаказаНаДоставку.ПервичнаяЗапись)
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.Доставка КАК ПервичныеДанныеПоЗаказуНаДоставку
	|		ПО (ДоставкаОбороты.Распоряжение = ПервичныеДанныеПоЗаказуНаДоставку.Распоряжение)
	|			И (ДоставкаОбороты.ДокументПланирования ССЫЛКА Документ.ЗаказНаДоставку)
	|			И (ПервичныеДанныеПоЗаказуНаДоставку.ДокументПланирования = НЕОПРЕДЕЛЕНО)
	|			И (ДоставкаОбороты.КодСтроки = ПервичныеДанныеПоЗаказуНаДоставку.КодСтроки)
	|			И (ПервичныеДанныеПоЗаказуНаДоставку.ПервичнаяЗапись)
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.РеестрДокументов КАК РеестрДокументов
	|		ПО ДоставкаОбороты.Распоряжение = РеестрДокументов.Ссылка
	|			И (НЕ РеестрДокументов.ДополнительнаяЗапись)
	|			И (РеестрДокументов.Партнер = &Получатель)
	|ГДЕ
	|	ДоставкаОбороты.КДоставкеОборот > 0
	|
	|СГРУППИРОВАТЬ ПО
	|	ДоставкаОбороты.Серия,
	|	ЕСТЬNULL(ПервичныеДанныеБезЗаказаНаДоставку.ПервичнаяДатаОтгрузки, ПервичныеДанныеПоЗаказуНаДоставку.ПервичнаяДатаОтгрузки),
	|	ДоставкаОбороты.Номенклатура,
	|	ДоставкаОбороты.Характеристика,
	|	ДоставкаОбороты.ДатаОтгрузки,
	|	ВЫБОР
	|		КОГДА РеестрДокументов.Партнер ЕСТЬ NULL
	|			ТОГДА ДоставкаОбороты.Распоряжение
	|		КОГДА РеестрДокументов.Партнер В (&ПустойПолучатель)
	|			ТОГДА ДоставкаОбороты.Распоряжение
	|		ИНАЧЕ РеестрДокументов.Партнер
	|	КОНЕЦ,
	|	ДоставкаОбороты.Распоряжение,
	|	ЕСТЬNULL(ПервичныеДанныеБезЗаказаНаДоставку.Назначение, ПервичныеДанныеПоЗаказуНаДоставку.Назначение)
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Распоряжение
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ДоставкаОбороты.Рейс КАК Рейс,
	|	ДоставкаОбороты.Распоряжение КАК Распоряжение,
	|	ЕСТЬNULL(ПервичныеДанныеБезЗаказаНаДоставку.ПервичнаяДатаОтгрузки, ПервичныеДанныеПоЗаказуНаДоставку.ПервичнаяДатаОтгрузки) КАК ДатаОтгрузкиПервичная,
	|	ДоставкаОбороты.ДатаОтгрузки КАК ДатаОтгрузкиКонечная,
	|	ВЫБОР
	|		КОГДА РеестрДокументов.Партнер ЕСТЬ NULL
	|			ТОГДА ДоставкаОбороты.Распоряжение
	|		КОГДА РеестрДокументов.Партнер В (&ПустойПолучатель)
	|			ТОГДА ДоставкаОбороты.Распоряжение
	|		ИНАЧЕ РеестрДокументов.Партнер
	|	КОНЕЦ КАК Получатель,
	|	ДоставкаОбороты.Номенклатура КАК Номенклатура,
	|	ДоставкаОбороты.Характеристика КАК Характеристика,
	|	ДоставкаОбороты.Серия КАК Серия,
	|	ЕСТЬNULL(ПервичныеДанныеБезЗаказаНаДоставку.Назначение, ПервичныеДанныеПоЗаказуНаДоставку.Назначение) КАК Назначение,
	|	СУММА(ДоставкаОбороты.КСборкеОборот) КАК КСборке,
	|	ДоставкаОбороты.Отправитель КАК Отправитель
	|ПОМЕСТИТЬ ВтКСборкеПоРейсу
	|ИЗ
	|	РегистрНакопления.Доставка.Обороты(
	|			,
	|			,
	|			,
	|			Отправитель = &Склад
	|				И (Распоряжение В (&РаспоряженияНаОтгрузку)
	|					ИЛИ &ПоВсемРаспоряжениям)
	|				И НЕ Распоряжение В
	|						(ВЫБРАТЬ
	|							ЗаблокированныеДокументыОтгрузки.ДокументОтгрузки
	|						ИЗ
	|							ЗаблокированныеДокументыОтгрузки КАК ЗаблокированныеДокументыОтгрузки)
	|				И СпособДоставки <> ЗНАЧЕНИЕ(Перечисление.СпособыДоставки25.Самовывоз)
	|				И Плечо = 1) КАК ДоставкаОбороты
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.Доставка КАК ПервичныеДанныеБезЗаказаНаДоставку
	|		ПО ДоставкаОбороты.Распоряжение = ПервичныеДанныеБезЗаказаНаДоставку.Распоряжение
	|			И (НЕ ДоставкаОбороты.ДокументПланирования ССЫЛКА Документ.ЗаказНаДоставку)
	|			И ДоставкаОбороты.ДокументПланирования = ПервичныеДанныеБезЗаказаНаДоставку.ДокументПланирования
	|			И ДоставкаОбороты.КодСтроки = ПервичныеДанныеБезЗаказаНаДоставку.КодСтроки
	|			И (ПервичныеДанныеБезЗаказаНаДоставку.ПервичнаяЗапись)
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.Доставка КАК ПервичныеДанныеПоЗаказуНаДоставку
	|		ПО (ДоставкаОбороты.Распоряжение = ПервичныеДанныеПоЗаказуНаДоставку.Распоряжение)
	|			И (ДоставкаОбороты.ДокументПланирования ССЫЛКА Документ.ЗаказНаДоставку)
	|			И (ПервичныеДанныеПоЗаказуНаДоставку.ДокументПланирования = НЕОПРЕДЕЛЕНО)
	|			И (ДоставкаОбороты.КодСтроки = ПервичныеДанныеПоЗаказуНаДоставку.КодСтроки)
