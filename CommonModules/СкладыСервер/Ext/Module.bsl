		|														ЗНАЧЕНИЕ(Перечисление.ВариантыПриемкиТоваров.НеРазделенаПоНакладным))
		|		ТОГДА
		|			ДанныеДокумента.Соглашение
		// Если РазделенаПоЗаказамИНакладным И ЭтоНакладная И НеПоЗаказу - значит накладная:
		|		КОГДА ДанныеДокумента.ЭтоНакладная
		|			И НЕ ДанныеДокумента.ПоступлениеПоЗаказам
		|			И ДанныеДокумента.ВариантПриемкиУслуг = ЗНАЧЕНИЕ(Перечисление.ВариантыПриемкиТоваров.РазделенаПоЗаказамИНакладным)
		|		ТОГДА
		|			ДанныеДокумента.Накладная
		|
		// Если РазделенаТолькоПоНакладным И ЭтоНакладная - значит накладная:
		|		КОГДА ДанныеДокумента.ЭтоНакладная
		|			И ДанныеДокумента.ВариантПриемкиУслуг = ЗНАЧЕНИЕ(Перечисление.ВариантыПриемкиТоваров.РазделенаТолькоПоНакладным)
		|		ТОГДА
		|			ДанныеДокумента.Накладная
		|		ИНАЧЕ
		|			ДанныеДокумента.Заказ
		|	КОНЕЦ";		
		
		СуммаКОформлениюПоступленияПоРаспоряжению =
		"	ВЫБОР
		|		КОГДА ДанныеДокумента.ВариантПриемкиУслуг В (ЗНАЧЕНИЕ(Перечисление.ВариантыПриемкиТоваров.ПоДоговорамБезЗаказовИНакладных),
		|														ЗНАЧЕНИЕ(Перечисление.ВариантыПриемкиТоваров.ПоДоговорамПослеЗаказовИлиНакладных),
		|														ЗНАЧЕНИЕ(Перечисление.ВариантыПриемкиТоваров.ПоДоговорамПослеНакладных)) 
		|			И ДанныеДокумента.Договор.ВариантОформленияЗакупок = ЗНАЧЕНИЕ(Перечисление.ВариантыОформленияЗакупок.НеРазделять)
		|		ТОГДА
		|			ДанныеДокумента.Количество
		|		КОГДА ДанныеДокумента.ВариантПриемкиУслуг В (ЗНАЧЕНИЕ(Перечисление.ВариантыПриемкиТоваров.МожетПроисходитьБезЗаказовИНакладных),
		|														ЗНАЧЕНИЕ(Перечисление.ВариантыПриемкиТоваров.НеРазделенаПоЗаказамИНакладным),
		|														ЗНАЧЕНИЕ(Перечисление.ВариантыПриемкиТоваров.НеРазделенаПоНакладным))
		|		ТОГДА
		|			0
		// Если РазделенаПоЗаказамИНакладным И ЭтоНакладная И НеПоЗаказу - значит накладная:
		|		КОГДА ДанныеДокумента.ЭтоНакладная
		|			И НЕ ДанныеДокумента.ПоступлениеПоЗаказам
		|			И ДанныеДокумента.ВариантПриемкиУслуг = ЗНАЧЕНИЕ(Перечисление.ВариантыПриемкиТоваров.РазделенаПоЗаказамИНакладным)
		|		ТОГДА
		|			0
		|
		// Если РазделенаТолькоПоНакладным И ЭтоНакладная - значит накладная:
		|		КОГДА ДанныеДокумента.ЭтоНакладная
		|			И ДанныеДокумента.ВариантПриемкиУслуг = ЗНАЧЕНИЕ(Перечисление.ВариантыПриемкиТоваров.РазделенаТолькоПоНакладным)
		|		ТОГДА
		|			0
		|		ИНАЧЕ
		|			0
		|	КОНЕЦ";
		
		ХозяйственнаяОперацияДвухходовки = 
		"	ВЫБОР
		|		КОГДА ДанныеДокумента.ХозяйственнаяОперация = ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.ЗакупкаУПоставщикаПоступлениеИзТоваровВПути)
		|			ТОГДА ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.ЗакупкаУПоставщикаТоварыВПути)
		|		КОГДА ДанныеДокумента.ХозяйственнаяОперация = ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.ЗакупкаУПоставщикаНеотфактурованнаяПоставка)
		|			ТОГДА ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.ЗакупкаУПоставщикаФактуровкаПоставки)
		|		КОГДА ДанныеДокумента.ХозяйственнаяОперация = ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.ЗакупкаВСтранахЕАЭСПоступлениеИзТоваровВПути)
		|			ТОГДА ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.ЗакупкаВСтранахЕАЭСТоварыВПути)
		|		КОГДА ДанныеДокумента.ХозяйственнаяОперация = ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.ЗакупкаВСтранахЕАЭСНеотфактурованнаяПоставка)
		|			ТОГДА ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.ЗакупкаВСтранахЕАЭСФактуровкаПоставки)
		|		КОГДА ДанныеДокумента.ХозяйственнаяОперация = ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.ЗакупкаПоИмпортуПоступлениеИзТоваровВПути)
		|			ТОГДА ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.ЗакупкаПоИмпортуТоварыВПути)
		|		ИНАЧЕ
		|			ДанныеДокумента.ХозяйственнаяОперация
		|	КОНЕЦ";
		
		ДополнительныеСоединения = ДополнительныеСоединения
			+"
			|	ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ДоговорыКонтрагентов КАК ДанныеДоговора
			|	ПО ДанныеДокумента.Договор = ДанныеДоговора.Ссылка";
		
		ДополнительныеСоединения				= СтрЗаменить(ДополнительныеСоединения,			"ДанныеДокумента", ИсточникДанных);
		Назначение								= СтрЗаменить(Назначение,						"ДанныеДокумента", ИсточникДанных);
		СерияКОформлениюНакладныхПоРаспоряжению = СтрЗаменить(СерияКОформлениюНакладныхПоРаспоряжению, "ДанныеДокумента", ИсточникДанных);
		Серия									= СтрЗаменить(Серия,							"ДанныеДокумента", ИсточникДанных);
		Количество								= СтрЗаменить(Количество,						"ДанныеДокумента", ИсточникДанных);
		ДокументПоступленияОдноходовки			= СтрЗаменить(ДокументПоступленияОдноходовки,	"ДанныеДокумента", ИсточникДанных);
		ДокументПоступленияУслугОдноходовки		= СтрЗаменить(ДокументПоступленияУслугОдноходовки,	"ДанныеДокумента", ИсточникДанных);
		ДоговорЯвляетсяРаспоряжением			= СтрЗаменить(ДоговорЯвляетсяРаспоряжением,		"ДанныеДокумента", ИсточникДанных);
		ПоДоговорамПослеНакладных				= СтрЗаменить(ПоДоговорамПослеНакладных,		"ДанныеДокумента", ИсточникДанных);
		ПоДоговорамДляУслугПослеНакладных		= СтрЗаменить(ПоДоговорамДляУслугПослеНакладных, "ДанныеДокумента", ИсточникДанных);
		ИспользуетсяДокументПоступлениеТоваров	= СтрЗаменить(ИспользуетсяДокументПоступлениеТоваров, "ДанныеДокумента", ИсточникДанных);
		НакладнаяЯвляетсяРаспоряжением			= СтрЗаменить(НакладнаяЯвляетсяРаспоряжением,	"ДанныеДокумента", ИсточникДанных);
		НакладнаяПоУслугамЯвляетсяРаспоряжением	= СтрЗаменить(НакладнаяПоУслугамЯвляетсяРаспоряжением,	"ДанныеДокумента", ИсточникДанных);
		ИспользуетсяОрдернаяСхемаПриПоступлении	= СтрЗаменить(ИспользуетсяОрдернаяСхемаПриПоступлении,	"ДанныеДокумента", ИсточникДанных);
		ИспользуетсяОрдернаяСхемаПриОтраженииИзлишковНедостач 
			= СтрЗаменить(ИспользуетсяОрдернаяСхемаПриОтраженииИзлишковНедостач, "ДанныеДокумента", ИсточникДанных);
		ДокументПоступленияНакладнойДвухходовки	= СтрЗаменить(ДокументПоступленияНакладнойДвухходовки,	"ДанныеДокумента", ИсточникДанных);
		ДокументПоступленияНакладнойУслугиДвухходовки = СтрЗаменить(ДокументПоступленияНакладнойУслугиДвухходовки,	"ДанныеДокумента", ИсточникДанных);
		ХозяйственнаяОперацияДвухходовки		= СтрЗаменить(ХозяйственнаяОперацияДвухходовки,	"ДанныеДокумента", ИсточникДанных);
		
		ПараметрыЗапроса.Вставить("ДополнительныеСоединения",					ДополнительныеСоединения);
		ПараметрыЗапроса.Вставить("Назначение",									Назначение);
		ПараметрыЗапроса.Вставить("СерияКОформлениюНакладныхПоРаспоряжению",	СерияКОформлениюНакладныхПоРаспоряжению);
		ПараметрыЗапроса.Вставить("Серия",										Серия);
		ПараметрыЗапроса.Вставить("Количество",									Количество);
		ПараметрыЗапроса.Вставить("ДокументПоступленияОдноходовки",				ДокументПоступленияОдноходовки);
		ПараметрыЗапроса.Вставить("ДоговорЯвляетсяРаспоряжением",				ДоговорЯвляетсяРаспоряжением);
		ПараметрыЗапроса.Вставить("ПоДоговорамПослеНакладных",					ПоДоговорамПослеНакладных);
		ПараметрыЗапроса.Вставить("ИспользуетсяДокументПоступлениеТоваров",		ИспользуетсяДокументПоступлениеТоваров);
		ПараметрыЗапроса.Вставить("НакладнаяЯвляетсяРаспоряжением",				НакладнаяЯвляетсяРаспоряжением);
		ПараметрыЗапроса.Вставить("ИспользуетсяОрдернаяСхемаПриПоступлении",	ИспользуетсяОрдернаяСхемаПриПоступлении);
		ПараметрыЗапроса.Вставить("ИспользуетсяОрдернаяСхемаПриОтраженииИзлишковНедостач", ИспользуетсяОрдернаяСхемаПриОтраженииИзлишковНедостач);
		ПараметрыЗапроса.Вставить("ДокументПоступленияНакладнойДвухходовки",	ДокументПоступленияНакладнойДвухходовки);	
		ПараметрыЗапроса.Вставить("ХозяйственнаяОперацияДвухходовки", 			ХозяйственнаяОперацияДвухходовки);
		
		Если УчитываютсяВДвиженияхУслугиРаботы Тогда
			ПараметрыЗапроса.Вставить("ДокументПоступленияУслугОдноходовки",		ДокументПоступленияУслугОдноходовки);
			ПараметрыЗапроса.Вставить("ПоДоговорамДляУслугПослеНакладных",			ПоДоговорамДляУслугПослеНакладных);
			ПараметрыЗапроса.Вставить("НакладнаяПоУслугамЯвляетсяРаспоряжением",	НакладнаяПоУслугамЯвляетсяРаспоряжением);
			ПараметрыЗапроса.Вставить("ДокументПоступленияНакладнойУслугиДвухходовки", ДокументПоступленияНакладнойУслугиДвухходовки);
			ПараметрыЗапроса.Вставить("СуммаКОформлениюПоступленияПоРаспоряжению",	СуммаКОформлениюПоступленияПоРаспоряжению);
		Иначе
			ПараметрыЗапроса.Вставить("ДокументПоступленияУслугОдноходовки",		ДокументПоступленияОдноходовки);
			ПараметрыЗапроса.Вставить("ПоДоговорамДляУслугПослеНакладных",			ПоДоговорамПослеНакладных);
			ПараметрыЗапроса.Вставить("НакладнаяПоУслугамЯвляетсяРаспоряжением",	НакладнаяЯвляетсяРаспоряжением);
			ПараметрыЗапроса.Вставить("ДокументПоступленияНакладнойУслугиДвухходовки", ДокументПоступленияНакладнойДвухходовки);
			ПараметрыЗапроса.Вставить("СуммаКОформлениюПоступленияПоРаспоряжению",	"0");
		КонецЕсли;
		
		Если ИмяОперации = "ОформитьПриобретениеТоваровПоДвухходовке" Тогда
			
			ОтражатьНеотфактурованныеПоставкиУслугИРабот = 
			"ДанныеДокумента.ХозяйственнаяОперация В (ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.ЗакупкаВСтранахЕАЭСФактуровкаПоставки)
			|											,ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.ЗакупкаУПоставщикаФактуровкаПоставки))
			|И ДанныеДоговора.ВариантОформленияДокументовПоступленияПоУслугам = ЗНАЧЕНИЕ(Перечисление.ВариантыОформленияДокументовПоУслугам.ПоступлениеУслугФактурируется)";
			
			ОтражатьНеотфактурованныеПоставкиУслугИРабот = СтрЗаменить(ОтражатьНеотфактурованныеПоставкиУслугИРабот, "ДанныеДокумента", ИсточникДанных);
			ПараметрыЗапроса.Вставить("ОтражатьНеотфактурованныеПоставкиУслугИРабот", ОтражатьНеотфактурованныеПоставкиУслугИРабот);
			
		КонецЕсли;
		
	КонецЕсли;

	#КонецОбласти
	
	ЭтоТовар = 
	"ВЫБОР
	|		КОГДА ДанныеДокумента.Номенклатура.ТипНоменклатуры В(
	|				ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Товар),
	|				ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.МногооборотнаяТара))
	|			ТОГДА ИСТИНА
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ";
	ЭтоТовар = СтрЗаменить(ЭтоТовар, "ДанныеДокумента", ИсточникДанных);
	
	ПараметрыЗапроса.Вставить("ЭтоТовар", ЭтоТовар);
	
	Возврат ПараметрыЗапроса;
	
КонецФункции

Функция ПараметрыУсловияСоединенияСТЧСерии()
	
	ПараметрыСоединения = Новый Структура;
	ПараметрыСоединения.Вставить("СинонимТЧТовары", "ДанныеДокумента");
	ПараметрыСоединения.Вставить("СинонимТЧСерии", "ДанныеСерий");
	ПараметрыСоединения.Вставить("ПоляТЧТовары", Неопределено);
	ПараметрыСоединения.Вставить("ПереопределяемыеПоляСоединения", Новый Соответствие);
	
	Возврат ПараметрыСоединения;
	
КонецФункции

Функция УсловиеСоединенияСТЧСерии(ОбъектМетаданных, ИмяТЧСерии, ПараметрыСоединения = Неопределено)
	
	ТЧСерии = ПолучитьТЧОбъектаМетаданных(ОбъектМетаданных, ИмяТЧСерии);
	
	Если ПараметрыСоединения = Неопределено Тогда
		ПараметрыСоединения = ПараметрыУсловияСоединенияСТЧСерии();
	КонецЕсли;
	
	ИсключаемыеРеквизиты = Новый Массив;
	ИсключаемыеРеквизиты.Добавить("Серия");
	ИсключаемыеРеквизиты.Добавить("Количество");
	ИсключаемыеРеквизиты.Добавить("КоличествоПоДокументу");
	ИсключаемыеРеквизиты.Добавить("КоличествоКРаспределениюПоПравилу");
	
	СинонимТЧТовары	= ПараметрыСоединения.СинонимТЧТовары;
	СинонимТЧСерии	= ПараметрыСоединения.СинонимТЧСерии;
	ПоляТЧТовары	= ПараметрыСоединения.ПоляТЧТовары;
	ПереопределяемыеПоляСоединения	= ПараметрыСоединения.ПереопределяемыеПоляСоединения;
	
	УсловияСоединенияТаблиц = Новый Массив;
	
	Для Каждого РеквизитТЧ Из ТЧСерии.Реквизиты Цикл
		Если ИсключаемыеРеквизиты.Найти(РеквизитТЧ.Имя) <> Неопределено Тогда
			Продолжить;
		КонецЕсли;
		// В ТЧ Товары может не быть реквизита, который имеется в ТЧ Серии. Такие реквизиты пропускаются.
		Если ПоляТЧТовары <> Неопределено
			И ПоляТЧТовары.Найти(РеквизитТЧ.Имя) = Неопределено Тогда
			
			Продолжить;
			
		КонецЕсли;
		
		ПереопределяемоеПоле = ПереопределяемыеПоляСоединения.Получить(РеквизитТЧ.Имя);
		
		Если ПоляТЧТовары <> Неопределено
			И ПереопределяемоеПоле <> Неопределено
			И ПоляТЧТовары.Найти(ПереопределяемоеПоле) <> Неопределено Тогда
			
			// Условие формируется по заданным настройкам состава реквизитов ТЧ Товары и переопределению псевдонимов
			// реквизитов ТЧ Серии.
			УсловиеСоединения = СинонимТЧТовары + "." + ПереопределяемоеПоле + " = " + СинонимТЧСерии + "." + РеквизитТЧ.Имя;
			
		ИначеЕсли ПоляТЧТовары = Неопределено
			И ПереопределяемоеПоле <> Неопределено Тогда
			
			// Условие формируется по стандартному набору состава реквизитов ТЧ Товары объекта и переопределению
			// псевдонимов реквизитов ТЧ Серии.
			УсловиеСоединения = СинонимТЧТовары + "." + ПереопределяемоеПоле + " = " + СинонимТЧСерии + "." + РеквизитТЧ.Имя
			
		Иначе
			УсловиеСоединения = СинонимТЧТовары + "." + РеквизитТЧ.Имя + " = " + СинонимТЧСерии + "." + РеквизитТЧ.Имя;
		КонецЕсли;
		
		УсловияСоединенияТаблиц.Добавить(УсловиеСоединения);
	КонецЦикла;
	
	РазделительСоединения = "
		|			И ";
	УсловиеСоединенияТаблиц = СтрСоединить(УсловияСоединенияТаблиц, РазделительСоединения);
	
	Возврат УсловиеСоединенияТаблиц;
	
КонецФункции

// Выполняет подготовку итоговых запросов отражения документа по складским регистрам:
// - ТоварыНаСкладах
// - ТоварыКПоступлению.
//
// Параметры:
//  Запрос - Запрос - Запрос отражения документа.
//  ТекстыЗапроса - СписокЗначений Из Строка - Список текстов запроса отражения документа.
// 	Регистры - Неопределено, Структура, Строка - Список регистров для отражения.
//  ТекстЗапросаДокумента - Строка - Текст запроса выборки данных документа, содержащий следующие обязательные поля:
//     * Ссылка                - ДокументСсылка - Ссылка на текущий документ.
//     * Заказ                 - ДокументСсылка - Ссылка на заказ. Если такого реквизита нет, следует передать
//                               Неопределено. Накладная ссылку на себя передать не может.
//     * Накладная             - ДокументСсылка - Ссылка на накладную. Если текущий документ - заказ, следует
//                               передать Неопределено. Накладная передает ссылку на себя.
//     * Дата                  - Дата - Дата поступления товара.
//     * Договор               - СправочникСсылка.ДоговорыКонтрагентов - Договор с поставщиком, может использоваться
//                               как ДокументПоступления. Если такого реквизита нет, или если по документу невозможна
//                               приемка по договору, следует передать Неопределено.
//     * Соглашение            - СправочникСсылка.СоглашенияСПоставщиками - Соглашение с поставщиком, может использоваться
//                               как ДокументПоступления. Если такого реквизита нет, или если по документу невозможна
//                               приемка по соглашению, следует передать Неопределено.
//     * ВариантПриемкиТоваров - ПеречислениеСсылка.ВариантыПриемкиТоваров - одноименный реквизит документа, если 
//                               такого реквизита нет, следует передать Неопределено.
//     * Склад                 - СправочникСсылка.Склады - Склад на который будет поступать товар.
//     * Отправитель           - ОпределяемыйТип.ОтправительПолучательТоваров - откуда ожидается поступление товара.
//     * ХозяйственнаяОперация - ПеречислениеСсылка.ХозяйственныеОперации - одноименный реквизит документа.
//     * Номенклатура          - СправочникСсылка.Номенклатура - Номенклатура.
//     * Характеристика        - СправочникСсылка.ХарактеристикиНоменклатуры - Характеристика.
//     * Назначение            - СправочникСсылка.Назначения - Назначение.
//     * ПроконтролироватьКачество - Булево - Если поступающие товары подлежат контролю качества, то Истина, иначе - Ложь.
//     * ДвижениеРанееПоступившейПартии - Булево - Если поступает товар, который ранее поступил на другой склад и находится на контроле качества, то Истина, иначе - Ложь.
//     * КонтролируемаяПартия - СправочникСсылка.КонтролируемыеПартии - Ссылка на партию, поступившую ранее (если параметр ДвижениеРанееПоступившейПартии = Истина), иначе Неопределено или пустая ссылка. 
//     * СтатусУказанияСерий   - Число - Служебное поле табличной части, если такого реквизита нет, следует передать 0.
//     * СверхЗаказа           - Булево - Служебное поле для накладных, которое взводится в истину если накладная по
//                               заказу, и строка имеет признак что она не привязана к заказу, например, КодСтроки = 0.
//     * Серия                 - СправочникСсылка.СерииНоменклатуры - Серия, если такого реквизита нет, следует передать Неопределено.
//     * Количество            - Число - Количество.
//     * ПоступлениеПоЗаказам  - Булево - Признак того, что текущий документ является накладной по заказу.
//     * ЭтоНакладная          - Булево - Признак того, что текущий документ является накладной.
//     * ЭтоКорректировкаВнутриНакладной - Булево - Признак того, что строка накладной делает отрицательный приход.
//  ОбъектМетаданных - ОбъектМетаданныхДокумент - объект метаданных текущего документа.
//  ПараметрыМетода - см. ПараметрыМодульногоПроведения
//
Процедура ОформитьПоступлениеТоваровПоОдноходовкеВнутренний(Запрос,
													ТекстыЗапроса,
													Регистры,
													ТекстЗапросаДокумента,
													ОбъектМетаданных,
													ПараметрыМетода)
	
	ИмяТЧСерии = ПараметрыМетода.ИмяТЧСерии;
	СинонимТаблицыДокумента = ПараметрыМетода.СинонимТаблицыДокумента;
	ТребуетсяУчитыватьСерииКОформлениюНакладныхПоРаспоряжению 
		= ПараметрыМетода.ТребуетсяУчитыватьСерииКОформлениюНакладныхПоРаспоряжению;
	ТребуетсяОтборПоОрдерностиСкладаНаОтражениеИзлишковНедостач 
		= ПараметрыМетода.ТребуетсяОтборПоОрдерностиСкладаНаОтражениеИзлишковНедостач;
	
	ТекстЗапросаВТТовары =
	"ВЫБРАТЬ
	|	ДанныеДокумента.Ссылка					КАК Ссылка,
	|	ДанныеДокумента.Исправление				КАК Исправление,
	|	ДанныеДокумента.ИсправляемыйДокумент	КАК ИсправляемыйДокумент,
	|	ДанныеДокумента.Заказ					КАК Заказ,
	|	ДанныеДокумента.Накладная				КАК Накладная,
	|	ДанныеДокумента.Договор					КАК Договор,
	|	ДанныеДокумента.Соглашение				КАК Соглашение,
	|	ДанныеДокумента.ВариантПриемкиТоваров	КАК ВариантПриемкиТоваров,
	|	ДанныеДокумента.Отправитель				КАК Отправитель,
	|	ДанныеДокумента.ХозяйственнаяОперация	КАК ХозяйственнаяОперация,
	|	ДанныеДокумента.СверхЗаказа				КАК СверхЗаказа,
	|	ДанныеДокумента.ПоступлениеПоЗаказам	КАК ПоступлениеПоЗаказам,
	|	ДанныеДокумента.ЭтоНакладная			КАК ЭтоНакладная,
	|	ДанныеДокумента.Дата					КАК Дата,
	|	ДанныеДокумента.Номенклатура			КАК Номенклатура,
	|	ДанныеДокумента.Характеристика			КАК Характеристика,
	|	&Назначение								КАК Назначение,
	|	ВЫБОР
	|		КОГДА ДанныеДокумента.ПроконтролироватьКачество
	|			ТОГДА ДанныеДокумента.КонтролируемаяПартия
	|		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.КонтролируемыеПартии.ПустаяСсылка)
	|	КОНЕЦ КАК КонтролируемаяПартия,
	|	ВЫБОР
	|		КОГДА ДанныеДокумента.ПроконтролироватьКачество И ДанныеДокумента.ДвижениеРанееПоступившейПартии
	|			ТОГДА ДанныеДокумента.КонтролируемаяПартия
	|		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.КонтролируемыеПартии.ПустаяСсылка)
	|	КОНЕЦ КАК КонтролируемаяПартияТоварыКПоступлению,
	|	ДанныеДокумента.СтатусУказанияСерий		КАК СтатусУказанияСерий,
	|	ДанныеДокумента.Серия					КАК Серия,
	|	ДанныеДокумента.Склад					КАК Склад,
	|	&ДополнительныеПоляВыборки,
	|	СУММА(ДанныеДокумента.Количество)		КАК Количество,
	|	МАКСИМУМ(ДанныеДокумента.ЭтоКорректировкаВнутриНакладной) КАК ЭтоКорректировкаВнутриНакладной
	|ПОМЕСТИТЬ ВТТоварыОформитьПоступлениеТоваровПоОдноходовке
	|ИЗ
	|	#ДанныеДокумента КАК ДанныеДокумента
	|ГДЕ
	|	ДанныеДокумента.Количество <> 0
	|
	|СГРУППИРОВАТЬ ПО
	|	ДанныеДокумента.Ссылка,
	|	ДанныеДокумента.Исправление,
	|	ДанныеДокумента.ИсправляемыйДокумент,
	|	ДанныеДокумента.Заказ,
	|	ДанныеДокумента.Накладная,
	|	ДанныеДокумента.Договор,
	|	ДанныеДокумента.Соглашение,
	|	ДанныеДокумента.ВариантПриемкиТоваров,
	|	ДанныеДокумента.Отправитель,
	|	ДанныеДокумента.ХозяйственнаяОперация,
	|	ДанныеДокумента.СверхЗаказа,
	|	ДанныеДокумента.ПоступлениеПоЗаказам,
	|	ДанныеДокумента.ЭтоНакладная,
	|	ДанныеДокумента.Дата,
	|	ДанныеДокумента.Номенклатура,
	|	ДанныеДокумента.Характеристика,
	|	&Назначение,
	|	ВЫБОР
	|		КОГДА ДанныеДокумента.ПроконтролироватьКачество
	|			ТОГДА ДанныеДокумента.КонтролируемаяПартия
	|		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.КонтролируемыеПартии.ПустаяСсылка)
	|	КОНЕЦ,
	|	ВЫБОР
	|		КОГДА ДанныеДокумента.ПроконтролироватьКачество И ДанныеДокумента.ДвижениеРанееПоступившейПартии
	|			ТОГДА ДанныеДокумента.КонтролируемаяПартия
	|		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.КонтролируемыеПартии.ПустаяСсылка)
	|	КОНЕЦ,
	|	ДанныеДокумента.Серия,
	|	ДанныеДокумента.СтатусУказанияСерий,
	|	&ДополнительныеПоляГруппировки,
	|	ДанныеДокумента.Склад";
	
	ПараметрыЗапроса = ПараметрыТекстаЗапросаДанныхДокумента("ОформитьПоступлениеТоваровПоОдноходовке",
															СинонимТаблицыДокумента);
	
	ЗаполнитьПараметрыТекстаЗапроса(ТекстЗапросаВТТовары, ПараметрыЗапроса);
	
	ДополнительныеПоляВыборки		= Новый Массив;
	ДополнительныеПоляГруппировки	= Новый Массив;
	
	ШаблонПодменыДопПолейВыборки		= "ДанныеДокумента.%1 КАК %1";
	ШаблонПодменыДопПолейГруппировки	= "ДанныеДокумента.%1";
	
	// Поля выборки коллекции ДополнительныеПоляСоединенияССериями должны быть без псевдонима,
	// т.к. возможны дублирования с обязательными полями источника данных.
	Для Каждого Поле Из ПараметрыМетода.ДополнительныеПоляСоединенияССериями Цикл
		ДополнительныеПоляВыборки.Добавить(СтрШаблон(ШаблонПодменыДопПолейГруппировки, Поле));
		ДополнительныеПоляГруппировки.Добавить(СтрШаблон(ШаблонПодменыДопПолейГруппировки, Поле));
	КонецЦикла;
	
	Для Каждого КлючИЗначение Из ПараметрыМетода.ПереопределяемыеПоляСоединенияССериями Цикл
		Если Не ЗначениеЗаполнено(КлючИЗначение.Значение) Тогда
			Продолжить;
		КонецЕсли;
		
		ДополнительныеПоляВыборки.Добавить(СтрШаблон(ШаблонПодменыДопПолейВыборки, КлючИЗначение.Значение));
		ДополнительныеПоляГруппировки.Добавить(СтрШаблон(ШаблонПодменыДопПолейГруппировки, КлючИЗначение.Значение));
	КонецЦикла;
	
	РазделительПолей = ",
		|	";
	
	ТекстПодменыДопПолейВыборки		= СтрСоединить(ДополнительныеПоляВыборки, РазделительПолей);
	ТекстПодменыДопПолейГруппировки	= СтрСоединить(ДополнительныеПоляГруппировки, РазделительПолей);
	
	Если ДополнительныеПоляВыборки.Количество() > 0 Тогда
		ТекстЗапросаВТТовары = СтрЗаменить(ТекстЗапросаВТТовары,
											"&ДополнительныеПоляВыборки",
											ТекстПодменыДопПолейВыборки);
		ТекстЗапросаВТТовары = СтрЗаменить(ТекстЗапросаВТТовары,
											"&ДополнительныеПоляГруппировки",
											ТекстПодменыДопПолейГруппировки);
	Иначе
		ТекстЗапросаВТТовары = СтрЗаменить(ТекстЗапросаВТТовары, "&ДополнительныеПоляВыборки,", "");
		ТекстЗапросаВТТовары = СтрЗаменить(ТекстЗапросаВТТовары, "&ДополнительныеПоляГруппировки,", "");
	КонецЕсли;
	
	ТекстЗапросаВТТовары = СтрЗаменить(ТекстЗапросаВТТовары, "ДанныеДокумента", СинонимТаблицыДокумента);
	
	ТекстыЗапросовВременныхТаблиц = Новый Структура;
	ТекстыЗапросовВременныхТаблиц.Вставить("ВТТоварыОформитьПоступлениеТоваровПоОдноходовке", ТекстЗапросаВТТовары);
	
	Если ИмяТЧСерии <> "" Тогда
		
		ТекстЗапросаВТТоварыБезЗаказа =
		"ВЫБРАТЬ
		|	ДанныеДокумента.Ссылка					КАК Ссылка,
		|	ДанныеДокумента.Дата					КАК Дата,
		|	ДанныеДокумента.Номенклатура			КАК Номенклатура,
		|	ДанныеДокумента.Характеристика			КАК Характеристика,
		|	&Назначение								КАК Назначение,
		|	ВЫБОР
		|		КОГДА ДанныеДокумента.ПроконтролироватьКачество
		|			ТОГДА ДанныеДокумента.КонтролируемаяПартия
		|		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.КонтролируемыеПартии.ПустаяСсылка)
		|	КОНЕЦ КАК КонтролируемаяПартия,
		|	ДанныеДокумента.СтатусУказанияСерий		КАК СтатусУказанияСерий,
		|	ДанныеДокумента.Серия					КАК Серия,
		|	ДанныеДокумента.Склад					КАК Склад,
		|	&ДополнительныеПоляВыборки,
		|	СУММА(ДанныеДокумента.Количество)		КАК Количество,
		|	МАКСИМУМ(ДанныеДокумента.ЭтоКорректировкаВнутриНакладной) КАК ЭтоКорректировкаВнутриНакладной
		|ПОМЕСТИТЬ ВТТоварыБезЗаказаОформитьПоступлениеТоваровПоОдноходовке
		|ИЗ
		|	#ДанныеДокумента КАК ДанныеДокумента
		|ГДЕ
		|	ДанныеДокумента.Количество <> 0
		|
		|СГРУППИРОВАТЬ ПО
		|	ДанныеДокумента.Ссылка,
		|	ДанныеДокумента.Дата,
		|	ДанныеДокумента.Номенклатура,
		|	ДанныеДокумента.Характеристика,
		|	&Назначение,
		// Когда в документе для одной и той же номенклатуры с серией в отдельной табличной части
		// есть строки с установленным признаком Проконтролировать качество и со сброшенным.
		// В табличной части серий должно быть поле Контролируемая партия и должно быть организовано соединение по этому полю.
		// В противном случае в обработке проверки заполнения выдается ошибка. 
		|	ВЫБОР
		|		КОГДА ДанныеДокумента.ПроконтролироватьКачество
		|			ТОГДА ДанныеДокумента.КонтролируемаяПартия
		|		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.КонтролируемыеПартии.ПустаяСсылка)
		|	КОНЕЦ,
		|	ДанныеДокумента.Серия,
		|	ДанныеДокумента.СтатусУказанияСерий,
		|	&ДополнительныеПоляГруппировки,
		|	ДанныеДокумента.Склад";
		
		ЗаполнитьПараметрыТекстаЗапроса(ТекстЗапросаВТТоварыБезЗаказа, ПараметрыЗапроса);
		Если ПараметрыМетода.ДополнительныеПоляСоединенияССериями.Количество() > 0 Тогда
			ТекстЗапросаВТТоварыБезЗаказа = СтрЗаменить(ТекстЗапросаВТТоварыБезЗаказа,
														"&ДополнительныеПоляВыборки",
														ТекстПодменыДопПолейВыборки);
			ТекстЗапросаВТТоварыБезЗаказа = СтрЗаменить(ТекстЗапросаВТТоварыБезЗаказа,
														"&ДополнительныеПоляГруппировки",
														ТекстПодменыДопПолейГруппировки);
		Иначе
			ТекстЗапросаВТТоварыБезЗаказа = СтрЗаменить(ТекстЗапросаВТТоварыБезЗаказа,
														"&ДополнительныеПоляВыборки,",
														"");
			ТекстЗапросаВТТоварыБезЗаказа = СтрЗаменить(ТекстЗапросаВТТоварыБезЗаказа,
														"&ДополнительныеПоляГруппировки,",
														"");
		КонецЕсли;
		
		ТекстЗапросаВТТоварыБезЗаказа = СтрЗаменить(ТекстЗапросаВТТоварыБезЗаказа, "ДанныеДокумента", СинонимТаблицыДокумента);
		ТекстыЗапросовВременныхТаблиц.Вставить("ВТТоварыБезЗаказаОформитьПоступлениеТоваровПоОдноходовке", ТекстЗапросаВТТоварыБезЗаказа);
		
		ТекстЗапросаВТСерии =
		"ВЫБРАТЬ
		|	ДанныеДокумента.Ссылка					КАК Ссылка,
		|	ДанныеДокумента.Дата					КАК Дата,
		|	ДанныеДокумента.Номенклатура			КАК Номенклатура,
		|	ДанныеДокумента.Характеристика			КАК Характеристика,
		|	&Назначение								КАК Назначение,
		|	ДанныеДокумента.КонтролируемаяПартия    КАК КонтролируемаяПартия,
		|	МАКСИМУМ(ДанныеДокумента.СтатусУказанияСерий) КАК СтатусУказанияСерий,
