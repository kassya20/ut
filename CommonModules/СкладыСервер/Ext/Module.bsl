//
// Параметры:
//	Запрос						- Запрос			- запрос отражения документа в учете.
//	ТекстыЗапроса				- СписокЗначений	- коллекция текстов запроса отражения документа в учете.
//	Регистры					- Структура, Строка, Неопределено - коллекция регистров для отражения документа в учете.
//	ТекстЗапросаДанныхДокумента	- Строка			- текст запроса данных документа.
//		Состав полей выборки:
//			* Ссылка				- ДокументСсылка								- ссылка документа-регистратора.
//			* Период				- Дата											- дата отражения операции.
//			* Склад					- СправочникСсылка.Склады						- склад, с которого выполняется отгрузка товаров.
//			* Номенклатура			- СправочникСсылка.Номенклатура					- отгружаемый товар.
//			* Характеристика		- СправочникСсылка.ХарактеристикиНоменклатуры	- характеристика отгружаемого товара.
//			* Серия					- СправочникСсылка.СерииНоменклатуры			- серия отгружаемого товара.
//			* СтатусУказанияСерий	- Число											- статус указания серии.
//			* Количество			- Число											- количество отгружаемого товара.
//			* ВозвратТовара			- Булево										- Истина - признак того, что оформляется возврат товара.
//	ОбъектМетаданных			- ОбъектМетаданных,
//									Неопределено	- объект метаданных документа-регистратора.
//														Заполняется, если в состав документа включена табличная часть, хранящая информацию о сериях товаров.
//  ПараметрыМетода - см. ПараметрыМодульногоПроведения
//
Процедура ОформитьОтгрузкуВРозницу(Запрос,
									ТекстыЗапроса,
									Регистры,
									ТекстЗапросаДанныхДокумента,
									ОбъектМетаданных = Неопределено,
									ПараметрыМетода) Экспорт
									
	ИмяТЧСерии = ПараметрыМетода.ИмяТЧСерии;
	СинонимТЧДокумента = ПараметрыМетода.СинонимТаблицыДокумента;
									
	ТекстЗапросаВТТоварыСвернутые = 
	"ВЫБРАТЬ
	|	ДанныеДокумента.Ссылка				КАК Ссылка,
	|	ДанныеДокумента.Период				КАК Период,
	|	ДанныеДокумента.Склад				КАК Склад,
	|	ДанныеДокумента.Помещение			КАК Помещение,
	|	ДанныеДокумента.Номенклатура		КАК Номенклатура,
	|	ДанныеДокумента.Характеристика		КАК Характеристика,
	|	ДанныеДокумента.Серия				КАК Серия,
	|	ДанныеДокумента.СтатусУказанияСерий	КАК СтатусУказанияСерий,
	|	&ДополнительныеПоля,	
	|	СУММА(ДанныеДокумента.Количество)	КАК Количество,
	|	ДанныеДокумента.ВозвратТовара		КАК ВозвратТовара
	|ПОМЕСТИТЬ ВТТоварыСвернутыеОформитьОтгрузкуВРозницу
	|ИЗ
	|	#ДанныеДокумента КАК ДанныеДокумента
	|
	|СГРУППИРОВАТЬ ПО
	|	ДанныеДокумента.Ссылка,
	|	ДанныеДокумента.Период,
	|	ДанныеДокумента.Склад,
	|	ДанныеДокумента.Помещение,
	|	ДанныеДокумента.Номенклатура,
	|	ДанныеДокумента.Характеристика,
	|	ДанныеДокумента.Серия,
	|	ДанныеДокумента.СтатусУказанияСерий,
	|	&ДополнительныеПоля,	
	|	ДанныеДокумента.ВозвратТовара";
	
	ПараметрыЗапроса = ПараметрыТекстаЗапросаДанныхДокумента("ОформитьОтгрузкуВРозницу");
	
	ЗаполнитьПараметрыТекстаЗапроса(ТекстЗапросаВТТоварыСвернутые, ПараметрыЗапроса);
	
	ТекстПодменыДопПолей = "";
	Для Каждого Поле Из ПараметрыМетода.ДополнительныеПоляСоединенияССериями Цикл
		ТекстПодменыДопПолей = ТекстПодменыДопПолей + ", " + "ДанныеДокумента." + Поле + Символы.ПС;
	КонецЦикла;
	ТекстПодменыДопПолей = Сред(ТекстПодменыДопПолей, 2);
	
	Если ПараметрыМетода.ДополнительныеПоляСоединенияССериями.Количество() > 0 Тогда
		ТекстЗапросаВТТоварыСвернутые = СтрЗаменить(ТекстЗапросаВТТоварыСвернутые, "&ДополнительныеПоля", ТекстПодменыДопПолей);
	Иначе
