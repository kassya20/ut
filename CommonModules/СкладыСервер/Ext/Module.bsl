Процедура РаспределитьТоварыКОтгрузкеПоЗаданиямНаПеревозку(ДеревоТоварыКОтгрузке)
	
	СтрокиКУдалению = Новый Массив;
	КоличествоКДоставкеПоЗаданиюНаПеревозку = Новый Соответствие;
	
	Для Каждого УровеньОтгрузкаПоЗаданиюНаПеревозку Из ДеревоТоварыКОтгрузке.Строки Цикл
		
		Если Не УровеньОтгрузкаПоЗаданиюНаПеревозку.ОтгрузкаПоЗаданиюНаПеревозку Тогда
			Продолжить;
		КонецЕсли;
		
		Для Каждого УровеньПолучатель Из УровеньОтгрузкаПоЗаданиюНаПеревозку.Строки Цикл
			Для Каждого УровеньДокументОтгрузки Из УровеньПолучатель.Строки Цикл
				Для Каждого УровеньНоменклатура Из УровеньДокументОтгрузки.Строки Цикл
					Для Каждого УровеньХарактеристика Из УровеньНоменклатура.Строки  Цикл
						Для Каждого УровеньНазначение Из УровеньХарактеристика.Строки Цикл
							Для Каждого УровеньКонтролируемаяПартия Из УровеньНазначение.Строки Цикл
								Для Каждого УровеньСерия Из УровеньКонтролируемаяПартия.Строки Цикл
									
									КоличествоКДоставкеПоЗаданиюНаПеревозку.Очистить();
									
									Для Каждого УровеньКоличествоКОтгрузке Из УровеньСерия.Строки Цикл 
										
										КоличествоКОтгрузке = УровеньКоличествоКОтгрузке.Количество;
										
										Для Каждого УровеньЗаданиеНаПеревозку Из УровеньКоличествоКОтгрузке.Строки Цикл
											Для Каждого Строка Из УровеньЗаданиеНаПеревозку.Строки Цикл
												
												Если КоличествоКОтгрузке = 0 Тогда
													АдресУдаляемойСтроки = Новый Массив;
													АдресУдаляемойСтроки.Добавить(Строка);
													АдресУдаляемойСтроки.Добавить(УровеньЗаданиеНаПеревозку);
													АдресУдаляемойСтроки.Добавить(УровеньКоличествоКОтгрузке);
													АдресУдаляемойСтроки.Добавить(УровеньСерия);
													АдресУдаляемойСтроки.Добавить(УровеньНазначение);
													АдресУдаляемойСтроки.Добавить(УровеньКонтролируемаяПартия);
													АдресУдаляемойСтроки.Добавить(УровеньХарактеристика);
													АдресУдаляемойСтроки.Добавить(УровеньНоменклатура);
													АдресУдаляемойСтроки.Добавить(УровеньДокументОтгрузки);
													АдресУдаляемойСтроки.Добавить(УровеньПолучатель);
													АдресУдаляемойСтроки.Добавить(УровеньОтгрузкаПоЗаданиюНаПеревозку);
													АдресУдаляемойСтроки.Добавить(ДеревоТоварыКОтгрузке);
													
													СтрокиКУдалению.Добавить(АдресУдаляемойСтроки);
													
													Продолжить;
												КонецЕсли;
												
												Если Строка.ВсеТовары Тогда
													КоличествоКДоставке = КоличествоКОтгрузке;
												Иначе
													
													КоличествоКДоставкеИзрасходовано = КоличествоКДоставкеПоЗаданиюНаПеревозку.Получить(Строка.ЗаданиеНаПеревозку);
													КоличествоКДоставкеИзрасходовано = ?(КоличествоКДоставкеИзрасходовано = Неопределено,
																							0,
																							КоличествоКДоставкеИзрасходовано);
													
													КоличествоКДоставке = Строка.КоличествоКДоставке - КоличествоКДоставкеИзрасходовано;
													КоличествоКДоставке = Мин(КоличествоКОтгрузке, КоличествоКДоставке);
													
													Если КоличествоКДоставке > 0 Тогда
														КоличествоКДоставкеПоЗаданиюНаПеревозку.Вставить(
															Строка.ЗаданиеНаПеревозку,
															КоличествоКДоставке + КоличествоКДоставкеИзрасходовано);
													Иначе
														АдресУдаляемойСтроки = Новый Массив;
														АдресУдаляемойСтроки.Добавить(Строка);
														АдресУдаляемойСтроки.Добавить(УровеньЗаданиеНаПеревозку);
														АдресУдаляемойСтроки.Добавить(УровеньКоличествоКОтгрузке);
														АдресУдаляемойСтроки.Добавить(УровеньСерия);
														АдресУдаляемойСтроки.Добавить(УровеньНазначение);
														АдресУдаляемойСтроки.Добавить(УровеньКонтролируемаяПартия);
														АдресУдаляемойСтроки.Добавить(УровеньХарактеристика);
														АдресУдаляемойСтроки.Добавить(УровеньНоменклатура);
														АдресУдаляемойСтроки.Добавить(УровеньДокументОтгрузки);
														АдресУдаляемойСтроки.Добавить(УровеньПолучатель);
														АдресУдаляемойСтроки.Добавить(УровеньОтгрузкаПоЗаданиюНаПеревозку);
														АдресУдаляемойСтроки.Добавить(ДеревоТоварыКОтгрузке);
														
														СтрокиКУдалению.Добавить(АдресУдаляемойСтроки);
														
														Продолжить;
													КонецЕсли;
													
												КонецЕсли;
												
												Строка.Количество = КоличествоКДоставке;
												
												КоличествоКОтгрузке = КоличествоКОтгрузке - КоличествоКДоставке;
											КонецЦикла;
										КонецЦикла;
										
									КонецЦикла;
									
								КонецЦикла;
							КонецЦикла;
						КонецЦикла;
					КонецЦикла;
				КонецЦикла;
			КонецЦикла;
		КонецЦикла;
		
	КонецЦикла;
	
	Для Каждого АдресКУдалению Из СтрокиКУдалению Цикл
		// Последний элемент массива не обрабатывается т.к. это ссылка на корень дерева.
		Уровней = АдресКУдалению.ВГраница() - 1;
		
		Для Индекс = 0 По Уровней Цикл
			ТекущаяСтрока	= АдресКУдалению[Индекс];
			Родитель		= АдресКУдалению[Индекс + 1]; // СтрокаДереваЗначений -
			
			Если Индекс = 0 Тогда
				Родитель.Строки.Удалить(ТекущаяСтрока);
			ИначеЕсли ТекущаяСтрока.Строки.Количество() = 0 Тогда
				// Удаление пустого родителя.
				Родитель.Строки.Удалить(ТекущаяСтрока);
			КонецЕсли;
		КонецЦикла;
	КонецЦикла;
	
КонецПроцедуры

Функция ТаблицаДляВычисленияТоваровОформленияРасходныхОрдеров(ИсходнаяТаблица, ПоЗаданиюНаПеревозку = Истина)
	
	ОписаниеРегистра	= Метаданные.РегистрыНакопления.ТоварыКОтгрузке;
	ОписаниеИзмерений	= ОписаниеРегистра.Измерения;
	
	ОписаниеТипаПериод		= Новый ОписаниеТипов("Дата");
	ОписаниеТипаПолучатель	= Новый ОписаниеТипов(ОписаниеИзмерений.Получатель.Тип,
										ОписаниеИзмерений.ДокументОтгрузки.Тип.Типы());
	ОписаниеТипаКоличество	= ОбщегоНазначенияУТ.ОписаниеТипаКоличественногоПоля(ДопустимыйЗнак.Неотрицательный);
	
	ТаблицаТоваров = Новый ТаблицаЗначений;
	ТаблицаТоваров.Колонки.Добавить("Период", ОписаниеТипаПериод);
	ТаблицаТоваров.Колонки.Добавить("ДокументОтгрузки", ОписаниеИзмерений.ДокументОтгрузки.Тип);
	ТаблицаТоваров.Колонки.Добавить("Получатель", ОписаниеТипаПолучатель);
	ТаблицаТоваров.Колонки.Добавить("Склад", ОписаниеИзмерений.Склад.Тип);
	ТаблицаТоваров.Колонки.Добавить("Номенклатура", ОписаниеИзмерений.Номенклатура.Тип);
	ТаблицаТоваров.Колонки.Добавить("Характеристика", ОписаниеИзмерений.Характеристика.Тип);
	ТаблицаТоваров.Колонки.Добавить("Назначение", ОписаниеИзмерений.Назначение.Тип);
	ТаблицаТоваров.Колонки.Добавить("КонтролируемаяПартия", ОписаниеИзмерений.КонтролируемаяПартия.Тип);
	ТаблицаТоваров.Колонки.Добавить("Серия", ОписаниеИзмерений.Серия.Тип);
	ТаблицаТоваров.Колонки.Добавить("Количество", ОписаниеТипаКоличество);
	ТаблицаТоваров.Колонки.Добавить("ПериодОтгрузки", ОписаниеТипаПериод);
	
	Если ПоЗаданиюНаПеревозку Тогда
		ТаблицаТоваров.Колонки.Добавить("ОтгрузкаПоЗаданиюНаПеревозку", Новый ОписаниеТипов("Булево"));
		ТаблицаТоваров.Колонки.Добавить("ЗаданиеНаПеревозку", ОписаниеРегистра.Реквизиты.ЗаданиеНаПеревозку.Тип);
	КонецЕсли;
	
	Для Каждого ИсходнаяСтрока Из ИсходнаяТаблица Цикл
		НоваяСтрока = ТаблицаТоваров.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, ИсходнаяСтрока);
	КонецЦикла;
	
	Возврат ТаблицаТоваров;
	
КонецФункции

