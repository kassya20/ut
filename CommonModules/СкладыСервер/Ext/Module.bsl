	КонецЕсли;
	
 	ПараметрыЗапроса = ПараметрыТекстаЗапросаДанныхДокумента("ОформитьПоступлениеТоваровПоДвухходовке",
		СинонимТаблицыДокумента, УчитываютсяВДвиженияхУслугиРаботы);
	ПараметрыЗапроса.Вставить("УчитываютсяВДвиженияхУслугиРаботы", ?(УчитываютсяВДвиженияхУслугиРаботы,"ИСТИНА","ЛОЖЬ"));
	
	Если Не ПараметрыМетода.ЭтоПоступлениеУслугВПодразделение Тогда
		ШаблонТекстаЗапросаТоварыКПоступлению = СтрЗаменить(ШаблонТекстаЗапросаТоварыКПоступлению,
																"ДокументПоступленияНакладнойУслугиДвухходовки",
																"ДокументПоступленияНакладнойДвухходовки");
	КонецЕсли;
	
	ЗаполнитьПараметрыТекстаЗапроса(ШаблонТекстаЗапросаТоварыНаСкладах,		ПараметрыЗапроса);
	ЗаполнитьПараметрыТекстаЗапроса(ШаблонТекстаЗапросаТоварыКПоступлению,	ПараметрыЗапроса);
	
	ШаблонТекстаЗапросаТоварыНаСкладах		= СтрЗаменить(ШаблонТекстаЗапросаТоварыНаСкладах,
															"ДанныеДокумента",
															СинонимТаблицыДокумента);
	ШаблонТекстаЗапросаТоварыКПоступлению	= СтрЗаменить(ШаблонТекстаЗапросаТоварыКПоступлению,
															"ДанныеДокумента",
															СинонимТаблицыДокумента);
	
	ТекстыШаблоновОтражения = Новый Структура;
	
	Если ПроведениеДокументов.ТребуетсяТаблицаДляДвижений("ТоварыНаСкладах", Регистры) Тогда
		ТекстыШаблоновОтражения.Вставить("ТоварыНаСкладах", ШаблонТекстаЗапросаТоварыНаСкладах);
	КонецЕсли;
	
	Если ПроведениеДокументов.ТребуетсяТаблицаДляДвижений("ТоварыКПоступлению", Регистры) Тогда
		ТекстыШаблоновОтражения.Вставить("ТоварыКПоступлению", ШаблонТекстаЗапросаТоварыКПоступлению);
	КонецЕсли;
	
	ТекстыЗапросовДанныхДокумента = Новый Структура(СинонимТаблицыДокумента, ТекстЗапросаДокумента);
	
	ПроведениеДокументов.ДополнитьЗапросОтраженияДокумента(Запрос,
															ТекстыЗапроса,
															ТекстыШаблоновОтражения,
															ТекстыЗапросовДанныхДокумента);
	
КонецПроцедуры

#КонецОбласти

Функция ДополнительныеАналитикиОшибкиКонтроляОстатков(СтрокаОшибки)
	
	Тексты = Новый Массив();
	Если ЗначениеЗаполнено(СтрокаОшибки.Назначение) Тогда
		Тексты.Добавить(Строка(СтрокаОшибки.Назначение));
	КонецЕсли;
	Если ЗначениеЗаполнено(СтрокаОшибки.КонтролируемаяПартия) Тогда
		Тексты.Добавить(Строка(СтрокаОшибки.КонтролируемаяПартия));
	КонецЕсли;
	ДополнительныеАналитики = ?(Тексты.Количество() = 0, "", СтрШаблон("(%1)", СтрСоединить(Тексты, ", ")));
	Возврат ДополнительныеАналитики;
	
КонецФункции

Функция ДокументыДляКонтроляПоТоварамОрганизаций()
	
	ДокументыСКонтролем = Новый Массив();
	
	

	ДокументыСКонтролем.Добавить(Тип("ДокументОбъект.ПередачаТоваровХранителю"));
	ДокументыСКонтролем.Добавить(Тип("ДокументОбъект.ОтгрузкаТоваровКлиенту"));
	ДокументыСКонтролем.Добавить(Тип("ДокументОбъект.ОтгрузкаТоваровСХранения"));
	ДокументыСКонтролем.Добавить(Тип("ДокументОбъект.ЗаказКлиента"));
	ДокументыСКонтролем.Добавить(Тип("ДокументОбъект.ЗаказНаВнутреннееПотребление"));
	ДокументыСКонтролем.Добавить(Тип("ДокументОбъект.ЗаказНаПеремещение"));
	ДокументыСКонтролем.Добавить(Тип("ДокументОбъект.ЗаказНаСборку"));
	ДокументыСКонтролем.Добавить(Тип("ДокументОбъект.ЗаявкаНаВозвратТоваровОтКлиента"));
	ДокументыСКонтролем.Добавить(Тип("ДокументОбъект.ВнутреннееПотребление"));
	ДокументыСКонтролем.Добавить(Тип("ДокументОбъект.ПеремещениеТоваров"));
	ДокументыСКонтролем.Добавить(Тип("ДокументОбъект.РеализацияТоваровУслуг"));
	ДокументыСКонтролем.Добавить(Тип("ДокументОбъект.СборкаТоваров"));
	ДокументыСКонтролем.Добавить(Тип("ДокументОбъект.ВозвратТоваровПоставщику"));
	ДокументыСКонтролем.Добавить(Тип("ДокументОбъект.Сторно"));
	// РасходныйОрдерНаТовары контролируется отдельно
	
	Возврат ДокументыСКонтролем;
	
КонецФункции

#КонецОбласти
