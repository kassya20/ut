////////////////////////////////////////////////////////////////////////////////
// Модуль "СкладыСервер", содержит процедуры и функции для
// управления складскими операциями.
//
////////////////////////////////////////////////////////////////////////////////

#Область ПрограммныйИнтерфейс

#Область Проведение

// Формирует параметры для проведения документа по регистрам учетного механизма через общий механизм проведения.
//
// Параметры:
//  Документ - ДокументОбъект - записываемый документ
//  Свойства - см. ПроведениеДокументов.СвойстваДокумента
//
// Возвращаемое значение:
//  Структура - см. ПроведениеДокументов.ПараметрыУчетногоМеханизма
//
Функция ПараметрыДляПроведенияДокумента(Документ, Свойства) Экспорт
	
	Параметры = ПроведениеДокументов.ПараметрыУчетногоМеханизма();
	
	ДополнительныеДокументы = Новый Структура;
	ПроведениеДокументовЛокализация.ЗаполнитьЛокальныеДокументыДвиженияТоваров(ДополнительныеДокументы);
	
	// Проведение
	Если Свойства.РежимЗаписи = РежимЗаписиДокумента.Проведение Тогда
		
		ТипДокумента = ТипЗнч(Документ);
		
		Параметры.ПодчиненныеРегистры.Добавить(Метаданные.РегистрыНакопления.ТоварыНаСкладах);
		Параметры.ПодчиненныеРегистры.Добавить(Метаданные.РегистрыНакопления.ТоварыКОформлениюИзлишковНедостач);
		Параметры.ПодчиненныеРегистры.Добавить(Метаданные.РегистрыНакопления.ТоварныеМестаКОтражениюИзлишковНедостач);
		
		Если ТипДокумента <> Тип("ДокументОбъект.ОрдерНаПеремещениеТоваров") Тогда
			Параметры.ПодчиненныеРегистры.Добавить(Метаданные.РегистрыНакопления.ТоварыКПоступлению);
			Параметры.ПодчиненныеРегистры.Добавить(Метаданные.РегистрыНакопления.ТоварыКОтгрузке);
		КонецЕсли;
		
		Параметры.ПодчиненныеРегистры.Добавить(Метаданные.РегистрыНакопления.ТоварыВЯчейках);
		Параметры.ПодчиненныеРегистры.Добавить(Метаданные.РегистрыНакопления.ТоварыКОтбору);
		Параметры.ПодчиненныеРегистры.Добавить(Метаданные.РегистрыСведений.БлокировкиСкладскихЯчеек);
		
	КонецЕсли;
	
	// Контроль
	Если Свойства.РежимЗаписи <> РежимЗаписиДокумента.Запись Тогда
		
		Параметры.КонтрольныеРегистрыЗаданий.Добавить(Метаданные.РегистрыНакопления.ТоварныеМестаКОтражениюИзлишковНедостач);
		Параметры.КонтрольныеРегистрыЗаданий.Добавить(Метаданные.РегистрыНакопления.ТоварыКПоступлению);
		
		ТипДокумента = ТипЗнч(Документ);
		
		#Область ТоварыНаСкладах
		
		Если ТипДокумента = Тип("ДокументОбъект.ВнутреннееПотребление")
			Или ТипДокумента = Тип("ДокументОбъект.ВозвратТоваровПоставщику")
			Или ТипДокумента = Тип("ДокументОбъект.ОтгрузкаТоваровСХранения")
			Или ТипДокумента = Тип("ДокументОбъект.ПередачаТоваровХранителю")
			Или ТипДокумента = Тип("ДокументОбъект.ОтгрузкаТоваровКлиенту")
			Или ТипДокумента = Тип("ДокументОбъект.ОтчетОРозничныхПродажах")
			Или ТипДокумента = Тип("ДокументОбъект.ОтчетОРозничныхВозвратах")
			Или ТипДокумента = Тип("ДокументОбъект.ПеремещениеТоваров")
			Или ТипДокумента = Тип("ДокументОбъект.РеализацияТоваровУслуг")
			Или ТипДокумента = Тип("ДокументОбъект.ОрдерНаОтражениеНедостачТоваров")
			Или ТипДокумента = Тип("ДокументОбъект.ОрдерНаОтражениеПересортицыТоваров")
			Или ТипДокумента = Тип("ДокументОбъект.ОрдерНаОтражениеПорчиТоваров") 
			Или (ДополнительныеДокументы.Свойство("КонтрольныеРегистрыИзменений")
				И ДополнительныеДокументы.КонтрольныеРегистрыИзменений.Свойство("ТоварыНаСкладах")
				И ДополнительныеДокументы.КонтрольныеРегистрыИзменений.ТоварыНаСкладах.Найти(ТипДокумента)<>Неопределено)
			Тогда
			
			МенеджерДокумента = Документы[Документ.Метаданные().Имя];
			ИспользуютсяСерии = НоменклатураСервер.ПараметрыУказанияСерий(Документ, МенеджерДокумента).ИспользоватьСерииНоменклатуры;
			
		ИначеЕсли ТипДокумента = Тип("ДокументОбъект.СборкаТоваров") Тогда
			ПараметрыУказанияСерий =  НоменклатураСервер.ПараметрыУказанияСерий(Документ, Документы.СборкаТоваров);
			ИспользуютсяСерии = ПараметрыУказанияСерий.ТЧ.ИспользоватьСерииНоменклатуры
				Или ПараметрыУказанияСерий.Шапка.ИспользоватьСерииНоменклатуры;
		Иначе
			ИспользуютсяСерии = Ложь;
		КонецЕсли;
		
		Если Свойства.РежимЗаписи = РежимЗаписиДокумента.Проведение
			И (ТипДокумента = Тип("ДокументОбъект.КорректировкаНазначенияТоваров")
				Или ТипДокумента = Тип("ДокументОбъект.ЗаявкаНаКонтрольКачестваТоваров")
				Или ТипДокумента = Тип("ДокументОбъект.КорректировкаРеализации")
				Или ТипДокумента = Тип("ДокументОбъект.ЧекККМ")
				Или ТипДокумента = Тип("ДокументОбъект.ЧекККМВозврат")
				Или ТипДокумента = Тип("ДокументОбъект.ЧекККМКоррекции")
				Или ИспользуютсяСерии)
			Или ТипДокумента = Тип("ДокументОбъект.ОрдерНаПеремещениеТоваров") Тогда
			
			Параметры.КонтрольныеРегистрыИзменений.Добавить(Метаданные.РегистрыНакопления.ТоварыНаСкладах);
			
		КонецЕсли;
		
		#КонецОбласти
		
		#Область ТоварыКОтгрузке
		
		ДокументыДляКонтроля = ДокументыДляКонтроляПоТоварамОрганизаций();
		
		Если ДокументыДляКонтроля.Найти(ТипДокумента) <> Неопределено Тогда
			КонтрольРазрешен = Истина;
			Если Документ.ДополнительныеСвойства.Свойство("ИзменениеНаОснованииАктаОРасхождениях")
				И Документ.ДополнительныеСвойства.ИзменениеНаОснованииАктаОРасхождениях Тогда
				КонтрольРазрешен = Ложь;
			КонецЕсли;
			
			Если КонтрольРазрешен Тогда
				Параметры.КонтрольныеРегистрыИзменений.Добавить(Метаданные.РегистрыНакопления.ТоварыКОтгрузке);
			КонецЕсли;
		КонецЕсли;
		
		#КонецОбласти
		
		Если ТипДокумента = Тип("ДокументОбъект.РасходныйОрдерНаТовары")
			И Не Документ.ДополнительныеСвойства.Свойство("ОтключитьКонтрольПриПроведении")
			И (Свойства.РежимЗаписи = РежимЗаписиДокумента.Проведение
				Или Свойства.РежимЗаписи = РежимЗаписиДокумента.ОтменаПроведения) Тогда
			
			Параметры.КонтрольныеРегистрыИзменений.Добавить(Метаданные.РегистрыНакопления.ТоварыКОтгрузке);
			Документ.Движения.ТоварыКОтгрузке.ДополнительныеСвойства.Вставить(
				"ЗапретитьКонтрольДвиженияТоварыКОтгрузкеИзменениеСводно", Истина);
			
			Если Документ.Статус = Перечисления.СтатусыРасходныхОрдеров.КОтбору
				Или Документ.Статус = Перечисления.СтатусыРасходныхОрдеров.Подготовлен Тогда
				Параметры.КонтрольныеРегистрыИзменений.Добавить(Метаданные.РегистрыНакопления.ТоварыНаСкладах);
			КонецЕсли;
			
		КонецЕсли;
		
		Если ТипДокумента = Тип("ДокументОбъект.КорректировкаНазначенияТоваров")
				И Документ.ДополнительныеСвойства.Свойство("ИспользуетсяАдресноеХранение")
			Или ТипДокумента = Тип("ДокументОбъект.ОтборРазмещениеТоваров")
				И Не Документ.ДополнительныеСвойства.Свойство("ПроведениеИзМРМРаботникаСклада")
				И (Документ.Статус = Перечисления.СтатусыОтборовРазмещенийТоваров.ВРаботе
					Или Документ.Статус = Перечисления.СтатусыОтборовРазмещенийТоваров.Подготовлено) Тогда
			Параметры.КонтрольныеРегистрыИзменений.Добавить(Метаданные.РегистрыНакопления.ТоварыВЯчейках);
		КонецЕсли;
		
		Если (ТипДокумента = Тип("ДокументОбъект.РасходныйОрдерНаТовары")
				Или ТипДокумента = Тип("ДокументОбъект.ОрдерНаПеремещениеТоваров"))
				И ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Документ.ЗонаОтгрузки, "ТипСкладскойЯчейки") =
					Перечисления.ТипыСкладскихЯчеек.ОтгрузкаУчетОстатков
			Или ТипДокумента = Тип("ДокументОбъект.ОтборРазмещениеТоваров")
				И (Документ.Статус = Перечисления.СтатусыОтборовРазмещенийТоваров.ВыполненоСОшибками
					Или Документ.Статус = Перечисления.СтатусыОтборовРазмещенийТоваров.ВыполненоБезОшибок) Тогда
			
			Параметры.КонтрольныеРегистрыИзменений.Добавить(Метаданные.РегистрыНакопления.ТоварыВЯчейках);
			Документ.Движения.ТоварыВЯчейках.Записывать = Истина;
			
		КонецЕсли;
		
		Если ТипДокумента = Тип("ДокументОбъект.ОрдерНаПеремещениеТоваров")
			Или ТипДокумента = Тип("ДокументОбъект.ОтборРазмещениеТоваров")
			Или ТипДокумента = Тип("ДокументОбъект.РасходныйОрдерНаТовары")
				И Не Документ.ДополнительныеСвойства.Свойство("ОтключитьКонтрольПриПроведении")
				И СкладыСервер.ИспользоватьАдресноеХранение(Документ.Склад, Документ.Помещение, Документ.ДатаОтгрузки) Тогда
			Параметры.КонтрольныеРегистрыИзменений.Добавить(Метаданные.РегистрыНакопления.ТоварыКОтбору);
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Параметры;
	
КонецФункции

// Возвращает тексты запросов для сторнирования движений при исправлении документов
// 
// Параметры:
// 	МетаданныеДокумента - ОбъектМетаданныхДокумент - Метаданные документа, который проводится.
// 
// Возвращаемое значение:
// 	Соответствие - Соответствие полного имени регистра тексту запроса сторнирования
//
Функция ТекстыЗапросовСторнирования(МетаданныеДокумента) Экспорт
	
	ДвиженияДокумента = МетаданныеДокумента.Движения;

	ТекстыЗапросов = Новый Соответствие();
	
	МетаданныеРегистра = Метаданные.РегистрыНакопления.ТоварыНаСкладах;
	Если ДвиженияДокумента.Содержит(МетаданныеРегистра) Тогда
		ТекстыЗапросов.Вставить(МетаданныеРегистра.ПолноеИмя(),
			ПроведениеДокументов.ТекстСторнирующегоЗапроса(
				МетаданныеРегистра, МетаданныеДокумента));
	КонецЕсли;
	
	МетаданныеРегистра = Метаданные.РегистрыНакопления.ТоварыКПоступлению;
	Если ДвиженияДокумента.Содержит(МетаданныеРегистра) Тогда
		ТекстыЗапросов.Вставить(МетаданныеРегистра.ПолноеИмя(),
			ПроведениеДокументов.ТекстСторнирующегоЗапроса(
				МетаданныеРегистра, МетаданныеДокумента));
	КонецЕсли;
	
	МетаданныеРегистра = Метаданные.РегистрыНакопления.ТоварыКОтгрузке;
	Если ДвиженияДокумента.Содержит(МетаданныеРегистра) Тогда
		ТекстыЗапросов.Вставить(МетаданныеРегистра.ПолноеИмя(),
			ПроведениеДокументов.ТекстСторнирующегоЗапроса(
				МетаданныеРегистра, МетаданныеДокумента));
	КонецЕсли;
	
	МетаданныеРегистра = Метаданные.РегистрыНакопления.ТоварыКОформлениюИзлишковНедостач;
	Если ДвиженияДокумента.Содержит(МетаданныеРегистра) Тогда
		ТекстыЗапросов.Вставить(МетаданныеРегистра.ПолноеИмя(),
			ПроведениеДокументов.ТекстСторнирующегоЗапроса(
				МетаданныеРегистра, МетаданныеДокумента));
	КонецЕсли;
	
	МетаданныеРегистра = Метаданные.РегистрыНакопления.ТоварыВЯчейках;
	Если ДвиженияДокумента.Содержит(МетаданныеРегистра) Тогда
		ТекстыЗапросов.Вставить(МетаданныеРегистра.ПолноеИмя(),
			ПроведениеДокументов.ТекстСторнирующегоЗапроса(
				МетаданныеРегистра, МетаданныеДокумента));
	КонецЕсли;
	
	МетаданныеРегистра = Метаданные.РегистрыНакопления.ТоварыКОтбору;
	Если ДвиженияДокумента.Содержит(МетаданныеРегистра) Тогда
		ТекстыЗапросов.Вставить(МетаданныеРегистра.ПолноеИмя(),
			ПроведениеДокументов.ТекстСторнирующегоЗапроса(
				МетаданныеРегистра, МетаданныеДокумента));
	КонецЕсли;
	
	МетаданныеРегистра = Метаданные.РегистрыНакопления.ТоварныеМестаКОтражениюИзлишковНедостач;
	Если ДвиженияДокумента.Содержит(МетаданныеРегистра) Тогда
		ТекстыЗапросов.Вставить(МетаданныеРегистра.ПолноеИмя(),
			ПроведениеДокументов.ТекстСторнирующегоЗапроса(
				МетаданныеРегистра, МетаданныеДокумента));
	КонецЕсли;
	
	
	Возврат ТекстыЗапросов;
	
КонецФункции

// Дополняет текст запроса механизма проверки даты запрета по таблице изменений.
// 
// Параметры:
// 	Запрос - Запрос - используется для установки параметров запроса.
// 
// Возвращаемое значение:
//	Соответствие - соответствие имен таблиц изменения регистров и текстов запросов.
//	
Функция ТекстыЗапросовКонтрольДатыЗапретаПоТаблицеИзменений(Запрос) Экспорт

	СоответствиеТекстовЗапросов = Новый Соответствие();
	Возврат СоответствиеТекстовЗапросов;
	
КонецФункции

// Процедура формирования движений по подчиненным регистрам адресного склада.
//
// Параметры:
//	ТаблицыДляДвижений - Структура - таблицы данных документа
//	Движения - КоллекцияДвижений - коллекция наборов записей движений документа
//	Отказ - Булево - признак отказа от проведения документа.
//
Процедура ОтразитьДвижения(ТаблицыДляДвижений, Движения, Отказ) Экспорт
	
	Если Отказ Тогда
		Возврат;
	КонецЕсли;
	
	ПроведениеДокументов.ОтразитьДвижения(ТаблицыДляДвижений, Движения, "ТоварыНаСкладах");
	ПроведениеДокументов.ОтразитьДвижения(ТаблицыДляДвижений, Движения, "ТоварыКПоступлению");
	ПроведениеДокументов.ОтразитьДвижения(ТаблицыДляДвижений, Движения, "ТоварыКОтгрузке");
	ПроведениеДокументов.ОтразитьДвижения(ТаблицыДляДвижений, Движения, "ТоварыКОформлениюИзлишковНедостач");
	ПроведениеДокументов.ОтразитьДвижения(ТаблицыДляДвижений, Движения, "ТоварныеМестаКОтражениюИзлишковНедостач");
	
	ПроведениеДокументов.ОтразитьДвижения(ТаблицыДляДвижений, Движения, "ТоварыВЯчейках");
	ПроведениеДокументов.ОтразитьДвижения(ТаблицыДляДвижений, Движения, "ТоварыКОтбору");
	ПроведениеДокументов.ОтразитьДвижения(ТаблицыДляДвижений, Движения, "БлокировкиСкладскихЯчеек");
	
КонецПроцедуры

// Формирует тексты запросов для контроля изменений записанных движений регистров.
//
// Параметры:
//  Запрос - Запрос - запрос, хранящий параметры используемые в списке запросов
//  ТекстыЗапроса - СписокЗначений - список текстов запросов и их имен.
//  Документ - ДокументОбъект - записываемый документ.
//
Процедура ИнициализироватьДанныеКонтроляИзменений(Запрос, ТекстыЗапроса, Документ) Экспорт
	
	#Область ТоварыНаСкладах
	
	Если ПроведениеДокументов.ЕстьЗаписиВТаблице(Документ, "ДвиженияТоварыНаСкладахИзменение") Тогда
		
		ТекстЗапроса =
			"ВЫБРАТЬ
			|	ТоварыНаСкладахОстатки.Номенклатура КАК Номенклатура,
			|	ТоварыНаСкладахОстатки.Характеристика КАК Характеристика,
			|	ТоварыНаСкладахОстатки.Назначение КАК Назначение,
			|	ТоварыНаСкладахОстатки.КонтролируемаяПартия КАК КонтролируемаяПартия,
			|	ТоварыНаСкладахОстатки.Склад КАК Склад,
			|	ТоварыНаСкладахОстатки.Номенклатура.ЕдиницаИзмерения КАК ЕдиницаИзмерения,
			|	ТоварыНаСкладахОстатки.Помещение КАК Помещение,
			|	ТаблицаИзменений.Серия КАК Серия,
			|	СУММА(ТоварыНаСкладахОстатки.ВНаличииОстаток - ТоварыНаСкладахОстатки.КОтгрузкеОстаток) КАК Количество
			|ИЗ
			|	ДвиженияТоварыНаСкладахИзменение КАК ТаблицаИзменений
			|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрНакопления.ТоварыНаСкладах.Остатки(
			|				,
			|				(Номенклатура, Характеристика, Назначение, КонтролируемаяПартия, Склад, Помещение) В
			|					(ВЫБРАТЬ
			|						Таблица.Номенклатура,
			|						Таблица.Характеристика,
			|						Таблица.Назначение,
			|						Таблица.КонтролируемаяПартия,
			|						Таблица.Склад,
			|						Таблица.Помещение
			|					ИЗ
			|						ДвиженияТоварыНаСкладахИзменение КАК Таблица)) КАК ТоварыНаСкладахОстатки
			|		ПО ТаблицаИзменений.Номенклатура = ТоварыНаСкладахОстатки.Номенклатура
			|			И ТаблицаИзменений.Характеристика = ТоварыНаСкладахОстатки.Характеристика
			|			И ТаблицаИзменений.Назначение = ТоварыНаСкладахОстатки.Назначение
			|			И ТаблицаИзменений.КонтролируемаяПартия = ТоварыНаСкладахОстатки.КонтролируемаяПартия
			|			И ТаблицаИзменений.Склад = ТоварыНаСкладахОстатки.Склад
			|			И ТаблицаИзменений.Помещение = ТоварыНаСкладахОстатки.Помещение
			|			И (ВЫБОР
			|				КОГДА ТаблицаИзменений.Серия = ЗНАЧЕНИЕ(Справочник.СерииНоменклатуры.ПустаяСсылка)
			|					ТОГДА ИСТИНА
			|				ИНАЧЕ ТаблицаИзменений.Серия = ТоварыНаСкладахОстатки.Серия
			|			КОНЕЦ)
			|
			|СГРУППИРОВАТЬ ПО
			|	ТоварыНаСкладахОстатки.Номенклатура,
			|	ТоварыНаСкладахОстатки.Характеристика,
			|	ТоварыНаСкладахОстатки.Назначение,
			|	ТоварыНаСкладахОстатки.КонтролируемаяПартия,
			|	ТоварыНаСкладахОстатки.Склад,
			|	ТоварыНаСкладахОстатки.Номенклатура.ЕдиницаИзмерения,
			|	ТоварыНаСкладахОстатки.Помещение,
			|	ТаблицаИзменений.Серия
			|
			|ИМЕЮЩИЕ
			|	СУММА(ТоварыНаСкладахОстатки.ВНаличииОстаток - ТоварыНаСкладахОстатки.КОтгрузкеОстаток) < 0";
		
		ТекстыЗапроса.Добавить(ТекстЗапроса, "ОшибкиТоварыНаСкладах");
		
	КонецЕсли;
	
	#КонецОбласти
	
	#Область ТоварыКОтгрузке
	
	Если ПроведениеДокументов.ЕстьЗаписиВТаблице(Документ, "ДвиженияТоварыКОтгрузкеИзменение") Тогда
		
		ДопустимоеОтклонениеОтгрузкиПриемкиМерныхТоваров =
			Константы.ДопустимоеОтклонениеОтгрузкиПриемкиМерныхТоваров.Получить();
		
		ТекстЗапроса =
			"ВЫБРАТЬ
			|	ТаблицаОстатков.ДокументОтгрузки КАК ДокументОтгрузки,
			|	ТаблицаОстатков.Номенклатура КАК Номенклатура,
			|	ТаблицаОстатков.Номенклатура.ЕдиницаИзмерения КАК ЕдиницаИзмерения,
			|	ТаблицаОстатков.Характеристика КАК Характеристика,
			|	ТаблицаОстатков.Назначение КАК Назначение,
			|	ТаблицаОстатков.КонтролируемаяПартия КАК КонтролируемаяПартия,
			|	ТаблицаОстатков.Серия КАК Серия,
			|	ТаблицаОстатков.Получатель КАК Получатель,
			|	ТаблицаОстатков.Склад КАК Склад,
			|	ТаблицаОстатков.КОтгрузкеОстаток - ТаблицаОстатков.СобираетсяОстаток - ТаблицаОстатков.СобраноОстаток КАК Количество
			|ИЗ
			|	РегистрНакопления.ТоварыКОтгрузке.Остатки(,
			|			(ДокументОтгрузки, Номенклатура, Характеристика, Назначение, КонтролируемаяПартия, Серия, Получатель, Склад) В
			|				(ВЫБРАТЬ
			|					Таблица.ДокументОтгрузки,
			|					Таблица.Номенклатура,
			|					Таблица.Характеристика,
			|					Таблица.Назначение,
			|					Таблица.КонтролируемаяПартия,
			|					Таблица.Серия,
			|					Таблица.Получатель,
			|					Таблица.Склад
			|				ИЗ
			|					ДвиженияТоварыКОтгрузкеИзменение КАК Таблица)) КАК ТаблицаОстатков";
		
		Если ДопустимоеОтклонениеОтгрузкиПриемкиМерныхТоваров <> 0 Тогда
			
			ТекстЗапроса = ТекстЗапроса + "
			|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ТоварыКОтгрузке.Обороты(
			|				,
			|				,
			|				,
			|				(ДокументОтгрузки, Номенклатура, Характеристика, Назначение, КонтролируемаяПартия, Серия, Склад) В
			|					(ВЫБРАТЬ
			|						Таблица.ДокументОтгрузки,
			|						Таблица.Номенклатура,
			|						Таблица.Характеристика,
			|						Таблица.Назначение,
			|						Таблица.КонтролируемаяПартия,
			|						Таблица.Серия,
			|						Таблица.Склад
			|					ИЗ
			|						ДвиженияТоварыКОтгрузкеИзменение КАК Таблица)) КАК ТаблицаОборотов
			|		ПО ТаблицаОстатков.ДокументОтгрузки = ТаблицаОборотов.ДокументОтгрузки
			|			И ТаблицаОстатков.Номенклатура = ТаблицаОборотов.Номенклатура
			|			И ТаблицаОстатков.Характеристика = ТаблицаОборотов.Характеристика
			|			И ТаблицаОстатков.Назначение = ТаблицаОборотов.Назначение
			|			И ТаблицаОстатков.КонтролируемаяПартия = ТаблицаОборотов.КонтролируемаяПартия
			|			И ТаблицаОстатков.Серия = ТаблицаОборотов.Серия
			|			И ТаблицаОстатков.Склад = ТаблицаОборотов.Склад
			|ГДЕ
			|	ТаблицаОстатков.КОтгрузкеОстаток - ТаблицаОстатков.СобираетсяОстаток - ТаблицаОстатков.СобраноОстаток < ВЫБОР
			|			КОГДА ТаблицаОстатков.Номенклатура.ЕдиницаИзмерения.ТипИзмеряемойВеличины В (&МерныеТипыЕдиницИзмерений)
			|				ТОГДА -&ДопустимоеОтклонениеОтгрузкиПриемкиМерныхТоваров / 100 * ТаблицаОборотов.КОтгрузкеПриход
			|			ИНАЧЕ 0
			|		КОНЕЦ";
			
			Запрос.УстановитьПараметр("ДопустимоеОтклонениеОтгрузкиПриемкиМерныхТоваров",
				ДопустимоеОтклонениеОтгрузкиПриемкиМерныхТоваров);
			Запрос.УстановитьПараметр("МерныеТипыЕдиницИзмерений",
				Справочники.УпаковкиЕдиницыИзмерения.МерныеТипыЕдиницИзмерений());
			
		Иначе
			
			ТекстЗапроса = ТекстЗапроса + "
			|ГДЕ
			|	ТаблицаОстатков.КОтгрузкеОстаток - ТаблицаОстатков.СобираетсяОстаток - ТаблицаОстатков.СобраноОстаток < 0";
			
		КонецЕсли;
		
		ТекстыЗапроса.Добавить(ТекстЗапроса, "ОшибкиТоварыКОтгрузке");
		
	КонецЕсли;
	
	Если ПроведениеДокументов.ЕстьЗаписиВТаблице(Документ, "ДвиженияТоварыКОтгрузкеИзменениеСводно") Тогда
		
		ТекстЗапросаОстатки =
		"ВЫБРАТЬ
		|	Т.Номенклатура         КАК Номенклатура,
		|	Т.Характеристика       КАК Характеристика,
		|	Т.Назначение           КАК Назначение,
		|	Т.КонтролируемаяПартия КАК КонтролируемаяПартия,
		|	Т.Склад                КАК Склад,
		|	Т.Серия                КАК Серия,
		|	-Т.ВРезервеОстаток - Т.КОтгрузкеОстаток КАК Количество,
		|	0                КАК ОстатокДоИзменения
		|ИЗ
		|	РегистрНакопления.ТоварыКОтгрузке.Остатки(
		|			,
		|			(Номенклатура, Характеристика, Назначение, КонтролируемаяПартия, Склад, Серия) В
		|				(ВЫБРАТЬ
		|					Т.Номенклатура,
		|					Т.Характеристика,
		|					Т.Назначение,
		|					Т.КонтролируемаяПартия,
		|					Т.Склад,
		|					Т.Серия
		|				ИЗ
		|					ДвиженияТоварыКОтгрузкеИзменениеСводно КАК Т)) КАК Т
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	Т.Номенклатура         КАК Номенклатура,
		|	Т.Характеристика       КАК Характеристика,
		|	Т.Назначение           КАК Назначение,
		|	Т.КонтролируемаяПартия КАК КонтролируемаяПартия,
		|	Т.Склад                КАК Склад,
		|	Т.Серия                КАК Серия,
		|	Т.ВНаличииОстаток      КАК Количество,
		|	Т.ВНаличииОстаток      КАК ОстатокДоИзменения
		|ИЗ
		|	РегистрНакопления.ТоварыНаСкладах.Остатки(
		|			,
		|			(Номенклатура, Характеристика, Назначение, КонтролируемаяПартия, Склад, Серия) В
		|				(ВЫБРАТЬ
		|					Т.Номенклатура,
		|					Т.Характеристика,
		|					Т.Назначение,
		|					Т.КонтролируемаяПартия,
		|					Т.Склад,
		|					Т.Серия
		|				ИЗ
		|					ДвиженияТоварыКОтгрузкеИзменениеСводно КАК Т)) КАК Т";
		
		Если ПроведениеДокументов.ЕстьЗаписиВТаблице(Документ, "ДвиженияТоварыНаСкладахИзменение") Тогда
			
			ТекстЗапросаОстатки = ТекстЗапросаОстатки + ОбщегоНазначения.ТекстОбъединитьВсе() + "
				|ВЫБРАТЬ
				|	Т.Номенклатура         КАК Номенклатура,
				|	Т.Характеристика       КАК Характеристика,
				|	Т.Назначение           КАК Назначение,
				|	Т.КонтролируемаяПартия КАК КонтролируемаяПартия,
				|	Т.Склад                КАК Склад,
				|	Т.Серия                КАК Серия,
				|	0                      КАК Количество,
				|	Т.ВНаличииИзменение    КАК ОстатокДоИзменения
				|ИЗ
				|	ДвиженияТоварыНаСкладахИзмененияСводно КАК Т
				|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ДвиженияТоварыКОтгрузкеИзменениеСводно КАК ДвиженияТоварыКОтгрузке
				|		ПО Т.Номенклатура = ДвиженияТоварыКОтгрузке.Номенклатура
				|			И Т.Характеристика = ДвиженияТоварыКОтгрузке.Характеристика
				|			И Т.Назначение = ДвиженияТоварыКОтгрузке.Назначение
				|			И Т.КонтролируемаяПартия = ДвиженияТоварыКОтгрузке.КонтролируемаяПартия
				|			И Т.Склад = ДвиженияТоварыКОтгрузке.Склад
				|			И Т.Серия = ДвиженияТоварыКОтгрузке.Серия";
			
		КонецЕсли;
		
		ТекстЗапроса =
		"ВЫБРАТЬ
		|	Остатки.Номенклатура                   КАК Номенклатура,
		|	Остатки.Номенклатура.ЕдиницаИзмерения  КАК ЕдиницаИзмерения,
		|	Остатки.Характеристика                 КАК Характеристика,
		|	Остатки.Назначение                     КАК Назначение,
		|	Остатки.КонтролируемаяПартия           КАК КонтролируемаяПартия,
		|	Остатки.Склад                          КАК Склад,
		|	Остатки.Серия                          КАК Серия,
		|	СУММА(Остатки.Количество)              КАК Количество
		|ИЗ
		|	&ТекстЗапросаОстатки КАК Остатки
		|
		|СГРУППИРОВАТЬ ПО
		|	Остатки.Номенклатура,
		|	Остатки.Характеристика,
		|	Остатки.Назначение,
		|	Остатки.КонтролируемаяПартия,
		|	Остатки.Склад,
		|	Остатки.Серия
		|
		|ИМЕЮЩИЕ
		|	СУММА(Остатки.Количество) < 0
		|	И СУММА(Остатки.ОстатокДоИзменения) >= 0";
		
		ТекстЗапросаОстатки = СтрШаблон("(%1)", ТекстЗапросаОстатки);
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&ТекстЗапросаОстатки", ТекстЗапросаОстатки);
		
		ТекстыЗапроса.Добавить(ТекстЗапроса, "ОшибкиТоварыКОтгрузкеСводно");
		
	КонецЕсли;
	
	#КонецОбласти
	
	#Область ТоварыВЯчейках
	
	Если ПроведениеДокументов.ЕстьЗаписиВТаблице(Документ, "ДвиженияТоварыВЯчейкахИзменение") Тогда
		
		ТекстыЗапроса.Добавить(
			"ВЫБРАТЬ РАЗЛИЧНЫЕ
			|	СпрНоменклатура.Ссылка
			|ПОМЕСТИТЬ ВТМногооборотнаяТара
			|ИЗ
			|	Справочник.Номенклатура КАК СпрНоменклатура
			|ГДЕ
			|	СпрНоменклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.МногооборотнаяТара)");
		
		ТекстыЗапроса.Добавить(
			"ВЫБРАТЬ РАЗЛИЧНЫЕ
			|	СкладскиеЯчейки.Ссылка КАК Ссылка
			|ПОМЕСТИТЬ ВТЯчейкиКонтролироватьОбособление
			|ИЗ
			|	Справочник.СкладскиеЯчейки КАК СкладскиеЯчейки
			|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ОбластиХранения КАК ОбластиХранения
			|		ПО СкладскиеЯчейки.ОбластьХранения = ОбластиХранения.Ссылка
			|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ДвиженияТоварыВЯчейкахИзменение КАК ДвиженияТоварыВЯчейкахИзменение
			|		ПО СкладскиеЯчейки.Ссылка = ДвиженияТоварыВЯчейкахИзменение.Ячейка
			|ГДЕ
			|	ОбластиХранения.КонтролироватьОбособление
			|	И ДвиженияТоварыВЯчейкахИзменение.КРазмещениюИзменение < 0
			|
			|ИНДЕКСИРОВАТЬ ПО
			|	Ссылка");
		
		ТекстЗапроса =
			"ВЫБРАТЬ
			|	ТоварыВЯчейкахОстатки.Номенклатура КАК Номенклатура,
			|	ТоварыВЯчейкахОстатки.Характеристика КАК Характеристика,
			|	ТоварыВЯчейкахОстатки.Назначение КАК Назначение,
			|	ВЫБОР
			|		КОГДА ТоварыВЯчейкахОстатки.Упаковка = ЗНАЧЕНИЕ(Справочник.УпаковкиЕдиницыИзмерения.ПустаяСсылка)
			|			ТОГДА
			|				ТоварыВЯчейкахОстатки.Номенклатура.ЕдиницаИзмерения
			|			ИНАЧЕ
			|				ТоварыВЯчейкахОстатки.Упаковка
			|		КОНЕЦ КАК Упаковка,
			|	ТаблицаИзменений.Серия КАК Серия,
			|	ТоварыВЯчейкахОстатки.Ячейка КАК Ячейка,
			|	СУММА(ТоварыВЯчейкахОстатки.ВНаличииОстаток - ТоварыВЯчейкахОстатки.КОтборуОстаток) КАК Количество
			|ИЗ
			|	ДвиженияТоварыВЯчейкахИзменение КАК ТаблицаИзменений
			|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрНакопления.ТоварыВЯчейках.Остатки(
			|				,
			|				(Номенклатура, Характеристика, Назначение, Упаковка, Ячейка) В
			|					(ВЫБРАТЬ
			|						Таблица.Номенклатура,
			|						Таблица.Характеристика,
			|						Таблица.Назначение,
			|						Таблица.Упаковка,
			|						Таблица.Ячейка
			|					ИЗ
			|						ДвиженияТоварыВЯчейкахИзменение КАК Таблица)) КАК ТоварыВЯчейкахОстатки
			|		ПО ТаблицаИзменений.Номенклатура = ТоварыВЯчейкахОстатки.Номенклатура
			|			И ТаблицаИзменений.Характеристика = ТоварыВЯчейкахОстатки.Характеристика
			|			И ТаблицаИзменений.Назначение = ТоварыВЯчейкахОстатки.Назначение
			|			И ТаблицаИзменений.Упаковка = ТоварыВЯчейкахОстатки.Упаковка
			|			И ТаблицаИзменений.Ячейка = ТоварыВЯчейкахОстатки.Ячейка
			|			И (ВЫБОР
