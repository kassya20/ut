	УчитываютсяВДвиженияхУслугиРаботы = Ложь) Экспорт
	
	ПараметрыМетода = ПараметрыМодульногоПроведения();
	ПараметрыМетода.СинонимТаблицыДокумента = СинонимТаблицыДокумента;
	
	ЗапланироватьПоступлениеТоваровВнутренний(Запрос,
		ТекстыЗапроса,
		Регистры,
		ТекстЗапросаДокумента,
		ПараметрыМетода,
		УчитываютсяВДвиженияхУслугиРаботы);
		
