#Область СборкаИДоставка

// Возвращает признак использования на складе доставки своими курьерами.
//
//	Параметры:
//		Склад - СправочникСсылка.Склады - ссылка на элемент справочника "Склады"
//		Дата - Дата - на которую проверяется поддержка доставки своими курьерами
//
//	Возвращаемое значение:
//		Булево - признак поддержки доставки своими курьерами.
//
Функция ЕстьПоддержкаДоставкиСвоимиКурьерами(Склад, Дата = Неопределено) Экспорт
	
	Если Не ПолучитьФункциональнуюОпцию("ИспользоватьУправлениеДоставкой") Тогда
		Возврат Ложь;
	КонецЕсли;
	
	НастройкиСклада = НастройкиСкладаДляСборкиИДоставки(Склад, Дата);
	
	Возврат ?(НастройкиСклада = Неопределено, Ложь, НастройкиСклада.ВМагазинеПоддерживаетсяДоставкаСвоимиКурьерами);
	
КонецФункции

// Возвращает признак использования на складе сборки.
//
//	Параметры:
//		Склад - СправочникСсылка.Склады - ссылка на элемент справочника "Склады"
//		Дата - Дата - на которую проверяется поддержка сборки заказов
//
//	Возвращаемое значение:
//		Булево - признак поддержки сборки заказов.
//
Функция ЕстьПоддержкаСборкиЗаказов(Склад, Дата = Неопределено) Экспорт
	
	НастройкиСклада = НастройкиСкладаДляСборкиИДоставки(Склад, Дата);
	
	Возврат ?(НастройкиСклада = Неопределено, Ложь, НастройкиСклада.ВМагазинеПоддерживаетсяСборкаЗаказов);
	
КонецФункции

// Получает доступные сотруднику для работы склады. 
//
// Параметры:
//  Сотрудник	 - 	СправочникСсылка.ФизическиеЛица - сотрудник для которого необходимо получить склады.
//  ТипСотрудника	 - 	Строка - наименование типа сотрудника из списка (курьер, сборщик, диспетчер).
// 
// Возвращаемое значение:
//  Массив - массив ссылок на склады.
//
Функция ДоступныеСкладыСотрудникаПоТипуСотрудника(Сотрудник, ТипСотрудника) Экспорт
	
	Запрос = Новый Запрос();
	Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
	               |	СотрудникиМагазинов.Склад КАК Склад
	               |ИЗ
	               |	РегистрСведений.СотрудникиМагазинов КАК СотрудникиМагазинов
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Склады КАК Склады
	               |		ПО СотрудникиМагазинов.Склад = Склады.Ссылка
	               |		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ИсторияИзмененияФорматовМагазинов.СрезПоследних(&Дата, ) КАК ИсторияИзменения
	               |		ПО (ИсторияИзменения.Склад = Склады.Ссылка)
	               |ГДЕ
	               |	(Склады.ИспользоватьОрдернуюСхемуПриОтгрузке = ЛОЖЬ
	               |				И ВЫБОР
	               |					КОГДА ЕСТЬNULL(ИсторияИзменения.ФорматМагазина, ЗНАЧЕНИЕ(Справочник.ФорматыМагазинов.ПустаяСсылка)) = ЗНАЧЕНИЕ(Справочник.ФорматыМагазинов.ПустаяСсылка)
	               |						ТОГДА Склады.ВМагазинеПоддерживаетсяДоставкаСвоимиКурьерами
	               |								И Склады.ДатаНачалаДоставкиСвоимиКурьерами <= &Дата
	               |					ИНАЧЕ ИсторияИзменения.ФорматМагазина.ВМагазинеПоддерживаетсяДоставкаСвоимиКурьерами
	               |				КОНЕЦ
	               |				И Склады.ЭтоГруппа = ЛОЖЬ
	               |				И СотрудникиМагазинов.Сотрудник = &Сотрудник
	               |				И (СотрудникиМагазинов.Курьер
	               |					И &ЭтоКурьер)
	               |			ИЛИ СотрудникиМагазинов.Сборщик
	               |				И &ЭтоСборщик
	               |			ИЛИ СотрудникиМагазинов.Диспетчер
	               |				И &ЭтоДиспетчер)";
	
	Запрос.УстановитьПараметр("Дата", ТекущаяДатаСеанса());
	Запрос.УстановитьПараметр("Сотрудник", Сотрудник);
	Запрос.УстановитьПараметр("ЭтоКурьер", НРег(ТипСотрудника) = "курьер");
	Запрос.УстановитьПараметр("ЭтоСборщик", НРег(ТипСотрудника) = "сборщик");
	Запрос.УстановитьПараметр("ЭтоДиспетчер", НРег(ТипСотрудника) = "диспетчер");
	
	Возврат Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Склад");
	
КонецФункции

