//
// Параметры:
//  Запрос - Запрос - Запрос отражения документа.
//  ТекстыЗапроса - СписокЗначений - Список текстов запроса отражения документа.
// 	Регистры - Неопределено, Структура, Строка - Список регистров для отражения.
//  ТекстЗапросаДокумента - Строка - Текст запроса выборки данных документа, содержащий следующие обязательные поля:
//     * Ссылка                - ДокументСсылка - Ссылка на текущий документа
//     * Дата                  - Дата - Дата поступления товара
//     * Склад                 - СправочникСсылка.Склады - 
//     * Номенклатура          - СправочникСсылка.Номенклатура - 
//     * Характеристика        - СправочникСсылка.ХарактеристикиНоменклатуры - 
//     * Назначение            - СправочникСсылка.Назначения - 
//     * КонтролируемаяПартия  - СправочникСсылка.КонтролируемыеПартии - контролируемая партия, по которой оформляется излишек/недостача.
//     * СтатусУказанияСерий   - Число -
//     * Серия                 - СправочникСсылка.СерииНоменклатуры -
//     * Количество            - Число - отрицательное значение является признаком что отражается недостача
//
Процедура ОформитьИзлишкиНедостачиНаСкладе(Запрос, ТекстыЗапроса, Регистры,
		ТекстЗапросаДокумента) Экспорт

	ОформитьИзлишкиНедостачиНаСкладеВнутренний(Запрос, ТекстыЗапроса, Регистры,
		ТекстЗапросаДокумента);
	
КонецПроцедуры

// Выполняет подготовку итоговых запросов отражения документа по складским регистрам:
// - ТоварыНаСкладах
// - ТоварыКОформлениюИзлишковНедостач
//
// Закрывает движения сформированные операцией ЗарегистрироватьИзлишкиНедостачиНаСкладе
//
// Параметры:
//  Запрос - Запрос - Запрос отражения документа.
//  ТекстыЗапроса - СписокЗначений - Список текстов запроса отражения документа.
// 	Регистры - Неопределено, Структура, Строка - Список регистров для отражения.
//  ТекстЗапросаДокумента - Строка - Текст запроса выборки данных документа, содержащий следующие обязательные поля:
//     * Ссылка                - ДокументСсылка - Ссылка на текущий документа
//     * Дата                  - Дата - Дата поступления товара
//     * Склад                 - СправочникСсылка.Склады - 
//     * Номенклатура          - СправочникСсылка.Номенклатура - 
//     * Характеристика        - СправочникСсылка.ХарактеристикиНоменклатуры - 
//     * Назначение            - СправочникСсылка.Назначения - 
//     * СтатусУказанияСерий   - Число -
//     * Серия                 - СправочникСсылка.СерииНоменклатуры -
//     * Количество            - Число - отрицательное значение является признаком что отражается недостача
//     * РазрешеноОтражатьОстатокПоОрдерномуСкладу - Булево - для совместного отбора по хоз.операции и ордерности.
//     * РазрешеноОтражатьОстатокПоНеОрдерномуСкладу - Булево - для совместного отбора по хоз.операции и ордерности.
//
Процедура ОформитьИзлишкиНедостачиНаСкладеСОтборомПоОрдерности(Запрос, ТекстыЗапроса, Регистры,
		ТекстЗапросаДокумента) Экспорт
	
	ОформитьИзлишкиНедостачиНаСкладеВнутренний(Запрос, ТекстыЗапроса, Регистры,
		ТекстЗапросаДокумента, Истина);
	
КонецПроцедуры

// Выполняет подготовку итоговых запросов отражения документа по складским регистрам:
// - ТоварыКОтбору
// - ТоварыВЯчейках
//
// Параметры:
//  Запрос - Запрос - Запрос отражения документа.
//  ТекстыЗапроса - СписокЗначений - Список текстов запроса отражения документа.
// 	Регистры - Неопределено, Структура, Строка - Список регистров для отражения.
//  ТекстЗапросаДокумента - Строка - Текст запроса выборки данных документа, содержащий следующие обязательные поля:
//     * Ссылка                - ДокументСсылка - Ссылка на текущий документа
//     * Дата                  - Дата - Дата поступления товара
//     * Распоряжение          - ДокументСсылка.РасходныйОрдерНаТовары, ДокументСсылка.ОрдерНаПеремещениеТоваров - 
//     * Ячейка                - СправочникСсылка.СкладскиеЯчейки -
//     * Номенклатура          - СправочникСсылка.Номенклатура - 
//     * Характеристика        - СправочникСсылка.ХарактеристикиНоменклатуры - 
//     * Назначение            - СправочникСсылка.Назначения - 
//     * Серия                 - СправочникСсылка.СерииНоменклатуры -
//     * Упаковка              - СправочникСсылка.УпаковкиЕдиницыИзмерения -
//     * Количество            - Число - 
//     * КоличествоУпаковок    - Число - 
//     * СтатусУказанияСерий   - Число -
//     * Отобрано              - Булево - Признак того, что товар отобран из ячейки (иначе - в процессе отбора).
//     * ЭтоОтбор              - Булево - Признак того, что это операция отбора (иначе - это операция размещения).
//     * ЭтоОтражениеЯчеек     - Булево - Признак того, что производятся операции над ячейками (отключение признака
//                                        может быть необходимо для формирования движений только по РН ТоварыКОтбору).
//
Процедура ОтобратьТовары(Запрос, ТекстыЗапроса, Регистры,
		ТекстЗапросаДокумента) Экспорт

	ТекстыШаблоновОтражения = Новый Структура();
	ТекстыЗапросовДанныхДокумента = Новый Структура();
	ТекстыЗапросовВременныхТаблиц = Новый Структура();

	ТекстыЗапросовДанныхДокумента.Вставить("ДанныеДокумента", ТекстЗапросаДокумента);
	ТекстЗапросаВТОтобратьТовары = "
		|ВЫБРАТЬ
		|	ДанныеДокумента.Ссылка              КАК Ссылка,
		|	ДанныеДокумента.Дата                КАК Дата,
		|	ДанныеДокумента.Распоряжение        КАК Распоряжение,
		|	ДанныеДокумента.Ячейка              КАК Ячейка,
		|	ДанныеДокумента.Номенклатура        КАК Номенклатура,
		|	ДанныеДокумента.Характеристика      КАК Характеристика,
		|	ДанныеДокумента.Назначение          КАК Назначение,
		|	ДанныеДокумента.Серия               КАК Серия,
		|	ДанныеДокумента.Упаковка            КАК Упаковка,
		|	ДанныеДокумента.Количество          КАК Количество,
		|	ДанныеДокумента.КоличествоУпаковок  КАК КоличествоУпаковок,
		|	ДанныеДокумента.СтатусУказанияСерий КАК СтатусУказанияСерий,
		|	ДанныеДокумента.Отобрано            КАК Отобрано,
		|	ДанныеДокумента.ЭтоОтбор            КАК ЭтоОтбор,
		|	ДанныеДокумента.ЭтоОтражениеЯчеек   КАК ЭтоОтражениеЯчеек,
		|	ЕСТЬNULL(ДанныеДокумента.Упаковка.ТипУпаковки, НЕОПРЕДЕЛЕНО) = ЗНАЧЕНИЕ(Перечисление.ТипыУпаковокНоменклатуры.ТоварноеМесто) КАК ЭтоТоварноеМесто,
		|	ЕСТЬNULL(ДанныеДокумента.Упаковка.ТипИзмеряемойВеличины, НЕОПРЕДЕЛЕНО) = ЗНАЧЕНИЕ(Перечисление.ТипыИзмеряемыхВеличин.Упаковка) КАК ЭтоУпаковка
		|ПОМЕСТИТЬ ВТОтобратьТовары
		|ИЗ
		|	#ДанныеДокумента КАК ДанныеДокумента
		|";

	ТекстыЗапросовВременныхТаблиц.Вставить("ВТОтобратьТовары", ТекстЗапросаВТОтобратьТовары);

	ШаблонТекстаЗапросаТоварыКОтбору = "ВЫБРАТЬ
		|	ДанныеДокумента.Дата                   КАК Период,
		|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход) КАК ВидДвижения,
		|	ДанныеДокумента.Ссылка                 КАК Регистратор,
		|	ДанныеДокумента.Номенклатура           КАК Номенклатура,
		|	ДанныеДокумента.Характеристика         КАК Характеристика,
		|	ВЫБОР
		|		КОГДА ДанныеДокумента.СтатусУказанияСерий В (6, 8, 10, 14)
		|			ТОГДА ДанныеДокумента.Серия
		|		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.СерииНоменклатуры.ПустаяСсылка)
		|	КОНЕЦ                                  КАК Серия,
		|	ДанныеДокумента.Распоряжение           КАК Распоряжение,
		|	ВЫБОР
		|		КОГДА ДанныеДокумента.ЭтоТоварноеМесто
		|			ТОГДА ДанныеДокумента.КоличествоУпаковок
		|		ИНАЧЕ ДанныеДокумента.Количество
		|	КОНЕЦ                                  КАК Отбирается,
		|	0                                      КАК Отобрано,
		|	ВЫБОР
		|		КОГДА ЕСТЬNULL(ДанныеДокумента.Назначение.ДвиженияПоСкладскимРегистрам, ЛОЖЬ)
		|			ТОГДА ДанныеДокумента.Назначение
		|		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.Назначения.ПустаяСсылка)
		|	КОНЕЦ                                  КАК Назначение,
		|	ВЫБОР
		|		КОГДА ДанныеДокумента.ЭтоТоварноеМесто
		|			ТОГДА ДанныеДокумента.Упаковка
		|		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.УпаковкиЕдиницыИзмерения.ПустаяСсылка)
		|	КОНЕЦ                                  КАК ТоварноеМесто
		|ИЗ
		|	ВТОтобратьТовары КАК ДанныеДокумента
		|ГДЕ
		|	НЕ ДанныеДокумента.Отобрано
		|	И ДанныеДокумента.ЭтоОтбор
		|	И ДанныеДокумента.Количество > 0
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	ДанныеДокумента.Дата                   КАК Период,
		|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход) КАК ВидДвижения,
		|	ДанныеДокумента.Ссылка                 КАК Регистратор,
		|	ДанныеДокумента.Номенклатура           КАК Номенклатура,
		|	ДанныеДокумента.Характеристика         КАК Характеристика,
		|	ВЫБОР
		|		КОГДА ДанныеДокумента.СтатусУказанияСерий В (6, 8, 10, 14)
		|			ТОГДА ДанныеДокумента.Серия
		|		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.СерииНоменклатуры.ПустаяСсылка)
		|	КОНЕЦ                                  КАК Серия,
		|	ДанныеДокумента.Распоряжение           КАК Распоряжение,
		|	0                                      КАК Отбирается,
		|	ВЫБОР
		|		КОГДА ДанныеДокумента.ЭтоТоварноеМесто
		|			ТОГДА ДанныеДокумента.КоличествоУпаковок
		|		ИНАЧЕ ДанныеДокумента.Количество
		|	КОНЕЦ                                  КАК Отобрано,
		|	ВЫБОР
		|		КОГДА ЕСТЬNULL(ДанныеДокумента.Назначение.ДвиженияПоСкладскимРегистрам, ЛОЖЬ)
		|			ТОГДА ДанныеДокумента.Назначение
		|		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.Назначения.ПустаяСсылка)
		|	КОНЕЦ                                  КАК Назначение,
		|	ВЫБОР
		|		КОГДА ДанныеДокумента.ЭтоТоварноеМесто
		|			ТОГДА ДанныеДокумента.Упаковка
		|		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.УпаковкиЕдиницыИзмерения.ПустаяСсылка)
		|	КОНЕЦ                                  КАК ТоварноеМесто
		|ИЗ
		|	ВТОтобратьТовары КАК ДанныеДокумента
		|ГДЕ
		|	ДанныеДокумента.Отобрано
		|	И ДанныеДокумента.ЭтоОтбор
		|	И ДанныеДокумента.Количество > 0
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	ДанныеДокумента.Дата                   КАК Период,
		|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход) КАК ВидДвижения,
		|	ДанныеДокумента.Ссылка                 КАК Регистратор,
		|	ДанныеДокумента.Номенклатура           КАК Номенклатура,
		|	ДанныеДокумента.Характеристика         КАК Характеристика,
		|	ВЫБОР
		|		КОГДА ДанныеДокумента.СтатусУказанияСерий В (6, 8, 10, 14)
		|			ТОГДА ДанныеДокумента.Серия
		|		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.СерииНоменклатуры.ПустаяСсылка)
		|	КОНЕЦ                                  КАК Серия,
		|	ДанныеДокумента.Распоряжение           КАК Распоряжение,
		|	0                                      КАК Отбирается,
		|	ВЫБОР
		|		КОГДА ДанныеДокумента.ЭтоТоварноеМесто
		|			ТОГДА -ДанныеДокумента.КоличествоУпаковок
		|		ИНАЧЕ -ДанныеДокумента.Количество
		|	КОНЕЦ                                  КАК Отобрано,
		|	ВЫБОР
		|		КОГДА ЕСТЬNULL(ДанныеДокумента.Назначение.ДвиженияПоСкладскимРегистрам, ЛОЖЬ)
		|			ТОГДА ДанныеДокумента.Назначение
		|		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.Назначения.ПустаяСсылка)
		|	КОНЕЦ                                  КАК Назначение,
		|	ВЫБОР
		|		КОГДА ДанныеДокумента.ЭтоТоварноеМесто
		|			ТОГДА ДанныеДокумента.Упаковка
		|		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.УпаковкиЕдиницыИзмерения.ПустаяСсылка)
		|	КОНЕЦ                                  КАК ТоварноеМесто
		|ИЗ
		|	ВТОтобратьТовары КАК ДанныеДокумента
		|ГДЕ
		|	ДанныеДокумента.Отобрано
		|	И ДанныеДокумента.ЭтоОтбор
		|	И ДанныеДокумента.Количество < 0
		|";

	ШаблонТекстаЗапросаТоварыВЯчейках = "ВЫБРАТЬ
	|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход) КАК ВидДвижения,
	|	ДанныеДокумента.Ссылка КАК Регистратор,
	|	ДанныеДокумента.Дата КАК Период,
	|	ДанныеДокумента.Ячейка КАК Ячейка,
	|	ДанныеДокумента.Номенклатура КАК Номенклатура,
	|	ДанныеДокумента.Характеристика КАК Характеристика,
	|	ВЫБОР
	|		КОГДА ДанныеДокумента.ЭтоУпаковка
	|			ТОГДА ДанныеДокумента.Упаковка
	|		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.УпаковкиЕдиницыИзмерения.ПустаяСсылка)
	|	КОНЕЦ КАК Упаковка,
	|	ВЫБОР
	|		КОГДА ДанныеДокумента.ЭтоУпаковка
	|			ТОГДА -ДанныеДокумента.КоличествоУпаковок
	|		ИНАЧЕ -ДанныеДокумента.Количество
	|	КОНЕЦ КАК ВНаличии,
	|	0 КАК КОтбору,
	|	ВЫБОР
	|		КОГДА ДанныеДокумента.СтатусУказанияСерий В (4, 6, 8, 10, 14)
	|			ТОГДА ДанныеДокумента.Серия
	|		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.СерииНоменклатуры.ПустаяСсылка)
	|	КОНЕЦ КАК Серия,
	|	ВЫБОР
	|		КОГДА ЕСТЬNULL(ТаблицаНазначений.ДвиженияПоСкладскимРегистрам, ЛОЖЬ)
	|			ТОГДА ДанныеДокумента.Назначение
	|		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.Назначения.ПустаяСсылка)
	|	КОНЕЦ КАК Назначение
	|ИЗ
	|	ВТОтобратьТовары КАК ДанныеДокумента
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Назначения КАК ТаблицаНазначений
	|		ПО ДанныеДокумента.Назначение = ТаблицаНазначений.Ссылка
	|ГДЕ
	|	ДанныеДокумента.Отобрано
	|	И ДанныеДокумента.Количество < 0
	|	И ДанныеДокумента.ЭтоОтражениеЯчеек
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход) КАК ВидДвижения,
	|	ДанныеДокумента.Ссылка КАК Регистратор,
	|	ДанныеДокумента.Дата КАК Период,
	|	ДанныеДокумента.Ссылка.ЗонаОтгрузки КАК Ячейка,
	|	ДанныеДокумента.Номенклатура КАК Номенклатура,
	|	ДанныеДокумента.Характеристика КАК Характеристика,
	|	ВЫБОР
	|		КОГДА ДанныеДокумента.ЭтоУпаковка
	|			ТОГДА ДанныеДокумента.Упаковка
	|		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.УпаковкиЕдиницыИзмерения.ПустаяСсылка)
	|	КОНЕЦ КАК Упаковка,
	|	ВЫБОР
	|		КОГДА ДанныеДокумента.ЭтоУпаковка
	|			ТОГДА ДанныеДокумента.КоличествоУпаковок
	|		ИНАЧЕ ДанныеДокумента.Количество
	|	КОНЕЦ КАК ВНаличии,
	|	0 КАК КОтбору,
	|	ВЫБОР
