Процедура ВычестьТаблицуИзДерева(Дерево, ВычитаемыеТаблицы, НачинатьОтгрузкуПослеФормированияЗаданияНаПеревозку)
	
	РеквизитыОтбора						= "Склад, Получатель, ДокументОтгрузки, Номенклатура, Характеристика,
											|Назначение, КонтролируемаяПартия, Серия";
	РеквизитыОтбораПоПериоду			= РеквизитыОтбора + ", ПериодОтгрузки";
	РеквизитыОтбораСЗаданием			= РеквизитыОтбора + ", ЗаданиеНаПеревозку";
	РеквизитыОтбораПоПериодуСЗаданием	= РеквизитыОтбораПоПериоду + ", ЗаданиеНаПеревозку";
	
	Отбор					= Новый Структура(РеквизитыОтбора);
	ОтборПоПериоду			= Новый Структура(РеквизитыОтбораПоПериоду);
	ОтборСЗаданием			= Новый Структура(РеквизитыОтбораСЗаданием);
	ОтборПоПериодуСЗаданием	= Новый Структура(РеквизитыОтбораПоПериодуСЗаданием);
	
	Для Каждого УровеньЗаданиеНаПеревозку Из Дерево.Строки Цикл
		Для Каждого УровеньДокументОтгрузки Из УровеньЗаданиеНаПеревозку.Строки Цикл
			Для Каждого УровеньНоменклатура Из УровеньДокументОтгрузки.Строки Цикл
				Для Каждого УровеньХарактеристика Из УровеньНоменклатура.Строки  Цикл
					Для Каждого УровеньНазначение Из УровеньХарактеристика.Строки Цикл
						Для Каждого УровеньКонтролируемаяПартия Из УровеньНазначение.Строки Цикл
							Для Каждого УровеньСерия Из УровеньКонтролируемаяПартия.Строки Цикл
								
								ТаблицаТовары = УровеньСерия.Строки;
								
								Если Не НачинатьОтгрузкуПослеФормированияЗаданияНаПеревозку
									Или (ДоставкаТоваровКлиентСервер.ИспользуетсяДоставка20()
										И Не ЗначениеЗаполнено(УровеньЗаданиеНаПеревозку.ЗаданиеНаПеревозку)) Тогда
									
									ОсновнойОтбор		= ОтборПоПериоду;
									ДополнительныйОтбор	= Отбор;
									
								Иначе
									ОсновнойОтбор		= ОтборПоПериодуСЗаданием;
									ДополнительныйОтбор	= ОтборСЗаданием;
								КонецЕсли;
								
								ЗаполнитьЗначенияСвойств(ДополнительныйОтбор, ТаблицаТовары[0]);
								
								Для Каждого ТаблицаВычитания Из ВычитаемыеТаблицы Цикл
									РаспределитьТоварыПоПериоду(ТаблицаТовары, ТаблицаВычитания, ОсновнойОтбор);
									
									КоличетсвоСтрок = ТаблицаТовары.Количество();
									
									Если КоличетсвоСтрок = 0 Тогда
										Прервать;
									ИначеЕсли КоличетсвоСтрок = 1 Тогда
										РаспределитьТоварыСверхуВниз(ТаблицаТовары, ТаблицаВычитания, ДополнительныйОтбор);
									Иначе
										РаспределитьТоварыСнизуВверх(ТаблицаТовары, ТаблицаВычитания, ДополнительныйОтбор);
									КонецЕсли;
								КонецЦикла
								
							КонецЦикла;
						КонецЦикла;
					КонецЦикла;
				КонецЦикла;
			КонецЦикла;
		КонецЦикла;
	КонецЦикла;
	
КонецПроцедуры

Процедура РаспределитьТоварыПоПериоду(ТаблицаТовары, ВычитаемаяТаблица, СтруктураПоиска)
	
	СтрокиТаблицыКУдалению				= Новый Массив;
	СтрокиВычитаемойТаблицыКУдалению	= Новый Массив;
	
	Для Каждого СтрокаТовары Из ТаблицаТовары Цикл
		СтрокиВычитаемойТаблицыКУдалению.Очистить();
		
		Если СтрокаТовары.Количество > 0 Тогда
			ЗаполнитьЗначенияСвойств(СтруктураПоиска, СтрокаТовары);
			СтруктураПоиска.ПериодОтгрузки = СтрокаТовары.Период;
			
			МассивСтрок = ВычитаемаяТаблица.НайтиСтроки(СтруктураПоиска);
			
			Для Каждого ВычитаемаяСтрока Из МассивСтрок Цикл 
				ВычестьСтроки(СтрокаТовары, ВычитаемаяСтрока, СтрокиВычитаемойТаблицыКУдалению);
			КонецЦикла;
		КонецЕсли;
		
		Если СтрокаТовары.Количество = 0 Тогда
			СтрокиТаблицыКУдалению.Добавить(СтрокаТовары);
		КонецЕсли;
		
		УдалениеПустыхСтрокИзТаблицы(ВычитаемаяТаблица, СтрокиВычитаемойТаблицыКУдалению);
	КонецЦикла;
	
	УдалениеПустыхСтрокИзТаблицы(ТаблицаТовары, СтрокиТаблицыКУдалению);
	
КонецПроцедуры

Процедура РаспределитьТоварыСверхуВниз(ТаблицаТовары, ВычитаемаяТаблица, СтруктураПоиска)
	
	ИндексТаблицы	= ТаблицаТовары.Количество() - 1;
	МассивСтрок		= ВычитаемаяТаблица.НайтиСтроки(СтруктураПоиска);
	
	СтрокиТаблицыКУдалению				= Новый Массив;
	СтрокиВычитаемойТаблицыКУдалению	= Новый Массив;
	
	Пока ИндексТаблицы >= 0 Цикл
		СтрокиВычитаемойТаблицыКУдалению.Очистить();
		
		Индекс			= МассивСтрок.ВГраница();
		СтрокаТовара	= ТаблицаТовары[ИндексТаблицы];
		
		Пока Индекс >= 0
			И СтрокаТовара.Количество > 0 Цикл
			
			ВычестьСтроки(СтрокаТовара, МассивСтрок[Индекс], СтрокиВычитаемойТаблицыКУдалению);
			
			Индекс = Индекс - 1;
			
		КонецЦикла;
		
		Если СтрокаТовара.Количество = 0 Тогда
			СтрокиТаблицыКУдалению.Добавить(СтрокаТовара);
		КонецЕсли;
		
		// Удаление распределенных строк.
		Для Каждого СтрокаКУдалению Из СтрокиВычитаемойТаблицыКУдалению Цикл
			МассивСтрок.Удалить(МассивСтрок.Найти(СтрокаКУдалению));
			ВычитаемаяТаблица.Удалить(СтрокаКУдалению);
		КонецЦикла;
		
		ИндексТаблицы = ИндексТаблицы - 1;
	КонецЦикла;
	
	УдалениеПустыхСтрокИзТаблицы(ТаблицаТовары, СтрокиТаблицыКУдалению);
	
КонецПроцедуры

Процедура РаспределитьТоварыСнизуВверх(ТаблицаТовары, ВычитаемаяТаблица, СтруктураПоиска)
	
	ИндексТаблицы	= 0;
	МассивСтрок		= ВычитаемаяТаблица.НайтиСтроки(СтруктураПоиска);
	
	СтрокиТаблицыКУдалению				= Новый Массив;
	СтрокиВычитаемойТаблицыКУдалению	= Новый Массив;
	
	КоличествоСтрокТаблицы = ТаблицаТовары.Количество();
	
	Пока ИндексТаблицы < КоличествоСтрокТаблицы Цикл 
		СтрокиВычитаемойТаблицыКУдалению.Очистить();
		
		Индекс			= 0;
		СтрокаТовара	= ТаблицаТовары[ИндексТаблицы];
		КоличествоСтрок	= МассивСтрок.Количество();
		
		Пока Индекс < КоличествоСтрок
			И СтрокаТовара.Количество > 0  Цикл
			
			ВычестьСтроки(СтрокаТовара, МассивСтрок[Индекс], СтрокиВычитаемойТаблицыКУдалению);
			
			Индекс = Индекс + 1;
			
		КонецЦикла;
		
		Если СтрокаТовара.Количество = 0 Тогда
			СтрокиТаблицыКУдалению.Добавить(СтрокаТовара);
		КонецЕсли;
		
		// Удаление распределенных строк.
		Для Каждого СтрокаКУдалению Из СтрокиВычитаемойТаблицыКУдалению Цикл
			МассивСтрок.Удалить(МассивСтрок.Найти(СтрокаКУдалению));
			ВычитаемаяТаблица.Удалить(СтрокаКУдалению);
		КонецЦикла;
		
		ИндексТаблицы = ИндексТаблицы + 1;
	КонецЦикла;
	
	УдалениеПустыхСтрокИзТаблицы(ТаблицаТовары, СтрокиТаблицыКУдалению);
	
КонецПроцедуры

Процедура ВычестьСтроки(СтрокаТовара, ВычитаемаяСтрока, СтрокиВычитаемойТаблицыКУдалению)
	
	КоличествоРаспределяемое = Мин(СтрокаТовара.Количество, ВычитаемаяСтрока.Количество);
	
	СтрокаТовара.Количество		= СтрокаТовара.Количество - КоличествоРаспределяемое;
	ВычитаемаяСтрока.Количество	= ВычитаемаяСтрока.Количество - КоличествоРаспределяемое;
	
	// Эти строки распределены - позже их удалим.
	Если ВычитаемаяСтрока.Количество = 0 Тогда
		СтрокиВычитаемойТаблицыКУдалению.Добавить(ВычитаемаяСтрока);
	КонецЕсли;
	
КонецПроцедуры

Процедура УдалениеПустыхСтрокИзТаблицы(Таблица, УдаляемыеСтроки)
	
	Для Каждого СтрокаКУдалению Из УдаляемыеСтроки Цикл
		Таблица.Удалить(СтрокаКУдалению);
	КонецЦикла;
	
КонецПроцедуры

Функция ПолучитьОбъектОрдер(ПараметрыПоискаРасходногоОрдера)
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ДанныеДокумента.Ссылка			КАК Ссылка,
	|	ДанныеДокумента.ВерсияДанных	КАК ВерсияДанных
	|ИЗ
	|	Документ.РасходныйОрдерНаТовары.ТоварыПоРаспоряжениям КАК РаспоряженияТоваров
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.РасходныйОрдерНаТовары КАК ДанныеДокумента
	|		ПО РаспоряженияТоваров.Ссылка = ДанныеДокумента.Ссылка
	|
	|ГДЕ
	|	ДанныеДокумента.Проведен
	|	И ДанныеДокумента.Склад = &Склад
	|	И ДанныеДокумента.Помещение = &Помещение
	|	И ДанныеДокумента.ДатаОтгрузки = &ДатаОтгрузки
	|	И ДанныеДокумента.СкладскаяОперация = &СкладскаяОперация
	|	И ДанныеДокумента.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыРасходныхОрдеров.Подготовлен)
	|	И (ДанныеДокумента.Получатель = &Получатель
	|		ИЛИ (ДанныеДокумента.Получатель В (&ПустойПолучатель)
	|			И РаспоряженияТоваров.Распоряжение = &Получатель))
	|	И (&ПоВсемЗонамОтгрузки
	|		ИЛИ ДанныеДокумента.ЗонаОтгрузки = &ЗонаОтгрузки)
	|	И (&ПоВсемРаспоряжениям
	|			ИЛИ РаспоряженияТоваров.Распоряжение В (&РаспоряженияНаОтгрузку))
	|	И (НЕ &ОтгрузкаПоЗаданиюНаПеревозку
	|		ИЛИ ДанныеДокумента.ЗаданиеНаПеревозку В (&ЗаданиеНаПеревозку))
	|	И (РаспоряженияТоваров.Распоряжение В (&РаспоряжениеГруппировка)
	|		ИЛИ &БезГруппировкиПоРаспоряжениям
	|			И ВЫБОР
	|				КОГДА РаспоряженияТоваров.Распоряжение ССЫЛКА Документ.ЗаказКлиента
	|						ИЛИ РаспоряженияТоваров.Распоряжение ССЫЛКА Документ.ПередачаТоваровХранителю
	|						ИЛИ РаспоряженияТоваров.Распоряжение ССЫЛКА Документ.ОтгрузкаТоваровКлиенту
	|						ИЛИ РаспоряженияТоваров.Распоряжение ССЫЛКА Документ.РеализацияТоваровУслуг
	|					ТОГДА НЕ ЕСТЬNULL(РаспоряженияТоваров.Распоряжение.Соглашение.РазбиватьРасходныеОрдераПоРаспоряжениям, ЛОЖЬ)
	|				ИНАЧЕ ИСТИНА
	|			КОНЕЦ)";
	
	Для Каждого КлючИЗначение Из ПараметрыПоискаРасходногоОрдера Цикл
		Запрос.УстановитьПараметр(КлючИЗначение.Ключ, КлючИЗначение.Значение);
	КонецЦикла;
	
	Если ПараметрыПоискаРасходногоОрдера.ОтгрузкаПоЗаданиюНаПеревозку
		И ТипЗнч(ПараметрыПоискаРасходногоОрдера.ЗаданиеНаПеревозку) = Тип("ДокументСсылка.Рейс") Тогда
		
		ДатаОтгрузки = ПараметрыПоискаРасходногоОрдера.ДатаОтгрузки;
		
	Иначе
		
		ДатаОтгрузки = Макс(ПараметрыПоискаРасходногоОрдера.ДатаОтгрузки, ПараметрыПоискаРасходногоОрдера.ТекущаяДата);
		
	КонецЕсли;
	
	ЗаданиеНаПеревозку = ?(ЗначениеЗаполнено(ПараметрыПоискаРасходногоОрдера.ЗаданиеНаПеревозку),
							ПараметрыПоискаРасходногоОрдера.ЗаданиеНаПеревозку,
							ПустоеЗаданиеНаПеревозку());
	
	Запрос.УстановитьПараметр("ДатаОтгрузки", ДатаОтгрузки);
	Запрос.УстановитьПараметр("ЗаданиеНаПеревозку", ЗаданиеНаПеревозку);
	Запрос.УстановитьПараметр("ПустойПолучатель", ПустойПолучательОтправитель());
	Запрос.УстановитьПараметр("ПоВсемРаспоряжениям",
		ПараметрыПоискаРасходногоОрдера.РаспоряженияНаОтгрузку.Количество() = 0);
	Запрос.УстановитьПараметр("БезГруппировкиПоРаспоряжениям",
		Не ЗначениеЗаполнено(ПараметрыПоискаРасходногоОрдера.РаспоряжениеГруппировка));
	Запрос.УстановитьПараметр("ПоВсемЗонамОтгрузки", Не ЗначениеЗаполнено(ПараметрыПоискаРасходногоОрдера.ЗонаОтгрузки));
	
	Если Не ДоставкаТоваровКлиентСервер.ИспользуетсяДоставка()
		Или ДоставкаТоваровКлиентСервер.ИспользуетсяДоставка20() Тогда
		
		Запрос.УстановитьПараметр("ОтгрузкаПоЗаданиюНаПеревозку", ПараметрыПоискаРасходногоОрдера.ОтгрузкаПоЗаданиюНаПеревозку);
		
	Иначе
		// В доставке 2.5 может быть одно распоряжение и по доставке и самовывозом.
		// Поэтому условие в запросе должно всегда накладываться на параметр ЗаданиеНаПеревозку
		Запрос.УстановитьПараметр("ОтгрузкаПоЗаданиюНаПеревозку", Истина);
	КонецЕсли;
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда
		ДокументОбъект = Выборка.Ссылка.ПолучитьОбъект();
		ДокументОбъект.Заблокировать();
	Иначе
		ДокументОбъект = Документы.РасходныйОрдерНаТовары.СоздатьДокумент();
		ЗаполнитьРасходныйОрдерНаТовары(ПараметрыПоискаРасходногоОрдера, ДокументОбъект);
	КонецЕсли;
	
	Возврат ДокументОбъект;
	
КонецФункции

Функция ЗаполнитьРасходныйОрдерНаТовары(ПараметрыЗаполненияРасходногоОрдера, ДокументОбъект)
	
	ДокументОбъект.ТоварыПоРаспоряжениям.Очистить();
	ДокументОбъект.ОтгружаемыеТовары.Очистить();
	
	ЗаполнитьЗначенияСвойств(ДокументОбъект, ПараметрыЗаполненияРасходногоОрдера);
	
	ДокументОбъект.Дата = ПараметрыЗаполненияРасходногоОрдера.ТекущаяДата;

	Если ПараметрыЗаполненияРасходногоОрдера.ОтгрузкаПоЗаданиюНаПеревозку
		И ТипЗнч(ПараметрыЗаполненияРасходногоОрдера.ЗаданиеНаПеревозку) = Тип("ДокументСсылка.Рейс") Тогда
		
		ДокументОбъект.ДатаОтгрузки = ПараметрыЗаполненияРасходногоОрдера.ДатаОтгрузки;
		
	Иначе
		
		ДокументОбъект.ДатаОтгрузки = Макс(ПараметрыЗаполненияРасходногоОрдера.ТекущаяДата,
											ПараметрыЗаполненияРасходногоОрдера.ДатаОтгрузки);
		
	КонецЕсли;
	
	Если Метаданные.ОпределяемыеТипы.ОтправительПолучательТоваров.Тип.СодержитТип(ТипЗнч(ПараметрыЗаполненияРасходногоОрдера.Получатель)) Тогда
		ДокументОбъект.Получатель = ПараметрыЗаполненияРасходногоОрдера.Получатель;
	Иначе
		ДокументОбъект.Получатель = Справочники.СтруктураПредприятия.ПустаяСсылка();
	КонецЕсли;
	
	Если ДоставкаТоваровКлиентСервер.ИспользуетсяДоставка20()
		И ПараметрыЗаполненияРасходногоОрдера.ОтгрузкаПоЗаданиюНаПеревозку Тогда
		
		ДокументОбъект.ПорядокДоставки = ДоставкаТоваров.ПорядокДоставкиВЗаданииНаПеревозку(
											ДокументОбъект.ЗаданиеНаПеревозку,
											ПараметрыЗаполненияРасходногоОрдера.Получатель);
		
	КонецЕсли;
	
	Возврат ДокументОбъект;
	
КонецФункции

// Параметры:
//	ДокументОбъект - ДокументОбъект.РасходныйОрдерНаТовары
//	ФоновоеЗадание - Булево
//
// Возвращаемое значение:
//	Булево - 
//
Функция ЗаписатьОбъектОрдер(ДокументОбъект, ФоновоеЗадание)
	
	ЕстьОшибка = Ложь;
	
	ДокументОбъект.ТоварыПоРаспоряжениям.Свернуть("Распоряжение, Номенклатура, Характеристика, Назначение, Серия", "Количество");
	ДокументОбъект.Заполнить(Неопределено);
	
	Попытка
		ДокументОбъект.Записать(РежимЗаписиДокумента.Проведение);
	Исключение
		
		Если ФоновоеЗадание Тогда
			ТекстСообщения = НСтр("ru = 'Не удалось записать расходный ордер %1 фоновым заданием по причине: %2'");
			ТекстСообщения = СтрШаблон(ТекстСообщения,
										Строка(ДокументОбъект.Ссылка),
										ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
			
			ЗаписьЖурналаРегистрации(
				НСтр("ru = 'Оформление расходных ордеров'"),
				УровеньЖурналаРегистрации.Предупреждение,
				Метаданные.Документы.РасходныйОрдерНаТовары,
				ДокументОбъект.Ссылка,
				ТекстСообщения);
		Иначе
			ОбщегоНазначения.СообщитьПользователю(ОбработкаОшибок.КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));
		КонецЕсли;
			
		ЕстьОшибка = Истина;
		
	КонецПопытки;
	
	Возврат Не ЕстьОшибка;
	
КонецФункции

Функция ПустоеЗаданиеНаПеревозку()
	
	ПустыеЗначения = Новый Массив;
	ПустыеЗначения.Добавить(Неопределено);
	
	Если Не ДоставкаТоваровКлиентСервер.ИспользуетсяДоставка()
		Или ДоставкаТоваровКлиентСервер.ИспользуетсяДоставка20() Тогда
		
		ПустыеЗначения.Добавить(Документы.ЗаданиеНаПеревозку.ПустаяСсылка());
		
	Иначе
		ПустыеЗначения.Добавить(Документы.Рейс.ПустаяСсылка());
	КонецЕсли;
	
	Возврат ПустыеЗначения;
	
КонецФункции

#КонецОбласти

Процедура СоздатьЗаданияНаОтборПоРаспоряжениям(СтруктураПараметров, СтруктураДанных)
	
	Склад = СтруктураПараметров.Склад;
	Помещение = СтруктураПараметров.Помещение;
	РабочийУчасток = СтруктураПараметров.РабочийУчасток;
	НастройкаФормированияПоРабочимУчасткам = СтруктураПараметров.НастройкаФормированияПоРабочимУчасткам;
	ОграничениеПоВесу = СтруктураПараметров.ОграничениеПоВесу;
	ОграничениеПоОбъему = СтруктураПараметров.ОграничениеПоОбъему;
	ОграничиватьПоОбъему = СтруктураПараметров.ОграничиватьПоОбъему;
	ОграничиватьПоВесу = СтруктураПараметров.ОграничиватьПоВесу;
	
	Если СтруктураПараметров.Свойство("Исполнитель") Тогда
		Исполнитель = СтруктураПараметров.Исполнитель;
	Иначе 
		Исполнитель = Справочники.Пользователи.ПустаяСсылка();
	КонецЕсли;
	
	РаспоряженияЗадания = Новый Соответствие;
	
	Если СтруктураДанных.ТаблицаРезультатов.Количество() > 0 Тогда
		
		Если НастройкаФормированияПоРабочимУчасткам = "СРазбиениемПоРабочимУчасткам" Тогда
			
			ЗапросУчастки = Новый Запрос;
			ЗапросУчастки.Текст = "ВЫБРАТЬ
			|	РабочиеУчастки.Ссылка КАК РабочийУчасток,
			|	РабочиеУчастки.ОграничиватьПоВесу КАК ОграничиватьПоВесу,
			|	РабочиеУчастки.ОграничениеПоВесу КАК ОграничениеПоВесу,
			|	РабочиеУчастки.ОграничиватьПоОбъему КАК ОграничиватьПоОбъему,
			|	РабочиеУчастки.ОграничениеПоОбъему КАК ОграничениеПоОбъему
			|ИЗ
			|	Справочник.РабочиеУчастки КАК РабочиеУчастки
			|ГДЕ
			|	РабочиеУчастки.Владелец = &Склад
			|	И РабочиеУчастки.Помещение = &Помещение";
			
			ЗапросУчастки.УстановитьПараметр("Склад",Склад);
			ЗапросУчастки.УстановитьПараметр("Помещение",Помещение);
			
			ТаблицаРабочихУчастков = ЗапросУчастки.Выполнить().Выгрузить();
			
			НоваяСтрока = ТаблицаРабочихУчастков.Добавить();
			НоваяСтрока.РабочийУчасток = Справочники.РабочиеУчастки.ПустаяСсылка();
			НоваяСтрока.ОграничиватьПоОбъему = Ложь;
			НоваяСтрока.ОграничиватьПоВесу = Ложь;
			
		Иначе	
			ТаблицаРабочихУчастков = Новый ТаблицаЗначений;
			ТаблицаРабочихУчастков.Колонки.Добавить("РабочийУчасток", Новый ОписаниеТипов("СправочникСсылка.РабочиеУчастки"));
			НоваяСтрока = ТаблицаРабочихУчастков.Добавить();
			Если НастройкаФормированияПоРабочимУчасткам = "БезРазбиенияПоРабочимУчасткам" Тогда
				НоваяСтрока.РабочийУчасток = Справочники.РабочиеУчастки.ПустаяСсылка();
			Иначе
				НоваяСтрока.РабочийУчасток = РабочийУчасток;
			КонецЕсли;
			
		КонецЕсли;
		
		НевозможныйНабор = 9999999999;
		
		Для Каждого СтрокаРабочийУчасток Из ТаблицаРабочихУчастков Цикл
			
			Если НастройкаФормированияПоРабочимУчасткам = "СРазбиениемПоРабочимУчасткам" Тогда						
				МаксимальныйОбъем = ?(СтрокаРабочийУчасток.ОграничиватьПоОбъему, СтрокаРабочийУчасток.ОграничениеПоОбъему, НевозможныйНабор);
				МаксимальныйВес = ?(СтрокаРабочийУчасток.ОграничиватьПоВесу, СтрокаРабочийУчасток.ОграничениеПоВесу, НевозможныйНабор);						
			Иначе
				МаксимальныйОбъем = ?(ОграничиватьПоОбъему, ОграничениеПоОбъему, НевозможныйНабор);
				МаксимальныйВес = ?(ОграничиватьПоВесу, ОграничениеПоВесу, НевозможныйНабор);						
			КонецЕсли;
			
			Если НастройкаФормированияПоРабочимУчасткам <> "БезРазбиенияПоРабочимУчасткам" Тогда			
				ТаблицаРезультата = СтруктураДанных.ТаблицаРезультатов.НайтиСтроки(Новый Структура("РабочийУчасток",СтрокаРабочийУчасток.РабочийУчасток));			
			Иначе			
				ТаблицаРезультата = СтруктураДанных.ТаблицаРезультатов;
			КонецЕсли;			
			
			// Разбиение по весу и объему. Соглашения:
			//  - если вес (объем) одной строки больше, чем ограничения - создается отдельный документ,
			//		вес (объем) которого будет больше, чем максимальный
			//	- разбиение по весу (объему) не оптимально, т.к. более приоритетно сохранение порядка обхода
			//			(лучше пусть будет больше заданий, но каждое можно быстрее обойти).
			
			ТекущееРаспоряжение 	  = Неопределено;
			ФормироватьПоРаспоряжению = Истина;
			ПропуститьТару = 0;
			КлючСвязиСТаройПоследний = 0;
			
			// Идем сначала результату, т.к. в нем строки упорядочены по обходу
			Для Каждого СтрТабл Из ТаблицаРезультата Цикл
				
				Если ТекущееРаспоряжение <> СтрТабл.Распоряжение Тогда
					
					ТекущееРаспоряжение = СтрТабл.Распоряжение;
					ФормироватьПоРаспоряжению = Истина;
					
					Если Не ЗначениеЗаполнено(ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ТекущееРаспоряжение, "ЗонаОтгрузки")) Тогда
						
						ФормироватьПоРаспоряжению = Ложь;
						
						ТекстСообщения = НСтр("ru = 'В распоряжении %Распоряжении% не указана зона отгрузки.
						|Необходимо указать зону отгрузки при настройке формирования заданий на отбор товаров.'");
						
						ТекстСообщения = СтрЗаменить(ТекстСообщения,"%Распоряжении%",ТекущееРаспоряжение);
						
						ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
						
					КонецЕсли;
					
					Если ФормироватьПоРаспоряжению Тогда
						
						СтруктураДокумента = РаспоряженияЗадания[ТекущееРаспоряжение];
						
						Если СтруктураДокумента = Неопределено Тогда
							
							СтруктураДокумента = Новый Структура;
							СтруктураДокумента.Вставить("ДокументОбъект", НовыйОбъектЗадание(ТекущееРаспоряжение,СтрокаРабочийУчасток.РабочийУчасток, Склад, Помещение, Исполнитель));
							СтруктураДокумента.Вставить("Объем", 0);
							СтруктураДокумента.Вставить("Вес", 0);
							
							РаспоряженияЗадания.Вставить(ТекущееРаспоряжение,СтруктураДокумента);
							
						ИначеЕсли НастройкаФормированияПоРабочимУчасткам = "СРазбиениемПоРабочимУчасткам" Тогда
							
							СтруктураДокумента.Объем    = 0;
							СтруктураДокумента.Вес	  = 0;
							СтруктураДокумента.ДокументОбъект = НовыйОбъектЗадание(ТекущееРаспоряжение,СтрокаРабочийУчасток.РабочийУчасток, Склад, Помещение, Исполнитель);
							
						КонецЕсли;
						
					КонецЕсли;
				КонецЕсли;
				
				Если Не ФормироватьПоРаспоряжению Тогда
					Продолжить;
				КонецЕсли;
				
				Если ПропуститьТару = СтрТабл.КлючСвязиСТарой Тогда
					Продолжить;
				КонецЕсли;
				
				ПропуститьТару = 0;
				
				Если (СтрТабл.ОбъемУпаковки*СтрТабл.КоличествоУпаковок > МаксимальныйОбъем
					Или  СтрТабл.ВесУпаковки*СтрТабл.КоличествоУпаковок > МаксимальныйВес) Тогда
					
					ДокументОбъект = НовыйОбъектЗадание(СтрТабл.Распоряжение,СтрокаРабочийУчасток.РабочийУчасток, Склад, Помещение, Исполнитель);
					
					Для Каждого СтрокиТаблицы Из ТаблицаРезультата Цикл
						
						Если СтрокиТаблицы.КлючСвязиСТарой = СтрТабл.КлючСвязиСТарой Тогда
							НоваяСтрока = ДокументОбъект.ТоварыОтбор.Добавить();
							ЗаполнитьЗначенияСвойств(НоваяСтрока,СтрТабл);
						КонецЕсли;
						
					КонецЦикла;
					
					ПропуститьТару = СтрТабл.КлючСвязиСТарой;
					
					ЗаписатьОбъектЗадание(ДокументОбъект);
					
				Иначе
					
					Если КлючСвязиСТаройПоследний <> СтрТабл.КлючСвязиСТарой 
						И (РаспоряженияЗадания[СтрТабл.Распоряжение].Объем + СтрТабл.ОбъемУпаковки*СтрТабл.КоличествоУпаковок) > МаксимальныйОбъем
						Или (РаспоряженияЗадания[СтрТабл.Распоряжение].Вес + СтрТабл.ВесУпаковки*СтрТабл.КоличествоУпаковок) > МаксимальныйВес Тогда
						
						ЗаписатьОбъектЗадание(РаспоряженияЗадания[СтрТабл.Распоряжение].ДокументОбъект);
						//
						РаспоряженияЗадания[СтрТабл.Распоряжение].Объем    = 0;
						РаспоряженияЗадания[СтрТабл.Распоряжение].Вес	  = 0;
						РаспоряженияЗадания[СтрТабл.Распоряжение].ДокументОбъект = НовыйОбъектЗадание(СтрТабл.Распоряжение,СтрокаРабочийУчасток.РабочийУчасток, Склад, Помещение, Исполнитель);
						
					КонецЕсли;
					
					ДокументОбъектТоварыОтбор = РаспоряженияЗадания[СтрТабл.Распоряжение].ДокументОбъект.ТоварыОтбор; // ДокументТабличнаяЧасть.ОтборРазмещениеТоваров.ТоварыОтбор
					НоваяСтрока = ДокументОбъектТоварыОтбор.Добавить();
					ЗаполнитьЗначенияСвойств(НоваяСтрока,СтрТабл);
					
					РаспоряженияЗадания[СтрТабл.Распоряжение].Объем = РаспоряженияЗадания[СтрТабл.Распоряжение].Объем
																	+ СтрТабл.ОбъемУпаковки*СтрТабл.КоличествоУпаковок;
					РаспоряженияЗадания[СтрТабл.Распоряжение].Вес	= РаспоряженияЗадания[СтрТабл.Распоряжение].Вес 
																	+ СтрТабл.ВесУпаковки*СтрТабл.КоличествоУпаковок;
					
				КонецЕсли;
				
				КлючСвязиСТарой = СтрТабл.КлючСвязиСТарой;
				
			КонецЦикла;
			
			Для Каждого СтрДок Из РаспоряженияЗадания Цикл
				
				Если СтрДок.Значение.ДокументОбъект.ТоварыОтбор.Количество() > 0 Тогда
					
					ЗаписатьОбъектЗадание(СтрДок.Значение.ДокументОбъект)
					
				КонецЕсли;
				
			КонецЦикла;
		КонецЦикла;		
	Иначе
		ТекстСообщения = НСтр("ru = 'Не удалось сформировать задания на отбор товаров согласно правилам отбора.'");
		
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
	КонецЕсли;
КонецПроцедуры

Процедура ЗаписатьОбъектЗадание(ДокументОбъект)
	Попытка
		
		Если ДокументОбъект.ПроверитьЗаполнение() Тогда
			ПараметрыУказанияСерий = НоменклатураСервер.ПараметрыУказанияСерий(ДокументОбъект, Документы.ОтборРазмещениеТоваров);
			НоменклатураСервер.ЗаполнитьСтатусыУказанияСерий(ДокументОбъект, ПараметрыУказанияСерий.Отбор);
			Если ДокументОбъект.ВидОперации = Перечисления.ВидыОперацийОтбораРазмещенияТоваров.Перемещение Тогда
				НоменклатураСервер.ЗаполнитьСтатусыУказанияСерий(ДокументОбъект, ПараметрыУказанияСерий.Размещение);
			КонецЕсли;
			ДокументОбъект.Записать(РежимЗаписиДокумента.Проведение);
			
		КонецЕсли;
	Исключение
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));
	КонецПопытки;
КонецПроцедуры

Функция НовыйОбъектЗадание(Распоряжение,РабочийУчасток, Склад, Помещение, Исполнитель)
	
	ДокументОбъект = Документы.ОтборРазмещениеТоваров.СоздатьДокумент();
	ДокументОбъект.Дата 				= ТекущаяДатаСеанса();
	ДокументОбъект.Статус 				= Перечисления.СтатусыОтборовРазмещенийТоваров.Подготовлено;
	ДокументОбъект.Склад 				= Склад;
	ДокументОбъект.Помещение 			= Помещение;
	
	Если Распоряжение = Неопределено Тогда
		ДокументОбъект.ВидОперации 			= Перечисления.ВидыОперацийОтбораРазмещенияТоваров.Перемещение;
	Иначе 
		ДокументОбъект.ВидОперации 			= Перечисления.ВидыОперацийОтбораРазмещенияТоваров.Отбор;
		ДокументОбъект.ЗонаОтгрузки		 	= ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Распоряжение, "ЗонаОтгрузки");
		ДокументОбъект.Распоряжение			= Распоряжение;
	КонецЕсли;
	
	ДокументОбъект.Ответственный 	= Пользователи.ТекущийПользователь();
	Если ЗначениеЗаполнено(Исполнитель) Тогда
		ДокументОбъект.Исполнитель 	= Исполнитель;
	КонецЕсли;
	
	ДокументОбъект.РабочийУчасток 	= РабочийУчасток;
		
	Возврат ДокументОбъект;
	
КонецФункции

// Выполняет запуск фонового формирования очереди регистра сведений и переоформление расходных ордеров при изменении
// настройки системы порядка формирования расходных ордеров.
//
Процедура ЗапускФормированияОчередиИПереоформленияРасходныхОрдеров() Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	Если ОбщегоНазначения.ИнформационнаяБазаФайловая() Тогда
		ВыполнитьФоновоеФормированиеОчередиИПереоформленияРасходныхОрдеров();
	Иначе
		Ключ = "ФормированиеОчередиПереоформленияРасходныхОрдеров";
		
		Отбор = Новый Структура;
		Отбор.Вставить("Ключ", Ключ);
		Отбор.Вставить("Состояние", СостояниеФоновогоЗадания.Активно);
		
		АктивныеЗадания = ФоновыеЗадания.ПолучитьФоновыеЗадания(Отбор);
		
		Если АктивныеЗадания.Количество() > 0 Тогда
			Возврат;
		КонецЕсли;
		
		ИмяЭкспортнойПроцедуры = "СкладыСервер.ВыполнитьФоновоеФормированиеОчередиИПереоформленияРасходныхОрдеров";
		ПараметрыЭкспортнойПроцедуры = Новый Массив;
		
		ПараметрыЗадания = Новый Массив;
		ПараметрыЗадания.Добавить(ИмяЭкспортнойПроцедуры);
		ПараметрыЗадания.Добавить(ПараметрыЭкспортнойПроцедуры);
		
		НаименованиеЗадания = НСтр("ru = 'Формирование очереди переоформления расходных ордеров.'");
		
		ФоновыеЗадания.Выполнить("ОбщегоНазначения.ВыполнитьМетодКонфигурации",
								ПараметрыЗадания,
								Ключ,
								НаименованиеЗадания);
	КонецЕсли;
	
КонецПроцедуры

// Выполняет формирование очереди регистра сведений и переоформление расходных ордеров при изменении
// настройки системы порядка формирования расходных ордеров в фоновом режиме.
//
Процедура ВыполнитьФоновоеФормированиеОчередиИПереоформленияРасходныхОрдеров() Экспорт
	
	ДобавляемыеЗаписи = Неопределено;
	
	ПараметрыТекстаЗапроса = ПараметрыТекстаЗапросаФормированияОчереди();
	ПараметрыТекстаЗапроса.ОтгрузитьПослеЗаданияНаПеревозку = Истина;
	ПараметрыТекстаЗапроса.ДопустимоеОтклонениеОтгрузкиПриемкиМерныхТоваров =
		Константы.ДопустимоеОтклонениеОтгрузкиПриемкиМерныхТоваров.Получить();
	
	МерныеТипыЕдиницИзмерений	= Справочники.УпаковкиЕдиницыИзмерения.МерныеТипыЕдиницИзмерений();
	ПорядокОформленияДокументов	= Константы.ПорядокОформленияНакладныхРасходныхОрдеров.Получить();
	ОформлятьСначалаНакладные	= 
		ПорядокОформленияДокументов = Перечисления.ПорядокОформленияНакладныхРасходныхОрдеров.СначалаНакладные;
	
	НачатьТранзакцию();
	
	Попытка
		Блокировка = Новый БлокировкаДанных;
		
		ЭлементБлокировки = Блокировка.Добавить("РегистрСведений.ОчередьПереоформленияРасходныхОрдеров");
		
		ЭлементБлокировки = Блокировка.Добавить("РегистрНакопления.ТоварыКОтгрузке");
		ЭлементБлокировки.Режим = РежимБлокировкиДанных.Разделяемый;
		
		ЭлементБлокировки = Блокировка.Добавить("РегистрНакопления.ТоварыНаСкладах");
		ЭлементБлокировки.Режим = РежимБлокировкиДанных.Разделяемый;
		
		ЭлементБлокировки = Блокировка.Добавить("РегистрСведений.ТоварыКДоставке");
		ЭлементБлокировки.Режим = РежимБлокировкиДанных.Разделяемый;
		
		ЭлементБлокировки = Блокировка.Добавить("РегистрСведений.СостоянияИРеквизитыДоставки");
		ЭлементБлокировки.Режим = РежимБлокировкиДанных.Разделяемый;
		
		ЭлементБлокировки = Блокировка.Добавить("Документ.ЗаданиеНаПеревозку");
		ЭлементБлокировки.Режим = РежимБлокировкиДанных.Разделяемый;
		
		Блокировка.Заблокировать();
		
		МенеджерВТ = Новый МенеджерВременныхТаблиц;
		
		ДополнительныеПараметры = ОбновлениеИнформационнойБазы.ДополнительныеПараметрыВыборкиДанныхДляОбработки();
		ДополнительныеПараметры.ИмяВременнойТаблицы = "ВТЗаблокированоТоварыКОтгрузке";
		
		ОбновлениеИнформационнойБазы.СоздатьВременнуюТаблицуЗначенийЗаблокированныхИзмерений(
			Неопределено, "РегистрНакопления.ТоварыКОтгрузке", "ДокументОтгрузки", МенеджерВТ, ДополнительныеПараметры);
		
		ДополнительныеПараметры.ИмяВременнойТаблицы = "ВТЗаблокированоТоварыНаСкладах";
		
		ОбновлениеИнформационнойБазы.СоздатьВременнуюТаблицуЗначенийЗаблокированныхИзмерений(
			Неопределено, "РегистрНакопления.ТоварыНаСкладах", "Склад", МенеджерВТ, ДополнительныеПараметры);
		
		ДополнительныеПараметры.ИмяВременнойТаблицы = "ВТЗаблокированоЗаданиеНаПеревозку";
		
		ОбновлениеИнформационнойБазы.СоздатьВременнуюТаблицуЗаблокированныхДляЧтенияИИзмененияДанных(
			Неопределено, "Документ.ЗаданиеНаПеревозку", МенеджерВТ, ДополнительныеПараметры);
		
		Запрос = Новый Запрос;
		Запрос.МенеджерВременныхТаблиц = МенеджерВТ;
		Запрос.Текст = ТекстЗапросаФормированияОчереди(ПараметрыТекстаЗапроса);
		
		Запрос.УстановитьПараметр("ОформлятьСначалаНакладные", ОформлятьСначалаНакладные);
		Запрос.УстановитьПараметр("МерныеТипыЕдиницИзмерений", МерныеТипыЕдиницИзмерений);
		Запрос.УстановитьПараметр("ДопустимоеОтклонениеОтгрузкиПриемкиМерныхТоваров",
			ПараметрыТекстаЗапроса.ДопустимоеОтклонениеОтгрузкиПриемкиМерныхТоваров);
		Запрос.УстановитьПараметр("ИспользоватьЗаданияНаПеревозкуДляУчетаДоставкиПеревозчиками",
			ПолучитьФункциональнуюОпцию("ИспользоватьЗаданияНаПеревозкуДляУчетаДоставкиПеревозчиками"));
		
		ДобавляемыеЗаписи = Запрос.Выполнить().Выгрузить();
		
		Если ДобавляемыеЗаписи.Количество() > 0 Тогда
			НаборЗаписей = РегистрыСведений.ОчередьПереоформленияРасходныхОрдеров.СоздатьНаборЗаписей();
			НаборЗаписей.Загрузить(ДобавляемыеЗаписи);
			НаборЗаписей.Записать(РежимЗамещения.Добавление);
		КонецЕсли;
		
		ЗафиксироватьТранзакцию();
	Исключение
		ОтменитьТранзакцию();
		
		ИмяСобытия = НСтр("ru = 'Обновление очереди переоформления расходных ордеров'",
						ОбщегоНазначения.КодОсновногоЯзыка());
		
		ТекстСообщения = НСтр("ru = 'Не удалось обновить очередь переоформления расходных ордеров по причине: %1'");
		ТекстСообщения = СтрШаблон(ТекстСообщения, ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
		
		ЗаписьЖурналаРегистрации(ИмяСобытия, УровеньЖурналаРегистрации.Ошибка, , , ТекстСообщения);
		
		ВызватьИсключение;
	КонецПопытки;
	
	Если ДобавляемыеЗаписи <> Неопределено Тогда
		ОтборЗадания = Новый Структура("Склад, Получатель");
		
		Для Каждого ЗаписьОчереди Из ДобавляемыеЗаписи Цикл
			ЗаполнитьЗначенияСвойств(ОтборЗадания, ЗаписьОчереди);
			
			СтруктураПараметров = Новый Структура("СтруктураПараметров", ОтборЗадания);
			
			ВыполнитьФоновоеПереоформлениеРасходныхОрдеров(СтруктураПараметров);
		КонецЦикла;
	КонецЕсли;
	
КонецПроцедуры

// Выполняет запуск фонового переоформления расходных ордеров при отражении документов в учете.
//
// Параметры:
//	СтруктураПараметров - Структура - коллекция, содержащая следующие свойства:
//		* Склад - СправочникСсылка.Склады - склад, для которого выполняется задание.
//		* Получатель - СправочникСсылка.СтруктураПредприятия, СправочникСсылка.Партнеры, СправочникСсылка.Склады - получатель товаров.
//
Процедура ЗапускВыполненияФоновогоПереоформленияРасходныхОрдеров(СтруктураПараметров) Экспорт
	
	Если ОбщегоНазначения.ИнформационнаяБазаФайловая() Тогда
		ВыполнитьФоновоеПереоформлениеРасходныхОрдеров(Новый Структура("СтруктураПараметров", СтруктураПараметров));
	Иначе
		ЗапускВыполненияФоновогоПереоформленияРасходныхОрдеровФрагмент(СтруктураПараметров);
	КонецЕсли;
	
КонецПроцедуры

// Выполняет запуск фонового переоформления расходных ордеров при отражении документов в учете.
//
// Параметры:
//	СтруктураПараметров - Структура - коллекция, содержащая следующие свойства:
//		* Склад - СправочникСсылка.Склады - склад, для которого выполняется задание.
//		* Получатель - СправочникСсылка.СтруктураПредприятия, СправочникСсылка.Партнеры, СправочникСсылка.Склады - получатель товаров.
//
Процедура ЗапускВыполненияФоновогоПереоформленияРасходныхОрдеровФрагмент(СтруктураПараметров)
	
	Ключ = "ПереоформлениеРасходныхОрдеров"
			+ Строка(СтруктураПараметров.Склад.УникальныйИдентификатор())
			+ Строка(СтруктураПараметров.Получатель.УникальныйИдентификатор());
	
	Отбор = Новый Структура;
	Отбор.Вставить("Ключ", Ключ);
	Отбор.Вставить("Состояние", СостояниеФоновогоЗадания.Активно);
	
	АктивныеЗадания = ФоновыеЗадания.ПолучитьФоновыеЗадания(Отбор);
	
	Если АктивныеЗадания.Количество() > 0 Тогда
		Возврат;
	КонецЕсли;
	
	ИмяЭкспортнойПроцедуры = "СкладыСервер.ВыполнитьФоновоеПереоформлениеРасходныхОрдеров";
	
	ПараметрыЭкспортнойПроцедуры = Новый Массив;
	ПараметрыЭкспортнойПроцедуры.Добавить(Новый Структура("СтруктураПараметров", СтруктураПараметров));
	
	ПараметрыЗадания = Новый Массив;
	ПараметрыЗадания.Добавить(ИмяЭкспортнойПроцедуры);
	ПараметрыЗадания.Добавить(ПараметрыЭкспортнойПроцедуры);
	
	НаименованиеЗадания = НСтр("ru = 'Переоформление расходных ордеров по Складу - %1; Получателю - %2'");
	НаименованиеЗадания = СтрШаблон(НаименованиеЗадания,
									Строка(СтруктураПараметров.Склад),
									Строка(СтруктураПараметров.Получатель));
	
	ФоновыеЗадания.Выполнить("ОбщегоНазначения.ВыполнитьМетодКонфигурации", ПараметрыЗадания, Ключ, НаименованиеЗадания);
	
КонецПроцедуры

// Подписка на событие, выполняющая запуск фонового переоформления расходных ордеров.
//
// Параметры:
//	Источник - ДокументОбъект - документ, инициализировавший событие.
//	Отказ - Булево - признак отказа от записи.
//	РежимПроведения - РежимПроведенияДокумента - режим проведения документа.
//
Процедура ПриОтменеПроведенияДокументовОтгрузкиОбработкаПроведения(Источник, Отказ, РежимПроведения) Экспорт
	
	ПриИзмененииСостоянияПроведенияДокументовОтгрузки(Источник);
	
КонецПроцедуры

// Подписка на событие, выполняющая запуск фонового переоформления расходных ордеров.
//
// Параметры:
//	Источник - ДокументОбъект - документ, инициализировавший событие.
//	Отказ - Булево - признак отказа от записи.
//	РежимПроведения - РежимПроведенияДокумента - режим проведения документа.
//
Процедура ПриПроведенииДокументовОтгрузкиОбработкаПроведения(Источник, Отказ, РежимПроведения) Экспорт
	
	ПриИзмененииСостоянияПроведенияДокументовОтгрузки(Источник);
	
КонецПроцедуры

Процедура ПриИзмененииСостоянияПроведенияДокументовОтгрузки(Источник)
	
	РежимФормированияРасходныхОрдеровАвтоматически = Константы.РежимФормированияРасходныхОрдеров.Получить()
		= Перечисления.РежимыФормированияРасходныхОрдеров.Автоматически;
	
	Если Не РежимФормированияРасходныхОрдеровАвтоматически Тогда
		Возврат;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ОчередьПереоформленияРасходныхОрдеров.Склад КАК Склад,
	|	ОчередьПереоформленияРасходныхОрдеров.Получатель КАК Получатель
	|ИЗ
	|	РегистрСведений.ОчередьПереоформленияРасходныхОрдеров КАК ОчередьПереоформленияРасходныхОрдеров";
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	СтруктураПараметров = Новый Структура("Склад, Получатель");
	
	Пока Выборка.Следующий() Цикл
		ЗаполнитьЗначенияСвойств(СтруктураПараметров, Выборка);
		ЗапускВыполненияФоновогоПереоформленияРасходныхОрдеровФрагмент(СтруктураПараметров);
	КонецЦикла;
	
КонецПроцедуры

// Выполняет переоформление расходных ордеров.
//
// Параметры:
//	ПараметрыЗадания - Структура - коллекция, содержащая следующие параметры выпонения задания:
//		* СтруктураПараметров - Структура - коллекция, содержащая следующие свойства:
//			** Склад - СправочникСсылка.Склады - склад, для которого выполняется задание.
//			** Получатель - СправочникСсылка.СтруктураПредприятия, СправочникСсылка.Партнеры, СправочникСсылка.Склады - получатель товаров.
//
Процедура ВыполнитьФоновоеПереоформлениеРасходныхОрдеров(ПараметрыЗадания) Экспорт
	
	Склад		= ПараметрыЗадания.СтруктураПараметров.Склад;
	Получатель	= ПараметрыЗадания.СтруктураПараметров.Получатель;
	
	Если ПараметрыЗадания.Свойство("КоличествоОшибок") Тогда
		Если ПараметрыЗадания.КоличествоОшибок >= 3 Тогда
			ТекстСообщения = НСтр("ru = 'Фоновое переоформление расходных ордеров остановлено по Складу - %1; Получателю - %2. Для дополнительной информации перейдите в рабочее место отгрузки. Количество неудачных попыток: %3.'");
			ТекстСообщения = СтрШаблон(ТекстСообщения,
										Строка(Склад),
										Строка(Получатель),
										ПараметрыЗадания.КоличествоОшибок);
			
			ЗаписьЖурналаРегистрации(НСтр("ru = 'Фоновое переоформление расходных ордеров'"),
									УровеньЖурналаРегистрации.Ошибка,
									,
									,
									ТекстСообщения);
			Возврат;
		КонецЕсли;
	Иначе
		ПараметрыЗадания.Вставить("КоличествоОшибок", 0);
	КонецЕсли;
	
	УстановитьПривилегированныйРежим(Истина);
	
	ПараметрыСозданияРасходныхОрдеров = ПараметрыПереоформленияРасходныхОрдеров();
	ПараметрыСозданияРасходныхОрдеров.Склад = Склад;
	ПараметрыСозданияРасходныхОрдеров.Получатель = Получатель;
	ПараметрыСозданияРасходныхОрдеров.ФоновоеЗадание = Истина;
	
	ЕстьОшибка = ПереоформитьРасходныеОрдера(ПараметрыСозданияРасходныхОрдеров).ЕстьОшибка;
	
	Если ЕстьОшибка Тогда
		ПараметрыЗадания.КоличествоОшибок = ПараметрыЗадания.КоличествоОшибок + 1;
		
		ТекстСообщения = НСтр("ru = 'Есть ошибки при переоформлении расходных ордеров. Склад: %1; Получатель: %2. Количество попыток: %3.'");
		ТекстСообщения = СтрШаблон(ТекстСообщения,
									Строка(Склад),
									Строка(Получатель),
									ПараметрыЗадания.КоличествоОшибок);
		
		ЗаписьЖурналаРегистрации(НСтр("ru = 'Фоновое переоформление расходных ордеров'"),
								УровеньЖурналаРегистрации.Ошибка,
								,
								,
								ТекстСообщения);
	КонецЕсли;
	
	Если ПроверитьНаличиеЗаписейВОчереди(ПараметрыЗадания) Тогда
		ВыполнитьФоновоеПереоформлениеРасходныхОрдеров(ПараметрыЗадания);
	КонецЕсли;
	
КонецПроцедуры

Функция ПроверитьНаличиеЗаписейВОчереди(ПараметрыЗадания)
	
	ЕстьЗаписиВОчереди = Истина;
	
	Склад		= ПараметрыЗадания.СтруктураПараметров.Склад;
	Получатель	= ПараметрыЗадания.СтруктураПараметров.Получатель;
	
	НетВнешнейТранзакции = Не ТранзакцияАктивна();
	
	Если НетВнешнейТранзакции Тогда
		НачатьТранзакцию();
	КонецЕсли;
	
	Попытка
		Блокировка = Новый БлокировкаДанных;
		
		ЭлементБлокировки = Блокировка.Добавить("РегистрСведений.ОчередьПереоформленияРасходныхОрдеров");
		ЭлементБлокировки.УстановитьЗначение("Склад", Склад);
		ЭлементБлокировки.УстановитьЗначение("Получатель", Получатель);
		
		ЭлементБлокировки = Блокировка.Добавить("РегистрНакопления.ТоварыКОтгрузке");
		ЭлементБлокировки.УстановитьЗначение("Склад", Склад);
		ЭлементБлокировки.УстановитьЗначение("Получатель", Получатель);
		ЭлементБлокировки.Режим = РежимБлокировкиДанных.Разделяемый;
		
		ЭлементБлокировки = Блокировка.Добавить("РегистрНакопления.ТоварыНаСкладах");
		ЭлементБлокировки.УстановитьЗначение("Склад", Склад);
		ЭлементБлокировки.Режим = РежимБлокировкиДанных.Разделяемый;
		
		ЭлементБлокировки = Блокировка.Добавить("РегистрСведений.ТоварыКДоставке");
		ЭлементБлокировки.УстановитьЗначение("Склад", Склад);
		ЭлементБлокировки.Режим = РежимБлокировкиДанных.Разделяемый;
		
		ЭлементБлокировки = Блокировка.Добавить("РегистрСведений.СостоянияИРеквизитыДоставки");
		ЭлементБлокировки.УстановитьЗначение("Склад", Склад);
		ЭлементБлокировки.Режим = РежимБлокировкиДанных.Разделяемый;
		
		ЭлементБлокировки = Блокировка.Добавить("Документ.ЗаданиеНаПеревозку");
		ЭлементБлокировки.Режим = РежимБлокировкиДанных.Разделяемый;
		
		Блокировка.Заблокировать();
		
		Если Не ТребуетсяПереоформитьРасходныеОрдера(Склад, Получатель) Тогда
			НаборЗаписей = РегистрыСведений.ОчередьПереоформленияРасходныхОрдеров.СоздатьНаборЗаписей();
			НаборЗаписей.Отбор.Склад.Установить(Склад);
			НаборЗаписей.Отбор.Получатель.Установить(Получатель);
			
			НаборЗаписей.Записать();
			
			ЕстьЗаписиВОчереди = Ложь;
		КонецЕсли;
		
		Если НетВнешнейТранзакции Тогда
			ЗафиксироватьТранзакцию();
		КонецЕсли;
	Исключение
		Если НетВнешнейТранзакции Тогда
			ОтменитьТранзакцию();
		КонецЕсли;
		
		ЕстьЗаписиВОчереди = Истина;
		ПараметрыЗадания.КоличествоОшибок = ПараметрыЗадания.КоличествоОшибок + 1;
		
		ТекстСообщения = НСтр("ru = 'Не удалось сформировать очередь расходных ордеров по складу %1 и получателю %2 по причине: %3'");
		ТекстСообщения = СтрШаблон(ТекстСообщения,
									Строка(Склад),
									Строка(Получатель),
									ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
		
		ЗаписьЖурналаРегистрации(ОбновлениеИнформационнойБазы.СобытиеЖурналаРегистрации(),
								УровеньЖурналаРегистрации.Ошибка,
								,
								,
								ТекстСообщения);
		
		Если Не НетВнешнейТранзакции Тогда
			ВызватьИсключение;
		КонецЕсли;
	КонецПопытки;
	
	Возврат ЕстьЗаписиВОчереди;
	
КонецФункции

// Выполняет проверку необходимости переоформления расходных ордеров.
//
// Параметры:
//	Склад - СправочникСсылка.Склады - склад, по которому нужно выполнить проверку.
//	Получатель - СправочникСсылка.СтруктураПредприятия, СправочникСсылка.Партнеры, СправочникСсылка.Склады - получатель товаров.
//
// Возвращаемое значение:
//	Булево - признак необходимости переоформления расходных ордеров.
//
Функция ТребуетсяПереоформитьРасходныеОрдера(Склад, Получатель) Экспорт
	
	ПустойНаборЗаписей	= РегистрыСведений.ОчередьПереоформленияРасходныхОрдеров.СоздатьНаборЗаписей();
	ПолучателиТоваров	= ПустойНаборЗаписей.ВыгрузитьКолонки("Склад, Получатель");
	
	НоваяСтрока = ПолучателиТоваров.Добавить();
	НоваяСтрока.Склад = Склад;
	НоваяСтрока.Получатель = Получатель;
	
	ДанныеДляФормированияОчереди = ДанныеДляФормированияОчередиПереоформленияРасходныхОрдеров(ПолучателиТоваров);
	
	Возврат ДанныеДляФормированияОчереди.Количество() > 0;
	
КонецФункции

// Возвращает таблицу, содержащую данные для формирования очереди переоформления расходных ордеров.
//
// Параметры:
//	ПолучателиТоваров - ТаблицаЗначений - таблица, содержащая сведения о получателях товаров, для которых необходимо
//											проверить возможность отгрузки товаров со склада.
//
// Возвращаемое значение:
//	ТаблицаЗначений:
//		* Склад - СправочникСсылка.Склады - склад, с которого выполняется отгрузка товаров.
//		* Получатель - СправочникСсылка.СтруктураПредприятия, СправочникСсылка.Партнеры, СправочникСсылка.Склады - получатель товаров.
//
Функция ДанныеДляФормированияОчередиПереоформленияРасходныхОрдеров(ПолучателиТоваров) Экспорт
	
	МенеджерВТ = Новый МенеджерВременныхТаблиц;
	
	ДополнительныеПараметры = ОбновлениеИнформационнойБазы.ДополнительныеПараметрыВыборкиДанныхДляОбработки();
	ДополнительныеПараметры.ИмяВременнойТаблицы = "ВТЗаблокированоТоварыКОтгрузке";
	
	ОбновлениеИнформационнойБазы.СоздатьВременнуюТаблицуЗначенийЗаблокированныхИзмерений(
		Неопределено, "РегистрНакопления.ТоварыКОтгрузке", "ДокументОтгрузки", МенеджерВТ, ДополнительныеПараметры);
	
	ДополнительныеПараметры.ИмяВременнойТаблицы = "ВТЗаблокированоТоварыНаСкладах";
	
	ОбновлениеИнформационнойБазы.СоздатьВременнуюТаблицуЗначенийЗаблокированныхИзмерений(
		Неопределено, "РегистрНакопления.ТоварыНаСкладах", "Склад", МенеджерВТ, ДополнительныеПараметры);
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВТ;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ТаблицаПолучателей.Склад		КАК Склад,
	|	ТаблицаПолучателей.Получатель	КАК Получатель
	|ПОМЕСТИТЬ ВТТаблицаПолучателей
	|ИЗ
	|	&ТаблицаПолучателей КАК ТаблицаПолучателей
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТаблицаПолучателей.Склад		КАК Склад,
	|	ТаблицаПолучателей.Получатель	КАК Получатель,
	|	ВЫБОР
	|		КОГДА СправочникСклады.НачинатьОтгрузкуПослеФормированияЗаданияНаПеревозку ЕСТЬ NULL
	|			ТОГДА ЛОЖЬ
	|		ИНАЧЕ СправочникСклады.НачинатьОтгрузкуПослеФормированияЗаданияНаПеревозку
	|	КОНЕЦ							КАК ОтгрузитьПослеЗаданияНаПеревозку
	|ПОМЕСТИТЬ ТаблицаПолучателей
	|ИЗ
	|	ВТТаблицаПолучателей КАК ТаблицаПолучателей
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Склады СправочникСклады
	|		ПО ТаблицаПолучателей.Склад = СправочникСклады.Ссылка
	|
	|ГДЕ
	|	СправочникСклады.ИспользоватьОрдернуюСхемуПриОтгрузке
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Склад,
	|	Получатель";
	
	Запрос.УстановитьПараметр("ТаблицаПолучателей", ПолучателиТоваров);
	
	РезультатЗапроса = Запрос.ВыполнитьПакетСПромежуточнымиДанными();
	РасширеннаяТаблицаПолучателей = РезультатЗапроса[РезультатЗапроса.ВГраница()].Выгрузить();
	
	Если РасширеннаяТаблицаПолучателей.Количество() = 0 Тогда
		ПустойНаборЗаписей		= РегистрыСведений.ОчередьПереоформленияРасходныхОрдеров.СоздатьНаборЗаписей();
		ДанныеДляПереоформления = ПустойНаборЗаписей.ВыгрузитьКолонки("Склад, Получатель");
		
		Возврат ДанныеДляПереоформления;
	Иначе
		РасширеннаяТаблицаПолучателей.Индексы.Добавить("ОтгрузитьПослеЗаданияНаПеревозку");
	КонецЕсли;
	
	ПараметрыТекстаЗапроса = ПараметрыТекстаЗапросаФормированияОчереди();
	ПараметрыТекстаЗапроса.ПереоформлениеОчереди = Ложь;
	ПараметрыТекстаЗапроса.ОтгрузитьПослеЗаданияНаПеревозку =
		РасширеннаяТаблицаПолучателей.Найти(Истина, "ОтгрузитьПослеЗаданияНаПеревозку") <> Неопределено;
	ПараметрыТекстаЗапроса.ОтгрузитьБезЗаданияНаПеревозку =
		РасширеннаяТаблицаПолучателей.Найти(Ложь, "ОтгрузитьПослеЗаданияНаПеревозку") <> Неопределено;
	ПараметрыТекстаЗапроса.ДопустимоеОтклонениеОтгрузкиПриемкиМерныхТоваров =
		Константы.ДопустимоеОтклонениеОтгрузкиПриемкиМерныхТоваров.Получить();
	
	Если ПараметрыТекстаЗапроса.ОтгрузитьПослеЗаданияНаПеревозку Тогда
		
		Если ДоставкаТоваровКлиентСервер.ИспользуетсяДоставка20() Тогда
			
			ДополнительныеПараметры.ИмяВременнойТаблицы = "ВТЗаблокированоЗаданиеНаПеревозку";
			
			ОбновлениеИнформационнойБазы.СоздатьВременнуюТаблицуЗаблокированныхДляЧтенияИИзмененияДанных(
				Неопределено, "Документ.ЗаданиеНаПеревозку", МенеджерВТ, ДополнительныеПараметры);
			
		Иначе
			
			ДополнительныеПараметры.ИмяВременнойТаблицы = "ВТЗаблокированоДоставка";
			ОбновлениеИнформационнойБазы.СоздатьВременнуюТаблицуЗначенийЗаблокированныхИзмерений(
				Неопределено,
				"РегистрНакопления.Доставка",
				"Распоряжение",
				МенеджерВТ,
				ДополнительныеПараметры);
			
		КонецЕсли;
		
	КонецЕсли;
	
	МерныеТипыЕдиницИзмерений	= Справочники.УпаковкиЕдиницыИзмерения.МерныеТипыЕдиницИзмерений();
	ПорядокОформленияДокументов	= Константы.ПорядокОформленияНакладныхРасходныхОрдеров.Получить();
	ОформлятьСначалаНакладные	=
		ПорядокОформленияДокументов = Перечисления.ПорядокОформленияНакладныхРасходныхОрдеров.СначалаНакладные;
	
	Запрос.Текст = ТекстЗапросаДанныеДляФормированияОчереди(ПараметрыТекстаЗапроса);
	
	Запрос.УстановитьПараметр("ОформлятьСначалаНакладные", ОформлятьСначалаНакладные);
	Запрос.УстановитьПараметр("МерныеТипыЕдиницИзмерений", МерныеТипыЕдиницИзмерений);
	Запрос.УстановитьПараметр("ТоварыКОтгрузке",
		РегистрыНакопления.ТоварыКОтгрузке.СоздатьНаборЗаписей().ВыгрузитьКолонки());
	Запрос.УстановитьПараметр("ДопустимоеОтклонениеОтгрузкиПриемкиМерныхТоваров",
		ПараметрыТекстаЗапроса.ДопустимоеОтклонениеОтгрузкиПриемкиМерныхТоваров);
	Запрос.УстановитьПараметр("ИспользоватьЗаданияНаПеревозкуДляУчетаДоставкиПеревозчиками",
		ПолучитьФункциональнуюОпцию("ИспользоватьЗаданияНаПеревозкуДляУчетаДоставкиПеревозчиками"));
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Если РезультатЗапроса.Пустой() Тогда
		ПустойНаборЗаписей		= РегистрыСведений.ОчередьПереоформленияРасходныхОрдеров.СоздатьНаборЗаписей();
		ДанныеДляПереоформления = ПустойНаборЗаписей.ВыгрузитьКолонки("Склад, Получатель");
	Иначе
		ДанныеДляПереоформления = РезультатЗапроса.Выгрузить();
	КонецЕсли;
	
	Возврат ДанныеДляПереоформления;
	
КонецФункции

// Возвращает коллекцию, содержащую сведения о получателях товаров, по которым нет фоновых заданий для переоформления
// расходных ордеров.
// Также выполняется актуализация регистра сведений очереди переоформления расходных ордеров.
//
// Параметры:
//	Склад - СправочникСсылка.Склады - склад, для которого выполняется операция.
//	ОчередьОбновилась - Булево - признак актуализации регистра сведений очереди переоформления расходных ордеров.
//
// Возвращаемое значение:
//	Массив Из СправочникСсылка - коллекция, содержащая сведения о получателях товаров, по которым нет фоновых заданий
//								для переоформления расходных ордеров.
//
Функция ПолучателиПоКоторымНетФоновогоЗаданияПереоформленияОрдеров(Склад, ОчередьОбновилась) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ОчередьПереоформленияРасходныхОрдеров.Получатель
	|ИЗ
	|	РегистрСведений.ОчередьПереоформленияРасходныхОрдеров КАК ОчередьПереоформленияРасходныхОрдеров
	|ГДЕ
	|	ОчередьПереоформленияРасходныхОрдеров.Склад = &Склад
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ИСТИНА КАК ОтгрузитьПослеЗаданияНаПеревозку
	|ИЗ
	|	Справочник.Склады СправочникСклады
	|
	|ГДЕ
	|	СправочникСклады.Ссылка = &Склад
	|	И СправочникСклады.НачинатьОтгрузкуПослеФормированияЗаданияНаПеревозку";
	
	Запрос.УстановитьПараметр("Склад", Склад);
	
	РезультатЗапроса = Запрос.ВыполнитьПакет();
	ПроверяемыеПолучатели = РезультатЗапроса[РезультатЗапроса.ВГраница() - 1].Выгрузить().ВыгрузитьКолонку("Получатель");
	
	ЕстьОшибкиТранзакции = Ложь;
	ПолучателиБезЗаданий = Новый Массив;
	
	ПараметрыТекстаЗапроса = ПараметрыТекстаЗапросаФормированияОчереди();
	ПараметрыТекстаЗапроса.ПереоформлениеОчередиПоСкладу = Истина;
	ПараметрыТекстаЗапроса.ОтгрузитьПослеЗаданияНаПеревозку = Не РезультатЗапроса[РезультатЗапроса.ВГраница()].Пустой();
	ПараметрыТекстаЗапроса.ДопустимоеОтклонениеОтгрузкиПриемкиМерныхТоваров =
		Константы.ДопустимоеОтклонениеОтгрузкиПриемкиМерныхТоваров.Получить();
	
	МерныеТипыЕдиницИзмерений	= Справочники.УпаковкиЕдиницыИзмерения.МерныеТипыЕдиницИзмерений();
	ПорядокОформленияДокументов	= Константы.ПорядокОформленияНакладныхРасходныхОрдеров.Получить();
	ОформлятьСначалаНакладные	= 
		ПорядокОформленияДокументов = Перечисления.ПорядокОформленияНакладныхРасходныхОрдеров.СначалаНакладные;
	
	НачатьТранзакцию();
	
	Попытка
		Блокировка = Новый БлокировкаДанных;
		
		ЭлементБлокировки = Блокировка.Добавить("РегистрСведений.ОчередьПереоформленияРасходныхОрдеров");
		ЭлементБлокировки.УстановитьЗначение("Склад", Склад);
		
		ЭлементБлокировки = Блокировка.Добавить("РегистрНакопления.ТоварыКОтгрузке");
		ЭлементБлокировки.УстановитьЗначение("Склад", Склад);
		ЭлементБлокировки.Режим = РежимБлокировкиДанных.Разделяемый;
		
		ЭлементБлокировки = Блокировка.Добавить("РегистрНакопления.ТоварыНаСкладах");
		ЭлементБлокировки.УстановитьЗначение("Склад", Склад);
		ЭлементБлокировки.Режим = РежимБлокировкиДанных.Разделяемый;
		
		Если ПараметрыТекстаЗапроса.ОтгрузитьПослеЗаданияНаПеревозку Тогда
			ЭлементБлокировки = Блокировка.Добавить("РегистрСведений.ТоварыКДоставке");
			ЭлементБлокировки.УстановитьЗначение("Склад", Склад);
			ЭлементБлокировки.Режим = РежимБлокировкиДанных.Разделяемый;
			
			ЭлементБлокировки = Блокировка.Добавить("РегистрСведений.СостоянияИРеквизитыДоставки");
			ЭлементБлокировки.УстановитьЗначение("Склад", Склад);
			ЭлементБлокировки.Режим = РежимБлокировкиДанных.Разделяемый;
			
			ЭлементБлокировки = Блокировка.Добавить("Документ.ЗаданиеНаПеревозку");
			ЭлементБлокировки.Режим = РежимБлокировкиДанных.Разделяемый;
		КонецЕсли;
		
		Блокировка.Заблокировать();
		
		МенеджерВТ = Новый МенеджерВременныхТаблиц;
		
		ДополнительныеПараметры = ОбновлениеИнформационнойБазы.ДополнительныеПараметрыВыборкиДанныхДляОбработки();
		ДополнительныеПараметры.ИмяВременнойТаблицы = "ВТЗаблокированоТоварыКОтгрузке";
		
		ОбновлениеИнформационнойБазы.СоздатьВременнуюТаблицуЗначенийЗаблокированныхИзмерений(
			Неопределено, "РегистрНакопления.ТоварыКОтгрузке", "ДокументОтгрузки", МенеджерВТ, ДополнительныеПараметры);
		
		ДополнительныеПараметры.ИмяВременнойТаблицы = "ВТЗаблокированоТоварыНаСкладах";
		
		ОбновлениеИнформационнойБазы.СоздатьВременнуюТаблицуЗначенийЗаблокированныхИзмерений(
			Неопределено, "РегистрНакопления.ТоварыНаСкладах", "Склад", МенеджерВТ, ДополнительныеПараметры);
		
		Если ПараметрыТекстаЗапроса.ОтгрузитьПослеЗаданияНаПеревозку Тогда
			
			Если ДоставкаТоваровКлиентСервер.ИспользуетсяДоставка20() Тогда
			
				ДополнительныеПараметры.ИмяВременнойТаблицы = "ВТЗаблокированоЗаданиеНаПеревозку";
				
				ОбновлениеИнформационнойБазы.СоздатьВременнуюТаблицуЗаблокированныхДляЧтенияИИзмененияДанных(
					Неопределено, "Документ.ЗаданиеНаПеревозку", МенеджерВТ, ДополнительныеПараметры);
				
			Иначе
				
				ДополнительныеПараметры.ИмяВременнойТаблицы = "ВТЗаблокированоДоставка";
				ОбновлениеИнформационнойБазы.СоздатьВременнуюТаблицуЗначенийЗаблокированныхИзмерений(
					Неопределено,
					"РегистрНакопления.Доставка",
					"Распоряжение",
					МенеджерВТ,
					ДополнительныеПараметры);
				
			КонецЕсли;
			
		КонецЕсли;
		
		Запрос.МенеджерВременныхТаблиц = МенеджерВТ;
		Запрос.Текст = ТекстЗапросаФормированияОчереди(ПараметрыТекстаЗапроса)
			+ ОбщегоНазначения.РазделительПакетаЗапросов()
			+ ТекстЗапросаУдаляемыхЗаписейОчереди();
		
		Запрос.УстановитьПараметр("ОформлятьСначалаНакладные", ОформлятьСначалаНакладные);
		Запрос.УстановитьПараметр("МерныеТипыЕдиницИзмерений", МерныеТипыЕдиницИзмерений);
		Запрос.УстановитьПараметр("ДопустимоеОтклонениеОтгрузкиПриемкиМерныхТоваров",
			ПараметрыТекстаЗапроса.ДопустимоеОтклонениеОтгрузкиПриемкиМерныхТоваров);
		Запрос.УстановитьПараметр("ИспользоватьЗаданияНаПеревозкуДляУчетаДоставкиПеревозчиками",
			ПолучитьФункциональнуюОпцию("ИспользоватьЗаданияНаПеревозкуДляУчетаДоставкиПеревозчиками"));
		
		РезультатЗапроса	= Запрос.ВыполнитьПакет();
		УдаляемыеЗаписи		= РезультатЗапроса[РезультатЗапроса.ВГраница()].Выгрузить();
		ДобавляемыеЗаписи	= РезультатЗапроса[РезультатЗапроса.ВГраница() - 1].Выгрузить();
		
		Если УдаляемыеЗаписи.Количество() > 0 Тогда
			НаборЗаписей = РегистрыСведений.ОчередьПереоформленияРасходныхОрдеров.СоздатьНаборЗаписей();
			НаборЗаписей.Загрузить(УдаляемыеЗаписи);
			НаборЗаписей.Записать(РежимЗамещения.Удаление);
		КонецЕсли;
		
		Если ДобавляемыеЗаписи.Количество() > 0 Тогда
			НаборЗаписей = РегистрыСведений.ОчередьПереоформленияРасходныхОрдеров.СоздатьНаборЗаписей();
			НаборЗаписей.Загрузить(ДобавляемыеЗаписи);
			НаборЗаписей.Записать(РежимЗамещения.Добавление);
		КонецЕсли;
		
		ЗафиксироватьТранзакцию();
	Исключение
		ОтменитьТранзакцию();
		
		ЕстьОшибкиТранзакции = Истина;
		
		ИмяСобытия = НСтр("ru = 'Обновление очереди переоформления расходных ордеров'",
						ОбщегоНазначения.КодОсновногоЯзыка());
		
		ТекстСообщения = НСтр("ru = 'Не удалось обновить очередь переоформления расходных ордеров по Складу - %1 по причине: %2'");
		ТекстСообщения = СтрШаблон(ТекстСообщения,
									Строка(Склад),
									ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
		
		ЗаписьЖурналаРегистрации(ИмяСобытия, УровеньЖурналаРегистрации.Ошибка, , , ТекстСообщения);
	КонецПопытки;
	
	Если Не ЕстьОшибкиТранзакции Тогда
		ОтборЗаданий = Новый Структура("Ключ, Состояние", "", СостояниеФоновогоЗадания.Активно);
		
		Для Каждого Получатель Из ПроверяемыеПолучатели Цикл
			Если УдаляемыеЗаписи.Найти(Получатель, "Получатель") <> Неопределено Тогда
				Продолжить;
			КонецЕсли;
			
			ОтборЗаданий.Ключ	= "ПереоформлениеРасходныхОрдеров"
									+ Строка(Склад.УникальныйИдентификатор())
									+ Строка(Получатель.УникальныйИдентификатор());
			АктивныеЗадания		= ФоновыеЗадания.ПолучитьФоновыеЗадания(ОтборЗаданий);
			
			Если АктивныеЗадания.Количество() = 0 Тогда
				ПолучателиБезЗаданий.Добавить(Получатель);
			КонецЕсли;
		КонецЦикла;
		
		Если ДобавляемыеЗаписи.Количество() > 0 Тогда
			ОчередьОбновилась = УдаляемыеЗаписи.Количество() = 0;
			
			ОбщегоНазначенияКлиентСервер.ДополнитьМассив(ПолучателиБезЗаданий,
														ДобавляемыеЗаписи.ВыгрузитьКолонку("Получатель"));
		КонецЕсли;
	КонецЕсли;
	
	Возврат ПолучателиБезЗаданий;
	
КонецФункции

Функция ПараметрыТекстаЗапросаФормированияОчереди()
	
	ПараметрыТекстаЗапроса = Новый Структура;
	ПараметрыТекстаЗапроса.Вставить("ПереоформлениеОчереди", Истина);
	ПараметрыТекстаЗапроса.Вставить("ПереоформлениеОчередиПоСкладу", Ложь);
	ПараметрыТекстаЗапроса.Вставить("ОтгрузитьПослеЗаданияНаПеревозку", Ложь);
	ПараметрыТекстаЗапроса.Вставить("ОтгрузитьБезЗаданияНаПеревозку", Ложь);
	ПараметрыТекстаЗапроса.Вставить("ДопустимоеОтклонениеОтгрузкиПриемкиМерныхТоваров", 0);
	
	Возврат ПараметрыТекстаЗапроса;
	
КонецФункции

Функция ТекстЗапросаДанныеДляФормированияОчереди(ПараметрыТекстаЗапроса)
	
	ТекстыЗапросов = Новый Массив;
	
	Если ПараметрыТекстаЗапроса.ДопустимоеОтклонениеОтгрузкиПриемкиМерныхТоваров <> 0 Тогда
		ТекстыЗапросов.Добавить(ТекстЗапросаВТТоварыКОформлениюРасходныхОрдеров());
	КонецЕсли;
	
	ТекстыЗапросов.Добавить(ТекстЗапросаОстаткиТоварыКОтгрузке(ПараметрыТекстаЗапроса));
	ТекстыЗапросов.Добавить(ТекстЗапросаОстаткиТоварыНаСкладах());
	ТекстыЗапросов.Добавить(ТекстЗапросаПотребностьПереоформленияРасходныхОрдеров(Ложь));
	
	ТекстЗапроса = СтрСоединить(ТекстыЗапросов, ОбщегоНазначения.РазделительПакетаЗапросов());
	
	УсловиеОтборПоСкладу =
	"(Склад, Получатель) В
	|					(ВЫБРАТЬ
	|						ТаблицаПолучателей.Склад,
	|						ТаблицаПолучателей.Получатель
	|					ИЗ
	|						ТаблицаПолучателей КАК ТаблицаПолучателей)";
	
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&ОтборПоСкладу1", УсловиеОтборПоСкладу);
	
	УсловиеОтборПоСкладу =
	"(Склад, Получатель) В
	|					(ВЫБРАТЬ
	|						ТаблицаПолучателей.Склад,
	|						ТаблицаПолучателей.Получатель
	|					ИЗ
	|						ТаблицаПолучателей КАК ТаблицаПолучателей
	|					ГДЕ
	|						ТаблицаПолучателей.ОтгрузитьПослеЗаданияНаПеревозку)";
	
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&ОтборПоСкладуПоЗаданию", УсловиеОтборПоСкладу);
	
	Если ДоставкаТоваровКлиентСервер.ИспользуетсяДоставка25() Тогда
		
		УсловиеОтборПоСкладуДляДоставки =
		"(Отправитель) В
		|	(ВЫБРАТЬ
		|		ТаблицаПолучателей.Склад КАК Отправитель
		|	ИЗ
		|		ТаблицаПолучателей КАК ТаблицаПолучателей
		|	ГДЕ
		|		ТаблицаПолучателей.ОтгрузитьПослеЗаданияНаПеревозку)";
		
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&ОтборДоставка25ПоСкладуПоЗаданию", УсловиеОтборПоСкладуДляДоставки);
		
	КонецЕсли;
	
	УсловиеОтборПоСкладу =
	"(Склад, Получатель) В
	|					(ВЫБРАТЬ
	|						ТаблицаПолучателей.Склад,
	|						ТаблицаПолучателей.Получатель
	|					ИЗ
	|						ТаблицаПолучателей КАК ТаблицаПолучателей
	|					ГДЕ
	|						НЕ ТаблицаПолучателей.ОтгрузитьПослеЗаданияНаПеревозку)";
	
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&ОтборПоСкладуБезЗадания", УсловиеОтборПоСкладу);
	
	Если ПараметрыТекстаЗапроса.ДопустимоеОтклонениеОтгрузкиПриемкиМерныхТоваров <> 0 Тогда
		УсловиеДопустимоеОтклонение = "(Склад, ДокументОтгрузки, Номенклатура, Характеристика, Назначение, КонтролируемаяПартия, Серия) В
		|				(ВЫБРАТЬ
		|					Таблица.Склад,
		|					Таблица.ДокументОтгрузки,
		|					Таблица.Номенклатура,
		|					Таблица.Характеристика,
		|					Таблица.Назначение,
		|					Таблица.КонтролируемаяПартия,
		|					Таблица.Серия
		|				ИЗ
		|					ВТТоварыКОформлениюРасходныхОрдеров КАК Таблица)"
	Иначе
		УсловиеДопустимоеОтклонение = "ИСТИНА";
	КонецЕсли;
	
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&УсловиеДопустимоеОтклонение", УсловиеДопустимоеОтклонение);
	
	Возврат ТекстЗапроса;
	
КонецФункции

Функция ТекстЗапросаФормированияОчереди(ПараметрыТекстаЗапроса)
	
	ТекстыЗапросов = Новый Массив;
	
	Если ПараметрыТекстаЗапроса.ДопустимоеОтклонениеОтгрузкиПриемкиМерныхТоваров <> 0 Тогда
		ТекстыЗапросов.Добавить(ТекстЗапросаВТТоварыКОформлениюРасходныхОрдеров());
	КонецЕсли;
	
	ТекстыЗапросов.Добавить(ТекстЗапросаОстаткиТоварыКОтгрузке(ПараметрыТекстаЗапроса));
	ТекстыЗапросов.Добавить(ТекстЗапросаОстаткиТоварыНаСкладах());
	ТекстыЗапросов.Добавить(ТекстЗапросаПотребностьПереоформленияРасходныхОрдеров());
	ТекстыЗапросов.Добавить(ТекстЗапросаОчередьПереоформленияРасходныхОрдеров());
	
	ТекстЗапроса = СтрСоединить(ТекстыЗапросов, ОбщегоНазначения.РазделительПакетаЗапросов());
	
	Если ПараметрыТекстаЗапроса.ПереоформлениеОчередиПоСкладу Тогда
		
		УсловиеОтборПоСкладу = "Склад = &Склад";
		УсловиеОтборПоСкладуДоставка25 = "Отправитель = &Склад";
		
	Иначе
		
		УсловиеОтборПоСкладу = "ИСТИНА";
		УсловиеОтборПоСкладуДоставка25 = "ИСТИНА";
		
	КонецЕсли;
	
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&ОтборПоСкладу1", УсловиеОтборПоСкладу);
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&ОтборПоСкладуДоставка25", УсловиеОтборПоСкладуДоставка25);
	
	Если ПараметрыТекстаЗапроса.ДопустимоеОтклонениеОтгрузкиПриемкиМерныхТоваров <> 0 Тогда
		УсловиеДопустимоеОтклонение = "(Склад, ДокументОтгрузки, Номенклатура, Характеристика, Назначение, КонтролируемаяПартия, Серия) В
		|				(ВЫБРАТЬ
		|					Таблица.Склад,
		|					Таблица.ДокументОтгрузки,
		|					Таблица.Номенклатура,
		|					Таблица.Характеристика,
		|					Таблица.Назначение,
		|					Таблица.КонтролируемаяПартия,
		|					Таблица.Серия
		|				ИЗ
		|					ВТТоварыКОформлениюРасходныхОрдеров КАК Таблица)"
	Иначе
		УсловиеДопустимоеОтклонение = "ИСТИНА";
	КонецЕсли;
	
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&УсловиеДопустимоеОтклонение", УсловиеДопустимоеОтклонение);
	
	Возврат ТекстЗапроса;
	
КонецФункции

Функция ТекстЗапросаВТТоварыКОформлениюРасходныхОрдеров()
	
	ТекстЗапроса =
	"ВЫБРАТЬ
	|	ТаблицаОборотов.Склад				КАК Склад,
	|	ТаблицаОборотов.ДокументОтгрузки	КАК ДокументОтгрузки,
	|	ТаблицаОборотов.Номенклатура		КАК Номенклатура,
	|	ЕСТЬNULL(ДанныеЕдиницИзмерений.ТипИзмеряемойВеличины, НЕОПРЕДЕЛЕНО) КАК ТипИзмеряемойВеличины,
	|	ТаблицаОборотов.Характеристика		КАК Характеристика,
	|	ТаблицаОборотов.Назначение			КАК Назначение,
	|	ТаблицаОборотов.КонтролируемаяПартия КАК КонтролируемаяПартия,
	|	ТаблицаОборотов.Серия				КАК Серия,
	|	ТаблицаОборотов.КОтгрузкеПриход		КАК Количество
	|ПОМЕСТИТЬ ТаблицаОборотов
	|ИЗ
	|	РегистрНакопления.ТоварыКОтгрузке.Обороты(
	|			,
	|			,
	|			,
	|			&ОтборПоСкладу1
	|			И НЕ ДокументОтгрузки В
	|					(ВЫБРАТЬ
	|						ВТЗаблокированоТоварыКОтгрузке.ДокументОтгрузки
	|					ИЗ
	|						ВТЗаблокированоТоварыКОтгрузке КАК ВТЗаблокированоТоварыКОтгрузке)
	|	) КАК ТаблицаОборотов
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК ДанныеНоменклатуры
	|		ПО ТаблицаОборотов.Номенклатура = ДанныеНоменклатуры.Ссылка
	|		
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.УпаковкиЕдиницыИзмерения КАК ДанныеЕдиницИзмерений
	|		ПО ДанныеНоменклатуры.ЕдиницаИзмерения = ДанныеЕдиницИзмерений.Ссылка
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Склад,
	|	ДокументОтгрузки,
	|	Номенклатура,
	|	Характеристика,
	|	Назначение,
	|	КонтролируемаяПартия,
	|	Серия
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТаблицаОстатков.Склад				КАК Склад,
	|	ТаблицаОстатков.ДокументОтгрузки	КАК ДокументОтгрузки,
	|	ТаблицаОстатков.Номенклатура		КАК Номенклатура,
	|	ТаблицаОстатков.Характеристика		КАК Характеристика,
	|	ТаблицаОстатков.Назначение			КАК Назначение,
	|	ТаблицаОстатков.КонтролируемаяПартия КАК КонтролируемаяПартия,
	|	ТаблицаОстатков.Серия				КАК Серия
	|ПОМЕСТИТЬ ВТТоварыКОформлениюРасходныхОрдеров
	|ИЗ
	|	РегистрНакопления.ТоварыКОтгрузке.Остатки(
	|			,
	|			&ОтборПоСкладу1
	|			И (ДокументОтгрузки, Номенклатура, Характеристика, Назначение, КонтролируемаяПартия, Серия) В
	|					(ВЫБРАТЬ РАЗЛИЧНЫЕ
	|						ТаблицаОтбора.ДокументОтгрузки,
	|						ТаблицаОтбора.Номенклатура,
	|						ТаблицаОтбора.Характеристика,
	|						ТаблицаОтбора.Назначение,
	|						ТаблицаОтбора.КонтролируемаяПартия,
	|						ТаблицаОтбора.Серия
	|					ИЗ
	|						ТаблицаОборотов КАК ТаблицаОтбора)
	|	) КАК ТаблицаОстатков
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ТаблицаОборотов КАК ТаблицаОборотов
	|		ПО ТаблицаОстатков.Склад = ТаблицаОборотов.Склад
	|			И ТаблицаОстатков.ДокументОтгрузки = ТаблицаОборотов.ДокументОтгрузки
	|			И ТаблицаОстатков.Номенклатура = ТаблицаОборотов.Номенклатура
	|			И ТаблицаОстатков.Характеристика = ТаблицаОборотов.Характеристика
	|			И ТаблицаОстатков.Назначение = ТаблицаОборотов.Назначение
	|			И ТаблицаОстатков.КонтролируемаяПартия = ТаблицаОборотов.КонтролируемаяПартия
	|			И ТаблицаОстатков.Серия = ТаблицаОборотов.Серия
	|
	|ГДЕ
	|	ТаблицаОстатков.КОтгрузкеОстаток > ВЫБОР
	|			КОГДА ТаблицаОборотов.ТипИзмеряемойВеличины В (&МерныеТипыЕдиницИзмерений)
	|				ТОГДА ТаблицаОборотов.Количество * &ДопустимоеОтклонениеОтгрузкиПриемкиМерныхТоваров / 100
	|			ИНАЧЕ 0
	|		КОНЕЦ
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Склад,
	|	ДокументОтгрузки,
	|	Номенклатура,
	|	Характеристика,
	|	Назначение,
	|	КонтролируемаяПартия,
	|	Серия";
	
	Возврат ТекстЗапроса;
	
КонецФункции

Функция ТекстЗапросаОстаткиТоварыКОтгрузке(ПараметрыТекстаЗапроса)
	
	Если ПараметрыТекстаЗапроса.ПереоформлениеОчереди Тогда
		Если ПараметрыТекстаЗапроса.ОтгрузитьПослеЗаданияНаПеревозку Тогда
			ТекстЗапроса = ТекстЗапросаОстаткиТоваровКОтгрузкеПоСкладамСЗаданиямиНаПеревозку();
		Иначе
			ТекстЗапроса = ТекстЗапросаОстаткиТоваровКОтгрузкеПоСкладамБезЗаданийНаПеревозку()
		КонецЕсли;
	Иначе
		ТекстыЗапросов = Новый Массив;
		
		Если ПараметрыТекстаЗапроса.ОтгрузитьПослеЗаданияНаПеревозку Тогда
			ТекстЗапроса = ТекстЗапросаОстаткиТоваровКОтгрузкеПоСкладамСЗаданиямиНаПеревозку(
							"ОстаткиТоваровКОтгрузкеПоЗаданиям");
		Иначе
			ТекстЗапроса = ТекстЗапросаОстаткиТоварыКОтгрузкеССуффиксом("ОстаткиТоваровКОтгрузкеПоЗаданиям");
		КонецЕсли;
		
		ТекстыЗапросов.Добавить(ТекстЗапроса);
		
		Если ПараметрыТекстаЗапроса.ОтгрузитьБезЗаданияНаПеревозку Тогда
			ТекстЗапроса = ТекстЗапросаОстаткиТоваровКОтгрузкеПоСкладамБезЗаданийНаПеревозку(
							"ОстаткиТоваровКОтгрузкеБезЗаданий");
		Иначе
			ТекстЗапроса = ТекстЗапросаОстаткиТоварыКОтгрузкеССуффиксом("ОстаткиТоваровКОтгрузкеБезЗаданий");
		КонецЕсли;
		
		ТекстыЗапросов.Добавить(ТекстЗапроса);
		
		ТекстЗапроса =
		"ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ТоварыКОтгрузке.Склад			КАК Склад,
		|	ТоварыКОтгрузке.Получатель		КАК Получатель,
		|	ТоварыКОтгрузке.Номенклатура	КАК Номенклатура,
		|	ТоварыКОтгрузке.Характеристика	КАК Характеристика,
		|	ТоварыКОтгрузке.Назначение		КАК Назначение,
		|	ТоварыКОтгрузке.КонтролируемаяПартия КАК КонтролируемаяПартия,
		|	ТоварыКОтгрузке.Серия			КАК Серия
		|ПОМЕСТИТЬ ОстаткиТоварыКОтгрузке
		|ИЗ
		|	ОстаткиТоваровКОтгрузкеПоЗаданиям КАК ТоварыКОтгрузке
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ТоварыКОтгрузке.Склад,
		|	ТоварыКОтгрузке.Получатель,
		|	ТоварыКОтгрузке.Номенклатура,
		|	ТоварыКОтгрузке.Характеристика,
		|	ТоварыКОтгрузке.Назначение,
		|	ТоварыКОтгрузке.КонтролируемаяПартия,
		|	ТоварыКОтгрузке.Серия
		|ИЗ
		|	ОстаткиТоваровКОтгрузкеБезЗаданий КАК ТоварыКОтгрузке
		|
		|ИНДЕКСИРОВАТЬ ПО
		|	Склад,
		|	Номенклатура,
		|	Характеристика,
		|	Назначение,
		|	КонтролируемаяПартия,
		|	Серия";
		
		ТекстыЗапросов.Добавить(ТекстЗапроса);
		
		ТекстЗапроса = СтрСоединить(ТекстыЗапросов, ОбщегоНазначения.РазделительПакетаЗапросов());
	КонецЕсли;
	
	Возврат ТекстЗапроса;
	
КонецФункции

Функция ТекстЗапросаОстаткиТоваровКОтгрузкеПоСкладамСЗаданиямиНаПеревозкуДоставка25(ИмяВТ)
	
	ТекстЗапроса =
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ЗаблокированныеДокументы.ДокументОтгрузки КАК ДокументОтгрузки
	|ПОМЕСТИТЬ ВтЗаблокированныеДокументыОтгрузки
	|ИЗ
	|	(ВЫБРАТЬ
	|		ВТЗаблокированоДоставка.Распоряжение КАК ДокументОтгрузки
	|	ИЗ
	|		ВТЗаблокированоДоставка КАК ВТЗаблокированоДоставка
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ
	|		ВТЗаблокированоТоварыКОтгрузке.ДокументОтгрузки
	|	ИЗ
	|		ВТЗаблокированоТоварыКОтгрузке КАК ВТЗаблокированоТоварыКОтгрузке) КАК ЗаблокированныеДокументы
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	ДокументОтгрузки
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ДоставкаОбороты.Отправитель КАК Склад,
	|	ЕСТЬNULL(КонечноеПлечоБезЗаказаНаДоставку.Получатель, КонечноеПлечоПоЗаказуНаДоставку.Получатель) КАК Получатель,
	|	ДоставкаОбороты.Распоряжение КАК Распоряжение,
	|	ДоставкаОбороты.Номенклатура КАК Номенклатура,
	|	ДоставкаОбороты.Характеристика КАК Характеристика,
	|	ЕСТЬNULL(ПервичныеДанныеБезЗаказаНаДоставку.Назначение, ПервичныеДанныеПоЗаказуНаДоставку.Назначение) КАК Назначение,
	|	ЗНАЧЕНИЕ(Справочник.КонтролируемыеПартии.ПустаяСсылка) КАК КонтролируемаяПартия,
	|	ДоставкаОбороты.Серия КАК Серия,
	|	СУММА(ДоставкаОбороты.КДоставкеОборот) КАК КДоставке,
	|	СУММА(ДоставкаОбороты.КСборкеОборот) КАК КСборкеОсталось
	|ПОМЕСТИТЬ ВтДанныеДоставки
	|ИЗ
	|	РегистрНакопления.Доставка.Обороты(
	|			,
	|			,
	|			,
	|			&ОтборПоСкладуДоставка25
	|				И Плечо = 1
	|				И ТипДоставки = ЗНАЧЕНИЕ(Перечисление.ТипыДоставки.Исходящая)
	|				И СпособДоставки <> ЗНАЧЕНИЕ(Перечисление.СпособыДоставки25.Самовывоз)
	|				И НЕ Распоряжение В
	|						(ВЫБРАТЬ
	|							ЗаблокированныеДокументыОтгрузки.ДокументОтгрузки КАК ДокументОтгрузки
	|						ИЗ
	|							ВтЗаблокированныеДокументыОтгрузки КАК ЗаблокированныеДокументыОтгрузки)) КАК ДоставкаОбороты
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.Доставка КАК ПервичныеДанныеБезЗаказаНаДоставку
	|		ПО ДоставкаОбороты.Распоряжение = ПервичныеДанныеБезЗаказаНаДоставку.Распоряжение
	|			И (НЕ ДоставкаОбороты.ДокументПланирования ССЫЛКА Документ.ЗаказНаДоставку)
	|			И ДоставкаОбороты.ДокументПланирования = ПервичныеДанныеБезЗаказаНаДоставку.ДокументПланирования
	|			И ДоставкаОбороты.КодСтроки = ПервичныеДанныеБезЗаказаНаДоставку.КодСтроки
	|			И (ПервичныеДанныеБезЗаказаНаДоставку.ПервичнаяЗапись)
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.Доставка КАК ПервичныеДанныеПоЗаказуНаДоставку
	|		ПО ДоставкаОбороты.Распоряжение = ПервичныеДанныеПоЗаказуНаДоставку.Распоряжение
	|			И (ДоставкаОбороты.ДокументПланирования ССЫЛКА Документ.ЗаказНаДоставку)
	|			И (ПервичныеДанныеПоЗаказуНаДоставку.ДокументПланирования = НЕОПРЕДЕЛЕНО)
	|			И ДоставкаОбороты.КодСтроки = ПервичныеДанныеПоЗаказуНаДоставку.КодСтроки
	|			И (ПервичныеДанныеПоЗаказуНаДоставку.ПервичнаяЗапись)
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.Доставка КАК КонечноеПлечоБезЗаказаНаДоставку
	|		ПО ДоставкаОбороты.Распоряжение = КонечноеПлечоБезЗаказаНаДоставку.Распоряжение
	|			И (НЕ ДоставкаОбороты.ДокументПланирования ССЫЛКА Документ.ЗаказНаДоставку)
	|			И ДоставкаОбороты.ДокументПланирования = КонечноеПлечоБезЗаказаНаДоставку.ДокументПланирования
	|			И ДоставкаОбороты.КодСтроки = КонечноеПлечоБезЗаказаНаДоставку.КодСтроки
	|			И (КонечноеПлечоБезЗаказаНаДоставку.ЭтоКонечноеПлечо)
	|			И (КонечноеПлечоБезЗаказаНаДоставку.УровеньОперации В (10, 15))
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.Доставка КАК КонечноеПлечоПоЗаказуНаДоставку
	|		ПО ДоставкаОбороты.Распоряжение = КонечноеПлечоПоЗаказуНаДоставку.Распоряжение
	|			И (ДоставкаОбороты.ДокументПланирования ССЫЛКА Документ.ЗаказНаДоставку)
	|			И (КонечноеПлечоПоЗаказуНаДоставку.ДокументПланирования = НЕОПРЕДЕЛЕНО)
	|			И ДоставкаОбороты.КодСтроки = КонечноеПлечоПоЗаказуНаДоставку.КодСтроки
	|			И (КонечноеПлечоПоЗаказуНаДоставку.ЭтоКонечноеПлечо)
	|			И (КонечноеПлечоПоЗаказуНаДоставку.УровеньОперации В (10, 15))
	|
	|СГРУППИРОВАТЬ ПО
	|	ЕСТЬNULL(КонечноеПлечоБезЗаказаНаДоставку.Получатель, КонечноеПлечоПоЗаказуНаДоставку.Получатель),
	|	ДоставкаОбороты.Отправитель,
	|	ЕСТЬNULL(ПервичныеДанныеБезЗаказаНаДоставку.Назначение, ПервичныеДанныеПоЗаказуНаДоставку.Назначение),
	|	ДоставкаОбороты.Серия,
	|	ДоставкаОбороты.Распоряжение,
	|	ДоставкаОбороты.Характеристика,
	|	ДоставкаОбороты.Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТоварыКОтгрузкеБезДоставки.Склад КАК Склад,
	|	ТоварыКОтгрузкеБезДоставки.Получатель КАК Получатель,
	|	ТоварыКОтгрузкеБезДоставки.ДокументОтгрузки КАК ДокументОтгрузки,
	|	ТоварыКОтгрузкеБезДоставки.Номенклатура КАК Номенклатура,
	|	ТоварыКОтгрузкеБезДоставки.Характеристика КАК Характеристика,
	|	ТоварыКОтгрузкеБезДоставки.Назначение КАК Назначение,
	|	ТоварыКОтгрузкеБезДоставки.КонтролируемаяПартия КАК КонтролируемаяПартия,
	|	ТоварыКОтгрузкеБезДоставки.Серия КАК Серия,
	|	СУММА(ТоварыКОтгрузкеБезДоставки.КоличествоКОтгрузке) КАК КоличествоКОтгрузке
	|ПОМЕСТИТЬ ВтТоварыКОтгрузкеПриход
	|ИЗ
