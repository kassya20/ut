// Возвращает разрешение фискализации по складу
//
// Параметры:
// 	Склад - СправочникСсылка.Склады
// 	ПерсональнаяНастройка - Булево - персональная настройка фискализации
// 	Дата - Дата
// 	
// Возвращаемое значение:
// 	Булево
Функция РазрешенаФискализацияПоСкладу(Склад, ПерсональнаяНастройка, Дата = Неопределено) Экспорт
	
	Результат = Ложь;
	
	Если Не ЗначениеЗаполнено(Склад) Тогда
		Возврат Результат;
	КонецЕсли;
	
	НастройкиСклада = НастройкиСкладаДляСборкиИДоставки(Склад, Дата);
	
	СкладРеквизиты = ОбщегоНазначенияУТВызовСервера.ЗначенияРеквизитовОбъекта(Склад, "ЭтоГруппа");
	
	Если НастройкиСклада = Неопределено Тогда
		Возврат СкладРеквизиты.ЭтоГруппа И ПерсональнаяНастройка;
	КонецЕсли;
	
	СкладФискализацияРазрешена = Не СкладРеквизиты.ЭтоГруппа 
			И (НастройкиСклада.ВМагазинеПоддерживаетсяСборкаЗаказов ИЛИ НастройкиСклада.ВМагазинеПоддерживаетсяДоставкаСвоимиКурьерами);
	СкладФискализацииПриРеализации = (НастройкиСклада.СпособФискализацииПриДоставке = ПредопределенноеЗначение("Перечисление.СпособыФискализацииПриДоставке.ВМоментОформленияРеализации"));
	
	Если СкладФискализацияРазрешена И СкладФискализацииПриРеализации
		ИЛИ Не СкладФискализацияРазрешена И ПерсональнаяНастройка Тогда
		Результат = Истина;
	КонецЕсли; 
	
	Возврат Результат;
	
КонецФункции

// Получает статусы сборки и доставки заказов необходимых для назначения заказов курьеру. 
//
// Возвращаемое значение:
