									Регистры,
									ТекстЗапросаДанныхДокумента,
									ОбъектМетаданных = Неопределено,
									ИмяТЧСерии = "",
									СинонимТЧДокумента = "ТоварыДокумента") Экспорт
	
	ПараметрыМодульногоПроведения = ПараметрыМодульногоПроведения();
	ПараметрыМодульногоПроведения.СинонимТаблицыДокумента = СинонимТЧДокумента;
	ПараметрыМодульногоПроведения.ИмяТЧСерии = ИмяТЧСерии;
	ПараметрыМодульногоПроведения.ОбъектМетаданных = ОбъектМетаданных;
	
	ОформитьОтгрузкуТоваровВнутренний(Запрос,
