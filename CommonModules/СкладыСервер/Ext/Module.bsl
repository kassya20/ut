#Область ФормированиеЗапросовПроведения

Функция ОперацииОтгрузки()
	
	ОперацииОтгрузки = Новый Массив;
	ОперацииОтгрузки.Добавить("ОтразитьРезерв");
	ОперацииОтгрузки.Добавить("ЗапланироватьОтгрузкуТоваров");
	ОперацииОтгрузки.Добавить("ОформитьОтгрузкуТоваров");
	ОперацииОтгрузки.Добавить("ОтгрузитьТоварСоСклада");
	ОперацииОтгрузки.Добавить("ОформитьОтгрузкуВРозницу");
	
	Возврат ОперацииОтгрузки;
	
КонецФункции

Функция ОперацииПриемки()
	
	ОперацииОтгрузки = Новый Массив;
	ОперацииОтгрузки.Добавить("ЗапланироватьПоступлениеТоваров");
	ОперацииОтгрузки.Добавить("ОформитьПоступлениеТоваровПоОдноходовке");
	ОперацииОтгрузки.Добавить("ОформитьПриобретениеТоваровПоДвухходовке");
	ОперацииОтгрузки.Добавить("ПринятьТоварНаСклад");
	ОперацииОтгрузки.Добавить("ОформитьПоступлениеТоваровПоДвухходовке");
	
	Возврат ОперацииОтгрузки;
	
КонецФункции

Процедура ЗаполнитьПараметрыТекстаЗапроса(ТекстЗапроса, ПараметрыЗапроса)
	
	Для Каждого ПараметрЗапроса Из ПараметрыЗапроса Цикл
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, ",&" + ПараметрЗапроса.Ключ, ПараметрЗапроса.Значение);
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&" + ПараметрЗапроса.Ключ, ПараметрЗапроса.Значение);
	КонецЦикла;
	
КонецПроцедуры

// Функция возвращает табличную часть объекта метаданных
//
// Параметры:
// 	ОбъектМетаданных - ОбъектМетаданныхДокумент, Неопределено, ОбъектМетаданных -
// 	ИмяТЧ - Строка
//
// Возвращаемое значение:
// 	ОбъектМетаданныхТабличнаяЧасть - 
//
Функция ПолучитьТЧОбъектаМетаданных(ОбъектМетаданных, ИмяТЧ)
	
	ТЧОбъекта = ОбъектМетаданных.ТабличныеЧасти.Найти(ИмяТЧ);
	
	Если ТЧОбъекта = Неопределено Тогда
		ШаблонОшибки	= НСтр("ru = 'Обнаружены не правильные настройки - не существует табличной части %1 объекта метаданных %2'");
		ТекстОшибки		= СтрШаблон(ШаблонОшибки, ИмяТЧ, ОбъектМетаданных.Имя);
		
		ВызватьИсключение ТекстОшибки;
	КонецЕсли;
	
	Возврат ТЧОбъекта;
	
КонецФункции

Функция ТекстЗапросаДанныхОтгружаемыеТовары(ИмяТаблицы)
	
	ТекстЗапроса = 
	"ВЫБРАТЬ
	|	ДанныеДокумента.Ссылка				КАК Ссылка,
	|	ДанныеДокумента.Период				КАК Период,
	|	ДанныеДокумента.Склад				КАК Склад,
	|	ДанныеДокумента.Помещение			КАК Помещение,
	|	ДанныеДокумента.Номенклатура		КАК Номенклатура,
	|	ДанныеДокумента.Характеристика		КАК Характеристика,
	|	ДанныеДокумента.Назначение			КАК Назначение,
	|	ДанныеДокумента.КонтролируемаяПартия КАК КонтролируемаяПартия,
	|	ДанныеДокумента.Серия				КАК Серия,
	|	ДанныеДокумента.СтатусУказанияСерий	КАК СтатусУказанияСерий,
	|	ДанныеДокумента.Количество			КАК Количество,
	|	ДанныеДокумента.Действие			КАК Действие,
	|	ДанныеДокумента.КСборке				КАК КСборке,
	|	ДанныеДокумента.Собирается			КАК Собирается,
	|	ДанныеДокумента.Собрано				КАК Собрано,
	|	ДанныеДокумента.КОтгрузке			КАК КОтгрузке,
	|	&ИспользоватьАдресноеХранение		КАК ИспользоватьАдресноеХранение,
	|	&ЭтоТовар							КАК ЭтоТовар
	|ПОМЕСТИТЬ ИмяВТДанных
	|ИЗ
	|	#ДанныеДокумента КАК ДанныеДокумента
	|
	|ГДЕ
	|	&ТипУпаковки <> ЗНАЧЕНИЕ(Перечисление.ТипыУпаковокНоменклатуры.ТоварноеМесто)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ДанныеДокументаБезУпаковок.Ссылка				КАК Ссылка,
	|	ДанныеДокумента.Период							КАК Период,
	|	ДанныеДокумента.Склад							КАК Склад,
	|	ДанныеДокумента.Помещение						КАК Помещение,
	|	ДанныеДокументаБезУпаковок.Номенклатура			КАК Номенклатура,
	|	ДанныеДокументаБезУпаковок.Характеристика		КАК Характеристика,
	|	ДанныеДокументаБезУпаковок.Назначение			КАК Назначение,
	|	ДанныеДокументаБезУпаковок.КонтролируемаяПартия КАК КонтролируемаяПартия,
	|	ДанныеДокументаБезУпаковок.Серия				КАК Серия,
	|	ДанныеДокументаБезУпаковок.СтатусУказанияСерий	КАК СтатусУказанияСерий,
	|	СУММА(ДанныеДокумента.Количество)				КАК Количество,
	|	ДанныеДокументаБезУпаковок.Действие				КАК Действие,
	|	ДанныеДокумента.КСборке							КАК КСборке,
	|	ДанныеДокумента.Собирается						КАК Собирается,
	|	ДанныеДокумента.Собрано							КАК Собрано,
	|	ДанныеДокумента.КОтгрузке						КАК КОтгрузке,
	|	&ИспользоватьАдресноеХранение					КАК ИспользоватьАдресноеХранение,
	|	&ЭтоТовар										КАК ЭтоТовар
	|ИЗ
	|	(ВЫБРАТЬ
	|		ДанныеДокумента.Ссылка				КАК Ссылка,
	|		ДанныеДокумента.Номенклатура		КАК Номенклатура,
	|		ДанныеДокумента.Характеристика		КАК Характеристика,
	|		ДанныеДокумента.Назначение			КАК Назначение,
	|		ДанныеДокумента.КонтролируемаяПартия КАК КонтролируемаяПартия,
	|		МАКСИМУМ(ДанныеДокумента.Упаковка)	КАК Упаковка,
	|		ДанныеДокумента.Серия				КАК Серия,
	|		ДанныеДокумента.СтатусУказанияСерий	КАК СтатусУказанияСерий,
	|		ДанныеДокумента.Действие			КАК Действие
	|	ИЗ
	|		#ДанныеДокумента КАК ДанныеДокумента
	|	
	|	ГДЕ
	|		&ТипУпаковки = ЗНАЧЕНИЕ(Перечисление.ТипыУпаковокНоменклатуры.ТоварноеМесто)
	|	
	|	СГРУППИРОВАТЬ ПО
	|		ДанныеДокумента.Ссылка,
	|		ДанныеДокумента.Номенклатура,
	|		ДанныеДокумента.Характеристика,
	|		ДанныеДокумента.Назначение,
	|		ДанныеДокумента.КонтролируемаяПартия,
	|		ДанныеДокумента.Серия,
	|		ДанныеДокумента.СтатусУказанияСерий,
	|		ДанныеДокумента.Действие
	|	
	|	) КАК ДанныеДокументаБезУпаковок
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ #ДанныеДокумента КАК ДанныеДокумента
	|		ПО ДанныеДокументаБезУпаковок.Ссылка = ДанныеДокумента.Ссылка
	|			И ДанныеДокументаБезУпаковок.Номенклатура = ДанныеДокумента.Номенклатура
	|			И ДанныеДокументаБезУпаковок.Характеристика = ДанныеДокумента.Характеристика
	|			И ДанныеДокументаБезУпаковок.Назначение = ДанныеДокумента.Назначение
	|			И ДанныеДокументаБезУпаковок.КонтролируемаяПартия = ДанныеДокумента.КонтролируемаяПартия
	|			И ДанныеДокументаБезУпаковок.Серия = ДанныеДокумента.Серия
	|			И ДанныеДокументаБезУпаковок.Упаковка = ДанныеДокумента.Упаковка
	|			И ДанныеДокументаБезУпаковок.Действие = ДанныеДокумента.Действие
	|
	|СГРУППИРОВАТЬ ПО
	|	ДанныеДокументаБезУпаковок.Ссылка,
	|	ДанныеДокумента.Период,
	|	ДанныеДокумента.Склад,
	|	ДанныеДокумента.Помещение,
	|	ДанныеДокументаБезУпаковок.Номенклатура,
	|	ДанныеДокументаБезУпаковок.Характеристика,
	|	ДанныеДокументаБезУпаковок.Назначение,
	|	ДанныеДокументаБезУпаковок.КонтролируемаяПартия,
	|	ДанныеДокументаБезУпаковок.Серия,
	|	ДанныеДокументаБезУпаковок.СтатусУказанияСерий,
	|	ДанныеДокументаБезУпаковок.Действие,
	|	ДанныеДокумента.КСборке,
	|	ДанныеДокумента.Собирается,
	|	ДанныеДокумента.Собрано,
	|	ДанныеДокумента.КОтгрузке,
	|	&ИспользоватьАдресноеХранение,
	|	&ЭтоТовар";
	
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "ИмяВТДанных", ИмяТаблицы);
	
	Возврат ТекстЗапроса;
	
КонецФункции

Функция ПараметрыТекстаЗапросаДанныхДокумента(ИмяОперации, ИсточникДанных = "ДанныеДокумента", УчитываютсяВДвиженияхУслугиРаботы = Ложь)
	
	ПараметрыЗапроса = Новый Структура;
	ОперацииОтгрузки = ОперацииОтгрузки();
	ОперацииПриемки = ОперацииПриемки();
	
	ПараметрыЗапроса.Вставить("ВидДвиженияПриход", "ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход)");
	ПараметрыЗапроса.Вставить("ВидДвиженияРасход", "ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход)");
	
	#Область ОперацииОтгрузки
	Если ОперацииОтгрузки.Найти(ИмяОперации) <> Неопределено Тогда
		
		Если ИмяОперации = "ОтгрузитьТоварСоСклада" Тогда
			ДокументОтгрузки = "ДанныеДокумента.Заказ";
		Иначе
			ДокументОтгрузки = 
			"ВЫБОР
			|		КОГДА ДанныеДокумента.Заказ <> НЕОПРЕДЕЛЕНО
			|			ТОГДА ДанныеДокумента.Заказ 
			|		ИНАЧЕ
			|			ВЫБОР
			|				КОГДА ДанныеДокумента.ОтгрузкаПоЗаказу
			|					ТОГДА ДанныеДокумента.Заказ 
			|				КОГДА ДанныеДокумента.Исправление
			|					ТОГДА ДанныеДокумента.ИсправляемыйДокумент
			|				ИНАЧЕ ДанныеДокумента.Накладная
			|			КОНЕЦ
			|	КОНЕЦ";
		КонецЕсли;
		
		Назначение = 
		"ВЫБОР
		|		КОГДА ЕСТЬNULL(ДанныеДокумента.Назначение.ДвиженияПоСкладскимРегистрам, ЛОЖЬ)
		|			ТОГДА ДанныеДокумента.Назначение
		|		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.Назначения.ПустаяСсылка)
		|	КОНЕЦ";
		
		Если ИмяОперации = "ОтразитьРезерв"
			Или ИмяОперации = "ЗапланироватьОтгрузкуТоваров" Тогда
			
			Серия = 
			"ВЫБОР
			|		КОГДА НЕ ДанныеДокумента.ЭтоНакладная
			|				ИЛИ ДанныеДокумента.СтатусУказанияСерий В(10, 14)
			|			ТОГДА ДанныеДокумента.Серия
			|		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.СерииНоменклатуры.ПустаяСсылка)
			|	КОНЕЦ";
			
		ИначеЕсли ИмяОперации = "ОформитьОтгрузкуТоваров"
			Или ИмяОперации = "ОтгрузитьТоварСоСклада" Тогда
			
			Серия = 
			"ВЫБОР
			|		КОГДА ДанныеДокумента.СтатусУказанияСерий В(10, 14)
			|			ТОГДА ДанныеДокумента.Серия
			|		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.СерииНоменклатуры.ПустаяСсылка)
			|	КОНЕЦ";
			
		КонецЕсли;
		
		ТипУпаковки = "ЕСТЬNULL(ДанныеДокумента.Упаковка.ТипУпаковки, НЕОПРЕДЕЛЕНО)";
		
		ТипИзмеряемойВеличины = "ЕСТЬNULL(ДанныеДокумента.Упаковка.ТипИзмеряемойВеличины, НЕОПРЕДЕЛЕНО)";
		
		ТоварноеМесто = 
		"ВЫБОР
		|		КОГДА ЕСТЬNULL(ДанныеДокумента.Упаковка.ТипУпаковки, НЕОПРЕДЕЛЕНО) = ЗНАЧЕНИЕ(Перечисление.ТипыУпаковокНоменклатуры.ТоварноеМесто)
		|			ТОГДА ДанныеДокумента.Упаковка
		|		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.УпаковкиЕдиницыИзмерения.ПустаяСсылка)
		|	КОНЕЦ";
		
		ИспользоватьОрдернуюСхему = 
		"ВЫБОР
		|		КОГДА ДанныеДокумента.Склад.ИспользоватьОрдернуюСхемуПриОтгрузке
		|				И ДанныеДокумента.Период >= ДанныеДокумента.Склад.ДатаНачалаОрдернойСхемыПриОтгрузке
		|			ТОГДА ИСТИНА
		|		ИНАЧЕ ЛОЖЬ
		|	КОНЕЦ";
		
		ИспользуетсяОрдернаяСхемаПриПоступлении =
		"	(ДанныеДокумента.Склад.ИспользоватьОрдернуюСхемуПриПоступлении
		|		И ДанныеДокумента.Период >= ДанныеДокумента.Склад.ДатаНачалаОрдернойСхемыПриПоступлении)";
		
		ИспользуетсяОрдернаяСхемаПриОтраженииИзлишковНедостач =
		"	(ДанныеДокумента.Склад.ИспользоватьОрдернуюСхемуПриОтраженииИзлишковНедостач
		|		И ДанныеДокумента.Период >= ДанныеДокумента.Склад.ДатаНачалаОрдернойСхемыПриОтраженииИзлишковНедостач)";
		
		ИспользоватьАдресноеХранение = 
		"ВЫБОР
		|		КОГДА ДанныеДокумента.Склад.ИспользоватьСкладскиеПомещения
		|				И ДанныеДокумента.Период >= ДанныеДокумента.Склад.ДатаНачалаИспользованияСкладскихПомещений
		|			ТОГДА ВЫБОР
		|					КОГДА ДанныеДокумента.Помещение.ИспользоватьАдресноеХранение
		|							И ДанныеДокумента.Период >= ДанныеДокумента.Помещение.ДатаНачалаАдресногоХраненияОстатков
		|						ТОГДА ИСТИНА
		|					ИНАЧЕ ЛОЖЬ
		|				КОНЕЦ
		|		ИНАЧЕ ВЫБОР
		|				КОГДА ДанныеДокумента.Склад.ИспользоватьАдресноеХранение
		|						И ДанныеДокумента.Период >= ДанныеДокумента.Склад.ДатаНачалаАдресногоХраненияОстатков
		|					ТОГДА ИСТИНА
		|				ИНАЧЕ ЛОЖЬ
		|			КОНЕЦ
		|	КОНЕЦ";
		
		ДокументОтгрузки				= СтрЗаменить(ДокументОтгрузки,				"ДанныеДокумента", ИсточникДанных);
		Назначение						= СтрЗаменить(Назначение,					"ДанныеДокумента", ИсточникДанных);
		Серия							= СтрЗаменить(Серия,						"ДанныеДокумента", ИсточникДанных);
		ТипУпаковки						= СтрЗаменить(ТипУпаковки,					"ДанныеДокумента", ИсточникДанных);
		ТипИзмеряемойВеличины			= СтрЗаменить(ТипИзмеряемойВеличины,		"ДанныеДокумента", ИсточникДанных);
		ТоварноеМесто					= СтрЗаменить(ТоварноеМесто,				"ДанныеДокумента", ИсточникДанных);
		ИспользоватьОрдернуюСхему		= СтрЗаменить(ИспользоватьОрдернуюСхему,	"ДанныеДокумента", ИсточникДанных);
		ИспользоватьАдресноеХранение	= СтрЗаменить(ИспользоватьАдресноеХранение,	"ДанныеДокумента", ИсточникДанных);
		ИспользуетсяОрдернаяСхемаПриПоступлении	= СтрЗаменить(ИспользуетсяОрдернаяСхемаПриПоступлении,	"ИспользуетсяОрдернаяСхемаПриПоступлении", ИсточникДанных);
		ИспользуетсяОрдернаяСхемаПриОтраженииИзлишковНедостач	= СтрЗаменить(ИспользуетсяОрдернаяСхемаПриОтраженииИзлишковНедостач,	"ДанныеДокумента", ИсточникДанных);
		
		ПараметрыЗапроса.Вставить("ДокументОтгрузки",				ДокументОтгрузки);
		ПараметрыЗапроса.Вставить("Назначение",						Назначение);
		ПараметрыЗапроса.Вставить("Серия",							Серия);
		ПараметрыЗапроса.Вставить("ТипУпаковки",					ТипУпаковки);
		ПараметрыЗапроса.Вставить("ТипИзмеряемойВеличины",			ТипИзмеряемойВеличины);
		ПараметрыЗапроса.Вставить("ТоварноеМесто",					ТоварноеМесто);
		ПараметрыЗапроса.Вставить("ИспользоватьОрдернуюСхему",		ИспользоватьОрдернуюСхему);
		ПараметрыЗапроса.Вставить("ИспользоватьАдресноеХранение",	ИспользоватьАдресноеХранение);
		ПараметрыЗапроса.Вставить("ИспользуетсяОрдернаяСхемаПриПоступлении", ИспользуетсяОрдернаяСхемаПриПоступлении);
		ПараметрыЗапроса.Вставить("ИспользуетсяОрдернаяСхемаПриОтраженииИзлишковНедостач", ИспользуетсяОрдернаяСхемаПриОтраженииИзлишковНедостач);
		
	КонецЕсли;
	#КонецОбласти
	
	#Область ОперацииПриемки

	Если ОперацииПриемки.Найти(ИмяОперации) <> Неопределено Тогда
		
		ДополнительныеСоединения = "";
	
		Назначение =
		"	ВЫБОР
		|		КОГДА ЕСТЬNULL(ДанныеДокумента.Назначение.ДвиженияПоСкладскимРегистрам, ЛОЖЬ)
		|			ТОГДА ДанныеДокумента.Назначение
		|		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.Назначения.ПустаяСсылка)
		|	КОНЕЦ";
		
		ИспользуетсяОрдернаяСхемаПриПоступлении =
		"	(ДанныеДокумента.Склад.ИспользоватьОрдернуюСхемуПриПоступлении
		|		И ДанныеДокумента.Дата >= ДанныеДокумента.Склад.ДатаНачалаОрдернойСхемыПриПоступлении)";
		
		ИспользуетсяОрдернаяСхемаПриОтраженииИзлишковНедостач =
		"	(ДанныеДокумента.Склад.ИспользоватьОрдернуюСхемуПриОтраженииИзлишковНедостач
		|		И ДанныеДокумента.Дата >= ДанныеДокумента.Склад.ДатаНачалаОрдернойСхемыПриОтраженииИзлишковНедостач)";
		
		НакладнаяЯвляетсяРаспоряжением = 
		"	ДанныеДокумента.ВариантПриемкиТоваров = ЗНАЧЕНИЕ(Перечисление.ВариантыПриемкиТоваров.РазделенаТолькоПоНакладным)";
		
		НакладнаяПоУслугамЯвляетсяРаспоряжением = 
		"	ДанныеДокумента.ВариантПриемкиУслуг = ЗНАЧЕНИЕ(Перечисление.ВариантыПриемкиТоваров.РазделенаТолькоПоНакладным)";
		
		ИспользуетсяДокументПоступлениеТоваров =
		"	ВЫБОР
		|		КОГДА ДанныеДокумента.ХозяйственнаяОперация В(ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.ЗакупкаУПоставщикаТоварыВПути),
		|														ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.ЗакупкаУПоставщикаПоступлениеИзТоваровВПути),
		|														ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.ЗакупкаУПоставщикаФактуровкаПоставки),
		|														ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.ЗакупкаУПоставщикаНеотфактурованнаяПоставка),
		|														ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.ЗакупкаВСтранахЕАЭСТоварыВПути),
		|														ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.ЗакупкаВСтранахЕАЭСПоступлениеИзТоваровВПути),
		|														ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.ЗакупкаВСтранахЕАЭСФактуровкаПоставки),
		|														ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.ЗакупкаВСтранахЕАЭСНеотфактурованнаяПоставка),
