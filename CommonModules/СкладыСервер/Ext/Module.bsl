//	Параметры:
//		Склад - СправочникСсылка.Склады - ссылка на элемент справочника "Склады"
//		Дата - Дата - на которую проверяется поддержка доставки своими курьерами
//
//	Возвращаемое значение:
//		Структура, Неопределено - структура значений настроек, если настройки не заданы, то возвращает.
//
Функция НастройкиСкладаДляСборкиИДоставки(Склад, Дата = Неопределено) Экспорт
	
	Если Не ЗначениеЗаполнено(Склад) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	Склады.Ссылка КАК Ссылка,
		|	ВЫБОР
		|		КОГДА ЕСТЬNULL(ИсторияИзменения.ФорматМагазина, ЗНАЧЕНИЕ(Справочник.ФорматыМагазинов.ПустаяСсылка)) = ЗНАЧЕНИЕ(Справочник.ФорматыМагазинов.ПустаяСсылка)
		|			ТОГДА Склады.ВМагазинеПоддерживаетсяДоставкаСвоимиКурьерами
		|					И Склады.ДатаНачалаДоставкиСвоимиКурьерами <= &Дата
		|		ИНАЧЕ ИсторияИзменения.ФорматМагазина.ВМагазинеПоддерживаетсяДоставкаСвоимиКурьерами
		|	КОНЕЦ КАК ВМагазинеПоддерживаетсяДоставкаСвоимиКурьерами,
		|	ВЫБОР
		|		КОГДА ЕСТЬNULL(ИсторияИзменения.ФорматМагазина, ЗНАЧЕНИЕ(Справочник.ФорматыМагазинов.ПустаяСсылка)) = ЗНАЧЕНИЕ(Справочник.ФорматыМагазинов.ПустаяСсылка)
		|			ТОГДА Склады.ВМагазинеПоддерживаетсяСборкаЗаказов
		|					И Склады.ДатаНачалаСборкиЗаказов <= &Дата
		|		ИНАЧЕ ИсторияИзменения.ФорматМагазина.ВМагазинеПоддерживаетсяСборкаЗаказов
		|	КОНЕЦ КАК ВМагазинеПоддерживаетсяСборкаЗаказов,
		|	ЕСТЬNULL(ИсторияИзменения.ФорматМагазина.СпособСозданияРеализацииПриСборкеЗаказов, Склады.СпособСозданияРеализацииПриСборкеЗаказов) КАК СпособСозданияРеализацииПриСборкеЗаказов,
		|	ЕСТЬNULL(ИсторияИзменения.ФорматМагазина.СпособФискализацииПриДоставке, Склады.СпособФискализацииПриДоставке) КАК СпособФискализацииПриДоставке,
		|	ЕСТЬNULL(ИсторияИзменения.ФорматМагазина.СборкаИДоставкаВыполняетсяОднимСотрудником, Склады.СборкаИДоставкаВыполняетсяОднимСотрудником) КАК СборкаИДоставкаВыполняетсяОднимСотрудником,
		|	ЕСТЬNULL(ИсторияИзменения.ФорматМагазина.КурьерыМогутНазначатьСебеЗаказы, Склады.КурьерыМогутНазначатьСебеЗаказы) КАК КурьерыМогутНазначатьСебеЗаказы,
		|	ЕСТЬNULL(ИсторияИзменения.ФорматМагазина.СборщикиМогутНазначатьСебеЗаказы, Склады.СборщикиМогутНазначатьСебеЗаказы) КАК СборщикиМогутНазначатьСебеЗаказы,
		|	ЕСТЬNULL(ИсторияИзменения.ФорматМагазина.НормативныйСрокДоставкиЗаказов, Склады.НормативныйСрокДоставкиЗаказов) КАК НормативныйСрокДоставкиЗаказов,
		|	ЕСТЬNULL(ИсторияИзменения.ФорматМагазина.КурьерыИспользуютЭквайринговыеТерминалы, Склады.КурьерыИспользуютЭквайринговыеТерминалы) КАК КурьерыИспользуютЭквайринговыеТерминалы,
		|	ЕСТЬNULL(ИсторияИзменения.ФорматМагазина.КурьерыИспользуютАвтономныеККТ, Склады.КурьерыИспользуютАвтономныеККТ) КАК КурьерыИспользуютАвтономныеККТ,
		|	ЕСТЬNULL(ИсторияИзменения.ФорматМагазина.ГруппировкаТоваров, Склады.ГруппировкаТоваров) КАК ГруппировкаТоваров
		|ИЗ
		|	Справочник.Склады КАК Склады
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ИсторияИзмененияФорматовМагазинов.СрезПоследних(&Дата, Склад = &Склад) КАК ИсторияИзменения
		|		ПО (ИсторияИзменения.Склад = Склады.Ссылка)
		|ГДЕ
		|	Склады.Ссылка = &Склад
		|	И Склады.ИспользоватьОрдернуюСхемуПриОтгрузке = ЛОЖЬ
		|	И Склады.ЭтоГруппа = ЛОЖЬ";
	
	Запрос.УстановитьПараметр("Склад",Склад);
	Запрос.УстановитьПараметр("Дата",
		?(ЗначениеЗаполнено(Дата),Дата,ТекущаяДатаСеанса()));
		
	УстановитьПривилегированныйРежим(Истина);
	Результат = Запрос.Выполнить();
	УстановитьПривилегированныйРежим(Ложь);
	
	Если Результат.Пустой() Тогда
		Возврат Неопределено;
	Иначе
		Возврат ОбщегоНазначения.СтрокаТаблицыЗначенийВСтруктуру(Результат.Выгрузить()[0]);
	КонецЕсли;
	
КонецФункции

// Получает статусы сборки и доставки заказов необходимых для назначения заказов курьеру. 
//
// Возвращаемое значение:
//  Массив - массив значений статусов.
//
Функция СтатусЗаказаКСборке() Экспорт
	
	Возврат Перечисления.СтатусыСборкиИДоставки.КСборке;
	
КонецФункции

