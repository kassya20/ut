Процедура ЗапланироватьПоступлениеТоваровВнутренний(Запрос, ТекстыЗапроса, Регистры,
		ТекстЗапросаДокумента, ПараметрыМетода, УчитываютсяВДвиженияхУслугиРаботы = Ложь)
	
	СинонимТаблицыДокумента = ПараметрыМетода.СинонимТаблицыДокумента;
	ТребуетсяУчитыватьСерииКОформлениюНакладныхПоРаспоряжению 
		= ПараметрыМетода.ТребуетсяУчитыватьСерииКОформлениюНакладныхПоРаспоряжению;
	ЭтоАктОРасхождениях = ПараметрыМетода.ЭтоАктОРасхождениях;
	
	ТекстыЗапросовВременныхТаблиц = Новый Структура();
	
	ТекстЗапросаВТТовары = 
	"ВЫБРАТЬ
	|	ДанныеДокумента.Ссылка КАК Ссылка,
	|	ДанныеДокумента.Исправление КАК Исправление,
	|	ДанныеДокумента.ИсправляемыйДокумент КАК ИсправляемыйДокумент,
	|	ДанныеДокумента.Заказ КАК Заказ,
	|	ДанныеДокумента.Накладная КАК Накладная,
	|	ДанныеДокумента.Договор КАК Договор,
	|	ДанныеДокумента.Соглашение КАК Соглашение,
	|	ДанныеДокумента.ВариантПриемкиТоваров КАК ВариантПриемкиТоваров,
	|	&ВариантПриемкиУслуг КАК ВариантПриемкиУслуг,
	|	ДанныеДокумента.Отправитель КАК Отправитель,
	|	ДанныеДокумента.ХозяйственнаяОперация КАК ХозяйственнаяОперация,
	|	ДанныеДокумента.СверхЗаказа КАК СверхЗаказа,
	|	ДанныеДокумента.ПоступлениеПоЗаказам КАК ПоступлениеПоЗаказам,
	|	ДанныеДокумента.ЭтоНакладная КАК ЭтоНакладная,
	|	ДанныеДокумента.Дата КАК Дата,
	|	ДанныеДокумента.Номенклатура КАК Номенклатура,
	|	ДанныеДокумента.Характеристика КАК Характеристика,
	|	&Назначение КАК Назначение,
	|	ВЫБОР
	|		КОГДА ДанныеДокумента.ДвижениеРанееПоступившейПартии И ДанныеДокумента.ПроконтролироватьКачество
	|			ТОГДА ДанныеДокумента.КонтролируемаяПартия
	|		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.КонтролируемыеПартии.ПустаяСсылка)
	|	КОНЕЦ КАК КонтролируемаяПартияТоварыКПоступлению,
	|	ДанныеДокумента.СтатусУказанияСерий КАК СтатусУказанияСерий,
	|	ДанныеДокумента.Серия КАК Серия,
	|	ДанныеДокумента.Склад КАК Склад,
	|	СУММА(ДанныеДокумента.Количество) КАК Количество
	|ПОМЕСТИТЬ ВТТоварыЗапланироватьПоступлениеТоваров
	|ИЗ
	|	#ДанныеДокумента КАК ДанныеДокумента
	|
	|СГРУППИРОВАТЬ ПО
	|	ДанныеДокумента.Ссылка,
	|	ДанныеДокумента.Исправление,
	|	ДанныеДокумента.ИсправляемыйДокумент,
	|	ДанныеДокумента.Заказ,
	|	ДанныеДокумента.Накладная,
	|	ДанныеДокумента.Договор,
	|	ДанныеДокумента.Соглашение,
	|	ДанныеДокумента.ВариантПриемкиТоваров,
	|	&ВариантПриемкиУслуг,
	|	ДанныеДокумента.Отправитель,
	|	ДанныеДокумента.ХозяйственнаяОперация,
	|	ДанныеДокумента.СверхЗаказа,
	|	ДанныеДокумента.ПоступлениеПоЗаказам,
	|	ДанныеДокумента.ЭтоНакладная,
	|	ДанныеДокумента.Дата,
	|	ДанныеДокумента.Номенклатура,
	|	ДанныеДокумента.Характеристика,
	|	&Назначение,
	|	ВЫБОР
	|		КОГДА ДанныеДокумента.ДвижениеРанееПоступившейПартии И ДанныеДокумента.ПроконтролироватьКачество
	|			ТОГДА ДанныеДокумента.КонтролируемаяПартия
	|		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.КонтролируемыеПартии.ПустаяСсылка)
	|	КОНЕЦ,
	|	ДанныеДокумента.СтатусУказанияСерий,
	|	ДанныеДокумента.Серия,
	|	ДанныеДокумента.Склад";
	
	ПараметрыЗапроса = ПараметрыТекстаЗапросаДанныхДокумента("ЗапланироватьПоступлениеТоваров", СинонимТаблицыДокумента, 
		УчитываютсяВДвиженияхУслугиРаботы);
	
	ЗаполнитьПараметрыТекстаЗапроса(ТекстЗапросаВТТовары, ПараметрыЗапроса);
	
	Если УчитываютсяВДвиженияхУслугиРаботы Тогда
		ТекстЗапросаВТТовары = СтрЗаменить(ТекстЗапросаВТТовары, "&ВариантПриемкиУслуг", "ДанныеДокумента.ВариантПриемкиУслуг");
	Иначе
		ТекстЗапросаВТТовары = СтрЗаменить(ТекстЗапросаВТТовары, "&ВариантПриемкиУслуг", "НЕОПРЕДЕЛЕНО");
	КонецЕсли;
	
	ТекстЗапросаВТТовары = СтрЗаменить(ТекстЗапросаВТТовары, "ДанныеДокумента", СинонимТаблицыДокумента);
	
	ТекстыЗапросовВременныхТаблиц.Вставить("ВТТоварыЗапланироватьПоступлениеТоваров", ТекстЗапросаВТТовары);
	
	ШаблонТекстаЗапроса =
		"ВЫБРАТЬ
		|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход) КАК ВидДвижения,
		|	ДанныеДокумента.Ссылка                 КАК Регистратор,
		|	ДанныеДокумента.Дата                   КАК Период,
		|	ДанныеДокумента.Заказ                  КАК ДокументПоступления,
		|	ДанныеДокумента.Номенклатура           КАК Номенклатура,
		|	ДанныеДокумента.Характеристика         КАК Характеристика,
		|	&Назначение                            КАК Назначение,
		|	ДанныеДокумента.КонтролируемаяПартияТоварыКПоступлению КАК КонтролируемаяПартия,
		|	ДанныеДокумента.Склад                  КАК Склад,
		|	ДанныеДокумента.Отправитель            КАК Отправитель,
		|	ДанныеДокумента.ХозяйственнаяОперация  КАК ХозяйственнаяОперация,
		|	&СерияКОформлениюНакладныхПоРаспоряжению КАК Серия,
		|	ДанныеДокумента.Количество             КАК КОформлениюНакладныхПоРаспоряжению,
		|	0                                      КАК КОформлениюПоступленийПоРаспоряжению,
		// Не используется, нужно для адаптированного текста.
		|	0                                      КАК КОформлениюПоступленийПоНакладным,
		// Не используется, нужно для адаптированного текста.
		|	0                                      КАК КОформлениюПоступленийПоОрдерам,
		|	0                                      КАК КОформлениюОрдеров
		|ИЗ
		|	ВТТоварыЗапланироватьПоступлениеТоваров КАК ДанныеДокумента
		|	,&ДополнительныеСоединения
		|ГДЕ
		|	НЕ ДанныеДокумента.ЭтоНакладная
		// Избыточное условие для Акта о расхождениях после перемещения.
		|	И НЕ ДанныеДокумента.СверхЗаказа
		|	И ДанныеДокумента.Номенклатура.ТипНоменклатуры В
		|		(ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Товар),
		|		 ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.МногооборотнаяТара))
		|	И ДанныеДокумента.Количество <> 0
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход) КАК ВидДвижения,
		|	ДанныеДокумента.Ссылка                 КАК Регистратор,
		|	ДанныеДокумента.Дата                   КАК Период,
		|	
		|	ВЫБОР
		|		КОГДА ДанныеДокумента.ВариантПриемкиТоваров В(
		|				ЗНАЧЕНИЕ(Перечисление.ВариантыПриемкиТоваров.МожетПроисходитьБезЗаказовИНакладных),
		|				ЗНАЧЕНИЕ(Перечисление.ВариантыПриемкиТоваров.НеРазделенаПоЗаказамИНакладным),
		// только для одноходовки, в двухходовке заказ не делает приход
		|				ЗНАЧЕНИЕ(Перечисление.ВариантыПриемкиТоваров.НеРазделенаПоНакладным))
		|			ТОГДА ДанныеДокумента.Соглашение
		|		КОГДА ДанныеДокумента.ВариантПриемкиТоваров В(
		|				ЗНАЧЕНИЕ(Перечисление.ВариантыПриемкиТоваров.ПоДоговорамБезЗаказовИНакладных),
		|				ЗНАЧЕНИЕ(Перечисление.ВариантыПриемкиТоваров.ПоДоговорамПослеЗаказовИлиНакладных),
		// только для одноходовки, в двухходовке заказ не делает приход
		|				ЗНАЧЕНИЕ(Перечисление.ВариантыПриемкиТоваров.ПоДоговорамПослеНакладных))
		|			ТОГДА ДанныеДокумента.Договор
		|		КОГДА ДанныеДокумента.ВариантПриемкиТоваров В(
		|			ЗНАЧЕНИЕ(Перечисление.ВариантыПриемкиТоваров.РазделенаПоЗаказамИНакладным),
		// только для одноходовки, в двухходовке заказ не делает приход. Особенность, так как движение делает заказ, документом поступления не может быть накладная.
		|			ЗНАЧЕНИЕ(Перечисление.ВариантыПриемкиТоваров.РазделенаТолькоПоНакладным),
		// в некоторых документах поле ВариантПриемкиТоваров не заполнено
		|			ЗНАЧЕНИЕ(Перечисление.ВариантыПриемкиТоваров.ПустаяСсылка),
		// в некоторых документах поля ВариантПриемкиТоваров нет
		|			НЕОПРЕДЕЛЕНО)
		|		ТОГДА ДанныеДокумента.Заказ
		|	КОНЕЦ КАК ДокументПоступления,
		|	
		|	ДанныеДокумента.Номенклатура           КАК Номенклатура,
		|	ДанныеДокумента.Характеристика         КАК Характеристика,
		|	&Назначение                            КАК Назначение,
		|	ДанныеДокумента.КонтролируемаяПартияТоварыКПоступлению КАК КонтролируемаяПартия,
		|	ДанныеДокумента.Склад                  КАК Склад,
		|	ДанныеДокумента.Отправитель            КАК Отправитель,
		|	ДанныеДокумента.ХозяйственнаяОперация  КАК ХозяйственнаяОперация,
		|	ЗНАЧЕНИЕ(Справочник.СерииНоменклатуры.ПустаяСсылка) КАК Серия,
		|	0                                      КАК КОформлениюНакладныхПоРаспоряжению,
		|	ДанныеДокумента.Количество             КАК КОформлениюПоступленийПоРаспоряжению,
		// Не используется, нужно для адаптированного текста.
		|	0                                      КАК КОформлениюПоступленийПоНакладным,
		// Не используется, нужно для адаптированного текста.
		|	0                                      КАК КОформлениюПоступленийПоОрдерам,
		|	0                                      КАК КОформлениюОрдеров
		|ИЗ
		|	ВТТоварыЗапланироватьПоступлениеТоваров КАК ДанныеДокумента
		|	,&ДополнительныеСоединения
		|ГДЕ
		|	ДанныеДокумента.Номенклатура.ТипНоменклатуры В
		|		(ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Товар),
		|		 ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.МногооборотнаяТара))
		|	И НЕ ДанныеДокумента.ЭтоНакладная
		|	И НЕ (&ИспользуетсяДокументПоступлениеТоваров
		|			И (&НакладнаяЯвляетсяРаспоряжением ИЛИ &ПоДоговорамПослеНакладных))
		// Избыточное условие, нужно только для Акта о расхождениях после перемещения.
		|	И НЕ ДанныеДокумента.ПоступлениеПоЗаказам
		|	И ДанныеДокумента.Количество <> 0
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход) КАК ВидДвижения,
		|	ДанныеДокумента.Ссылка                 КАК Регистратор,
		|	ДанныеДокумента.Дата                   КАК Период,
		|	ВЫБОР
		|		КОГДА &ДокументПоступленияОдноходовки <> НЕОПРЕДЕЛЕНО
		|			ТОГДА
		|				&ДокументПоступленияОдноходовки
		|			ИНАЧЕ
		|				ДанныеДокумента.Накладная
		|	КОНЕЦ                                  КАК ДокументПоступления,
		|	ДанныеДокумента.Номенклатура           КАК Номенклатура,
		|	ДанныеДокумента.Характеристика         КАК Характеристика,
		|	&Назначение                            КАК Назначение,
		|	ДанныеДокумента.КонтролируемаяПартияТоварыКПоступлению КАК КонтролируемаяПартия,
		|	ДанныеДокумента.Склад                  КАК Склад,
		|	ДанныеДокумента.Отправитель            КАК Отправитель,
		|	ДанныеДокумента.ХозяйственнаяОперация  КАК ХозяйственнаяОперация,
		|	ЗНАЧЕНИЕ(Справочник.СерииНоменклатуры.ПустаяСсылка) КАК Серия,
		|	0                                      КАК КОформлениюНакладныхПоРаспоряжению,
		|	ДанныеДокумента.Количество             КАК КОформлениюПоступленийПоРаспоряжению,
		// Не используется, нужно для адаптированного текста.
		|	0                                      КАК КОформлениюПоступленийПоНакладным,
		// Не используется, нужно для адаптированного текста.
		|	0                                      КАК КОформлениюПоступленийПоОрдерам,
		|	0                                      КАК КОформлениюОрдеров
		|ИЗ
		|	ВТТоварыЗапланироватьПоступлениеТоваров КАК ДанныеДокумента
		|	,&ДополнительныеСоединения
		|ГДЕ
		|	ДанныеДокумента.Номенклатура.ТипНоменклатуры В
		|		(ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Товар),
		|		 ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.МногооборотнаяТара))
		|	И 
		|		(ДанныеДокумента.ЭтоНакладная
		|		 И &ИспользуетсяДокументПоступлениеТоваров
		|		 И (&НакладнаяЯвляетсяРаспоряжением
		|			ИЛИ ДанныеДокумента.СверхЗаказа
		|			ИЛИ НЕ ДанныеДокумента.ПоступлениеПоЗаказам
		|			ИЛИ &ПоДоговорамПослеНакладных))
		|		ИЛИ
		|		(
		// Для учета ситуации, когда двухходовка используется в документах, где нет специальной второй накладной,
		// например, для Сборки товаров (не по заказу). А так же для накладных не по заказу при одноходовке.
		|		НЕ &ИспользуетсяДокументПоступлениеТоваров
		|		И ДанныеДокумента.ЭтоНакладная
		|		И (ДанныеДокумента.СверхЗаказа
		|			ИЛИ НЕ ДанныеДокумента.ПоступлениеПоЗаказам)
		|		И ДанныеДокумента.Номенклатура.ТипНоменклатуры В
		|				(ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Товар),
		|				 ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.МногооборотнаяТара))
		|		)
		|	И ДанныеДокумента.Количество <> 0
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход) КАК ВидДвижения,
		|	ДанныеДокумента.Ссылка                 КАК Регистратор,
		|	ДанныеДокумента.Дата                   КАК Период,
		|	&ДокументПоступленияОдноходовки        КАК ДокументПоступления,
		|	ДанныеДокумента.Номенклатура           КАК Номенклатура,
		|	ДанныеДокумента.Характеристика         КАК Характеристика,
		|	&Назначение                            КАК Назначение,
		|	ДанныеДокумента.КонтролируемаяПартияТоварыКПоступлению КАК КонтролируемаяПартия,
		|	ДанныеДокумента.Склад                  КАК Склад,
		|	ДанныеДокумента.Отправитель            КАК Отправитель,
		|	ДанныеДокумента.ХозяйственнаяОперация  КАК ХозяйственнаяОперация,
		|	ЗНАЧЕНИЕ(Справочник.СерииНоменклатуры.ПустаяСсылка) КАК Серия,
		|	0                                      КАК КОформлениюНакладныхПоРаспоряжению,
		|	0                                      КАК КОформлениюПоступленийПоРаспоряжению,
		// Не используется, нужно для адаптированного текста.
		|	0                                      КАК КОформлениюПоступленийПоНакладным,
		// Не используется, нужно для адаптированного текста.
		|	0                                      КАК КОформлениюПоступленийПоОрдерам,
		|	ДанныеДокумента.Количество             КАК КОформлениюОрдеров
		|ИЗ
		|	ВТТоварыЗапланироватьПоступлениеТоваров КАК ДанныеДокумента
		|	,&ДополнительныеСоединения
		|ГДЕ
		|	ДанныеДокумента.Номенклатура.ТипНоменклатуры В
		|		(ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Товар),
		|		 ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.МногооборотнаяТара))
		|	И &ИспользуетсяОрдернаяСхемаПриПоступлении
		|	И (НЕ ДанныеДокумента.ЭтоНакладная
		|		И &ДокументПоступленияОдноходовки <> НЕОПРЕДЕЛЕНО
		|		И НЕ &НакладнаяЯвляетсяРаспоряжением
		|	  ИЛИ
		|		ДанныеДокумента.ЭтоНакладная
		|		И (&НакладнаяЯвляетсяРаспоряжением
		|			ИЛИ ДанныеДокумента.СверхЗаказа
		|			ИЛИ НЕ ДанныеДокумента.ПоступлениеПоЗаказам
		|			ИЛИ &ПоДоговорамПослеНакладных)
		// Для акта о расхождениях после перемещения.
		|	  ИЛИ
		|		(
		|			&ЭтоАктОРасхождениях
		|			И НЕ ДанныеДокумента.ЭтоНакладная
		|			И &ДокументПоступленияОдноходовки <> НЕОПРЕДЕЛЕНО
		|			И &НакладнаяЯвляетсяРаспоряжением
		|		)
		|	)
		|	И ДанныеДокумента.Количество <> 0
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		// Работы и услуги
		|ВЫБРАТЬ
		|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход) КАК ВидДвижения,
		|	ДанныеДокумента.Ссылка                 КАК Регистратор,
		|	ДанныеДокумента.Дата                   КАК Период,
		|	ДанныеДокумента.Заказ                  КАК ДокументПоступления,
		|	ДанныеДокумента.Номенклатура           КАК Номенклатура,
		|	ДанныеДокумента.Характеристика         КАК Характеристика,
		|	&Назначение                            КАК Назначение,
		|	ДанныеДокумента.КонтролируемаяПартияТоварыКПоступлению КАК КонтролируемаяПартия,
		|	ДанныеДокумента.Склад                  КАК Склад,
		|	ДанныеДокумента.Отправитель            КАК Отправитель,
		|	ДанныеДокумента.ХозяйственнаяОперация  КАК ХозяйственнаяОперация,
		|	&СерияКОформлениюНакладныхПоРаспоряжению КАК Серия,
		|	ДанныеДокумента.Количество             КАК КОформлениюНакладныхПоРаспоряжению,
		|	0                                      КАК КОформлениюПоступленийПоРаспоряжению,
		// Не используется, нужно для адаптированного текста.
		|	0                                      КАК КОформлениюПоступленийПоНакладным,
		// Не используется, нужно для адаптированного текста.
		|	0                                      КАК КОформлениюПоступленийПоОрдерам,
		|	0                                      КАК КОформлениюОрдеров
		|ИЗ
		|	ВТТоварыЗапланироватьПоступлениеТоваров КАК ДанныеДокумента
		|	,&ДополнительныеСоединения
		|ГДЕ
		|	НЕ ДанныеДокумента.ЭтоНакладная
		// Избыточное условие для Акта о расхождениях после перемещения.
		|	И НЕ ДанныеДокумента.СверхЗаказа
		|	И ДанныеДокумента.Номенклатура.ТипНоменклатуры В
		|		(ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Услуга),
		|		 ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Работа))
		|	И &УчитываютсяВДвиженияхУслугиРаботы
		|	И ДанныеДокумента.Количество <> 0
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход) КАК ВидДвижения,
		|	ДанныеДокумента.Ссылка                 КАК Регистратор,
		|	ДанныеДокумента.Дата                   КАК Период,
		|	ВЫБОР
		|		КОГДА &ДокументПоступленияУслугОдноходовки <> НЕОПРЕДЕЛЕНО
		|			ТОГДА
		|				&ДокументПоступленияУслугОдноходовки
		|			ИНАЧЕ
		|				ДанныеДокумента.Заказ
		|	КОНЕЦ                                  КАК ДокументПоступления,
		|	ДанныеДокумента.Номенклатура           КАК Номенклатура,
		|	ДанныеДокумента.Характеристика         КАК Характеристика,
		|	&Назначение                            КАК Назначение,
		|	ДанныеДокумента.КонтролируемаяПартияТоварыКПоступлению КАК КонтролируемаяПартия,
		|	ДанныеДокумента.Склад                  КАК Склад,
		|	ДанныеДокумента.Отправитель            КАК Отправитель,
		|	ДанныеДокумента.ХозяйственнаяОперация  КАК ХозяйственнаяОперация,
		|	ЗНАЧЕНИЕ(Справочник.СерииНоменклатуры.ПустаяСсылка) КАК Серия,
		|	0                                      КАК КОформлениюНакладныхПоРаспоряжению,
		|	ДанныеДокумента.Количество             КАК КОформлениюПоступленийПоРаспоряжению,
		// Не используется, нужно для адаптированного текста.
		|	0                                      КАК КОформлениюПоступленийПоНакладным,
		// Не используется, нужно для адаптированного текста.
		|	0                                      КАК КОформлениюПоступленийПоОрдерам,
		|	0                                      КАК КОформлениюОрдеров
		|ИЗ
		|	ВТТоварыЗапланироватьПоступлениеТоваров КАК ДанныеДокумента
		|	,&ДополнительныеСоединения
		|ГДЕ
		|	ДанныеДокумента.Номенклатура.ТипНоменклатуры В
		|		(ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Услуга),
		|		 ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Работа))
		|	И &УчитываютсяВДвиженияхУслугиРаботы
		|	И НЕ ДанныеДокумента.ЭтоНакладная
		|	И НЕ &НакладнаяПоУслугамЯвляетсяРаспоряжением
		|	И НЕ &ПоДоговорамДляУслугПослеНакладных
		// Избыточное условие, нужно только для Акта о расхождениях после перемещения.
		|	И НЕ ДанныеДокумента.ПоступлениеПоЗаказам
		|	И ДанныеДокумента.Количество <> 0
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход) КАК ВидДвижения,
		|	ДанныеДокумента.Ссылка                 КАК Регистратор,
		|	ДанныеДокумента.Дата                   КАК Период,
		|	ВЫБОР
		|		КОГДА &ДокументПоступленияУслугОдноходовки <> НЕОПРЕДЕЛЕНО
		|			ТОГДА
		|				&ДокументПоступленияУслугОдноходовки
		|			ИНАЧЕ
		|				ДанныеДокумента.Накладная
		|	КОНЕЦ                                  КАК ДокументПоступления,
		|	ДанныеДокумента.Номенклатура           КАК Номенклатура,
		|	ДанныеДокумента.Характеристика         КАК Характеристика,
		|	&Назначение                            КАК Назначение,
		|	ДанныеДокумента.КонтролируемаяПартияТоварыКПоступлению КАК КонтролируемаяПартия,
		|	ДанныеДокумента.Склад                  КАК Склад,
		|	ДанныеДокумента.Отправитель            КАК Отправитель,
		|	ДанныеДокумента.ХозяйственнаяОперация  КАК ХозяйственнаяОперация,
		|	ЗНАЧЕНИЕ(Справочник.СерииНоменклатуры.ПустаяСсылка) КАК Серия,
		|	0                                      КАК КОформлениюНакладныхПоРаспоряжению,
		|	ДанныеДокумента.Количество             КАК КОформлениюПоступленийПоРаспоряжению,
		// Не используется, нужно для адаптированного текста.
		|	0                                      КАК КОформлениюПоступленийПоНакладным,
		// Не используется, нужно для адаптированного текста.
		|	0                                      КАК КОформлениюПоступленийПоОрдерам,
		|	0                                      КАК КОформлениюОрдеров
		|ИЗ
		|	ВТТоварыЗапланироватьПоступлениеТоваров КАК ДанныеДокумента
		|	,&ДополнительныеСоединения
		|ГДЕ
		|	ДанныеДокумента.Номенклатура.ТипНоменклатуры В
		|		(ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Работа),
		|		 ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Услуга))
		|	И &УчитываютсяВДвиженияхУслугиРаботы
		|	И 
		|		(ДанныеДокумента.ЭтоНакладная
		|		 И (&НакладнаяПоУслугамЯвляетсяРаспоряжением
		|			ИЛИ ДанныеДокумента.СверхЗаказа
		|			ИЛИ НЕ ДанныеДокумента.ПоступлениеПоЗаказам
		|			ИЛИ &ПоДоговорамДляУслугПослеНакладных))
		|	И ДанныеДокумента.Количество <> 0
		|";
	
	Если Не ТребуетсяУчитыватьСерииКОформлениюНакладныхПоРаспоряжению Тогда
		ШаблонТекстаЗапроса = СтрЗаменить(ШаблонТекстаЗапроса, "&СерияКОформлениюНакладныхПоРаспоряжению",
			"ЗНАЧЕНИЕ(Справочник.СерииНоменклатуры.ПустаяСсылка)");
	КонецЕсли;
	Если ЭтоАктОРасхождениях Тогда
		ШаблонТекстаЗапроса = СтрЗаменить(ШаблонТекстаЗапроса, "&ЭтоАктОРасхождениях",
			"ИСТИНА");
	Иначе
		ШаблонТекстаЗапроса = СтрЗаменить(ШаблонТекстаЗапроса, "&ЭтоАктОРасхождениях",
			"ЛОЖЬ");
	КонецЕсли;
	
	ШаблонТекстаЗапроса = СтрЗаменить(ШаблонТекстаЗапроса, "ДанныеДокумента", СинонимТаблицыДокумента);
	
	Если УчитываютсяВДвиженияхУслугиРаботы Тогда
		
		ТекстУсловияОтраженияРаботИУслуг = 
		"(ДанныеДокумента.Договор.ВариантОформленияДокументовПоступленияПоУслугам В (ЗНАЧЕНИЕ(Перечисление.ВариантыОформленияДокументовПоУслугам.ПоступлениеУслугФактурируется), 
		|	ЗНАЧЕНИЕ(Перечисление.ВариантыОформленияДокументовПоУслугам.ПоступлениеУслугСторнируется))
		|	И ДанныеДокумента.ХозяйственнаяОперация В (ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.ЗакупкаУПоставщикаФактуровкаПоставки),
		|										ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.ЗакупкаВСтранахЕАЭСФактуровкаПоставки)))";
		ТекстУсловияОтраженияРаботИУслуг = СтрЗаменить(ТекстУсловияОтраженияРаботИУслуг, "ДанныеДокумента", СинонимТаблицыДокумента);
		
		ПараметрыЗапроса.Вставить("УчитываютсяВДвиженияхУслугиРаботы", ТекстУсловияОтраженияРаботИУслуг);
		
	Иначе
		
		ПараметрыЗапроса.Вставить("УчитываютсяВДвиженияхУслугиРаботы", "ЛОЖЬ");
		
	КонецЕсли;
	
	ЗаполнитьПараметрыТекстаЗапроса(ШаблонТекстаЗапроса, ПараметрыЗапроса);
	
	ТекстыШаблоновОтражения = Новый Структура();
	
	Если ПроведениеДокументов.ТребуетсяТаблицаДляДвижений("ТоварыКПоступлению", Регистры) Тогда
		ТекстыШаблоновОтражения.Вставить("ТоварыКПоступлению", ШаблонТекстаЗапроса);
	КонецЕсли;

	ТекстыЗапросовДанныхДокумента = Новый Структура(СинонимТаблицыДокумента, ТекстЗапросаДокумента);
	ПроведениеДокументов.ДополнитьЗапросОтраженияДокумента(Запрос, ТекстыЗапроса, ТекстыШаблоновОтражения, ТекстыЗапросовДанныхДокумента, ТекстыЗапросовВременныхТаблиц);

КонецПроцедуры

Процедура ОформитьПоступлениеТоваровПоДвухходовкеВнутренний(Запрос,
													ТекстыЗапроса,
													Регистры,
													ТекстЗапросаДокумента,
													ОбъектМетаданных,
													ПараметрыМетода,
													ТребуетсяОтборПоОрдерностиСкладаПриПоступлении = Ложь)
	
	ИмяТЧСерии = ПараметрыМетода.ИмяТЧСерии;
	СинонимТаблицыДокумента = ПараметрыМетода.СинонимТаблицыДокумента;
	УчитываютсяВДвиженияхУслугиРаботы = ПараметрыМетода.УчитываютсяВДвиженияхУслугиРаботы;
	
	Если ИмяТЧСерии <> "" Тогда
		
		ШаблонТекстаЗапросаТоварыНаСкладах =
		"ВЫБРАТЬ
		|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход) КАК ВидДвижения,
		|	ДанныеДокумента.Ссылка                 КАК Регистратор,
		|	ДанныеДокумента.Дата                   КАК Период,
		|	ДанныеДокумента.Номенклатура           КАК Номенклатура,
		|	ДанныеДокумента.Характеристика         КАК Характеристика,
		|	&Назначение                            КАК Назначение,
		|	ВЫБОР
		|		КОГДА ДанныеДокумента.ПроконтролироватьКачество
		|			ТОГДА ДанныеДокумента.КонтролируемаяПартия
		|		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.КонтролируемыеПартии.ПустаяСсылка)
		|	КОНЕЦ КАК КонтролируемаяПартия,
		|	ВЫБОР
		|		КОГДА ДанныеДокумента.СтатусУказанияСерийНаСкладах В(4, 6, 8, 10, 14)
		|			ТОГДА ДанныеДокумента.Серия
		|		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.СерииНоменклатуры.ПустаяСсылка)
		|	КОНЕЦ                                  КАК Серия,
		|	ДанныеДокумента.Склад                  КАК Склад,
		|	ЗНАЧЕНИЕ(Справочник.СкладскиеПомещения.ПустаяСсылка) КАК Помещение,
		|	ДанныеДокумента.Количество             КАК ВНаличии,
		|	0                                      КАК КОтгрузке,
		|	ЛОЖЬ                                   КАК КонтролироватьОстатки
		|ИЗ
		|	#ДанныеДокумента КАК ДанныеДокумента
		|ГДЕ
		|	НЕ (&ИспользуетсяОрдернаяСхемаПриПоступлении)
		|	И (НЕ ДанныеДокумента.СтатусУказанияСерийНаСкладах В(4, 6, 8, 10)
		|		ИЛИ ДанныеДокумента.Серия <> ЗНАЧЕНИЕ(Справочник.СерииНоменклатуры.ПустаяСсылка))
		|	И ДанныеДокумента.Номенклатура.ТипНоменклатуры В
		|			(ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Товар),
		|			 ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.МногооборотнаяТара))
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход) КАК ВидДвижения,
		|	ДанныеДокумента.Ссылка                 КАК Регистратор,
		|	ДанныеДокумента.Дата                   КАК Период,
		|	ДанныеДокумента.Номенклатура           КАК Номенклатура,
		|	ДанныеДокумента.Характеристика         КАК Характеристика,
		|	&Назначение                            КАК Назначение,
		|	ВЫБОР
		|		КОГДА ДанныеДокумента.ПроконтролироватьКачество
		|			ТОГДА ДанныеДокумента.КонтролируемаяПартия
		|		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.КонтролируемыеПартии.ПустаяСсылка)
		|	КОНЕЦ КАК КонтролируемаяПартия,
		|	ВЫБОР
		|		КОГДА ДанныеДокумента.СтатусУказанияСерийНаСкладах В(4, 6, 8, 10)
		|			ТОГДА &Серия
		|		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.СерииНоменклатуры.ПустаяСсылка)
		|	КОНЕЦ                                  КАК Серия,
		|	ДанныеДокумента.Склад                  КАК Склад,
		|	ЗНАЧЕНИЕ(Справочник.СкладскиеПомещения.ПустаяСсылка) КАК Помещение,
		|	МАКСИМУМ(&Количество)                  КАК ВНаличии,
		|	0                                      КАК КОтгрузке,
		|	ЛОЖЬ                                   КАК КонтролироватьОстатки
		|ИЗ
		|	#ДанныеДокумента КАК ДанныеДокумента
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ &ИмяТЧСерии КАК ДанныеСерий
		|		ПО ДанныеДокумента.Ссылка = ДанныеСерий.Ссылка
		|			И &УсловиеСоединенияТаблиц
		|
		|ГДЕ
		|	НЕ (&ИспользуетсяОрдернаяСхемаПриПоступлении)
		|	И ДанныеДокумента.Серия = ЗНАЧЕНИЕ(Справочник.СерииНоменклатуры.ПустаяСсылка)
		|	И ДанныеДокумента.Номенклатура.ТипНоменклатуры В
		|			(ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Товар),
		|			 ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.МногооборотнаяТара))
		|
		|СГРУППИРОВАТЬ ПО
		|	ДанныеСерий.НомерСтроки,
		|	ДанныеДокумента.Ссылка,
		|	ДанныеДокумента.Дата,
		|	ДанныеДокумента.Номенклатура,
		|	ДанныеДокумента.Характеристика,
		|	ДанныеДокумента.СтатусУказанияСерийНаСкладах,
		|	&Назначение,
		|	ВЫБОР
		|		КОГДА ДанныеДокумента.ПроконтролироватьКачество
		|			ТОГДА ДанныеДокумента.КонтролируемаяПартия
