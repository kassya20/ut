Процедура ДобавитьДанныеОписанияКодовМаркировки(ДанныеШаблонаКодаМаркировки, СписокШаблонов, Параметры, ОчищатьПараметры = Истина)
	
	Если СписокШаблонов.Количество() > 0 Тогда
		
		ТипШтрихкодаИВидУпаковки = РазборКодаМаркировкиИССлужебныйКлиентСервер.ТипШтрихкодаИВидУпаковки();
		ТипШтрихкодаИВидУпаковки.ТипШтрихкода = ДанныеШаблонаКодаМаркировки.ТипШтрихкода;
		ТипШтрихкодаИВидУпаковки.ВидУпаковки  = ВидУпаковкиПоТипуКодаМаркировки(ДанныеШаблонаКодаМаркировки.ТипКодаМаркировки);
		
		СоставКодаМаркировки = РазборКодаМаркировкиИСМПСлужебныйКлиентСервер.НовыйСоставКодаМаркировки(ТипШтрихкодаИВидУпаковки);
		СоставКодаМаркировки.ВключаетИдентификаторыПрименения = Параметры.ВключаетИдентификаторыПрименения;
		СоставКодаМаркировки.Вставить("ВключаетКриптоХвост", Ложь);
		
		Если Параметры.ЕстьМРЦ Тогда
			СоставКодаМаркировки.Вставить("ВключаетМРЦ", Ложь);
			СоставКодаМаркировки.Вставить("МРЦ",         0);
			СоставКодаМаркировки.Вставить("МРЦСтрокой",  "");
		КонецЕсли;
		
		Если Параметры.ЕстьВес Тогда
			СоставКодаМаркировки.Вставить("МассаНеттоВКг", Неопределено);
		КонецЕсли;
		
		Если Параметры.ЕстьОбъем Тогда
			СоставКодаМаркировки.Вставить("ОбъемВЛитрах", Неопределено);
		КонецЕсли;
		
		Если Параметры.ЕстьКодТНВЭД Тогда
			СоставКодаМаркировки.Вставить("КодТНВЭД", "");
		КонецЕсли;
		
		НастройкаОписанияКодаМаркировки = РазборКодаМаркировкиИССлужебный.НастройкиОписанияШаблонаКодаМаркировкиВидаПродукции();
		НастройкаОписанияКодаМаркировки.ВидПродукции             = Параметры.ВидПродукции;
		НастройкаОписанияКодаМаркировки.ДанныеОбщегоМодуля       = Параметры.ДанныеОбщегоМодуля;
		НастройкаОписанияКодаМаркировки.ТипШтрихкодаИВидУпаковки = ТипШтрихкодаИВидУпаковки;
		НастройкаОписанияКодаМаркировки.СоставКодаМаркировки     = СоставКодаМаркировки;
		НастройкаОписанияКодаМаркировки.СписокШаблонов           = СписокШаблонов;
		
		Параметры.ДанныеОписанийКодаМаркировки.ОписанияКодовМаркировки.Добавить(НастройкаОписанияКодаМаркировки);
		
	КонецЕсли;
	
	СписокШаблонов = Новый Массив;
	Если ОчищатьПараметры Тогда
		Параметры.ВключаетИдентификаторыПрименения = Истина;
		Параметры.ЕстьМРЦ            = Ложь;
		Параметры.ЕстьВес            = Ложь;
		Параметры.ЕстьКодТНВЭД       = Ложь;
	КонецЕсли;
	
КонецПроцедуры

Функция ВидУпаковкиПоТипуКодаМаркировки(ТипКодаМаркировки)
	
	Если ТипКодаМаркировки = Перечисления.ТипыКодовМаркировкиИСМП.ГрупповаяУпаковка Тогда
		Возврат Перечисления.ВидыУпаковокИС.Групповая;
	ИначеЕсли ТипКодаМаркировки = Перечисления.ТипыКодовМаркировкиИСМП.Набор Тогда
		Возврат Перечисления.ВидыУпаковокИС.Набор;
	Иначе
		Возврат Перечисления.ВидыУпаковокИС.Потребительская;
	КонецЕсли;
	
КонецФункции

#КонецОбласти

#Область ОписаниеКодаМаркировки

Процедура ОписаниеКодаМаркировкиПродукцииИзНатуральногоМеха(ДанныеОписанийКодаМаркировки, ВидПродукции, ДанныеОбщегоМодуля)

	// Шаблон: (RU|AM|BY|KZ|KG)[-]{1}[A-Z0-9]{6}[-]{1}[A-Z0-9]{10}

	Алфавит = ДанныеОписанийКодаМаркировки.Алфавит;

	ОписаниеЭлементовКМ = Новый Структура("КодСтраны, Секция6, Секция10, Разделитель1, Разделитель2");

	ОписаниеЭлементовКМ.КодСтраны    = РазборКодаМаркировкиИССлужебный.ОписаниеЭлементаКодаМаркировки("", "КодСтраны",    2);
	ОписаниеЭлементовКМ.Секция6      = РазборКодаМаркировкиИССлужебный.ОписаниеЭлементаКодаМаркировки("", "Секция6",      6, Алфавит.БуквыПрописныеЦифры);
	ОписаниеЭлементовКМ.Секция10     = РазборКодаМаркировкиИССлужебный.ОписаниеЭлементаКодаМаркировки("", "Секция10",    10, Алфавит.БуквыПрописныеЦифры);
	ОписаниеЭлементовКМ.Разделитель1 = РазборКодаМаркировкиИССлужебный.ОписаниеЭлементаКодаМаркировки("", "Разделитель1",  1, "-");
	ОписаниеЭлементовКМ.Разделитель2 = РазборКодаМаркировкиИССлужебный.ОписаниеЭлементаКодаМаркировки("", "Разделитель2",  1, "-");

	ШаблоныСтрокой = Новый Массив;
	ШаблоныСтрокой.Добавить("КодСтраны + Разделитель1 + Секция6 + Разделитель2 + Секция10");

	СписокШаблонов = РазборКодаМаркировкиИССлужебный.ОписанияШаблоновКодаМаркировки(ОписаниеЭлементовКМ, ШаблоныСтрокой);

	ТипШтрихкодаИВидУпаковки = РазборКодаМаркировкиИССлужебныйКлиентСервер.ТипШтрихкодаИВидУпаковки();
	ТипШтрихкодаИВидУпаковки.ТипШтрихкода = Перечисления.ТипыШтрихкодов.Code128;
	ТипШтрихкодаИВидУпаковки.ВидУпаковки  = Перечисления.ВидыУпаковокИС.Потребительская;

	СоставКодаМаркировки = РазборКодаМаркировкиИСМПСлужебныйКлиентСервер.НовыйСоставКодаМаркировки(ТипШтрихкодаИВидУпаковки);

	// Добавление настроек
	НастройкаОписанияКодаМаркировки = РазборКодаМаркировкиИССлужебный.НастройкиОписанияШаблонаКодаМаркировкиВидаПродукции();
	НастройкаОписанияКодаМаркировки.ВидПродукции             = ВидПродукции;
	НастройкаОписанияКодаМаркировки.ТипШтрихкодаИВидУпаковки = ТипШтрихкодаИВидУпаковки;
	НастройкаОписанияКодаМаркировки.СоставКодаМаркировки     = СоставКодаМаркировки;
	НастройкаОписанияКодаМаркировки.ДанныеОбщегоМодуля       = ДанныеОбщегоМодуля;
	НастройкаОписанияКодаМаркировки.СписокШаблонов           = СписокШаблонов;

	ДанныеОписанийКодаМаркировки.ОписанияКодовМаркировки.Добавить(НастройкаОписанияКодаМаркировки);

КонецПроцедуры

