Функция ДанныеШаблоновКодаМаркировки(ВидыПродукции)
	
	Результат = Новый Соответствие;
	
	ДанныеЭлемента = КонструкторИСОбщегоНазначенияКлиентСервер.ДанныеЭлементаКонструктора(
		Справочники.ЭлементыКонструктораВидовПродукцииИС.ТоварныеГруппыГИСМТ);
	
	ТаблицаВидовПродукции = Новый ТаблицаЗначений;
	ТаблицаВидовПродукции.Колонки.Добавить("ВидПродукции",   Новый ОписаниеТипов("СправочникСсылка.ВидыПродукцииИС"));
	ТаблицаВидовПродукции.Колонки.Добавить("ТоварнаяГруппа", Новый ОписаниеТипов("СправочникСсылка.ТоварныеГруппыГИСМТ"));
	Для Каждого ВидПродукции Из ВидыПродукции Цикл
		Значения = ДанныеЭлемента.ВидыПродукции[ВидПродукции];
		Если Значения <> Неопределено Тогда
			Для Каждого КлючИЗначение Из Значения Цикл
				Строка = ТаблицаВидовПродукции.Добавить();
				Строка.ВидПродукции   = ВидПродукции;
				Строка.ТоварнаяГруппа = КлючИЗначение.Ключ;
			КонецЦикла;
		КонецЕсли;
	КонецЦикла;
		
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ТаблицаВидовПродукции", ТаблицаВидовПродукции);
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ТаблицаВидовПродукции.ВидПродукции КАК ВидПродукции,
	|	ТаблицаВидовПродукции.ТоварнаяГруппа КАК ТоварнаяГруппа
	|ПОМЕСТИТЬ ТаблицаВидовПродукции
	|ИЗ
	|	&ТаблицаВидовПродукции КАК ТаблицаВидовПродукции
	|;
	|ВЫБРАТЬ
	|	ТаблицаВидовПродукции.ВидПродукции КАК ВидПродукции,
	|	ШаблоныКодовМаркировкиСУЗ.Ссылка КАК ШаблонКодаМаркировки,
	|	ШаблоныРазбораКодовМаркировкиИСМП.Ссылка КАК ШаблонРазбораКодаМаркировки,
	|	ШаблоныКодовМаркировкиСУЗ.ТипКодаМаркировки КАК ТипКодаМаркировки,
	|	ШаблоныКодовМаркировкиСУЗ.ТипШтрихкода КАК ТипШтрихкода,
	|	ВЫБОР
	|		КОГДА ШаблоныРазбораКодовМаркировкиИСМП.ДлинаСерийногоНомера > 0
	|			ТОГДА ШаблоныРазбораКодовМаркировкиИСМП.ДлинаСерийногоНомера
	|		ИНАЧЕ ШаблоныКодовМаркировкиСУЗ.ДлинаСерийногоНомера
	|	КОНЕЦ КАК ДлинаСерийногоНомера,
	|	ШаблоныРазбораКодовМаркировкиИСМП.ИдентификаторыПримененияОтсутствуют КАК ИдентификаторыПримененияОтсутствуют,
	|	СоставКодаМаркировкиТаблица.ЭлементСоставаКодаМаркировки КАК ЭлементСоставаКодаМаркировки
	|ИЗ
	|	ТаблицаВидовПродукции КАК ТаблицаВидовПродукции
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ШаблоныКодовМаркировкиСУЗ КАК ШаблоныКодовМаркировкиСУЗ
	|		ПО ТаблицаВидовПродукции.ТоварнаяГруппа = ШаблоныКодовМаркировкиСУЗ.ТоварнаяГруппа
	|			И НЕ ШаблоныКодовМаркировкиСУЗ.Архивный
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ШаблоныКодовМаркировкиСУЗ.ШаблоныРазбораКодовМаркировки КАК
	|			ШаблоныКодовМаркировкиТаблица
	|		ПО ШаблоныКодовМаркировкиСУЗ.Ссылка = ШаблоныКодовМаркировкиТаблица.Ссылка
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ШаблоныРазбораКодовМаркировкиИСМП КАК ШаблоныРазбораКодовМаркировкиИСМП
	|		ПО ШаблоныКодовМаркировкиТаблица.ШаблонРазбораКодовМаркировки = ШаблоныРазбораКодовМаркировкиИСМП.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ШаблоныРазбораКодовМаркировкиИСМП.СоставКодаМаркировки КАК СоставКодаМаркировкиТаблица
	|		ПО ШаблоныРазбораКодовМаркировкиИСМП.Ссылка = СоставКодаМаркировкиТаблица.Ссылка
	|
	|УПОРЯДОЧИТЬ ПО
	|	ВидПродукции,
	|	ШаблонКодаМаркировки,
	|	ШаблонРазбораКодаМаркировки,
	|	СоставКодаМаркировкиТаблица.НомерСтроки";
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	ТекущийВидПродукции                = Неопределено;
	ТекущийШаблонКодаМаркировки        = Неопределено;
	ТекущийШаблонРазбораКодаМаркировки = Неопределено;
	
	Пока Выборка.Следующий() Цикл
		
		Если Выборка.ВидПродукции <> ТекущийВидПродукции Тогда
			Результат.Вставить(Выборка.ВидПродукции, ТаблицаШаблоновКодаМаркировки());
			Данные = Результат[Выборка.ВидПродукции];
			ТекущийВидПродукции = Выборка.ВидПродукции;
		КонецЕсли;
		
		Если Выборка.ШаблонКодаМаркировки <> ТекущийШаблонКодаМаркировки
			Или Выборка.ШаблонРазбораКодаМаркировки <> ТекущийШаблонРазбораКодаМаркировки Тогда
			СтрокаДанных = Данные.Добавить();
			ЗаполнитьЗначенияСвойств(СтрокаДанных, Выборка);
			ТекущийШаблонКодаМаркировки        = Выборка.ШаблонКодаМаркировки;
			ТекущийШаблонРазбораКодаМаркировки = Выборка.ШаблонРазбораКодаМаркировки;
		КонецЕсли;
		
		Если ЗначениеЗаполнено(Выборка.ЭлементСоставаКодаМаркировки) Тогда
			СтрокаДанных.СоставКодаМаркировки.Добавить(Выборка.ЭлементСоставаКодаМаркировки);
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Функция ТаблицаШаблоновКодаМаркировки()
	
	Результат = Новый ТаблицаЗначений;
	Результат.Колонки.Добавить("ШаблонКодаМаркировки",                Новый ОписаниеТипов("СправочникСсылка.ШаблоныКодовМаркировкиСУЗ"));
	Результат.Колонки.Добавить("ШаблонРазбораКодаМаркировки",         Новый ОписаниеТипов("СправочникСсылка.ШаблоныРазбораКодовМаркировкиИСМП"));
	Результат.Колонки.Добавить("ТипКодаМаркировки",                   Новый ОписаниеТипов("ПеречислениеСсылка.ТипыКодовМаркировкиИСМП"));
