#Область СлужебныйПрограммныйИнтерфейс

#Область НастройкиРазбораКодаМаркировки

Процедура ДополнитьОписанияКодовМаркировки(ДанныеОписанийКодаМаркировки, НастройкиРазбораКодаМаркировки, МодулиПодсистемы) Экспорт
	
	ДанныеШаблоновКодаМаркировки = ДанныеШаблоновКодаМаркировки(НастройкиРазбораКодаМаркировки.ДоступныеВидыПродукции);
	
	Параметры = Новый Структура;
	Параметры.Вставить("ДанныеОписанийКодаМаркировки", ДанныеОписанийКодаМаркировки);
	Параметры.Вставить("ДанныеОбщегоМодуля",           МодулиПодсистемы.Разбор);
	
	Параметры.Вставить("ВключаетИдентификаторыПрименения", Истина);
	Параметры.Вставить("ЕстьМРЦ",            Ложь);
	Параметры.Вставить("ЕстьВес",            Ложь);
	Параметры.Вставить("ЕстьОбъем",          Ложь);
	Параметры.Вставить("ЕстьКодТНВЭД",       Ложь);
	Параметры.Вставить("ЕстьЗаводскойSN",    Ложь);
	Параметры.Вставить("ЕстьПроизвольныеAI", Ложь);
	
	СписокШаблонов = Новый Массив;
	
	ОписанияЭлементовКодовМаркировки = ОписанияЭлементовКодовМаркировки(Параметры.ДанныеОписанийКодаМаркировки.Алфавит);
	
	Для Каждого КлючИЗначение Из ДанныеШаблоновКодаМаркировки Цикл
		
		ВидПродукции = КлючИЗначение.Ключ;
		ТаблицаШаблоновКодаМаркировки = КлючИЗначение.Значение;
		
		Параметры.Вставить("ВидПродукции", ВидПродукции);
		
		ИндексПоследнейСтроки = ТаблицаШаблоновКодаМаркировки.Количество() - 1;
		
		Для Каждого ДанныеШаблонаКодаМаркировки Из ТаблицаШаблоновКодаМаркировки Цикл
			
			ЭлементыСпискаШаблонов = Новый Массив;
			
			Если ДанныеШаблонаКодаМаркировки.ИдентификаторыПримененияОтсутствуют Тогда
				Параметры.ВключаетИдентификаторыПрименения = Ложь;
			КонецЕсли;
			
			Если ДанныеШаблонаКодаМаркировки.ШаблонРазбораКодаМаркировки = Справочники.ШаблоныРазбораКодовМаркировкиИСМП.ИзделияИзМеха Тогда
				ОписаниеКодаМаркировкиПродукцииИзНатуральногоМеха(Параметры.ДанныеОписанийКодаМаркировки, ВидПродукции, Параметры.ДанныеОбщегоМодуля);
				ДобавитьБуквенныеКодыСтранДляПродукцииИзНатуральногоМеха(НастройкиРазбораКодаМаркировки, МодулиПодсистемы);
				Продолжить;
			Иначе
				Для Каждого ЭлементСоставаКодаМаркировки Из ДанныеШаблонаКодаМаркировки.СоставКодаМаркировки Цикл
					
					Если ЭлементСоставаКодаМаркировки = Перечисления.ЭлементыСоставаКодаМаркировкиИСМП.МРЦ4
						Или ЭлементСоставаКодаМаркировки = Перечисления.ЭлементыСоставаКодаМаркировкиИСМП.МРЦ6 Тогда
						Параметры.ЕстьМРЦ = Истина;
					ИначеЕсли ЭлементСоставаКодаМаркировки = Перечисления.ЭлементыСоставаКодаМаркировкиИСМП.Вес6 Тогда
						Параметры.ЕстьВес = Истина;
					ИначеЕсли ЭлементСоставаКодаМаркировки = Перечисления.ЭлементыСоставаКодаМаркировкиИСМП.Объем6 Тогда
						Параметры.ЕстьОбъем = Истина;
					ИначеЕсли ЭлементСоставаКодаМаркировки = Перечисления.ЭлементыСоставаКодаМаркировкиИСМП.КодТНВЭД4
						Или ЭлементСоставаКодаМаркировки = Перечисления.ЭлементыСоставаКодаМаркировкиИСМП.КодТНВЭД8
						Или ЭлементСоставаКодаМаркировки = Перечисления.ЭлементыСоставаКодаМаркировкиИСМП.КодТНВЭД10 Тогда
						Параметры.ЕстьКодТНВЭД = Истина;
					КонецЕсли;
					
					Если ЭлементСоставаКодаМаркировки = Перечисления.ЭлементыСоставаКодаМаркировкиИСМП.ЗаводскойSN Тогда
						Параметры.ЕстьЗаводскойSN = Истина;
					ИначеЕсли ЭлементСоставаКодаМаркировки = Перечисления.ЭлементыСоставаКодаМаркировкиИСМП.ПроизвольныеAI Тогда
						Параметры.ЕстьПроизвольныеAI = Истина;
					Иначе
						ОписаниеЭлементаКодовМаркировки = ОписанияЭлементовКодовМаркировки[ЭлементСоставаКодаМаркировки];
						Если ОписаниеЭлементаКодовМаркировки <> Неопределено Тогда
							Если ЭлементСоставаКодаМаркировки = Перечисления.ЭлементыСоставаКодаМаркировкиИСМП.СерийныйНомер Тогда
								Длина = ДанныеШаблонаКодаМаркировки.ДлинаСерийногоНомера;
							Иначе
								Длина = ОписаниеЭлементаКодовМаркировки.Длина;
							КонецЕсли;
							Если Параметры.ВключаетИдентификаторыПрименения Тогда
								Код = ОписаниеЭлементаКодовМаркировки.Код;
							Иначе
								Код = "";
							КонецЕсли;
							ЭлементыСпискаШаблонов.Добавить(
								РазборКодаМаркировкиИССлужебный.ОписаниеЭлементаКодаМаркировки(
									Код,
									ОписаниеЭлементаКодовМаркировки.Имя,
									Длина,
									ОписаниеЭлементаКодовМаркировки.Алфавит));
						КонецЕсли;
					КонецЕсли;
					
				КонецЦикла;
			КонецЕсли;
			
			Если ЭлементыСпискаШаблонов.Количество() > 0 Тогда
				
				Если Параметры.ЕстьЗаводскойSN
					Или Параметры.ЕстьПроизвольныеAI Тогда
					Если Параметры.ЕстьЗаводскойSN Тогда
						ИмяШаблона = "ЗаводскойSN";
					Иначе
						ИмяШаблона = "ПроизвольныеAI";
					КонецЕсли;
					ШаблоныНеФормализованныхКодовМаркировки = РазборКодаМаркировкиИСМПСлужебныйКлиентСервер.ШаблоныНеФормализованныхКодовМаркировки(
						НастройкиРазбораКодаМаркировки, МодулиПодсистемы.Подсистема, ИмяШаблона);
					ДанныеШаблонаКМ = РазборКодаМаркировкиИССлужебный.ОписаниеЭлементовШаблонаКодаМаркировкиВСтруктуру(
						НастройкиРазбораКодаМаркировки, ЭлементыСпискаШаблонов);
					ДанныеШаблонаКМ.Вставить("ВидПродукции", ВидПродукции);
					ДанныеШаблонаКМ.Вставить("ТипШтрихкода", ДанныеШаблонаКодаМаркировки.ТипШтрихкода);
					ДанныеШаблонаКМ.Вставить("ВидУпаковки",  ВидУпаковкиПоТипуКодаМаркировки(ДанныеШаблонаКодаМаркировки.ТипКодаМаркировки));
					ШаблоныНеФормализованныхКодовМаркировки.Добавить(ДанныеШаблонаКМ);
					Параметры.ЕстьЗаводскойSN = Ложь;
					Параметры.ЕстьПроизвольныеAI = Ложь;
				КонецЕсли;
				
				Если Параметры.ЕстьОбъем Тогда
					СписокШаблоновКопия = Новый Массив;
					Для Счетчик = 0 По 5 Цикл
						ЭлементыСпискаШаблоновСОбъемом = Новый Массив;
						Для Каждого ЭлементСписка Из ЭлементыСпискаШаблонов Цикл
							Если ЭлементСписка.Код = "335Y" Тогда
								Код = СтрЗаменить(ЭлементСписка.Код, "Y", Счетчик);
							Иначе
								Код = ЭлементСписка.Код;
							КонецЕсли;
							ЭлементыСпискаШаблоновСОбъемом.Добавить(
								РазборКодаМаркировкиИССлужебный.ОписаниеЭлементаКодаМаркировки(
									Код,
									ЭлементСписка.Имя,
									ЭлементСписка.Длина,
									ЭлементСписка.Алфавит));
						КонецЦикла;
						СписокШаблоновКопия.Добавить(ЭлементыСпискаШаблоновСОбъемом);
					КонецЦикла;
					ДобавитьДанныеОписанияКодовМаркировки(ДанныеШаблонаКодаМаркировки, СписокШаблоновКопия, Параметры, Ложь);
					Параметры.ЕстьОбъем = Ложь;
				Иначе
					СписокШаблонов.Добавить(ЭлементыСпискаШаблонов);
				КонецЕсли;
				
			КонецЕсли;
			
			ИндексТекущейСтроки = ТаблицаШаблоновКодаМаркировки.Индекс(ДанныеШаблонаКодаМаркировки);
			ЭтоПоследняяСтрока = ИндексТекущейСтроки = ИндексПоследнейСтроки;
			
			Если ЭтоПоследняяСтрока
				Или ДанныеШаблонаКодаМаркировки.ШаблонКодаМаркировки <> ТаблицаШаблоновКодаМаркировки[ИндексТекущейСтроки+1].ШаблонКодаМаркировки Тогда
				ДобавитьДанныеОписанияКодовМаркировки(ДанныеШаблонаКодаМаркировки, СписокШаблонов, Параметры);
			КонецЕсли;
			
		КонецЦикла;
		
		Если КонструкторИСМПОбщегоНазначенияКлиентСервер.ИспользуетсяSSCC18(ВидПродукции) Тогда
			ОписаниеКодаМаркировкиЛогистическаяУпаковка18(Параметры.ДанныеОписанийКодаМаркировки, ВидПродукции, Параметры.ДанныеОбщегоМодуля);
		КонецЕсли;
		
		Если КонструкторИСМПОбщегоНазначенияКлиентСервер.ИспользуетсяSSCC20(ВидПродукции) Тогда
			ОписаниеКодаМаркировкиЛогистическаяУпаковка20(Параметры.ДанныеОписанийКодаМаркировки, ВидПродукции, Параметры.ДанныеОбщегоМодуля);
		КонецЕсли;
		
		Если КонструкторИСМПОбщегоНазначенияКлиентСервер.ИспользуетсяАТК(ВидПродукции) Тогда
			ОписаниеАгрегированногоТаможенногоКода(Параметры.ДанныеОписанийКодаМаркировки, ВидПродукции, Параметры.ДанныеОбщегоМодуля);
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

Процедура ДополнитьВспомогательнымиНастройкиРазбораКодаМаркировки(НастройкиРазбораКодаМаркировки, МодулиПодсистемы) Экспорт
	
	ДополнитьШаблоныНеФормализованныхКодовМаркировки(НастройкиРазбораКодаМаркировки, МодулиПодсистемы, "ЗаводскойSN");
	ДополнитьШаблоныНеФормализованныхКодовМаркировки(НастройкиРазбораКодаМаркировки, МодулиПодсистемы, "ПроизвольныеAI");
	
КонецПроцедуры

