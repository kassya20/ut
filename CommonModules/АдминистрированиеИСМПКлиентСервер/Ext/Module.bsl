#Область ПрограммныйИнтерфейс

// Параметры записи маркируемой продукции.
// 
// Возвращаемое значение:
//  Структура - Параметры записи маркируемой продукции:
// * ЗаписыватьВидПродукции - Булево - 
// * Данные - Массив из Структура - 
Функция ПараметрыЗаписиМаркируемойПродукции() Экспорт
	
	Результат = Новый Структура;
	Результат.Вставить("ЗаписыватьВидПродукции", Ложь);
	Результат.Вставить("Данные",                 Новый Массив);
	
	Для Каждого Имя Из КонструкторИСМПОбщегоНазначенияКлиентСервер.ИменаДатНачалаРаботыСМаркируемойПродукцией() Цикл
		Результат.Вставить("Записывать" + Имя, Ложь);
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

// Строка данных записи маркируемой продукции.
// 
// Возвращаемое значение:
//  Структура - Строка данных записи маркируемой продукции:
// * ВидПродукции - СправочникСсылка.ВидыПродукцииИС - 
// * ВидПродукцииВерхнегоУровня - Булево - 
// * УдалениеДанных - Булево - 
Функция СтрокаДанныхЗаписиМаркируемойПродукции() Экспорт
	
	Результат = Новый Структура;
	Результат.Вставить("ВидПродукции",               ПредопределенноеЗначение("Справочник.ВидыПродукцииИС.ПустаяСсылка"));
	Результат.Вставить("ВидПродукцииВерхнегоУровня", Ложь);
	Результат.Вставить("УдалениеДанных",             Ложь);
	
	Для Каждого Имя Из КонструкторИСМПОбщегоНазначенияКлиентСервер.ИменаДатНачалаРаботыСМаркируемойПродукцией() Цикл
		Результат.Вставить(Имя, Дата(1, 1, 1));
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти