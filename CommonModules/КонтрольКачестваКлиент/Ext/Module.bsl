#Область ПрограммныйИнтерфейс

// Конструктор параметров формы Справочник.КонтролируемыеПартии.ФормаВыбора.
// Возвращаемое значение:
//  Структура:
//  * Источник - Строка, Неопределено - условное обозначение контекста открытия формы выбора
//  * Номенклатура - СправочникСсылка.Номенклатура, Неопределено - номенклатура для получения остатков, если источник "Документ.КорректировкаНазначенияТоваров"
//  * Характеристика - СправочникСсылка.ХарактеристикиНоменклатуры, Неопределено - характеристика для получения остатков, если источник "Документ.КорректировкаНазначенияТоваров"
//  * Склад - СправочникСсылка.Склады, Неопределено - склад для получения остатков, если источник "Документ.КорректировкаНазначенияТоваров"
//  * Назначение - СправочникСсылка.Назначения, Неопределено - назначение для получения остатков, если источник "Документ.КорректировкаНазначенияТоваров"
//  * Упаковка - СправочникСсылка.УпаковкиЕдиницыИзмерения, Неопределено - упаковка для получения остатков, если источник "Документ.КорректировкаНазначенияТоваров"
Функция НовыйПараметрыФормыВыбораКонтролируемыеПартии() Экспорт
	
	НовыйПараметры = Новый Структура();
	НовыйПараметры.Вставить("Источник", Неопределено);
	НовыйПараметры.Вставить("Назначение", Неопределено);
	НовыйПараметры.Вставить("Номенклатура", Неопределено);
	НовыйПараметры.Вставить("Склад", Неопределено);
	НовыйПараметры.Вставить("Упаковка", Неопределено);
	НовыйПараметры.Вставить("Характеристика", Неопределено);
	
	Возврат НовыйПараметры;
	
КонецФункции

#КонецОбласти