#Область СлужебныйПрограммныйИнтерфейс

// Выполняет нормализацию значений кодов маркировки для приведения к значениям,
// аналогичным получаемым из сервиса.
// 
// Параметры:
// 	УзелДерева               - ДеревоЗначений,СтрокаДереваЗначений - данные дерева.
// 	ПараметрыНормализацииКМ  - См. РазборКодаМаркировкиИССлужебныйКлиентСервер.ПараметрыНормализацииКодаМаркировки.
// 	ИсходныеЗначенияШрихкода - Соответствие из КлючИЗначение - Соответствие строк и исходных значений для восстановления.
Процедура НормализоватьДеревоЗначенийРекурсивно(УзелДерева, ПараметрыНормализацииКМ, ИсходныеЗначенияШрихкода) Экспорт
	
	Для Каждого СтрокаДерева Из УзелДерева.Строки Цикл
		
		НормализоватьДеревоЗначенийРекурсивно(СтрокаДерева, ПараметрыНормализацииКМ, ИсходныеЗначенияШрихкода);
		
		Если ОбщегоНазначенияИСПовтИсп.ЭтоПродукцияМОТП(СтрокаДерева.ВидПродукции) Тогда
			
			Если СтрокаДерева.ВидУпаковки = Перечисления.ВидыУпаковокИС.Потребительская Тогда
				
				Если ОбщегоНазначенияИСПовтИсп.ЭтоПродукцияМОТП(СтрокаДерева.ВидПродукции) Тогда
					ПараметрыНормализацииКМ.НачинаетсяСоСкобки = Ложь;
				Иначе
					ПараметрыНормализацииКМ.НачинаетсяСоСкобки = Истина;
				КонецЕсли;
				ПараметрыНормализацииКМ.ВключатьМРЦ = Ложь;
				
			ИначеЕсли СтрокаДерева.ВидУпаковки = Перечисления.ВидыУпаковокИС.Групповая
				Или СтрокаДерева.ВидУпаковки = Перечисления.ВидыУпаковокИС.Набор Тогда
				
				ПараметрыНормализацииКМ.НачинаетсяСоСкобки = Истина;
				ПараметрыНормализацииКМ.ВключатьМРЦ        = Ложь;
				
			ИначеЕсли СтрокаДерева.ВидУпаковки = Перечисления.ВидыУпаковокИС.Логистическая
				И ОбщегоНазначенияИСПовтИсп.ЭтоПродукцияИСМП(СтрокаДерева.ВидПродукции, Истина)
				И СтрокаДерева.ТипШтрихкода = Перечисления.ТипыШтрихкодов.GS1_128 Тогда
				
				ПараметрыНормализацииКМ.НачинаетсяСоСкобки = Ложь;
				
			Иначе
				Продолжить;
			КонецЕсли;
			
		Иначе
			Продолжить;
		КонецЕсли;
		
		КодМаркировки = РазборКодаМаркировкиИССлужебныйКлиентСервер.НормализоватьКодМаркировки(
			СтрокаДерева,
			СтрокаДерева.ВидПродукции,
			ПараметрыНормализацииКМ);
		
		Если СтрокаДерева[ПараметрыНормализацииКМ.ИмяСвойстваКодМаркировки] <> КодМаркировки Тогда
			ИсходныеЗначенияШрихкода.Вставить(СтрокаДерева, СтрокаДерева[ПараметрыНормализацииКМ.ИмяСвойстваКодМаркировки]);
			СтрокаДерева[ПараметрыНормализацииКМ.ИмяСвойстваКодМаркировки] = КодМаркировки;
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

// Получает таблицу "Штрихкоды упаковок" из документа по определенному сценарию параметров сканирования.
//   Таблица включает ссылки на штрихкоды упаковок, их представления, а также данные штрихкодов, хранимые в документе.
// 
// Параметры:
//  ДокументСсылка - ДокументСсылка - Источник штрихкодов
//  ПараметрыСканирования - См. ШтрихкодированиеОбщегоНазначенияИС.ПараметрыСканирования
// 
// Возвращаемое значение:
//  ТаблицаЗначений - Штрихкоды упаковок из документа
Функция ШтрихкодыУпаковокИзДокумента(Знач ДокументСсылка, Знач ПараметрыСканирования) Экспорт
	
	ИмяТабличнойЧасти = ПараметрыСканирования.ИмяТабличнойЧастиШтрихкодыУпаковок;
	ИмяКолонки        = ПараметрыСканирования.ИмяКолонкиШтрихкодУпаковки;
	
	МетаданныеДокумента           = ДокументСсылка.Метаданные();
	ИмяДокумента                  = МетаданныеДокумента.Имя;
	
	ИменаРеквизитов = Новый Соответствие;
	Для Каждого Реквизит Из МетаданныеДокумента.ТабличныеЧасти[ИмяТабличнойЧасти].Реквизиты Цикл
		ИменаРеквизитов.Вставить(Реквизит.Имя, Истина);
	КонецЦикла;
	
	ТекстЗапроса =
		"ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	%3
		|ИЗ
		|	Документ.%1.%2 КАК Штрихкоды
		|ГДЕ
		|	Штрихкоды.Ссылка = &ДокументСсылка";
	
	ВыбираемыеПоля = Новый Массив();
	ВыбираемыеПоля.Добавить(СтрШаблон("Штрихкоды.%1 КАК ШтрихкодУпаковки", ИмяКолонки));
	ПолеВыборкиСоЗначениемПоУмолчанию(ВыбираемыеПоля, ИменаРеквизитов, "ЗначениеШтрихкода", СтрШаблон("ЕСТЬNULL(Штрихкоды.%1.ЗначениеШтрихкода, """")", ИмяКолонки), "Штрихкод");
	
	Если ШтрихкодированиеОбщегоНазначенияИС.ТребуетсяЧастичноеВыбытие(ПараметрыСканирования) Тогда
		ПолеВыборкиСоЗначениемПоУмолчанию(ВыбираемыеПоля, ИменаРеквизитов, "ЧастичноеВыбытиеКоличество", "0", "Количество");
		ПолеВыборкиСоЗначениемПоУмолчанию(ВыбираемыеПоля, ИменаРеквизитов, "ЧастичноеВыбытиеВариантУчета", "НЕОПРЕДЕЛЕНО", "ЧастичноеВыбытиеВариантУчета");
		ПолеВыборкиСоЗначениемПоУмолчанию(ВыбираемыеПоля, ИменаРеквизитов, "ЧастичноеВыбытиеНоменклатура", "НЕОПРЕДЕЛЕНО", "ЧастичноеВыбытиеНоменклатура");
		ПолеВыборкиСоЗначениемПоУмолчанию(ВыбираемыеПоля, ИменаРеквизитов, "ЧастичноеВыбытиеХарактеристика", "НЕОПРЕДЕЛЕНО", "ЧастичноеВыбытиеХарактеристика");
		ПолеВыборкиСоЗначениемПоУмолчанию(ВыбираемыеПоля, ИменаРеквизитов, "ВыбытиеБутылки", "ЛОЖЬ", "ВыбытиеБутылки");
	КонецЕсли;
	
	Если ПараметрыСканирования.ИСМП И ПараметрыСканирования.ТребуетсяПроверкаСредствамиККТ Тогда
		Если ПараметрыСканирования.Свойство("ИмяКолонкиРазрешительныйРежимИдентификаторЗапросаГИСМТ")
			И ЗначениеЗаполнено(ПараметрыСканирования.ИмяКолонкиРазрешительныйРежимИдентификаторЗапросаГИСМТ) Тогда
			ВыбираемыеПоля.Добавить(
				СтрШаблон("Штрихкоды.%1 КАК РазрешительныйРежимИдентификаторЗапросаГИСМТ",
				ПараметрыСканирования.ИмяКолонкиРазрешительныйРежимИдентификаторЗапросаГИСМТ));
		КонецЕсли;
		Если ПараметрыСканирования.Свойство("ИмяКолонкиРазрешительныйРежимДатаЗапросаГИСМТ")
			И ЗначениеЗаполнено(ПараметрыСканирования.ИмяКолонкиРазрешительныйРежимДатаЗапросаГИСМТ) Тогда
			ВыбираемыеПоля.Добавить(
				СтрШаблон("Штрихкоды.%1 КАК РазрешительныйРежимДатаЗапросаГИСМТ",
				ПараметрыСканирования.ИмяКолонкиРазрешительныйРежимДатаЗапросаГИСМТ));
		КонецЕсли;
		Если ПараметрыСканирования.Свойство("ИмяКолонкиРазрешительныйРежимИдентификаторЭкземпляраПО")
			И ЗначениеЗаполнено(ПараметрыСканирования.ИмяКолонкиРазрешительныйРежимИдентификаторЭкземпляраПО) Тогда
			ВыбираемыеПоля.Добавить(
				СтрШаблон("Штрихкоды.%1 КАК РазрешительныйРежимИдентификаторЭкземпляраПО",
				ПараметрыСканирования.ИмяКолонкиРазрешительныйРежимИдентификаторЭкземпляраПО));
		КонецЕсли;
		Если ПараметрыСканирования.Свойство("ИмяКолонкиРазрешительныйРежимВерсияБазы")
			И ЗначениеЗаполнено(ПараметрыСканирования.ИмяКолонкиРазрешительныйРежимВерсияБазы) Тогда
			ВыбираемыеПоля.Добавить(
				СтрШаблон("Штрихкоды.%1 КАК РазрешительныйРежимВерсияБазы",
				ПараметрыСканирования.ИмяКолонкиРазрешительныйРежимВерсияБазы));
		КонецЕсли;
		Если ПараметрыСканирования.Свойство("ИмяКолонкиМРЦ")
			И ЗначениеЗаполнено(ПараметрыСканирования.ИмяКолонкиМРЦ) Тогда
			ВыбираемыеПоля.Добавить(
				СтрШаблон("Штрихкоды.%1 КАК МинимальнаяРозничнаяЦена",
				ПараметрыСканирования.ИмяКолонкиМРЦ));
		КонецЕсли;
	КонецЕсли;
	
	Если ШтрихкодированиеОбщегоНазначенияИСКлиентСервер.ЗапрашиватьСправку2(ПараметрыСканирования) Тогда
		ВыбираемыеПоля.Добавить("Штрихкоды.Справка2 КАК Справка2");
		ВыбираемыеПоля.Добавить("Штрихкоды.Справка2.АлкогольнаяПродукция КАК АлкогольнаяПродукция");
	КонецЕсли;
	
	Если ШтрихкодированиеОбщегоНазначенияИСКлиентСервер.ЗаполнятьДанныеВЕТИС(ПараметрыСканирования) Тогда
		ПолеВыборкиСоЗначениемПоУмолчанию(ВыбираемыеПоля, ИменаРеквизитов, "ИдентификаторПроисхожденияВЕТИС", "НЕОПРЕДЕЛЕНО", "ИдентификаторПроисхожденияВЕТИС");
	КонецЕсли;
	Если ШтрихкодированиеОбщегоНазначенияИСКлиентСервер.ЗаполнятьСрокГодности(ПараметрыСканирования) Тогда
		ПолеВыборкиСоЗначениемПоУмолчанию(ВыбираемыеПоля, ИменаРеквизитов, "СрокГодности", "ДАТАВРЕМЯ(1,1,1)", "СрокГодности");
	КонецЕсли;
	
	ТекстЗапроса = СтрШаблон(
		ТекстЗапроса,
		ИмяДокумента,
		ИмяТабличнойЧасти,
		СтрСоединить(ВыбираемыеПоля, ", " + Символы.ПС));
	
	Запрос = Новый Запрос(ТекстЗапроса);
	Запрос.УстановитьПараметр("ДокументСсылка", ДокументСсылка);
	
	ШтрихкодыУпаковок = Запрос.Выполнить().Выгрузить();
	
	Возврат ШтрихкодыУпаковок;
	
КонецФункции

// Инициализирует результат формирования вложенных штрихкодов по кодам маркировки ИСМП.
// 
// Возвращаемое значение:
//  Структура - Описание:
// * ВложенныеШтрихкоды - Структура - 
// * ДанныеКодовМаркировки - ТаблицаЗначений - 
// * ЕстьОшибки - Булево - Истина, если есть ошибки.
// * ТекстОшибки - Строка - Описание ошибки.
// * ТребуетсяОбновлениеКлючаСессии - Булево - Истина, если требуется авторизация.
// * ТребуетсяОбновлениеКлючаСессииРозница - Булево - Истина, если требуется авторизация в рознице
// * ПрерватьЗагрузку - Булево - Истина для выполнения дополнительных действий перед открытием
Функция ИнициализацияРезультатаФормированияВложенныхШтрихкодов() Экспорт
	
	РезультатФормированияВложенныхШтрихкодов = Новый Структура;
	
	РезультатФормированияВложенныхШтрихкодов.Вставить("ДанныеКодовМаркировки",                 Неопределено);
	РезультатФормированияВложенныхШтрихкодов.Вставить("ВложенныеШтрихкоды",                    Неопределено);
	РезультатФормированияВложенныхШтрихкодов.Вставить("ЕстьОшибки",                            Ложь);
	РезультатФормированияВложенныхШтрихкодов.Вставить("ТекстОшибки",                           "");
	РезультатФормированияВложенныхШтрихкодов.Вставить("ТребуетсяОбновлениеКлючаСессии",        Ложь);
	РезультатФормированияВложенныхШтрихкодов.Вставить("ТребуетсяОбновлениеКлючаСессииРозница", Ложь);
	РезультатФормированияВложенныхШтрихкодов.Вставить("ПрерватьЗагрузку",                      Ложь);

	Возврат РезультатФормированияВложенныхШтрихкодов;
	
КонецФункции

// Формирует структуру вложенных известных базе штрихкодов по таблице штрихкодов.
//
// Параметры:
//  ШтрихкодыУпаковок - ТаблицаЗначений - Описание:
// * ШтрихкодУпаковки - СправочникСсылка.ШтрихкодыУпаковокТоваров - Ссылка на элемент справочника.
//  ПараметрыСканирования - См. ШтрихкодированиеОбщегоНазначенияИС.ПараметрыСканирования.
// Возвращаемое значение:
//  См. ИнициализацияРезультатаФормированияВложенныхШтрихкодов.
Функция ВложенныеШтрихкодыУпаковок(ШтрихкодыУпаковок, ПараметрыСканирования) Экспорт
	
	ИзвестныеУпаковки   = Новый Массив;
	НеизвестныеУпаковки = Новый Массив;
	ПараметрыДополнения = Неопределено;
	
	Результат = ИнициализацияРезультатаФормированияВложенныхШтрихкодов();
	Результат.ВложенныеШтрихкоды = ШтрихкодированиеИС.ИнициализацияВложенныхШтрихкодов();
	
	Для Каждого Строка Из ШтрихкодыУпаковок Цикл
		
		Если ЗначениеЗаполнено(Строка.ШтрихкодУпаковки) Тогда
			ИзвестныеУпаковки.Добавить(Строка.ШтрихкодУпаковки);
		ИначеЕсли ЗначениеЗаполнено(Строка.Штрихкод) Тогда
			НеизвестныеУпаковки.Добавить(Новый Структура("Штрихкод, Количество", Строка.Штрихкод, 1));
		КонецЕсли;
		
	КонецЦикла;
	
	ЗаполнитьПараметрыДополненияВложенныхШтрихкодов(ПараметрыДополнения, ШтрихкодыУпаковок, ПараметрыСканирования);
	
	ДанныеПоШтрихкодам = ШтрихкодированиеОбщегоНазначенияИС.ИнициализацияДанныхПоШтрихкодам();
	
	ДопустимаАлкогольнаяПродукция = ШтрихкодированиеОбщегоНазначенияИС.ДопустимаАлкогольнаяПродукция(ПараметрыСканирования);
	ДопустимаТабачнаяПродукция = ШтрихкодированиеОбщегоНазначенияИС.ДопустимаТабачнаяПродукция(ПараметрыСканирования);
	ДопустимаПродукцияИСМП = ШтрихкодированиеОбщегоНазначенияИС.ДопустимаПродукцияИСМП(ПараметрыСканирования);
	
	Если ДопустимаАлкогольнаяПродукция Тогда
		МодульШтрихкодированиеЕГАИС = ОбщегоНазначенияИСПовтИсп.ОбщийМодуль("ШтрихкодированиеЕГАИС");
		МодульШтрихкодированиеЕГАИС.ДобавитьКолонкиТаблицыДанныеКодовМаркировки(ДанныеПоШтрихкодам, ПараметрыСканирования);
	КонецЕсли;
	
	Если ДопустимаТабачнаяПродукция Тогда
		МодульШтрихкодированиеМОТП = ОбщегоНазначенияИСПовтИсп.ОбщийМодуль("ШтрихкодированиеОбщегоНазначенияМОТП");
		МодульШтрихкодированиеМОТП.ДобавитьКолонкиТаблицыДанныеКодовМаркировки(
			ДанныеПоШтрихкодам, ПараметрыСканирования);
	КонецЕсли;
	
	Если ДопустимаПродукцияИСМП Тогда
		МодульШтрихкодированиеИСМП = ОбщегоНазначенияИСПовтИсп.ОбщийМодуль("ШтрихкодированиеОбщегоНазначенияИСМП");
		МодульШтрихкодированиеИСМП.ДобавитьКолонкиТаблицыДанныеКодовМаркировки(
			ДанныеПоШтрихкодам, ПараметрыСканирования);
	КонецЕсли;
	
	Если ПараметрыСканирования.ИСМП Тогда
		МодульШтрихкодированиеМОТП = ОбщегоНазначенияИСПовтИсп.ОбщийМодуль("ШтрихкодированиеМОТП");
		МодульШтрихкодированиеИСМПСлужебный = ОбщегоНазначенияИСПовтИсп.ОбщийМодуль("ШтрихкодированиеИСМПСлужебный");
	КонецЕсли;
	
	Если ИзвестныеУпаковки.Количество() Тогда
		
		ВложенныеШтрихкодыИзвестныхУпаковок = ШтрихкодированиеИС.ВложенныеШтрихкодыИзвестныхУпаковок(ИзвестныеУпаковки, ПараметрыСканирования);
		
		Если ПараметрыСканирования.ИСМП Тогда
			МодульШтрихкодированиеМОТП.ПривестиВложенныеШтрихкодыКТребуемомуВидуДетализации(ВложенныеШтрихкодыИзвестныхУпаковок, ПараметрыСканирования);
		КонецЕсли;
		
		Если ВложенныеШтрихкодыИзвестныхУпаковок.ДеревоУпаковок.Строки.Количество() = 0 Тогда
			Возврат Результат;
		КонецЕсли;
		
		ДанныеПоШтрихкодам.ВложенныеШтрихкоды = ВложенныеШтрихкодыИзвестныхУпаковок;
		
		ДобавленныеСтроки = Новый Массив;
		ШтрихкодированиеИС.ДополнитьТаблицуДанныеКодовМаркировкиПоСтрокамДереваУпаковок(
			ДанныеПоШтрихкодам, ВложенныеШтрихкодыИзвестныхУпаковок.ДеревоУпаковок, ДобавленныеСтроки, ПараметрыСканирования);
		
		// Заполнение массива видов продукции штрихкодов. При выполнении проверок
		// можно будет использовать ПрисутствуетТабачнаяПродукция(ВидыПродукции)
		ШтрихкодированиеОбщегоНазначенияИС.ЗаполнитьВидыПродукцииВДанныхПоШтрихкодам(ДанныеПоШтрихкодам, ПараметрыСканирования);
		
		ШтрихкодированиеИС.ЗаполнитьДанныеRFID(ДанныеПоШтрихкодам, ПараметрыСканирования);
		
		Если ПараметрыСканирования.ИСМП И Не ДопустимаПродукцияИСМП И Не ДопустимаТабачнаяПродукция Тогда
			
			Результат.ЕстьОшибки  = Истина;
			Результат.ТекстОшибки = ШтрихкодированиеОбщегоНазначенияИСКлиентСервер.ТекстОшибкиНеЗагруженКлассификаторПоВидуПродукции(ДанныеПоШтрихкодам.ВидыПродукции);
			Возврат Результат;
			
		КонецЕсли;
		
		Если ПараметрыСканирования.ИСМП Тогда
			ШтрихкодированиеОбщегоНазначенияИСМП.УстановитьПризнакОтказаОтПроверкиКодовМаркировки(ДанныеПоШтрихкодам, ПараметрыСканирования);
		КонецЕсли;
		
		ШтрихкодированиеИС.ЗаполнитьКоэффициентыВложенностиУпаковокПоШтрихкодамEAN(ДанныеПоШтрихкодам, ПараметрыСканирования, ДобавленныеСтроки);
		
		ШтрихкодированиеОбщегоНазначенияИС.ДополнитьДанныеШтрихкодовСпецификойМаркируемойПродукции(ДанныеПоШтрихкодам, ПараметрыСканирования, ПараметрыДополнения);
		
		// Все заполненные в ТЧ штрихкодов реквизиты переносятся в дерево
		// возможно, рекурсивно для маркировки с ВетИС и агрегацией
		ДополнитьДеревоДанныеКодовМаркировкиПоСтрокамДокумента(ШтрихкодыУпаковок, ДанныеПоШтрихкодам);
		
		НормализоватьДанныеДереваУпаковок(
			ВложенныеШтрихкодыИзвестныхУпаковок.ДеревоУпаковок, ПараметрыСканирования, ДанныеПоШтрихкодам.ДанныеКодовМаркировки,
			ДопустимаАлкогольнаяПродукция, ДопустимаТабачнаяПродукция, ДопустимаПродукцияИСМП);
		
		Если ПараметрыСканирования.ИСМП
			И (ШтрихкодированиеОбщегоНазначенияИСКлиентСервер.ВидОперацииИСМП(ПараметрыСканирования) = Перечисления["ВидыОперацийИСМП"].ПодтверждениеПоступленияКИЗ
				Или ШтрихкодированиеОбщегоНазначенияИСКлиентСервер.ВидОперацииИСМП(ПараметрыСканирования) = Перечисления["ВидыОперацийИСМП"].СписаниеЧерезСУЗМех) Тогда
			МодульШтрихкодированиеИСМПСлужебный.ДополнитьДанныеПоШтрихкодамДаннымиПулаКодовМаркировки(ДанныеПоШтрихкодам, ПараметрыСканирования, Истина);
		КонецЕсли;
		
		Если ДанныеПоШтрихкодам.ЕстьОшибки Тогда
			Результат.ЕстьОшибки  = Истина;
			Результат.ТекстОшибки = ДанныеПоШтрихкодам.ТекстОшибки;
			Результат.ТребуетсяОбновлениеКлючаСессии = ДанныеПоШтрихкодам.ТребуетсяОбновлениеКлючаСессии;
		Иначе
			Результат.ВложенныеШтрихкоды    = ВложенныеШтрихкодыИзвестныхУпаковок;
			Результат.ДанныеКодовМаркировки = ДанныеПоШтрихкодам.ДанныеКодовМаркировки;
		КонецЕсли;
		
	ИначеЕсли НеизвестныеУпаковки.Количество()
		И ПараметрыСканирования.ИСМП Тогда
		
		Если ПараметрыСканирования.ВидОперацииИСМП = Перечисления["ВидыОперацийИСМП"].ПриемкаИзЕАЭСПриОСУ Тогда
			
			Результат = МодульШтрихкодированиеИСМПСлужебный.ВложенныеШтрихкоды(НеизвестныеУпаковки, ПараметрыСканирования);
			
		Иначе
			
			Результат = МодульШтрихкодированиеИСМПСлужебный.ВложенныеШтрихкодыПоДаннымИСМП(НеизвестныеУпаковки, ПараметрыСканирования);
			
		КонецЕсли;
		
	Иначе
		
		Результат.ДанныеКодовМаркировки = ДанныеПоШтрихкодам.ДанныеКодовМаркировки;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Процедура ДополнитьДанныеПоШтрихкодамСпецификой(ДанныеПоШтрихкодам, ПараметрыСканирования, ПараметрыДополнения,
	ДопустимаАлкогольнаяПродукция, ДопустимаТабачнаяПродукция, ДопустимаПродукцияИСМП) Экспорт
	
	Если ДопустимаАлкогольнаяПродукция Тогда
		
		ШтрихкодированиеЕГАИС.ДополнитьДанныеПоШтрихкодамСпецификой(
			ДанныеПоШтрихкодам, ПараметрыСканирования, ПараметрыДополнения);
		
	КонецЕсли;
	
	Если ДопустимаТабачнаяПродукция Тогда
		
		ШтрихкодированиеМОТП.ДополнитьДанныеПоШтрихкодамСпецификой(
			ДанныеПоШтрихкодам, ПараметрыСканирования, ПараметрыДополнения, Истина);
		
	КонецЕсли;
	
	Если ДопустимаПродукцияИСМП Тогда
		
		ШтрихкодированиеИСМПСлужебный.ДополнитьДанныеПоШтрихкодамСпецификой(
			ДанныеПоШтрихкодам, ПараметрыСканирования, ПараметрыДополнения);
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Процедура ПолеВыборкиСоЗначениемПоУмолчанию(ВыбираемыеПоля, ИменаРеквизитов, ИмяРеквизита, ЗначениеПоУмолчанию, ИмяПоляВыборки)
	
	Если ИменаРеквизитов[ИмяРеквизита] = Истина Тогда
		ВыбираемыеПоля.Добавить(СтрШаблон("Штрихкоды.%1 КАК %2", ИмяРеквизита, ИмяПоляВыборки));
	Иначе
		ВыбираемыеПоля.Добавить(СтрШаблон("%1 КАК %2", ЗначениеПоУмолчанию, ИмяПоляВыборки));
	КонецЕсли;
	
КонецПроцедуры

Процедура ДополнитьДеревоДанныеКодовМаркировкиПоСтрокамДокумента(ШтрихкодыУпаковок, ДанныеПоШтрихкодам)
	
	ВложенныеШтрихкоды = ДанныеПоШтрихкодам.ВложенныеШтрихкоды;
	
	ШтрихкодыУпаковок.Индексы.Добавить("ШтрихкодУпаковки");
	ДанныеПоШтрихкодам.ДанныеКодовМаркировки.Индексы.Добавить("ШтрихкодУпаковки");
	
	// Дополнение недоступно для входящего документа
	Для Каждого СтрокаТаблицы Из ВложенныеШтрихкоды.МаркированныеТовары Цикл
		Если ЗначениеЗаполнено(СтрокаТаблицы.ШтрихкодУпаковки) Тогда
			ЗначениеДополнения = ШтрихкодыУпаковок.Найти(СтрокаТаблицы.ШтрихкодУпаковки, "ШтрихкодУпаковки");
			Если ЗначениеДополнения = Неопределено Тогда
				Продолжить;
			КонецЕсли;
		КонецЕсли;
		ЗаполненныеЗначения = Новый Структура;
		Для Каждого Колонка Из ШтрихкодыУпаковок.Колонки Цикл
			Если Колонка.Имя <> "ШтрихкодУпаковки"
				И Колонка.Имя <> "Штрихкод"
				И ЗначениеЗаполнено(ЗначениеДополнения[Колонка.Имя]) Тогда
					ЗаполненныеЗначения.Вставить(Колонка.Имя, ЗначениеДополнения[Колонка.Имя]);
			КонецЕсли;
		КонецЦикла;
		Если ЗаполненныеЗначения.Количество() Тогда
			ЗаполнитьЗначенияДополненияВДеревеРекурсивно(ДанныеПоШтрихкодам, СтрокаТаблицы, ЗаполненныеЗначения);
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

Процедура ЗаполнитьЗначенияДополненияВДеревеРекурсивно(ДанныеПоШтрихкодам, СтрокаТаблицы, ЗаполненныеЗначения)
	
	ЗаполнитьЗначенияСвойств(СтрокаТаблицы, ЗаполненныеЗначения);
	ЗаполнитьЗначенияСвойств(СтрокаТаблицы.СтрокаДерева, ЗаполненныеЗначения);
	СтрокаДанныеКодовМаркировки = ДанныеПоШтрихкодам.ДанныеКодовМаркировки.Найти(СтрокаТаблицы.ШтрихкодУпаковки, "ШтрихкодУпаковки");
	Если СтрокаДанныеКодовМаркировки <> Неопределено Тогда
		ЗаполнитьЗначенияСвойств(СтрокаДанныеКодовМаркировки, ЗаполненныеЗначения);
	КонецЕсли;
	Для Каждого ВложеннаяСтрока Из СтрокаТаблицы.СтрокаДерева.Строки Цикл
		ЗаполнитьЗначенияДополненияВДеревеРекурсивно(ДанныеПоШтрихкодам,
			ДанныеПоШтрихкодам.ВложенныеШтрихкоды.МаркированныеТовары.Найти(ВложеннаяСтрока.ШтрихкодУпаковки, "ШтрихкодУпаковки"), ЗаполненныеЗначения);
	КонецЦикла;
	
КонецПроцедуры

Процедура НормализоватьДанныеДереваУпаковок(ДеревоУпаковок, ПараметрыСканирования, ДанныеКодовМаркировки,
	ДопустимаАлкогольнаяПродукция, ДопустимаТабачнаяПродукция, ДопустимаПродукцияИСМП)
	
	Если ДопустимаАлкогольнаяПродукция Тогда
		
		ШтрихкодированиеЕГАИС.НормализоватьДанныеДереваУпаковок(
			ДеревоУпаковок, ПараметрыСканирования, ДанныеКодовМаркировки);
		
	КонецЕсли;
	
	Если ДопустимаТабачнаяПродукция Или ДопустимаПродукцияИСМП Тогда
		
		ШтрихкодированиеИСМПСлужебный.НормализоватьДанныеДереваУпаковок(
			ДеревоУпаковок, ПараметрыСканирования, ДанныеКодовМаркировки);
		
	КонецЕсли;
	
КонецПроцедуры

Процедура ЗаполнитьПараметрыДополненияВложенныхШтрихкодов(ПараметрыДополнения, ШтрихкодыУпаковок, ПараметрыСканирования) Экспорт
	
	ЕстьВидПродукцииВСтроке        = Неопределено;
	ЭтоРозничнаяОперация           = Неопределено;
	ПоддерживаетсяЧастичноеВыбытие = Ложь;
	
	Если ПараметрыСканирования.ИСМП
		И ЗначениеЗаполнено(ПараметрыСканирования.СсылкаНаОбъект) Тогда
		Для Каждого ВидПродукции Из ПараметрыСканирования.ДопустимыеВидыПродукции Цикл
			Если ОбщегоНазначенияИСКлиентСерверПовтИсп.ПоддерживаетсяЧастичноеВыбытие(
				ВидПродукции, ПараметрыСканирования.ВидОперацииИСМП) Тогда
				ПоддерживаетсяЧастичноеВыбытие = ПараметрыСканирования.ТребуетсяЧастичноеВыбытие;
				Прервать;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
	Для Каждого СтрокаТаблицы Из ШтрихкодыУпаковок Цикл
		
		Если Не ЗначениеЗаполнено(СтрокаТаблицы.ШтрихкодУпаковки) Тогда
			Продолжить;
		КонецЕсли;
		
		Если ЕстьВидПродукцииВСтроке = Неопределено Тогда
			ЕстьВидПродукцииВСтроке = ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(
				СтрокаТаблицы, "ВидПродукции");
		КонецЕсли;
		
		СтрокаЧастичногоВыбытия     = Ложь;
		СтрокаРазрешительногоРежима = Ложь;
		
		Если ЕстьВидПродукцииВСтроке Тогда
			
			СтрокаЧастичногоВыбытия     = ШтрихкодированиеОбщегоНазначенияИСКлиентСервер.ЭтоСтрокаДанныхЧастичногоВыбытия(СтрокаТаблицы, ПараметрыСканирования, Истина);
			СтрокаРазрешительногоРежима = СтрокаТаблицы.ПодлежитПроверкеРазрешительногоРежима;
			
			Если Не СтрокаЧастичногоВыбытия
				И Не СтрокаРазрешительногоРежима Тогда
				Продолжить;
			КонецЕсли;
			
		Иначе
			Если ЭтоРозничнаяОперация = Неопределено Тогда
				Если ПараметрыСканирования.ИСМП Тогда
					ОперацияИС = ПараметрыСканирования.ВидОперацииИСМП;
					РозничныеОперации    = НастройкаПараметровСканированияСлужебныйКлиентСерверПовтИсп.ОперацииРозничнойТорговли();
					ЭтоРозничнаяОперация = (РозничныеОперации.Найти(ОперацияИС) <> Неопределено);
				Иначе
					ОперацияИС = ПараметрыСканирования.Операция;
					ЭтоРозничнаяОперация = (ОперацияИС = Перечисления.ВидыДокументовЕГАИС.ЧекККМ
						Или ОперацияИС = Перечисления.ВидыДокументовЕГАИС.АктПостановкиНаБалансВРегистр1
						Или ОперацияИС = Перечисления.ВидыДокументовЕГАИС.АктПостановкиНаБалансВРегистр2
						Или ОперацияИС = Перечисления.ВидыДокументовЕГАИС.АктПостановкиНаБалансВРегистр3);
				КонецЕсли;
			КонецЕсли;
			Если ЭтоРозничнаяОперация Тогда
				СтрокаЧастичногоВыбытия = Истина;
				СтрокаРазрешительногоРежима = Истина;
			ИначеЕсли ПоддерживаетсяЧастичноеВыбытие
				И ШтрихкодированиеОбщегоНазначенияИСКлиентСервер.ЭтоСтрокаДанныхЧастичногоВыбытия(
					СтрокаТаблицы, ПараметрыСканирования) Тогда
				СтрокаЧастичногоВыбытия = Истина;
			Иначе
				Продолжить;
			КонецЕсли;
		КонецЕсли;
		
		Если ПараметрыДополнения = Неопределено Тогда
			ПараметрыДополнения = ШтрихкодированиеИС.ПараметрыДополненияВложенныхШтрихкодовУпаковок();
		КонецЕсли;
		
		ЭлементДополнения = ШтрихкодированиеИС.НовыйЭлементДополненияВложенныхШтрихкодовУпаковокДанныеГИСМТ();
		ЗаполнитьЗначенияСвойств(ЭлементДополнения, СтрокаТаблицы);
		
		Если СтрокаРазрешительногоРежима И ЗначениеЗаполнено(ЭлементДополнения.РазрешительныйРежимДатаЗапросаГИСМТ) Тогда
		
			ПараметрыДополнения.ДанныеЗапросаГИСМТ.Вставить(
				СтрокаТаблицы.ШтрихкодУпаковки,
				ЭлементДополнения);
				
		КонецЕсли;
		
		ЭлементДополнения = ШтрихкодированиеИС.НовыйЭлементДополненияВложенныхШтрихкодовУпаковокЧастичноеВыбытие();
		ЗаполнитьЗначенияСвойств(ЭлементДополнения, СтрокаТаблицы);
		
		Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(СтрокаТаблицы, "ЧастичноеВыбытиеКоличество") Тогда
			ЭлементДополнения.Количество = СтрокаТаблицы.ЧастичноеВыбытиеКоличество;
		КонецЕсли;
		
		Если СтрокаЧастичногоВыбытия И ЗначениеЗаполнено(ЭлементДополнения.Количество) Тогда
		
			ПараметрыДополнения.ДанныеЧастичногоВыбытия.Вставить(
				СтрокаТаблицы.ШтрихкодУпаковки,
				ЭлементДополнения);
				
		КонецЕсли;
		
	КонецЦикла;
		
КонецПроцедуры

#КонецОбласти
