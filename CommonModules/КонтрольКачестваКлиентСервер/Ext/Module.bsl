#Область ПрограммныйИнтерфейс

// Используется для получения кэша механизма контроля качества в формах документов в контексте объекта,
// например: Шапка или Товары.
// Параметры:
//  Кэш - См. КонтрольКачества.КэшДанныхМеханизма
//  Ключ - Строка - ключ источника данных в объекте, в котором используется кэш
// Возвращаемое значение:
//   Структура - структура с полями:
//    * Ключ - Строка
//    * ЗаполнитьПроконтролироватьКачествоДатаПодтвержденияКачества - См. КонтрольКачества.НовыйПараметрыДействия
//    * ЗаполнитьПодлежитРазблокировкеДатаПодтвержденияКачества - См. КонтрольКачества.НовыйПараметрыДействия
//    * ЗаполнитьКонтролируемуюПартиюОтправителя - См. КонтрольКачества.НовыйПараметрыДействия
Функция КэшПоКлючу(Кэш, Ключ = Неопределено) Экспорт
	
	Если Ключ = Неопределено Или ТипЗнч(Кэш) <> Тип("ФиксированныйМассив") Тогда
		Возврат Кэш;
	Иначе
		Для Каждого Элемент Из Кэш Цикл
			Если Элемент.Ключ = Ключ Тогда
				Возврат Элемент.Параметры;
			КонецЕсли;
		КонецЦикла;
		Возврат Неопределено;
	КонецЕсли;
	
КонецФункции

// Формирует представление элемента справочника "КонтролируемыеПартии".
// Параметры:
//  Реквизиты - см. КонтрольКачества.НовыйРеквизитыКонтролируемойПартии
//  КодЯзыка - Строка,Неопределено - код языка, если не указан, то представление будет на языке пользователя.
// Возвращаемое значение:
//  Строка - представление контролируемой партии.
Функция ПредставлениеКонтролируемойПартии(Реквизиты, КодЯзыка = Неопределено) Экспорт
	
	Если Не ТипЗнч(Реквизиты.Партия) = Тип("СправочникСсылка.СоглашенияСПоставщиками")
			И Не ТипЗнч(Реквизиты.Партия) = Тип("СправочникСсылка.ДоговорыКонтрагентов") Тогда
		
		Партия = Реквизиты.Партия;
		ХозяйственнаяОперация = Реквизиты.ХозяйственнаяОперация;
		ТипДокумента = НСтр("ru = 'Неизвестный документ'", КодЯзыка);
		Если ТипЗнч(Партия) = Тип("ДокументСсылка.ВозвратТоваровОтКлиента") Тогда
			ТипДокумента = НСтр("ru = 'Возврат товаров от клиента'", КодЯзыка);
		
		ИначеЕсли ТипЗнч(Партия) = Тип("ДокументСсылка.ПоступлениеТоваровОтКлиента") Тогда
			ТипДокумента = НСтр("ru = 'Поступление товаров от клиента'", КодЯзыка);
		
		
		ИначеЕсли ТипЗнч(Партия) = Тип("ДокументСсылка.ПеремещениеТоваров") Тогда
			ТипДокумента = НСтр("ru = 'Перемещение товаров'", КодЯзыка);
		ИначеЕсли ТипЗнч(Партия) = Тип("ДокументСсылка.ПоступлениеТоваровНаСклад") Тогда
			ТипДокумента = НСтр("ru = 'Поступление товаров на склад'", КодЯзыка);
		ИначеЕсли ТипЗнч(Партия) = Тип("ДокументСсылка.ПоступлениеТоваровОтХранителя") Тогда
			
			Если ХозяйственнаяОперация = ПредопределенноеЗначение("Перечисление.ХозяйственныеОперации.ВозвратОтХранителя") Тогда
				ТипДокумента = НСтр("ru = 'Возврат от хранителя'", КодЯзыка);
			ИначеЕсли ХозяйственнаяОперация = ПредопределенноеЗначение("Перечисление.ХозяйственныеОперации.ВозвратОтКомиссионера") Тогда
				ТипДокумента = НСтр("ru = 'Возврат от комиссионера'", КодЯзыка);
			
			
			КонецЕсли;
			
		ИначеЕсли ТипЗнч(Партия) = Тип("ДокументСсылка.ПриемкаТоваровНаХранение") Тогда
			
			Если ХозяйственнаяОперация = ПредопределенноеЗначение("Перечисление.ХозяйственныеОперации.ПриемНаХранениеСПравомПродажи") Тогда
				ТипДокумента = НСтр("ru = 'Прием на хранение с правом продажи'", КодЯзыка);
			
			
			КонецЕсли;
			
		ИначеЕсли ТипЗнч(Партия) = Тип("ДокументСсылка.ПриобретениеТоваровУслуг") Тогда
			ТипДокумента = НСтр("ru = 'Приобретение товаров и услуг'", КодЯзыка);
		
		
		ИначеЕсли ТипЗнч(Партия) = Тип("ДокументСсылка.ПрочееОприходованиеТоваров") Тогда
			ТипДокумента = НСтр("ru = 'Прочее оприходование товаров'", КодЯзыка);
		ИначеЕсли ТипЗнч(Партия) = Тип("ДокументСсылка.СборкаТоваров") Тогда
			ТипДокумента = НСтр("ru = 'Сборка (разборка) товаров'", КодЯзыка);
		
		
		ИначеЕсли ТипЗнч(Партия) = Тип("ДокументСсылка.ЗаявкаНаКонтрольКачестваТоваров") Тогда
			ТипДокумента = НСтр("ru = 'Заявка на контроль качества'", КодЯзыка);
		ИначеЕсли ТипЗнч(Партия) = Тип("ДокументСсылка.ЗаказПоставщику") Тогда
			ТипДокумента = НСтр("ru = 'Заказ поставщику'", КодЯзыка);
		ИначеЕсли ТипЗнч(Партия) = Тип("ДокументСсылка.ЗаявкаНаВозвратТоваровОтКлиента") Тогда
			ТипДокумента = НСтр("ru = 'Заявка на возврат товаров от клиента'", КодЯзыка);
		ИначеЕсли ТипЗнч(Партия) = Тип("ДокументСсылка.ЗаказНаСборку") Тогда
			ТипДокумента = НСтр("ru = 'Заказ на сборку (разборку)'", КодЯзыка);
		ИначеЕсли ТипЗнч(Партия) = Тип("ДокументСсылка.ЗаказНаПеремещение") Тогда
			ТипДокумента = НСтр("ru = 'Заказ на перемещение'", КодЯзыка);
		
		
		
		КонецЕсли;
		
		Представление = НСтр("ru = '%1 %2 от %3'", КодЯзыка);
		Представление = СтрШаблон(Представление,
			ТипДокумента,
			Реквизиты.НомерДокументаПоступления,
			Формат(Реквизиты.ДатаДокументаПоступления, "ДЛФ=D;"));
		
	ИначеЕсли ЗначениеЗаполнено(Реквизиты.Договор) Тогда // партия - договор
		
		Представление = НСтр("ru = 'Договор: %1'", КодЯзыка);
		Представление = СтрШаблон(Представление, Реквизиты.Договор);
		
	КонецЕсли;
	
	Возврат Представление;
	
КонецФункции

// Структура параметров для заполнения табличной части "Товары" рабочего места ТоварыНаКонтролеКачества.
// Возвращаемое значение:
//  Структура - структура с полями:
//   * НастройкиКомпоновки - НастройкиКомпоновкиДанных - настройки компоновки данных
//   * Отбор - Структура - структура с полями:
//      ** Склад - СправочникСсылка.Склады, Неопределено - отбор по складу.
//      ** Номенклатура - СправочникСсылка.Номенклатура, Неопределено - отбор по номенклатуре.
//      ** Назначение - СправочникСсылка.Назначения, Неопределено - отбор по назначению.
//      ** ЗаявкаОформлена - Булево, Неопределено - отбор для отображения только заявок или не заявок.
Функция ПараметрыЗаполненияТоваровДляКонтроляКачества() Экспорт
	
	ПараметрыЗаполнения = Новый Структура();
	ПоляОтбора = Новый Структура();
	ПоляОтбора.Вставить("Склад");
	ПоляОтбора.Вставить("Номенклатура");
	ПоляОтбора.Вставить("Назначение");
	ПоляОтбора.Вставить("ЗаявкаОформлена");
	ПараметрыЗаполнения.Вставить("Отбор", ПоляОтбора);
	ПараметрыЗаполнения.Вставить("НастройкиКомпоновки", Новый НастройкиКомпоновкиДанных);
	Возврат ПараметрыЗаполнения;
	
КонецФункции

// Конструктор структуры для передачи данных заполнения заявки на контроль качества товаров в форму документа.
// Возвращаемое значение:
//  Структура - структура с полями:
//   * ПричинаБлокировкиТовара - СправочникСсылка.ПричиныБлокировкиТоваров
Функция НовыеДанныеЗаполненияЗаявкиНаКонтрольКачестваТоваров() Экспорт
	
	Результат = Новый Структура();
	Результат.Вставить("ПричинаБлокировкиТовара", ПредопределенноеЗначение("Справочник.ПричиныБлокировкиТоваров.ПустаяСсылка"));
	Возврат Результат;
	
КонецФункции

#КонецОбласти