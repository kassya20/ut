#КонецОбласти 

#Область ПакетнаяОбработкаТабличныхЧастейСлужебная

// Возвращает список запросов для заполнения счета-фактуры.
//
// Возвращаемое значение:
// 	СписокЗначений Из Строка.
//
Функция ТекстыЗапросовЗаполнитьСчетФактуруПолученнуюВОтчетеКомитентуОЗакупках()
	
	Результат = Новый СписокЗначений;
	
	ТекстЗапроса =
	"ВЫБРАТЬ
	|	ВтИсточникДанных.ИдентификаторСтрокиВТ КАК ИдентификаторСтрокиВТ,
	|	ТаблицаДокументов.Ссылка КАК ДокументПриобретения,
	|	ТаблицаДокументов.Организация КАК Организация
	|ПОМЕСТИТЬ ТаблицаДокументовПриобретения
	|ИЗ
	|	ВтИсточникДанных КАК ВтИсточникДанных
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ПриобретениеТоваровУслуг КАК ТаблицаДокументов
	|		ПО ВтИсточникДанных.ДокументПриобретения = ТаблицаДокументов.Ссылка
	|		И (НЕ ТаблицаДокументов.НалогообложениеНДС В (&ВидыНалогообложения))
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ВтИсточникДанных.ИдентификаторСтрокиВТ,
	|	ТаблицаДокументов.Ссылка,
	|	ТаблицаДокументов.Организация
	|ИЗ
	|	ВтИсточникДанных КАК ВтИсточникДанных
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ВозвратТоваровПоставщику КАК ТаблицаДокументов
	|		ПО ВтИсточникДанных.ДокументПриобретения = ТаблицаДокументов.Ссылка
	|		И (НЕ ТаблицаДокументов.НалогообложениеНДС В (&ВидыНалогообложения))
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ВтИсточникДанных.ИдентификаторСтрокиВТ,
	|	ТаблицаДокументов.Ссылка,
	|	ТаблицаДокументов.Организация
	|ИЗ
	|	ВтИсточникДанных КАК ВтИсточникДанных
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.КорректировкаПриобретения КАК ТаблицаДокументов
	|		ПО ВтИсточникДанных.ДокументПриобретения = ТаблицаДокументов.Ссылка
	|		И (НЕ ТаблицаДокументов.НалогообложениеНДС В (&ВидыНалогообложения))";
	
	Результат.Добавить(ТекстЗапроса, "ТаблицаДокументовПриобретения");
	
	ТекстЗапроса =
	"ВЫБРАТЬ
	|	ВтИсточникДанных.ИдентификаторСтрокиВТ КАК ИдентификаторСтрокиВТ,
	|	ЕСТЬNULL(СчетаФактуры.Ссылка, ЗНАЧЕНИЕ(Документ.СчетФактураПолученный.ПустаяСсылка)) КАК Ссылка
	|ИЗ
	|	ВтИсточникДанных КАК ВтИсточникДанных
	|		ЛЕВОЕ СОЕДИНЕНИЕ ТаблицаДокументовПриобретения КАК ТаблицаДокументовПриобретения
	|		ПО ВтИсточникДанных.ИдентификаторСтрокиВТ = ТаблицаДокументовПриобретения.ИдентификаторСтрокиВТ
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.СчетФактураПолученный.ДокументыОснования КАК СчетаФактуры
	|		ПО ТаблицаДокументовПриобретения.ДокументПриобретения = СчетаФактуры.ДокументОснование
	|		И (СчетаФактуры.Ссылка.Проведен)
	|		И ТаблицаДокументовПриобретения.Организация В (СчетаФактуры.Ссылка.Организация, НЕОПРЕДЕЛЕНО)";
	
	Результат.Добавить(ТекстЗапроса, "ЗаполнитьСчетФактуруПолученнуюВОтчетеКомитентуОЗакупках");
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти

#Область ЗачетыАвансовПолученныхСчетамиФактурами

Процедура УстановитьПараметрыЗапросаЗачетыАвансовПолученныхСчетамиФактурами(Запрос, ПараметрыРасчета)
	
	Если НЕ ЗначениеЗаполнено(ПараметрыРасчета.ДатаОкончания) Тогда
		ДатаОкончания        = Дата(3000, 1, 1);
	Иначе
		ДатаОкончания        = ПараметрыРасчета.ДатаОкончания;
	КонецЕсли;
	
	ПустаяДата        = '00010101';
	
	Если ЗначениеЗаполнено(ПараметрыРасчета.Организации) Тогда
		Организации                 = ПараметрыРасчета.Организации;
	Иначе
		Организации                 = Неопределено;
	КонецЕсли;
	
	Запрос.УстановитьПараметр("ДатаНачала",           ПараметрыРасчета.ДатаНачала);
	Запрос.УстановитьПараметр("ДатаОкончания",        ДатаОкончания);
	Запрос.УстановитьПараметр("ПустаяДата",           ПустаяДата);
	Запрос.УстановитьПараметр("Организации",          Организации);
	Запрос.УстановитьПараметр("ВключитьОтборПоОрганизациям",        ПараметрыРасчета.ВключитьОтборПоОрганизациям);
	Запрос.УстановитьПараметр("ВключитьОтборПоКонтрагенту",        (ПараметрыРасчета.Свойство("РасчетныйДокумент") И ЗначениеЗаполнено(ПараметрыРасчета.РасчетныйДокумент)));
	Запрос.УстановитьПараметр("РасчетныйДокумент",                ?(ПараметрыРасчета.Свойство("РасчетныйДокумент") И ЗначениеЗаполнено(ПараметрыРасчета.РасчетныйДокумент), ПараметрыРасчета.РасчетныйДокумент, Неопределено));
	
КонецПроцедуры

#КонецОбласти

#Область ОбновлениеСчетовФактурВыданных

Процедура ЗарегистрироватьЗаданияАктуализацииСчетаФактуры(СчетаФактурыВыданные)
	
	ВидЗадания = Перечисления.ЗаданияУниверсальнойОчереди.ОбновлениеСчетовФактурВыданных;
	
	Для Каждого Документ Из СчетаФактурыВыданные Цикл
		УниверсальнаяОчередьОперативныхЗаданий.ДобавитьЗадание(Документ, ВидЗадания);
	КонецЦикла;
		
КонецПроцедуры

Функция ТекстЗапроса_ОбновлениеСчетовФактурВыданных()
	
	Текст = "ВЫБРАТЬ
	|	СчетФактураВыданныйДокументыОснования.Ссылка КАК СчетФактура,
	|	СчетФактураВыданныйДокументыОснования.ДокументОснование КАК ДокументОснование,
	|	СчетФактураВыданный.Склад КАК Склад,
	|	СчетФактураВыданный.Партнер КАК Партнер,
	|	СчетФактураВыданный.Договор КАК Договор,
	|	СчетФактураВыданный.Проведен КАК СчетФактураПроведен,
	|	СчетФактураВыданный.НаправлениеДеятельности КАК НаправлениеДеятельности
	|ПОМЕСТИТЬ ВТ_ДокументыОснования
	|ИЗ
	|	Документ.СчетФактураВыданный.ДокументыОснования КАК СчетФактураВыданныйДокументыОснования
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.СчетФактураВыданный КАК СчетФактураВыданный
	|		ПО (СчетФактураВыданныйДокументыОснования.Ссылка = СчетФактураВыданный.Ссылка)
	|ГДЕ
	|	СчетФактураВыданныйДокументыОснования.Ссылка В (&СчетФактуры)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ВТ_ДокументыОснования.СчетФактура КАК СчетФактура,
	|	ВЫРАЗИТЬ(РеестрДокументов.МестоХранения.Ключ КАК Справочник.Склады) КАК Склад,
	|	ВЫБОР
	|		КОГДА ТИПЗНАЧЕНИЯ(РеестрДокументов.Ссылка) = ТИП(Документ.ЗаписьКнигиПродаж)
	|			ТОГДА ЗаписьКнигиПродаж.Контрагент.Партнер
	|		ИНАЧЕ РеестрДокументов.Партнер
	|	КОНЕЦ КАК Партнер,
	|	РеестрДокументов.Договор КАК Договор,
	|	РеестрДокументов.НаправлениеДеятельности КАК НаправлениеДеятельности
	|ПОМЕСТИТЬ ВТ_ДанныеДокументовОснований
	|ИЗ
	|	РегистрСведений.РеестрДокументов КАК РеестрДокументов
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ЗаписьКнигиПродаж КАК ЗаписьКнигиПродаж
	|		ПО (РеестрДокументов.Ссылка = ЗаписьКнигиПродаж.Ссылка)
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ДокументыОснования КАК ВТ_ДокументыОснования
	|		ПО (РеестрДокументов.Ссылка = ВТ_ДокументыОснования.ДокументОснование)
	|ГДЕ
	|	РеестрДокументов.Ссылка В
	|		(ВЫБРАТЬ
	|			ВТ_ДокументыОснования.ДокументОснование
	|		ИЗ
	|			ВТ_ДокументыОснования)
	|	И НЕ РеестрДокументов.ДополнительнаяЗапись
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_ДанныеДокументовОснований.СчетФактура КАК СчетФактура,
	|	КОЛИЧЕСТВО(*) КАК КоличествоРазныхДокументовОснований
	|ПОМЕСТИТЬ ВТ_РазныеДокументыОснования
	|ИЗ
	|	ВТ_ДанныеДокументовОснований КАК ВТ_ДанныеДокументовОснований
	|СГРУППИРОВАТЬ ПО
	|	ВТ_ДанныеДокументовОснований.СчетФактура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ВТ_ДокументыОснования.СчетФактура КАК СчетФактура,
	|	ВТ_РазныеДокументыОснования.КоличествоРазныхДокументовОснований КАК КоличествоРазныхДокументовОснований
	|ПОМЕСТИТЬ ВТ_ДокументыКОбновлению
	|ИЗ
	|	ВТ_ДокументыОснования КАК ВТ_ДокументыОснования
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ДанныеДокументовОснований КАК ВТ_ДанныеДокументовОснований
	|		ПО ВТ_ДокументыОснования.СчетФактура = ВТ_ДанныеДокументовОснований.СчетФактура
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_РазныеДокументыОснования КАК ВТ_РазныеДокументыОснования
	|		ПО ВТ_ДокументыОснования.СчетФактура = ВТ_РазныеДокументыОснования.СчетФактура
	|ГДЕ
	|	ВТ_ДокументыОснования.СчетФактураПроведен
	|	И (ВТ_ДокументыОснования.Склад <> ВТ_ДанныеДокументовОснований.Склад
	|	ИЛИ ВТ_ДокументыОснования.Партнер <> ВТ_ДанныеДокументовОснований.Партнер
	|	ИЛИ ВТ_ДокументыОснования.Договор <> ВТ_ДанныеДокументовОснований.Договор
	|	ИЛИ ВТ_ДокументыОснования.НаправлениеДеятельности <> ВТ_ДанныеДокументовОснований.НаправлениеДеятельности)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_ДокументыКОбновлению.СчетФактура КАК СчетФактура,
	|	ВТ_ДокументыКОбновлению.КоличествоРазныхДокументовОснований КАК КоличествоРазныхДокументовОснований,
	|	ЕСТЬNULL(ВТ_ДанныеДокументовОснований.Склад, ЗНАЧЕНИЕ(Справочник.Склады.ПустаяССылка)) КАК Склад,
	|	ЕСТЬNULL(ВТ_ДанныеДокументовОснований.Партнер, ЗНАЧЕНИЕ(Справочник.Партнеры.ПустаяССылка)) КАК Партнер,
	|	ЕСТЬNULL(ВТ_ДанныеДокументовОснований.НаправлениеДеятельности,
	|		ЗНАЧЕНИЕ(Справочник.НаправленияДеятельности.ПустаяССылка)) КАК НаправлениеДеятельности,
	|	ЕСТЬNULL(ВТ_ДанныеДокументовОснований.Договор, ЗНАЧЕНИЕ(Справочник.ДоговорыКонтрагентов.ПустаяССылка)) КАК Договор
	|ИЗ
	|	ВТ_ДокументыКОбновлению КАК ВТ_ДокументыКОбновлению
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ДанныеДокументовОснований КАК ВТ_ДанныеДокументовОснований
	|		ПО ВТ_ДокументыКОбновлению.СчетФактура = ВТ_ДанныеДокументовОснований.СчетФактура
	|		И (ВТ_ДокументыКОбновлению.КоличествоРазныхДокументовОснований = 1)";
	
	Возврат Текст;
	
КонецФункции

Процедура ДополнитьОшибкиОбработки(ИдентификаторыНеОбработанныхЗаписей, Задания, Знач СчетФактура, Знач ТекстОшибкиОбработки)

	Поля = Новый Структура("Объект", НСтр("ru='Документ'"));
	Отбор = Новый Структура("Объект");
		
	Отбор.Объект = СчетФактура;
	НайденныеСтроки = Задания.НайтиСтроки(Отбор); 
	
	Для Каждого Строка Из НайденныеСтроки Цикл
		ТекстОшибки = ОтложенныеЗадания.ТекстОшибкиВыполнения(Поля, Строка, ТекстОшибкиОбработки);
		ИдентификаторыНеОбработанныхЗаписей.Вставить(Строка.ИдентификаторЗаписи, ТекстОшибки);
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти

#КонецОбласти
