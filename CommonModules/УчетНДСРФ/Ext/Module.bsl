	|								ЗНАЧЕНИЕ(Перечисление.ТипыНалогообложенияНДС.ПродажаНаЭкспорт))
	|			ТОГДА НЕ НДССостояниеРеализации0.Состояние ЕСТЬ NULL
	|		КОГДА РазрезыВычетаНДС.ВидДеятельностиНДС = ЗНАЧЕНИЕ(Перечисление.ТипыНалогообложенияНДС.ЭкспортНесырьевыхТоваров) ТОГДА
	|			ВЫБОР 
	|				КОГДА ЕСТЬNULL(ДанныеПервичныхДокументовСчетФактура.ДатаРегистратора, ДАТАВРЕМЯ(1,1,1)) < &ДатаНачалаДействия150ФЗ
	|					ТОГДА НЕ НДССостояниеРеализации0.Состояние ЕСТЬ NULL
	|				ИНАЧЕ ИСТИНА
	|			КОНЕЦ
	|		КОГДА РазрезыВычетаНДС.ВидДеятельностиНДС = ЗНАЧЕНИЕ(Перечисление.ТипыНалогообложенияНДС.ПроизводствоСДЦ)
	|			ТОГДА РазрезыВычетаНДС.РеализацияЭкспорт <> НЕОПРЕДЕЛЕНО
	|		КОГДА РазрезыВычетаНДС.ВидДеятельностиНДС = ЗНАЧЕНИЕ(Перечисление.ТипыНалогообложенияНДС.Космос)
	|			ТОГДА РазрезыВычетаНДС.РеализацияЭкспорт <> НЕОПРЕДЕЛЕНО
	|		КОГДА РазрезыВычетаНДС.ВидДеятельностиНДС = ЗНАЧЕНИЕ(Перечисление.ТипыНалогообложенияНДС.ПродажаОблагаетсяНДС)
	|			ТОГДА ИСТИНА
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Организация,
	|	СчетФактура
	|";
	
	Запрос.МенеджерВременныхТаблиц = ПараметрыРасчета.МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("ДатаНачалаДействия150ФЗ", УчетНДСУП.НастройкиУчета().ДатаРазделенияЭкспорта);
	Запрос.УстановитьПараметр("КонецПериода",  ПараметрыРасчета.КонецПериода);
	Запрос.УстановитьПараметр("НачалоПериода", ПараметрыРасчета.НачалоПериода);
	Запрос.УстановитьПараметр("КонецКвартала", КонецКвартала(ПараметрыРасчета.КонецПериода));
	Запрос.УстановитьПараметр("ТипыДокументовВычетаНДС",
		Метаданные.РегистрыНакопления.НДСПредъявленный.СтандартныеРеквизиты.Регистратор.Тип.Типы());
	Запрос.Выполнить();
	
КонецПроцедуры

// См. УчетНДСУПСлужебный.ПолучитьБлокировкиНДС
Процедура ПолучитьБлокировкиНДС(ПараметрыРасчета) Экспорт
	
	ПолучитьДокументыОплатыЭлектронныхУслуг(ПараметрыРасчета);
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Оплаты.Организация КАК Организация,
	|	Оплаты.СчетФактура КАК СчетФактура,
	|	ВЫРАЗИТЬ(МАКСИМУМ(Оплаты.СуммаПриобретения) КАК ЧИСЛО(15, 2)) КАК СуммаПриобретения,
	|	ВЫРАЗИТЬ(СУММА(Оплаты.СуммаОплаты) КАК ЧИСЛО(15, 2)) КАК СуммаОплаты,
	|	ВЫРАЗИТЬ(МАКСИМУМ(Оплаты.НДСПриобретения) КАК ЧИСЛО(15, 2)) КАК НДСПриобретения
	|ПОМЕСТИТЬ ОплаченныеЭлектронныеУслуги
	|ИЗ
	|	ДокументыОплатыЭлектронныхУслуг КАК Оплаты
	|
	|СГРУППИРОВАТЬ ПО
	|	Оплаты.Организация,
	|	Оплаты.СчетФактура
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Организация,
	|	СчетФактура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	БлокировкаВычетаНДССчетаФактуры.СчетФактура КАК СчетФактура,
	|	МАКСИМУМ(БлокировкаВычетаНДССчетаФактуры.Ссылка.Дата) КАК ДатаПоследнегоДокумента
	|ПОМЕСТИТЬ ДатыПоследнихОперацийПоБлокировке
	|ИЗ
	|	Документ.БлокировкаВычетаНДС.СчетаФактуры КАК БлокировкаВычетаНДССчетаФактуры
	|ГДЕ
	|	НЕ БлокировкаВычетаНДССчетаФактуры.Ссылка.ПометкаУдаления
	|	И БлокировкаВычетаНДССчетаФактуры.Ссылка.Дата <= &КонецПериода
	|	И (БлокировкаВычетаНДССчетаФактуры.Ссылка.Организация, БлокировкаВычетаНДССчетаФактуры.СчетФактура) В
	|			(ВЫБРАТЬ
	|				Задания.Организация,
	|				Задания.СчетФактура
	|			ИЗ
	|				Задания КАК Задания)
	|СГРУППИРОВАТЬ ПО
	|	БлокировкаВычетаНДССчетаФактуры.СчетФактура
	|ИНДЕКСИРОВАТЬ ПО
	|	СчетФактура,
	|	ДатаПоследнегоДокумента
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	БлокировкаВычетаНДССчетаФактуры.СчетФактура КАК СчетФактура,
	|	МАКСИМУМ(БлокировкаВычетаНДССчетаФактуры.Ссылка) КАК Ссылка
	|ПОМЕСТИТЬ ВТ_СрезПоследнихДокументовБлокировки
	|ИЗ
	|	Документ.БлокировкаВычетаНДС.СчетаФактуры КАК БлокировкаВычетаНДССчетаФактуры
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ДатыПоследнихОперацийПоБлокировке
	|		ПО ДатыПоследнихОперацийПоБлокировке.СчетФактура = БлокировкаВычетаНДССчетаФактуры.СчетФактура
	|			И ДатыПоследнихОперацийПоБлокировке.ДатаПоследнегоДокумента = БлокировкаВычетаНДССчетаФактуры.Ссылка.Дата
	|ГДЕ
	|	НЕ БлокировкаВычетаНДССчетаФактуры.Ссылка.ПометкаУдаления
	|СГРУППИРОВАТЬ ПО
	|	БлокировкаВычетаНДССчетаФактуры.СчетФактура
	|ИНДЕКСИРОВАТЬ ПО
	|	СчетФактура,
	|	Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЧастичноПодтвержденныеРеализации0.Организация КАК Организация,
	|	ЧастичноПодтвержденныеРеализации0.СчетФактура КАК СчетФактура,
	|	ВЫРАЗИТЬ(ЧастичноПодтвержденныеРеализации0.НДСПриобретения *
	|		ВЫРАЗИТЬ((ЧастичноПодтвержденныеРеализации0.СуммаРеализации - ЧастичноПодтвержденныеРеализации0.СуммаПодтверждения)
	|		/ ЧастичноПодтвержденныеРеализации0.СуммаРеализации КАК ЧИСЛО(21, 8)) КАК ЧИСЛО(15, 2)) КАК ЗаблокированныйНДС,
	|	ЧастичноПодтвержденныеРеализации0.ДокументОтгрузки КАК РеализацияЭкспорт
	|ПОМЕСТИТЬ ЧастичноПодтвержденныеРеализации0
	|ИЗ
	|	НалоговаяБазаРеализации0 КАК ЧастичноПодтвержденныеРеализации0
	|ГДЕ
	|	ЧастичноПодтвержденныеРеализации0.Состояние = ЗНАЧЕНИЕ(Перечисление.НДССостоянияРеализация0.ЧастичноПодтвержденаРеализация0)
	|	И ЧастичноПодтвержденныеРеализации0.СуммаРеализации > ЧастичноПодтвержденныеРеализации0.СуммаПодтверждения
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВсеБлокировки.Организация КАК Организация,
	|	ВсеБлокировки.СчетФактура КАК СчетФактура,
	|	МАКСИМУМ(ВсеБлокировки.НДС) КАК НДС
	|ПОМЕСТИТЬ БлокировкаВычетаНДС
	|ИЗ
	|	(ВЫБРАТЬ РАЗЛИЧНЫЕ
	|		ЗаблокированныеСФ.Ссылка.Организация КАК Организация,
	|		ЗаблокированныеСФ.СчетФактура КАК СчетФактура,
	|		СУММА(ЗаблокированныеСФ.НДС) КАК НДС
	|	ИЗ
	|		Документ.БлокировкаВычетаНДС.СчетаФактуры КАК ЗаблокированныеСФ
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_СрезПоследнихДокументовБлокировки КАК ВТ_СрезПоследнихДокументовБлокировки
	|			ПО ЗаблокированныеСФ.СчетФактура = ВТ_СрезПоследнихДокументовБлокировки.СчетФактура
	|				И ЗаблокированныеСФ.Ссылка = ВТ_СрезПоследнихДокументовБлокировки.Ссылка
	|	ГДЕ
	|		(ЗаблокированныеСФ.СрокБлокировки = ДАТАВРЕМЯ(1, 1, 1, 0, 0, 0)
	|				ИЛИ ЗаблокированныеСФ.СрокБлокировки > &КонецПериода)
	|		И ЗаблокированныеСФ.Ссылка.Состояние = ЗНАЧЕНИЕ(Перечисление.СостоянияБлокировкиВычетаНДС.Установлена)
	|	
	|	СГРУППИРОВАТЬ ПО
	|		ЗаблокированныеСФ.Ссылка.Организация,
	|		ЗаблокированныеСФ.СчетФактура
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|
	|	ВЫБРАТЬ
	|		ОплаченныеЭлектронныеУслуги.Организация,
	|		ОплаченныеЭлектронныеУслуги.СчетФактура,
	|		ВЫБОР КОГДА ОплаченныеЭлектронныеУслуги.СуммаОплаты = 0
	|			ТОГДА 0
	|			ИНАЧЕ ВЫРАЗИТЬ(ОплаченныеЭлектронныеУслуги.НДСПриобретения
	|					* ВЫРАЗИТЬ((ОплаченныеЭлектронныеУслуги.СуммаПриобретения - ОплаченныеЭлектронныеУслуги.СуммаОплаты)
	|								/ ОплаченныеЭлектронныеУслуги.СуммаПриобретения КАК ЧИСЛО(21, 8)) КАК ЧИСЛО(15, 2))
	|		КОНЕЦ
	|	ИЗ
	|		ОплаченныеЭлектронныеУслуги КАК ОплаченныеЭлектронныеУслуги
	|	ГДЕ
	|		ОплаченныеЭлектронныеУслуги.СуммаПриобретения <> ОплаченныеЭлектронныеУслуги.СуммаОплаты
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ
	|		ЧастичноПодтвержденныеРеализации0.Организация,
	|		ЧастичноПодтвержденныеРеализации0.СчетФактура,
	|		СУММА(ЧастичноПодтвержденныеРеализации0.ЗаблокированныйНДС)
	|	ИЗ
	|		ЧастичноПодтвержденныеРеализации0 КАК ЧастичноПодтвержденныеРеализации0
	|	СГРУППИРОВАТЬ ПО
	|		ЧастичноПодтвержденныеРеализации0.Организация,
	|		ЧастичноПодтвержденныеРеализации0.СчетФактура) КАК ВсеБлокировки
	|СГРУППИРОВАТЬ ПО
	|	ВсеБлокировки.Организация,
	|	ВсеБлокировки.СчетФактура
	|;
	|ВЫБРАТЬ
	|		ЧастичноПодтвержденныеРеализации0.Организация КАК Организация,
	|		ЧастичноПодтвержденныеРеализации0.СчетФактура КАК СчетФактура,
	|		СУММА(ЧастичноПодтвержденныеРеализации0.ЗаблокированныйНДС) КАК НДС,
	|		ЧастичноПодтвержденныеРеализации0.РеализацияЭкспорт КАК РеализацияЭкспорт
	|ПОМЕСТИТЬ БлокировкаВычетаНДСРеализацияЭкспорт
	|ИЗ
	|		ЧастичноПодтвержденныеРеализации0 КАК ЧастичноПодтвержденныеРеализации0
	|	СГРУППИРОВАТЬ ПО
	|		ЧастичноПодтвержденныеРеализации0.Организация,
	|		ЧастичноПодтвержденныеРеализации0.СчетФактура,
	|		ЧастичноПодтвержденныеРеализации0.РеализацияЭкспорт";
	
	Запрос.МенеджерВременныхТаблиц = ПараметрыРасчета.МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("КонецПериода", ПараметрыРасчета.КонецПериода);
	Запрос.УстановитьПараметр("НачалоПериода", ПараметрыРасчета.НачалоПериода);
	Запрос.Выполнить();
		
КонецПроцедуры

// См. УчетНДСУПСлужебный.РассчитатьЗаписиНДСПредъявленныйВосстановлениеПодВидДеятельности
Процедура РассчитатьЗаписиНДСПредъявленныйВосстановлениеПодВидДеятельности(ПараметрыРасчета) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	НДСПредъявленныйОстаткиНаКонецПериода.ИсправленныйСчетФактура КАК ИсправленныйСчетФактура,
	|	МАКСИМУМ(ПартииНДСКРаспределению.Регистратор) КАК Регистратор
	|ПОМЕСТИТЬ ИсправленныеСФКРаспределению
	|ИЗ
	|	НДСПредъявленныйОстаткиНаКонецПериода КАК НДСПредъявленныйОстаткиНаКонецПериода
	|	
	|	ЛЕВОЕ СОЕДИНЕНИЕ
	|		РегистрНакопления.ПартииНДСКРаспределению КАК ПартииНДСКРаспределению
	|	ПО
	|		ПартииНДСКРаспределению.Период МЕЖДУ &НачалоПериода И &КонецПериода
	|		И НДСПредъявленныйОстаткиНаКонецПериода.ИсправленныйСчетФактура = ПартииНДСКРаспределению.Регистратор
	|		И ПартииНДСКРаспределению.ВидДеятельностиНДС = ЗНАЧЕНИЕ(Перечисление.ТипыНалогообложенияНДС.ОпределяетсяРаспределением)
	|
	|СГРУППИРОВАТЬ ПО
	|	НДСПредъявленныйОстаткиНаКонецПериода.ИсправленныйСчетФактура
	|;
	|
	|ВЫБРАТЬ
	|	1 КАК Приоритет,
	|	ВЫБОР
	|		КОГДА ЕСТЬNULL(СчетаФактурыДокументы.ДатаЗаписиКнигиПокупок, ДАТАВРЕМЯ(1, 1, 1)) >= &НачалоПериода
	|			ТОГДА СчетаФактурыДокументы.ДатаЗаписиКнигиПокупок
	|		ИНАЧЕ &КонецПериода
	|	КОНЕЦ КАК Период,
	|	ЕСТЬNULL(СчетаФактурыДокументы.Ссылка, НДСПредъявленный.СчетФактура) КАК Регистратор,
	|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход) КАК ВидДвижения,
	|	НДСПредъявленный.Организация КАК Организация,
	|	НДСПредъявленный.СчетФактура КАК СчетФактура,
	|	НДСПредъявленный.Поставщик КАК Поставщик,
	|	НДСПредъявленный.ВидЦенности КАК ВидЦенности,
	|	НДСПредъявленный.СтавкаНДС КАК СтавкаНДС,
	|	НДСПредъявленный.ВидДеятельностиНДС КАК ВидДеятельностиНДС,
	|	НДСПредъявленный.ИсправленныйСчетФактура КАК ИсправленныйСчетФактура,
	|	НДСПредъявленный.РеализацияЭкспорт КАК РеализацияЭкспорт,
	|	НДСПредъявленный.НаправлениеДеятельности КАК НаправлениеДеятельности,
	|	НДСПредъявленный.ОтнестиКПредыдущемуКварталу КАК ОтнестиКПредыдущемуКварталу,
	|	НДСПредъявленный.ИсправляемыйПериод КАК ИсправляемыйПериод,
	|	НДСПредъявленный.ДатаИсправленияРаспределенияНДС КАК ДатаИсправленияРаспределенияНДС,
	|	-СУММА(НДСПредъявленный.СуммаБезНДС) КАК СуммаБезНДС,
	|	-СУММА(НДСПредъявленный.НДС) КАК НДС,
	|	-СУММА(НДСПредъявленный.НДСУпр) КАК НДСУпр,
	|	ЗНАЧЕНИЕ(Перечисление.СобытияНДСПредъявленный.ВосстановлениеНДСПодВидДеятельности) КАК Событие,
	|	ЗНАЧЕНИЕ(Перечисление.ТипыНалогообложенияНДС.ПустаяСсылка) КАК КорВидДеятельностиНДС,
	|	НЕОПРЕДЕЛЕНО КАК Подразделение,
	|	НЕОПРЕДЕЛЕНО КАК КорНаправлениеДеятельности,
	|	НЕОПРЕДЕЛЕНО КАК СтатьяРасходов,
	|	НЕОПРЕДЕЛЕНО КАК АналитикаРасходов,
	|	"""" КАК ИдентификаторСтроки,
	|	ИСТИНА КАК РегламентнаяОперация,
	|	ЛОЖЬ КАК Сторно,
	|	ЗНАЧЕНИЕ(Справочник.НастройкиХозяйственныхОпераций.ВосстановлениеНДС) КАК НастройкаХозяйственнойОперации
	|ПОМЕСТИТЬ НДСПредъявленныйВосстановлениеПодВидДеятельности
	|ИЗ
	|	НДСПредъявленныйОстаткиНаКонецПериода КАК НДСПредъявленный
	|		
	|	ЛЕВОЕ СОЕДИНЕНИЕ СчетаФактурыДокументы КАК СчетаФактурыДокументы
	|		ПО НДСПредъявленный.Организация = СчетаФактурыДокументы.Организация
	|			И НДСПредъявленный.СчетФактура = СчетаФактурыДокументы.СчетФактура
	|	
	|	ЛЕВОЕ СОЕДИНЕНИЕ
	|		СписанияНДСНаРасходы КАК СписанияНДСНаРасходы
	|	ПО
	|		НДСПредъявленный.Организация = СписанияНДСНаРасходы.Организация
	|		И НДСПредъявленный.СчетФактура = СписанияНДСНаРасходы.СчетФактура
	|	
	|	ЛЕВОЕ СОЕДИНЕНИЕ
	|		КорректировочныеСчетаФактуры КАК КорректировочныеСчетаФактуры
	|	ПО
	|		НДСПредъявленный.Организация = КорректировочныеСчетаФактуры.Организация
	|		И НДСПредъявленный.СчетФактура = КорректировочныеСчетаФактуры.СчетФактура
	|
	|	ЛЕВОЕ СОЕДИНЕНИЕ
	|		УчетныеПолитикиПоПериодичностиРасчетаНДС КАК УчетныеПолитикиПоПериодичностиРасчетаНДС
	|	ПО
	|		НДСПредъявленный.Организация = УчетныеПолитикиПоПериодичностиРасчетаНДС.Организация
	|	
	|	ЛЕВОЕ СОЕДИНЕНИЕ
	|		ИсправленныеСФКРаспределению КАК ИсправленныеСФКРаспределению
	|	ПО
	|		НДСПредъявленный.ИсправленныйСчетФактура = ИсправленныеСФКРаспределению.ИсправленныйСчетФактура
	|
	|ГДЕ
	|	(УчетныеПолитикиПоПериодичностиРасчетаНДС.ПериодичностьФормированияВычетовИВосстановленийНДС = ЗНАЧЕНИЕ(Перечисление.Периодичность.Месяц)
	|		И ИсправленныеСФКРаспределению.Регистратор ЕСТЬ NULL
	|	ИЛИ &КонецПериода = КОНЕЦПЕРИОДА(&КонецПериода, КВАРТАЛ))
	|	И КорректировочныеСчетаФактуры.СчетФактура ЕСТЬ NULL
	|	И СписанияНДСНаРасходы.СчетФактура ЕСТЬ NULL
	|	И НЕ НДСПредъявленный.СчетФактура = НЕОПРЕДЕЛЕНО
	|
	|СГРУППИРОВАТЬ ПО
	|	ЕСТЬNULL(СчетаФактурыДокументы.Ссылка, НДСПредъявленный.СчетФактура),
	|	НДСПредъявленный.Организация,
	|	НДСПредъявленный.СчетФактура,
	|	НДСПредъявленный.Поставщик,
	|	НДСПредъявленный.ВидЦенности,
	|	НДСПредъявленный.СтавкаНДС,
	|	НДСПредъявленный.ВидДеятельностиНДС,
	|	НДСПредъявленный.ИсправленныйСчетФактура,
	|	НДСПредъявленный.РеализацияЭкспорт,
	|	НДСПредъявленный.НаправлениеДеятельности,
	|	НДСПредъявленный.ОтнестиКПредыдущемуКварталу,
	|	НДСПредъявленный.ИсправляемыйПериод,
	|	НДСПредъявленный.ДатаИсправленияРаспределенияНДС,
	|	ВЫБОР
	|		КОГДА ЕСТЬNULL(СчетаФактурыДокументы.ДатаЗаписиКнигиПокупок, ДАТАВРЕМЯ(1, 1, 1)) >= &НачалоПериода
	|			ТОГДА СчетаФактурыДокументы.ДатаЗаписиКнигиПокупок
	|		ИНАЧЕ &КонецПериода
	|	КОНЕЦ
	|
	|ИМЕЮЩИЕ
	|	СУММА(НДСПредъявленный.СуммаБезНДС) < 0
	|	ИЛИ СУММА(НДСПредъявленный.НДС) < 0
	|";
	
	Запрос.УстановитьПараметр("НачалоПериода",     ПараметрыРасчета.НачалоПериода);
	Запрос.УстановитьПараметр("КонецПериода",      ПараметрыРасчета.КонецПериода);
	Запрос.УстановитьПараметр("МассивОрганизаций", ПараметрыРасчета.МассивОрганизаций);
	Запрос.МенеджерВременныхТаблиц = ПараметрыРасчета.МенеджерВременныхТаблиц;
	Запрос.Выполнить();
		
КонецПроцедуры

// См. УчетНДСУПСлужебный.ПолучитьПовторноПринятыйКВычетуНДС
Процедура ПолучитьПовторноПринятыйКВычетуНДС(ПараметрыРасчета) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	НДСЗаписиКнигиПокупок.Организация КАК Организация,
	|	НДСЗаписиКнигиПокупок.СчетФактура КАК СчетФактура,
	|	НДСЗаписиКнигиПокупок.Поставщик КАК Поставщик,
	|	НДСЗаписиКнигиПокупок.ВидЦенности КАК ВидЦенности,
	|	НДСЗаписиКнигиПокупок.СтавкаНДС КАК СтавкаНДС,
	|	НДСЗаписиКнигиПокупок.ИсправленныйСчетФактура КАК ИсправленныйСчетФактура,
	|	НДСЗаписиКнигиПокупок.НаправлениеДеятельности КАК НаправлениеДеятельности,
	|	-НДСЗаписиКнигиПокупок.СуммаБезНДС КАК СуммаБезНДС,
	|	-НДСЗаписиКнигиПокупок.НДС КАК НДС,
	|	-НДСЗаписиКнигиПокупок.НДСУпр КАК НДСУпр
	|ПОМЕСТИТЬ ПовторноПринятыйКВычетуНДС
	|ИЗ
	|	РегистрНакопления.НДСЗаписиКнигиПокупок КАК НДСЗаписиКнигиПокупок
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Задания КАК Задания
	|		ПО НДСЗаписиКнигиПокупок.Организация = Задания.Организация
	|			И НДСЗаписиКнигиПокупок.СчетФактура = Задания.СчетФактура
	|ГДЕ
	|	НДСЗаписиКнигиПокупок.Период < &НачалоПериода
	|	И НДСЗаписиКнигиПокупок.КодВидаОперации = ""25""";
	
	Запрос.МенеджерВременныхТаблиц = ПараметрыРасчета.МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("НачалоПериода", ПараметрыРасчета.НачалоПериода);
	Запрос.Выполнить();
		
КонецПроцедуры

// См. УчетНДСУПСлужебный.ПолучитьНалоговуюБазуРеализации0
Процедура ПолучитьНалоговуюБазуРеализации0(ПараметрыРасчета) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = ПараметрыРасчета.МенеджерВременныхТаблиц;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	НДСПредъявленныйОстаткиНаКонецПериода.СчетФактура КАК СчетФактура,
	|	НДССостояниеРеализации0.ДокументРеализации КАК ДокументОтгрузки,
	|	НДССостояниеРеализации0.Состояние КАК Состояние
	|ПОМЕСТИТЬ НДССостояниеРеализации0
	|ИЗ
	|	НДСПредъявленныйОстаткиНаКонецПериода КАК НДСПредъявленныйОстаткиНаКонецПериода
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.НДССостояниеРеализации0.СрезПоследних(&КонецПериода) КАК НДССостояниеРеализации0
	|		ПО НДСПредъявленныйОстаткиНаКонецПериода.Организация = НДССостояниеРеализации0.Организация
	|		И НДСПредъявленныйОстаткиНаКонецПериода.РеализацияЭкспорт = НДССостояниеРеализации0.ДокументРеализации
	|		И НДССостояниеРеализации0.Состояние В (ЗНАЧЕНИЕ(Перечисление.НДССостоянияРеализация0.ПодтвержденаРеализация0),
	|			ЗНАЧЕНИЕ(Перечисление.НДССостоянияРеализация0.ЧастичноПодтвержденаРеализация0),
	|			ЗНАЧЕНИЕ(Перечисление.НДССостоянияРеализация0.НеПодтвержденаРеализация0))
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	ДокументОтгрузки
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СУММА(СуммыДокументовВВалютахУчетаСрезПоследних.БазаНДСРегл) КАК БазаНДСРегл,
	|	СуммыДокументовВВалютахУчетаСрезПоследних.Регистратор КАК Регистратор
	|ПОМЕСТИТЬ СуммыДокументовВВалютахУчета
	|ИЗ
	|	РегистрСведений.СуммыДокументовВВалютахУчета.СрезПоследних(, Регистратор В
	|		(ВЫБРАТЬ
	|			Т.ДокументОтгрузки
	|		ИЗ
	|			НДССостояниеРеализации0 КАК Т)) КАК СуммыДокументовВВалютахУчетаСрезПоследних
	|СГРУППИРОВАТЬ ПО
	|	СуммыДокументовВВалютахУчетаСрезПоследних.Регистратор
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	НДССостояниеРеализации0.ДокументОтгрузки КАК ДокументОтгрузки,
	|	НДССостояниеРеализации0.Состояние КАК Состояние,
	|	СуммыДокументовВВалютахУчета.БазаНДСРегл КАК СуммаРеализации
	|ПОМЕСТИТЬ ДокументыРеализации0
	|ИЗ
	|	НДССостояниеРеализации0 КАК НДССостояниеРеализации0
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ СуммыДокументовВВалютахУчета КАК СуммыДокументовВВалютахУчета
	|		ПО НДССостояниеРеализации0.ДокументОтгрузки = СуммыДокументовВВалютахУчета.Регистратор
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	ДокументОтгрузки
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ЕСТЬNULL(НДСПредъявленный.Организация, НДСПредъявленныйИзменениеВидаДеятельности.Организация) КАК Организация,
	|	ЕСТЬNULL(НДСПредъявленный.СчетФактура, НДСПредъявленныйИзменениеВидаДеятельности.СчетФактура) КАК СчетФактура,
	|	НДССостояниеРеализации0.ДокументОтгрузки КАК ДокументОтгрузки,
	|	НДССостояниеРеализации0.Состояние КАК Состояние,
	|	СУММА(ЕСТЬNULL(НДСПредъявленный.НДС, НДСПредъявленныйИзменениеВидаДеятельности.НДС)) КАК НДСПриобретения
	|ПОМЕСТИТЬ НДСПредъявленныйРеализацияЭкспорт
	|ИЗ
	|	НДССостояниеРеализации0 КАК НДССостояниеРеализации0
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.НДСПредъявленный КАК НДСПредъявленный
	|		ПО НДССостояниеРеализации0.ДокументОтгрузки = НДСПредъявленный.РеализацияЭкспорт
	|		И НДССостояниеРеализации0.СчетФактура = НДСПредъявленный.СчетФактура
	|		И НДСПредъявленный.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход)
	|		И НДСПредъявленный.ВидДеятельностиНДС = ЗНАЧЕНИЕ(Перечисление.ТипыНалогообложенияНДС.ЭкспортСырьевыхТоваровУслуг)
	|		И (НДСПредъявленный.Событие = ЗНАЧЕНИЕ(Перечисление.СобытияНДСПредъявленный.Реализация)
	|			И НДСПредъявленный.Период <= &НачалоПериода
	|			ИЛИ НДСПредъявленный.НастройкаХозяйственнойОперации = ЗНАЧЕНИЕ(Справочник.НастройкиХозяйственныхОпераций.ВводОстатковНДСПоПриобретеннымЦенностям))
	|		ЛЕВОЕ СОЕДИНЕНИЕ НДСПредъявленныйИзменениеВидаДеятельности КАК НДСПредъявленныйИзменениеВидаДеятельности
	|		ПО НДССостояниеРеализации0.ДокументОтгрузки = НДСПредъявленныйИзменениеВидаДеятельности.РеализацияЭкспорт
	|		И НДССостояниеРеализации0.СчетФактура = НДСПредъявленныйИзменениеВидаДеятельности.СчетФактура
	|		И НДСПредъявленныйИзменениеВидаДеятельности.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход)
	|		И НДСПредъявленныйИзменениеВидаДеятельности.ВидДеятельностиНДС = ЗНАЧЕНИЕ(Перечисление.ТипыНалогообложенияНДС.ЭкспортСырьевыхТоваровУслуг)
	|		И НДСПредъявленныйИзменениеВидаДеятельности.Событие = ЗНАЧЕНИЕ(Перечисление.СобытияНДСПредъявленный.Реализация)
	|СГРУППИРОВАТЬ ПО
	|	ЕСТЬNULL(НДСПредъявленный.Организация, НДСПредъявленныйИзменениеВидаДеятельности.Организация),
	|	ЕСТЬNULL(НДСПредъявленный.СчетФактура, НДСПредъявленныйИзменениеВидаДеятельности.СчетФактура),
	|	НДССостояниеРеализации0.ДокументОтгрузки,
	|	НДССостояниеРеализации0.Состояние
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Организация,
	|	СчетФактура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	НДСПредъявленныйРеализацияЭкспорт.Организация КАК Организация,
	|	НДСПредъявленныйРеализацияЭкспорт.СчетФактура КАК СчетФактура,
	|	НДСПредъявленныйРеализацияЭкспорт.Состояние КАК Состояние,
	|	МАКСИМУМ(НДСПредъявленныйРеализацияЭкспорт.НДСПриобретения) КАК НДСПриобретения,
	|	МАКСИМУМ(ДокументыРеализации0.СуммаРеализации) КАК СуммаРеализации,
	|	ДокументыРеализации0.ДокументОтгрузки КАК ДокументОтгрузки,
	|	ЕСТЬNULL(КодыОперацийНалоговаяБаза.КодОперации, """") КАК КодОперации,
	|	СУММА(ЕСТЬNULL(КодыОперацийНалоговаяБаза.ПродажиСНДС0, ПодтверждениеНулевойСтавкиНДС.ПродажиСНДС0)) КАК СуммаПодтверждения
	|ПОМЕСТИТЬ НалоговаяБазаРеализации0ВРазрезеКодовОпераций
	|ИЗ
	|	ДокументыРеализации0 КАК ДокументыРеализации0
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ НДСПредъявленныйРеализацияЭкспорт КАК НДСПредъявленныйРеализацияЭкспорт
	|		ПО ДокументыРеализации0.ДокументОтгрузки = НДСПредъявленныйРеализацияЭкспорт.ДокументОтгрузки
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ПодтверждениеНулевойСтавкиНДС.Состав КАК ПодтверждениеНулевойСтавкиНДС
	|		ПО ДокументыРеализации0.ДокументОтгрузки = ПодтверждениеНулевойСтавкиНДС.ДокументОтгрузки
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ НДССостояниеРеализации0 КАК НДССостояниеРеализации0
	|		ПО ПодтверждениеНулевойСтавкиНДС.ДокументОтгрузки = НДССостояниеРеализации0.ДокументОтгрузки
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ПодтверждениеНулевойСтавкиНДС.КодыОперацийНалоговаяБаза КАК КодыОперацийНалоговаяБаза
	|		ПО КодыОперацийНалоговаяБаза.Ссылка = ПодтверждениеНулевойСтавкиНДС.Ссылка
	|		И КодыОперацийНалоговаяБаза.КлючСтроки = ПодтверждениеНулевойСтавкиНДС.КлючСтроки
	|ГДЕ
	|	ПодтверждениеНулевойСтавкиНДС.Ссылка.Проведен
	|	И ПодтверждениеНулевойСтавкиНДС.Ссылка.Дата <= &КонецПериода
	|	И НЕ ЕСТЬNULL(КодыОперацийНалоговаяБаза.НесырьевыеТовары, ЛОЖЬ)
	|СГРУППИРОВАТЬ ПО
	|	ЕСТЬNULL(КодыОперацийНалоговаяБаза.КодОперации, """"),
	|	ДокументыРеализации0.ДокументОтгрузки,
	|	НДСПредъявленныйРеализацияЭкспорт.Состояние,
	|	НДСПредъявленныйРеализацияЭкспорт.СчетФактура,
	|	НДСПредъявленныйРеализацияЭкспорт.Организация
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	НалоговаяБазаРеализации0ВРазрезеКодовОпераций.Организация КАК Организация,
	|	НалоговаяБазаРеализации0ВРазрезеКодовОпераций.СчетФактура КАК СчетФактура,
	|	НалоговаяБазаРеализации0ВРазрезеКодовОпераций.Состояние КАК Состояние,
	|	МАКСИМУМ(НалоговаяБазаРеализации0ВРазрезеКодовОпераций.НДСПриобретения) КАК НДСПриобретения,
	|	НалоговаяБазаРеализации0ВРазрезеКодовОпераций.ДокументОтгрузки КАК ДокументОтгрузки,
	|	МАКСИМУМ(НалоговаяБазаРеализации0ВРазрезеКодовОпераций.СуммаРеализации) КАК СуммаРеализации,
	|	СУММА(НалоговаяБазаРеализации0ВРазрезеКодовОпераций.СуммаПодтверждения) КАК СуммаПодтверждения
	|ПОМЕСТИТЬ НалоговаяБазаРеализации0
	|ИЗ
	|	НалоговаяБазаРеализации0ВРазрезеКодовОпераций КАК НалоговаяБазаРеализации0ВРазрезеКодовОпераций
	|СГРУППИРОВАТЬ ПО
	|	НалоговаяБазаРеализации0ВРазрезеКодовОпераций.Организация,
	|	НалоговаяБазаРеализации0ВРазрезеКодовОпераций.СчетФактура,
	|	НалоговаяБазаРеализации0ВРазрезеКодовОпераций.Состояние,
	|	НалоговаяБазаРеализации0ВРазрезеКодовОпераций.ДокументОтгрузки";
	
	Запрос.УстановитьПараметр("НачалоПериода",  ПараметрыРасчета.НачалоПериода);
	Запрос.УстановитьПараметр("КонецПериода",  ПараметрыРасчета.КонецПериода);
	Запрос.УстановитьПараметр("МассивОрганизаций", ПараметрыРасчета.МассивОрганизаций);
	Запрос.Выполнить();
		
КонецПроцедуры

Процедура ПолучитьЗачетыАвансовПолученныхСчетамиФактурами(МенеджерВременныхТаблиц, ПараметрыРасчета) Экспорт
	
	Запрос = Новый Запрос;
	
	УстановитьПараметрыЗапросаЗачетыАвансовПолученныхСчетамиФактурами(Запрос, ПараметрыРасчета);
	
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ЗачетыАвансовСчетамиФактурами.ОбъектРасчетов.Организация КАК Организация,
	|	ЗачетыАвансовСчетамиФактурами.Регистратор КАК ДокументРегистратор,
	|	ЗачетыАвансовСчетамиФактурами.Контрагент КАК Контрагент,
	|	ЗачетыАвансовСчетамиФактурами.Договор КАК Договор,
	|	МАКСИМУМ(ЗачетыАвансовСчетамиФактурами.Период) КАК Дата,
	|	ЗачетыАвансовСчетамиФактурами.ОбъектРасчетов КАК ОбъектРасчетов,
	|	ЗачетыАвансовСчетамиФактурами.ОбъектРасчетов.НаправлениеДеятельности КАК НаправлениеДеятельности,
	|	ЗачетыАвансовСчетамиФактурами.ОбъектРасчетов.НалогообложениеНДС КАК НалогообложениеНДС,
	|	ЗачетыАвансовСчетамиФактурами.ОбъектРасчетов.Валюта КАК Валюта,
	|	ЗачетыАвансовСчетамиФактурами.РасчетныйДокумент КАК ДокументОплаты,
	|	СУММА(ЗачетыАвансовСчетамиФактурами.СуммаРегл) КАК СуммаРегл,
	|	СУММА(ЗачетыАвансовСчетамиФактурами.Сумма) КАК Сумма
	|ПОМЕСТИТЬ ЗачетыАвансовПолученныхСчетамиФактурамиПредварительная
	|ИЗ
	|	РегистрНакопления.ЗачетыАвансовСчетамиФактурами КАК ЗачетыАвансовСчетамиФактурами
	|ГДЕ
	|	ЗачетыАвансовСчетамиФактурами.Период МЕЖДУ &ДатаНачала И &ДатаОкончания
	|	И (НЕ &ВключитьОтборПоОрганизациям
	|			ИЛИ ЗачетыАвансовСчетамиФактурами.ОбъектРасчетов.Организация В (&Организации))
	|	И НЕ ЗачетыАвансовСчетамиФактурами.КорректировкаНаУменьшение
	|	И ЗачетыАвансовСчетамиФактурами.Активность = ИСТИНА
	|СГРУППИРОВАТЬ ПО
	|	ЗачетыАвансовСчетамиФактурами.Контрагент,
	|	ЗачетыАвансовСчетамиФактурами.Договор,
	|	ЗачетыАвансовСчетамиФактурами.ОбъектРасчетов,
	|	ЗачетыАвансовСчетамиФактурами.РасчетныйДокумент,
	|	ЗачетыАвансовСчетамиФактурами.Регистратор
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	ДокументРегистратор
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЗачетыАвансовСчетамиФактурами.Организация КАК Организация,
	|	ЗачетыАвансовСчетамиФактурами.ДокументРегистратор КАК ДокументРегистратор,
	|	ЗачетыАвансовСчетамиФактурами.Контрагент КАК Контрагент,
	|	ЗачетыАвансовСчетамиФактурами.Договор КАК Договор,
	|	ЗачетыАвансовСчетамиФактурами.Дата КАК Дата,
	|	ЗачетыАвансовСчетамиФактурами.ОбъектРасчетов КАК ОбъектРасчетов,
	|	ЗачетыАвансовСчетамиФактурами.НаправлениеДеятельности КАК НаправлениеДеятельности,
	|	ЗачетыАвансовСчетамиФактурами.НалогообложениеНДС КАК НалогообложениеНДС,
	|	ЗачетыАвансовСчетамиФактурами.Валюта КАК Валюта,
	|	ЗачетыАвансовСчетамиФактурами.ДокументОплаты КАК ДокументОплаты,
	|	ЗачетыАвансовСчетамиФактурами.СуммаРегл КАК СуммаРегл,
	|	ЗачетыАвансовСчетамиФактурами.Сумма КАК Сумма
	|ПОМЕСТИТЬ ЗачетыАвансовПолученныхСчетамиФактурами
	|ИЗ
	|	ЗачетыАвансовПолученныхСчетамиФактурамиПредварительная КАК ЗачетыАвансовСчетамиФактурами
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.РеестрДокументов КАК РеестрДокументов
	|		ПО ЗачетыАвансовСчетамиФактурами.ДокументРегистратор = РеестрДокументов.Ссылка
	|			И (НЕ &ВключитьОтборПоКонтрагенту
	|				ИЛИ ЗачетыАвансовСчетамиФактурами.Контрагент = РеестрДокументов.Контрагент)
	|			И (НЕ &ВключитьОтборПоКонтрагенту
	|				ИЛИ ЗачетыАвансовСчетамиФактурами.Договор = РеестрДокументов.Договор)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ ЗачетыАвансовПолученныхСчетамиФактурамиПредварительная";
	
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	
	Запрос.Выполнить();
	
КонецПроцедуры

