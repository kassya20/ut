	|	ЛЕВОЕ СОЕДИНЕНИЕ
	|		НДСЗаписиКнигиПродажПоНДСПредъявленныйСводно КАК НДСЗаписиКнигиПродажПоНДСПредъявленныйСводно
	|	ПО
	|		НДСЗаписиКнигиПродажПоНДСПредъявленныйПредварительно.Период = НДСЗаписиКнигиПродажПоНДСПредъявленныйСводно.Период
	|		И НДСЗаписиКнигиПродажПоНДСПредъявленныйПредварительно.Регистратор = НДСЗаписиКнигиПродажПоНДСПредъявленныйСводно.Регистратор
	|		И НДСЗаписиКнигиПродажПоНДСПредъявленныйПредварительно.Организация = НДСЗаписиКнигиПродажПоНДСПредъявленныйСводно.Организация
	|		И НДСЗаписиКнигиПродажПоНДСПредъявленныйПредварительно.Покупатель = НДСЗаписиКнигиПродажПоНДСПредъявленныйСводно.Покупатель
	|		И НДСЗаписиКнигиПродажПоНДСПредъявленныйПредварительно.СчетФактура = НДСЗаписиКнигиПродажПоНДСПредъявленныйСводно.СчетФактура
	|		И НДСЗаписиКнигиПродажПоНДСПредъявленныйПредварительно.ВидЦенности = НДСЗаписиКнигиПродажПоНДСПредъявленныйСводно.ВидЦенности
	|		И НДСЗаписиКнигиПродажПоНДСПредъявленныйПредварительно.СтавкаНДС = НДСЗаписиКнигиПродажПоНДСПредъявленныйСводно.СтавкаНДС
	|		И НДСЗаписиКнигиПродажПоНДСПредъявленныйПредварительно.ИсправленныйСчетФактура = НДСЗаписиКнигиПродажПоНДСПредъявленныйСводно.ИсправленныйСчетФактура
	|		И НДСЗаписиКнигиПродажПоНДСПредъявленныйПредварительно.ВидДеятельностиНДС = НДСЗаписиКнигиПродажПоНДСПредъявленныйСводно.ВидДеятельностиНДС
	|		И НДСЗаписиКнигиПродажПоНДСПредъявленныйПредварительно.НаправлениеДеятельности = НДСЗаписиКнигиПродажПоНДСПредъявленныйСводно.НаправлениеДеятельности
	|		И ТИПЗНАЧЕНИЯ(НДСЗаписиКнигиПродажПоНДСПредъявленныйПредварительно.Регистратор) = ТИП(Документ.РаспределениеНДС)
	|ГДЕ
	|	ЕСТЬNULL(НДСЗаписиКнигиПродажПоНДСПредъявленныйСводно.СуммаБезНДС, 1) <> 0
	|	ИЛИ ЕСТЬNULL(НДСЗаписиКнигиПродажПоНДСПредъявленныйСводно.НДС, 1) <> 0
	|	ИЛИ ЕСТЬNULL(НДСЗаписиКнигиПродажПоНДСПредъявленныйСводно.НДСУпр, 1) <> 0
	|";
	
	Запрос.МенеджерВременныхТаблиц = ПараметрыРасчета.МенеджерВременныхТаблиц;
	Запрос.Выполнить();
	
	Возврат "НДСЗаписиКнигиПродажПоНДСПредъявленный";
	
КонецФункции

