Процедура ОбработкаПолученияДанныхВыбора(Параметры, Запрос, ТекстЗапроса) Экспорт
	
	//++ Локализация
	
	Если Параметры.Отбор.Свойство("ВидПродукцииИС") Тогда
		
		Запрос.УстановитьПараметр("ВидыПродукцииИС", Параметры.Отбор.ВидПродукцииИС);
		
		УсловиеОтбора = "
		|	1 В (
		|		ВЫБРАТЬ 1
		|		ИЗ
		|			РегистрСведений.ОписаниеНоменклатурыИС КАК ОписаниеНоменклатурыИС
		|		ГДЕ
		|			ОписаниеНоменклатурыИС.Номенклатура = СпрНоменклатура.Ссылка
		|			И ОписаниеНоменклатурыИС.КлючВидовПродукции.ВидПродукцииЕГАИС В (&ВидыПродукцииИС)
		|		
		|		ОБЪЕДИНИТЬ ВСЕ
		|		
		|		ВЫБРАТЬ 1
		|		ИЗ
		|			РегистрСведений.ОписаниеНоменклатурыИС КАК ОписаниеНоменклатурыИС
		|		ГДЕ
		|			ОписаниеНоменклатурыИС.Номенклатура = СпрНоменклатура.Ссылка
		|			И ОписаниеНоменклатурыИС.КлючВидовПродукции.ВидПродукцииВЕТИС В (&ВидыПродукцииИС)
		|	
		|		ОБЪЕДИНИТЬ ВСЕ
		|		
		|		ВЫБРАТЬ 1
		|		ИЗ
		|			РегистрСведений.ОписаниеНоменклатурыИС КАК ОписаниеНоменклатурыИС
		|		ГДЕ
		|			ОписаниеНоменклатурыИС.Номенклатура = СпрНоменклатура.Ссылка
		|			И ОписаниеНоменклатурыИС.КлючВидовПродукции.ВидПродукцииГИСМТ В (&ВидыПродукцииИС)
		|	
		|		ОБЪЕДИНИТЬ ВСЕ
		|		
		|		ВЫБРАТЬ 1
		|		ИЗ
		|			РегистрСведений.ОписаниеНоменклатурыИС КАК ОписаниеНоменклатурыИС
		|		ГДЕ
		|			ОписаниеНоменклатурыИС.Номенклатура = СпрНоменклатура.Ссылка
		|			И ОписаниеНоменклатурыИС.КлючВидовПродукции.ВидПродукцииЗЕРНО В (&ВидыПродукцииИС)
		|	
		|		ОБЪЕДИНИТЬ ВСЕ
		|		
		|		ВЫБРАТЬ 1
		|		ИЗ
		|			РегистрСведений.ОписаниеНоменклатурыИС КАК ОписаниеНоменклатурыИС
		|		ГДЕ
		|			ОписаниеНоменклатурыИС.Номенклатура = СпрНоменклатура.Ссылка
		|			И ОписаниеНоменклатурыИС.КлючВидовПродукции.ВидПродукцииСАТУРН В (&ВидыПродукцииИС)
		|	)
		|	И &УсловиеОтбора";
		
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&УсловиеОтбора", УсловиеОтбора);
		
	КонецЕсли;
	
	//-- Локализация
	
КонецПроцедуры

// Возвращает коллекцию текстов запроса замены локализуемых реквизитов справочника Номенклатура.
//
// Возвращаемое значение:
//	Структура - коллекция текстов запроса:
//		* РеквизитыНоменклатурыВыборка - Строка - текст запроса реквизитов номенклатуры для полей выборки запроса.
//		* РеквизитыНоменклатурыГруппировка - Строка - текст запроса реквизитов номенклатуры для полей группировки запроса.
//		* РеквизитыНоменклатурыСоединения - Строка - текст запроса реквизитов номенклатуры для соединений запроса.
//
Функция ТекстыЗапросаРеквизитовНоменклатуры() Экспорт
	
	ТекстыЗапроса = Новый Структура;
	ТекстыЗапроса.Вставить("РеквизитыНоменклатурыВыборка",     "НЕОПРЕДЕЛЕНО");
	ТекстыЗапроса.Вставить("РеквизитыНоменклатурыГруппировка", "НЕОПРЕДЕЛЕНО");
	ТекстыЗапроса.Вставить("РеквизитыНоменклатурыСоединения",  "");
	
	Возврат ТекстыЗапроса;
	
КонецФункции

// Заполняет коллекцию текстов запроса замены локализуемых реквизитов справочника Номенклатура.
//
// Параметры:
//	ИсточникНоменклатуры - Строка - описание источника данных номенклатуры, из которого будут получены данные справочника.
//									Например, "ТаблицаТовары.Номенклатура"
//									или "ВЫРАЗИТЬ(&Номенклатура КАК Справочник.Номенклатура).
//	ТекстыЗапроса - см. ТекстыЗапросаРеквизитовНоменклатуры.
//
Процедура ЗаполнитьТекстЗапросаРеквизитыНоменклатуры(ИсточникНоменклатуры, ТекстыЗапроса) Экспорт
	
	//++ Локализация
	
	ТекстыЗапросаВыборки = Новый Массив;
	ТекстыЗапросаГруппировки = Новый Массив;
	ТекстыЗапросаСоединения = Новый Массив;
	
	Если ПолучитьФункциональнуюОпцию("ВестиУчетМаркируемойПродукцииИСМП")
		Или ПолучитьФункциональнуюОпцию("ВестиСведенияДляДекларацийПоАлкогольнойПродукции") Тогда
		
		ТекстЗапросаВыборки = "Не КлючиВидовПродукции.Ссылка ЕСТЬ NULL
		|	И (КлючиВидовПродукции.ВидПродукцииЕГАИС <> ЗНАЧЕНИЕ(Справочник.ВидыПродукцииИС.ПустаяСсылка)
		|		Или КлючиВидовПродукции.ВидПродукцииГИСМТ <> ЗНАЧЕНИЕ(Справочник.ВидыПродукцииИС.ПустаяСсылка)) КАК МаркируемаяПродукция";
		ТекстыЗапросаВыборки.Добавить(ТекстЗапросаВыборки);
		
		ТекстЗапросаГруппировки = "Не КлючиВидовПродукции.Ссылка ЕСТЬ NULL
		|	И(КлючиВидовПродукции.ВидПродукцииЕГАИС <> ЗНАЧЕНИЕ(Справочник.ВидыПродукцииИС.ПустаяСсылка)
		|		Или КлючиВидовПродукции.ВидПродукцииГИСМТ <> ЗНАЧЕНИЕ(Справочник.ВидыПродукцииИС.ПустаяСсылка))";
		ТекстыЗапросаГруппировки.Добавить(ТекстЗапросаГруппировки);
		
		ИсточникНоменклатурыПолем = ?(СтрНайти(ИсточникНоменклатуры, ".") > 0, ИсточникНоменклатуры, ИсточникНоменклатуры + ".Ссылка");
		ТекстЗапросаСоединения = "ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ОписаниеНоменклатурыИС КАК ОписаниеНоменклатурыИС
		|	ПО ТаблицаТовары.Номенклатура = ОписаниеНоменклатурыИС.Номенклатура
		|	ЛЕВОЕ СОЕДИНЕНИЕ Справочник.КлючиВидовПродукцииИС КАК КлючиВидовПродукции
		|	ПО ОписаниеНоменклатурыИС.КлючВидовПродукции = КлючиВидовПродукции.Ссылка";
		ТекстыЗапросаСоединения.Добавить(СтрЗаменить(ТекстЗапросаСоединения, "ТаблицаТовары.Номенклатура", ИсточникНоменклатурыПолем));
	КонецЕсли;
	
	
	Если ТекстыЗапросаВыборки.Количество() > 0 Тогда
		ТекстыЗапроса.РеквизитыНоменклатурыВыборка		= СтрСоединить(ТекстыЗапросаВыборки,",");
	КонецЕсли;
	Если ТекстыЗапросаГруппировки.Количество() > 0 Тогда
		ТекстыЗапроса.РеквизитыНоменклатурыГруппировка	= СтрСоединить(ТекстыЗапросаГруппировки,",");
	КонецЕсли;
	Если ТекстыЗапросаСоединения.Количество() > 0 Тогда
		ТекстыЗапроса.РеквизитыНоменклатурыСоединения	= СтрСоединить(ТекстыЗапросаСоединения);
	КонецЕсли;
	
	//-- Локализация
	
КонецПроцедуры

