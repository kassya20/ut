// Возвращает массив областей поиска товаров.
//
// Параметры:
// 	ОбластиПоиска - Массив - Массив метаданных областей поиска товаров.
// 	Форма - ФормаКлиентскогоПриложения - форма, из которой была вызвана функция поиска.
// 	ПараметрыПоиска - Структура
//
Процедура ОписанияОбластейПоиска(ОбластиПоиска, Форма, ПараметрыПоиска) Экспорт
	
	//++ Локализация
	
	Если ПараметрыПоиска.ИмяСпискаПоиска = "Номенклатура" Тогда
				
		Если ПолучитьФункциональнуюОпцию("ИспользованиеКлассификаторовНоменклатуры") Тогда
			
			Если ПолучитьФункциональнуюОпцию("ИспользованиеСтарыхКлассификаторовОКПиОКВЭД") Тогда
				
				ОписаниеОбластиПоиска                             = ПодборТоваровСервер.ОписаниеОбластиПоиска();
				ОписаниеОбластиПоиска.ОбъектМетаданных            = Метаданные.Справочники.ОбщероссийскийКлассификаторПродукции;
				ОписаниеОбластиПоиска.ТекстЗапросаПоискаПоОбласти =
				"ВЫБРАТЬ ПЕРВЫЕ 999
				|	ОбщероссийскийКлассификаторПродукции.Ссылка КАК Значение,
				|	""ОбщероссийскийКлассификаторПродукции"" КАК Метаданные
				|ИЗ
				|	Справочник.ОбщероссийскийКлассификаторПродукции КАК ОбщероссийскийКлассификаторПродукции
				|ГДЕ
				|	ОбщероссийскийКлассификаторПродукции.Код = &УсловиеСравнения";
				ОписаниеОбластиПоиска.ТекстЗапросаПоискаНоменклатуры =
				"ВЫБРАТЬ
				|	Номенклатура.Ссылка КАК Номенклатура
				|ИЗ
				|	Справочник.Номенклатура КАК Номенклатура
				|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ОбщероссийскийКлассификаторПродукции КАК ОбщероссийскийКлассификаторПродукции
				|		ПО Номенклатура.КодОКП = ОбщероссийскийКлассификаторПродукции.Ссылка
				|ГДЕ
				|	ОбщероссийскийКлассификаторПродукции.Ссылка В(&ОбщероссийскийКлассификаторПродукции)";
				ОбластиПоиска.Добавить(ОписаниеОбластиПоиска);
			
			КонецЕсли;
			
			ОписаниеОбластиПоиска                             = ПодборТоваровСервер.ОписаниеОбластиПоиска();
			ОписаниеОбластиПоиска.ОбъектМетаданных            = Метаданные.Справочники.КлассификаторОКПД2;
			ОписаниеОбластиПоиска.ТекстЗапросаПоискаПоОбласти =
			"ВЫБРАТЬ ПЕРВЫЕ 999
			|	КлассификаторОКПД2.Ссылка КАК Значение,
			|	""КлассификаторОКПД2"" КАК Метаданные
			|ИЗ
			|	Справочник.КлассификаторОКПД2 КАК КлассификаторОКПД2
			|ГДЕ
			|	КлассификаторОКПД2.Код = &УсловиеСравнения";
			ОписаниеОбластиПоиска.ТекстЗапросаПоискаНоменклатуры =
			"ВЫБРАТЬ
			|	Номенклатура.Ссылка КАК Номенклатура
			|ИЗ
			|	Справочник.Номенклатура КАК Номенклатура
			|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.КлассификаторОКПД2 КАК КлассификаторОКПД2
			|		ПО Номенклатура.КодОКПД2 = КлассификаторОКПД2.Ссылка
			|ГДЕ
			|	КлассификаторОКПД2.Ссылка В(&КлассификаторОКПД2)";
			ОбластиПоиска.Добавить(ОписаниеОбластиПоиска);
			
		КонецЕсли;
		
	КонецЕсли;
	
	//-- Локализация
	
	Возврат;
	
КонецПроцедуры

// Выполняет настройку формы элемента справочника Номенклатура.
//
// Параметры:
//	Форма - ФормаКлиентскогоПриложения - форма элемента справочника.
//	ВидимостьЭлементов - см. Справочники.Номенклатура.ИспользованиеЭлементов.
//
Процедура НастроитьФормуИОбновитьКарточку(Форма, ВидимостьЭлементов) Экспорт
	
	//++ Локализация
	
	ЗаголовокФормыЭлементаБРД = Неопределено;
	Форма.ПараметрыСоздания.Свойство("ЗаголовокФормыЭлементаБРД", ЗаголовокФормыЭлементаБРД);
	Если Не ЗаголовокФормыЭлементаБРД = Неопределено Тогда
		Форма.Заголовок = ЗаголовокФормыЭлементаБРД;
		Форма.АвтоЗаголовок = Ложь;
	КонецЕсли;
	
	НастроитьПодсказкиПолейКлассификаторов(Форма, ВидимостьЭлементов);
	
	ОсобенностьУчетаИлиКлючВидовПродукции = ОсобенностьУчетаИлиКлючВидовПродукции(Форма);
	
	Если ЭтоПродукцияИСМП(ОсобенностьУчетаИлиКлючВидовПродукции, Истина)
		Или ЭтоПродукцияЕГАИС(ОсобенностьУчетаИлиКлючВидовПродукции) Тогда
		ИнтеграцияИСУТ.ЗаполнитьЗначениеПолейПоВидамУпаковок(Форма);
		ИнтеграцияИСУТКлиентСервер.НастройкаЭлементовВидаУпаковки(Форма, Истина);
	КонецЕсли;
	
	//-- Локализация
	Возврат;
	
КонецПроцедуры

//++ Локализация

// Выполняет настройку элементов формы элемента справочника Номенклатура или Виды номенклатуры.
//
// Параметры:
//	Форма - ФормаКлиентскогоПриложения - форма элемента справочника.
//	ВидимостьЭлементов - см. Справочники.Номенклатура.ИспользованиеЭлементов.
//
Процедура НастроитьПодсказкиПолейКлассификаторов(Форма, ВидимостьЭлементов) Экспорт
	
	Объект		= Форма.Объект;
	Элементы	= Форма.Элементы;
	
	КодыКлассификаторов = Новый Массив;
	
	ЗаполнитьКодыКлассификаторов(Объект, ВидимостьЭлементов, Элементы.КодОКВЭД.Имя, КодыКлассификаторов);
	ЗаполнитьКодыКлассификаторов(Объект, ВидимостьЭлементов, Элементы.КодОКП.Имя, КодыКлассификаторов);
	ЗаполнитьКодыКлассификаторов(Объект, ВидимостьЭлементов, Элементы.КодОКПД2.Имя, КодыКлассификаторов);
	
	ДанныеКлассификаторов = ОбщегоНазначения.ЗначенияРеквизитовОбъектов(КодыКлассификаторов, "Наименование");
	
	НастроитьПодсказкуПоляКлассификатора(Элементы.КодОКВЭД,
										НаименованиеПоКлассификатору(ДанныеКлассификаторов, Объект.КодОКВЭД));
	НастроитьПодсказкуПоляКлассификатора(Элементы.КодОКВЭД2, Форма.НаименованиеОКВЭД2);
	НастроитьПодсказкуПоляКлассификатора(Элементы.КодОКП,
										НаименованиеПоКлассификатору(ДанныеКлассификаторов, Объект.КодОКП));
	НастроитьПодсказкуПоляКлассификатора(Элементы.КодОКПД2,
										НаименованиеПоКлассификатору(ДанныеКлассификаторов, Объект.КодОКПД2));
	
	// Состав элементов форм элементов справочников может различаться.
	Если Элементы.Найти("КодВидаНоменклатурнойКлассификации") <> Неопределено Тогда
		НастроитьПодсказкуПоляКлассификатора(Элементы.КодВидаНоменклатурнойКлассификации,
											Объект.НаименованиеВидаНоменклатурнойКлассификации);
	КонецЕсли;
	
КонецПроцедуры

Процедура ЗаполнитьКодыКлассификаторов(Объект, ВидимостьЭлементов, ИмяРеквизита, КодыКлассификаторов)
	
	Если ВидимостьЭлементов[ИмяРеквизита]
		И ЗначениеЗаполнено(Объект[ИмяРеквизита]) Тогда
		
		КодыКлассификаторов.Добавить(Объект[ИмяРеквизита]);
		
	КонецЕсли;
	
КонецПроцедуры

// Возвращает наименование по классификатору по значению его кода.
//
// Параметры:
//	ДанныеКлассификаторов - см. ОбщегоНазначения.ЗначенияРеквизитовОбъектов.
//	КодКлассификатора - ЛюбаяСсылка - код классификатора.
//
// Возвращаемое значение:
//	Строка - наименование по классификатору.
//
Функция НаименованиеПоКлассификатору(ДанныеКлассификаторов, КодКлассификатора)
	
	РеквизитыКлассификатора			= ДанныеКлассификаторов.Получить(КодКлассификатора);
	НаименованиеПоКлассификатору	= ?(РеквизитыКлассификатора <> Неопределено,
										РеквизитыКлассификатора.Наименование,
										"");
	
	Возврат НаименованиеПоКлассификатору;
	
КонецФункции

Процедура НастроитьПодсказкуПоляКлассификатора(Элемент, НаименованиеПоКлассификатору)
	
	Если Не Элемент.Видимость Тогда
		Возврат;
	КонецЕсли;
	
	Если ПустаяСтрока(НаименованиеПоКлассификатору) Тогда
		Элемент.ОтображениеПодсказки			= ОтображениеПодсказки.Авто;
		Элемент.РасширеннаяПодсказка.Заголовок	= "";
	Иначе
		Элемент.ОтображениеПодсказки			= ОтображениеПодсказки.Кнопка;
		Элемент.РасширеннаяПодсказка.Заголовок	= НаименованиеПоКлассификатору;
	КонецЕсли;
	
КонецПроцедуры
