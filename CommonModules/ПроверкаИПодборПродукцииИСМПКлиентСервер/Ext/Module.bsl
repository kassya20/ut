Функция РекомендуемыйРежимДобавленияКодовМаркировки(Форма) Экспорт
	
	Если Форма.ПроверкаНеПоДокументу
		Или Не Форма.ПоддерживаетсяОбъемноСортовойУчет Тогда
		
		Возврат ПредопределенноеЗначение("Перечисление.РежимДобавленияКодовМаркировкиИС.Поштучно");
		
	ИначеЕсли Форма.ЭтоДокументПриобретения Тогда
		
		Возврат ПредопределенноеЗначение("Перечисление.РежимДобавленияКодовМаркировкиИС.ОСУ");
		
	ИначеЕсли Не ЭтоДокументРеализации(Форма.ПроверяемыйДокумент) Тогда
		
		Возврат ПредопределенноеЗначение("Перечисление.РежимДобавленияКодовМаркировкиИС.Поштучно");
		
	ИначеЕсли Не ЗначениеЗаполнено(Форма.РежимДобавленияКодовМаркировки) Тогда
		
		Возврат ПредопределенноеЗначение("Перечисление.РежимДобавленияКодовМаркировкиИС.Поштучно");
		
	ИначеЕсли Форма.РежимДобавленияКодовМаркировки = ПредопределенноеЗначение("Перечисление.РежимДобавленияКодовМаркировкиИС.ОСУ") Тогда
		
		Возврат Форма.РежимДобавленияКодовМаркировки;
		
	ИначеЕсли Форма.ПараметрыПроверкиКодовМаркировки.ОтсутствуетПодключениеИСМП
		Или Не Форма.ПараметрыПроверкиКодовМаркировки.ЗапрашиватьДанныеСервиса Тогда
		
		Возврат ПредопределенноеЗначение("Перечисление.РежимДобавленияКодовМаркировкиИС.Поштучно");
		
	КонецЕсли;
	
	Возврат Форма.РежимДобавленияКодовМаркировки;
	
КонецФункции

Функция ДопустимыеРежимыДобавленияКодовМаркировки(Форма) Экспорт
	
	Если Не Форма.ПоддерживаетсяОбъемноСортовойУчет Или Форма.ПроверкаНеПоДокументу Тогда
		
		Возврат ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(
			ПредопределенноеЗначение("Перечисление.РежимДобавленияКодовМаркировкиИС.Поштучно"));
		
	ИначеЕсли Форма.ЭтоДокументПриобретения Тогда
		
		Возврат ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(
			ПредопределенноеЗначение("Перечисление.РежимДобавленияКодовМаркировкиИС.ОСУ"));
		
	ИначеЕсли Не ЭтоДокументРеализации(Форма.ПроверяемыйДокумент) Тогда
		
		Возврат ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(
			ПредопределенноеЗначение("Перечисление.РежимДобавленияКодовМаркировкиИС.Поштучно"));
		
	КонецЕсли;
	
	ДопустимыеРежимы = Новый Массив;
	ДопустимыеРежимы.Добавить(ПредопределенноеЗначение("Перечисление.РежимДобавленияКодовМаркировкиИС.Поштучно"));
	ДопустимыеРежимы.Добавить(ПредопределенноеЗначение("Перечисление.РежимДобавленияКодовМаркировкиИС.ОСУ"));
	
	Если Не Форма.ПараметрыПроверкиКодовМаркировки.ОтсутствуетПодключениеИСМП
		И Форма.ПараметрыПроверкиКодовМаркировки.ЗапрашиватьДанныеСервиса Тогда
		
		ДопустимыеРежимы.Добавить(ПредопределенноеЗначение("Перечисление.РежимДобавленияКодовМаркировкиИС.ПоВладельцу"));
		
	КонецЕсли;
	
	Возврат ДопустимыеРежимы;
	
КонецФункции

Функция ДокументИспользуетДанныеВЕТИС(ДокументСсылка) Экспорт
	Возврат ТипЗнч(ДокументСсылка) = Тип("ДокументСсылка.МаркировкаТоваровИСМП")
		Или ТипЗнч(ДокументСсылка) = Тип("ДокументСсылка.УточнениеСведенийОКодахМаркировкиИСМП");
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

#Область ПодобраннаяМаркируемаяПродукция

Процедура ЗаполнитьСвойствоВключаетМРЦ(ВидПродукции, НоваяСтрока, СтрокаИсточника) Экспорт
	
	Если Не КонструкторИСМПОбщегоНазначенияКлиентСервер.ДоступноПолеМРЦ(ВидПродукции) Тогда
		Возврат;
	КонецЕсли;
	
	НоваяСтрока.ВключаетМРЦ = (НоваяСтрока.МРЦ <> 0);
	
	Если НоваяСтрока.ВключаетМРЦ Или СтрокаИсточника.ДанныеРазбора = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если СтрокаИсточника.ВидУпаковки = ПредопределенноеЗначение("Перечисление.ВидыУпаковокИС.Потребительская")
		Или СтрокаИсточника.ВидУпаковки = ПредопределенноеЗначение("Перечисление.ВидыУпаковокИС.Групповая") Тогда
		
		НоваяСтрока.ВключаетМРЦ = СтрокаИсточника.ДанныеРазбора.СоставКодаМаркировки.Свойство("ВключаетМРЦ")
			И СтрокаИсточника.ДанныеРазбора.СоставКодаМаркировки.ВключаетМРЦ;
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

Функция ПоддерживаетсяОбъемноСортовойУчет(ПараметрыСканирования, ВидПродукции) Экспорт
	
	Возврат ПараметрыСканирования.ПоддерживаетсяОбъемноСортовойУчет
		И КонструкторИСМПОбщегоНазначенияКлиентСервер.ПоддерживаетсяОбъемноСортовойУчет(
			ВидПродукции, ПараметрыСканирования.ВидОперацииИСМП);
	
КонецФункции

Функция ВладелецМожетОтличатьсяПоДатеПроизводства(СтрокаДанных, ПараметрыПроверкиКодовМаркировки)
	
	Если Не (СтрокаДанных.ВидУпаковки = ПредопределенноеЗначение("Перечисление.ВидыУпаковокИС.Потребительская")
			Или СтрокаДанных.ВидУпаковки = ПредопределенноеЗначение("Перечисление.ВидыУпаковокИС.Групповая")
			Или СтрокаДанных.ВидУпаковки = ПредопределенноеЗначение("Перечисление.ВидыУпаковокИС.Набор"))
		Или Не ОбщегоНазначенияИСМПКлиентСерверПовтИсп.ВидОперацииПоддерживаетПроверкуВладельцаПоДатеПроизводства(ПараметрыПроверкиКодовМаркировки.ВидОперацииИСМП) Тогда
		Возврат Ложь;
	КонецЕсли;
	
	ДатаКонтроляВладельцаПоДатеПроизводства = ОбщегоНазначенияИСМПКлиентСерверПовтИсп.ДатаНачалаКонтроляПриПродажеОптомПоштучно(
		СтрокаДанных.ВидПродукции);
		
	Если ЗначениеЗаполнено(ДатаКонтроляВладельцаПоДатеПроизводства) Тогда
		
		Если ЗначениеЗаполнено(СтрокаДанных.ДатаВводаВОборот) Тогда
			ДатаКонтроля = СтрокаДанных.ДатаВводаВОборот;
		Иначе
			ДатаКонтроля = СтрокаДанных.ДатаПроизводства;
		КонецЕсли;
		
		ДатаНачалаКонтроляПриПродажеОптомПоштучно = ДатаКонтроляВладельцаПоДатеПроизводства;
		
		Возврат (ЗначениеЗаполнено(ДатаКонтроля) И НачалоДня(ДатаКонтроля) < ДатаНачалаКонтроляПриПродажеОптомПоштучно);
	
	Иначе
		Возврат Ложь;
	КонецЕсли;
	
КонецФункции

Процедура ПроверитьДопустимуюВложенностьУпаковок(ТекущаяСтрока, ПараметрыПроверкиКодовМаркировки)
	
	Если ТипЗнч(ТекущаяСтрока) = Тип("ДанныеФормыЭлементДерева") Тогда
		РодительТекущейСтроки = ТекущаяСтрока.ПолучитьРодителя();
	Иначе
		РодительТекущейСтроки = ТекущаяСтрока.Родитель;
	КонецЕсли;
	
	Если РодительТекущейСтроки <> Неопределено И ТипЗнч(РодительТекущейСтроки.ТипУпаковки) = Тип("ПеречислениеСсылка.ТипыУпаковок") Тогда
		
		ДопустимыеВложенияАгрегатов = ПараметрыПроверкиКодовМаркировки.ДопустимыеВложенияАгрегатов;
		
		ДопустимыеВложенияПоВидуУпаковки  = ДопустимыеВложенияАгрегатов.Получить(РодительТекущейСтроки.ВидУпаковки);
		ДопустимыеВложенияПоТипуШтрихкода = ДопустимыеВложенияАгрегатов.Получить(РодительТекущейСтроки.ТипШтрихкода);
		
		СтрокаОшибки = "";
		
		Если ДопустимыеВложенияПоВидуУпаковки <> Неопределено
			И ДопустимыеВложенияПоВидуУпаковки.Найти(ТекущаяСтрока.ВидУпаковки) = Неопределено Тогда
			
			СтрокаОшибки = СтрШаблон(
				НСтр("ru = '%1 упаковка не может содержать %2'"),
				РодительТекущейСтроки.ВидУпаковки,
				ТекущаяСтрока.ВидУпаковки);
			
		ИначеЕсли ТекущаяСтрока.ВидУпаковки = ПредопределенноеЗначение("Перечисление.ВидыУпаковокИС.Логистическая") Тогда
			
			Если ДопустимыеВложенияПоТипуШтрихкода <> Неопределено
				И ДопустимыеВложенияПоТипуШтрихкода.Найти(ТекущаяСтрока.ТипШтрихкода) = Неопределено Тогда
				
				СтрокаОшибки = СтрШаблон(
					НСтр("ru = 'Упаковка %1 не может содержать %2'"),
					РодительТекущейСтроки.ТипШтрихкода,
					ТекущаяСтрока.ТипШтрихкода);
				
			КонецЕсли;
			
		КонецЕсли;
		
		Если ЗначениеЗаполнено(СтрокаОшибки) Тогда
			
			РодительТекущейСтроки.НедопустимыйКодМаркировки = Истина;
			РодительТекущейСтроки.ПредставлениеПроверкиКодаМаркировки = СтрокаОшибки;
			
		КонецЕсли;
		
		Если ПараметрыПроверкиКодовМаркировки.Свойство("КонтролироватьСоставГрупповойУпаковкиПриИзмененииСтрокиДерева")
			И ПараметрыПроверкиКодовМаркировки.КонтролироватьСоставГрупповойУпаковкиПриИзмененииСтрокиДерева Тогда
			
			ПроверитьСоставАгрегата(РодительТекущейСтроки, ПараметрыПроверкиКодовМаркировки);
			
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

Функция РазрешительнаяДокументацияТребуетПроверкиПоДатеПроизводства(СтрокаДанных, ПараметрыПроверкиКодовМаркировки) Экспорт
	
	ДатаНачалаКонтроляРазрешительнойДокументации = ОбщегоНазначенияИСМПКлиентСерверПовтИсп.ДатаКонтроляРазрешительнойДокументации(
		СтрокаДанных.ВидПродукции);
	
	Если Не ЗначениеЗаполнено(ДатаНачалаКонтроляРазрешительнойДокументации)
		Или Не СтрокаДанных.ВидУпаковки = ПредопределенноеЗначение("Перечисление.ВидыУпаковокИС.Потребительская") Тогда
		Возврат Ложь;
	Иначе
		
		Если ЗначениеЗаполнено(СтрокаДанных.ДатаВводаВОборот) Тогда
			ДатаКонтроля = СтрокаДанных.ДатаВводаВОборот;
		Иначе
			ДатаКонтроля = СтрокаДанных.ДатаПроизводства;
		КонецЕсли;
		
		Возврат (ЗначениеЗаполнено(ДатаКонтроля) И ДатаНачалаКонтроляРазрешительнойДокументации < НачалоДня(ДатаКонтроля));
		
	КонецЕсли;
	
КонецФункции

#КонецОбласти
