КонецПроцедуры

// Возвращает помещения с адресным хранением
// Параметры:
//  Таблица - ТаблицаЗначений:
//   * Склад - СправочникСсылка.Склады -
//   * Помещение - СправочникСсылка.СкладскиеПомещения -
//  Дата - Дата -
// Возвращаемое значение:
// ВыборкаИзРезультатаЗапроса -
Функция ВыборкаСкладПомещение(Таблица, Дата) Экспорт
	
	Тексты = Новый Массив();
	Текст =
		"ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	Товары.Склад КАК Склад,
		|	Товары.Помещение КАК Помещение
		|ПОМЕСТИТЬ СкладыИПомещения
		|ИЗ
		|	&Товары КАК Товары
		|ИНДЕКСИРОВАТЬ ПО
		|	Склад, Помещение";
	Тексты.Добавить(Текст);
	
	Текст = ТекстЗапросаАдресноеХранение();
	Тексты.Добавить(Текст);
	
	Текст =
		"ВЫБРАТЬ
		|	Товары.Склад КАК Склад,
		|	Товары.Помещение КАК Помещение
		|ИЗ
		|	АдресныеСкладыИПомещения КАК Товары";
	Тексты.Добавить(Текст);
	
	Запрос = Новый Запрос();
	Запрос.Текст = СтрСоединить(Тексты, ОбщегоНазначения.РазделительПакетаЗапросов());
	Запрос.УстановитьПараметр("Товары", Таблица);
	Запрос.УстановитьПараметр("Дата", ?(ЗначениеЗаполнено(Дата),Дата,ТекущаяДатаСеанса()));
	
	ВыборкаСкладПомещение = Запрос.Выполнить().Выбрать();
	
	Возврат ВыборкаСкладПомещение;
	
КонецФункции

// Заполнение выполняется, если в документе реквизит не заполнен.
// Для заполнения в базе ищется подходящий по ключу элемент справочника КонтролируемыеПартии.
// Если такого элемента нет, то реквизит будет заполнен ссылкой нового объекта. Сам же объект будет создан в процедуре
// СоздатьКонтролируемуюПартиюВПриходномОрдере.
// 
// Параметры:
//  Объект - ДокументОбъект - Документ.
Процедура ЗаполнитьКонтролируемуюПартиюВПриходномОрдере(Объект) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	ПартияЗаполнена = ЗначениеЗаполнено(Объект.КонтролируемаяПартия);
	ВключенКонтрольКачества = ПолучитьФункциональнуюОпцию("ИспользоватьКонтрольКачестваТоваров");
	Если ПартияЗаполнена И Не ВключенКонтрольКачества
			И Объект.Товары.Найти(Истина, "ПроконтролироватьКачество") = Неопределено Тогда
		Объект.КонтролируемаяПартия = Справочники.КонтролируемыеПартии.ПустаяСсылка();
		Возврат;
	КонецЕсли;
	
	Если Не ВключенКонтрольКачества
			Или Объект.ДополнительныеСвойства.ПроведениеДокументов.СвойстваДокумента.РежимЗаписи
				<> РежимЗаписиДокумента.Проведение
			Или Объект.ДвижениеРанееПоступившейПартии
			Или Не ПоддерживаетсяКонтрольКачества(Объект.Распоряжение) Тогда
		Возврат;
	КонецЕсли;
	
	Если Не ПартияЗаполнена Тогда
		
		БлокировкаДанных = Новый БлокировкаДанных();
		
		ЭлементБлокировки = БлокировкаДанных.Добавить("Справочник.КонтролируемыеПартии");
		
		ЭлементБлокировки.Режим = РежимБлокировкиДанных.Исключительный;
		ЭлементБлокировки.УстановитьЗначение("Партия", Объект.Распоряжение);
		
		//@skip-check lock-out-of-try
		БлокировкаДанных.Заблокировать();
		
		Запрос = Новый Запрос(
			"ВЫБРАТЬ
			|	Партии.Ссылка КАК Ссылка
			|ИЗ
			|	Справочник.КонтролируемыеПартии КАК Партии
			|ГДЕ
			|	Партии.Партия = &Партия");
		Запрос.УстановитьПараметр("Партия", Объект.Распоряжение);
		Выборка = Запрос.Выполнить().Выбрать();
		Если Выборка.Следующий() Тогда
			Объект.КонтролируемаяПартия = Выборка.Ссылка;
		Иначе
			Объект.КонтролируемаяПартия = Справочники.КонтролируемыеПартии.ПолучитьСсылку();
			Объект.ДополнительныеСвойства.Вставить("СоздатьКонтролируемуюПартию");
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

// Создает элемент справочника КонтролируемыПартии, если ссылки на реквизит КонтролируемаяПартия из Объекта нет в базе.
// 
// Параметры:
//  Объект - ДокументОбъект - ДокументОбъект.ПриходныйОрдерНаТовары.
Процедура СоздатьКонтролируемуюПартиюВПриходномОрдере(Объект) Экспорт
	
	Если Не Объект.ДополнительныеСвойства.Свойство("СоздатьКонтролируемуюПартию") Тогда
		Возврат;
	КонецЕсли;
	
	СоздатьИЗаписатьПартиюПоРаспоряжению(
		Объект.КонтролируемаяПартия,
		Объект.Распоряжение,
		Объект.ХозяйственнаяОперация,
		Объект.Отправитель);
	
КонецПроцедуры

// Заполнение выполняется, если в документе реквизит не заполнен.
// Для заполнения в базе ищется подходящий по ключу элемент справочника КонтролируемыеПартии.
// Если такого элемента нет, то реквизит будет заполнен ссылкой нового объекта. Сам же объект будет создан в процедуре
// СоздатьКонтролируемыеПартииВТабличнойЧасти.
// 
// Параметры:
//  Объект - ДокументОбъект - Документ.
//  ТабЧасть - ТабличнаяЧасть -
//  ДокументыПартии - ТаблицаЗначений -
//  Индексы - Строка -
Процедура ЗаполнитьКонтролируемыеПартииВТабличнойЧасти(Объект, ТабЧасть, ДокументыПартии, Индексы) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	ВключенКонтрольКачества = ПолучитьФункциональнуюОпцию("ИспользоватьКонтрольКачестваТоваров");
	Если Не ВключенКонтрольКачества
			Или Объект.ДополнительныеСвойства.ПроведениеДокументов.СвойстваДокумента.РежимЗаписи
				<> РежимЗаписиДокумента.Проведение Тогда
		Возврат;
	КонецЕсли;
	
	БлокировкаДанных = Новый БлокировкаДанных();
	
	ЭлементБлокировки = БлокировкаДанных.Добавить("Справочник.КонтролируемыеПартии");
	
	ЭлементБлокировки.Режим = РежимБлокировкиДанных.Исключительный;
	ЭлементБлокировки.ИсточникДанных = ДокументыПартии;
	ЭлементБлокировки.ИспользоватьИзИсточникаДанных("Партия", "ДокументПартии");
	
	//@skip-check lock-out-of-try
	БлокировкаДанных.Заблокировать();
	
	Запрос = Новый Запрос(
		"ВЫБРАТЬ
		|	Партии.Ссылка КАК Ссылка,
		|	Партии.Партия КАК ДокументПартии
		|ИЗ
		|	Справочник.КонтролируемыеПартии КАК Партии
		|ГДЕ
		|	Партии.Партия В(&ДокументыПартии)");
	Запрос.УстановитьПараметр("ДокументыПартии", ДокументыПартии.ВыгрузитьКолонку("ДокументПартии"));
	ТаблицаКонтролируемыеПартии = Запрос.Выполнить().Выгрузить();
	ТаблицаКонтролируемыеПартии.Индексы.Добавить("ДокументПартии");
	
	ОтборСтрок = Новый Структура(Индексы);
	ОтборДокументовПартии = Новый Структура("ДокументПартии");
	
	Для Каждого Строка Из ТабЧасть Цикл
		
		ЗаполнитьЗначенияСвойств(ОтборСтрок, Строка, Индексы);
		ДокументыПартииСтрока = ДокументыПартии.НайтиСтроки(ОтборСтрок)[0];
		ОтборДокументовПартии.ДокументПартии = ДокументыПартииСтрока.ДокументПартии;
		НайденныеСтроки = ТаблицаКонтролируемыеПартии.НайтиСтроки(ОтборДокументовПартии);
		Если НайденныеСтроки.Количество() > 0 Тогда
			Строка.КонтролируемаяПартия = НайденныеСтроки[0].Ссылка;
		Иначе
			КонтролируемыеПартии = Неопределено;
			Если Не Объект.ДополнительныеСвойства.Свойство("СоздатьКонтролируемуюПартию", КонтролируемыеПартии) Тогда
				КонтролируемыеПартии = Новый Соответствие();
				Объект.ДополнительныеСвойства.Вставить("СоздатьКонтролируемуюПартию", КонтролируемыеПартии);
			КонецЕсли;
			СсылкаНаПартию = КонтролируемыеПартии.Получить(ОтборДокументовПартии.ДокументПартии);
			Если СсылкаНаПартию = Неопределено Тогда
				СсылкаНаПартию = Справочники.КонтролируемыеПартии.ПолучитьСсылку();
				РеквизитыСоздаваемойПартии = Новый Структура();
				РеквизитыСоздаваемойПартии.Вставить("Ссылка", СсылкаНаПартию);
				РеквизитыСоздаваемойПартии.Вставить("ХозяйственнаяОперация", ДокументыПартииСтрока.ХозяйственнаяОперация);
				РеквизитыСоздаваемойПартии.Вставить("Отправитель", ДокументыПартииСтрока.Отправитель);
				КонтролируемыеПартии.Вставить(ОтборДокументовПартии.ДокументПартии, РеквизитыСоздаваемойПартии);
			КонецЕсли;
			Строка.КонтролируемаяПартия = СсылкаНаПартию;
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

// Создает элемент справочника КонтролируемыПартии, если ссылки на реквизит КонтролируемаяПартия из Объекта нет в базе.
// 
// Параметры:
//  Объект - ДокументОбъект - документ
Процедура СоздатьКонтролируемыеПартииВТабличнойЧасти(Объект) Экспорт
	
	КонтролируемыеПартии = Неопределено;
	Если Не Объект.ДополнительныеСвойства.Свойство("СоздатьКонтролируемуюПартию", КонтролируемыеПартии) Тогда
		Возврат;
	КонецЕсли;
	
	Для Каждого КлючИЗначение Из КонтролируемыеПартии Цикл
		
		РеквизитыСоздаваемойПартии = КлючИЗначение.Значение; // Структура
		СоздатьИЗаписатьПартиюПоРаспоряжению(
			РеквизитыСоздаваемойПартии.Ссылка,
			КлючИЗначение.Ключ,
			РеквизитыСоздаваемойПартии.ХозяйственнаяОперация,
			РеквизитыСоздаваемойПартии.Отправитель);
		
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Процедура ОтключитьЕслиВыключенаФО(Результат)
	
	Если Не ПолучитьФункциональнуюОпцию("ИспользоватьКонтрольКачестваТоваров") Тогда
		Если ТипЗнч(Результат) = Тип("Структура") Тогда
			
			Для Каждого Свойство Из Результат Цикл
				Если Свойство.Ключ = "Ключ" Тогда
					Продолжить;
				КонецЕсли;
				Свойство.Значение.ИспользоватьКонтрольКачестваТоваров = Ложь;
			КонецЦикла;
			
		Иначе
			
			Для Каждого Элемент Из Результат Цикл // Структура
				
				Для Каждого Свойство Из Элемент.Параметры Цикл
					Если Свойство.Ключ = "Ключ" Тогда
						Продолжить;
					КонецЕсли;
					Свойство.Значение.ИспользоватьКонтрольКачестваТоваров = Ложь;
				КонецЦикла;
				
			КонецЦикла;
			
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

Процедура СоздатьИЗаписатьПартиюПоРаспоряжению(КонтролируемаяПартия, Распоряжение, ХозяйственнаяОперация, Отправитель)
	
	УстановитьПривилегированныйРежим(Истина);
	МенеджерОбъекта = ОбщегоНазначения.МенеджерОбъектаПоСсылке(Распоряжение);
	РеквизитыПартии = МенеджерОбъекта.РеквизитыКонтролируемойПартии(Распоряжение, "КонтролируемаяПартия");
	РеквизитыПартии.ДатаПоступления = НачалоДня(РеквизитыПартии.ДатаПоступления);
	КонтролируемаяПартияОбъект = Справочники.КонтролируемыеПартии.СоздатьЭлемент();
	КонтролируемаяПартияОбъект.УстановитьСсылкуНового(КонтролируемаяПартия);
	ЗаполнитьЗначенияСвойств(КонтролируемаяПартияОбъект, РеквизитыПартии);
	КонтролируемаяПартияОбъект.Наименование = КонтрольКачестваКлиентСервер.ПредставлениеКонтролируемойПартии(
		РеквизитыПартии, ОбщегоНазначения.КодОсновногоЯзыка());
	Если ЗначениеЗаполнено(ХозяйственнаяОперация) Тогда
		КонтролируемаяПартияОбъект.ХозяйственнаяОперация = ХозяйственнаяОперация;
		КонтролируемаяПартияОбъект.Отправитель = Отправитель;
	КонецЕсли;
	КонтролируемаяПартияОбъект.УдалитьПодразделениеОбработано = Истина;
	КонтролируемаяПартияОбъект.Записать();
	
КонецПроцедуры

Функция ТекстЗапросаАдресноеХранение()

	Возврат
		"ВЫБРАТЬ
		|	СкладыИПомещения.Склад КАК Склад,
		|	СкладыИПомещения.Помещение КАК Помещение
		|ПОМЕСТИТЬ АдресныеСкладыИПомещения
		|ИЗ
		|	СкладыИПомещения КАК СкладыИПомещения
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.НастройкиАдресныхСкладов КАК НастройкиАдресныхСкладов
		|		ПО (НастройкиАдресныхСкладов.ИспользоватьАдресноеХранение)
		|			И (НастройкиАдресныхСкладов.ДатаНачалаАдресногоХраненияОстатков <= &Дата)
		|			И (НастройкиАдресныхСкладов.Склад = СкладыИПомещения.Склад)
		|			И (НастройкиАдресныхСкладов.Помещение = СкладыИПомещения.Помещение)
		|			И (НЕ СкладыИПомещения.Помещение = ЗНАЧЕНИЕ(Справочник.СкладскиеПомещения.ПустаяСсылка)
		|				ИЛИ (НЕ НастройкиАдресныхСкладов.Склад.ИспользоватьСкладскиеПомещения
		|					ИЛИ &Дата < НастройкиАдресныхСкладов.Склад.ДатаНачалаИспользованияСкладскихПомещений))
		|ИНДЕКСИРОВАТЬ ПО
		|	Склад, Помещение";
		
КонецФункции

Функция ТоварныеМестаПоПеречнюНоменклатуры(ПереченьНоменклатуры)
	
	ТекстЗапросаУпаковки = Справочники.УпаковкиЕдиницыИзмерения.ТекстЗапросаКоэффициентаУпаковки(
		"Упаковки.Ссылка", "СписокНоменклатуры.Ссылка");
	
	ТекстЗапроса =
		"ВЫБРАТЬ
		|	СписокНоменклатуры.Ссылка КАК Ссылка,
		|	Упаковки.Ссылка КАК Упаковка,
		|	ЕСТЬNULL(&ТекстЗапросаКоэффициентаУпаковки, 1) КАК Коэффициент
		|ИЗ
		|	Справочник.Номенклатура КАК СписокНоменклатуры
		|		
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.НаборыУпаковок КАК Наборы
		|		ПО Наборы.Ссылка = СписокНоменклатуры.НаборУпаковок
		|		 И Наборы.Ссылка <> ЗНАЧЕНИЕ(Справочник.НаборыУпаковок.ИндивидуальныйДляНоменклатуры)
		|		
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.УпаковкиЕдиницыИзмерения КАК Упаковки
		|		ПО Упаковки.Владелец = ЕСТЬNULL(Наборы.Ссылка, СписокНоменклатуры.Ссылка)
		|ГДЕ
		|	СписокНоменклатуры.Ссылка В(&ПереченьНоменклатуры)
		|		И СписокНоменклатуры.НаборУпаковок <> ЗНАЧЕНИЕ(Справочник.НаборыУпаковок.ПустаяСсылка)
		|		И Упаковки.ТипУпаковки = ЗНАЧЕНИЕ(Перечисление.ТипыУпаковокНоменклатуры.ТоварноеМесто)
		|		И НЕ Упаковки.ПометкаУдаления";
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&ТекстЗапросаКоэффициентаУпаковки", ТекстЗапросаУпаковки);
	Запрос = Новый Запрос(ТекстЗапроса);
	Запрос.УстановитьПараметр("ПереченьНоменклатуры", ПереченьНоменклатуры);
	Выборка = Запрос.Выполнить().Выбрать();
	
	Результат = Новый Соответствие();
	ТекущаяНоменклатура = Неопределено;
	Упаковки = Неопределено;
	Пока Выборка.Следующий() Цикл
		Если Выборка.Ссылка <> ТекущаяНоменклатура Тогда
			ТекущаяНоменклатура = Выборка.Ссылка;
			Упаковки = Новый Соответствие();
			Результат.Вставить(ТекущаяНоменклатура, Упаковки);
		КонецЕсли;
		Упаковки.Вставить(Выборка.Упаковка, Выборка.Коэффициент);
	КонецЦикла;
	Возврат Результат;
	
КонецФункции

Процедура ОчиститьЕслиНеУчетЗатрат(НаправлениеДеятельности)
	
	Если Не НаправленияДеятельностиСервер.ЭтоНаправлениеДеятельностиСОбособлениемТоваровИРабот(НаправлениеДеятельности) Тогда
		НаправлениеДеятельности = Справочники.НаправленияДеятельности.ПустаяСсылка();
	КонецЕсли;
	
КонецПроцедуры

