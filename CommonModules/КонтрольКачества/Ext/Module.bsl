		|	НЕ АдресныеСкладыИПомещения.Склад ЕСТЬ NULL КАК ПодбиратьЯчейки,
		|	
		|	ЕСТЬNULL(ЗапасыИПотребности.Количество, 0) КАК КонтрольТовар,
		|	
		|	ЕСТЬNULL(ТоварыНаСкладахСводно.Количество, 0)
		|		- ЕСТЬNULL(ТоварыКОтгрузке.Количество, 0) КАК КонтрольСерия,
		|	
		|	ТоварыНаСкладах.Количество КАК Количество,
		|	ЗНАЧЕНИЕ(Справочник.СкладскиеЯчейки.ПустаяСсылка) КАК Ячейка,
		|	ЗНАЧЕНИЕ(Справочник.УпаковкиЕдиницыИзмерения.ПустаяСсылка) КАК Упаковка
		|ИЗ
		|	ТоварыНаСкладах КАК ТоварыНаСкладах
		|		
		|		ЛЕВОЕ СОЕДИНЕНИЕ ТоварыКОтгрузке КАК ТоварыКОтгрузке
		|		ПО ТоварыКОтгрузке.КонтролируемаяПартия = ТоварыНаСкладах.КонтролируемаяПартия
		|		 И ТоварыКОтгрузке.Номенклатура = ТоварыНаСкладах.Номенклатура
		|		 И ТоварыКОтгрузке.Характеристика = ТоварыНаСкладах.Характеристика
		|		 И ТоварыКОтгрузке.Склад = ТоварыНаСкладах.Склад
		|		 И ТоварыКОтгрузке.Назначение = ТоварыНаСкладах.Назначение
		|		 И ТоварыКОтгрузке.Серия = ТоварыНаСкладах.Серия
		|		
		|		ЛЕВОЕ СОЕДИНЕНИЕ ТоварыНаСкладахСводно КАК ТоварыНаСкладахСводно
		|		ПО ТоварыНаСкладахСводно.КонтролируемаяПартия = ТоварыНаСкладах.КонтролируемаяПартия
		|		 И ТоварыНаСкладахСводно.Номенклатура = ТоварыНаСкладах.Номенклатура
		|		 И ТоварыНаСкладахСводно.Характеристика = ТоварыНаСкладах.Характеристика
		|		 И ТоварыНаСкладахСводно.Склад = ТоварыНаСкладах.Склад
		|		 И ТоварыНаСкладахСводно.Назначение = ТоварыНаСкладах.Назначение
		|		 И ТоварыНаСкладахСводно.Серия = ТоварыНаСкладах.Серия
		|		
		|		ЛЕВОЕ СОЕДИНЕНИЕ ЗапасыИПотребности КАК ЗапасыИПотребности
		|		ПО ЗапасыИПотребности.КонтролируемаяПартия = ТоварыНаСкладах.КонтролируемаяПартия
		|		 И ЗапасыИПотребности.Номенклатура = ТоварыНаСкладах.Номенклатура
		|		 И ЗапасыИПотребности.Характеристика = ТоварыНаСкладах.Характеристика
		|		 И ЗапасыИПотребности.Склад = ТоварыНаСкладах.Склад
		|		 И ЗапасыИПотребности.Назначение = ТоварыНаСкладах.Назначение
		|		
		|		ЛЕВОЕ СОЕДИНЕНИЕ АдресныеСкладыИПомещения КАК АдресныеСкладыИПомещения
		|		ПО АдресныеСкладыИПомещения.Склад = ТоварыНаСкладах.Склад
		|		 И АдресныеСкладыИПомещения.Помещение = ТоварыНаСкладах.Помещение
		|ГДЕ
		|	&ИсключитьЗаявкиПереопределяемый
		|УПОРЯДОЧИТЬ ПО
		|	КонтролируемаяПартия, Номенклатура, Характеристика, Назначение, Склад, Серия, Помещение
		|;
		|
		|///////////////////////////////////////////////////////////////////////////////////////
		|УНИЧТОЖИТЬ ТоварыНаСкладах;
		|УНИЧТОЖИТЬ ТоварыКОтгрузке;
		|УНИЧТОЖИТЬ ТоварыНаСкладахСводно;
		|УНИЧТОЖИТЬ ЗапасыИПотребности;
		|УНИЧТОЖИТЬ АдресныеСкладыИПомещения";
	ТекстЗапросаКоэффициентаУпаковки = Справочники.УпаковкиЕдиницыИзмерения.ТекстЗапросаКоэффициентаУпаковки(
		"ТоварыВЯчейках.Упаковка", "ТоварыВЯчейках.Номенклатура");
	Текст = СтрЗаменить(Текст, "&ТекстЗапросаКоэффициентаУпаковки", ТекстЗапросаКоэффициентаУпаковки);
	Тексты.Добавить(Текст);
	
	Текст = СтрСоединить(Тексты, ОбщегоНазначения.РазделительПакетаЗапросов());
	Если ИсключитьЗаявкиНаКонтроль Тогда
		
		ИсключитьЗаявкиПереопределяемый =
			"ТИПЗНАЧЕНИЯ(ТоварыНаСкладах.КонтролируемаяПартия.Партия) <> ТИП(Документ.ЗаявкаНаКонтрольКачестваТоваров)"; // @query-part-1
	Иначе
		ИсключитьЗаявкиПереопределяемый = "ИСТИНА"; // @query-part-1
	КонецЕсли;
	Текст = СтрЗаменить(Текст, "&ИсключитьЗаявкиПереопределяемый", ИсключитьЗаявкиПереопределяемый);
	Запрос = Новый Запрос();
	Запрос.Текст = Текст;
	Запрос.УстановитьПараметр("Аналитики", Аналитики);
	Запрос.УстановитьПараметр("Дата", Дата);
	Запрос.УстановитьПараметр("Регистратор", Регистратор);
	ПакетРезультатов = Запрос.ВыполнитьПакет();
	
	ПереченьНоменклатуры = ПакетРезультатов[ПакетРезультатов.ВГраница() - 9].Выгрузить().ВыгрузитьКолонку("Ссылка");
	ТоварныеМеста = ТоварныеМестаПоПеречнюНоменклатуры(ПереченьНоменклатуры);
	
	Ячейки = ПакетРезультатов[ПакетРезультатов.ВГраница() - 8].Выгрузить();
	Таблица = ПакетРезультатов[ПакетРезультатов.ВГраница() - 5].Выгрузить();
	Таблица.Колонки.Добавить("Удалить", Новый ОписаниеТипов("Булево"));
	ТипЧисло = ОбщегоНазначения.ОписаниеТипаЧисло(15, 3, ДопустимыйЗнак.Неотрицательный);
	Таблица.Колонки.Добавить("КоличествоУпаковок", ТипЧисло);
	ВсегоСтрок = Таблица.Количество();
	
	КонтролируемаяПартия = Неопределено;
	Номенклатура = Неопределено;
	Характеристика = Неопределено;
	Склад = Неопределено;
	Назначение = Неопределено;
	Серия = Неопределено;
	Для Индекс = 0 По ВсегоСтрок - 1 Цикл
		
		СтрокаТаблицы = Таблица[Индекс];
		
		ИзменилсяТовар = Ложь;
		ИзмениласьСерия = Ложь;
		Если КонтролируемаяПартия <> СтрокаТаблицы.КонтролируемаяПартия Тогда
			КонтролируемаяПартия = СтрокаТаблицы.КонтролируемаяПартия;
			ИзменилсяТовар = Истина;
		КонецЕсли;
		Если Номенклатура <> СтрокаТаблицы.Номенклатура Тогда
			Номенклатура = СтрокаТаблицы.Номенклатура;
			ИзменилсяТовар = Истина;
		КонецЕсли;
		Если Характеристика <> СтрокаТаблицы.Характеристика Тогда
			Характеристика = СтрокаТаблицы.Характеристика;
			ИзменилсяТовар = Истина;
		КонецЕсли;
		Если Склад <> СтрокаТаблицы.Склад Тогда
			Склад = СтрокаТаблицы.Склад;
			ИзменилсяТовар = Истина;
		КонецЕсли;
		Если Назначение <> СтрокаТаблицы.Назначение Тогда
			Назначение = СтрокаТаблицы.Назначение;
			ИзменилсяТовар = Истина;
		КонецЕсли;
		Если Серия <> СтрокаТаблицы.Серия Тогда
			Серия = СтрокаТаблицы.Серия;
			ИзмениласьСерия = Истина;
		КонецЕсли;
		ИзмениласьСерия = ИзмениласьСерия Или ИзменилсяТовар;
		
		Если ИзменилсяТовар Тогда
			КонтрольТовар = СтрокаТаблицы.КонтрольТовар;
		КонецЕсли;
		
		Если ИзмениласьСерия Тогда
			КонтрольСерия = СтрокаТаблицы.КонтрольСерия;
		КонецЕсли;
		
		Если ЗаполнятьТоварамиПодтвержденногоКачества Тогда
			СтрокаТаблицы.Количество = Мин(КонтрольСерия, СтрокаТаблицы.Количество);
		Иначе
			СтрокаТаблицы.Количество = Мин(КонтрольСерия, КонтрольТовар, СтрокаТаблицы.Количество);
		КонецЕсли;
		СтрокаТаблицы.КоличествоУпаковок = СтрокаТаблицы.Количество;
		КонтрольСерия = КонтрольСерия - СтрокаТаблицы.Количество;
		КонтрольТовар = КонтрольТовар - СтрокаТаблицы.Количество;
		
		СтрокаТаблицы.Удалить = СтрокаТаблицы.Количество = 0;
		
	КонецЦикла;
	
	Колонки = "КонтролируемаяПартия,Номенклатура,Характеристика,Склад,
		|Назначение,Серия,Помещение,Ячейка,Упаковка,Количество,КоличествоУпаковок";
	
	Результат = Таблица.Скопировать(Новый Массив(), Колонки);
	Ключ = "Номенклатура,Характеристика,Назначение,Серия,Склад,Помещение";
	ОтборПоКлючу = Новый Структура(Ключ);
	Ячейки.Индексы.Добавить(Ключ);
	Таблица.Колонки.Добавить("КоличествоКомплект",
		ОбщегоНазначения.ОписаниеТипаЧисло(15, 3, ДопустимыйЗнак.Неотрицательный));
	
	МаксИндекс = Таблица.Количество() - 1;
	Комплект = Новый Соответствие();
	Для Индекс = 0 По МаксИндекс Цикл
		
		СтрокаТаблицы = Таблица[Индекс];
		Если СтрокаТаблицы.Удалить Тогда
			Продолжить;
		КонецЕсли;
		Если Не СтрокаТаблицы.ПодбиратьЯчейки Тогда
			ЗаполнитьЗначенияСвойств(Результат.Добавить(), СтрокаТаблицы); // добавление строки
			Продолжить;
		КонецЕсли;
		
		ЗаполнитьЗначенияСвойств(ОтборПоКлючу, СтрокаТаблицы);
		НайденныеСтроки = Ячейки.НайтиСтроки(ОтборПоКлючу);
		МаксИндексЯчейки = НайденныеСтроки.Количество() - 1;
		ЕстьТоварныеМеста = Ложь;
		Для ИндексЯчейки = 0 По МаксИндексЯчейки Цикл
			СтрокаЯчейки = НайденныеСтроки[ИндексЯчейки];
			Если Не СтрокаЯчейки.ЭтоТоварноеМесто Тогда
				Количество = Мин(СтрокаТаблицы.Количество, СтрокаЯчейки.КоличествоЕдиниц);
				СтрокаТаблицы.Количество = СтрокаТаблицы.Количество - Количество;
				Если Количество = 0 Тогда
					Продолжить;
				КонецЕсли;
				НоваяСтрока = Результат.Добавить(); // добавление строки
				ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаЯчейки);
				НоваяСтрока.КонтролируемаяПартия = СтрокаТаблицы.КонтролируемаяПартия;
				НоваяСтрока.Количество = Количество;
			Иначе
				ЕстьТоварныеМеста = Истина;
			КонецЕсли;
		КонецЦикла;
		
		// Товарные места.
		Номенклатура = ТоварныеМеста.Получить(СтрокаТаблицы.Номенклатура);
		Если СтрокаТаблицы.Количество > 0 И ЕстьТоварныеМеста И Номенклатура <> Неопределено Тогда
			
			Комплект.Очистить();
			Для Каждого Упаковка Из Номенклатура Цикл
				Комплект.Вставить(Упаковка.Ключ, 0);
			КонецЦикла;
			
			// Определяем количество целых комплектов.
			КоличествоКомплектов = 0;
			Для ИндексЯчейки = 0 По МаксИндексЯчейки Цикл
				СтрокаЯчейки = НайденныеСтроки[ИндексЯчейки];
				Если Не СтрокаЯчейки.ЭтоТоварноеМесто Тогда
					Продолжить;
				КонецЕсли;
				
				Количество = Комплект.Получить(СтрокаЯчейки.Упаковка);
				Если Количество <> Неопределено Тогда
					КоличествоКомплектов = Количество + СтрокаЯчейки.Количество * Номенклатура[СтрокаЯчейки.Упаковка];
					Комплект.Вставить(СтрокаЯчейки.Упаковка, КоличествоКомплектов);
				КонецЕсли;
				
			КонецЦикла;
			Для Каждого Упаковка Из Комплект Цикл
				КоличествоКомплектов = Мин(КоличествоКомплектов, Упаковка.Значение);
			КонецЦикла;
			
			ВсегоПодобратьКомплектов = Мин(СтрокаТаблицы.Количество, КоличествоКомплектов);
			СтрокаТаблицы.Количество = СтрокаТаблицы.Количество - ВсегоПодобратьКомплектов;
			
			// Набираем комплекты из упаковок.
			Для Каждого Упаковка Из Комплект Цикл
				Комплект.Вставить(Упаковка.Ключ, ?(Номенклатура[Упаковка.Ключ] = 0, 0, ВсегоПодобратьКомплектов / Номенклатура[Упаковка.Ключ]));
			КонецЦикла;
			Для ИндексЯчейки = 0 По МаксИндексЯчейки Цикл
				СтрокаЯчейки = НайденныеСтроки[ИндексЯчейки];
				Если Не СтрокаЯчейки.ЭтоТоварноеМесто Тогда
					Продолжить;
				КонецЕсли;
				
				Количество = Комплект.Получить(СтрокаЯчейки.Упаковка);
				Если Количество <> Неопределено И Количество > 0 Тогда
					КоличествоТекущее = Мин(Количество, СтрокаЯчейки.Количество);
					Комплект.Вставить(СтрокаЯчейки.Упаковка, Количество - КоличествоТекущее);
					НоваяСтрока = Результат.Добавить(); // добавление строки
					ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаЯчейки);
					НоваяСтрока.КонтролируемаяПартия = СтрокаТаблицы.КонтролируемаяПартия;
					НоваяСтрока.Количество = КоличествоТекущее * Номенклатура[СтрокаЯчейки.Упаковка];
				КонецЕсли;
				
			КонецЦикла;
			
		КонецЕсли;
		
		Если СтрокаТаблицы.Количество > 0 Тогда
			ЗаполнитьЗначенияСвойств(Результат.Добавить(), СтрокаТаблицы); // добавление строки
		КонецЕсли;
		
	КонецЦикла;
	
	СтруктураДействий = Новый Структура();
	СтруктураДействий.Вставить("ПересчитатьКоличествоУпаковок");
	ПакетнаяОбработкаТабличнойЧастиСервер.ОбработатьТЧ(Результат, СтруктураДействий, Неопределено);
	Возврат Результат;
	
КонецФункции

// По ссылке на объект партии определяет складские аналитики,
// по которым нужно получать остатки, для заполнения данных о количестве товаров партии на складе.
//  Параметры:
//   ДанныеЗаполнения - ОпределяемыйТип.ПартияКонтроляКачества
//  Возвращаемое значение:
//   ТаблицаЗначений - таблица с полями:
//    * Номенклатура - СправочникСсылка.Номенклатура - номенклатура товара партии.
//    * Характеристика - СправочникСсылка.ХарактеристикиНоменклатуры - характеристика товара партии.
//    * Склад - СправочникСсылка.Склады - склад, в котором находится товар партии.
//    * Назначение - СправочникСсылка.Назначения - назначение, для которого предназначается товар партии.
//    * КонтролируемаяПартия - СправочникСсылка.КонтролируемыеПартии - партия товара, по которой имеются остатки заблокированного товара.
//    * Серия - СправочникСсылка.СерииНоменклатуры - серия товара партии.
//    * Помещение - СправочникСсылка.СкладскиеПомещения - помещение, в котором находится товар партии.
Функция АналитикиПоступившегоТовара(ДанныеЗаполнения) Экспорт
	
	ИсправляемыйДокумент = ИсправлениеДокументов.ИсправляемыйДокумент(ДанныеЗаполнения);
	Ссылка = ?(ИсправляемыйДокумент = Неопределено, ДанныеЗаполнения, ИсправляемыйДокумент);
	
	Запрос = Новый Запрос();
	Запрос.Текст =
		"ВЫБРАТЬ
		|	Партии.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.КонтролируемыеПартии КАК Партии
		|ГДЕ
		|	Партии.Партия = &Ссылка";
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	Выборка = Запрос.Выполнить().Выбрать();
	КонтролируемаяПартияОснование = Неопределено;
	Если Выборка.Следующий() Тогда
		КонтролируемаяПартияОснование = Выборка.Ссылка;
	КонецЕсли;
	Запрос.УстановитьПараметр("КонтролируемаяПартия", КонтролируемаяПартияОснование);
	Запрос.Текст =
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
		|	Товары.КонтролируемаяПартия КАК КонтролируемаяПартия,
		|	Товары.Номенклатура КАК Номенклатура,
		|	Товары.Характеристика КАК Характеристика,
		|	Товары.Склад КАК Склад,
		|	Товары.Назначение КАК Назначение,
		|	Товары.Помещение КАК Помещение,
		|	Товары.Серия КАК Серия
		|ИЗ
		|	РегистрНакопления.ТоварыНаСкладах.Остатки(, КонтролируемаяПартия = &КонтролируемаяПартия) КАК Товары
		|ГДЕ
		|	Товары.ВНаличииОстаток > 0";
	Аналитики = Запрос.Выполнить().Выгрузить();
	
Возврат Аналитики;

КонецФункции

// Добавляет отбор, по которому устанавливать условное оформление реквизитов качества
// Параметры:
//  Отборы - Массив Из См. КонтрольКачества.ДобавитьОтбор
//  ПутьКДанным - Строка -
//  Значение - Строка,Число -
//  ВидСравнения - ВидСравненияКомпоновкиДанных
Процедура ДобавитьОтбор(Отборы, ПутьКДанным, Значение, ВидСравнения = Неопределено) Экспорт
	
	ВидСравненияТекущий = ?(ВидСравнения = Неопределено, ВидСравненияКомпоновкиДанных.Равно, ВидСравнения);
	Отборы.Добавить(Новый Структура("ПутьКДанным,Значение,ВидСравнения", ПутьКДанным, Значение, ВидСравненияТекущий));
	
КонецПроцедуры

// Формирует структуру полей для условного оформления в форме.
// Параметры:
//  ЭлементПроконтролироватьКачество - ПолеФормы - поле формы, связанное с реквизитом ПроконтролироватьКачество
//  ЭлементДатаПодтвержденияКачества - ПолеФормы - поле формы, связанное с реквизитом ДатаПодтвержденияКачества
// Возвращаемое значение:
//  Структура - структура с полями:
//   * ПроконтролироватьКачество - ПолеФормы - поле формы, связанное с реквизитом ПроконтролироватьКачество
//   * ДатаПодтвержденияКачества - ПолеФормы - поле формы, связанное с реквизитом ДатаПодтвержденияКачества
Функция Поля(ЭлементПроконтролироватьКачество, ЭлементДатаПодтвержденияКачества) Экспорт
	
	Возврат Новый Структура("ПроконтролироватьКачество,ДатаПодтвержденияКачества",
		ЭлементПроконтролироватьКачество, ЭлементДатаПодтвержденияКачества);
	
КонецФункции

// Добавляет в условное оформление формы элементы оформления реквизитов контроля качества.
//  Параметры:
//   УсловноеОформление - УсловноеОформлениеКомпоновкиДанных - свойство условное оформление формы
//   Поля - См. КонтрольКачества.Поля
//   ФлагНедоступен - Массив Из См. КонтрольКачества.ДобавитьОтбор
//   ДатаНеОбязательна - Массив Из См. КонтрольКачества.ДобавитьОтбор
Процедура УстановитьОформление(УсловноеОформление, Поля, ФлагНедоступен = Неопределено, ДатаНеОбязательна = Неопределено) Экспорт
	
	Элемент = УсловноеОформление.Элементы.Добавить();
	
	ПолеЭлемента = Элемент.Поля.Элементы.Добавить();
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(Поля.ДатаПодтвержденияКачества.Имя);
	
	ОтборЭлемента = Элемент.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ОтборЭлемента.ЛевоеЗначение = Новый ПолеКомпоновкиДанных(Поля.ПроконтролироватьКачество.ПутьКДанным);
	ОтборЭлемента.ВидСравнения = ВидСравненияКомпоновкиДанных.Равно;
	ОтборЭлемента.ПравоеЗначение = Ложь;
	
	Элемент.Оформление.УстановитьЗначениеПараметра("ТолькоПросмотр", Истина);
	Элемент.Оформление.УстановитьЗначениеПараметра("ОтметкаНезаполненного", Ложь);
	
	Если ФлагНедоступен <> Неопределено И  ФлагНедоступен.Количество() > 0 Тогда
		
		Элемент = УсловноеОформление.Элементы.Добавить();
		
		ПолеЭлемента = Элемент.Поля.Элементы.Добавить();
		ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(Поля.ПроконтролироватьКачество.Имя);
		
		ГруппаОтбора = Элемент.Отбор.Элементы.Добавить(Тип("ГруппаЭлементовОтбораКомпоновкиДанных"));
		ГруппаОтбора.ТипГруппы = ТипГруппыЭлементовОтбораКомпоновкиДанных.ГруппаИли;
		
			Для Каждого ЭлементОтбора Из ФлагНедоступен Цикл
				ОтборЭлемента = ГруппаОтбора.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
				ОтборЭлемента.ЛевоеЗначение = Новый ПолеКомпоновкиДанных(ЭлементОтбора.ПутьКДанным);
				ОтборЭлемента.ВидСравнения = ЭлементОтбора.ВидСравнения;
				ОтборЭлемента.ПравоеЗначение = ЭлементОтбора.Значение;
			КонецЦикла;
			
		Элемент.Оформление.УстановитьЗначениеПараметра("ТолькоПросмотр", Истина);
		
	КонецЕсли;
	
	Если ДатаНеОбязательна <> Неопределено И ДатаНеОбязательна.Количество() > 0 Тогда
		
		Элемент = УсловноеОформление.Элементы.Добавить();
		
		ПолеЭлемента = Элемент.Поля.Элементы.Добавить();
		ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(Поля.ДатаПодтвержденияКачества.Имя);
		
		ГруппаОтбора = Элемент.Отбор.Элементы.Добавить(Тип("ГруппаЭлементовОтбораКомпоновкиДанных"));
		ГруппаОтбора.ТипГруппы = ТипГруппыЭлементовОтбораКомпоновкиДанных.ГруппаИли;
		
		Для Каждого ЭлементОтбора Из ДатаНеОбязательна Цикл
			ОтборЭлемента = ГруппаОтбора.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
			ОтборЭлемента.ЛевоеЗначение = Новый ПолеКомпоновкиДанных(ЭлементОтбора.ПутьКДанным);
			ОтборЭлемента.ВидСравнения = ЭлементОтбора.ВидСравнения;
			ОтборЭлемента.ПравоеЗначение = ЭлементОтбора.Значение;
		КонецЦикла;
		
		Элемент.Оформление.УстановитьЗначениеПараметра("ОтметкаНезаполненного", Ложь);
		
	КонецЕсли;
	
КонецПроцедуры

// Устанавливает условное оформление реквизитов качества, в документах. где контролируемая партия указывается явным образом.
// Параметры:
//  УсловноеОформление - УсловноеОформлениеКомпоновкиДанных - условное оформление формы
//  Поле - ПолеФормы - поле, связанное с реквизитом ПроконтролироватьКачество
Процедура УсловноеОформлениеДатыПодтвержденияКачестваИзлишков(УсловноеОформление, Поле) Экспорт
	
	Элемент = УсловноеОформление.Элементы.Добавить();
	
	ПолеЭлемента = Элемент.Поля.Элементы.Добавить();
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(Поле.Имя);
	
	ГруппаИли = Элемент.Отбор.Элементы.Добавить(Тип("ГруппаЭлементовОтбораКомпоновкиДанных"));
	ГруппаИли.ТипГруппы = ТипГруппыЭлементовОтбораКомпоновкиДанных.ГруппаИли;
	
	ОтборЭлемента = ГруппаИли.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ОтборЭлемента.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("Объект.Товары.ПодлежитРазблокировке");
	ОтборЭлемента.ВидСравнения = ВидСравненияКомпоновкиДанных.Равно;
	ОтборЭлемента.ПравоеЗначение = Ложь;
	
	ОтборЭлемента = ГруппаИли.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ОтборЭлемента.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("Объект.Товары.КонтролируемаяПартия");
	ОтборЭлемента.ВидСравнения = ВидСравненияКомпоновкиДанных.НеЗаполнено;
	
	Элемент.Оформление.УстановитьЗначениеПараметра("ТолькоПросмотр", Истина);
	Элемент.Оформление.УстановитьЗначениеПараметра("Текст", НСтр("ru = '<только для партий, подлежащих разблокировке>'"));
	Элемент.Оформление.УстановитьЗначениеПараметра("ОтметкаНезаполненного", Ложь);
	Элемент.Оформление.УстановитьЗначениеПараметра("ЦветТекста", ЦветаСтиля.ЦветТекстаОтмененнойСтрокиДокумента);
	
КонецПроцедуры

// Обслуживает интерактивную работу пользователя с документами контроля качества (актом и заявкой).
// Определяет склад и помещение в шапке документа по данным табличной части. Если в табличной части одинаковое значение реквизита, то в шапке заполнеяется этим значением, иначе пустым.
// Параметры:
//  Объект - ДанныеФормыСтруктура - реквизит формы связанный с документом АктКонтроляКачестваТоваров или ЗаявкаНаКонтрольКачестваТоваров
Процедура ЗаполнитьОчиститьСкладПомещениеПоДаннымТабличнойЧастиДокумента(Объект) Экспорт
	
	Если Объект.Товары.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	Объект.Склад = Объект.Товары[0].Склад;
	Объект.Помещение = Объект.Товары[0].Помещение;
	Для Индекс = 1 По Объект.Товары.Количество() - 1 Цикл
		Если Объект.Товары[Индекс].Склад <> Объект.Склад Тогда
			Объект.Склад = Справочники.Склады.ПустаяСсылка();
		КонецЕсли;
		Если Объект.Товары[Индекс].Помещение <> Объект.Помещение Тогда
			Объект.Помещение = Справочники.СкладскиеПомещения.ПустаяСсылка();
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

// Процедура для использования в модулях объектов при создании документов на основании акта контроля качества.
// Проверяет допустимо ли создание на основании исходя из данных акта, если нет, то вызывает исключение.
// Параметры:
//  РеквизитыШапки - Структура - структура с полями:
//   * Статус - ПеречислениеСсылка.СтатусыАктовКонтроляКачества - статус акта контроля качества.
Процедура ВызватьИсключениеПриСозданииНаОснованииАкта(РеквизитыШапки) Экспорт
	
	Если РеквизитыШапки.Статус = Перечисления.СтатусыАктовКонтроляКачества.ВРаботе Тогда
		
		ТекстОшибки = СтрШаблон(НСтр("ru = 'Для выполнения команды необходимо установить статус ""%1"" или ""%2"".'"),
			Перечисления.СтатусыАктовКонтроляКачества.ОжидаетРешения,
			Перечисления.СтатусыАктовКонтроляКачества.Отработан);
		ВызватьИсключение ТекстОшибки;
		
	КонецЕсли;
	
КонецПроцедуры

// Инициализирует параметры структуры для описания варианта обработки табличной части, связанного с конкретным алгоритмом действий механизма.
// Параметры:
//  ИмяДействия - Строка - идентификатор алгоритма обработки табличной части.
// Возвращаемое значение:
//  Структура - структура с полями:
//   * ЧитаемыеПоля - Строка - Поля табличной части, которые будут передаваться с клиента на сервер в обработке табличной части.
//   * ИзменяемыеПоля - Строка - Поля табличной части, которые будут заполнены обработчиком табличной части.
//   * ПараметрыЗапроса - Структура - Параметры запроса получения данных, необходимых для пакетной обработки строк.
//   * ПереопределитьОбработкуВМенеджереОбъекта - Булево - Если истина, то в модуле менеджера объекта можно переопределить обработку.
//   * КлючевыеРеквизитыШапки - Структура - Содержит данные шапки объекта, изменение которых требует выполнения обрабоки строк, так как может привести
//                                          к изменению данных, формируемым запросом пакетной обработки. Необходимо формировать такие данные только,
//                                          если они не указаны в параметре ПараметрыЗапроса.
//   * ПолноеИмяОбъекта - Строка - полное имя объекта метаданных в котором будет выполняться обработка табличной части.
//   * ТекстЗапроса - Строка,Неопределено - Текст запроса получения данных, необходимых для пакетной обработки строк.
//   * ИспользоватьКонтрольКачестваТоваров - Булево - служебный, не требует переопределения Внутри механизма на сервере будет сброшен, если функциональная опция
//                                                    использования контроля качества товаров выключена, что приведет к тому, что обработка не будет выполняться.
Функция НовыйПараметрыДействия(ИмяДействия) Экспорт
	
	ПараметрыДействия = Новый Структура();
	ПараметрыЗапроса = Новый Структура();
	ПараметрыДействия.Вставить("ЧитаемыеПоля", "");
	ПараметрыДействия.Вставить("ИзменяемыеПоля", "");
	ПараметрыДействия.Вставить("ПараметрыЗапроса", ПараметрыЗапроса);
	ПараметрыДействия.Вставить("ПереопределитьОбработкуВМенеджереОбъекта", Ложь);
	ПараметрыДействия.Вставить("КлючевыеРеквизитыШапки", Новый Структура());
	ПараметрыДействия.Вставить("ПолноеИмяОбъекта", "");
	ПараметрыДействия.Вставить("ТекстЗапроса", Неопределено); // если нужно полностью переопределить логику.
	ПараметрыДействия.Вставить("ИспользоватьКонтрольКачестваТоваров", Истина);
	
	Если ИмяДействия = "ЗаполнитьПроконтролироватьКачествоДатаПодтвержденияКачества" Тогда
		
		// При изменении читаемых полей табличной части необходимо вызывать обработку действия для строки табличной части.
		// При изменении параметров запроса и ключевых реквизитов шапки необходимо вызывать
		// обновление кэша параметров действий и обработку действия для всей табличной части.
		
		ПараметрыДействия.ЧитаемыеПоля = "Номенклатура,Склад";
		ПараметрыДействия.ИзменяемыеПоля = "ПроконтролироватьКачество,ДатаПодтвержденияКачества";
		ПараметрыДействия.Вставить("ТекстЗапросаДанныеДокумента", Неопределено);
		// Неопределено означает следующий текст запроса:
		//	"ВЫБРАТЬ
		//	|	Таблица.ИдентификаторСтрокиВТ КАК ИдентификаторСтрокиВТ,
		//	|	Таблица.Номенклатура КАК Номенклатура,
		//	|	Таблица.Склад КАК Склад,
		//	|	&КонтрольКачестваДоговор КАК Договор,
		//	|	&КонтрольКачестваДатаПоступления КАК ДатаПоступления,
		//	|	ЛОЖЬ КАК Установить,
		//	|	ЛОЖЬ КАК Сбросить
		//	|ПОМЕСТИТЬ ДанныеДокументаДляЗаполненияПроконтролироватьКачествоДатаПодтвержденияКачества
		//	|ИЗ
		//	|	#ИсточникДанных КАК Таблица
		//	|ИНДЕКСИРОВАТЬ ПО
		//	|	Номенклатура,Склад,Договор";
		
		ПараметрыЗапроса.Вставить("КонтрольКачестваДоговор");
		ПараметрыЗапроса.Вставить("КонтрольКачестваДатаПоступления", '00010101');
		
	ИначеЕсли ИмяДействия = "ЗаполнитьПодлежитРазблокировкеДатаПодтвержденияКачества" Тогда
		
		ПараметрыДействия.ЧитаемыеПоля = "Номенклатура,КонтролируемаяПартия";
		ПараметрыДействия.ИзменяемыеПоля = "КонтролируемаяПартия,ПодлежитРазблокировке,ДатаПодтвержденияКачества";
		
		ПараметрыДействия.Вставить("ТекстЗапросаДанныеДокумента", Неопределено);
		// Неопределено означает следующий текст запроса:
		//	"ВЫБРАТЬ
		//	|	Таблица.ИдентификаторСтрокиВТ КАК ИдентификаторСтрокиВТ,
		//	|	Таблица.Номенклатура КАК Номенклатура,
		//	|	Таблица.КонтролируемаяПартия КАК КонтролируемаяПартия,
		//	|	&КонтрольКачестваДатаРазблокировкиЕслиНетДатыПоступленияПартии КАК ДатаПоступления,
		//	|	&КонтрольКачестваУстановить КАК Установить,
		//	|	&КонтрольКачестваСбросить КАК Сбросить
		//	|ПОМЕСТИТЬ ДанныеДокументаДляЗаполненияПодлежитРазблокировкеДатаПодтвержденияКачества
		//	|ИЗ
		//	|	#ИсточникДанных КАК Таблица
		//	|ИНДЕКСИРОВАТЬ ПО
		//	|	Номенклатура";
		
		ПараметрыЗапроса.Вставить("КонтрольКачестваДатаРазблокировкиЕслиНетДатыПоступленияПартии", '00010101');
		ПараметрыЗапроса.Вставить("КонтрольКачестваСбросить", Ложь);
		ПараметрыЗапроса.Вставить("КонтрольКачестваУстановить", Ложь);
		
	ИначеЕсли ИмяДействия = "ЗаполнитьКонтролируемуюПартиюОтправителя" Тогда
		
	КонецЕсли;
	
	Возврат ПараметрыДействия;
	
КонецФункции

#КонецОбласти

#Область СлужебныйПрограммныйИнтерфейс

Функция ОбновитьПараметрыДействий(МодульМенеджера, Объект, КэшПараметров, Принудительно = Ложь) Экспорт
	
	Результат = Ложь;
	
	НовыйКэш = МодульМенеджера.КонтрольКачестваПараметрыДействий(Объект);
	ОтключитьЕслиВыключенаФО(НовыйКэш);
	НовыеПараметрыДействий = КонтрольКачестваКлиентСервер.КэшПоКлючу(НовыйКэш, КэшПараметров.Ключ);
	
	Для Каждого Элемент Из НовыеПараметрыДействий Цикл
			
			Если Элемент.Ключ = "Ключ" Тогда
				Продолжить;
			КонецЕсли;
			Для Каждого ПараметрЗапроса Из Элемент.Значение.ПараметрыЗапроса Цикл
				
				Если КэшПараметров[Элемент.Ключ].ПараметрыЗапроса[ПараметрЗапроса.Ключ]
						<> ПараметрЗапроса.Значение Тогда
					Результат = Истина;
					Прервать;
				КонецЕсли;
				
			КонецЦикла;
			
			Если Результат Тогда
				Прервать;
			КонецЕсли;
			
			Для Каждого КлючевыеРеквизитыШапки Из Элемент.Значение.КлючевыеРеквизитыШапки Цикл
				
				Если КэшПараметров[Элемент.Ключ].КлючевыеРеквизитыШапки[КлючевыеРеквизитыШапки.Ключ]
						<> КлючевыеРеквизитыШапки.Значение Тогда
					Результат = Истина;
					Прервать;
				КонецЕсли;
				
			КонецЦикла;
			
			Если Результат Тогда
				Прервать;
			КонецЕсли;
			
	КонецЦикла;
	
	Для Каждого Свойство Из НовыеПараметрыДействий Цикл
		КэшПараметров[Свойство.Ключ] = Свойство.Значение;
	КонецЦикла;
	
	Возврат Результат Или Принудительно;
	
КонецФункции

Процедура ПакетнаяОбработкаДополнитьИсточникомДанныхКонтрольКачества(Действия, ОписаниеЗапроса, КэшированныеЗначения) Экспорт
	
	Перем ПараметрыДействий;
	ТекстыЗапросов = ОписаниеЗапроса.ТекстыЗапросов; // СписокЗначений
	
	ДобавляемыеТексты = Новый СписокЗначений();
	ИспользоватьТиповуюЛогикуРасчетаДат = Ложь;
	
	Если ПакетнаяОбработкаТабличнойЧастиСервер.ТребуетсяВыполнитьДействие(
			"ЗаполнитьПроконтролироватьКачествоДатаПодтвержденияКачества",
			Действия,
			КэшированныеЗначения,
			ПараметрыДействий) Тогда
		
		ПараметрыДействия = ПараметрыДействий["ЗаполнитьПроконтролироватьКачествоДатаПодтвержденияКачества"];
		
		ТекстЗапросаДанныеДокумента = ПараметрыДействия.ТекстЗапросаДанныеДокумента;
		ТекстЗапроса = ПараметрыДействия.ТекстЗапроса;
		
		Если ТекстЗапроса = Неопределено Тогда
			
			ИспользоватьТиповуюЛогикуРасчетаДат = Истина;
			
			Если ТекстЗапросаДанныеДокумента = Неопределено Тогда
				
				Текст =
					"ВЫБРАТЬ
					|	Таблица.ИдентификаторСтрокиВТ КАК ИдентификаторСтрокиВТ,
					|	Таблица.Номенклатура КАК Номенклатура,
					|	Таблица.Склад КАК Склад,
					|	&КонтрольКачестваДоговор КАК Договор,
					|	&КонтрольКачестваДатаПоступления КАК ДатаПоступления,
					|	ЛОЖЬ КАК Установить,
					|	ЛОЖЬ КАК Сбросить
					|ПОМЕСТИТЬ ДанныеДокументаДляЗаполненияПроконтролироватьКачествоДатаПодтвержденияКачества
					|ИЗ
					|	#ИсточникДанных КАК Таблица
					|ИНДЕКСИРОВАТЬ ПО
					|	Номенклатура,Склад,Договор";
					
			Иначе
				
				Текст = ТекстЗапросаДанныеДокумента;
				
			КонецЕсли;
			Текст = СтрЗаменить(Текст, "#ИсточникДанных", "ВтИсточникДанных");
			
			ДобавляемыеТексты.Добавить(Текст);
			
			Текст =
				"ВЫБРАТЬ
				|	Таблица.ИдентификаторСтрокиВТ КАК ИдентификаторСтрокиВТ,
				|	НЕ КонтролируемаяНоменклатура.Ссылка ЕСТЬ NULL
				|		И НЕ СкладыКонтроляКачества.Ссылка ЕСТЬ NULL
				|		И ДоговорыСГарантиейКачества.Ссылка ЕСТЬ NULL
				|		И НЕ Таблица.Сбросить
				|	ИЛИ Таблица.Установить
				|		И НЕ Таблица.Сбросить КАК ПроконтролироватьКачество,
				|	ВЫБОР
				|		КОГДА КонтролируемаяНоменклатура.Ссылка ЕСТЬ NULL
				|				ИЛИ СкладыКонтроляКачества.Ссылка ЕСТЬ NULL
				|				ИЛИ НЕ ДоговорыСГарантиейКачества.Ссылка ЕСТЬ NULL
				|				ИЛИ Таблица.Сбросить
				|			ТОГДА ДАТАВРЕМЯ(1, 1, 1)
				|		КОГДА Таблица.ДатаПоступления = ДАТАВРЕМЯ(1, 1, 1)
				|			ТОГДА ДАТАВРЕМЯ(1, 1, 1)
				|		КОГДА РасчетСрокаКонтроляКачестваПереопределяемый.НайденнаяДата > ДАТАВРЕМЯ(1, 1, 1)
				|			ТОГДА РасчетСрокаКонтроляКачестваПереопределяемый.НайденнаяДата
				|		ИНАЧЕ ДОБАВИТЬКДАТЕ(Таблица.ДатаПоступления, ДЕНЬ, КонтролируемаяНоменклатура.СрокКонтроляКачества)
				|	КОНЕЦ КАК ДатаПодтвержденияКачества
				|ИЗ
				|	ДанныеДокументаДляЗаполненияПроконтролироватьКачествоДатаПодтвержденияКачества КАК Таблица
				|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК КонтролируемаяНоменклатура
				|		ПО КонтролируемаяНоменклатура.Ссылка  = Таблица.Номенклатура
				|		И КонтролируемаяНоменклатура.КонтролироватьКачествоПоступившегоТовара
				|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Склады КАК СкладыКонтроляКачества
				|		ПО СкладыКонтроляКачества.Ссылка  = Таблица.Склад
				|		И СкладыКонтроляКачества.КонтролироватьКачествоПоступившегоТовара
				|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ДоговорыКонтрагентов КАК ДоговорыСГарантиейКачества
				|		ПО ДоговорыСГарантиейКачества.Ссылка = Таблица.Договор
				|		И ДоговорыСГарантиейКачества.КачествоТоваровГарантированоПоставщиком
				|		ЛЕВОЕ СОЕДИНЕНИЕ РасчетСрокаКонтроляКачестваПереопределяемый ПО ИСТИНА";
			
			Подстановки = ОбеспечениеВДокументахСервер.ДобавитьКДатеПоКалендарюПредприятия(
				"Таблица.ДатаПоступления",
				"КонтролируемаяНоменклатура.СрокКонтроляКачества");
			
			Текст = СтрЗаменить(Текст, "РасчетСрокаКонтроляКачестваПереопределяемый.НайденнаяДата", Подстановки.Поле);
			Текст = СтрЗаменить(Текст, "ЛЕВОЕ СОЕДИНЕНИЕ РасчетСрокаКонтроляКачестваПереопределяемый ПО ИСТИНА", Подстановки.Соединения);
			
			ДобавляемыеТексты.Добавить(Текст, "ЗаполнитьПроконтролироватьКачествоДатаПодтвержденияКачества");
			
		Иначе
			
			ДобавляемыеТексты.Добавить(ТекстЗапроса, "ЗаполнитьПроконтролироватьКачествоДатаПодтвержденияКачества");
			
		КонецЕсли;
		
		ПараметрыЗапроса = ОписаниеЗапроса.ПараметрыЗапроса; // Структура
		ОбщегоНазначенияКлиентСервер.ДополнитьСтруктуру(ПараметрыЗапроса, ПараметрыДействия.ПараметрыЗапроса);
		
	КонецЕсли;
	
	Если ПакетнаяОбработкаТабличнойЧастиСервер.ТребуетсяВыполнитьДействие(
			"ЗаполнитьПодлежитРазблокировкеДатаПодтвержденияКачества",
			Действия,
			КэшированныеЗначения,
			ПараметрыДействий) Тогда
		
		ПараметрыДействия = ПараметрыДействий["ЗаполнитьПодлежитРазблокировкеДатаПодтвержденияКачества"];
		ТекстЗапросаДанныеДокумента = ПараметрыДействия.ТекстЗапросаДанныеДокумента;
		ТекстЗапроса = ПараметрыДействия.ТекстЗапроса;
		
		Если ТекстЗапроса = Неопределено Тогда
			
			ИспользоватьТиповуюЛогикуРасчетаДат = Истина;
			
			Если ТекстЗапросаДанныеДокумента = Неопределено Тогда
				
				Текст =
					"ВЫБРАТЬ
					|	Таблица.ИдентификаторСтрокиВТ КАК ИдентификаторСтрокиВТ,
					|	Таблица.Номенклатура КАК Номенклатура,
					|	Таблица.КонтролируемаяПартия КАК КонтролируемаяПартия,
					|	&КонтрольКачестваДатаРазблокировкиЕслиНетДатыПоступленияПартии КАК ДатаПоступления,
					|	&КонтрольКачестваУстановить КАК Установить,
					|	&КонтрольКачестваСбросить КАК Сбросить
					|ПОМЕСТИТЬ ДанныеДокументаДляЗаполненияПодлежитРазблокировкеДатаПодтвержденияКачества
					|ИЗ
					|	#ИсточникДанных КАК Таблица
					|ИНДЕКСИРОВАТЬ ПО
					|	Номенклатура";
					
			Иначе
				
				Текст = ТекстЗапросаДанныеДокумента;
				
			КонецЕсли;
			
			Текст = СтрЗаменить(Текст, "#ИсточникДанных", "ВтИсточникДанных");
		
			ДобавляемыеТексты.Добавить(Текст);
			
			Текст =
				"ВЫБРАТЬ
				|	Таблица.ИдентификаторСтрокиВТ КАК ИдентификаторСтрокиВТ,
				|	НЕ Таблица.Сбросить
				|		И (Таблица.Установить ИЛИ ЕСТЬNULL(Таблица.КонтролируемаяПартия.ПланироватьРазблокировкуТовара, ЛОЖЬ)) КАК ПодлежитРазблокировке,
				|	ВЫБОР
				|		КОГДА Таблица.Сбросить
				|			ТОГДА ЗНАЧЕНИЕ(Справочник.КонтролируемыеПартии.ПустаяСсылка)
				|		ИНАЧЕ Таблица.КонтролируемаяПартия
				|	КОНЕЦ КАК КонтролируемаяПартия,
				|	ВЫБОР
				|		КОГДА Таблица.Сбросить
				|				ИЛИ Таблица.КонтролируемаяПартия.ПланироватьРазблокировкуТовара ЕСТЬ NULL
				|				ИЛИ НЕ Таблица.КонтролируемаяПартия.ПланироватьРазблокировкуТовара
				|			ТОГДА ДАТАВРЕМЯ(1, 1, 1)
				|		КОГДА Таблица.КонтролируемаяПартия.ДатаПодтвержденияКачества <> ДАТАВРЕМЯ(1, 1, 1)
				|			ТОГДА Таблица.КонтролируемаяПартия.ДатаПодтвержденияКачества
				// Для вырожденных партий без даты поступления, где партия заказ или договор
				|		КОГДА Таблица.КонтролируемаяПартия.ДатаПоступления = ДАТАВРЕМЯ(1, 1, 1)
				|			ТОГДА Таблица.ДатаПоступления
				|		КОГДА РасчетСрокаКонтроляКачестваПереопределяемый.НайденнаяДата > ДАТАВРЕМЯ(1, 1, 1)
				|			ТОГДА РасчетСрокаКонтроляКачестваПереопределяемый.НайденнаяДата
				|		ИНАЧЕ ДОБАВИТЬКДАТЕ(Таблица.КонтролируемаяПартия.ДатаПоступления, ДЕНЬ, ЕСТЬNULL(КонтролируемаяНоменклатура.СрокКонтроляКачества, 0))
				|	КОНЕЦ КАК ДатаПодтвержденияКачества
				|ИЗ
				|	ДанныеДокументаДляЗаполненияПодлежитРазблокировкеДатаПодтвержденияКачества КАК Таблица
				|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК КонтролируемаяНоменклатура
				|		ПО КонтролируемаяНоменклатура.Ссылка  = Таблица.Номенклатура
				|		И КонтролируемаяНоменклатура.КонтролироватьКачествоПоступившегоТовара
				|		ЛЕВОЕ СОЕДИНЕНИЕ РасчетСрокаКонтроляКачестваПереопределяемый ПО ИСТИНА";
		
			Подстановки = ОбеспечениеВДокументахСервер.ДобавитьКДатеПоКалендарюПредприятия(
				"Таблица.КонтролируемаяПартия.ДатаПоступления",
				"КонтролируемаяНоменклатура.СрокКонтроляКачества");
			
			Текст = СтрЗаменить(Текст, "РасчетСрокаКонтроляКачестваПереопределяемый.НайденнаяДата", Подстановки.Поле);
			Текст = СтрЗаменить(Текст, "ЛЕВОЕ СОЕДИНЕНИЕ РасчетСрокаКонтроляКачестваПереопределяемый ПО ИСТИНА", Подстановки.Соединения);
			
			ДобавляемыеТексты.Добавить(Текст, "ЗаполнитьПодлежитРазблокировкеДатаПодтвержденияКачества");
			
		Иначе
			
			ДобавляемыеТексты.Добавить(ТекстЗапроса, "ЗаполнитьПодлежитРазблокировкеДатаПодтвержденияКачества");
			
		КонецЕсли;
		
		ПараметрыЗапроса = ОписаниеЗапроса.ПараметрыЗапроса; // Структура
		ОбщегоНазначенияКлиентСервер.ДополнитьСтруктуру(ПараметрыЗапроса, ПараметрыДействия.ПараметрыЗапроса);
		
	КонецЕсли;
	
	Если ИспользоватьТиповуюЛогикуРасчетаДат Тогда
		ОбеспечениеВДокументахСервер.ДобавитьВременныеТаблицыГодыГрафикаПредприятия(ТекстыЗапросов);
	КонецЕсли;
	
	Для Индекс = 0 По ДобавляемыеТексты.Количество() - 1 Цикл
		
		ТекстыЗапросов.Добавить(ДобавляемыеТексты[Индекс].Значение, ДобавляемыеТексты[Индекс].Представление);
		
	КонецЦикла;
	
	Если ПакетнаяОбработкаТабличнойЧастиСервер.ТребуетсяВыполнитьДействие(
			"ЗаполнитьКонтролируемуюПартиюОтправителя",
			Действия,
			КэшированныеЗначения,
			ПараметрыДействий) Тогда
		
		ПараметрыДействия = ПараметрыДействий["ЗаполнитьКонтролируемуюПартиюОтправителя"];
		Текст = СтрЗаменить(ПараметрыДействия.ТекстЗапроса, "#ИсточникДанных", "ВтИсточникДанных");
		ТекстыЗапросов.Добавить(Текст, "ЗаполнитьКонтролируемуюПартиюОтправителя");
		ПараметрыЗапроса = ОписаниеЗапроса.ПараметрыЗапроса; // Структура
		ОбщегоНазначенияКлиентСервер.ДополнитьСтруктуру(ПараметрыЗапроса, ПараметрыДействия.ПараметрыЗапроса);
		
	КонецЕсли;
	
КонецПроцедуры

Функция ПостановкаНаКонтрольМожетОпределятьсяДоговором(ХозяйственнаяОперация) Экспорт
	
	Результат = ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.ЗакупкаУПоставщика
			Или ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.ЗакупкаУПоставщикаТоварыВПути
			Или ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.ЗакупкаУПоставщикаПоступлениеИзТоваровВПути
			Или ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.ЗакупкаУПоставщикаФактуровкаПоставки
			Или ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.ЗакупкаУПоставщикаНеотфактурованнаяПоставка
			Или ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.ЗакупкаВСтранахЕАЭС
			Или ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.ЗакупкаВСтранахЕАЭСТоварыВПути
			Или ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.ЗакупкаВСтранахЕАЭСПоступлениеИзТоваровВПути
			Или ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.ЗакупкаВСтранахЕАЭСФактуровкаПоставки
			Или ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.ЗакупкаВСтранахЕАЭСНеотфактурованнаяПоставка
			Или ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.ЗакупкаВСтранахЕАЭСНеотфактурованнаяПоставка
			Или ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.ЗакупкаПоИмпорту
			Или ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.ЗакупкаПоИмпортуТоварыВПути
			Или ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.ЗакупкаПоИмпортуПоступлениеИзТоваровВПути
			Или ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.ЗакупкаЧерезПодотчетноеЛицо
			Или ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.ПоступлениеОтПереработчика2_5
			Или ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.ПриемНаХранениеСПравомПродажи
			Или ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.ПоступлениеОтДавальца2_5;
			
	Возврат Результат;
	
КонецФункции

Процедура ЗаполнитьПроконтролироватьКачествоДатаПодтвержденияКачества(ТекущаяСтрока, ДанныеДляОбработки, Действия) Экспорт
	
	Перем ПараметрыДействий;
	Если Не Действия.Свойство("ЗаполнитьПроконтролироватьКачествоДатаПодтвержденияКачества", ПараметрыДействий) Тогда
