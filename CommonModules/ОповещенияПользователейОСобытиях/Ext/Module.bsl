	|ОБЪЕДИНИТЬ
	|
	|ВЫБРАТЬ
	|	Получатели.Пользователь КАК Пользователь,
	|	Получатели.АдресОповещения КАК АдресЭлектроннойПочты
	|ИЗ
	|	ПолучателиПоПочте КАК Получатели
	|ГДЕ
	|	НЕ Получатели.АдресОповещения ПОДОБНО """"
	|ИТОГИ
	|ПО
	|	Пользователь";
	
	Запрос.УстановитьПараметр("Пользователи", Пользователи);
	Запрос.УстановитьПараметр("ИспользоватьОповещенияПользователейВTelegram",
		ПолучитьФункциональнуюОпцию("ИспользоватьОповещенияПользователейВTelegram"));
	Запрос.УстановитьПараметр("ДоступнаОтправкаПоЭлектроннойПочте",
		ДоступнаОтправкаПоЭлектроннойПочте());
	
	УстановитьПривилегированныйРежим(Истина);
	ПакетЗапросов = Запрос.ВыполнитьПакет();
	УстановитьПривилегированныйРежим(Ложь);
	
	Получатели = Новый Соответствие;
	
	АдресаОповещений = Новый Структура();
	АдресаОповещений.Вставить("АдресаПочты", Новый Массив);
	АдресаОповещений.Вставить("АдресаИнтеграции", Новый Массив);
	
	ВыборкаМессенджеры = ПакетЗапросов[0].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	Пока ВыборкаМессенджеры.Следующий() Цикл
		ВыборкаАдреса = ВыборкаМессенджеры.Выбрать();
		АдресаПользователя = Получатели.Получить(ВыборкаМессенджеры.Пользователь);
		Если АдресаПользователя = Неопределено Тогда
			АдресаПользователя = КонструкторАдресаОповещенийПользователя();
			Получатели.Вставить(ВыборкаМессенджеры.Пользователь, АдресаПользователя);
		КонецЕсли;
		Пока ВыборкаАдреса.Следующий() Цикл
			АдресОповещения = ВыборкаАдреса.АдресОповещения;
			Если АдресаПользователя.АдресаИнтеграции.Найти(ВыборкаАдреса.АдресОповещения) = Неопределено Тогда
				АдресаПользователя.АдресаИнтеграции.Добавить(АдресОповещения);
			КонецЕсли;
		КонецЦикла;
		
	КонецЦикла;
	
	ВыборкаПочта = ПакетЗапросов[2].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	Пока ВыборкаПочта.Следующий() Цикл
		ВыборкаАдреса = ВыборкаПочта.Выбрать();
		АдресаПользователя = Получатели.Получить(ВыборкаПочта.Пользователь);
		Если АдресаПользователя = Неопределено Тогда
			АдресаПользователя = КонструкторАдресаОповещенийПользователя();
			Получатели.Вставить(ВыборкаПочта.Пользователь, АдресаПользователя);
		КонецЕсли;
		Пока ВыборкаАдреса.Следующий() Цикл
			АдресЭлектроннойПочты = ВыборкаАдреса.АдресЭлектроннойПочты;
			Если АдресаПользователя.АдресаПочты.Найти(ВыборкаАдреса.АдресЭлектроннойПочты) = Неопределено Тогда
				АдресаПользователя.АдресаПочты.Добавить(АдресЭлектроннойПочты);
			КонецЕсли;
		КонецЦикла;
	КонецЦикла;
	
	Возврат Получатели;
	
КонецФункции

Функция СпособОповещенияПоОбсуждению(ИдентификаторОбсуждения)
	
	СпособОповещения = Перечисления.СпособыОповещенийПользователей.ПустаяСсылка();
	
	Попытка
		УстановитьПривилегированныйРежим(Истина);
		ОбсуждениеСВ = СистемаВзаимодействия.ПолучитьОбсуждение(ИдентификаторОбсуждения);
		ИнтеграцияСВ = СистемаВзаимодействия.ПолучитьИнтеграцию(ОбсуждениеСВ.Интеграция);
		ТипВнешнейСистемы = ИнтеграцияСВ.ТипВнешнейСистемы;
		СпособОповещения = СпособОповещенияПоТипуВнешнейСистемы(ТипВнешнейСистемы);
		УстановитьПривилегированныйРежим(Ложь);
	Исключение
		ИнформацияОбОшибке = ИнформацияОбОшибке();
		ОписаниеОшибки = ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке);
		ЗаписьЖурналаРегистрации(НСтр(
			"ru = 'Оповещения пользователей.Получение типа внешней системы'",
			ОбщегоНазначения.КодОсновногоЯзыка()), УровеньЖурналаРегистрации.Ошибка, , , ОписаниеОшибки);
	КонецПопытки;
	
	Возврат СпособОповещения;
	
КонецФункции

Функция СпособОповещенияПоТипуВнешнейСистемы(Знач ТипВнешнейСистемы)
	
	СпособОповещения = Перечисления.СпособыОповещенийПользователей.ПустаяСсылка();
	
	Если ВРег(ТипВнешнейСистемы) = "TELEGRAM" Тогда
		СпособОповещения = Перечисления.СпособыОповещенийПользователей.Telegram;
	КонецЕсли;
	
	Возврат СпособОповещения
	
КонецФункции

Функция КонструкторАдресаОповещенийПользователя()
	
	АдресаОповещений = Новый Структура();
	АдресаОповещений.Вставить("АдресаПочты", Новый Массив);
	АдресаОповещений.Вставить("АдресаИнтеграции", Новый Массив);
	
	Возврат АдресаОповещений;
	
КонецФункции

Функция ДоступнаОтправкаПоЭлектроннойПочте()
	
	ОтправкаДоступна = Ложь;
	ИспользоватьОповещенияПользователейПоПочте = ПолучитьФункциональнуюОпцию("ИспользоватьОповещенияПользователейПоПочте");
	УстановитьПривилегированныйРежим(Истина);
	Если ИспользоватьОповещенияПользователейПоПочте И ОбщегоНазначения.ПодсистемаСуществует("СтандартныеПодсистемы.РаботаСПочтовымиСообщениями") Тогда
		МодульРаботаСПочтовымиСообщениями = ОбщегоНазначения.ОбщийМодуль("РаботаСПочтовымиСообщениями");
		СистемнаяУчетнаяЗаписьНастроена = МодульРаботаСПочтовымиСообщениями.УчетнаяЗаписьНастроена(
			МодульРаботаСПочтовымиСообщениями.СистемнаяУчетнаяЗапись(), Истина, Ложь);
		ОтправкаДоступна = СистемнаяУчетнаяЗаписьНастроена
			И ИспользоватьОповещенияПользователейПоПочте;
	КонецЕсли;
	УстановитьПривилегированныйРежим(Ложь);
	
	Возврат ОтправкаДоступна;

КонецФункции

Функция НазваниеКонфигурации()
	
	УстановитьПривилегированныйРежим(Истина);
	
	Результат = Константы.ЗаголовокСистемы.Получить();
	
	Если ПустаяСтрока(Результат) Тогда
		
		Результат = Метаданные.Синоним;
		
	КонецЕсли;
	
	Возврат СокрЛП(Результат);
	
КонецФункции

Функция ПараметрыПубликацииИнфобазы()
	
	ПараметрыПубликации = Новый Структура;
	
	ПараметрыПубликации.Вставить("ЗаголовокСистемы", НазваниеКонфигурации());
	ПараметрыПубликации.Вставить("АдресБазыВИнтернете", ОбщегоНазначения.АдресПубликацииИнформационнойБазыВИнтернете());
	ПараметрыПубликации.Вставить("АдресБазыВЛокальнойСети", ОбщегоНазначения.АдресПубликацииИнформационнойБазыВЛокальнойСети());
	
	Возврат ПараметрыПубликации
	
КонецФункции

Функция НавигационнаяСсылкаДляКонтекстаОповещения(Ссылка, ПараметрыРассылки)
	
	АдресПубликацииИБ = "";
	ВебПубликация = Ложь;
	НавигационнаяСсылка = ПолучитьНавигационнуюСсылку(Ссылка);
	Если ЗначениеЗаполнено(ПараметрыРассылки.АдресБазыВЛокальнойСети) Тогда
		АдресПубликацииИБ = ПараметрыРассылки.АдресБазыВЛокальнойСети;
	ИначеЕсли ЗначениеЗаполнено(ПараметрыРассылки.АдресБазыВИнтернете) Тогда
		АдресПубликацииИБ = ПараметрыРассылки.АдресБазыВИнтернете;
		ВебПубликация = Истина;
	Иначе
		Возврат НавигационнаяСсылка;
	КонецЕсли;
	
	АдресПубликацииИБ = СокрЛП(АдресПубликацииИБ);
	
	Если ВебПубликация И Прав(АдресПубликацииИБ,1)<> "/" Тогда
		АдресПубликацииИБ = АдресПубликацииИБ + "/";
	КонецЕсли;
	
	Возврат АдресПубликацииИБ + "#" + НавигационнаяСсылка;
	
КонецФункции

Процедура ДобавитьСсылкуВТелоПисьма(Текст, Ссылка, ПредставлениеСсылки, ПараметрыПубликации)
	
	ТекстСсылки = ПредставлениеСсылки + Символы.ПС;
	ТекстСсылки = ТекстСсылки + НавигационнаяСсылкаДляКонтекстаОповещения(
		Ссылка,
		ПараметрыПубликации) + Символы.ПС;
	
	Текст = Текст + Символы.ПС + ТекстСсылки;
	
КонецПроцедуры

Функция ОтправитьПисьмо(ТемаПисьма, ТекстПисьма, ПочтовыйАдресПолучателя)
	
	ПисьмоОтправлено = Ложь;
	
	ПараметрыПисьма = Новый Структура;
	ПараметрыПисьма.Вставить("Тема", ТемаПисьма);
	ПараметрыПисьма.Вставить("Тело", ТекстПисьма);
	ПараметрыПисьма.Вставить("Кому", ПочтовыйАдресПолучателя);
	
	МодульРаботаСПочтовымиСообщениями = ОбщегоНазначения.ОбщийМодуль("РаботаСПочтовымиСообщениями");
	
	УчетнаяЗапись = МодульРаботаСПочтовымиСообщениями.СистемнаяУчетнаяЗапись();
	
	Письмо = МодульРаботаСПочтовымиСообщениями.ПодготовитьПисьмо(УчетнаяЗапись, ПараметрыПисьма);
	Попытка
		МодульРаботаСПочтовымиСообщениями.ОтправитьПисьмо(УчетнаяЗапись, Письмо);
		ПисьмоОтправлено = Истина;
	Исключение
		ЗаписьЖурналаРегистрации(НСтр("ru = 'Оповещения пользователей.Отправка оповещений по электронной почте'",
			ОбщегоНазначения.КодОсновногоЯзыка()), 
			УровеньЖурналаРегистрации.Ошибка,,,
			СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(НСтр("ru = 'Оповещения не отправлены по причине:
				|%1'"), 
				ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке())));
	КонецПопытки;
	
	Возврат ПисьмоОтправлено
	
КонецФункции

Функция НайтиБотов()
	
	УстановитьПривилегированныйРежим(Истина);
	МетаданныеБота = Метаданные.Боты.ОповещенияПользователейОСобытиях;
	Боты = СистемаВзаимодействия.ПолучитьБотов();
	НайденныеБоты = Новый Массив;
	
	Для каждого Бот Из Боты Цикл
		Если Бот.Метаданные = МетаданныеБота Тогда
			НайденныеБоты.Добавить(Бот);;
		КонецЕсли;
	КонецЦикла;
	
	Возврат НайденныеБоты;
	
КонецФункции

#КонецОбласти