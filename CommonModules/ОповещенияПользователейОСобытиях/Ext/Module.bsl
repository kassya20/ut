Функция ДанныеПолучателяОповещенийПоИдентификатору(Знач ИдентификаторОбсуждения, СпособОповещения)
	
	Если ТипЗнч(ИдентификаторОбсуждения) <> Тип("Строка") Тогда
		ИдентификаторОбсуждения = Строка(ИдентификаторОбсуждения);
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	ПолучателиОповещений.Пользователь КАК Пользователь,
	|	ПолучателиОповещений.СпособОповещения КАК СпособОповещения,
	|	ПолучателиОповещений.Использовать КАК Использовать
	|ИЗ
	|	РегистрСведений.ПолучателиОповещенийПользователей КАК ПолучателиОповещений
	|ГДЕ
	|	ПолучателиОповещений.АдресОповещения = &ИдентификаторОбсуждения
	|	И ПолучателиОповещений.СпособОповещения = &СпособОповещения";
	Запрос.УстановитьПараметр("ИдентификаторОбсуждения", ИдентификаторОбсуждения);
	Запрос.УстановитьПараметр("СпособОповещения", СпособОповещения);
	
	УстановитьПривилегированныйРежим(Истина);
	Результат = Запрос.Выполнить();
	УстановитьПривилегированныйРежим(Ложь);
	Если Результат.Пустой() Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Возврат Результат.Выгрузить();
	
КонецФункции

Функция ПользовательПоВременномуКодуTelegram(Знач ВременныйКод)
	
	Если НЕ ЭтоВременныйКод(ВременныйКод) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	УстановитьПривилегированныйРежим(Истина);
	ДанныеХранилища = ОбщегоНазначения.ПрочитатьДанныеИзБезопасногоХранилища(ИдентификаторВременныеКодыTelegram(), Неопределено);
	УстановитьПривилегированныйРежим(Ложь);
	
	Если ДанныеХранилища = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	УдаляемыеКлючи = "";
	Пользователь = Неопределено;
	Для каждого СтруктураДанные Из ДанныеХранилища Цикл
		ПользовательИД = СтрЗаменить(СтруктураДанные.Ключ, "_", "-");
		ПользовательИД = Прав(ПользовательИД, СтрДлина(ПользовательИД) - 1);
		ТекущаяДатаВМиллисекундах = ТекущаяУниверсальнаяДатаВМиллисекундах();
		Если Пользователь = Неопределено
			И ВременныйКод = СтруктураДанные.Значение.Код
			И ТекущаяДатаВМиллисекундах < СтруктураДанные.Значение.СрокДействия Тогда
				
				Пользователь = Справочники.Пользователи.ПолучитьСсылку(Новый УникальныйИдентификатор(ПользовательИД));
				
		КонецЕсли;
		
		Если ТекущаяДатаВМиллисекундах >= СтруктураДанные.Значение.СрокДействия Тогда
			УдаляемыеКлючи = УдаляемыеКлючи + ", " + СтруктураДанные.Ключ;
		КонецЕсли;
		
	КонецЦикла;
	
	Если УдаляемыеКлючи <> "" Тогда
		УстановитьПривилегированныйРежим(Истина);
		ОбщегоНазначения.УдалитьДанныеИзБезопасногоХранилища(ИдентификаторВременныеКодыTelegram(), УдаляемыеКлючи);
		УстановитьПривилегированныйРежим(Ложь);
	КонецЕсли;
	
	Возврат Пользователь
	
КонецФункции

Функция ЭтоВременныйКод(ВременныйКод)
	
	РегулярноеВыражениеКод = СтрШаблон("^[a-z]{%1}$", ДлинаВременногоКодаTelegram()); //@Non-NLS-1
	ЭтоВременныйКод = СтрПодобнаПоРегулярномуВыражению(Строка(ВременныйКод), 
		РегулярноеВыражениеКод,
		Ложь);
	
	Возврат ЭтоВременныйКод;
	
КонецФункции

