	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "НаборПереопределяемый", СтрШаблон("(%1)", ТекстНабора));
	ТекстыЗапроса.Добавить(ТекстЗапроса, "ЗапасыИПотребностиИзменениеСгруппированные");
	
	ТекстЗапроса =
		"ВЫБРАТЬ
