Функция ТекстРасчетаДоступныеОстаткиТоваров()
	
	Текст =
		"ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	Товары.Номенклатура КАК Номенклатура,
		|	Товары.Характеристика КАК Характеристика,
		|	Товары.Склад КАК Склад
		|ПОМЕСТИТЬ РазличныеТоварыБезНазначений
		|ИЗ
		|	ТоварыДляРаспределенияЗапасовПереопределяемый КАК Товары
		|ГДЕ
		|	Товары.Номенклатура.ТипНоменклатуры В(
		|		ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Товар),
		|		ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.МногооборотнаяТара))
		|	И Товары.Склад <> НЕОПРЕДЕЛЕНО
		|	И Товары.Склад <> ЗНАЧЕНИЕ(Справочник.Склады.ПустаяСсылка)
		|ИНДЕКСИРОВАТЬ ПО
		|	Номенклатура, Характеристика, Склад
		|;
		|
		|////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Запасы.Номенклатура КАК Номенклатура,
		|	Запасы.Характеристика КАК Характеристика,
		|	Запасы.Склад КАК Склад,
		|	ЗНАЧЕНИЕ(Справочник.КонтролируемыеПартии.ПустаяСсылка) КАК КонтролируемаяПартия,
		|	Запасы.ВНаличииОстаток КАК ВНаличии
		|ПОМЕСТИТЬ ВНаличииПоВсемНазначениям
		|ИЗ
		|	РегистрНакопления.ЗапасыИПотребности.Остатки(,
		|		(Номенклатура, Характеристика, Склад) В(
		|			ВЫБРАТЬ
		|				Товары.Номенклатура КАК Номенклатура,
		|				Товары.Характеристика КАК Характеристика,
		|				Товары.Склад КАК Склад
		|			ИЗ
		|				РазличныеТоварыБезНазначений КАК Товары)) КАК Запасы
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	Запасы.Номенклатура КАК Номенклатура,
		|	Запасы.Характеристика КАК Характеристика,
		|	Запасы.Склад КАК Склад,
		|	Запасы.Заказ КАК КонтролируемаяПартия,
		|	Запасы.ЗаблокированоВНаличииОстаток КАК ВНаличии
		|ИЗ
		|	РегистрНакопления.ЗапасыИПотребности.Остатки(,
		|		Заказ <> НЕОПРЕДЕЛЕНО
		|			И Заказ <> ЗНАЧЕНИЕ(Справочник.КонтролируемыеПартии.ПустаяСсылка)
		|			И ТИПЗНАЧЕНИЯ(Заказ) = ТИП(Справочник.КонтролируемыеПартии)
		|			И (Номенклатура, Характеристика, Склад) В(
		|				ВЫБРАТЬ
		|					Товары.Номенклатура КАК Номенклатура,
		|					Товары.Характеристика КАК Характеристика,
		|					Товары.Склад КАК Склад
		|				ИЗ
		|					РазличныеТоварыБезНазначений КАК Товары)) КАК Запасы
		|;
		|
		|////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Товары.Номенклатура КАК Номенклатура,
		|	Товары.Характеристика КАК Характеристика,
		|	Товары.Назначение КАК Назначение,
		|	Товары.Склад КАК Склад
		|ПОМЕСТИТЬ РазличныеТоварыСНазначениями
		|ИЗ
		|	ТоварыДляРаспределенияЗапасовПереопределяемый КАК Товары
		|ГДЕ
		|	ВЫРАЗИТЬ(Товары.Назначение КАК Справочник.Назначения).Заказ = НЕОПРЕДЕЛЕНО
		|		И ВЫРАЗИТЬ(Товары.Назначение КАК Справочник.Назначения).НаправлениеДеятельности
		|			<> ЗНАЧЕНИЕ(Справочник.НаправленияДеятельности.ПустаяСсылка)
		|	И Товары.Номенклатура.ТипНоменклатуры В(
		|		ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Товар),
		|		ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.МногооборотнаяТара))
		|	И Товары.Склад <> НЕОПРЕДЕЛЕНО
		|	И Товары.Склад <> ЗНАЧЕНИЕ(Справочник.Склады.ПустаяСсылка)
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	Товары.Номенклатура КАК Номенклатура,
		|	Товары.Характеристика КАК Характеристика,
		|	ЗНАЧЕНИЕ(Справочник.Назначения.ПустаяСсылка) КАК Назначение,
		|	Товары.Склад КАК Склад
		|ИЗ
		|	РазличныеТоварыБезНазначений КАК Товары
		|
		|ИНДЕКСИРОВАТЬ ПО
		|	Номенклатура, Характеристика, Склад, Назначение
		|;
		|
		|////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Запасы.Номенклатура КАК Номенклатура,
		|	Запасы.Характеристика КАК Характеристика,
		|	Запасы.Склад КАК Склад,
		|	Запасы.Назначение КАК Назначение,
		|	ЗНАЧЕНИЕ(Справочник.КонтролируемыеПартии.ПустаяСсылка) КАК КонтролируемаяПартия,
		|	Запасы.ВНаличииОстаток
		|		- Запасы.ЗаблокированоВНаличииОстаток КАК ВНаличии,
		|	ВЫБОР
		|		КОГДА
		|			Запасы.ВНаличииОстаток
		|				- Запасы.ЗаблокированоВНаличииОстаток
		|				- Запасы.РезервироватьНаСкладеОстаток < 0
		|			ТОГДА
		|				Запасы.ВНаличииОстаток
		|					- Запасы.ЗаблокированоВНаличииОстаток
		|					- Запасы.РезервироватьНаСкладеОстаток
		|		КОГДА Запасы.ВНаличииОстаток
		|				- Запасы.ЗаблокированоВНаличииОстаток
		|				- Запасы.РезервироватьНаСкладеОстаток
		|				- Запасы.РезервироватьПоМереПоступленияОстаток > 0
		|			ТОГДА
		|				Запасы.ВНаличииОстаток
		|				- Запасы.ЗаблокированоВНаличииОстаток
		|				- Запасы.РезервироватьНаСкладеОстаток
		|				- Запасы.РезервироватьПоМереПоступленияОстаток
		|		ИНАЧЕ 0
		|	КОНЕЦ КАК Доступно
		|ПОМЕСТИТЬ ДоступноПоНазначениям
		|ИЗ
		|	РегистрНакопления.ЗапасыИПотребности.Остатки(,
		|		(Номенклатура, Характеристика, Склад, Назначение) В(
		|			ВЫБРАТЬ
		|				Товары.Номенклатура КАК Номенклатура,
		|				Товары.Характеристика КАК Характеристика,
		|				Товары.Склад КАК Склад,
		|				Товары.Назначение КАК Назначение
		|			ИЗ
		|				РазличныеТоварыСНазначениями КАК Товары)) КАК Запасы
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	Запасы.Номенклатура КАК Номенклатура,
		|	Запасы.Характеристика КАК Характеристика,
		|	Запасы.Склад КАК Склад,
		|	Запасы.Назначение КАК Назначение,
		|	Запасы.Заказ КАК КонтролируемаяПартия,
		|	Запасы.ЗаблокированоВНаличииОстаток КАК ВНаличии,
		|	ВЫБОР
		|		КОГДА
		|			Запасы.ЗаблокированоВНаличииОстаток
		|				- Запасы.РезервироватьНаСкладеИзЗаблокированныхОстаток < 0
		|			ТОГДА
		|				Запасы.ЗаблокированоВНаличииОстаток
		|					- Запасы.РезервироватьНаСкладеИзЗаблокированныхОстаток
		|		КОГДА Запасы.ЗаблокированоВНаличииОстаток
		|				- Запасы.РезервироватьНаСкладеИзЗаблокированныхОстаток
		|				- Запасы.РезервироватьПоМереПоступленияИзЗаблокированныхОстаток > 0
		|			ТОГДА
		|				Запасы.ЗаблокированоВНаличииОстаток
		|				- Запасы.РезервироватьНаСкладеИзЗаблокированныхОстаток
		|				- Запасы.РезервироватьПоМереПоступленияИзЗаблокированныхОстаток 
		|		ИНАЧЕ 0
		|	КОНЕЦ КАК Доступно
		|ИЗ
		|	РегистрНакопления.ЗапасыИПотребности.Остатки(,
		|		Заказ <> НЕОПРЕДЕЛЕНО
		|			И Заказ <> ЗНАЧЕНИЕ(Справочник.КонтролируемыеПартии.ПустаяСсылка)
		|			И ТИПЗНАЧЕНИЯ(Заказ) = ТИП(Справочник.КонтролируемыеПартии)
		|			И (Номенклатура, Характеристика, Склад, Назначение) В(
		|				ВЫБРАТЬ
		|					Товары.Номенклатура КАК Номенклатура,
		|					Товары.Характеристика КАК Характеристика,
		|					Товары.Склад КАК Склад,
		|					Товары.Назначение КАК Назначение
		|				ИЗ
		|					РазличныеТоварыСНазначениями КАК Товары)) КАК Запасы
		|;
		|
		|///////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Товары.Номенклатура КАК Номенклатура,
		|	Товары.Характеристика КАК Характеристика,
		|	Товары.Склад КАК Склад,
		|	Товары.Назначение КАК Назначение,
		|	ВНаличииПоВсемНазначениям.КонтролируемаяПартия КАК КонтролируемаяПартия,
		|	ВНаличииПоВсемНазначениям.ВНаличии КАК ВНаличии,
		|	ВЫБОР
		|		КОГДА ВНаличииПоВсемНазначениям.ВНаличии = 0
		|			ТОГДА 0
		|		ИНАЧЕ ЕСТЬNULL(ДоступноПоНазначениям.Доступно, 0)
		|	КОНЕЦ КАК Доступно
		|ПОМЕСТИТЬ ДанныеРегистровДляРасчетаДоступныеОстаткиТоваров
		|ИЗ
		|	РазличныеТоварыСНазначениями КАК Товары
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВНаличииПоВсемНазначениям КАК ВНаличииПоВсемНазначениям
		|		ПО ВНаличииПоВсемНазначениям.Номенклатура = Товары.Номенклатура
		|		 И ВНаличииПоВсемНазначениям.Характеристика = Товары.Характеристика
		|		 И ВНаличииПоВсемНазначениям.Склад = Товары.Склад
		|		ЛЕВОЕ СОЕДИНЕНИЕ ДоступноПоНазначениям КАК ДоступноПоНазначениям
		|		ПО ДоступноПоНазначениям.Номенклатура = Товары.Номенклатура
		|		 И ДоступноПоНазначениям.Характеристика = Товары.Характеристика
		|		 И ДоступноПоНазначениям.Склад = Товары.Склад
		|		 И ДоступноПоНазначениям.Назначение = Товары.Назначение
		|		 И ДоступноПоНазначениям.КонтролируемаяПартия = ВНаличииПоВсемНазначениям.КонтролируемаяПартия
		|ГДЕ
		|	Товары.Назначение = ЗНАЧЕНИЕ(Справочник.Назначения.ПустаяСсылка)
		|		И НЕ ВНаличииПоВсемНазначениям.КонтролируемаяПартия ЕСТЬ NULL
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	Товары.Номенклатура КАК Номенклатура,
		|	Товары.Характеристика КАК Характеристика,
		|	Товары.Склад КАК Склад,
		|	Товары.Назначение КАК Назначение,
		|	ДоступноПоНазначениям.КонтролируемаяПартия КАК КонтролируемаяПартия,
		|	ДоступноПоНазначениям.ВНаличии КАК ВНаличии,
		|	ВЫБОР
		|		КОГДА ДоступноПоНазначениям.ВНаличии = 0
		|			ТОГДА 0
		|		ИНАЧЕ ДоступноПоНазначениям.Доступно
		|	КОНЕЦ КАК Доступно
		|ИЗ
		|	РазличныеТоварыСНазначениями КАК Товары
		|		ЛЕВОЕ СОЕДИНЕНИЕ ДоступноПоНазначениям КАК ДоступноПоНазначениям
		|		ПО ДоступноПоНазначениям.Номенклатура = Товары.Номенклатура
		|		 И ДоступноПоНазначениям.Характеристика = Товары.Характеристика
		|		 И ДоступноПоНазначениям.Склад = Товары.Склад
		|		 И ДоступноПоНазначениям.Назначение = Товары.Назначение
		|ГДЕ
		|	Товары.Назначение <> ЗНАЧЕНИЕ(Справочник.Назначения.ПустаяСсылка)
		|		И НЕ ДоступноПоНазначениям.КонтролируемаяПартия ЕСТЬ NULL
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	Товары.Номенклатура КАК Номенклатура,
		|	Товары.Характеристика КАК Характеристика,
		|	Товары.Склад КАК Склад,
		|	Товары.Назначение КАК Назначение,
		|	ДоступныеОстаткиТоваров.КонтролируемаяПартия КАК КонтролируемаяПартия,
		|	0 КАК ВНаличии,
		|	0 КАК Доступно
		|ИЗ
		|	РазличныеТоварыСНазначениями КАК Товары
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.ДоступныеОстаткиТоваров КАК ДоступныеОстаткиТоваров
		|		ПО ДоступныеОстаткиТоваров.Номенклатура = Товары.Номенклатура
		|		 И ДоступныеОстаткиТоваров.Характеристика = Товары.Характеристика
		|		 И ДоступныеОстаткиТоваров.Склад = Товары.Склад
		|		 И ДоступныеОстаткиТоваров.Назначение = Товары.Назначение
		|ГДЕ
		|	Товары.Назначение = ЗНАЧЕНИЕ(Справочник.Назначения.ПустаяСсылка)
		|	И НЕ ИСТИНА В(
		|		ВЫБРАТЬ ПЕРВЫЕ 1
		|			ИСТИНА КАК ЕстьЗаписи
		|		ИЗ
		|			ВНаличииПоВсемНазначениям КАК Таблица
		|		ГДЕ
		|			Таблица.Номенклатура = ДоступныеОстаткиТоваров.Номенклатура
		|			И Таблица.Характеристика = ДоступныеОстаткиТоваров.Характеристика
		|			И Таблица.Склад = ДоступныеОстаткиТоваров.Склад
		|			И Таблица.КонтролируемаяПартия = ДоступныеОстаткиТоваров.КонтролируемаяПартия)
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	Товары.Номенклатура КАК Номенклатура,
		|	Товары.Характеристика КАК Характеристика,
		|	Товары.Склад КАК Склад,
		|	Товары.Назначение КАК Назначение,
		|	ДоступныеОстаткиТоваров.КонтролируемаяПартия КАК КонтролируемаяПартия,
		|	0 КАК ВНаличии,
		|	0 КАК Доступно
		|ИЗ
		|	РазличныеТоварыСНазначениями КАК Товары
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.ДоступныеОстаткиТоваров КАК ДоступныеОстаткиТоваров
		|		ПО ДоступныеОстаткиТоваров.Номенклатура = Товары.Номенклатура
		|		 И ДоступныеОстаткиТоваров.Характеристика = Товары.Характеристика
		|		 И ДоступныеОстаткиТоваров.Склад = Товары.Склад
		|		 И ДоступныеОстаткиТоваров.Назначение = Товары.Назначение
		|ГДЕ
		|	Товары.Назначение <> ЗНАЧЕНИЕ(Справочник.Назначения.ПустаяСсылка)
		|	И НЕ ИСТИНА В(
		|		ВЫБРАТЬ ПЕРВЫЕ 1
		|			ИСТИНА КАК ЕстьЗаписи
		|		ИЗ
		|			ДоступноПоНазначениям КАК Таблица
		|		ГДЕ
		|			Таблица.Номенклатура = ДоступныеОстаткиТоваров.Номенклатура
		|			И Таблица.Характеристика = ДоступныеОстаткиТоваров.Характеристика
		|			И Таблица.Склад = ДоступныеОстаткиТоваров.Склад
		|			И Таблица.Назначение = ДоступныеОстаткиТоваров.Назначение
		|			И Таблица.КонтролируемаяПартия = ДоступныеОстаткиТоваров.КонтролируемаяПартия)
		|ИНДЕКСИРОВАТЬ ПО
		|	Номенклатура, Характеристика, Склад, Назначение
		|;
		|
		|///////////////////////////////////////////////////////////////////
		|УНИЧТОЖИТЬ ВНаличииПоВсемНазначениям;
		|УНИЧТОЖИТЬ ДоступноПоНазначениям;
		|УНИЧТОЖИТЬ РазличныеТоварыБезНазначений;
		|УНИЧТОЖИТЬ РазличныеТоварыСНазначениями";
		
	Возврат Текст;
	
КонецФункции

Процедура ВременныеТаблицыДанныхРегистров(Запрос, ИмяТаблицыТовары, ИменаРегистров, ИмяТаблицыРеестрДокументов, ИмяТаблицыКорректировки)
	
	Тексты = Новый Массив();
	
	Если СтрНайти(ИменаРегистров, "ДоступныеОстаткиТоваров") > 0 Тогда
		Текст = ТекстРасчетаДоступныеОстаткиТоваров();
		Тексты.Добавить(Текст);
	КонецЕсли;
	
	Если СтрНайти(ИменаРегистров, "РаспределениеЗапасов") > 0 Тогда
		Текст =
			"ВЫБРАТЬ
			|	Запасы.Номенклатура КАК Номенклатура,
			|	Запасы.Характеристика КАК Характеристика,
			|	Запасы.Склад КАК Склад,
			|	Запасы.Назначение КАК Назначение,
			|	Запасы.Заказ КАК Заказ,
			|	Запасы.ДатаСобытия КАК ДатаСобытия,
			|	Запасы.ВНаличииОстаток КАК ВНаличии,
			|	Запасы.ПоступитОстаток КАК Поступит,
			|	Запасы.ЗаказаноОстаток КАК Заказано,
			|	Запасы.ЗаблокированоВНаличииОстаток КАК ЗаблокированоВНаличии,
			|	Запасы.ЗаблокированоПоступитОстаток КАК ЗаблокированоПоступит,
			|	Запасы.КРазблокировкеОстаток КАК КРазблокировке
			|ПОМЕСТИТЬ Запасы
			|ИЗ
			|	РегистрНакопления.ЗапасыИПотребности.Остатки(,
			|		(Номенклатура, Характеристика, Склад, Назначение) В(
			|			ВЫБРАТЬ
			|				Товары.Номенклатура КАК Номенклатура,
			|				Товары.Характеристика КАК Характеристика,
			|				Товары.Склад КАК Склад,
			|				Товары.Назначение КАК Назначение
			|			ИЗ
			|				ТоварыДляРаспределенияЗапасовПереопределяемый КАК Товары)) КАК Запасы";
		
		ДополнитьТекстомЗапросаКорректировкиЗапаса(Текст, "ПОМЕСТИТЬ Запасы", ИмяТаблицыКорректировки);
		ДобавитьИндекс(Текст, "Номенклатура, Характеристика, Склад, Назначение");
		Тексты.Добавить(Текст);
		
		Текст =
			"ВЫБРАТЬ
			|	Потребности.Номенклатура КАК Номенклатура,
			|	Потребности.Характеристика КАК Характеристика,
			|	Потребности.Склад КАК Склад,
			|	Потребности.Назначение КАК Назначение,
			|	Потребности.Заказ КАК Заказ,
			|	Потребности.ДатаСобытия КАК ДатаСобытия,
			|	ВЫБОР
			|		КОГДА Потребности.РезервироватьНаСкладеОстаток > 0
			|			ТОГДА Потребности.РезервироватьНаСкладеОстаток
			|		ИНАЧЕ 0
			|	КОНЕЦ КАК РезервироватьНаСкладе,
			|	ВЫБОР
			|		КОГДА Потребности.РезервироватьПоМереПоступленияОстаток > 0
			|			ТОГДА Потребности.РезервироватьПоМереПоступленияОстаток
			|		ИНАЧЕ 0
			|	КОНЕЦ КАК РезервироватьПоМереПоступления,
			|	ВЫБОР
			|		КОГДА Потребности.ОтложитьРезервированиеОстаток > 0
			|			ТОГДА Потребности.ОтложитьРезервированиеОстаток
			|		ИНАЧЕ 0
			|	КОНЕЦ КАК ОтложитьРезервирование,
			|	ВЫБОР
			|		КОГДА Потребности.КОбеспечениюОстаток > 0
			|			ТОГДА Потребности.КОбеспечениюОстаток
			|		ИНАЧЕ 0
			|	КОНЕЦ КАК КОбеспечению,
			|	ВЫБОР
			|		КОГДА Потребности.НеОбеспечиватьОстаток > 0
			|			ТОГДА Потребности.НеОбеспечиватьОстаток
			|		ИНАЧЕ 0
			|	КОНЕЦ КАК НеОбеспечивать,
			|	ВЫБОР
			|		КОГДА Потребности.РезервироватьНаСкладеИзЗаблокированныхОстаток > 0
			|			ТОГДА Потребности.РезервироватьНаСкладеИзЗаблокированныхОстаток
			|		ИНАЧЕ 0
			|	КОНЕЦ КАК РезервироватьНаСкладеИзЗаблокированных,
			|	ВЫБОР
			|		КОГДА Потребности.РезервироватьПоМереПоступленияИзЗаблокированныхОстаток > 0
			|			ТОГДА Потребности.РезервироватьПоМереПоступленияИзЗаблокированныхОстаток
			|		ИНАЧЕ 0
			|	КОНЕЦ КАК РезервироватьПоМереПоступленияИзЗаблокированных
