			|	Таблица.ДатаСобытия КАК ДатаСобытия,
			|	Таблица.РезервироватьПоМереПоступления КАК РезервироватьПоМереПоступления,
			|	ЕСТЬNULL(РаспределенныеРанее.ВНаличии, 0) КАК ВНаличии,
			|	ЕСТЬNULL(РаспределенныеРанее.ВНаличииОжидаетсяРазблокировка, 0) КАК ВНаличииОжидаетсяРазблокировка
			|ПОМЕСТИТЬ ПотребностиРезервироватьПоМереПоступленияИЗапасыРаспределенныеРанее
			|ИЗ
			|	Потребности КАК Таблица
			|		
			|		ЛЕВОЕ СОЕДИНЕНИЕ ЗапасыРаспределенныеРанее КАК РаспределенныеРанее
			|		ПО РаспределенныеРанее.Номенклатура = Таблица.Номенклатура
			|		 И РаспределенныеРанее.Характеристика = Таблица.Характеристика
			|		 И РаспределенныеРанее.Склад = Таблица.Склад
			|		 И РаспределенныеРанее.Назначение = Таблица.Назначение
			|		 И РаспределенныеРанее.Заказ = Таблица.Заказ
			|ГДЕ
			|	Таблица.РезервироватьПоМереПоступления > 0
			|ИНДЕКСИРОВАТЬ ПО
			|	Заказ,Номенклатура,Характеристика,Склад,Назначение
			|;
			|
			|//////////////////////////////////////////////////////
			|УНИЧТОЖИТЬ ТоварыСКонтролемОбеспечения";
		Тексты.Добавить(Текст);
		
	КонецЕсли;
	
	Текст = СтрСоединить(Тексты, ОбщегоНазначения.РазделительПакетаЗапросов());
	Запрос.Текст = СтрЗаменить(Текст, "ТоварыДляРаспределенияЗапасовПереопределяемый", ИмяТаблицыТовары);
	Запрос.ВыполнитьПакет();
	
КонецПроцедуры

