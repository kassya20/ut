Процедура ДобавитьВременныеТаблицыАктуализацииСостояний(Запрос, ФильтрПереопределяемый, Постфикс) Экспорт
	
	ИменаРегистров = Новый Массив();
	ИменаРегистров.Добавить("РегистрСведений.СостоянияЗаказовКлиентов");
	ИменаРегистров.Добавить("РегистрСведений.СостоянияВнутреннихЗаказов");
	
	Тексты = Новый Массив();
	
	Для Каждого ИмяРегистра Из ИменаРегистров Цикл
		
		ИмяРегистра = СтрЗаменить(ИмяРегистра, "РегистрСведений.", "");
		Параметры = РегистрыСведений[ИмяРегистра].ПараметрыАктуализацииСостоянийЗаказов();
		Текст = Параметры.ПравилоОтбораЗаписей;
		Текст = СтрЗаменить(Текст, "ФильтрПереопределяемый",  ФильтрПереопределяемый);
		Текст = СтрЗаменить(Текст, "ТаблицаПереопределяемый", ИмяРегистра + Постфикс);
		Тексты.Добавить(Текст);
		
	КонецЦикла;
	
	Запрос.Текст = СтрСоединить(Тексты, ОбщегоНазначения.РазделительПакетаЗапросов());
	Запрос.Выполнить();
	
КонецПроцедуры

Процедура ТаблицаИзмененийРаспределениеЗапасовДляРасчетаСостояний(Запрос) Экспорт
	
	ИменаРегистров = Новый Массив();
	ИменаРегистров.Добавить("РегистрСведений.СостоянияЗаказовКлиентов");
	ИменаРегистров.Добавить("РегистрСведений.СостоянияВнутреннихЗаказов");
	
	Тексты = Новый Массив();
	
	Для Каждого ИмяРегистра Из ИменаРегистров Цикл
		
		ИмяРегистра = СтрЗаменить(ИмяРегистра, "РегистрСведений.", "");
		Параметры = РегистрыСведений[ИмяРегистра].ПараметрыАктуализацииСостоянийЗаказов();
		Текст = Параметры.ФункцияСравненияЗаписейВоВременнуюТаблицу;
		Текст = СтрЗаменить(Текст, "ПередЗаписьюПереопределяемый", ИмяРегистра + "ПередЗаписью");
		Текст = СтрЗаменить(Текст, "ПриЗаписиПереопределяемый",    ИмяРегистра + "ПриЗаписи");
		Текст = СтрЗаменить(Текст, "ИзменениеПереопределяемый",    ИмяРегистра + "Изменение");
		Тексты.Добавить(Текст);
		
	КонецЦикла;
	
	Для Каждого ИмяРегистра Из ИменаРегистров Цикл
		
		ИмяРегистра = СтрЗаменить(ИмяРегистра, "РегистрСведений.", "");
		
		Текст = "УНИЧТОЖИТЬ " + ИмяРегистра + "ПередЗаписью";
		Тексты.Добавить(Текст);
		
		Текст = "УНИЧТОЖИТЬ " + ИмяРегистра + "ПриЗаписи";
		Тексты.Добавить(Текст);
		
	КонецЦикла;
	
	Запрос.Текст = СтрСоединить(Тексты, ОбщегоНазначения.РазделительПакетаЗапросов());
	Запрос.ВыполнитьПакет();
	
КонецПроцедуры

Процедура ИсключитьСсылкиТребующиеОтложенногоОбновления(Ссылки) Экспорт
	
	Если ОбновлениеИнформационнойБазы.ОтложенноеОбновлениеЗавершено() Тогда
		Возврат;
	КонецЕсли;
	
	НаборСостоянияЗаказовКлиентов = РегистрыСведений.СостоянияЗаказовКлиентов.СоздатьНаборЗаписей();
	НаборСостоянияВнутреннихЗаказов = РегистрыСведений.СостоянияВнутреннихЗаказов.СоздатьНаборЗаписей();
	НаборСостоянияЗаказовКлиентов.Отбор.Заказ.Использование = Истина;
	НаборСостоянияВнутреннихЗаказов.Отбор.Заказ.Использование = Истина;
	
	ВсегоЭлементов = Ссылки.Количество();
	Для Счетчик = 1 По ВсегоЭлементов Цикл
		Индекс = ВсегоЭлементов - Счетчик;
		Ссылка = Ссылки[Индекс];
		
		Набор = Неопределено;
		Если НаборСостоянияЗаказовКлиентов.Отбор.Заказ.ТипЗначения.СодержитТип(ТипЗнч(Ссылка)) Тогда
			Набор = НаборСостоянияЗаказовКлиентов;
			Набор.Отбор.Заказ.Значение = Ссылка;
		ИначеЕсли НаборСостоянияВнутреннихЗаказов.Отбор.Заказ.ТипЗначения.СодержитТип(ТипЗнч(Ссылка)) Тогда
			Набор = НаборСостоянияВнутреннихЗаказов;
			Набор.Отбор.Заказ.Значение = Ссылка;
		КонецЕсли;
		
		Если Набор <> Неопределено Тогда
			РезультатПроверки = ОбновлениеИнформационнойБазы.ОбъектОбработан(Набор);
			Если Не РезультатПроверки.Обработан Тогда
				Ссылки.Удалить(Индекс);
			КонецЕсли;
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

Функция ДосчитыватьРегистрРегламентнымЗаданием() Экспорт
	Возврат Не ОбщегоНазначения.ИнформационнаяБазаФайловая() Или БлокироватьРаспределениеЗапасов();
КонецФункции

Функция БлокироватьРаспределениеЗапасов() Экспорт
	ПараметрЗапускаПриложения = ПараметрыСеанса.ПараметрыКлиентаНаСервере.Получить("ПараметрЗапуска");
	Возврат СтрНайти(ПараметрЗапускаПриложения, "БлокироватьРаспределениеЗапасов") > 0;
КонецФункции

Функция ОшибкиПроверкиКорректностиЗаписейРегистраСведенийРаспределениеЗапасов() Экспорт
	
	Запрос = Новый Запрос();
	
	Тексты = Новый Массив();
	
	#Область ОстаткиКонтролируемыхПартий
	Текст =
		"ВЫБРАТЬ
		|	&ТекстОстаткиКонтролируемыхПартий КАК Состояние,
		|	Набор.Номенклатура КАК Номенклатура,
		|	Набор.Характеристика КАК Характеристика,
		|	Набор.Склад КАК Склад,
		|	Набор.Назначение КАК Назначение,
		|	Набор.Заказ КАК КонтролируемаяПартия,
		|	СУММА(Набор.РезервироватьДвижения) КАК РезервироватьДвижения,
		|	СУММА(Набор.РезервироватьПоМереДвижения) КАК РезервироватьПоМереДвижения,
		|	СУММА(Набор.ВНаличииСБлокировкойДвижения) КАК ВНаличииСБлокировкойДвижения,
		|	СУММА(Набор.ОжидаетсяСБлокировкойДвижения) КАК ОжидаетсяСБлокировкойДвижения,
		|	СУММА(Набор.ВНаличииБезРазблокировкиДвижения) КАК ВНаличииБезРазблокировкиДвижения,
		|	СУММА(Набор.ОжидаетсяБезРазблокировкиДвижения) КАК ОжидаетсяБезРазблокировкиДвижения,
		|	СУММА(Набор.РезервироватьСведения) КАК РезервироватьСведения,
		|	СУММА(Набор.РезервироватьПоМереСведения) КАК РезервироватьПоМереСведения,
		|	СУММА(Набор.ВНаличииСБлокировкойСведения) КАК ВНаличииСБлокировкойСведения,
		|	СУММА(Набор.ОжидаетсяСБлокировкойСведения) КАК ОжидаетсяСБлокировкойСведения,
		|	СУММА(Набор.ВНаличииБезРазблокировкиСведения) КАК ВНаличииБезРазблокировкиСведения,
		|	СУММА(Набор.ОжидаетсяБезРазблокировкиСведения) КАК ОжидаетсяБезРазблокировкиСведения
		|ИЗ(
		|	ВЫБРАТЬ
		|		Таблица.Номенклатура КАК Номенклатура,
		|		Таблица.Характеристика КАК Характеристика,
		|		Таблица.Склад КАК Склад,
		|		Таблица.Назначение КАК Назначение,
		|		Таблица.Заказ КАК Заказ,
		|		Таблица.Резервировать КАК РезервироватьДвижения,
		|		Таблица.РезервироватьПоМере КАК РезервироватьПоМереДвижения,
		|		Таблица.ВНаличииСБлокировкой КАК ВНаличииСБлокировкойДвижения,
		|		Таблица.ОжидаетсяСБлокировкой КАК ОжидаетсяСБлокировкойДвижения,
		|		Таблица.ВНаличии - Таблица.ВНаличииСБлокировкой КАК ВНаличииБезРазблокировкиДвижения,
		|		Таблица.Ожидается - Таблица.ОжидаетсяСБлокировкой КАК ОжидаетсяБезРазблокировкиДвижения,
		|		0 КАК РезервироватьСведения,
		|		0 КАК РезервироватьПоМереСведения,
		|		0 КАК ВНаличииСБлокировкойСведения,
		|		0 КАК ОжидаетсяСБлокировкойСведения,
		|		0 КАК ВНаличииБезРазблокировкиСведения,
		|		0 КАК ОжидаетсяБезРазблокировкиСведения
		|	ИЗ(
		|		ВЫБРАТЬ
		|			Таблица.Номенклатура КАК Номенклатура,
		|			Таблица.Характеристика КАК Характеристика,
		|			Таблица.Склад КАК Склад,
		|			Таблица.Назначение КАК Назначение,
		|			Таблица.Заказ КАК Заказ,
		|			Таблица.РезервироватьНаСкладеИзЗаблокированныхОстаток КАК Резервировать,
		|			Таблица.РезервироватьПоМереПоступленияИзЗаблокированныхОстаток КАК РезервироватьПоМере,
		|			Таблица.ЗаблокированоВНаличииОстаток КАК ВНаличии,
		|			Таблица.ЗаблокированоПоступитОстаток КАК Ожидается,
		|			
					// ВНаличииСБлокировкой
		|			ВЫБОР
		|				КОГДА Таблица.ЗаблокированоВНаличииОстаток < 0
		|					ТОГДА Таблица.ЗаблокированоВНаличииОстаток
		|				КОГДА Таблица.ЗаблокированоВНаличииОстаток - Таблица.КРазблокировкеОстаток < 0
		|					ТОГДА Таблица.ЗаблокированоВНаличииОстаток
		|				ИНАЧЕ Таблица.КРазблокировкеОстаток
		|			КОНЕЦ КАК ВНаличииСБлокировкой,
		|			
					// ОжидаетсяСБлокировкой
		|			ВЫБОР
		|				КОГДА Таблица.ЗаблокированоВНаличииОстаток < 0
		|					ТОГДА
		|						ВЫБОР
		|							КОГДА Таблица.ЗаблокированоПоступитОстаток - Таблица.КРазблокировкеОстаток < 0
		|								ТОГДА Таблица.ЗаблокированоПоступитОстаток
		|							ИНАЧЕ Таблица.КРазблокировкеОстаток
		|						КОНЕЦ
		|				КОГДА Таблица.ЗаблокированоВНаличииОстаток - Таблица.КРазблокировкеОстаток < 0
		|					ТОГДА
		|						ВЫБОР
		|							КОГДА Таблица.ЗаблокированоВНаличииОстаток + Таблица.ЗаблокированоПоступитОстаток - Таблица.КРазблокировкеОстаток < 0
		|								ТОГДА Таблица.ЗаблокированоПоступитОстаток
		|							ИНАЧЕ Таблица.КРазблокировкеОстаток - Таблица.ЗаблокированоВНаличииОстаток
		|						КОНЕЦ
		|				ИНАЧЕ 0
		|			КОНЕЦ КАК ОжидаетсяСБлокировкой
		|		ИЗ
		|			РегистрНакопления.ЗапасыИПотребности.Остатки КАК Таблица) КАК Таблица
		|	
		|	ОБЪЕДИНИТЬ ВСЕ
		|	
		|	ВЫБРАТЬ
		|		Таблица.Номенклатура КАК Номенклатура,
		|		Таблица.Характеристика КАК Характеристика,
		|		Таблица.Склад КАК Склад,
		|		Таблица.Назначение КАК Назначение,
		|		Таблица.ЗаказНаПоступление КАК Заказ,
		|		0 КАК РезервироватьДвижения,
		|		0 КАК РезервироватьПоМереДвижения,
		|		0 КАК ВНаличииСБлокировкойДвижения,
		|		0 КАК ОжидаетсяСБлокировкойДвижения,
		|		0 КАК ВНаличииБезРазблокировкиДвижения,
		|		0 КАК ОжидаетсяБезРазблокировкиДвижения,
		|		0 КАК РезервироватьСведения,
		|		0 КАК РезервироватьПоМереСведения,
		|		ВЫБОР
		|			КОГДА Таблица.СостояниеЗапаса = ЗНАЧЕНИЕ(Перечисление.СостоянияЗапаса.ВНаличииОжидаетсяРазблокировка)
		|				ТОГДА Таблица.Количество
		|			ИНАЧЕ 0
		|		КОНЕЦ ВНаличииСБлокировкойСведения,
		|		ВЫБОР
		|			КОГДА Таблица.СостояниеЗапаса = ЗНАЧЕНИЕ(Перечисление.СостоянияЗапаса.ОжидаетсяКПоступлениюСБлокировкой)
		|				ТОГДА Таблица.Количество
		|			ИНАЧЕ 0
		|		КОНЕЦ КАК ОжидаетсяСБлокировкойСведения,
		|		ВЫБОР
		|			КОГДА Таблица.СостояниеЗапаса = ЗНАЧЕНИЕ(Перечисление.СостоянияЗапаса.ВНаличииНеПодлежитРазблокировке)
		|				ТОГДА Таблица.Количество
		|			ИНАЧЕ 0
		|		КОНЕЦ КАК ВНаличииБезРазблокировкиСведения,
		|		ВЫБОР
		|			КОГДА Таблица.СостояниеЗапаса = ЗНАЧЕНИЕ(Перечисление.СостоянияЗапаса.ОжидаетсяКПоступлениюНеПодлежитРазблокировке)
		|				ТОГДА Таблица.Количество
		|			ИНАЧЕ 0
		|		КОНЕЦ КАК ОжидаетсяБезРазблокировкиСведения
		|	ИЗ
		|		РегистрСведений.РаспределениеЗапасов КАК Таблица
		|	ГДЕ
		|		Таблица.СостояниеЗапаса В(
		|			ЗНАЧЕНИЕ(Перечисление.СостоянияЗапаса.ВНаличииОжидаетсяРазблокировка),
		|			ЗНАЧЕНИЕ(Перечисление.СостоянияЗапаса.ВНаличииНеПодлежитРазблокировке),
		|			ЗНАЧЕНИЕ(Перечисление.СостоянияЗапаса.ОжидаетсяКПоступлениюСБлокировкой),
		|			ЗНАЧЕНИЕ(Перечисление.СостоянияЗапаса.ОжидаетсяКПоступлениюНеПодлежитРазблокировке))
		|	
		|	ОБЪЕДИНИТЬ ВСЕ
		|	
		|	ВЫБРАТЬ
		|		Таблица.Номенклатура КАК Номенклатура,
		|		Таблица.Характеристика КАК Характеристика,
		|		Таблица.Склад КАК Склад,
		|		Таблица.Назначение КАК Назначение,
		|		Таблица.ЗаказНаОтгрузку КАК Заказ,
		|		0 КАК РезервироватьДвижения,
		|		0 КАК РезервироватьПоМереДвижения,
		|		0 КАК ВНаличииСБлокировкойДвижения,
		|		0 КАК ОжидаетсяСБлокировкойДвижения,
		|		0 КАК ВНаличииБезРазблокировкиДвижения,
		|		0 КАК ОжидаетсяБезРазблокировкиДвижения,
		|		ВЫБОР
		|			КОГДА Таблица.ХарактеристикаПотребности = ЗНАЧЕНИЕ(Перечисление.ХарактеристикиПотребности.РезервироватьНаСкладеИзЗаблокированных)
		|				ТОГДА Таблица.Количество
		|			ИНАЧЕ 0
		|		КОНЕЦ КАК РезервироватьСведения,
		|		ВЫБОР
		|			КОГДА Таблица.ХарактеристикаПотребности = ЗНАЧЕНИЕ(Перечисление.ХарактеристикиПотребности.РезервироватьПоМереПоступленияИзЗаблокированных)
		|				ТОГДА Таблица.Количество
		|			ИНАЧЕ 0
		|		КОНЕЦ КАК РезервироватьПоМереСведения,
		|		0 КАК ВНаличииСБлокировкойСведения,
		|		0 КАК ОжидаетсяСБлокировкойСведения,
		|		0 КАК ВНаличииБезРазблокировкиСведения,
		|		0 КАК ОжидаетсяБезРазблокировкиСведения
		|	ИЗ
		|		РегистрСведений.РаспределениеЗапасов КАК Таблица
		|	ГДЕ
		|		Таблица.ХарактеристикаПотребности В(
		|			ЗНАЧЕНИЕ(Перечисление.ХарактеристикиПотребности.РезервироватьНаСкладеИзЗаблокированных),
		|			ЗНАЧЕНИЕ(Перечисление.ХарактеристикиПотребности.РезервироватьПоМереПоступленияИзЗаблокированных))) КАК Набор
		|СГРУППИРОВАТЬ ПО
		|	Набор.Номенклатура,
		|	Набор.Характеристика,
		|	Набор.Склад,
		|	Набор.Назначение,
		|	Набор.Заказ
		|ИМЕЮЩИЕ
		|	СУММА(Набор.РезервироватьДвижения) <> СУММА(Набор.РезервироватьСведения)
		|	ИЛИ СУММА(Набор.РезервироватьПоМереДвижения) <> СУММА(Набор.РезервироватьПоМереСведения)
		|	ИЛИ СУММА(Набор.ВНаличииСБлокировкойДвижения) <> СУММА(Набор.ВНаличииСБлокировкойСведения)
		|	ИЛИ СУММА(Набор.ОжидаетсяСБлокировкойДвижения) <> СУММА(Набор.ОжидаетсяСБлокировкойСведения)
		|	ИЛИ СУММА(Набор.ВНаличииБезРазблокировкиДвижения) <> СУММА(Набор.ВНаличииБезРазблокировкиСведения)
		|	ИЛИ СУММА(Набор.ОжидаетсяБезРазблокировкиДвижения) <> СУММА(Набор.ОжидаетсяБезРазблокировкиСведения)";
