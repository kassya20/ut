Процедура ДобавитьВременнуюТаблицуЗапасыЗаблокированные(Запрос)
	
	Запрос.Текст =
		"ВЫБРАТЬ
		|	0 КАК ВидДвижения,
		|	0 КАК ВидЗаписи,
		|	Таблица.Номенклатура КАК Номенклатура,
		|	Таблица.Характеристика КАК Характеристика,
		|	Таблица.Склад КАК Склад,
		|	Таблица.Назначение КАК Назначение,
		|	Таблица.Заказ КАК Заказ,
		|	Таблица.ДатаСобытия КАК ДатаПоступления,
		|	ДАТАВРЕМЯ(1, 1, 1) КАК ДатаДоступности,
		|	Таблица.ДатаСобытия КАК ДатаСобытия,
		|	Таблица.ЗаблокированоВНаличии КАК Количество,
		|	Таблица.ЗаблокированоВНаличии КАК КоличествоИсходное,
		|	0 КАК КоличествоРаспределено,
		|	ЛОЖЬ КАК Пустая
		|ИЗ
		|	Запасы КАК Таблица
		|ГДЕ
			// Устраняем некорректные движения, где дата не пустая (чтобы не группировать данные).
		|	Таблица.ДатаСобытия = ДАТАВРЕМЯ(1, 1, 1)
		|		И Таблица.ЗаблокированоВНаличии <> 0
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	0 КАК ВидДвижения,
		|	1 КАК ВидЗаписи,
		|	Таблица.Номенклатура КАК Номенклатура,
		|	Таблица.Характеристика КАК Характеристика,
		|	Таблица.Склад КАК Склад,
		|	Таблица.Назначение КАК Назначение,
		|	Таблица.Заказ КАК Заказ,
		|	Таблица.ДатаСобытия КАК ДатаПоступления,
		|	ДАТАВРЕМЯ(1, 1, 1) КАК ДатаДоступности,
		|	Таблица.ДатаСобытия КАК ДатаСобытия,
		|	Таблица.ЗаблокированоПоступит КАК Количество,
		|	Таблица.ЗаблокированоПоступит КАК КоличествоИсходное,
		|	0 КАК КоличествоРаспределено,
		|	ЛОЖЬ КАК Пустая
		|ИЗ
		|	Запасы КАК Таблица
		|ГДЕ
		|	Таблица.ЗаблокированоПоступит > 0
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	1 КАК ВидДвижения,
		|	0 КАК ВидЗаписи,
		|	Таблица.Номенклатура КАК Номенклатура,
		|	Таблица.Характеристика КАК Характеристика,
		|	Таблица.Склад КАК Склад,
		|	Таблица.Назначение КАК Назначение,
		|	Таблица.Заказ КАК Заказ,
		|	ДАТАВРЕМЯ(1, 1, 1) КАК ДатаПоступления,
		|	Таблица.ДатаСобытия КАК ДатаДоступности,
		|	Таблица.ДатаСобытия КАК ДатаСобытия,
		|	Таблица.КРазблокировке КАК Количество,
		|	Таблица.КРазблокировке КАК КоличествоИсходное,
		|	0 КАК КоличествоРаспределено,
		|	ИСТИНА КАК Пустая
		|ИЗ
		|	Запасы КАК Таблица
		|ГДЕ
		|	Таблица.КРазблокировке > 0
		|УПОРЯДОЧИТЬ ПО
		|	Номенклатура, Характеристика, Склад, Назначение, Заказ, ВидДвижения, ВидЗаписи, ДатаСобытия";
	
	Таблица = Запрос.Выполнить().Выгрузить();
	Таблица.Колонки.Добавить("Индекс1", Новый ОписаниеТипов("Число")); // первая запись по товару
	Таблица.Колонки.Добавить("Индекс2", Новый ОписаниеТипов("Число")); // первая запись К разблокировке по товару, -1 если таких записей нет.
	Таблица.Колонки.Добавить("Индекс3", Новый ОписаниеТипов("Число")); // последняя запись по товару
	
	ПоляКлюча = "Номенклатура,Характеристика,Склад,Назначение,Заказ";
	Ключ = Новый Структура(ПоляКлюча);
	ВерхИндекс = Таблица.Количество() - 1;
	Для Индекс = 0 По ВерхИндекс Цикл
		
		Запись = Таблица[Индекс];
		Если Ключ.Номенклатура <> Запись.Номенклатура
				Или Ключ.Характеристика <> Запись.Характеристика
				Или Ключ.Склад <> Запись.Склад
				Или Ключ.Назначение <> Запись.Назначение
				Или Ключ.Заказ <> Запись.Заказ Тогда
				
				ПерваяЗапись = Запись;
				ЗаполнитьЗначенияСвойств(Ключ, ПерваяЗапись);
				ПерваяЗапись.Индекс1 = Индекс;
				ПерваяЗапись.Индекс2 = -1;
				
		КонецЕсли;
		
		ПерваяЗапись.Индекс3 = Индекс;
		
		Если Запись.ВидДвижения = 1 И ПерваяЗапись.Индекс2 = -1 Тогда
			ПерваяЗапись.Индекс2 = Индекс;
		КонецЕсли;
		
	КонецЦикла;
	
	// Результат работы цикла:
	// Индекс1 - первая запись по товару.
	// Индекс3 - последняя запись по товару.
	// Индекс2 - первая запись К разблокировке по товару, -1 если таких записей нет.
	
	Индекс = 0;
	Пока Индекс <= ВерхИндекс Цикл
		
		Запись = Таблица[Индекс];
		Если Запись.Индекс2 <> -1 И Запись.Индекс1 < Запись.Индекс2 Тогда
			
			ТекПриход = Запись.Индекс1;
			ТекРасход = Запись.Индекс2;
			
			ЗаписьПриход = Таблица[ТекПриход];
			ЗаписьРасход = Таблица[ТекРасход];
			
			ПриходКон = Запись.Индекс2 - 1;
			РасходКон = Запись.Индекс3;
			
			Пока Истина Цикл
				
				Пока ЗаписьРасход.Количество = 0 И ТекРасход < РасходКон Цикл
					ТекРасход = ТекРасход + 1;
					ЗаписьРасход = Таблица[ТекРасход];
				КонецЦикла;
				Если ЗаписьРасход.Количество = 0 Тогда
					Прервать;
				КонецЕсли;
				
				Пока ЗаписьПриход.Количество <= 0 И ТекПриход < ПриходКон Цикл
					ТекПриход = ТекПриход + 1;
					ЗаписьПриход = Таблица[ТекПриход];
				КонецЦикла;
				Если ЗаписьПриход.Количество <= 0 Тогда
					Прервать;
				КонецЕсли;
				
				Если ЗаписьПриход.Количество = ЗаписьРасход.Количество Тогда
					
					ЗаписьРасход.Количество = 0;
					НоваяЗапись = ЗаписьПриход;
					
				ИначеЕсли ЗаписьПриход.Количество < ЗаписьРасход.Количество Тогда
					
					ЗаписьРасход.Количество = ЗаписьРасход.Количество - Макс(ЗаписьПриход.Количество, 0);
					НоваяЗапись = ЗаписьПриход;
					
				Иначе // ЗаписьПриход.Количество > ЗаписьРасход.Количество
					
					ЗаписьПриход.Количество = ЗаписьПриход.Количество - ЗаписьРасход.Количество;
					
					НоваяЗапись = Таблица.Добавить();
					ЗаполнитьЗначенияСвойств(НоваяЗапись, ЗаписьПриход);
					НоваяЗапись.Количество = ЗаписьРасход.Количество;
					
					ЗаписьРасход.Количество = 0;
					
				КонецЕсли;
				
				НоваяЗапись.ДатаДоступности = ЗаписьРасход.ДатаДоступности;
				НоваяЗапись.КоличествоРаспределено = НоваяЗапись.Количество;
				НоваяЗапись.Количество = 0;
				
			КонецЦикла;
			
		КонецЕсли;
		
		Индекс = Запись.Индекс3 + 1;
		
	КонецЦикла;
	
	Запрос.Текст =
		"ВЫБРАТЬ
		|	ВЫБОР
		|		КОГДА Таблица.ВидЗаписи = 0 И Таблица.Количество < 0
		|			ТОГДА ЗНАЧЕНИЕ(Перечисление.СостоянияЗапаса.ВНаличииОжидаетсяРазблокировка)
		|		КОГДА Таблица.ВидЗаписи = 0 И Таблица.Количество > 0
		|			ТОГДА ЗНАЧЕНИЕ(Перечисление.СостоянияЗапаса.ВНаличииНеПодлежитРазблокировке)
		|		КОГДА Таблица.ВидЗаписи = 0
		|			ТОГДА ЗНАЧЕНИЕ(Перечисление.СостоянияЗапаса.ВНаличииОжидаетсяРазблокировка)
		|		КОГДА Таблица.ВидЗаписи = 1 И Таблица.Количество > 0
		|			ТОГДА ЗНАЧЕНИЕ(Перечисление.СостоянияЗапаса.ОжидаетсяКПоступлениюНеПодлежитРазблокировке)
		|		ИНАЧЕ ЗНАЧЕНИЕ(Перечисление.СостоянияЗапаса.ОжидаетсяКПоступлениюСБлокировкой)
		|	КОНЕЦ КАК СостояниеЗапаса,
		|	Таблица.Номенклатура КАК Номенклатура,
		|	Таблица.Характеристика КАК Характеристика,
		|	Таблица.Склад КАК Склад,
		|	Таблица.Назначение КАК Назначение,
		|	Таблица.Заказ КАК Заказ,
		|	Таблица.ДатаПоступления КАК ДатаПоступления,
		|	Таблица.ДатаДоступности КАК ДатаДоступности,
		|	ВЫБОР
		|		КОГДА Таблица.Количество <> 0
		|			ТОГДА Таблица.Количество
		|		ИНАЧЕ Таблица.КоличествоРаспределено
		|	КОНЕЦ КАК Количество
		|ПОМЕСТИТЬ ЗапасыЗаблокированные
		|ИЗ
		|	&ЗапасыЗаблокированные КАК Таблица
		|ГДЕ
		|	НЕ Таблица.Пустая";
	Запрос.УстановитьПараметр("ЗапасыЗаблокированные", Таблица);
	Запрос.Выполнить();
	
КонецПроцедуры

Функция РезультатРаспределенияЗапасов(Запрос, ИмяТаблицыТовары, ВсеТовары, ИменаРегистров)
	
	#Область ВыборкаДанных
	
	РезультатРаспределенияЗапасов = Новый Структура("РаспределениеЗапасов,ДоступныеОстаткиТоваров");
	ТекстДоступныеОстаткиТоваров =
		// Тексты запросов "Доступные остатки товаров".
		"ВЫБРАТЬ
		|	Таблица.Номенклатура КАК Номенклатура,
		|	Таблица.Характеристика КАК Характеристика,
		|	Таблица.Склад КАК Склад,
		|	Таблица.Назначение КАК Назначение,
		|	Таблица.КонтролируемаяПартия КАК КонтролируемаяПартия,
		|	Таблица.ВНаличии КАК ВНаличии,
		|	Таблица.Доступно КАК Доступно,
		|	НЕ Аналитики.Номенклатура ЕСТЬ NULL КАК АналитикаЕстьВЗаданияхКРасчету
		|ИЗ
		|	ДанныеРегистровДляРасчетаДоступныеОстаткиТоваров КАК Таблица
		|		ЛЕВОЕ СОЕДИНЕНИЕ ИмяТаблицыТовары КАК Аналитики
		|		ПО Аналитики.Номенклатура = Таблица.Номенклатура
		|		 И Аналитики.Характеристика = Таблица.Характеристика
		|		 И Аналитики.Склад = Таблица.Склад
		|		 И Аналитики.Назначение = Таблица.Назначение
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	Таблица.Номенклатура КАК Номенклатура,
		|	Таблица.Характеристика КАК Характеристика,
		|	Таблица.Склад КАК Склад,
		|	Таблица.Назначение КАК Назначение,
		|	ЗНАЧЕНИЕ(Справочник.КонтролируемыеПартии.ПустаяСсылка) КАК КонтролируемаяПартия,
		|	0 КАК ВНаличии,
		|	0 КАК Доступно,
		|	ИСТИНА КАК АналитикаЕстьВЗаданияхКРасчету
		|ИЗ
		|	ИмяТаблицыТовары КАК Таблица
		|ГДЕ
		|	НЕ ИСТИНА В(
		|		ВЫБРАТЬ ПЕРВЫЕ 1
		|			ИСТИНА КАК ЕстьЗаписи
		|		ИЗ
		|			ДанныеРегистровДляРасчетаДоступныеОстаткиТоваров КАК Фильтр
		|		ГДЕ
		|			Фильтр.Номенклатура = Таблица.Номенклатура
		|			И Фильтр.Характеристика = Таблица.Характеристика
		|			И Фильтр.Склад = Таблица.Склад
		|			И Фильтр.Назначение = Таблица.Назначение)
		|УПОРЯДОЧИТЬ ПО
		|	Номенклатура, Характеристика, Склад, Назначение
		|;
		|
		|//////////////////////////////////
		|УНИЧТОЖИТЬ ДанныеРегистровДляРасчетаДоступныеОстаткиТоваров";
	ТекстДоступныеОстаткиТоваров = СтрЗаменить(ТекстДоступныеОстаткиТоваров, "ИмяТаблицыТовары", ИмяТаблицыТовары);
	
	Если СтрНайти(ИменаРегистров, "ДоступныеОстаткиТоваров") > 0 И СтрНайти(ИменаРегистров, "РаспределениеЗапасов") = 0 Тогда
		
		Запрос.Текст = ТекстДоступныеОстаткиТоваров;
		РезультатРаспределенияЗапасов.РаспределениеЗапасов = Неопределено;
		РезультатРаспределенияЗапасов.ДоступныеОстаткиТоваров = Запрос.ВыполнитьПакет()[0].Выгрузить();
		Возврат РезультатРаспределенияЗапасов;
	
	КонецЕсли;
	
	Текст =
		// Потребности.
		"ВЫБРАТЬ
		|	Таблица.Номенклатура КАК Номенклатура,
		|	Таблица.Характеристика КАК Характеристика,
		|	Таблица.Склад КАК Склад,
		|	Таблица.Назначение КАК Назначение,
		|	Таблица.Заказ КАК ЗаказНаОтгрузку,
		|	Таблица.ДатаСобытия КАК ЖелаемаяДатаОтгрузки,
		|	0 КАК ПорядокХарактеристикиПотребности,
		|	Таблица.РезервироватьНаСкладеИзЗаблокированных КАК Количество,
		|	ЗНАЧЕНИЕ(Перечисление.ХарактеристикиПотребности.РезервироватьНаСкладеИзЗаблокированных) КАК ХарактеристикаПотребности,
		|	ЗНАЧЕНИЕ(Перечисление.СостоянияЗапаса.ВНаличииОжидаетсяРазблокировка) КАК СостояниеЗапаса,
		|	Таблица.Заказ КАК КонтролируемаяПартия,
		|	ВЫРАЗИТЬ(ЗаказыРеестра.Приоритет КАК Справочник.Приоритеты).РеквизитДопУпорядочивания КАК ПорядокПоПриоритетуДокумента,
		|	
		|	ВЫБОР
		|		КОГДА НЕ УпорядочиваниеПоДатеДокумента.Значение ЕСТЬ NULL
		|			ТОГДА НЕОПРЕДЕЛЕНО
		|		КОГДА Таблица.ДатаСобытия > &КонецТекущегоДня
		|			ТОГДА Таблица.ДатаСобытия
		|		ИНАЧЕ ЗаказыРеестра.ДатаДокументаИБ
		|	КОНЕЦ КАК ПорядокПоДатеОтгрузкиЛибоБезПорядка,
		|	
		|	ЗаказыРеестра.ДатаДокументаИБ КАК ПорядокПоДатеДокумента,
		|	
		|	ВЫБОР
		|		КОГДА Таблица.ДатаСобытия > &КонецТекущегоДня
		|			ТОГДА Таблица.ДатаСобытия
		|		ИНАЧЕ ЗаказыРеестра.ДатаДокументаИБ
		|	КОНЕЦ КАК ПорядокПоДатеОтгрузки,
		|	
		|	0 КАК КоличествоПриоритет1,
		|	0 КАК КоличествоПриоритет2
		|ИЗ
		|	Потребности КАК Таблица
		|		
		|		ЛЕВОЕ СОЕДИНЕНИЕ ТаблицаЗаказыРеестра КАК ЗаказыРеестра
		|		ПО ЗаказыРеестра.Ссылка = Таблица.Заказ
		|		
		|		ЛЕВОЕ СОЕДИНЕНИЕ Константа.ВариантУпорядочиванияПотребностейПоЗаказамДляОбеспечения КАК УпорядочиваниеПоДатеДокумента
		|		ПО УпорядочиваниеПоДатеДокумента.Значение = ЗНАЧЕНИЕ(Перечисление.ВариантыУпорядочиванияПотребностейПоЗаказамДляОбеспечения.ПриоритетИДатаДокумента)
		|ГДЕ
		|	Таблица.РезервироватьНаСкладеИзЗаблокированных > 0
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	Таблица.Номенклатура КАК Номенклатура,
		|	Таблица.Характеристика КАК Характеристика,
		|	Таблица.Склад КАК Склад,
		|	Таблица.Назначение КАК Назначение,
		|	Таблица.Заказ КАК ЗаказНаОтгрузку,
		|	Таблица.ДатаСобытия КАК ЖелаемаяДатаОтгрузки,
		|	1 КАК ПорядокХарактеристикиПотребности,
		|	Таблица.РезервироватьПоМереПоступленияИзЗаблокированных КАК Количество,
		|	ЗНАЧЕНИЕ(Перечисление.ХарактеристикиПотребности.РезервироватьПоМереПоступленияИзЗаблокированных) КАК ХарактеристикаПотребности,
		|	ЗНАЧЕНИЕ(Перечисление.СостоянияЗапаса.НеОбеспечен) КАК СостояниеЗапаса,
		|	Таблица.Заказ КАК КонтролируемаяПартия,
