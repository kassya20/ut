		|	ЗНАЧЕНИЕ(Перечисление.СостоянияЗапаса.НаСогласованииПоставки) КАК СостояниеЗапаса,
		|	Таблица.Номенклатура КАК Номенклатура,
		|	Таблица.Характеристика КАК Характеристика,
		|	Таблица.Склад КАК Склад,
		|	Таблица.Назначение КАК Назначение,
		|	Таблица.Заказ КАК ЗаказНаПоступление,
		|	НЕОПРЕДЕЛЕНО КАК КонтролируемаяПартия,
		|	ДАТАВРЕМЯ(1, 1, 1) КАК ДатаПоступления,
		|	ДАТАВРЕМЯ(1, 1, 1) КАК ДатаДоступности,
		|	Таблица.Заказано - Таблица.Поступит КАК Количество
		|ИЗ
		|	Запасы КАК Таблица
		|ГДЕ
		|	Таблица.ДатаСобытия = ДАТАВРЕМЯ(1, 1, 1)
		|		И Таблица.Заказано - Таблица.Поступит > 0
		|УПОРЯДОЧИТЬ ПО
		|	Номенклатура,
		|	Характеристика,
		|	Склад,
		|	Назначение,
		|	ПорядокПоСостояниюЗапаса,
		|	ДатаДоступности,
		|	ПорядокПоСостояниюЗапасаДополнительный,
		|	ДатаПоступления,
		|	ЗаказНаПоступление,
		|	КонтролируемаяПартия
		|;
		|
		|////////////////////////////////////////////////////////////////////
		// Товары.
		|ВЫБРАТЬ
		|	Таблица.Номенклатура КАК Номенклатура,
		|	Таблица.Характеристика КАК Характеристика,
		|	Таблица.Склад КАК Склад,
		|	Таблица.Назначение КАК Назначение,
		|	ВЫРАЗИТЬ(-1 КАК ЧИСЛО (10,0)) КАК ПотребностиПервый,
		|	ВЫРАЗИТЬ(-2 КАК ЧИСЛО (10,0)) КАК ПотребностиПоследний,
		|	ВЫРАЗИТЬ(-1 КАК ЧИСЛО (10,0)) КАК ЗапасыПервый,
		|	ВЫРАЗИТЬ(-2 КАК ЧИСЛО (10,0)) КАК ЗапасыПоследний
		|ИЗ
		|	ИмяТаблицыТовары КАК Таблица
		|УПОРЯДОЧИТЬ ПО
		|	Номенклатура, Характеристика, Склад, Назначение
		|;
		|
		|//////////////////////////////////
		// ПотребностиРаспределеноНаНесколькоЗаписей.
		|ВЫБРАТЬ
		|	Таблица.Номенклатура КАК Номенклатура,
		|	Таблица.Характеристика КАК Характеристика,
		|	Таблица.Склад КАК Склад,
		|	Таблица.Назначение КАК Назначение,
		|	Таблица.Заказ КАК ЗаказНаОтгрузку,
		|	МАКСИМУМ(Таблица.ВНаличии) КАК КоличествоПриоритет1,
		|	МАКСИМУМ(Таблица.ВНаличииОжидаетсяРазблокировка) КАК КоличествоПриоритет2
		|ИЗ
		|	ПотребностиРезервироватьПоМереПоступленияИЗапасыРаспределенныеРанее КАК Таблица
		|ГДЕ
		|	(Таблица.ВНаличии > 0 ИЛИ Таблица.ВНаличииОжидаетсяРазблокировка > 0)
		|		И ИСТИНА В(
		|			ВЫБРАТЬ ПЕРВЫЕ 1
		|				ИСТИНА КАК ЕстьВтораяЗапись
		|			ИЗ
		|				ПотребностиРезервироватьПоМереПоступленияИЗапасыРаспределенныеРанее КАК ЭтаЖеТаблица
		|			ГДЕ
		|				ЭтаЖеТаблица.Номенклатура = Таблица.Номенклатура
		|				И ЭтаЖеТаблица.Характеристика = Таблица.Характеристика
		|				И ЭтаЖеТаблица.Склад = Таблица.Склад
		|				И ЭтаЖеТаблица.Назначение = Таблица.Назначение
		|				И ЭтаЖеТаблица.Заказ = Таблица.Заказ
		|				И ЭтаЖеТаблица.ДатаСобытия <> Таблица.ДатаСобытия)
		|СГРУППИРОВАТЬ ПО
		|	Таблица.Номенклатура,
		|	Таблица.Характеристика,
		|	Таблица.Склад,
		|	Таблица.Назначение,
		|	Таблица.Заказ
		|;
		|
		|//////////////////////////////////////////////////////
		|УНИЧТОЖИТЬ Запасы;
		|УНИЧТОЖИТЬ ЗапасыЗаблокированные;
		|УНИЧТОЖИТЬ ТаблицаЗаказыРеестра;
		|УНИЧТОЖИТЬ Потребности;
		|УНИЧТОЖИТЬ ПотребностиРезервироватьПоМереПоступленияИЗапасыРаспределенныеРанее;
		|УНИЧТОЖИТЬ ЗапасыРаспределенныеРанее;
		|УНИЧТОЖИТЬ ПотребностиПоТовару";
	Текст = СтрЗаменить(Текст, "ИмяТаблицыТовары", ИмяТаблицыТовары);
	
	Если СтрНайти(ИменаРегистров, "ДоступныеОстаткиТоваров") > 0 Тогда
		
		Тексты = Новый Массив();
		Тексты.Добавить(Текст);
		Тексты.Добавить(ТекстДоступныеОстаткиТоваров);
		Текст = СтрСоединить(Тексты, ОбщегоНазначения.РазделительПакетаЗапросов());
		
	КонецЕсли;
	
	Запрос.Текст = Текст;
	Запрос.УстановитьПараметр("КонецТекущегоДня", КонецДня(ТекущаяДатаСеанса()));
	Результат = Запрос.ВыполнитьПакет();
	
	Потребности = Результат[0].Выгрузить();
	Запасы = Результат[1].Выгрузить();
	Товары = Результат[2].Выгрузить();
	
	ПотребностиРаспределеноНаНесколькоЗаписей = Результат[3].Выгрузить();
	ПоляКлюча = "Номенклатура,Характеристика,Склад,Назначение,ЗаказНаОтгрузку";
	КлючПоиска = Новый Структура(ПоляКлюча);
	ПотребностиРаспределеноНаНесколькоЗаписей.Индексы.Добавить(ПоляКлюча);
	
	ДоступныеОстаткиТоваров = Неопределено;
	Если СтрНайти(ИменаРегистров, "ДоступныеОстаткиТоваров") > 0 Тогда
		ДоступныеОстаткиТоваров = Результат[Результат.ВГраница() - 1].Выгрузить();
	КонецЕсли;
	
	Набор = РегистрыСведений.РаспределениеЗапасов.СоздатьНаборЗаписей();
	Если ВсеТовары Тогда
		Потребности.Колонки.Добавить("Пустая", Новый ОписаниеТипов("Булево"));
	КонецЕсли;
	Потребности.Колонки.Добавить("ЗаказНаПоступление", Набор.Метаданные().Измерения.ЗаказНаПоступление.Тип);
	Потребности.Колонки.Добавить("ДатаПоступления", Набор.Метаданные().Измерения.ДатаПоступления.Тип);
	Потребности.Колонки.Добавить("ДатаДоступности", Набор.Метаданные().Измерения.ДатаДоступности.Тип);
	Потребности.Колонки.Добавить("НайденаВТаблицеНесколькоЗаписей", Новый ОписаниеТипов("Булево"));
	Потребности.Колонки.Добавить("ВсеРаспределено", Новый ОписаниеТипов("Булево"));
	Потребности.Колонки.Добавить("Количество0", Набор.Метаданные().Ресурсы.Количество.тип);
	Потребности.Колонки.Добавить("Количество1", Набор.Метаданные().Ресурсы.Количество.тип);
	
	#КонецОбласти
	
	// Таблица Товары должна содержать все аналитики Номенклатура+Характеристика+Склад+Назначение, которые встречаются в
	// таблицах Потребности и Запасы. Все три таблицы должны быть упорядочены по этим аналитикам.
	ЗаполнитьИндексыВТаблицеТовары(Товары, Потребности, "ПотребностиПервый", "ПотребностиПоследний");
	ЗаполнитьИндексыВТаблицеТовары(Товары, Запасы, "ЗапасыПервый", "ЗапасыПоследний");
	
	// Потребности упорядочены по полю ПорядокХарактеристикиПотребности
	// 0 - ПеречислениеСсылка.ХарактеристикиПотребности.РезервироватьНаСкладеИзЗаблокированных
	// 1 - ПеречислениеСсылка.ХарактеристикиПотребности.РезервироватьПоМереПоступленияИзЗаблокированных
	// 2 - ПеречислениеСсылка.ХарактеристикиПотребности.РезервироватьНаСкладе
	// 3 - ПеречислениеСсылка.ХарактеристикиПотребности.РезервироватьПоМереПоступления
	// 4 - ПеречислениеСсылка.ХарактеристикиПотребности.ОтложитьРезервирование
	// 5 - ПеречислениеСсылка.ХарактеристикиПотребности.КОбеспечению
	// 6 - ПеречислениеСсылка.ХарактеристикиПотребности.НеОбеспечивать
	
	// Запасы упорядочены по полю ПорядокПоСостояниюЗапаса
	// 0 - ПеречислениеСсылка.СостоянияЗапаса.ВНаличии
	// 1 - ПеречислениеСсылка.СостоянияЗапаса.ВНаличииОжидаетсяРазблокировка
	// 2 - ПеречислениеСсылка.СостоянияЗапаса.ВНаличииНеПодлежитРазблокировке
	// 3 - ПеречислениеСсылка.СостоянияЗапаса.ОжидаетсяКПоступлениюСБлокировкой, доп. упорядочивание по дате доступности
	// 3 - ПеречислениеСсылка.СостоянияЗапаса.ОжидаетсяКПоступлению, доп. упорядочивание по дате доступности
	// 4 - ПеречислениеСсылка.СостоянияЗапаса.ОжидаетсяКПоступлениюНеПодлежитРазблокировке
	// 5 - ПеречислениеСсылка.СостоянияЗапаса.НаСогласованииПоставки
	
	ЗаполняемыеПоляЗапаса = "ЗаказНаПоступление,СостояниеЗапаса,ДатаПоступления,ДатаДоступности";
	ОбщиеЗаполняемыеПоля = "Номенклатура,Характеристика,Склад,Назначение";
	
	ДобавленоСтрок = 0;
	
	ЗначениеИзлишек = Перечисления.ХарактеристикиПотребности.Излишек;
	ЗначениеВНаличии = Перечисления.СостоянияЗапаса.ВНаличии;
	ЗначениеВНаличииОжидаетсяРазблокировка = Перечисления.СостоянияЗапаса.ВНаличииОжидаетсяРазблокировка;
	
	Для ИндексТовары = 0 По Товары.Количество() - 1 Цикл
		
		Строка = Товары[ИндексТовары];
		ПотребностиПервый = Строка.ПотребностиПервый + ДобавленоСтрок;
		ПотребностиПоследний = Строка.ПотребностиПоследний + ДобавленоСтрок;
		
		Запись0 = Неопределено;
		Если Строка.ЗапасыПервый <> -1 И Запасы[Строка.ЗапасыПервый].ПорядокПоСостояниюЗапаса = 0 Тогда
			Запись0 = Запасы[Строка.ЗапасыПервый];
		КонецЕсли;
		
		#Область ОбработкаЗапасов
		
		СоответствиеПартий = Новый Соответствие();
		Для ИндексЗапас = Строка.ЗапасыПервый По Строка.ЗапасыПоследний Цикл
			
			Запас = Запасы[ИндексЗапас];
			
			Если ЗначениеЗаполнено(Запас.КонтролируемаяПартия) Тогда
				
				Партия = СоответствиеПартий.Получить(Запас.КонтролируемаяПартия);
				Если Партия = Неопределено Тогда
					Партия = Новый Структура();
					Партия.Вставить("ВсеЗаписи", Новый Массив());
					Партия.Вставить("Запись1", Новый Массив());
					Партия.Вставить("Запись2", Новый Массив());
					Партия.Вставить("РезервВМинус", Неопределено);
					Партия.Вставить("Количество1", 0);
					Партия.Вставить("Количество2", 0);
					СоответствиеПартий.Вставить(Запас.КонтролируемаяПартия, Партия);
				КонецЕсли;
				Партия.ВсеЗаписи.Добавить(Запас);
				
				Если Запас.ПорядокПоСостояниюЗапаса = 1 Тогда
					Партия.Запись1.Добавить(Запас);
					Партия.Количество1 = Партия.Количество1 + Макс(0, Запас.Количество);
				ИначеЕсли Запас.ПорядокПоСостояниюЗапаса = 2 Тогда
					Партия.Запись2.Добавить(Запас);
					Партия.Количество2 = Партия.Количество2 + Макс(0, Запас.Количество);
				КонецЕсли;
				
			КонецЕсли;
			
		КонецЦикла;
		
		#КонецОбласти
		
		Если Строка.ПотребностиПервый = -1 И Строка.ЗапасыПервый = -1 Тогда // нет запасов, нет потребностей.
			
			Если ВсеТовары Тогда
				// Добавление новых строк в конец таблицы, не мешает следующим товарам создавать непрерывные наборы по аналитикам (номенклатура и т.п.),
				// так как по текущему товару других строк в таблице потребностей нет.
				ТекущаяЗапись = Потребности.Добавить();
				ЗаполнитьЗначенияСвойств(ТекущаяЗапись, Строка);
				ТекущаяЗапись.Пустая = Истина;
			КонецЕсли;
			
		Иначе
			
			// Потребности.
			Если Строка.ПотребностиПервый <> -1 Тогда
				
				ЕстьРезервироватьПоМере = Ложь;
				Для ИндексПотребность = ПотребностиПервый По ПотребностиПоследний Цикл
					
					Потребность = Потребности[ИндексПотребность];
					
					Если Потребность.ПорядокХарактеристикиПотребности = 0 Тогда
					
					#Область РезервироватьНаСкладеИзЗаблокированных
						
						Партия = СоответствиеПартий.Получить(Потребность.КонтролируемаяПартия);
						Если Партия = Неопределено Тогда
							Партия = Новый Структура();
							Партия.Вставить("ВсеЗаписи", Новый Массив());
							Партия.Вставить("Запись1", Новый Массив());
							Партия.Вставить("Запись2", Новый Массив());
							Партия.Вставить("РезервВМинус", Неопределено);
							Партия.Вставить("Количество1", 0);
							Партия.Вставить("Количество2", 0);
							СоответствиеПартий.Вставить(Потребность.КонтролируемаяПартия, Партия);
						КонецЕсли;
						
						Распределить1 = Мин(Партия.Количество1, Потребность.Количество);
						Распределить2 = Мин(Потребность.Количество - Распределить1, Партия.Количество2);
						Распределить3 = Потребность.Количество - Распределить1 - Распределить2;
						
						Партия.Количество1 = Партия.Количество1 - Распределить1;
						ИндексЗапасПартии = 0;
						Пока Распределить1 > 0 И ИндексЗапасПартии < Партия.Запись1.Количество() Цикл
							
							Запас = Партия.Запись1[ИндексЗапасПартии];
							Если Запас.Количество <= 0 Тогда
								ИндексЗапасПартии = ИндексЗапасПартии + 1;
								Продолжить;
							КонецЕсли;
							
							РаспределитьТекущее = Мин(Макс(0, Запас.Количество), Распределить1);
							Распределить1 = Распределить1 - РаспределитьТекущее;
							
							Если РаспределитьТекущее >= Потребность.Количество Тогда
								
								ТекущаяЗапись = Потребность;
								
							Иначе
								
								Потребность.Количество = Потребность.Количество - РаспределитьТекущее;
								
								ТекущаяЗапись = Потребности.Вставить(ПотребностиПоследний + 1);
								ДобавленоСтрок = ДобавленоСтрок + 1;
								ЗаполнитьЗначенияСвойств(ТекущаяЗапись, Потребность);
								ТекущаяЗапись.Количество = РаспределитьТекущее;
								
							КонецЕсли;
							
							ЗаполнитьЗначенияСвойств(ТекущаяЗапись, Запас, ЗаполняемыеПоляЗапаса);
							Запас.Количество = Запас.Количество - РаспределитьТекущее;
						
						КонецЦикла;
						
						ИндексЗапасПартии = 0;
						Пока Распределить2 > 0 И ИндексЗапасПартии < Партия.Запись2.Количество() Цикл
							
							Запас = Партия.Запись2[ИндексЗапасПартии];
							Если Запас.Количество <= 0 Тогда
								ИндексЗапасПартии = ИндексЗапасПартии + 1;
								Продолжить;
							КонецЕсли;
							
							РаспределитьТекущее = Мин(Макс(0, Запас.Количество), Распределить2);
							Распределить2 = Распределить2 - РаспределитьТекущее;
							
							Если РаспределитьТекущее >= Потребность.Количество Тогда
								
								ТекущаяЗапись = Потребность;
								
							Иначе
								
								Потребность.Количество = Потребность.Количество - РаспределитьТекущее;
								
								ТекущаяЗапись = Потребности.Вставить(ПотребностиПоследний + 1);
								ДобавленоСтрок = ДобавленоСтрок + 1;
								ЗаполнитьЗначенияСвойств(ТекущаяЗапись, Потребность);
								ТекущаяЗапись.Количество = РаспределитьТекущее;
								
							КонецЕсли;
							
							ЗаполнитьЗначенияСвойств(ТекущаяЗапись, Запас, ЗаполняемыеПоляЗапаса);
							Запас.Количество = Запас.Количество - РаспределитьТекущее;
						
						КонецЦикла;
						
						Если Распределить3 > 0 Тогда // отрицательный излишек.
							
							Потребность.ЗаказНаПоступление = Потребность.КонтролируемаяПартия;
							Если Партия.РезервВМинус = Неопределено Тогда
								
								Партия.РезервВМинус = Потребности.Вставить(ПотребностиПоследний + 1);
								ТекущаяЗапись = Партия.РезервВМинус;
								
								ДобавленоСтрок = ДобавленоСтрок + 1;
								
								ЗаполнитьЗначенияСвойств(ТекущаяЗапись, Потребность, ОбщиеЗаполняемыеПоля);
								ТекущаяЗапись.ЗаказНаПоступление = Потребность.КонтролируемаяПартия;
								ТекущаяЗапись.СостояниеЗапаса = ЗначениеВНаличииОжидаетсяРазблокировка;
								ТекущаяЗапись.Количество = 0;
								ТекущаяЗапись.ХарактеристикаПотребности = ЗначениеИзлишек;
								
							КонецЕсли;
							
							Партия.РезервВМинус.Количество = Партия.РезервВМинус.Количество - Распределить3;
							
						КонецЕсли;
						
					#КонецОбласти
					
					ИначеЕсли Потребность.ПорядокХарактеристикиПотребности = 1 Тогда
					
					#Область РезервироватьПоМереПоступленияИзЗаблокированных
						
						Партия = СоответствиеПартий.Получить(Потребность.КонтролируемаяПартия);
						Последний = ?(Партия = Неопределено, -1, Партия.ВсеЗаписи.Количество() - 1);
						ИндексЗапасПартии = 0;
						
						ВсеРаспределено = Ложь;
						Пока ИндексЗапасПартии <= Последний Цикл
							
							Запас = Партия.ВсеЗаписи[ИндексЗапасПартии];
							Если Запас.Количество <= 0 Тогда
								ИндексЗапасПартии = ИндексЗапасПартии + 1;
								Продолжить;
							КонецЕсли;
							
							ВсеРаспределено = Ложь;
							Если Запас.Количество >= Потребность.Количество Тогда
								
								ТекущаяЗапись = Потребность;
								ВсеРаспределено = Истина;
								
							Иначе
								
								Потребность.Количество = Потребность.Количество - Запас.Количество;
								
								ТекущаяЗапись = Потребности.Вставить(ПотребностиПоследний + 1);
								ДобавленоСтрок = ДобавленоСтрок + 1;
								ЗаполнитьЗначенияСвойств(ТекущаяЗапись, Потребность);
								ТекущаяЗапись.Количество = Запас.Количество;
								
							КонецЕсли;
							
							ЗаполнитьЗначенияСвойств(ТекущаяЗапись, Запас, ЗаполняемыеПоляЗапаса);
							Запас.Количество = Запас.Количество - ТекущаяЗапись.Количество;
							Если Запас.ПорядокПоСостояниюЗапаса = 1 Тогда
								Партия.Количество1 = Партия.Количество1 - ТекущаяЗапись.Количество;
							КонецЕсли;
							
							Если ВсеРаспределено Тогда
								Прервать;
							КонецЕсли;
							
						КонецЦикла;
						
					#КонецОбласти
					
					ИначеЕсли Потребность.ПорядокХарактеристикиПотребности = 2 Тогда
					
					#Область РезервироватьНаСкладе
						
						Если Запись0 = Неопределено Тогда
							
							Запись0 = Потребности.Вставить(ПотребностиПоследний + 1);
							ДобавленоСтрок = ДобавленоСтрок + 1;
							
							ЗаполнитьЗначенияСвойств(Запись0, Потребность, ОбщиеЗаполняемыеПоля);
							Запись0.СостояниеЗапаса = ЗначениеВНаличии;
							Запись0.Количество = 0;
							Запись0.ХарактеристикаПотребности = ЗначениеИзлишек;
							
						КонецЕсли;
						
						Запись0.Количество = Запись0.Количество - Потребность.Количество;
						
					#КонецОбласти
					
					Иначе
						
						ЕстьРезервироватьПоМере = Потребность.ПорядокХарактеристикиПотребности = 3;
						ПотребностиПервый = ИндексПотребность;
						Прервать;
						
					КонецЕсли;
					
				КонецЦикла;
				
				#Область СкладскиеЗапасыНаРезервироватьПоМереПоступления
				
				Количество0 = Макс(0, ?(Запись0 = Неопределено, 0, Запись0.Количество));
				Количество1 = 0;
				Для Каждого КлючИЗначение Из СоответствиеПартий Цикл
					Количество1 = Количество1 + Макс(0, КлючИЗначение.Значение.Количество1);
				КонецЦикла;
				
				Если ЕстьРезервироватьПоМере И (Количество0 > 0 Или Количество1 > 0) Тогда
					
					// Расчет Потребность.Количество0 и Потребность.Количество1;
					Для НомерПрохода = 1 По 3 Цикл
						
						Для ИндексПотребность = ПотребностиПервый По ПотребностиПоследний Цикл
							
							Потребность = Потребности[ИндексПотребность];
							Если Потребность.ПорядокХарактеристикиПотребности <> 3 Тогда
								Прервать;
							КонецЕсли;
							
							ЗаполнитьЗначенияСвойств(КлючПоиска, Потребность);
							НайденныеСтроки = ПотребностиРаспределеноНаНесколькоЗаписей.НайтиСтроки(КлючПоиска);
							Приемник = ?(НомерПрохода < 3 И НайденныеСтроки.Количество() > 0, НайденныеСтроки[0], Потребность);
							ТекущаяПотребность = ?(НомерПрохода = 1, Приемник.КоличествоПриоритет1, ?(НомерПрохода = 2, Приемник.КоличествоПриоритет2, Потребность.Количество));
							// Заказ мог быть уменьшен а резервы остались.
							ТекущаяПотребность = Мин(ТекущаяПотребность, Потребность.Количество - Потребность.Количество0 - Потребность.Количество1);
							
							Распределить0 = Мин(ТекущаяПотребность, Количество0);
							Количество0 = Количество0 - Распределить0;
							ТекущаяПотребность = ТекущаяПотребность - Распределить0;
							
							Распределить1 = Мин(ТекущаяПотребность, Количество1);
							Количество1 = Количество1 - Распределить1;
							
							// Важно, если потребность по заказу задана несколькими строками.
							Если НомерПрохода = 1 Тогда
								Приемник.КоличествоПриоритет1 = Приемник.КоличествоПриоритет1 - Распределить0 - Распределить1;
							ИначеЕсли НомерПрохода = 2 Тогда
								Приемник.КоличествоПриоритет2 = Приемник.КоличествоПриоритет2 - Распределить0 - Распределить1;
							КонецЕсли;
							
							Потребность.Количество0 = Потребность.Количество0 + Распределить0;
							Потребность.Количество1 = Потребность.Количество1 + Распределить1;
							
							Если Количество0 = 0 И Количество1 = 0 Тогда
								Прервать;
							КонецЕсли;
							
						КонецЦикла;
						
						Если Количество0 = 0 И Количество1 = 0 Тогда
							Прервать;
						КонецЕсли;
						
					КонецЦикла;
					
					// Приоритетное распределение складских запасов.
					ИндексЗапасы = Строка.ЗапасыПервый;
					
					Для ИндексПотребность = ПотребностиПервый По ПотребностиПоследний Цикл
						
						Потребность = Потребности[ИндексПотребность];
						Если Потребность.ПорядокХарактеристикиПотребности <> 3 Тогда
							Прервать;
						КонецЕсли;
						
						Распределить = Потребность.Количество0;
						Запас = Запись0;
						
						Если Распределить > 0 Тогда
							
							Если Распределить >= Потребность.Количество Тогда
								
								ТекущаяЗапись = Потребность;
								Потребность.ВсеРаспределено = Истина;
								
							Иначе
								
								Потребность.Количество = Потребность.Количество - Распределить;
								
								ТекущаяЗапись = Потребности.Вставить(ПотребностиПоследний + 1);
								ДобавленоСтрок = ДобавленоСтрок + 1;
								ЗаполнитьЗначенияСвойств(ТекущаяЗапись, Потребность);
								ТекущаяЗапись.Количество = Распределить;
								
							КонецЕсли;
							
							ЗаполнитьЗначенияСвойств(ТекущаяЗапись, Запас, ЗаполняемыеПоляЗапаса);
							Запас.Количество = Запас.Количество - Распределить;
							
						КонецЕсли;
						
						РаспределитьВсего = Потребность.Количество1;
						
						Пока РаспределитьВсего > 0 И ИндексЗапасы <= Строка.ЗапасыПоследний Цикл
							
							Запас = Запасы[ИндексЗапасы];
							
							Если Запас.Количество <= 0 Или Запас.ПорядокПоСостояниюЗапаса = 0 Тогда
								ИндексЗапасы = ИндексЗапасы + 1;
								Продолжить;
							КонецЕсли;
							
							Если Запас.ПорядокПоСостояниюЗапаса <> 1 Тогда
								Прервать;
							КонецЕсли;
							
							Распределить = Мин(РаспределитьВсего, Запас.Количество);
							РаспределитьВсего = РаспределитьВсего - Распределить;
							
							Если Распределить >= Потребность.Количество Тогда
								
								ТекущаяЗапись = Потребность;
								Потребность.ВсеРаспределено = Истина;
								
							Иначе
								
								Потребность.Количество = Потребность.Количество - Распределить;
								
								ТекущаяЗапись = Потребности.Вставить(ПотребностиПоследний + 1);
								ДобавленоСтрок = ДобавленоСтрок + 1;
								ЗаполнитьЗначенияСвойств(ТекущаяЗапись, Потребность);
								ТекущаяЗапись.Количество = Распределить;
								
							КонецЕсли;
							
							ЗаполнитьЗначенияСвойств(ТекущаяЗапись, Запас, ЗаполняемыеПоляЗапаса);
							Запас.Количество = Запас.Количество - Распределить;
							
						КонецЦикла;
						
					КонецЦикла;
					
				КонецЕсли;
				
				#КонецОбласти
				
				#Область РаспределениеЗапасовОбщее
				
				ИндексЗапасы = Строка.ЗапасыПервый;
				
				Для ИндексПотребность = ПотребностиПервый По ПотребностиПоследний Цикл
					
					Потребность = Потребности[ИндексПотребность];
					Если Потребность.ПорядокХарактеристикиПотребности = 3 И Потребность.ВсеРаспределено Тогда
						Продолжить;
					КонецЕсли;
					
					Если Потребность.ПорядокХарактеристикиПотребности <> 3
							И Потребность.ПорядокХарактеристикиПотребности <> 4
							И Потребность.ПорядокХарактеристикиПотребности <> 5 Тогда
							
						Прервать;
						
					КонецЕсли;
					
					Пока ИндексЗапасы <= Строка.ЗапасыПоследний Цикл
						
						Запас = Запасы[ИндексЗапасы];
						
						Если Запас.Количество <= 0
								// Запасы не подлежащие разблокировке.
								Или Запас.ПорядокПоСостояниюЗапаса = 2
								Или Запас.ПорядокПоСостояниюЗапаса = 4 Тогда
							ИндексЗапасы = ИндексЗапасы + 1;
							Продолжить;
						КонецЕсли;
						
						ВсеРаспределено = Ложь;
						Распределить = Запас.Количество;
						
						Если Распределить >= Потребность.Количество Тогда
							
							ТекущаяЗапись = Потребность;
							ВсеРаспределено = Истина;
							
						Иначе
							
							Потребность.Количество = Потребность.Количество - Распределить;
							
							ТекущаяЗапись = Потребности.Вставить(ПотребностиПоследний + 1);
							ДобавленоСтрок = ДобавленоСтрок + 1;
							ЗаполнитьЗначенияСвойств(ТекущаяЗапись, Потребность);
							ТекущаяЗапись.Количество = Распределить;
							
						КонецЕсли;
						
						ЗаполнитьЗначенияСвойств(ТекущаяЗапись, Запас, ЗаполняемыеПоляЗапаса);
						Запас.Количество = Запас.Количество - ТекущаяЗапись.Количество;
						
						Если ВсеРаспределено Тогда
							Прервать;
						КонецЕсли;
						
					КонецЦикла;
					
				КонецЦикла;
				
				#КонецОбласти
				
			КонецЕсли;
			
			// Излишки.
			ИндексЗапасы = Строка.ЗапасыПервый;
			Пока ИндексЗапасы <= Строка.ЗапасыПоследний Цикл
				
				Запас = Запасы[ИндексЗапасы];
				ИндексЗапасы = ИндексЗапасы + 1;
				Если Запас.Количество = 0 Тогда
					Продолжить;
				КонецЕсли;
				
				Если Строка.ПотребностиПервый = -1 Тогда
					// Добавление новых строк в конец таблицы, не мешает следующим товарам создавать непрерывные наборы по аналитикам (номенклатура и т.п.),
					// так как по текущему товару других строк в таблице потребностей нет.
					ТекущаяЗапись = Потребности.Добавить();
				Иначе
					ТекущаяЗапись = Потребности.Вставить(ПотребностиПоследний + 1);
					ДобавленоСтрок = ДобавленоСтрок + 1;
				КонецЕсли;
				
				ЗаполнитьЗначенияСвойств(ТекущаяЗапись, Запас);
				ТекущаяЗапись.ХарактеристикаПотребности = ЗначениеИзлишек;
				
			КонецЦикла;
			
		КонецЕсли;
		
	КонецЦикла; // Товары
	
	РезультатРаспределенияЗапасов.РаспределениеЗапасов = Потребности;
	РезультатРаспределенияЗапасов.ДоступныеОстаткиТоваров = ДоступныеОстаткиТоваров;
	Возврат РезультатРаспределенияЗапасов;
	
КонецФункции

Процедура ЗаполнитьИндексыВТаблицеТовары(Товары, Таблица, Первый, Последний)
	
	ИндексТовары = 0;
	Для Индекс = 0 По Таблица.Количество() - 1 Цикл
		
		Запись = Таблица[Индекс];
		
		Пока Истина Цикл
			
			Товар = Товары[ИндексТовары];
			Если Товар.Номенклатура = Запись.Номенклатура
				И Товар.Характеристика = Запись.Характеристика
				И Товар.Склад = Запись.Склад
				И Товар.Назначение = Запись.Назначение Тогда
				
				Прервать;
				
			КонецЕсли;
			ИндексТовары = ИндексТовары + 1;
			
		КонецЦикла;
		
		Если Товар[Первый] = -1 Тогда
			Товар[Первый] = Индекс;
		КонецЕсли;
		Товар[Последний] = Индекс;
		
	КонецЦикла;
	
КонецПроцедуры

Процедура ЗаписатьРезультатРаспределенияЗапасов(Результат)
	
	Набор = РегистрыСведений.РаспределениеЗапасов.СоздатьНаборЗаписей();
	Поля = "Номенклатура,Характеристика,Склад,Назначение";
	Отбор = Новый Структура(Поля);
	Таблица = Результат.РаспределениеЗапасов;
	Для Индекс = 0 По Таблица.Количество() - 1 Цикл
		
		Строка = Таблица[Индекс];
		
		Если Отбор.Номенклатура <> Строка.Номенклатура
				Или Отбор.Характеристика <> Строка.Характеристика
				Или Отбор.Склад <> Строка.Склад
				Или Отбор.Назначение <> Строка.Назначение Тогда
					
					Если Отбор.Номенклатура <> Неопределено Тогда
						Набор.Записать();
					КонецЕсли;
					
					ЗаполнитьЗначенияСвойств(Отбор, Строка);
					
					Набор.Очистить();
					Набор.Отбор.Номенклатура.Установить(Отбор.Номенклатура);
					Набор.Отбор.Характеристика.Установить(Отбор.Характеристика);
					Набор.Отбор.Склад.Установить(Отбор.Склад);
					Набор.Отбор.Назначение.Установить(Отбор.Назначение);
					
		КонецЕсли;
		
		Если Не Строка.Пустая Тогда
			ЗаполнитьЗначенияСвойств(Набор.Добавить(), Строка);
		КонецЕсли;
		
	КонецЦикла;
	
	Если Таблица.Количество() > 0 Тогда
		Набор.Записать();
	КонецЕсли;
	
	Таблица = Результат.ДоступныеОстаткиТоваров;
	Набор = РегистрыСведений.ДоступныеОстаткиТоваров.СоздатьНаборЗаписей();
	Для Индекс = 0 По Таблица.Количество() - 1 Цикл
		
		Строка = Таблица[Индекс];
		
		Набор.Очистить();
		Набор.Отбор.Номенклатура.Установить(Строка.Номенклатура);
		Набор.Отбор.Характеристика.Установить(Строка.Характеристика);
		Набор.Отбор.Склад.Установить(Строка.Склад);
		Набор.Отбор.Назначение.Установить(Строка.Назначение);
		Набор.Отбор.КонтролируемаяПартия.Установить(Строка.КонтролируемаяПартия);
		Если Строка.ВНаличии <> 0 Или Строка.Доступно <> 0 Тогда
			ЗаполнитьЗначенияСвойств(Набор.Добавить(), Строка);
		КонецЕсли;
		Набор.Записать();
		
	КонецЦикла;
	
КонецПроцедуры

Функция РаспределениеЗапасовПоТоварам(Запрос, ИмяТаблицыТовары, ВсеТовары, ИменаРегистров, ИмяТаблицыРеестрДокументов = Неопределено, ИмяТаблицыКорректировки = Неопределено)
	
	ВременныеТаблицыДанныхРегистров(Запрос, ИмяТаблицыТовары, ИменаРегистров, ИмяТаблицыРеестрДокументов, ИмяТаблицыКорректировки);
	Если СтрНайти(ИменаРегистров, "РаспределениеЗапасов") > 0 Тогда
		ДобавитьВременнуюТаблицуЗапасыЗаблокированные(Запрос);
	КонецЕсли;
	Результат = РезультатРаспределенияЗапасов(Запрос, ИмяТаблицыТовары, ВсеТовары, ИменаРегистров); // Структура
	Возврат Результат;
	
КонецФункции

Процедура СообщитьОНеудачнойОбработкеНоменклатуры(ИнформацияОбОшибке, ТекстСообщения)
	
	ТекстСообщения = НСтр("ru = 'Задание распределения запасов завершилось неудачно по причине: %Причина%'");
	ТекстСообщения = СтрЗаменить(ТекстСообщения, "%Причина%", ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке));
	СобытиеЖурнала = НСтр("ru = 'Распределение запасов'", ОбщегоНазначения.КодОсновногоЯзыка());
	ЗаписьЖурналаРегистрации(СобытиеЖурнала,
	УровеньЖурналаРегистрации.Ошибка, Метаданные.РегистрыСведений.РаспределениеЗапасов,, ТекстСообщения);
	
КонецПроцедуры

#КонецОбласти
