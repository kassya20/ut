///////////////////////////////////////////////////////////////////////////////////////////////////////
// Подсистема "ИнтернетПоддержкаПользователей.ПлатежныеСистемы.БазоваяФункциональностьПлатежныхСистем".
// ОбщийМодуль.ПлатежныеСистемыКлиентСервер.
//
// Клиент-серверные процедуры статических идентификаторов:
//  - получение типов операции;
//  - получение имени события подсистемы для журнала регистрации.
//
///////////////////////////////////////////////////////////////////////////////////////////////////////

#Область ПрограммныйИнтерфейс

#Область ТипыОпераций

// Возвращает тип операции "Оплата".
//
// Возвращаемое значение:
//  Строка
//
Функция ТипОперацииОплата() Экспорт
	
	Возврат "Оплата";
	
КонецФункции

// Возвращает тип операции "Возврат".
//
// Возвращаемое значение:
//  Строка
//
Функция ТипОперацииВозврат() Экспорт
	
	Возврат "Возврат";
	
КонецФункции

#КонецОбласти

#Область СпособыОплаты

// Возвращает идентификатор, соответствующий не указанному способу оплаты
// 
// Возвращаемое значение:
//  Строка
//
Функция СпособОплатыНеУказан() Экспорт
	
	Возврат "НеУказан";
	
КонецФункции

// Возвращает идентификатор, соответствующий оплате через СБП
// 
// Возвращаемое значение:
//  Строка
//
Функция СпособОплатыСБП() Экспорт
	
	Возврат "СБП";
	
КонецФункции

// Возвращает идентификатор, соответствующий оплате с помощью пластиковой карты
// 
// Возвращаемое значение:
//  Строка
//
Функция СпособОплатыБанковскаяКарта() Экспорт
	
	Возврат "БанковскаяКарта";
	
КонецФункции

// Возвращает идентификатор, соответствующий оплате с помощью карты Озон Банка
// 
// Возвращаемое значение:
//  Строка
//
Функция СпособОплатыОзонКарта() Экспорт
	
	Возврат "ОзонКарта";
	
КонецФункции

#КонецОбласти

#КонецОбласти

#Область СлужебныйПрограммныйИнтерфейс

#Область ЖурналРегистрации

// Возвращает имя события для журнала регистрации.
//
// Параметры:
//  КодОсновногоЯзыка - Строка - код основного языка. Можно получить методом ОбщегоНазначения.КодОсновногоЯзыка
//    или ОбщегоНазначенияКлиент.КодОсновногоЯзыка.
// 
// Возвращаемое значение:
//  Строка
//
Функция ИмяСобытияЖурналаРегистрации(КодОсновногоЯзыка) Экспорт
	
	Возврат НСтр("ru = 'Платежные системы'", КодОсновногоЯзыка);
	
КонецФункции

#КонецОбласти

#КонецОбласти