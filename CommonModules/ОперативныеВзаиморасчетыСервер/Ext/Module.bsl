Процедура ПеренестиКорректировкуРегистровНаСервере()
	
	Запрос = Новый Запрос;
	МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	Запрос.Текст = ТекстЗапросаПереносаКорректировокРегистров();
	
	ТипРасчетов = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	ВсегоПеренесено = 0;
	ТипРегистратора = Тип("ДокументСсылка.КорректировкаРегистров");
	Тип = 21;
	ВидОперацииДляСортировки = "0";
	ПорядокОперацииВПределахДокумента = "1";
	Пока ТипРасчетов.Следующий() Цикл
		
		Корректировка = ТипРасчетов.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		Пока Корректировка.Следующий() Цикл
			НачатьТранзакцию();
			Попытка
				Если ТипРасчетов.ЭтоРасчетыСКлиентами Тогда
					ИмяРегистра = Метаданные.РегистрыНакопления.РасчетыСКлиентамиПоСрокам.Имя;
					Набор = РегистрыНакопления.РасчетыСКлиентамиПоСрокам.СоздатьНаборЗаписей();
					Набор.Отбор.Регистратор.Установить(Корректировка.ДокументРегистратор);
				Иначе
					ИмяРегистра = Метаданные.РегистрыНакопления.РасчетыСПоставщикамиПоСрокам.Имя;
					Набор = РегистрыНакопления.РасчетыСПоставщикамиПоСрокам.СоздатьНаборЗаписей();
					Набор.Отбор.Регистратор.Установить(Корректировка.ДокументРегистратор);
				КонецЕсли;
				ДатаКорректировки = Корректировка.ДатаКорректировки;
				НомерКорректировки = Корректировка.НомерКорректировки;
				КорректировкаОбъект = Корректировка.ДокументРегистратор.ПолучитьОбъект();
				Если КорректировкаОбъект.ТаблицаРегистров.Найти(ИмяРегистра) = Неопределено Тогда
					НовыйРегистр = КорректировкаОбъект.ТаблицаРегистров.Добавить();
					НовыйРегистр.Имя = ИмяРегистра;
				КонецЕсли;
				Движения = Корректировка.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
				Пока Движения.Следующий() Цикл
					
					ДатаПлатежа = ?(ЗначениеЗаполнено(Движения.ДатаПлатежа), Движения.ДатаПлатежа, Дата(3000,1,1));
					
					НоваяЗапись = Набор.Добавить();
					
					//измерения
					НоваяЗапись.Период = Движения.Период;
					НоваяЗапись.АналитикаУчетаПоПартнерам = Движения.АналитикаУчетаПоПартнерам;
					НоваяЗапись.ОбъектРасчетов = Движения.ОбъектРасчетов;
					НоваяЗапись.Валюта = Движения.Валюта;
					НоваяЗапись.РасчетныйДокумент = Движения.РасчетныйДокумент;
					НоваяЗапись.ДатаВозникновения = Движения.ДатаРасчетногоДокумента;
					Если НоваяЗапись.Предоплата = 0 Тогда
						НоваяЗапись.ДатаПлановогоПогашения = Движения.ДатаПлатежа;
					КонецЕсли;
					//ресурсы
					НоваяЗапись.Предоплата = Движения.Предоплата;
					НоваяЗапись.ПредоплатаРегл = Движения.ПредоплатаРегл;
					НоваяЗапись.ПредоплатаУпр = Движения.ПредоплатаУпр;
					НоваяЗапись.Долг = Движения.Долг;
					НоваяЗапись.ДолгРегл = Движения.ДолгРегл;
					НоваяЗапись.ДолгУпр = Движения.ДолгУпр;
					
					//реквизиты
					НоваяЗапись.СтатьяДвиженияДенежныхСредств = Движения.СтатьяДвиженияДенежныхСредств;
					НоваяЗапись.ХозяйственнаяОперация = Движения.ХозяйственнаяОперация;
					НоваяЗапись.ДокументРегистратор = Движения.ДокументРегистратор;
					
					НоваяЗапись.ПорядокОперации = ОперативныеВзаиморасчетыСервер.Порядок(Движения.ДатаКорректировки, Движения.НомерКорректировки, Неопределено, ВидОперацииДляСортировки, Тип, ПорядокОперацииВПределахДокумента);
					НоваяЗапись.ПорядокЗачета = ОперативныеВзаиморасчетыСервер.Порядок(ДатаПлатежа, Движения.НомерКорректировки, Неопределено, ВидОперацииДляСортировки, Тип);
					ЗаполнитьТипЗаписиВзаиморасчетов(НоваяЗапись, ТипРегистратора);
					
				КонецЦикла;
				КорректировкаОбъект.ОбменДанными.Загрузка = Истина;
				КорректировкаОбъект.Записать();
				Набор.ОбменДанными.Загрузка = Истина;
				Набор.Записать();
				
				ВсегоПеренесено = ВсегоПеренесено + 1;
				ЗафиксироватьТранзакцию();
			Исключение
				ОтменитьТранзакцию();
				ИмяСобытия = ИмяСобытияЖурналаРегистрацииПриВключенииОнлайнРасчетов() 
							+ НСтр("ru = 'Перенос Корректировки регистров.'", ОбщегоНазначения.КодОсновногоЯзыка());
				Шаблон = НСтр("ru = 'Не удалось перенести Корректировку регистров %1 от %2 по причине:
				|%3'");
				Текст = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(Шаблон, 
							НомерКорректировки, Формат(ДатаКорректировки, "ДФ='dd-MM-yyyy'"), ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
				ЗаписьЖурналаРегистрации(ИмяСобытия,УровеньЖурналаРегистрации.Ошибка,,, Текст);
			КонецПопытки;
		КонецЦикла;//по документам
	
	КонецЦикла;//по типам расчетов
	
	Шаблон = НСтр("ru = 'Перенесено корректировок регистров'")+": %1";
	ЗаписьЖурналаРегистрации(ИмяСобытияЖурналаРегистрацииПриВключенииОнлайнРасчетов(),
		УровеньЖурналаРегистрации.Информация,,,СтрШаблон(Шаблон, ВсегоПеренесено));
	
	
КонецПроцедуры

Функция ТекстЗапросаПереносаКорректировокРегистров()
	
	Возврат 
	"ВЫБРАТЬ
	|	ИСТИНА                                                              КАК ЭтоРасчетыСКлиентами,
	|	РасчетыСКлиентамиПоДокументам.АналитикаУчетаПоПартнерам             КАК АналитикаУчетаПоПартнерам,
	|	РасчетыСКлиентамиПоДокументам.ЗаказКлиента                          КАК ОбъектРасчетов,
	|	РасчетыСКлиентамиПоДокументам.ЗаказКлиента.ТипОбъектаРасчетов       КАК ТипОбъектаРасчетов,
	|	РасчетыСКлиентамиПоДокументам.Валюта                                КАК Валюта,
	|	РасчетыСКлиентамиПоДокументам.Регистратор                           КАК ДокументРегистратор,
	|	РасчетыСКлиентамиПоДокументам.Период                                КАК Период,
	|	РасчетыСКлиентамиПоДокументам.РасчетныйДокумент                     КАК РасчетныйДокумент,
	|	РасчетыСКлиентамиПоДокументам.ХозяйственнаяОперация                 КАК ХозяйственнаяОперация,
	|	РасчетыСКлиентамиПоДокументам.СтатьяДвиженияДенежныхСредств         КАК СтатьяДвиженияДенежныхСредств,
	|	ВЫБОР КОГДА ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход) 
	|			И (РасчетыСКлиентамиПоДокументам.Долг > 0
	|				ИЛИ РасчетыСКлиентамиПоДокументам.ДолгРегл > 0 ИЛИ РасчетыСКлиентамиПоДокументам.ДолгУпр > 0
	|				ИЛИ РасчетыСКлиентамиПоДокументам.Предоплата < 0 ИЛИ РасчетыСКлиентамиПоДокументам.ПредоплатаРегл < 0
	|				ИЛИ РасчетыСКлиентамиПоДокументам.ПредоплатаУпр < 0)
	|		ИЛИ ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход)
	|		И НЕ (РасчетыСКлиентамиПоДокументам.Предоплата > 0
	|				ИЛИ РасчетыСКлиентамиПоДокументам.ПредоплатаРегл > 0 ИЛИ РасчетыСКлиентамиПоДокументам.ПредоплатаУпр > 0
	|				ИЛИ РасчетыСКлиентамиПоДокументам.Долг < 0 ИЛИ РасчетыСКлиентамиПоДокументам.ДолгРегл < 0 
	|				ИЛИ РасчетыСКлиентамиПоДокументам.ДолгУпр < 0) ТОГДА
	|		ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход)
	|	ИНАЧЕ
	|		ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход)
	|	КОНЕЦ                                                               КАК ВидДвижения,
	|	ВЫБОР КОГДА РасчетыСКлиентамиПоДокументам.Регистратор ССЫЛКА Документ.КорректировкаРеализации 
	|		ТОГДА ВЫРАЗИТЬ(РасчетыСКлиентамиПоДокументам.Регистратор КАК Документ.КорректировкаРеализации).ДокументОснование
	|		ИНАЧЕ ВЫРАЗИТЬ(РасчетыСКлиентамиПоДокументам.РасчетныйДокумент КАК Документ.КорректировкаРеализации).ДокументОснование
	|	КОНЕЦ КАК СвязанныйДокумент,
	|
	|	ВЫБОР 
	|		КОГДА РасчетыСКлиентамиПоДокументам.Предоплата < 0
	|			ТОГДА -РасчетыСКлиентамиПоДокументам.Предоплата 
	|	ИНАЧЕ
	|		РасчетыСКлиентамиПоДокументам.Предоплата
	|	КОНЕЦ                                                               КАК Предоплата,
	|	ВЫБОР 
	|		КОГДА РасчетыСКлиентамиПоДокументам.ПредоплатаУпр < 0 
	|			ТОГДА -РасчетыСКлиентамиПоДокументам.ПредоплатаУпр 
	|	ИНАЧЕ
	|		РасчетыСКлиентамиПоДокументам.ПредоплатаУпр
	|	КОНЕЦ                                                               КАК ПредоплатаУпр,
	|	ВЫБОР 
	|		КОГДА РасчетыСКлиентамиПоДокументам.ПредоплатаРегл < 0
	|			ТОГДА -РасчетыСКлиентамиПоДокументам.ПредоплатаРегл
	|	ИНАЧЕ
	|		РасчетыСКлиентамиПоДокументам.ПредоплатаРегл
	|	КОНЕЦ                                                               КАК ПредоплатаРегл,
	|	ВЫБОР КОГДА РасчетыСКлиентамиПоДокументам.Долг < 0 ТОГДА
	|		-РасчетыСКлиентамиПоДокументам.Долг 
	|	ИНАЧЕ
	|		РасчетыСКлиентамиПоДокументам.Долг
	|	КОНЕЦ                                                               КАК Долг,
	|	ВЫБОР КОГДА РасчетыСКлиентамиПоДокументам.ДолгУпр < 0 ТОГДА
	|		-РасчетыСКлиентамиПоДокументам.ДолгУпр 
	|	ИНАЧЕ
	|		РасчетыСКлиентамиПоДокументам.ДолгУпр
	|	КОНЕЦ                                                               КАК ДолгУпр,
	|	ВЫБОР КОГДА РасчетыСКлиентамиПоДокументам.ДолгРегл < 0 ТОГДА
	|		-РасчетыСКлиентамиПоДокументам.ДолгРегл 
	|	ИНАЧЕ
	|		РасчетыСКлиентамиПоДокументам.ДолгРегл
	|	КОНЕЦ                                                               КАК ДолгРегл,
	|	РасчетыСКлиентамиПоДокументам.ДатаПлатежа                           КАК ДатаПлатежа,
	|	Корректировки.Дата                                                  КАК ДатаКорректировки,
	|	Корректировки.Номер                                                 КАК НомерКорректировки,
	|	ЕСТЬNULL(Реестр.ДатаДокументаИБ,Корректировки.Дата)                 КАК ДатаРасчетногоДокумента,
	|	ЕСТЬNULL(Реестр.НомерДокументаИБ,Корректировки.Номер)               КАК НомерРасчетногоДокумента
	|ИЗ
	|	РегистрНакопления.РасчетыСКлиентамиПоДокументам КАК РасчетыСКлиентамиПоДокументам
	|	ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.КорректировкаРегистров КАК Корректировки
	|	ПО РасчетыСКлиентамиПоДокументам.Регистратор = Корректировки.Ссылка
	|	ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.РеестрДокументов КАК Реестр
	|	ПО РасчетыСКлиентамиПоДокументам.РасчетныйДокумент = Реестр.Ссылка
	|	И НЕ Реестр.ДополнительнаяЗапись
	|ГДЕ
	|	(РасчетыСКлиентамиПоДокументам.Предоплата <> 0
	|		ИЛИ РасчетыСКлиентамиПоДокументам.ПредоплатаРегл <> 0
	|		ИЛИ РасчетыСКлиентамиПоДокументам.ПредоплатаУпр <> 0
	|		ИЛИ РасчетыСКлиентамиПоДокументам.Долг <> 0
	|		ИЛИ РасчетыСКлиентамиПоДокументам.ДолгРегл <> 0
	|		ИЛИ РасчетыСКлиентамиПоДокументам.ДолгУпр <> 0)
	|	И РасчетыСКлиентамиПоДокументам.Активность
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ЛОЖЬ                                                            КАК ЭтоРасчетыСКлиентами,
	|	РасчетыСПоставщикамиПоДокументам.АналитикаУчетаПоПартнерам      КАК АналитикаУчетаПоПартнерам,
	|	РасчетыСПоставщикамиПоДокументам.ЗаказПоставщику                КАК ОбъектРасчетов,
	|	РасчетыСПоставщикамиПоДокументам.ЗаказПоставщику.ТипОбъектаРасчетов КАК ТипОбъектаРасчетов,
	|	РасчетыСПоставщикамиПоДокументам.Валюта                         КАК Валюта,
	|	РасчетыСПоставщикамиПоДокументам.Регистратор                    КАК ДокументРегистратор,
	|	РасчетыСПоставщикамиПоДокументам.Период                         КАК Период,
	|	РасчетыСПоставщикамиПоДокументам.РасчетныйДокумент              КАК РасчетныйДокумент,
	|	РасчетыСПоставщикамиПоДокументам.ХозяйственнаяОперация          КАК ХозяйственнаяОперация,
	|	РасчетыСПоставщикамиПоДокументам.СтатьяДвиженияДенежныхСредств  КАК СтатьяДвиженияДенежныхСредств,
	|	ВЫБОР КОГДА ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход)
	|				И (РасчетыСПоставщикамиПоДокументам.Долг < 0
	|					ИЛИ РасчетыСПоставщикамиПоДокументам.ДолгРегл < 0 ИЛИ РасчетыСПоставщикамиПоДокументам.ДолгУпр < 0
	|					ИЛИ РасчетыСПоставщикамиПоДокументам.Предоплата > 0 
	|					ИЛИ РасчетыСПоставщикамиПоДокументам.ПредоплатаРегл > 0 ИЛИ РасчетыСПоставщикамиПоДокументам.ПредоплатаУпр > 0 )
	|		ИЛИ ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход) 
	|				И (РасчетыСПоставщикамиПоДокументам.Предоплата < 0
	|					ИЛИ РасчетыСПоставщикамиПоДокументам.ПредоплатаРегл < 0 ИЛИ РасчетыСПоставщикамиПоДокументам.ПредоплатаУпр < 0
	|					ИЛИ РасчетыСПоставщикамиПоДокументам.Долг > 0 ИЛИ РасчетыСПоставщикамиПоДокументам.ДолгРегл > 0 
	|					ИЛИ РасчетыСПоставщикамиПоДокументам.ДолгУпр > 0) ТОГДА
	|		ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход)
	|	ИНАЧЕ
	|		ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход)
	|	КОНЕЦ                                                           КАК ВидДвижения,
	|	ВЫБОР КОГДА РасчетыСПоставщикамиПоДокументам.Регистратор ССЫЛКА Документ.КорректировкаПриобретения 
	|		ТОГДА ВЫРАЗИТЬ(РасчетыСПоставщикамиПоДокументам.Регистратор КАК Документ.КорректировкаПриобретения).ДокументОснование
	|		ИНАЧЕ ВЫРАЗИТЬ(РасчетыСПоставщикамиПоДокументам.РасчетныйДокумент КАК Документ.КорректировкаПриобретения).ДокументОснование
	|	КОНЕЦ КАК СвязанныйДокумент,
	|
	|	ВЫБОР
	|		КОГДА РасчетыСПоставщикамиПоДокументам.Предоплата < 0  ТОГДА
	|			-РасчетыСПоставщикамиПоДокументам.Предоплата 
	|	ИНАЧЕ
	|		РасчетыСПоставщикамиПоДокументам.Предоплата
	|	КОНЕЦ                                                           КАК Предоплата,
	|	ВЫБОР 
	|		КОГДА РасчетыСПоставщикамиПоДокументам.ПредоплатаУпр < 0  ТОГДА
