				КонецЕсли;
				
				РасчетыДляПроверки = ТекущиеПеременные.ТаблицаРасчетовПоСрокам.Скопировать(Новый Структура("ЗаписьДоНачалаРасчета",Ложь));
				
				Запрос.УстановитьПараметр("ТаблицаПоСрокам", РасчетыДляПроверки);
				Запрос.УстановитьПараметр("МассивЗадействованныхРегистраторов",
					ТекущиеПеременные["МассивЗадействованныхРегистраторов"
						+ ?(ТекущиеПеременные.ТипРасчетов = Перечисления.ТипыРасчетовСПартнерами.РасчетыСКлиентом,"РасчетыСКлиентамиПоСрокам","РасчетыСПоставщикамиПоСрокам")]);
						
				Если ЗначениеЗаполнено(ТекущиеПеременные.ПериодКонтроляИзмененийИСозданияЗаданий) Тогда
					Запрос.УстановитьПараметр("ПериодКонтроляИзмененийИСозданияЗаданий", ТекущиеПеременные.ПериодКонтроляИзмененийИСозданияЗаданий);
				Иначе
					Запрос.УстановитьПараметр("ПериодКонтроляИзмененийИСозданияЗаданий", ТекущиеПеременные.ДатаНачалаПересчета);
				КонецЕсли;
				
				Запрос.Выполнить();
				
				Если ПланыОбмена.ГлавныйУзел() = Неопределено Тогда
					РегистрыСведений.ЗаданияКРаспределениюВзаиморасчетов.СоздатьЗаданияНеоперативнойОчередиПриИзмененииРасчетовПоСрокам(
						Запрос.МенеджерВременныхТаблиц, ТекущиеПеременные.ТипРасчетов = Перечисления.ТипыРасчетовСПартнерами.РасчетыСКлиентом);
				КонецЕсли;
				
				Если ТекущиеПеременные.ЭтоРасчетыСКлиентами Тогда
					
					ТекстАктуализацииОтражения =
