#Область СлужебныйПрограммныйИнтерфейс

// Возвращает группу настроек сканирования по имени параметра.
// 
// Параметры:
// 	НастройкиСканирования - см. ОбщегоНазначенияИСМПВызовСервера.НастройкиСканированияКодовМаркировки
// 	ИмяПараметра          - Строка - Идентификатор параметра.
// Возвращаемое значение:
// 	см. НоваяГруппаПараметровНастройки
Функция ЗначениеГруппыНастроек(НастройкиСканирования, ИмяПараметра) Экспорт
	
	ВозвращаемоеЗначение = НоваяГруппаПараметровНастройки();
	ТекущееЗначение      = НастройкиСканирования[ИмяПараметра];
	
	Если ТекущееЗначение <> Неопределено Тогда
		
		ЗаполнитьЗначенияСвойств(ВозвращаемоеЗначение, ТекущееЗначение);
		
		ПараметрыКонтроля = НастройкаПараметровСканированияСлужебныйКлиентСерверПовтИсп.ПараметрыКонтроля();
		
		Если ИмяПараметра <> ПараметрыКонтроля.ПараметрыИгнорированияПроверкиККТ
			И ИмяПараметра <> ПараметрыКонтроля.ПараметрыКонтроляВладельцев Тогда
			ИсключитьДействующиеТоварныеГруппыОбязательногоРозничногоКонтроля(ВозвращаемоеЗначение);
		КонецЕсли;
		
	КонецЕсли;
	
	НастройкиСканирования[ИмяПараметра] = ВозвращаемоеЗначение;
	
	Возврат ВозвращаемоеЗначение;
	
КонецФункции

// Группа настроек параметра сканирования.
// 
// Параметры:
// 	РежимИсключения - Булево - Признак работы в режиме исключения.
// Возвращаемое значение:
// 	Структура - Описание:
// * Исключения         - Соответствие - Исключения по виду продукции и операциям
// * Включено           - Булево       - Признак включения настройки.
// * РежимИсключения    - Булево       - Признак работы в режиме исключения.
// * ВариантОтображения - Строка       - Вариант отображения в форме настройки.
Функция НоваяГруппаПараметровНастройки(РежимИсключения = Истина) Экспорт
	
	ВозвращаемоеЗначение = Новый Структура();
	ВозвращаемоеЗначение.Вставить("Включено",           Ложь);
	ВозвращаемоеЗначение.Вставить("РежимИсключения",    РежимИсключения);
	ВозвращаемоеЗначение.Вставить("ВариантОтображения", "ПоТоварнымГруппам");
	ВозвращаемоеЗначение.Вставить("Исключения",         Новый Соответствие());
	
	Возврат ВозвращаемоеЗначение;
	
КонецФункции

// Определяет необходимость контроля статусов кодов маркировки для вида операции по видам продукции.
// 
// Параметры:
//  ВидыПродукции - Массив Из СправочникСсылка.ВидыПродукцииИС, Неопределено - Вид продукции.
//  ВидОперации - Массив Из ПеречислениеСсылка.ВидыОперацийИСМП, ПеречислениеСсылка.ВидыОперацийИСМП, Неопределено - Вид операции.
//  ТребуетсяПроверкаСредствамиККТ - Булево - в зависимости от флага проверяется контроль статусов с учетом или
//   без учета разрешительного режима. Если Ложь, то проверяются исключения, если Истина - контроль всегда.
// 
// Возвращаемое значение:
//  Булево - Контролировать статусы кодов маркировки (хотя бы по одному из видов продукции).
Функция КонтролироватьСтатусыКодовМаркировки(ВидыПродукции = Неопределено, ВидОперации = Неопределено, ТребуетсяПроверкаСредствамиККТ = Истина) Экспорт
	
	Если ТипЗнч(ВидОперации) = Тип("Массив") Тогда
		ОперацииКонтроля = ВидОперации;
	ИначеЕсли ЗначениеЗаполнено(ВидОперации) Тогда
		ОперацииКонтроля = ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(ВидОперации);
	Иначе
		ПараметрыКонтроля = НастройкаПараметровСканированияСлужебныйКлиентСерверПовтИсп.ПараметрыКонтроля();
		ДопустимыеВидыОпераций = НастройкаПараметровСканированияСлужебныйКлиентСерверПовтИсп.ДопустимыеВидыОпераций();
		ОперацииКонтроля = ДопустимыеВидыОпераций[ПараметрыКонтроля.ПараметрыКонтроляСтатусов];
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ВидыПродукции) Тогда
		ВидыПродукцииКонтроля = ВидыПродукции;
	Иначе
		ВидыПродукцииКонтроля = ОбщегоНазначенияИСМПКлиентСерверПовтИсп.УчитываемыеВидыМаркируемойПродукции();
	КонецЕсли;
	
	Для Каждого ОперацияКонтроля Из ОперацииКонтроля Цикл
		Для Каждого ВидПродукции Из ВидыПродукцииКонтроля Цикл
			Если НастройкаПараметровСканированияСлужебныйКлиентСерверПовтИсп.КонтролироватьСтатусыКодовМаркировки(
				ВидПродукции,
				ОперацияКонтроля,
				ТребуетсяПроверкаСредствамиККТ) Тогда
				Возврат Истина;
			КонецЕсли;
		КонецЦикла;
	КонецЦикла;
	
	Возврат Ложь;

КонецФункции

// Определяет необходимость контроля владельцев кодов маркировки для вида операции по видам продукции.
// 
// Параметры:
//  ВидыПродукции - Массив Из СправочникСсылка.ВидыПродукцииИС, Неопределено  - Вид продукции.
//  ВидОперации - Массив Из ПеречислениеСсылка.ВидыОперацийИСМП, ПеречислениеСсылка.ВидыОперацийИСМП, Неопределено - Вид операции.
// 
// Возвращаемое значение:
//  Булево - Контролировать владельцев кодов маркировки (хотя бы по одному из видов продукции).
Функция КонтролироватьВладельцевКодовМаркировки(ВидыПродукции = Неопределено, ВидОперации = Неопределено) Экспорт
	
	Если ТипЗнч(ВидОперации) = Тип("Массив") Тогда
		ОперацииКонтроля = ВидОперации;
	ИначеЕсли ЗначениеЗаполнено(ВидОперации) Тогда
		ОперацииКонтроля = ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(ВидОперации);
	Иначе
		ПараметрыКонтроля = НастройкаПараметровСканированияСлужебныйКлиентСерверПовтИсп.ПараметрыКонтроля();
		ДопустимыеВидыОпераций = НастройкаПараметровСканированияСлужебныйКлиентСерверПовтИсп.ДопустимыеВидыОпераций();
		ОперацииКонтроля = ДопустимыеВидыОпераций[ПараметрыКонтроля.ПараметрыКонтроляВладельцев];
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ВидыПродукции) Тогда
		ВидыПродукцииКонтроля = ВидыПродукции;
	Иначе
		ВидыПродукцииКонтроля = ОбщегоНазначенияИСМПКлиентСерверПовтИсп.УчитываемыеВидыМаркируемойПродукции();
	КонецЕсли;
	
	Для Каждого ОперацияКонтроля Из ОперацииКонтроля Цикл
		Для Каждого ВидПродукции Из ВидыПродукцииКонтроля Цикл
			Если НастройкаПараметровСканированияСлужебныйКлиентСерверПовтИсп.КонтролироватьВладельцевКодовМаркировки(
				ВидПродукции, ОперацияКонтроля) Тогда
				Возврат Истина;
			КонецЕсли;
		КонецЦикла;
	КонецЦикла;
	
	Возврат Ложь;

КонецФункции

// Определяет необходимость игнорирования результатов проверки кодов маркировки средствами ККТ для вида опреации по товарной группе.
// 
// Параметры:
//  ВидыПродукции - Массив Из СправочникСсылка.ВидыПродукцииИС, Неопределено - Виды продукции
//  ВидОперации  - ПеречислениеСсылка.ВидыОперацийИСМП, Неопределено - Вид операции
// 
// Возвращаемое значение:
//  Булево - Контролировать коды маркировки средствами ККТ.
Функция ИгнорироватьРезультатыПроверкиСредствамиККТ(ВидыПродукции = Неопределено, ВидОперации = Неопределено) Экспорт
	
	Если ЗначениеЗаполнено(ВидОперации) Тогда
		ОперацииКонтроля = Новый Массив();
		ОперацииКонтроля.Добавить(ВидОперации);
	Иначе
		ПараметрыКонтроля = НастройкаПараметровСканированияСлужебныйКлиентСерверПовтИсп.ПараметрыКонтроля();
		ДопустимыеВидыОпераций = НастройкаПараметровСканированияСлужебныйКлиентСерверПовтИсп.ДопустимыеВидыОпераций();
		ОперацииКонтроля = ДопустимыеВидыОпераций[ПараметрыКонтроля.ПараметрыИгнорированияПроверкиККТ];
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ВидыПродукции) Тогда
		ВидыПродукцииКонтроля = ВидыПродукции;
	Иначе
		ВидыПродукцииКонтроля = ОбщегоНазначенияИСМПКлиентСерверПовтИсп.УчитываемыеВидыМаркируемойПродукции();
	КонецЕсли;
	
	Для Каждого ОперацияКонтроля Из ОперацииКонтроля Цикл
		Для Каждого ВидПродукции Из ВидыПродукцииКонтроля Цикл
			Если Не НастройкаПараметровСканированияСлужебныйКлиентСерверПовтИсп.КонтролироватьКодыМаркировкиСредствамиККТ(
				ВидПродукции, ОперацияКонтроля) Тогда
				Возврат Истина;
			КонецЕсли;
		КонецЦикла;
	КонецЦикла;
	
	Возврат Ложь;
	
КонецФункции

// Конвертировать имя элемента элемент конструктора.
// 
// Параметры:
//  Значение - Строка, СправочникСсылка.ЭлементыКонструктораВидовПродукцииИС -
// 
// Возвращаемое значение:
//  СправочникСсылка.ЭлементыКонструктораВидовПродукцииИС, Строка, Неопределено - Конвертировать имя элемента элемент конструктора
Функция КонвертироватьИмяЭлементаЭлементКонструктора(Значение) Экспорт
	
	Результат = Неопределено;
	
	Если ТипЗнч(Значение) = Тип("Строка") Тогда
		Если Значение = "ПараметрыКонтроляСтатусовНастройка" Тогда
			Результат = ПредопределенноеЗначение(
				"Справочник.ЭлементыКонструктораВидовПродукцииИС.КонтролироватьСтатусыКодовМаркировки");
		ИначеЕсли Значение = "ПараметрыКонтроляВладельцевНастройка" Тогда
			Результат = ПредопределенноеЗначение(
				"Справочник.ЭлементыКонструктораВидовПродукцииИС.КонтролироватьВладельцевКодовМаркировки");
		ИначеЕсли Значение = "ПараметрыИгнорированияПроверкиККТНастройка" Тогда
			Результат = ПредопределенноеЗначение(
				"Справочник.ЭлементыКонструктораВидовПродукцииИС.ИгнорироватьРезультатыПроверкиКодовМаркировкиНаККТ");
		КонецЕсли;
	Иначе
		Если Значение = ПредопределенноеЗначение("Справочник.ЭлементыКонструктораВидовПродукцииИС.КонтролироватьСтатусыКодовМаркировки") Тогда
			Результат = "ПараметрыКонтроляСтатусовНастройка";
		ИначеЕсли Значение = ПредопределенноеЗначение("Справочник.ЭлементыКонструктораВидовПродукцииИС.КонтролироватьВладельцевКодовМаркировки") Тогда
			Результат = "ПараметрыКонтроляВладельцевНастройка";
		ИначеЕсли Значение = ПредопределенноеЗначение("Справочник.ЭлементыКонструктораВидовПродукцииИС.ИгнорироватьРезультатыПроверкиКодовМаркировкиНаККТ") Тогда
			Результат = "ПараметрыИгнорированияПроверкиККТНастройка";
		КонецЕсли;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция ОперацииИсключеныИзКонтроляСтатусовИВладельцев(ВидыОпераций, ВидПродукции = Неопределено) Экспорт

	ВсеНастройкиОтключены = Истина;

	Если ЗначениеЗаполнено(ВидПродукции) Тогда
		ВидыПродукции = Новый Массив();
		ВидыПродукции.Добавить(ВидПродукции);
	Иначе
		ВидыПродукции = ОбщегоНазначенияИСМПКлиентСерверПовтИсп.УчитываемыеВидыМаркируемойПродукции();
	КонецЕсли;

	Для Каждого ВидПродукции Из ВидыПродукции Цикл

		Для Каждого Операция Из ВидыОпераций Цикл

			ВедетсяКонтрольСтатусов = НастройкаПараметровСканированияСлужебныйКлиентСерверПовтИсп.КонтролироватьСтатусыКодовМаркировки(
				ВидПродукции,
				Операция,
				Ложь);

			ВедетсяКонтрольВладельцев = НастройкаПараметровСканированияСлужебныйКлиентСерверПовтИсп.КонтролироватьВладельцевКодовМаркировки(
				ВидПродукции,
				Операция);

			Если ВедетсяКонтрольСтатусов
				Или ВедетсяКонтрольВладельцев Тогда
				ВсеНастройкиОтключены = Ложь;
				Прервать;
			КонецЕсли;

		КонецЦикла;

		Если Не ВсеНастройкиОтключены Тогда
			Прервать;
		КонецЕсли;

	КонецЦикла;

	Возврат ВсеНастройкиОтключены;

КонецФункции

Процедура ИсключитьДействующиеТоварныеГруппыОбязательногоРозничногоКонтроля(ГруппаПараметровНастройки)
	
	ДействующиеТоварныеГруппыОбязательногоРозничногоКонтроля = КонструкторИСМПОбщегоНазначенияКлиентСервер.ВидыПродукцииОбязательнойОнлайнПроверкиПередРозничнойПродажейНаДату();
	ОперацияРозничнаяПродажа                                 = ПредопределенноеЗначение("Перечисление.ВидыОперацийИСМП.ВыводИзОборотаРозничнаяПродажа");
	
	Если ГруппаПараметровНастройки.РежимИсключения Тогда
		
		Если ГруппаПараметровНастройки.Исключения.Получить(ОперацияРозничнаяПродажа) <> Неопределено Тогда
			
			ТоварныеГруппыПоРозничнойПродаже = ГруппаПараметровНастройки.Исключения.Получить(ОперацияРозничнаяПродажа);
			МассивТоварныхГруппДляУдаления   = Новый Массив;
			
			Для Каждого ТоварнаяГруппа Из ДействующиеТоварныеГруппыОбязательногоРозничногоКонтроля Цикл
				
				Если ТоварныеГруппыПоРозничнойПродаже.Получить(ТоварнаяГруппа) <> Неопределено Тогда
					МассивТоварныхГруппДляУдаления.Добавить(ТоварнаяГруппа);
				КонецЕсли;
				
			КонецЦикла;
			
			Для Каждого ТоварнаяГруппаДляУдаления Из МассивТоварныхГруппДляУдаления Цикл
				ТоварныеГруппыПоРозничнойПродаже.Удалить(ТоварнаяГруппаДляУдаления);
			КонецЦикла;
			
			Если ТоварныеГруппыПоРозничнойПродаже.Количество() = 0 И МассивТоварныхГруппДляУдаления.Количество() Тогда
				ГруппаПараметровНастройки.Исключения.Удалить(ОперацияРозничнаяПродажа);
			КонецЕсли;
			
		КонецЕсли;
		
		МассивТоварныхГруппДляУдаления   = Новый Массив;
		
		Для Каждого ТоварнаяГруппа Из ДействующиеТоварныеГруппыОбязательногоРозничногоКонтроля Цикл
			
			Если ГруппаПараметровНастройки.Исключения.Получить(ТоварнаяГруппа) <> Неопределено Тогда
				
				ОперацииПоТоварнымГруппамОбязательногоКонтроля = ГруппаПараметровНастройки.Исключения.Получить(ТоварнаяГруппа);
				
				Если ОперацииПоТоварнымГруппамОбязательногоКонтроля.Получить(ОперацияРозничнаяПродажа) <> Неопределено Тогда
					МассивТоварныхГруппДляУдаления.Добавить(ТоварнаяГруппа);
				КонецЕсли;
				
			КонецЕсли;
			
		КонецЦикла;
		
		Для Каждого ТоварнаяГруппаДляУдаления Из МассивТоварныхГруппДляУдаления Цикл
			
			ОперацииПоТоварнымГруппамОбязательногоКонтроля = ГруппаПараметровНастройки.Исключения.Получить(ТоварнаяГруппаДляУдаления);
			ОперацииПоТоварнымГруппамОбязательногоКонтроля.Удалить(ОперацияРозничнаяПродажа);
			
			Если ОперацииПоТоварнымГруппамОбязательногоКонтроля.Количество() = 0 Тогда
				ГруппаПараметровНастройки.Исключения.Удалить(ТоварнаяГруппаДляУдаления);
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти