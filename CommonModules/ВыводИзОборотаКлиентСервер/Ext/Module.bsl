#Область ПрограммныйИнтерфейс

// Проверяет, доступно ли поле "ОСУ" для указанного вида продукции
//
// Параметры:
//  ВидПродукцииТоварнаяГруппа - СправочникСсылка.КлючиВидовПродукцииИС,
//                               СправочникСсылка.ВидыПродукцииИС,
//                               Массив из СправочникСсылка.ВидыПродукцииИС - Виды продукции,
//                               СправочникСсылка.ТоварныеГруппыГИСМТ - Товарная группа
//
// Возвращаемое значение:
//  Булево - Истина, если поле ОСУ доступно
Функция ДоступноПолеОСУ(ВидПродукцииТоварнаяГруппа) Экспорт
	
	#Если Сервер Или ВнешнееСоединение Или МобильноеПриложениеСервер Или МобильныйАвтономныйСервер Тогда
		Дата = ТекущаяДатаСеанса();
	#Иначе
		Дата = ОбщегоНазначенияКлиент.ДатаСеанса();
	#КонецЕсли
	
	ДоступноПолеОСУ = КонструкторИСОбщегоНазначенияКлиентСервер.ЗначенияЭлементаКонструктораПоВидуПродукции(
		ПредопределенноеЗначение(
			"Справочник.ЭлементыКонструктораВидовПродукцииИС.ПолеОСУ"),
		КонструкторИСМПОбщегоНазначенияКлиентСервер.ВидыПродукции(ВидПродукцииТоварнаяГруппа));
	
	ДатаНачалаОформленияОСУ = КонструкторИСМПОбщегоНазначенияКлиентСервер.ДатаНачалаОформленияУПДОСУ(ВидПродукцииТоварнаяГруппа);
	Если ДатаНачалаОформленияОСУ = Неопределено Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Возврат ДоступноПолеОСУ И ДатаНачалаОформленияОСУ <= Дата;
	
КонецФункции

// Проверяет, доступно ли уведомление об отгрузке на экспорт для указанного вида продукции и причины
//
// Параметры:
//  ВидПродукцииТоварнаяГруппа - СправочникСсылка.КлючиВидовПродукцииИС,
//                               СправочникСсылка.ВидыПродукцииИС,
//                               Массив из СправочникСсылка.ВидыПродукцииИС - Виды продукции,
//                               СправочникСсылка.ТоварныеГруппыГИСМТ - Товарная группа
//  Причина - ПеречислениеСсылка - причина вывода из оборота
//
// Возвращаемое значение:
//  Булево - Истина, если уведомление доступно
Функция ДоступноУведомлениеОбОтгрузкеНаЭкспорт(ВидПродукцииТоварнаяГруппа, Причина) Экспорт
	
	Возврат КонструкторИСМПОбщегоНазначенияКлиентСервер.ЭлементКонструктораСодержитЗначение(
		ПредопределенноеЗначение(
			"Справочник.ЭлементыКонструктораВидовПродукцииИС.УведомлениеОбОтгрузкеНаЭкспорт"),
		ВидПродукцииТоварнаяГруппа,
		Причина);
	
КонецФункции

#КонецОбласти

#Область СлужебныйПрограммныйИнтерфейс

#Область ЭлементыКонструктораВидовПродукции

Функция ДоступныеПричиныВыводаИзОборота(ЭтоОбъемноСортовойУчет, ВидыПродукцииПоТоварнойГруппе) Экспорт
	
	Если ЭтоОбъемноСортовойУчет Тогда
		ЭлементКонструктора = ПредопределенноеЗначение(
			"Справочник.ЭлементыКонструктораВидовПродукцииИС.ПричиныВыводаИзОборотаОСУ");
	Иначе
		ЭлементКонструктора = ПредопределенноеЗначение(
			"Справочник.ЭлементыКонструктораВидовПродукцииИС.ПричиныВыводаИзОборотаПоштучно");
	КонецЕсли;
	
	Возврат КонструкторИСОбщегоНазначенияКлиентСервер.ЗначенияЭлементаКонструктораПоВидуПродукции(
		ЭлементКонструктора,
		ВидыПродукцииПоТоварнойГруппе);
	
КонецФункции

