#Область ПрограммныйИнтерфейс

// Отмечает выделенные элементы в списке как дубли и предлагает открыть рабочее место для подтверждения.
//
// Параметры:
//   Список - ТаблицаФормы - динамический список, содержащий элементы для пометки дублями.
//
Процедура ОтметитьДублямиВыделенные(Список) Экспорт
	
	Ссылки = Новый Массив;
	
	Для Каждого ВыделеннаяСтрока Из Список.ВыделенныеСтроки Цикл
		Если ТипЗнч(ВыделеннаяСтрока) = Тип("СтрокаГруппировкиДинамическогоСписка") Тогда
			Продолжить;
		КонецЕсли;
		
		ТекущаяСтрока = Список.ДанныеСтроки(ВыделеннаяСтрока);
		Если ТекущаяСтрока <> Неопределено И ЗначениеЗаполнено(ТекущаяСтрока.Ссылка) Тогда
			Ссылки.Добавить(ТекущаяСтрока.Ссылка);
		КонецЕсли;
	КонецЦикла;
	
	Если Ссылки.Количество() < 2 Тогда
		ОбщегоНазначенияКлиент.СообщитьПользователю((НСтр("ru = 'Для отметки дублей необходимо выделить минимум два элемента.'")));
		Возврат;
	КонецЕсли;
	
	ДобавитьДубли(Ссылки);
	
	Оповестить("ОбновитьРабочееМестоУдалениеДублейНСИ", ТипЗнч(Ссылки[0]));
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Процедура ПослеПодтвержденияОткрытьРабочееМесто(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = КодВозвратаДиалога.Да Тогда
		ИдентификаторГруппы = ПоискИЗаменаДублейНСИВызовСервера.ГруппаДубля(ДополнительныеПараметры.Дубль);
		
		ПараметрыОткрытия = Новый Структура;
		ПараметрыОткрытия.Вставить("ТипСсылки", ДополнительныеПараметры.ТипСсылки);
		ПараметрыОткрытия.Вставить("ИдентификаторГруппы", ИдентификаторГруппы);
		
		ОткрытьФорму("Обработка.ДублиНСИ.Форма.СравнениеИПодтверждениеДублей", ПараметрыОткрытия);
	КонецЕсли;
	
КонецПроцедуры

Процедура ДобавитьДубли(Ссылки)
	
	ПоискИЗаменаДублейНСИВызовСервера.ДобавитьДубли(Ссылки);
	
	ДоступнаИнтерактивнаяПометка = ПоискИЗаменаДублейНСИВызовСервера.ДоступнаИнтерактивнаяПометка(Ссылки[0]);
	
	Если ДоступнаИнтерактивнаяПометка Тогда
		ДополнительныеПараметры = Новый Структура;
		ДополнительныеПараметры.Вставить("ТипСсылки", ТипЗнч(Ссылки[0]));
		ДополнительныеПараметры.Вставить("Дубль", Ссылки[0]);
		
		Оповещение = Новый ОписаниеОповещения("ПослеПодтвержденияОткрытьРабочееМесто", ЭтотОбъект, ДополнительныеПараметры);
		ТекстВопроса = НСтр("ru = 'Выбранные элементы были отмечены как дубли. Открыть рабочее место для подтверждения дублей?'");
		
		ПоказатьВопрос(Оповещение, ТекстВопроса, РежимДиалогаВопрос.ДаНет);
	Иначе
		ПоказатьОповещениеПользователя(НСтр("ru = 'Элементы отмечены как дубли.'"));
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти