// Возвращает структуру свойств стратегии размещения.
//
// Возвращаемое значение:
//   Структура:
//    * placement - Структура - Параметры размещения:
//       ** position - Строка    - Способ размещения картинок штампов на странице документа.
//       ** pages    - Структура - Параметры расположения картинок штампов на страницах документа:
//            *** rule       - Строка - Способ расположения картинок штампов на страницах документа.
//            *** pageNumber - Число  - Номер страницы документа для расположения картинок штампов.
//    * strategy - Структура - Стратегия размещения:
//      ** route           - Строка - Направление при последовательной установке картинок штампов.
//      ** horizontalVisit - Строка - Смещение по горизонтали.
//
Функция НоваяСтруктураСвойствСтратегииРазмещения()
	
	СтруктураРазмещениеНаСтраницах = Новый Структура;
	
	СтруктураРазмещениеНаСтраницах.Вставить("rule"  , "");
	СтруктураРазмещениеНаСтраницах.Вставить("number", 0);
	
	СтруктураРасположение = Новый Структура;
	
	СтруктураРасположение.Вставить("position", "");
	СтруктураРасположение.Вставить("pages"   , СтруктураРазмещениеНаСтраницах);
	
	СтруктураСтратегия = Новый Структура;
	
	СтруктураСтратегия.Вставить("route"          , "");
	СтруктураСтратегия.Вставить("horizontalVisit", "");
	
	СтруктураСтратегииРазмещения = Новый Структура;
	СтруктураСтратегииРазмещения.Вставить("placement", СтруктураРасположение);
	СтруктураСтратегииРазмещения.Вставить("strategy" , СтруктураСтратегия);
	
	Возврат СтруктураСтратегииРазмещения;
	
КонецФункции

