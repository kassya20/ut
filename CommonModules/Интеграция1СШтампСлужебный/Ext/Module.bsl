Процедура ПреобразоватьPDFДокумент(Знач ТипФайлаPDF, ДвоичныеДанные)
	
	ПотокДанныхФайла = Новый ПотокВПамяти;
	
	Попытка
	
		ДокументPDF = Новый ДокументPDF;
		
		ДокументPDF.Прочитать(ДвоичныеДанные.ОткрытьПотокДляЧтения());
		ДокументPDF.Записать(ПотокДанныхФайла, , ТипФайлаPDF);
		
	Исключение
		ИнформацияОбОшибке = ИнформацияОбОшибке();
		ПодробныйТекстОшибки = ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке);
		ЗаписьЖурналаРегистрации(
			НСтр("ru = 'Преобразование PDF документа в 1С:Штамп.'", ОбщегоНазначения.КодОсновногоЯзыка()),
			УровеньЖурналаРегистрации.Ошибка,,, ПодробныйТекстОшибки);
		ВызватьИсключение;
	КонецПопытки;
	
	ДвоичныеДанные = ПотокДанныхФайла.ЗакрытьИПолучитьДвоичныеДанные();
	
