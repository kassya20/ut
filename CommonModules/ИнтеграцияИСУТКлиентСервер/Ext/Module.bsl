Функция ЭтоРозничныйДокумент(Контекст) Экспорт
	
	Если ТипЗнч(Контекст) = Тип("ФормаКлиентскогоПриложения") Тогда
		Контрагент = Контекст.Объект.Контрагент;
		Возврат РозничныеПродажиВызовСервера.КонтрагентЭтоФизическоеЛицо(Контрагент);
	ИначеЕсли ТипЗнч(Контекст) = Тип("Структура") Тогда
		Контрагент = Контекст.Контрагент;
		Возврат РозничныеПродажиВызовСервера.КонтрагентЭтоФизическоеЛицо(Контрагент);
	Иначе
		Возврат ИнтеграцияИСВызовСервераУТ.КонтрагентЭтоФизическоеЛицоВДокументе(Контекст);
	КонецЕсли;
	
КонецФункции

Функция ЭтоОрдерНаВнутреннееПеремещениеТоваров(Контекст) Экспорт
	
	ЭтоОрдерНаВнутреннееПеремещение = Ложь;
	
	Если ТипЗнч(Контекст) = Тип("ФормаКлиентскогоПриложения") Тогда
		
		СтруктураПроверки = Новый Структура("Распоряжение, СкладскаяОперация");
		ЗаполнитьЗначенияСвойств(СтруктураПроверки, Контекст.Объект);
		
		Если СтруктураПроверки.СкладскаяОперация <> Неопределено Тогда
			ЭтоОрдерНаВнутреннееПеремещение = (СтруктураПроверки.СкладскаяОперация = ПредопределенноеЗначение("Перечисление.СкладскиеОперации.ОтгрузкаПоПеремещению"));
		ИначеЕсли СтруктураПроверки.Распоряжение <> Неопределено Тогда
			ЭтоОрдерНаВнутреннееПеремещение = ИнтеграцияИСВызовСервераУТ.ЭтоРаспоряжениеОрдераНаВнутреннееПеремещение(СтруктураПроверки.Распоряжение);
		КонецЕсли;
		
	ИначеЕсли ТипЗнч(Контекст) = Тип("Структура") Тогда
		
		СтруктураПроверки = Новый Структура("Распоряжение, СкладскаяОперация");
		ЗаполнитьЗначенияСвойств(СтруктураПроверки, Контекст);
		
		Если СтруктураПроверки.СкладскаяОперация <> Неопределено Тогда
			ЭтоОрдерНаВнутреннееПеремещение = (СтруктураПроверки.СкладскаяОперация = ПредопределенноеЗначение("Перечисление.СкладскиеОперации.ОтгрузкаПоПеремещению"));
		ИначеЕсли СтруктураПроверки.Распоряжение <> Неопределено Тогда
			ЭтоОрдерНаВнутреннееПеремещение = ИнтеграцияИСВызовСервераУТ.ЭтоРаспоряжениеОрдераНаВнутреннееПеремещение(СтруктураПроверки.Распоряжение);
		КонецЕсли;
		
	Иначе
		
		Если ТипЗнч(Контекст) = Тип("ДокументСсылка.ОтборРазмещениеТоваров") Тогда
			ЭтоОрдерНаВнутреннееПеремещение = ИнтеграцияИСВызовСервераУТ.ЭтоРаспоряжениеОрдераНаВнутреннееПеремещение(Контекст);
		ИначеЕсли ТипЗнч(Контекст) = Тип("ДокументСсылка.РасходныйОрдерНаТовары")
			Или ТипЗнч(Контекст) = Тип("ДокументСсылка.ПриходныйОрдерНаТовары") Тогда
			ЭтоОрдерНаВнутреннееПеремещение = ИнтеграцияИСВызовСервераУТ.ЭтоРаспоряжениеОрдераНаВнутреннееПеремещение(Контекст);
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат ЭтоОрдерНаВнутреннееПеремещение;
	
КонецФункции

