		|		КОГДА Статьи.ВариантРаспределенияРасходовНУ = ЗНАЧЕНИЕ(Перечисление.ВариантыРаспределенияРасходов.НаРасходыТекущегоПериода)
		|			ТОГДА 0
		|		ИНАЧЕ Т.СуммаРегл - Т.ПостояннаяРазница - Т.ВременнаяРазница КОНЕЦ) <> 0
		|	ИЛИ СУММА(ВЫБОР
		|		КОГДА Статьи.ВариантРаспределенияРасходовУпр = ЗНАЧЕНИЕ(Перечисление.ВариантыРаспределенияРасходов.НаРасходыТекущегоПериода)
		|			ТОГДА 0
		|		ИНАЧЕ Т.СуммаУпр КОНЕЦ) <> 0
		|	ИЛИ СУММА(ВЫБОР
		|		КОГДА Статьи.ВариантРаспределенияРасходовНУ = ЗНАЧЕНИЕ(Перечисление.ВариантыРаспределенияРасходов.НаРасходыТекущегоПериода)
		|			ТОГДА 0
		|		ИНАЧЕ Т.СуммаНДД КОНЕЦ) <> 0
		|";
	#КонецОбласти
	
	#Область РаспределениеРасходовБудущихПериодов_8
	ТекстЗапроса = ТекстЗапроса + "
		|ОБЪЕДИНИТЬ ВСЕ
		|
		// Распределение расходов будущих периодов.
		|ВЫБРАТЬ
		|	""8"" КАК ЗапросИсточник,
		|	ЛОЖЬ КАК ЭтоТекущийПериод,
		|	ЛОЖЬ КАК ЕстьКорЧасть,
		|	НЕОПРЕДЕЛЕНО КАК Регистратор,
		|	(ВЫБОР
		|		КОГДА Т.Период > &НачалоПериода ТОГДА Т.Период
		|		ИНАЧЕ &НачалоПериода КОНЕЦ) КАК Период,
		|	Т.ПериодМесяц КАК ПериодРаспределения,
		// Измерения
		|	Т.Организация КАК Организация,
		|	Т.Подразделение КАК Подразделение,
		|	Т.НаправлениеДеятельности КАК НаправлениеДеятельности,
		|	Т.СтатьяРасходов КАК СтатьяРасходов,
		|	Т.АналитикаРасходов КАК АналитикаРасходов,
		|	НЕОПРЕДЕЛЕНО КАК Партия,
		// Кор реквизиты отклонений
		|	Т.Организация КАК КорОрганизация,
		|	ЗНАЧЕНИЕ(Справочник.Номенклатура.ПустаяСсылка) КАК КорНоменклатура,
		|	ЗНАЧЕНИЕ(Справочник.ХарактеристикиНоменклатуры.ПустаяСсылка) КАК КорХарактеристика,
		|	ЗНАЧЕНИЕ(Справочник.ВидыЗапасов.ПустаяСсылка) КАК КорВидЗапасов,
		|	Т.КорНаправлениеДеятельности КАК КорНаправлениеДеятельности,
		|	Т.КорПодразделение КАК КорПодразделение,
		|	НЕОПРЕДЕЛЕНО КАК КорМестоХранения,
		// Кор реквизиты себестоимости
		|	ЗНАЧЕНИЕ(Перечисление.РазделыУчетаСебестоимостиТоваров.ПустаяСсылка) КАК КорРазделУчета,
		|	ЗНАЧЕНИЕ(Справочник.КлючиАналитикиУчетаНоменклатуры.ПустаяСсылка) КАК КорАналитикаУчетаНоменклатуры,
		|	НЕОПРЕДЕЛЕНО КАК КорПартия,
		|	ЗНАЧЕНИЕ(Справочник.КлючиАналитикиУчетаПартий.ПустаяСсылка) КАК КорАналитикаУчетаПартий,
		|	НЕОПРЕДЕЛЕНО КАК КорАналитикаФинансовогоУчета,
		|	ЗНАЧЕНИЕ(Перечисление.ТипыНалогообложенияНДС.ПустаяСсылка) КАК КорВидДеятельностиНДС,
		|
		|	ЗНАЧЕНИЕ(Справочник.КлючиАналитикиУчетаПоПартнерам.ПустаяСсылка) КАК АналитикаУчетаПоПартнерам,
		|	НЕОПРЕДЕЛЕНО КАК ЗаказКлиента,
		|	НЕОПРЕДЕЛЕНО КАК СтатьяКалькуляции,
		|	НЕОПРЕДЕЛЕНО КАК ПравилоОтнесенияНаВыпуск,
		|	Т.КорСтатьяРасходов КАК КорСтатьяРасходов,
		|	Т.КорАналитикаРасходов КАК КорАналитикаРасходов,
		|	Т.ХозяйственнаяОперация КАК ХозяйственнаяОперация,
		|	Т.НастройкаХозяйственнойОперации КАК НастройкаХозяйственнойОперации,
		|	МИНИМУМ(Т.ИдентификаторФинЗаписи) КАК ИдентификаторФинЗаписи,
		|	СУММА(Т.Сумма) КАК СуммаСНДС,
		|	СУММА(Т.СуммаБезНДС) КАК СуммаБезНДС,
		|	СУММА(Т.СуммаРегл) КАК СуммаРегл,
		|	СУММА(Т.СуммаРегл - Т.ПостояннаяРазница - Т.ВременнаяРазница) КАК СуммаНУ,
		|	СУММА(Т.СуммаУпр) КАК СуммаУпр,
		|	СУММА(Т.СуммаНДД) КАК СуммаНДД
		|ИЗ
		|	ВтПрочиеРасходыПрошлыйПериод КАК Т
		|ГДЕ
		|	Т.ХозяйственнаяОперация = ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.РаспределениеРБП)
		|	И ТИПЗНАЧЕНИЯ(Т.Регистратор) = ТИП(Документ.РаспределениеРасходовБудущихПериодов)
		|СГРУППИРОВАТЬ ПО
		|	(ВЫБОР
		|		КОГДА Т.Период > &НачалоПериода ТОГДА Т.Период
		|		ИНАЧЕ &НачалоПериода КОНЕЦ), // Период
		|	Т.ПериодМесяц,
		// Измерения
		|	Т.Организация,
		|	Т.Подразделение,
		|	Т.НаправлениеДеятельности,
		|	Т.СтатьяРасходов,
		|	Т.АналитикаРасходов,
		// Кор реквизиты
		|	Т.КорПодразделение,
		|	Т.КорНаправлениеДеятельности,
		|	Т.КорСтатьяРасходов,
		|	Т.КорАналитикаРасходов,
		|	Т.ХозяйственнаяОперация,
		|	Т.НастройкаХозяйственнойОперации
		|ИМЕЮЩИЕ
		|	СУММА(Т.Сумма) <> 0
		|	ИЛИ СУММА(Т.СуммаБезНДС) <> 0
		|	ИЛИ СУММА(Т.СуммаРегл) <> 0
		|	ИЛИ СУММА(Т.ПостояннаяРазница) <> 0
		|	ИЛИ СУММА(Т.ВременнаяРазница) <> 0
		|	ИЛИ СУММА(Т.СуммаУпр) <> 0
		|	ИЛИ СУММА(Т.СуммаНДД) <> 0
		|";
	#КонецОбласти
	
	ТекстЗапроса = ТекстЗапроса + "
		|ИНДЕКСИРОВАТЬ ПО
		|	ПериодРаспределения,
		|	Организация,
		|	Подразделение,
		|	НаправлениеДеятельности,
		|	СтатьяРасходов,
		|	АналитикаРасходов,
		|	Партия,
		|	СтатьяКалькуляции
		|	
		|";
		
	Возврат ТекстЗапроса;
		
КонецФункции	

Функция ТекстВтУзлыКорректировкиПрошлыхПериодовПредварительная() // вт ВтУзлыКорректировкиПрошлыхПериодовПредварительная
	// Выборка должна быть аналогично выборке для среднескользящей в функции
	// ТекстВтУзлыКорректировкиПрошлыхПериодовПредварительнаяОтклонения().
	Возврат "
		|ВЫБРАТЬ
		|	Т.Период КАК ПериодРаспределения,
		|	Т.АналитикаУчетаНоменклатуры КАК АналитикаУчетаНоменклатуры,
		|	Т.АналитикаУчетаНоменклатуры.Номенклатура КАК Номенклатура,
		|	Т.АналитикаУчетаНоменклатуры.МестоХранения КАК МестоХранения,
		|	Т.РазделУчета КАК РазделУчета,
		|	Т.Организация КАК Организация,
		|	Т.ВидЗапасов КАК ВидЗапасов,
		|	Т.Партия КАК Партия,
		|	Т.АналитикаУчетаПартий КАК АналитикаУчетаПартий,
		|	Т.АналитикаФинансовогоУчета КАК АналитикаФинансовогоУчета,
		|	Т.ВидДеятельностиНДС КАК ВидДеятельностиНДС,
		|	Т.КоличествоНачальныйОстаток КАК КоличествоНачальныйОстаток,
		|	Т.КоличествоКонечныйОстаток КАК КоличествоКонечныйОстаток,
		|	Т.КоличествоПриход КАК КоличествоПриход
		|
		|ПОМЕСТИТЬ ВтУзлыКорректировкиПрошлыхПериодовПредварительная
		|ИЗ
		|	РегистрНакопления.СебестоимостьТоваров.ОстаткиИОбороты(&МинимальныйПрошлыйПериод, &НачалоПериода, Месяц, ,
		|		Организация В (&ОрганизацииСРаспределениемОтклоненийВПрошлыхПериодах) 
		|		И НЕ Организация В (&ОрганизацииСреднескользящая)
		|		И &МинимальныйПрошлыйПериод <> &КонецПредыдущегоПериода
		|	) КАК Т
		|ГДЕ
		|	Т.КоличествоНачальныйОстаток <> 0
		|	ИЛИ Т.КоличествоПриход <> 0
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		// Из количества в узле вычитаем списание по фиксированной стоимости.
		// На выпуски по фиксированной стоимости не выполняется распределение расходов. 
		|ВЫБРАТЬ
		|	НАЧАЛОПЕРИОДА(Т.Период, МЕСЯЦ) КАК ПериодРаспределения,
		|	Т.АналитикаУчетаНоменклатуры КАК АналитикаУчетаНоменклатуры,
		|	Т.АналитикаУчетаНоменклатуры.Номенклатура КАК Номенклатура,
		|	Т.АналитикаУчетаНоменклатуры.МестоХранения КАК МестоХранения,
		|	Т.РазделУчета КАК РазделУчета,
		|	Т.Организация КАК Организация,
		|	Т.ВидЗапасов КАК ВидЗапасов,
		|	Т.Партия КАК Партия,
		|	Т.АналитикаУчетаПартий КАК АналитикаУчетаПартий,
		|	Т.АналитикаФинансовогоУчета КАК АналитикаФинансовогоУчета,
		|	Т.ВидДеятельностиНДС КАК ВидДеятельностиНДС,
		|	0 КАК КоличествоНачальныйОстаток,
		|	0 КАК КоличествоКонечныйОстаток,
		|	-СУММА(Т.Количество) КАК КоличествоПриход
		|ИЗ
		|	РегистрНакопления.СебестоимостьТоваров КАК Т
		|ГДЕ
		|	Т.Период МЕЖДУ &МинимальныйПрошлыйПериод И &КонецПредыдущегоПериода
		|	И Т.Организация В (&ОрганизацииСРаспределениемОтклоненийВПрошлыхПериодах)
		|	И НЕ Т.Организация В (&ОрганизацииСреднескользящая)
		|	И Т.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход)
		|	И Т.Количество <> 0
		|	И Т.ХозяйственнаяОперация = ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.СписаниеНаРасходыФиксированнаяСтоимость)
		|
		|СГРУППИРОВАТЬ ПО
		|	НАЧАЛОПЕРИОДА(Т.Период, МЕСЯЦ),
		|	Т.АналитикаУчетаНоменклатуры,
		|	Т.АналитикаУчетаНоменклатуры.Номенклатура,
		|	Т.АналитикаУчетаНоменклатуры.МестоХранения,
		|	Т.РазделУчета,
		|	Т.Организация,
		|	Т.ВидЗапасов,
		|	Т.Партия,
		|	Т.АналитикаУчетаПартий,
		|	Т.АналитикаФинансовогоУчета,
		|	Т.ВидДеятельностиНДС
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		// Количество в узле увеличиваем на количество, списанное по изменению метода оценки стоимости.
		|ВЫБРАТЬ
		|	НАЧАЛОПЕРИОДА(Т.Период, МЕСЯЦ) КАК ПериодРаспределения,
		|	Т.АналитикаУчетаНоменклатуры КАК АналитикаУчетаНоменклатуры,
		|	Т.АналитикаУчетаНоменклатуры.Номенклатура КАК Номенклатура,
		|	Т.АналитикаУчетаНоменклатуры.МестоХранения КАК МестоХранения,
		|	Т.РазделУчета КАК РазделУчета,
		|	Т.Организация КАК Организация,
		|	Т.ВидЗапасов КАК ВидЗапасов,
		|	Т.Партия КАК Партия,
		|	Т.АналитикаУчетаПартий КАК АналитикаУчетаПартий,
		|	Т.АналитикаФинансовогоУчета КАК АналитикаФинансовогоУчета,
		|	Т.ВидДеятельностиНДС КАК ВидДеятельностиНДС,
		|	0 КАК КоличествоНачальныйОстаток,
		|	0 КАК КоличествоКонечныйОстаток,
		|	-СУММА(Т.Количество) КАК КоличествоПриход
		|ИЗ
		|	РегистрНакопления.СебестоимостьТоваров КАК Т
		|ГДЕ
		|	Т.Период МЕЖДУ &МинимальныйПрошлыйПериод И &КонецПредыдущегоПериода
		|	И Т.Организация В (&ОрганизацииСРаспределениемОтклоненийВПрошлыхПериодах)
		|	И НЕ Т.Организация В (&ОрганизацииСреднескользящая)
		|	И Т.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход)
		|	И Т.Количество < 0
		|	И Т.ТипЗаписи = ЗНАЧЕНИЕ(Перечисление.ТипыЗаписейПартий.СлужебноеИзменениеМетодаОценкиСтоимости)
		|
		|СГРУППИРОВАТЬ ПО
		|	НАЧАЛОПЕРИОДА(Т.Период, МЕСЯЦ),
		|	Т.АналитикаУчетаНоменклатуры,
		|	Т.АналитикаУчетаНоменклатуры.Номенклатура,
		|	Т.АналитикаУчетаНоменклатуры.МестоХранения,
		|	Т.РазделУчета,
		|	Т.Организация,
		|	Т.ВидЗапасов,
		|	Т.Партия,
		|	Т.АналитикаУчетаПартий,
		|	Т.АналитикаФинансовогоУчета,
		|	Т.ВидДеятельностиНДС
		|";
КонецФункции

Функция ТекстВтУзлыКорректировкиПрошлыхПериодовСгруппированная() // вт ВтУзлыКорректировкиПрошлыхПериодовСгруппированная
	Возврат "
		|ВЫБРАТЬ
		|	Т.ПериодРаспределения КАК ПериодРаспределения,
		|	Т.АналитикаУчетаНоменклатуры КАК АналитикаУчетаНоменклатуры,
		|	Т.Номенклатура КАК Номенклатура,
		|	Т.МестоХранения КАК МестоХранения,
		|	Т.РазделУчета КАК РазделУчета,
		|	Т.Организация КАК Организация,
		|	Т.ВидЗапасов КАК ВидЗапасов,
		|	Т.Партия КАК Партия,
		|	Т.АналитикаУчетаПартий КАК АналитикаУчетаПартий,
		|	Т.АналитикаФинансовогоУчета КАК АналитикаФинансовогоУчета,
		|	Т.ВидДеятельностиНДС КАК ВидДеятельностиНДС,
		|	СУММА(Т.КоличествоНачальныйОстаток) КАК КоличествоНачальныйОстаток,
		|	СУММА(Т.КоличествоКонечныйОстаток) КАК КоличествоКонечныйОстаток,
		|	СУММА(Т.КоличествоПриход) КАК КоличествоПриход
		|
		|ПОМЕСТИТЬ ВтУзлыКорректировкиПрошлыхПериодовСгруппированная
		|ИЗ
		|	ВтУзлыКорректировкиПрошлыхПериодовПредварительная КАК Т
		|
		|СГРУППИРОВАТЬ ПО
		|	Т.ПериодРаспределения,
		|	Т.АналитикаУчетаНоменклатуры,
		|	Т.Номенклатура,
		|	Т.МестоХранения,
		|	Т.РазделУчета,
		|	Т.Организация,
		|	Т.ВидЗапасов,
		|	Т.Партия,
		|	Т.АналитикаУчетаПартий,
		|	Т.АналитикаФинансовогоУчета,
		|	Т.ВидДеятельностиНДС
		|
		|ИНДЕКСИРОВАТЬ ПО
		|	АналитикаУчетаНоменклатуры,
		|	Организация,
		|	Партия
		|";
КонецФункции

Функция ТекстВтУзлыКорректировкиПрошлыхПериодов() // вт ВтУзлыКорректировкиПрошлыхПериодов
	// Выборка должна быть аналогично выборке для среднескользящей
	// в функции ТекстВтУзлыКорректировкиПрошлыхПериодовОтклонения().
	Возврат "
		|ВЫБРАТЬ
		|	Т.ПериодРаспределения КАК ПериодРаспределения,
		|	МАКСИМУМ(ЕСТЬNULL(Т2.ПериодРаспределения, НЕОПРЕДЕЛЕНО)) КАК ПериодРаспределенияПредыдущий,
		|	Т.АналитикаУчетаНоменклатуры КАК АналитикаУчетаНоменклатуры,
		|	Т.Номенклатура КАК Номенклатура,
		|	Т.МестоХранения КАК МестоХранения,
		|	Т.РазделУчета КАК РазделУчета,
		|	Т.Организация КАК Организация,
		|	Т.ВидЗапасов КАК ВидЗапасов,
		|	Т.Партия КАК Партия,
		|	Т.АналитикаУчетаПартий КАК АналитикаУчетаПартий,
		|	Т.АналитикаФинансовогоУчета КАК АналитикаФинансовогоУчета,
		|	Т.ВидДеятельностиНДС КАК ВидДеятельностиНДС,
		|	Т.КоличествоНачальныйОстаток КАК КоличествоНачальныйОстаток,
		|	Т.КоличествоКонечныйОстаток КАК КоличествоКонечныйОстаток,
		|	Т.КоличествоПриход КАК КоличествоПриход
		|
		|ПОМЕСТИТЬ ВтУзлыКорректировкиПрошлыхПериодов
		|ИЗ
		|	ВтУзлыКорректировкиПрошлыхПериодовСгруппированная КАК Т
		|	ЛЕВОЕ СОЕДИНЕНИЕ ВтУзлыКорректировкиПрошлыхПериодовСгруппированная КАК Т2
		|		ПО Т.АналитикаУчетаНоменклатуры = Т2.АналитикаУчетаНоменклатуры
		|		И Т.РазделУчета = Т2.РазделУчета
		|		И Т.Организация = Т2.Организация
		|		И Т.ВидЗапасов = Т2.ВидЗапасов
		|		И Т.Партия = Т2.Партия
		|		И Т.АналитикаУчетаПартий = Т2.АналитикаУчетаПартий
		|		И Т.АналитикаФинансовогоУчета = Т2.АналитикаФинансовогоУчета
		|		И Т.ВидДеятельностиНДС = Т2.ВидДеятельностиНДС
		|		И Т.ПериодРаспределения > Т2.ПериодРаспределения
		|
		|СГРУППИРОВАТЬ ПО
		|	Т.ПериодРаспределения,
		|	Т.АналитикаУчетаНоменклатуры,
		|	Т.Номенклатура,
		|	Т.МестоХранения,
		|	Т.РазделУчета,
		|	Т.Организация,
		|	Т.ВидЗапасов,
		|	Т.Партия,
		|	Т.АналитикаУчетаПартий,
		|	Т.АналитикаФинансовогоУчета,
		|	Т.ВидДеятельностиНДС,
		|	Т.КоличествоНачальныйОстаток,
		|	Т.КоличествоКонечныйОстаток,
		|	Т.КоличествоПриход
		|
		|ИНДЕКСИРОВАТЬ ПО
		|	АналитикаУчетаНоменклатуры,
		|	Организация,
		|	Партия
		|";
КонецФункции

Функция ТекстВтУзлыРасходовПрошлыхПериодовПредварительная() // вт ТекстВтУзлыРасходовПрошлыхПериодовПредварительная
	Возврат "
		|ВЫБРАТЬ
		|	НЕОПРЕДЕЛЕНО КАК Ссылка,
		|	ЗНАЧЕНИЕ(Перечисление.ВариантыРаспределенияРасходов.ПустаяСсылка) КАК ВариантРаспределенияРасходовУпр,
		|	ЗНАЧЕНИЕ(Перечисление.ВариантыРаспределенияРасходов.ПустаяСсылка) КАК ВариантРаспределенияРасходовРегл,
		|	ЗНАЧЕНИЕ(Перечисление.ВариантыРаспределенияРасходов.ПустаяСсылка) КАК ВариантРаспределенияРасходовНУ
		|	
		|ПОМЕСТИТЬ ВтОбъектыВозникновенияЗатрат
		|
		|
		|ИНДЕКСИРОВАТЬ ПО
		|	Ссылка
		|;
		|ВЫБРАТЬ
		|	""1"" КАК ЗапросИсточник,
		|	0 КАК НомерУзлаДопРасходы,
		|	Т.Период КАК ПериодРаспределения,
		|	Т.Организация КАК Организация,
		|	Т.Подразделение КАК Подразделение,
		|	Т.НаправлениеДеятельности КАК НаправлениеДеятельности,
		|	Т.СтатьяРасходов КАК СтатьяРасходов,
		|	Т.АналитикаРасходов КАК АналитикаРасходов,
		|	НЕОПРЕДЕЛЕНО КАК Партия,
		|	НЕОПРЕДЕЛЕНО КАК СтатьяКалькуляции,
		|	(ВЫБОР
		|		КОГДА Статья.ВариантРаспределенияРасходовУпр = ЗНАЧЕНИЕ(Перечисление.ВариантыРаспределенияРасходов.НаРасходыБудущихПериодов)
		|		 ИЛИ ЕСТЬNULL(ОВЗ.ВариантРаспределенияРасходовУпр, НЕОПРЕДЕЛЕНО) = ЗНАЧЕНИЕ(Перечисление.ВариантыРаспределенияРасходов.НаРасходыБудущихПериодов)
		|			ТОГДА 0
		|		ИНАЧЕ Т.СуммаНачальныйОстаток КОНЕЦ) КАК СуммаНачальныйОстаток,
		|	(ВЫБОР
		|		КОГДА Статья.ВариантРаспределенияРасходовУпр = ЗНАЧЕНИЕ(Перечисление.ВариантыРаспределенияРасходов.НаРасходыБудущихПериодов)
		|		 ИЛИ ЕСТЬNULL(ОВЗ.ВариантРаспределенияРасходовУпр, НЕОПРЕДЕЛЕНО) = ЗНАЧЕНИЕ(Перечисление.ВариантыРаспределенияРасходов.НаРасходыБудущихПериодов)
		|			ТОГДА 0
		|		ИНАЧЕ Т.СуммаБезНДСНачальныйОстаток КОНЕЦ) КАК СуммаБезНДСНачальныйОстаток,
		|	(ВЫБОР
		|		КОГДА Статья.ВариантРаспределенияРасходовРегл = ЗНАЧЕНИЕ(Перечисление.ВариантыРаспределенияРасходов.НаРасходыБудущихПериодов)
		|		 ИЛИ ЕСТЬNULL(ОВЗ.ВариантРаспределенияРасходовРегл, НЕОПРЕДЕЛЕНО) = ЗНАЧЕНИЕ(Перечисление.ВариантыРаспределенияРасходов.НаРасходыБудущихПериодов)
		|			ТОГДА 0
		|		ИНАЧЕ Т.СуммаРеглНачальныйОстаток КОНЕЦ) КАК СуммаРеглНачальныйОстаток,
		|	(ВЫБОР
		|		КОГДА Статья.ВариантРаспределенияРасходовНУ = ЗНАЧЕНИЕ(Перечисление.ВариантыРаспределенияРасходов.НаРасходыБудущихПериодов)
		|		 ИЛИ ЕСТЬNULL(ОВЗ.ВариантРаспределенияРасходовНУ, НЕОПРЕДЕЛЕНО) = ЗНАЧЕНИЕ(Перечисление.ВариантыРаспределенияРасходов.НаРасходыБудущихПериодов)
		|			ТОГДА 0
		|		ИНАЧЕ Т.СуммаРеглНачальныйОстаток
		|			-Т.ПостояннаяРазницаНачальныйОстаток
		|			-Т.ВременнаяРазницаНачальныйОстаток КОНЕЦ) КАК СуммаНУНачальныйОстаток,
		|	(ВЫБОР
		|		КОГДА Статья.ВариантРаспределенияРасходовУпр = ЗНАЧЕНИЕ(Перечисление.ВариантыРаспределенияРасходов.НаРасходыБудущихПериодов)
		|		 ИЛИ ЕСТЬNULL(ОВЗ.ВариантРаспределенияРасходовУпр, НЕОПРЕДЕЛЕНО) = ЗНАЧЕНИЕ(Перечисление.ВариантыРаспределенияРасходов.НаРасходыБудущихПериодов)
		|			ТОГДА 0
		|		ИНАЧЕ Т.СуммаУпрНачальныйОстаток КОНЕЦ) КАК СуммаУпрНачальныйОстаток,
		|	(ВЫБОР
		|		КОГДА Статья.ВариантРаспределенияРасходовУпр = ЗНАЧЕНИЕ(Перечисление.ВариантыРаспределенияРасходов.НаРасходыБудущихПериодов)
		|		 ИЛИ ЕСТЬNULL(ОВЗ.ВариантРаспределенияРасходовУпр, НЕОПРЕДЕЛЕНО) = ЗНАЧЕНИЕ(Перечисление.ВариантыРаспределенияРасходов.НаРасходыБудущихПериодов)
		|			ТОГДА 0
		|		ИНАЧЕ Т.СуммаПриход КОНЕЦ) КАК СуммаПриход,
		|	(ВЫБОР
		|		КОГДА Статья.ВариантРаспределенияРасходовУпр = ЗНАЧЕНИЕ(Перечисление.ВариантыРаспределенияРасходов.НаРасходыБудущихПериодов)
		|		 ИЛИ ЕСТЬNULL(ОВЗ.ВариантРаспределенияРасходовУпр, НЕОПРЕДЕЛЕНО) = ЗНАЧЕНИЕ(Перечисление.ВариантыРаспределенияРасходов.НаРасходыБудущихПериодов)
		|			ТОГДА 0
		|		ИНАЧЕ Т.СуммаБезНДСПриход КОНЕЦ) КАК СуммаБезНДСПриход,
		|	(ВЫБОР
		|		КОГДА Статья.ВариантРаспределенияРасходовРегл = ЗНАЧЕНИЕ(Перечисление.ВариантыРаспределенияРасходов.НаРасходыБудущихПериодов)
		|		 ИЛИ ЕСТЬNULL(ОВЗ.ВариантРаспределенияРасходовРегл, НЕОПРЕДЕЛЕНО) = ЗНАЧЕНИЕ(Перечисление.ВариантыРаспределенияРасходов.НаРасходыБудущихПериодов)
		|			ТОГДА 0
		|		ИНАЧЕ Т.СуммаРеглПриход КОНЕЦ) КАК СуммаРеглПриход,
		|	(ВЫБОР
		|		КОГДА Статья.ВариантРаспределенияРасходовНУ = ЗНАЧЕНИЕ(Перечисление.ВариантыРаспределенияРасходов.НаРасходыБудущихПериодов)
		|		 ИЛИ ЕСТЬNULL(ОВЗ.ВариантРаспределенияРасходовНУ, НЕОПРЕДЕЛЕНО) = ЗНАЧЕНИЕ(Перечисление.ВариантыРаспределенияРасходов.НаРасходыБудущихПериодов)
		|			ТОГДА 0
		// Если в прошлом периоде не было распределения суммы НУ, то будет использоваться сумма регл в качестве базы распределения,
		// при одинаковых вариантах распределения в НУ и регл учете.
		|		КОГДА (Т.СуммаРеглПриход - Т.ПостояннаяРазницаПриход - Т.ВременнаяРазницаПриход) = 0
		|		 И Статья.ВариантРаспределенияРасходовРегл = Статья.ВариантРаспределенияРасходовНУ
		|			ТОГДА Т.СуммаРеглПриход
		|		ИНАЧЕ Т.СуммаРеглПриход - Т.ПостояннаяРазницаПриход - Т.ВременнаяРазницаПриход КОНЕЦ) КАК СуммаНУПриход,
		|	(ВЫБОР
		|		КОГДА Статья.ВариантРаспределенияРасходовУпр = ЗНАЧЕНИЕ(Перечисление.ВариантыРаспределенияРасходов.НаРасходыБудущихПериодов)
		|		 ИЛИ ЕСТЬNULL(ОВЗ.ВариантРаспределенияРасходовУпр, НЕОПРЕДЕЛЕНО) = ЗНАЧЕНИЕ(Перечисление.ВариантыРаспределенияРасходов.НаРасходыБудущихПериодов)
		|			ТОГДА 0
		|		ИНАЧЕ Т.СуммаУпрПриход КОНЕЦ) КАК СуммаУпрПриход
		|
		|ПОМЕСТИТЬ ВтУзлыРасходовПрошлыхПериодовПредварительная
		|ИЗ
		|	РегистрНакопления.ПрочиеРасходы.ОстаткиИОбороты(&МинимальныйПрошлыйПериод, &КонецПредыдущегоПериода, Месяц, ,
		|		Организация В (&ОрганизацииСРаспределениемОтклоненийВПрошлыхПериодах) 
		|		И &МинимальныйПрошлыйПериод <> &КонецПредыдущегоПериода
		|		И (Организация, Подразделение, НаправлениеДеятельности, СтатьяРасходов, АналитикаРасходов) В (
		|			ВЫБРАТЬ
		|				Отбор.Организация,
		|				Отбор.Подразделение,
		|				Отбор.НаправлениеДеятельности,
		|				Отбор.СтатьяРасходов,
		|				Отбор.АналитикаРасходов
		|			ИЗ
		|				ВтИспользуемыеРасходыПоПериодам КАК Отбор)
		|	) КАК Т
		|	ВНУТРЕННЕЕ СОЕДИНЕНИЕ ПланВидовХарактеристик.СтатьиРасходов КАК Статья
		|		ПО Статья.Ссылка = Т.СтатьяРасходов
		|	ЛЕВОЕ СОЕДИНЕНИЕ ВтОбъектыВозникновенияЗатрат КАК ОВЗ
		|		ПО ОВЗ.Ссылка = Т.АналитикаРасходов
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		// Расходы будущих периодов.
		|ВЫБРАТЬ
		|	""2"" КАК ЗапросИсточник,
		|	0 КАК НомерУзлаДопРасходы,
		|	Т.Период КАК ПериодРаспределения,
		|	Т.Организация КАК Организация,
		|	Т.Подразделение КАК Подразделение,
		|	Т.НаправлениеДеятельности КАК НаправлениеДеятельности,
		|	Т.СтатьяРасходов КАК СтатьяРасходов,
		|	Т.АналитикаРасходов КАК АналитикаРасходов,
		|	НЕОПРЕДЕЛЕНО КАК Партия,
		|	НЕОПРЕДЕЛЕНО КАК СтатьяКалькуляции,
		|	0 КАК СуммаНачальныйОстаток,
		|	0 КАК СуммаБезНДСНачальныйОстаток,
		|	0 КАК СуммаРеглНачальныйОстаток,
		|	0 КАК СуммаНУНачальныйОстаток,
		|	0 КАК СуммаУпрНачальныйОстаток,
		// Для расходов будущих периодов начальная стоимость в узле определяется суммой расхода - суммой распределения РБП.
		// Начальный остаток по РБП не имеет смысла для целей распределения отклонений, т.к. он может в себя включать 
		// ранее распределенные отклонения и это нарушит пропорцию коэффициентов распределения.
		|	(ВЫБОР
		|		КОГДА Статья.ВариантРаспределенияРасходовУпр = ЗНАЧЕНИЕ(Перечисление.ВариантыРаспределенияРасходов.НаРасходыБудущихПериодов)
		|		 ИЛИ ЕСТЬNULL(ОВЗ.ВариантРаспределенияРасходовУпр, НЕОПРЕДЕЛЕНО) = ЗНАЧЕНИЕ(Перечисление.ВариантыРаспределенияРасходов.НаРасходыБудущихПериодов)
		|			ТОГДА Т.Сумма
		|		ИНАЧЕ 0 КОНЕЦ) КАК СуммаПриход,
		|	(ВЫБОР
		|		КОГДА Статья.ВариантРаспределенияРасходовУпр = ЗНАЧЕНИЕ(Перечисление.ВариантыРаспределенияРасходов.НаРасходыБудущихПериодов)
		|		 ИЛИ ЕСТЬNULL(ОВЗ.ВариантРаспределенияРасходовУпр, НЕОПРЕДЕЛЕНО) = ЗНАЧЕНИЕ(Перечисление.ВариантыРаспределенияРасходов.НаРасходыБудущихПериодов)
		|			ТОГДА Т.СуммаБезНДС
		|		ИНАЧЕ 0 КОНЕЦ) КАК СуммаБезНДСПриход,
		|	(ВЫБОР
		|		КОГДА Статья.ВариантРаспределенияРасходовРегл = ЗНАЧЕНИЕ(Перечисление.ВариантыРаспределенияРасходов.НаРасходыБудущихПериодов)
		|		 ИЛИ ЕСТЬNULL(ОВЗ.ВариантРаспределенияРасходовРегл, НЕОПРЕДЕЛЕНО) = ЗНАЧЕНИЕ(Перечисление.ВариантыРаспределенияРасходов.НаРасходыБудущихПериодов)
		|			ТОГДА Т.СуммаРегл
		|		ИНАЧЕ 0 КОНЕЦ) КАК СуммаРеглПриход,
		|	(ВЫБОР
		|		КОГДА Статья.ВариантРаспределенияРасходовНУ = ЗНАЧЕНИЕ(Перечисление.ВариантыРаспределенияРасходов.НаРасходыБудущихПериодов)
		|		 ИЛИ ЕСТЬNULL(ОВЗ.ВариантРаспределенияРасходовНУ, НЕОПРЕДЕЛЕНО) = ЗНАЧЕНИЕ(Перечисление.ВариантыРаспределенияРасходов.НаРасходыБудущихПериодов)
		|			ТОГДА Т.СуммаРегл - Т.ПостояннаяРазница - Т.ВременнаяРазница
		|		ИНАЧЕ 0 КОНЕЦ) КАК СуммаНУПриход,
		|	(ВЫБОР
		|		КОГДА Статья.ВариантРаспределенияРасходовУпр = ЗНАЧЕНИЕ(Перечисление.ВариантыРаспределенияРасходов.НаРасходыБудущихПериодов)
		|		 ИЛИ ЕСТЬNULL(ОВЗ.ВариантРаспределенияРасходовУпр, НЕОПРЕДЕЛЕНО) = ЗНАЧЕНИЕ(Перечисление.ВариантыРаспределенияРасходов.НаРасходыБудущихПериодов)
		|			ТОГДА Т.СуммаУпр
		|		ИНАЧЕ 0 КОНЕЦ) КАК СуммаУпрПриход
		|ИЗ
		|	РегистрНакопления.ПрочиеРасходы КАК Т
		|	ВНУТРЕННЕЕ СОЕДИНЕНИЕ ПланВидовХарактеристик.СтатьиРасходов КАК Статья
		|		ПО Статья.Ссылка = Т.СтатьяРасходов
		|	ЛЕВОЕ СОЕДИНЕНИЕ ВтОбъектыВозникновенияЗатрат КАК ОВЗ
		|		ПО ОВЗ.Ссылка = Т.АналитикаРасходов
		|ГДЕ
		|	Т.Период >= &МинимальныйПрошлыйПериод
		|	И Т.Организация В (&ОрганизацииСРаспределениемОтклоненийВПрошлыхПериодах) 
		|	И Т.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход)
		|	И Т.ХозяйственнаяОперация = ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.РаспределениеРБП)
		|	И ТИПЗНАЧЕНИЯ(Т.Регистратор) = ТИП(Документ.РаспределениеРасходовБудущихПериодов) 
		|	И (Т.Организация, Т.Подразделение, Т.НаправлениеДеятельности, Т.СтатьяРасходов, Т.АналитикаРасходов) В (
		|		ВЫБРАТЬ
		|			Отбор.Организация,
		|			Отбор.Подразделение,
		|			Отбор.НаправлениеДеятельности,
		|			Отбор.СтатьяРасходов,
		|			Отбор.АналитикаРасходов
		|		ИЗ
		|			ВтИспользуемыеРасходыПоПериодам КАК Отбор)
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	""3"" КАК ЗапросИсточник,
		|	Т.НомерУзла КАК НомерУзлаДопРасходы,
		|	НАЧАЛОПЕРИОДА(Т.ПериодПоступления, МЕСЯЦ) КАК ПериодРаспределения,
		|	Т.Организация КАК Организация,
		|	Т.Подразделение КАК Подразделение,
		|	Т.НаправлениеДеятельности КАК НаправлениеДеятельности,
		|	Т.СтатьяРасходов КАК СтатьяРасходов,
		|	Т.АналитикаРасходов КАК АналитикаРасходов,
		|	НЕОПРЕДЕЛЕНО КАК Партия,
		|	НЕОПРЕДЕЛЕНО КАК СтатьяКалькуляции,
		|	0 КАК СуммаНачальныйОстаток,
		|	0 КАК СуммаБезНДСНачальныйОстаток,
		|	0 КАК СуммаРеглНачальныйОстаток,
		|	0 КАК СуммаНУНачальныйОстаток,
		|	0 КАК СуммаУпрНачальныйОстаток,
		|	Т.ВесСНДС 	КАК СуммаПриход,
		|	Т.ВесБезНДС КАК СуммаБезНДСПриход,
		|	Т.ВесРегл	КАК СуммаРеглПриход,
		|	Т.ВесНУ		КАК СуммаНУПриход,
		|	Т.ВесУпр	КАК СуммаУпрПриход
		|ИЗ
		|	УзлыКорректировкиДополнительныхРасходов КАК Т
		|ГДЕ
		|	НАЧАЛОПЕРИОДА(Т.ПериодПоступления, МЕСЯЦ) < &НачалоПериода
		|	И (Т.ВесСНДС <> 0
		|		ИЛИ Т.ВесБезНДС <> 0
		|		ИЛИ Т.ВесРегл <> 0
		|		ИЛИ Т.ВесНУ <> 0
		|		ИЛИ Т.ВесУпр <> 0)
		|
		|
		|ИНДЕКСИРОВАТЬ ПО
		|	Организация,
		|	СтатьяРасходов,
		|	АналитикаРасходов
		|";
КонецФункции

Функция ТекстВтУзлыРасходовПрошлыхПериодов() // ВтУзлыРасходовПрошлыхПериодов
	Возврат "
		|ВЫБРАТЬ
		|	Т.НомерУзлаДопРасходы,
		|	Т.ПериодРаспределения КАК ПериодРаспределения,
		|	МАКСИМУМ(ЕСТЬNULL(Т2.ПериодРаспределения, НЕОПРЕДЕЛЕНО)) КАК ПериодРаспределенияПредыдущий,
		|	Т.Организация КАК Организация,
		|	Т.Подразделение КАК Подразделение,
		|	Т.НаправлениеДеятельности КАК НаправлениеДеятельности,
		|	Т.СтатьяРасходов КАК СтатьяРасходов,
		|	Т.АналитикаРасходов КАК АналитикаРасходов,
		|	Т.Партия КАК Партия,
		|	Т.СтатьяКалькуляции КАК СтатьяКалькуляции,
		|	Т.СуммаНачальныйОстаток КАК СуммаНачальныйОстаток,
		|	Т.СуммаБезНДСНачальныйОстаток КАК СуммаБезНДСНачальныйОстаток,
		|	Т.СуммаРеглНачальныйОстаток КАК СуммаРеглНачальныйОстаток,
		|	Т.СуммаНУНачальныйОстаток КАК СуммаНУНачальныйОстаток,
		|	Т.СуммаУпрНачальныйОстаток КАК СуммаУпрНачальныйОстаток,
		|	Т.СуммаПриход КАК СуммаПриход,
		|	Т.СуммаБезНДСПриход КАК СуммаБезНДСПриход,
		|	Т.СуммаРеглПриход КАК СуммаРеглПриход,
		|	Т.СуммаНУПриход КАК СуммаНУПриход,
		|	Т.СуммаУпрПриход КАК СуммаУпрПриход
		|
		|ПОМЕСТИТЬ ВтУзлыРасходовПрошлыхПериодов
		|ИЗ
		|	ВтУзлыРасходовПрошлыхПериодовПредварительная КАК Т
		|
		|	ЛЕВОЕ СОЕДИНЕНИЕ ВтУзлыРасходовПрошлыхПериодовПредварительная КАК Т2
		|		ПО Т.Организация = Т2.Организация
		|		И Т.Подразделение = Т2.Подразделение
		|		И Т.НаправлениеДеятельности = Т2.НаправлениеДеятельности
		|		И Т.СтатьяРасходов = Т2.СтатьяРасходов
		|		И Т.АналитикаРасходов = Т2.АналитикаРасходов
		|		И Т.Партия = Т2.Партия
		|		И Т.СтатьяКалькуляции = Т2.СтатьяКалькуляции
		|		И Т.ПериодРаспределения > Т2.ПериодРаспределения
		|		И Т.ПериодРаспределения <> ДАТАВРЕМЯ(1,1,1)
		|
		|СГРУППИРОВАТЬ ПО
		|	Т.НомерУзлаДопРасходы,
		|	Т.ПериодРаспределения,
		|	Т.Организация,
		|	Т.Подразделение,
		|	Т.НаправлениеДеятельности,
		|	Т.СтатьяРасходов,
		|	Т.АналитикаРасходов,
		|	Т.Партия,
		|	Т.СтатьяКалькуляции,
		|	Т.СуммаНачальныйОстаток,
		|	Т.СуммаБезНДСНачальныйОстаток,
		|	Т.СуммаРеглНачальныйОстаток,
		|	Т.СуммаНУНачальныйОстаток,
		|	Т.СуммаУпрНачальныйОстаток,
		|	Т.СуммаПриход,
		|	Т.СуммаБезНДСПриход,
		|	Т.СуммаРеглПриход,
		|	Т.СуммаНУПриход,
		|	Т.СуммаУпрПриход
		|
		|ИНДЕКСИРОВАТЬ ПО
		|	Организация,
		|	СтатьяРасходов,
		|	АналитикаРасходов
		|";
КонецФункции

Функция ТекстВтУзлыОтклоненийПостатейные() // ВтУзлыОтклоненийПостатейные
	Возврат "
		|ВЫБРАТЬ
		|	Т.НомерУзлаДопРасходы,
		|	ЕСТЬNULL(ОтклоненияКРаспределению.ПериодОтклонения, Т.ПериодРаспределения) КАК ПериодОтклонения,
		|	Т.ПериодРаспределения,
		|	Т.Организация КАК Организация,
		|	Т.Партия КАК Партия,
		|
		|	Т.СтатьяКалькуляции КАК СтатьяКалькуляции,
		|	Т.Подразделение КАК Подразделение,
		|	Т.НаправлениеДеятельности КАК НаправлениеДеятельности,
		|	Т.СтатьяРасходов КАК СтатьяРасходов,
		|	Т.АналитикаРасходов КАК АналитикаРасходов,
		|	(Т.Партия <> НЕОПРЕДЕЛЕНО) КАК ЭтоНЗП,
		|
		|	ЕСТЬNULL(ОтклоненияКРаспределению.Сумма, 0) КАК ОтклоненияВСтоимостиСНДС,
		|	ЕСТЬNULL(ОтклоненияКРаспределению.СуммаБезНДС, 0) КАК ОтклоненияВСтоимостиБезНДС,
		|	ЕСТЬNULL(ОтклоненияКРаспределению.СуммаРегл, 0) КАК ОтклоненияВСтоимостиРегл,
		|	ЕСТЬNULL(ОтклоненияКРаспределению.СуммаУпр, 0) КАК ОтклоненияВСтоимостиУпр,
		|
		|	ЕСТЬNULL(УзлыДопРасходов.СтоимостьСНДС, 0)
		|		+ ЕСТЬNULL(СтоимостьУзлов.ДопРасходыСНДС, 0) КАК ДопРасходыСНДС,
		|	ЕСТЬNULL(УзлыДопРасходов.СтоимостьБезНДС, 0)
		|		+ ЕСТЬNULL(СтоимостьУзлов.ДопРасходыБезНДС, 0) КАК ДопРасходыБезНДС,
		|	ЕСТЬNULL(УзлыДопРасходов.СтоимостьРегл, 0)
		|		+ ЕСТЬNULL(СтоимостьУзлов.ДопРасходыРегл, 0) КАК ДопРасходыРегл,
		|	ЕСТЬNULL(УзлыДопРасходов.СтоимостьУпр, 0)
		|		+ ЕСТЬNULL(СтоимостьУзлов.ДопРасходыУпр, 0) КАК ДопРасходыУпр,
		|	ЕСТЬNULL(ОтклоненияКРаспределению.ПостояннаяРазница, 0)
		|		+ ЕСТЬNULL(УзлыДопРасходов.ПостояннаяРазница, 0) КАК ПостояннаяРазница,
		|	ЕСТЬNULL(ОтклоненияКРаспределению.СуммаНУ, 0)
		|		+ ЕСТЬNULL(УзлыДопРасходов.СтоимостьНУ, 0) КАК СтоимостьНУ,
		|	ЕСТЬNULL(ОтклоненияКРаспределению.НДД, 0)
		|		+ ЕСТЬNULL(УзлыДопРасходов.СтоимостьНДД, 0) КАК НДД,
		|
		|	0 КАК Количество,
		|	Т.СуммаНачальныйОстаток + Т.СуммаПриход КАК КоличествоСНДС,
		|	Т.СуммаБезНДСНачальныйОстаток + Т.СуммаБезНДСПриход КАК КоличествоБезНДС,
		|	Т.СуммаРеглНачальныйОстаток + Т.СуммаРеглПриход КАК КоличествоРегл,
		|	Т.СуммаНУНачальныйОстаток + Т.СуммаНУПриход КАК КоличествоНУ,
		|	Т.СуммаУпрНачальныйОстаток + Т.СуммаУпрПриход КАК КоличествоУпр
		|
		|ПОМЕСТИТЬ ВтУзлыОтклоненийПостатейные
		|ИЗ
		|	ВтУзлыРасходовПрошлыхПериодов КАК Т
		|
		|	ЛЕВОЕ СОЕДИНЕНИЕ ВтОтклоненияПрочиеРасходыКРаспределению КАК ОтклоненияКРаспределению
		|		ПО Т.ПериодРаспределения = ОтклоненияКРаспределению.ПериодОтклонения
		|		И Т.Организация = ОтклоненияКРаспределению.Организация
		|		И Т.Подразделение = ОтклоненияКРаспределению.Подразделение
		|		И Т.НаправлениеДеятельности = ОтклоненияКРаспределению.НаправлениеДеятельности
		|		И Т.СтатьяРасходов = ОтклоненияКРаспределению.СтатьяРасходов
		|		И Т.АналитикаРасходов = ОтклоненияКРаспределению.АналитикаРасходов
		|		И Т.Партия = НЕОПРЕДЕЛЕНО
		|
		|	ЛЕВОЕ СОЕДИНЕНИЕ УзлыКорректировкиДополнительныхРасходов КАК УзлыДопРасходов
		|		ПО УзлыДопРасходов.НомерУзла = Т.НомерУзлаДопРасходы
		|
		|	ЛЕВОЕ СОЕДИНЕНИЕ НачальнаяСтоимостьДополнительныхРасходов КАК СтоимостьУзлов
		|		ПО СтоимостьУзлов.НомерУзла = Т.НомерУзлаДопРасходы
		|";
КонецФункции

Функция ТекстВтУзлыОтклоненийПредварительная() // ВтУзлыОтклоненийПредварительная
	Возврат "
		|ВЫБРАТЬ
		|	""1"" КАК ЗапросИсточник,
		|	0 КАК НомерУзлаДопРасходы,
		|	ЕСТЬNULL(ОтклоненияКРаспределению.ПериодОтклонения, Т.ПериодРаспределения) КАК ПериодОтклонения,
		|	Т.ПериодРаспределения,
		|	Т.Организация КАК Организация,
		|	Т.АналитикаУчетаНоменклатуры КАК АналитикаУчетаНоменклатуры,
		|	Т.Номенклатура КАК Номенклатура,
		|	Т.РазделУчета КАК РазделУчета,
		|	Т.ВидЗапасов КАК ВидЗапасов,
		|	Т.Партия КАК Партия,
		|	Т.АналитикаУчетаПартий КАК АналитикаУчетаПартий,
		|	Т.АналитикаФинансовогоУчета КАК АналитикаФинансовогоУчета,
		|	Т.ВидДеятельностиНДС КАК ВидДеятельностиНДС,
		|
		|	НЕОПРЕДЕЛЕНО КАК СтатьяКалькуляции,
		|	ЗНАЧЕНИЕ(Справочник.СтруктураПредприятия.ПустаяСсылка) КАК Подразделение,
		|	ЗНАЧЕНИЕ(Справочник.НаправленияДеятельности.ПустаяСсылка) КАК НаправлениеДеятельности,
		|	ЗНАЧЕНИЕ(ПланВидовХарактеристик.СтатьиРасходов.ПустаяСсылка) КАК СтатьяРасходов,
		|	НЕОПРЕДЕЛЕНО КАК АналитикаРасходов,
		|	ЛОЖЬ КАК ЭтоПостатейные,
		|	ЛОЖЬ КАК ЭтоНЗП,
		|
		|	ЕСТЬNULL(ОтклоненияКРаспределению.ДопРасходыСНДС, 0) КАК ОтклоненияВСтоимостиСНДС,
		|	ЕСТЬNULL(ОтклоненияКРаспределению.ДопРасходыБезНДС, 0) КАК ОтклоненияВСтоимостиБезНДС,
		|	ЕСТЬNULL(ОтклоненияКРаспределению.ДопРасходыРегл, 0) КАК ОтклоненияВСтоимостиРегл,
		|	ЕСТЬNULL(ОтклоненияКРаспределению.ДопРасходыУпр, 0) КАК ОтклоненияВСтоимостиУпр,
		|	0 КАК ДопРасходыСНДС,
		|	0 КАК ДопРасходыБезНДС,
		|	0 КАК ДопРасходыРегл,
		|	0 КАК ДопРасходыУпр,
		|	ЕСТЬNULL(ОтклоненияКРаспределению.ПостояннаяРазница, 0) КАК ПостояннаяРазница,
		|	ЕСТЬNULL(ОтклоненияКРаспределению.СтоимостьНУ, 0) КАК СтоимостьНУ,
		|	ЕСТЬNULL(ОтклоненияКРаспределению.НДД, 0) КАК НДД,
		|
		|	Т.КоличествоНачальныйОстаток + Т.КоличествоПриход КАК Количество,
		|	Т.КоличествоНачальныйОстаток + Т.КоличествоПриход КАК КоличествоСНДС,
		|	Т.КоличествоНачальныйОстаток + Т.КоличествоПриход КАК КоличествоБезНДС,
		|	Т.КоличествоНачальныйОстаток + Т.КоличествоПриход КАК КоличествоРегл,
		|	Т.КоличествоНачальныйОстаток + Т.КоличествоПриход КАК КоличествоНУ,
		|	Т.КоличествоНачальныйОстаток + Т.КоличествоПриход КАК КоличествоУпр
		|
		|ПОМЕСТИТЬ ВтУзлыОтклоненийПредварительная
		|ИЗ
		|	ВтУзлыКорректировкиПрошлыхПериодов КАК Т
		|
		|	ЛЕВОЕ СОЕДИНЕНИЕ ВтОтклоненияКРаспределению КАК ОтклоненияКРаспределению
		|		ПО Т.ПериодРаспределения = ОтклоненияКРаспределению.ПериодОтклонения
		|		И Т.АналитикаУчетаНоменклатуры = ОтклоненияКРаспределению.АналитикаУчетаНоменклатуры
		|		И Т.РазделУчета = ОтклоненияКРаспределению.РазделУчета
		|		И Т.Организация = ОтклоненияКРаспределению.Организация
		|		И Т.ВидЗапасов = ОтклоненияКРаспределению.ВидЗапасов
		|		И Т.Партия = ОтклоненияКРаспределению.Партия
		|		И Т.АналитикаУчетаПартий = ОтклоненияКРаспределению.АналитикаУчетаПартий
		|		И Т.АналитикаФинансовогоУчета = ОтклоненияКРаспределению.АналитикаФинансовогоУчета
		|		И Т.ВидДеятельностиНДС = ОтклоненияКРаспределению.ВидДеятельностиНДС
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	""2"" КАК ЗапросИсточник,
		|	Т.НомерУзлаДопРасходы,
		|	Т.ПериодОтклонения,
		|	Т.ПериодРаспределения,
		|	Т.Организация КАК Организация,
		|	ЗНАЧЕНИЕ(Справочник.КлючиАналитикиУчетаНоменклатуры.ПустаяСсылка) КАК АналитикаУчетаНоменклатуры,
		|	НЕОПРЕДЕЛЕНО КАК Номенклатура,
		|	ЗНАЧЕНИЕ(Перечисление.РазделыУчетаСебестоимостиТоваров.ПустаяСсылка) КАК РазделУчета,
		|	ЗНАЧЕНИЕ(Справочник.ВидыЗапасов.ПустаяСсылка) КАК ВидЗапасов,
		|	Т.Партия КАК Партия,
		|	ЗНАЧЕНИЕ(Справочник.КлючиАналитикиУчетаПартий.ПустаяСсылка) КАК АналитикаУчетаПартий,
		|	НЕОПРЕДЕЛЕНО КАК АналитикаФинансовогоУчета,
		|	ЗНАЧЕНИЕ(Перечисление.ТипыНалогообложенияНДС.ПустаяСсылка) КАК ВидДеятельностиНДС,
		|
		|	Т.СтатьяКалькуляции КАК СтатьяКалькуляции,
		|	Т.Подразделение КАК Подразделение,
		|	Т.НаправлениеДеятельности КАК НаправлениеДеятельности,
		|	Т.СтатьяРасходов КАК СтатьяРасходов,
		|	Т.АналитикаРасходов КАК АналитикаРасходов,
		|	ИСТИНА КАК ЭтоПостатейные,
		|	Т.ЭтоНЗП,
		|
		|	Т.ОтклоненияВСтоимостиСНДС,
		|	Т.ОтклоненияВСтоимостиБезНДС,
		|	Т.ОтклоненияВСтоимостиРегл,
		|	Т.ОтклоненияВСтоимостиУпр,
		|
		|	Т.ДопРасходыСНДС,
		|	Т.ДопРасходыБезНДС,
		|	Т.ДопРасходыРегл,
		|	Т.ДопРасходыУпр,
		|	Т.ПостояннаяРазница,
		|	Т.СтоимостьНУ,
		|	Т.НДД,
		|
		|	0 КАК Количество,
		|	Т.КоличествоСНДС,
		|	Т.КоличествоБезНДС,
		|	Т.КоличествоРегл,
		|	Т.КоличествоНУ,
		|	Т.КоличествоУпр
		|ИЗ
		|	ВтУзлыОтклоненийПостатейные КАК Т
		|ГДЕ
		|	НЕ Т.Организация В (&ОрганизацииСреднескользящая)
		|
		|ИНДЕКСИРОВАТЬ ПО
		|	АналитикаУчетаНоменклатуры,
		|	Организация,
		|	Партия
