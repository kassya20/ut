		|	(ВЫБОР
		|		КОГДА Т.РазделУчета = ЗНАЧЕНИЕ(Перечисление.РазделыУчетаСебестоимостиТоваров.ВыпускПродукции)
		|		 И ВТУчетныеПолитикиФинУчета.УчетГотовойПродукцииПоПлановойСтоимости
		|		 И ВТУчетныеПолитикиФинУчета.СписыватьОтклоненияВСтоимостиПродукцииНаСебестоимостьПродаж
		|			ТОГДА ИСТИНА
		|		ИНАЧЕ ЛОЖЬ
		|	КОНЕЦ) // СписыватьОтклоненияНаСебестоимостьПродаж
		|ИМЕЮЩИЕ
		|	СУММА(Т.Количество) <> 0
		|
		|ИНДЕКСИРОВАТЬ ПО
		|	АналитикаУчетаНоменклатуры,
		|	Организация,
		|	Партия
		|";
КонецФункции	

Функция ТекстВтСписанияНаРасходыПоПериодам() // вт ВтСписанияНаРасходыПоПериодам
	Возврат "
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	Т.ПериодРаспределения,
		|	Т.Организация КАК Организация,
		|	Т.Подразделение КАК Подразделение,
		|	Т.КорНаправлениеДеятельности КАК НаправлениеДеятельности,
		|	Т.СтатьяРасходовСписания КАК СтатьяРасходов,
		|	Т.АналитикаРасходов КАК АналитикаРасходов
		|
		|ПОМЕСТИТЬ ВтСписанияНаРасходыПоПериодам
		|ИЗ
		|	ВтДвиженияСебестоимостиТоваровПоПериодамДетальные КАК Т
		|ГДЕ
		|	Т.СтатьяРасходовСписания <> НЕОПРЕДЕЛЕНО 
		|	И Т.СтатьяРасходовСписания <> ЗНАЧЕНИЕ(ПланВидовХарактеристик.СтатьиРасходов.ПустаяСсылка)
		|	И Т.СтатьяРасходовСписания <> ЗНАЧЕНИЕ(ПланВидовХарактеристик.СтатьиРасходов.ПогрешностьРасчетаСебестоимости)
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	НАЧАЛОПЕРИОДА(Т.Период, МЕСЯЦ) КАК ПериодРаспределения,
		|	Т.Организация КАК Организация,
		|	Т.КорПодразделение КАК Подразделение,
		|	Т.КорНаправлениеДеятельности КАК НаправлениеДеятельности,
		|	Т.КорСтатьяРасходов КАК СтатьяРасходов,
		|	Т.КорАналитикаРасходов КАК АналитикаРасходов
		|ИЗ
		|	РегистрНакопления.ПрочиеРасходы КАК Т
		|ГДЕ
		|	Т.Период МЕЖДУ &МинимальныйПрошлыйПериод И &КонецПредыдущегоПериода
		|	И Т.Организация В (&МассивОрганизаций)
		|	И Т.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход)
		|	И Т.КорСтатьяРасходов <> ЗНАЧЕНИЕ(ПланВидовХарактеристик.СтатьиРасходов.ПустаяСсылка)
		|";
КонецФункции

Функция ТекстВтИспользуемыеРасходыПоПериодам() // вт ВтИспользуемыеРасходыПоПериодам
	Возврат "
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	НАЧАЛОПЕРИОДА(Т.ПериодОтклонения, МЕСЯЦ) КАК ПериодРаспределения,
		|	Т.Организация КАК Организация,
		|	Т.Подразделение КАК Подразделение,
		|	Т.НаправлениеДеятельности КАК НаправлениеДеятельности,
		|	Т.СтатьяРасходов КАК СтатьяРасходов,
		|	Т.АналитикаРасходов КАК АналитикаРасходов
		|
		|ПОМЕСТИТЬ ВтИспользуемыеРасходыПоПериодамПредварительная
		|ИЗ
		|	ВтОтклоненияПрочиеРасходыКРаспределению КАК Т
		|ГДЕ
		|	(&СтатьяРасходовДляОтбора = НЕОПРЕДЕЛЕНО
		|		ИЛИ Т.СтатьяРасходов = &СтатьяРасходовДляОтбора)
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	Т.ПериодРаспределения,
		|	Т.Организация КАК Организация,
		|	Т.Подразделение КАК Подразделение,
		|	Т.НаправлениеДеятельности КАК НаправлениеДеятельности,
		|	Т.СтатьяРасходов КАК СтатьяРасходов,
		|	Т.АналитикаРасходов КАК АналитикаРасходов
		|ИЗ
		|	ВтСписанияНаРасходыПоПериодам КАК Т
		|ГДЕ
		|	(&СтатьяРасходовДляОтбора = НЕОПРЕДЕЛЕНО
		|		ИЛИ Т.СтатьяРасходов = &СтатьяРасходовДляОтбора)
		|
		|ИНДЕКСИРОВАТЬ ПО
		|	Организация,
		|	Подразделение,
		|	НаправлениеДеятельности,
		|	СтатьяРасходов,
		|	АналитикаРасходов
		|;
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	Т.ПериодРаспределения,
		|	Т.Организация КАК Организация,
		|	Т.Подразделение КАК Подразделение,
		|	Т.НаправлениеДеятельности КАК НаправлениеДеятельности,
		|	Т.СтатьяРасходов КАК СтатьяРасходов,
		|	Т.АналитикаРасходов КАК АналитикаРасходов
		|
		|ПОМЕСТИТЬ ВтИспользуемыеРасходыПоПериодам
		|ИЗ
		|	ВтИспользуемыеРасходыПоПериодамПредварительная КАК Т
		|
		|	ЛЕВОЕ СОЕДИНЕНИЕ УзлыКорректировкиДополнительныхРасходов КАК УзлыДопРасходов
		|		ПО УзлыДопРасходов.Организация = Т.Организация
		|		И УзлыДопРасходов.Подразделение = Т.Подразделение
		|		И УзлыДопРасходов.НаправлениеДеятельности = Т.НаправлениеДеятельности
		|		И УзлыДопРасходов.СтатьяРасходов = Т.СтатьяРасходов
		|		И УзлыДопРасходов.АналитикаРасходов = Т.АналитикаРасходов
		|		И УзлыДопРасходов.ПериодПоступления < &НачалоПериода
		|ГДЕ
		// Исключаем расходы, для которых есть база распределения по документу распределения расходов.
		// По таким расходам узлы формируются в запросе 3 по данным таблицы УзлыКорректировкиДополнительныхРасходов. 
		|	УзлыДопРасходов.Организация ЕСТЬ NULL
		|
		|ИНДЕКСИРОВАТЬ ПО
		|	Организация,
		|	Подразделение,
		|	НаправлениеДеятельности,
		|	СтатьяРасходов,
		|	АналитикаРасходов
		|;
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	Т.Организация КАК Организация,
		|	Т.СтатьяРасходов КАК СтатьяРасходов,
		|	Т.АналитикаРасходов КАК АналитикаРасходов
		|
		|ПОМЕСТИТЬ ВтИспользуемыеРасходыПоПериодамСвернутая
		|ИЗ
		|	ВтИспользуемыеРасходыПоПериодам КАК Т
		|
		|ИНДЕКСИРОВАТЬ ПО
		|	Организация,
		|	СтатьяРасходов,
		|	АналитикаРасходов
		|";
КонецФункции

Функция ТекстВтВыпускиПрошлыйПериод() // вт ВтВыпускиПрошлыйПериод
	Возврат "
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ДД.Период КАК Период,
		|	ДД.Регистратор КАК Регистратор,
		|	ДД.Организация,
		|	ДД.АналитикаУчетаНоменклатуры,
		|	ДД.РазделУчета,
		|	ДД.ВидЗапасов, 
		|	ДД.Партия,
		|	ДД.АналитикаУчетаПартий,
		|	ДД.АналитикаФинансовогоУчета,
		|	ДД.ВидДеятельностиНДС,
		|	ДД.ХозяйственнаяОперация,
		|	ДД.ИдентификаторФинЗаписи,
		|	ДД.НастройкаХозяйственнойОперации
		|
		|ПОМЕСТИТЬ ВтВыпускиПрошлыйПериод
		|ИЗ
		|	РегистрНакопления.СебестоимостьТоваров КАК ДД
		|	ВНУТРЕННЕЕ СОЕДИНЕНИЕ МинимальныеПериоды КАК МинимальныеПериоды
		|		ПО МинимальныеПериоды.Организация = ДД.Организация
		|		И МинимальныеПериоды.ПериодОтклонения <= ДД.Период
		|ГДЕ
		|	ДД.Период МЕЖДУ &МинимальныйПрошлыйПериод И &КонецПредыдущегоПериода
		|	И ДД.Организация В(&ОрганизацииСРаспределениемОтклоненийВПрошлыхПериодах)
		|	И ДД.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход)
		|	И ДД.ХозяйственнаяОперация В (
		|		ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.ВыпускПродукции),
		|		ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.ВыпускПродукцииНаСклад),
		|		ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.ВыпускПродукцииВПодразделение),
		|		ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.ПриемПередачаРаботМеждуФилиалами))
		|	И НЕ ДД.Сторно
		|
		|ИНДЕКСИРОВАТЬ ПО
		|	Период,
		|	Регистратор
		|";
КонецФункции

Функция ТекстВтДвиженияПрочиеРасходыПоПериодамПредварительная() // вт ВтДвиженияПрочиеРасходыПоПериодамПредварительная
	ТекстЗапроса = "";
	
	#Область РаспределениеРасходовНаСебестоимостьТоваров_1
	ТекстЗапроса = ТекстЗапроса + "
		// Распределение расходов на себестоимость товаров.
		|ВЫБРАТЬ
		|	""1"" КАК ЗапросИсточник,
		|	ЛОЖЬ КАК ЭтоТекущийПериод,
		|	ИСТИНА КАК ЕстьКорЧасть,
		|	НЕОПРЕДЕЛЕНО КАК Регистратор,
		|	&НачалоПериода КАК Период,
		|	Т.ПериодМесяц КАК ПериодРаспределения,
		// Измерения
		|	Т.Организация КАК Организация,
		|	Т.Подразделение КАК Подразделение,
		|	Т.НаправлениеДеятельности КАК НаправлениеДеятельности,
		|	Т.СтатьяРасходов КАК СтатьяРасходов,
		|	Т.АналитикаРасходов КАК АналитикаРасходов,
		|	НЕОПРЕДЕЛЕНО КАК Партия,
		// Кор реквизиты отклонений
		|	Себестоимость.Организация КАК КорОрганизация,
		|	ЕСТЬNULL(Себестоимость.АналитикаУчетаНоменклатуры.Номенклатура,
		|		ЗНАЧЕНИЕ(Справочник.Номенклатура.ПустаяСсылка)) КАК КорНоменклатура,
		|	ЕСТЬNULL(Себестоимость.АналитикаУчетаНоменклатуры.Характеристика,
		|		ЗНАЧЕНИЕ(Справочник.ХарактеристикиНоменклатуры.ПустаяСсылка)) КАК КорХарактеристика,
		|	Себестоимость.ВидЗапасов КАК КорВидЗапасов,
		|	ЗНАЧЕНИЕ(Справочник.НаправленияДеятельности.ПустаяСсылка) КорНаправлениеДеятельности,
		|	ЗНАЧЕНИЕ(Справочник.СтруктураПредприятия.ПустаяСсылка) КАК КорПодразделение,
		|	НЕОПРЕДЕЛЕНО КАК КорМестоХранения,
		// Кор реквизиты себестоимости
		|	Себестоимость.РазделУчета КАК КорРазделУчета,
		|	Себестоимость.АналитикаУчетаНоменклатуры КАК КорАналитикаУчетаНоменклатуры,
		|	Себестоимость.Партия КАК КорПартия,
		|	Себестоимость.АналитикаУчетаПартий КАК КорАналитикаУчетаПартий,
		|	Себестоимость.АналитикаФинансовогоУчета КАК КорАналитикаФинансовогоУчета,
		|	Себестоимость.ВидДеятельностиНДС КАК КорВидДеятельностиНДС,
		|
		|	ЗНАЧЕНИЕ(Справочник.КлючиАналитикиУчетаПоПартнерам.ПустаяСсылка) КАК АналитикаУчетаПоПартнерам,
		|	НЕОПРЕДЕЛЕНО КАК ЗаказКлиента,
		|	НЕОПРЕДЕЛЕНО КАК СтатьяКалькуляции,
		|	НЕОПРЕДЕЛЕНО  КАК ПравилоОтнесенияНаВыпуск,
		|	Т.КорСтатьяРасходов КАК КорСтатьяРасходов,
		|	Т.КорАналитикаРасходов КАК КорАналитикаРасходов,
		|	Т.ХозяйственнаяОперация КАК ХозяйственнаяОперация,
		|	Т.НастройкаХозяйственнойОперации КАК НастройкаХозяйственнойОперации,
		|	МИНИМУМ(Т.ИдентификаторФинЗаписи) КАК ИдентификаторФинЗаписи,
		|	СУММА(Т.Сумма) КАК СуммаСНДС,
		|	СУММА(Т.СуммаБезНДС) КАК СуммаБезНДС,
		|	СУММА(Т.СуммаРегл) КАК СуммаРегл,
		|	СУММА(Т.СуммаРегл - Т.ПостояннаяРазница - Т.ВременнаяРазница) КАК СуммаНУ,
		|	СУММА(Т.СуммаУпр) КАК СуммаУпр,
		|	СУММА(Т.СуммаНДД) КАК СуммаНДД
		|
		|ПОМЕСТИТЬ ВтДвиженияПрочиеРасходыПоПериодамПредварительная
		|ИЗ
		|	ВтПрочиеРасходыПрошлыйПериодКонецПериодаОграничен КАК Т
		|
		|	ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрНакопления.СебестоимостьТоваров КАК Себестоимость
		|		ПО Себестоимость.Период = Т.Период
		|		И Себестоимость.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход)
		|		И Себестоимость.Регистратор = Т.Регистратор
		|		И Себестоимость.НастройкаХозяйственнойОперации = Т.НастройкаХозяйственнойОперации		
		|		И Себестоимость.ИдентификаторФинЗаписи = Т.ИдентификаторФинЗаписи
		|		И Себестоимость.ДопРасходы = Т.Сумма
		|		И Себестоимость.ДопРасходыРегл = Т.СуммаРегл
		|		И Себестоимость.ДопРасходыУпр = Т.СуммаУпр
		|		И Себестоимость.СтоимостьНДД = Т.СуммаНДД
		|
		|ГДЕ
		|	НЕ Т.Организация В (&ОрганизацииСреднескользящая)
		|	И ТИПЗНАЧЕНИЯ(Т.Регистратор) <> ТИП(Документ.РегистраторРасчетаСебестоимости)
		|
		|СГРУППИРОВАТЬ ПО
		|	Т.ПериодМесяц,
		// Измерения
		|	Т.Организация,
		|	Т.Подразделение,
		|	Т.НаправлениеДеятельности,
		|	Т.СтатьяРасходов,
		|	Т.АналитикаРасходов,
		// Кор реквизиты отклонений
		|	Себестоимость.Организация,
		|	ЕСТЬNULL(Себестоимость.АналитикаУчетаНоменклатуры.Номенклатура,
		|		ЗНАЧЕНИЕ(Справочник.Номенклатура.ПустаяСсылка)), // КорНоменклатура
		|	ЕСТЬNULL(Себестоимость.АналитикаУчетаНоменклатуры.Характеристика,
		|		ЗНАЧЕНИЕ(Справочник.ХарактеристикиНоменклатуры.ПустаяСсылка)), // КорХарактеристика
		|	Себестоимость.ВидЗапасов, // КорВидЗапасов
		// // Кор реквизиты себестоимости
		|	Себестоимость.РазделУчета,
		|	Себестоимость.АналитикаУчетаНоменклатуры,
		|	Себестоимость.Партия,
		|	Себестоимость.АналитикаУчетаПартий,
		|	Себестоимость.АналитикаФинансовогоУчета,
		|	Себестоимость.ВидДеятельностиНДС,
		|
		|	Т.КорПодразделение,
		|	Т.КорНаправлениеДеятельности,
		|	Т.КорСтатьяРасходов,
		|	Т.КорАналитикаРасходов,
		|	Т.ХозяйственнаяОперация,
		|	Т.НастройкаХозяйственнойОперации
		|ИМЕЮЩИЕ
		|	СУММА(Т.Сумма) <> 0
		|	ИЛИ СУММА(Т.СуммаБезНДС) <> 0
		|	ИЛИ СУММА(Т.СуммаРегл) <> 0
		|	ИЛИ СУММА(Т.ПостояннаяРазница) <> 0
		|	ИЛИ СУММА(Т.ВременнаяРазница) <> 0
		|	ИЛИ СУММА(Т.СуммаУпр) <> 0
		|	ИЛИ СУММА(Т.СуммаНДД) <> 0
		|";
	#КонецОбласти
	
	#Область РаспределениеРасходовНаСебестоимостьТоваровСреднескользящая_2
	ТекстЗапроса = ТекстЗапроса + "
		|ОБЪЕДИНИТЬ ВСЕ
		|
		// Распределение расходов на себестоимость товаров при среднескользящей.
		|ВЫБРАТЬ
		|	""2"" КАК ЗапросИсточник,
		|	ЛОЖЬ КАК ЭтоТекущийПериод,
		|	ИСТИНА КАК ЕстьКорЧасть,
		|	НЕОПРЕДЕЛЕНО КАК Регистратор,
