		|	ВЫРАЗИТЬ(Т.КоличествоРегл / ЕСТЬNULL(КоэффициентыПриведения.КоэффициентРегл, 1) КАК ЧИСЛО (23,10)) КАК КоличествоРегл,
		|	ВЫРАЗИТЬ(Т.КоличествоНУ / ЕСТЬNULL(КоэффициентыПриведения.КоэффициентНУ, 1) КАК ЧИСЛО (23,10)) КАК КоличествоНУ,
		|	ВЫРАЗИТЬ(Т.КоличествоУпр / ЕСТЬNULL(КоэффициентыПриведения.КоэффициентУпр, 1) КАК ЧИСЛО (23,10)) КАК КоличествоУпр
