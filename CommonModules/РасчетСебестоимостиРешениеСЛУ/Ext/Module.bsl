		|	СУММА(Т.СуммаБезНДС) КАК КоличествоБезНДС,
		|	СУММА(Т.СуммаРегл)   КАК КоличествоРегл,
		|	СУММА(Т.СуммаНУ)     КАК КоличествоНУ,
		|	СУММА(Т.СуммаУпр)    КАК КоличествоУпр
		|ИЗ
		|	ВтДвиженияПрочиеРасходыПоПериодам КАК Т
		|
		|	ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТУзлыОтклонений КАК УзлыПриемники
		|		ПО УзлыПриемники.Организация = Т.Организация
		|		И УзлыПриемники.Подразделение = Т.КорПодразделение
		|		И УзлыПриемники.НаправлениеДеятельности = Т.КорНаправлениеДеятельности
		|		И УзлыПриемники.СтатьяРасходов = Т.КорСтатьяРасходов
		|		И УзлыПриемники.АналитикаРасходов = Т.КорАналитикаРасходов	
		|		И УзлыПриемники.Партия = НЕОПРЕДЕЛЕНО
		|		И УзлыПриемники.ПериодРаспределения = Т.ПериодРаспределения
		|ГДЕ
		|	Т.ЕстьКорЧасть
		|	И Т.КорНоменклатура = НЕОПРЕДЕЛЕНО
		|	И Т.КорПартия = НЕОПРЕДЕЛЕНО
		|	И Т.КорСтатьяРасходов <> ЗНАЧЕНИЕ(ПланВидовХарактеристик.СтатьиРасходов.ПустаяСсылка)
		|
		|СГРУППИРОВАТЬ ПО
		|	Т.НомерУзла,
		|	УзлыПриемники.НомерУзла,
		|	Т.СтатьяРасходов,
		|	Т.КорСтатьяРасходов,
		|	Т.ПериодРаспределения,
		|	УзлыПриемники.ПериодРаспределения
		|
		|УПОРЯДОЧИТЬ ПО
		|	НомерУзлаИсточник,
		|	НомерУзлаПриемник
		|";
КонецФункции

Функция ТекстВтСвязиОтклонений() // вт ВтСвязиОтклонений, использует ВТСвязиОтклоненийПредварительная
	Возврат "
		|ВЫБРАТЬ
		|	Т.НомерУзлаИсточник КАК НомерУзлаИсточник,
		|	Т.НомерУзлаПриемник,
		|	Т.АналитикаУчетаНоменклатуры,
		|	Т.Номенклатура,
		|	Т.СтатьяРасходов,
		|	Т.КорАналитикаУчетаНоменклатуры,
		|	Т.КорНоменклатура,
		|	Т.СтатьяРасходовСписания,
		|	Т.ПериодРаспределенияИсточник,
		|	Т.ПериодРаспределенияПриемник,
		|	Т.ЭтоОстатки,
		|	СУММА(Т.Количество) КАК Количество,
		|	СУММА(Т.КоличествоСНДС) КАК КоличествоСНДС,
		|	СУММА(Т.КоличествоБезНДС) КАК КоличествоБезНДС,
		|	СУММА(Т.КоличествоРегл) КАК КоличествоРегл,
		|	СУММА(Т.КоличествоНУ) КАК КоличествоНУ,
		|	СУММА(Т.КоличествоУпр) КАК КоличествоУпр
		|
		|ПОМЕСТИТЬ ВтСвязиОтклонений
		|ИЗ
		|	ВТСвязиОтклоненийПредварительная КАК Т
		|ГДЕ
		|	Т.НомерУзлаИсточник <> Т.НомерУзлаПриемник
		|СГРУППИРОВАТЬ ПО
		|	Т.НомерУзлаИсточник,
		|	Т.НомерУзлаПриемник,
		|	Т.АналитикаУчетаНоменклатуры,
		|	Т.Номенклатура,
		|	Т.СтатьяРасходов,
		|	Т.КорАналитикаУчетаНоменклатуры,
		|	Т.КорНоменклатура,
		|	Т.СтатьяРасходовСписания,
		|	Т.ПериодРаспределенияИсточник,
		|	Т.ПериодРаспределенияПриемник,
		|	Т.ЭтоОстатки
		|
		|ИНДЕКСИРОВАТЬ ПО
		|	НомерУзлаИсточник
		|";
КонецФункции

Функция ТекстУзлыСЛУ_РасчетСебестоимостиПрошлыхПериодов() // вт УзлыСЛУ_РасчетСебестоимостиПрошлыхПериодов
	Возврат "
		|ВЫБРАТЬ
		|	Т.НомерУзла КАК НомерУзла,
		|	Т.ОтклоненияВСтоимостиСНДС КАК ОтклоненияВСтоимостиСНДС,
		|	Т.ОтклоненияВСтоимостиБезНДС КАК ОтклоненияВСтоимостиБезНДС,
		|	Т.ОтклоненияВСтоимостиРегл КАК ОтклоненияВСтоимостиРегл,
		|	Т.ОтклоненияВСтоимостиУпр КАК ОтклоненияВСтоимостиУпр,
		|	Т.ДопРасходыСНДС КАК ДопРасходыСНДС,
		|	Т.ДопРасходыБезНДС КАК ДопРасходыБезНДС,
		|	Т.ДопРасходыРегл КАК ДопРасходыРегл,
		|	Т.ДопРасходыУпр КАК ДопРасходыУпр,
		|	Т.ПостояннаяРазница КАК ПостояннаяРазница,
		|	Т.СтоимостьНУ КАК СтоимостьНУ,
		|	Т.НДД КАК НДД
		|
		|ПОМЕСТИТЬ УзлыСЛУ_РасчетСебестоимостиПрошлыхПериодов
		|ИЗ
		|	ВтУзлыОтклонений КАК Т
		|";
КонецФункции

Функция ТекстСвязиСЛУ_РасчетСебестоимостиПрошлыхПериодов() // вт СвязиСЛУ_РасчетСебестоимостиПрошлыхПериодов
	Возврат "
		|ВЫБРАТЬ
		|	Связи.НомерУзлаИсточник КАК НомерУзлаИсточник,
		|	Связи.НомерУзлаПриемник КАК НомерУзлаПриемник,
		|
		|	-Связи.КоличествоСНДС КАК ВесДугиСНДС,
		|	-Связи.КоличествоБезНДС КАК ВесДугиБезНДС,
		|	-Связи.КоличествоРегл КАК ВесДугиРегл,
		|	-Связи.КоличествоНУ КАК ВесДугиНУ,
		|	-Связи.КоличествоУпр КАК ВесДугиУпр
		|
		|ПОМЕСТИТЬ СвязиСЛУ_РасчетСебестоимостиПрошлыхПериодов
		|ИЗ
		|	ВтСвязиОтклонений КАК Связи
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	Узлы.НомерУзла КАК НомерУзлаИсточник,
		|	Узлы.НомерУзла КАК НомерУзлаПриемник,
		|
		|	ВЫРАЗИТЬ(Узлы.КоличествоСНДС КАК ЧИСЛО(28,10)) КАК ВесДугиСНДС,
		|	ВЫРАЗИТЬ(Узлы.КоличествоБезНДС КАК ЧИСЛО(28,10)) КАК ВесДугиБезНДС,
		|	ВЫРАЗИТЬ(Узлы.КоличествоРегл КАК ЧИСЛО(28,10)) КАК ВесДугиРегл,
		|	ВЫРАЗИТЬ(Узлы.КоличествоНУ КАК ЧИСЛО(28,10)) КАК ВесДугиНУ,
		|	ВЫРАЗИТЬ(Узлы.КоличествоУпр КАК ЧИСЛО(28,10)) КАК ВесДугиУпр
		|ИЗ
		|	ВтУзлыОтклонений КАК Узлы
		|";
КонецФункции

#КонецОбласти

#Область ПроцедурыЭтапа_ПодготовкаДанныхДляРешенияСЛУ_РасчетСебестоимостиПрошлыхПериодов_ПостояннаяРазница

Процедура ПодготовкаДанныхДляРешенияСЛУ_РасчетСебестоимостиПрошлыхПериодов_ПостояннаяРазница(ПараметрыРасчета)
	
	РасчетСебестоимостиПротоколРасчета.НачалоЭтапаРасчета(ПараметрыРасчета, "ПодготовкаДанныхДляРешенияСЛУ_РасчетСебестоимостиПрошлыхПериодов_ПостояннаяРазница");
	
	// 1. Инициализация структуры данных этапа подготовки данных.
	РасчетСебестоимостиПрикладныеАлгоритмы.ИнициализироватьПодготовкуДанныхДляСледующихЭтапов(
		ПараметрыРасчета,
		"УзлыСЛУ_РасчетСебестоимостиПрошлыхПериодов_ПостояннаяРазница");
		
	// 2. Формирование временных таблиц.
	РасчетСебестоимостиПрикладныеАлгоритмы.ПодготовитьДанныеДляСледующихЭтапов(
		ПараметрыРасчета,
		ТекстЗапросаДляРешенияСЛУОтклоненияПостояннаяРазница(ПараметрыРасчета));
	
	// 3. Завершаем этап подготовки данных. 
	РасчетСебестоимостиПрикладныеАлгоритмы.ЗавершитьПодготовкуДанныхДляСледующихЭтапов(ПараметрыРасчета);
	
КонецПроцедуры

Функция ТекстЗапросаДляРешенияСЛУОтклоненияПостояннаяРазница(ПараметрыРасчета = Неопределено) Экспорт
	
	ТекстЗапроса = ""
		// подготовка временных таблиц
		+ ТекстНачальнаяСтоимостьОтклоненияПостояннаяРазница() // вт НачальнаяСтоимостьПостояннаяРазница
		+ ОбщегоНазначения.РазделительПакетаЗапросов() + ТекстУзлыСЛУ_РасчетСебестоимостиПрошлыхПериодов_ПостояннаяРазница() // вт ВтУзлыКорректировкиПостояннаяРазница
		+ "";
	
	Если ПараметрыРасчета <> Неопределено Тогда
		ТекстЗапроса = РасчетСебестоимостиКорректировкаСтоимости.УстановитьРазрядностьЧиселВТекстеЗапроса(ПараметрыРасчета, ТекстЗапроса);
	КонецЕсли;
	
	Возврат ТекстЗапроса;
	
КонецФункции

Функция ТекстНачальнаяСтоимостьОтклоненияПостояннаяРазница() // вт НачальнаяСтоимостьОтклоненияПостояннаяРазница
	Возврат "
		|ВЫБРАТЬ
		|	УзлыКорректировки.НомерУзла КАК НомерУзла,
		|
		// Постоянная разница по расходам, не принимаемым к налоговому учету.
		|	ВЫРАЗИТЬ(СУММА(ВЫБОР
		|		КОГДА НЕ Статьи.ПринятиеКНалоговомуУчету
		|			ТОГДА ЕСТЬNULL(ТаблицаРешений.СтоимостьНУ, 0)
		|				* ЕСТЬNULL(Связи.КоличествоРегл, 0)
		|		ИНАЧЕ 0 КОНЕЦ) КАК ЧИСЛО(28,10)) КАК ПостояннаяРазница
		|
		|ПОМЕСТИТЬ НачальнаяСтоимостьОтклоненияПостояннаяРазница
		|ИЗ
		|	ВтУзлыОтклонений КАК УзлыКорректировки
		|
		|	ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВтСвязиОтклонений КАК Связи
		|		ПО УзлыКорректировки.НомерУзла = Связи.НомерУзлаПриемник
		|
		|	ВНУТРЕННЕЕ СОЕДИНЕНИЕ ПланВидовХарактеристик.СтатьиРасходов КАК Статьи
		|		ПО Статьи.Ссылка = Связи.СтатьяРасходовСписания
		|
		|	ЛЕВОЕ СОЕДИНЕНИЕ РезультатРасчетаНУ КАК ТаблицаРешений
		|		ПО ТаблицаРешений.НомерУзла = Связи.НомерУзлаИсточник
		|
		|СГРУППИРОВАТЬ ПО
		|	УзлыКорректировки.НомерУзла
		|
		|ИНДЕКСИРОВАТЬ ПО
		|	НомерУзла
		|";
КонецФункции	

Функция ТекстУзлыСЛУ_РасчетСебестоимостиПрошлыхПериодов_ПостояннаяРазница() // вт УзлыСЛУ_РасчетСебестоимостиПрошлыхПериодов_ПостояннаяРазница
	Возврат "
		|ВЫБРАТЬ
		|	УзлыКорректировки.НомерУзла КАК НомерУзла,
		|	ВЫРАЗИТЬ(ЕСТЬNULL(УзлыКорректировки.ПостояннаяРазница, 0)
		|		+ ЕСТЬNULL(НачальнаяСтоимость.ПостояннаяРазница, 0) КАК ЧИСЛО(28, 10)) КАК ПостояннаяРазница
		|
		|ПОМЕСТИТЬ УзлыСЛУ_РасчетСебестоимостиПрошлыхПериодов_ПостояннаяРазница
		|ИЗ
		|	ВтУзлыОтклонений КАК УзлыКорректировки
		|
		|	ЛЕВОЕ СОЕДИНЕНИЕ НачальнаяСтоимостьОтклоненияПостояннаяРазница КАК НачальнаяСтоимость
		|		ПО НачальнаяСтоимость.НомерУзла = УзлыКорректировки.НомерУзла
		|
		|ИНДЕКСИРОВАТЬ ПО
		|	НомерУзла
		|";
КонецФункции

#КонецОбласти

#Область ПроцедурыЭтапа_ПодготовкаДанныхДляРешенияСЛУ_ОтклоненияВСтоимостиТоваров

// Этап "ПодготовкаДанныхДляРешенияСЛУ_РасчетСебестоимостиПрошлыхПериодов"
//
// Параметры:
//	ПараметрыРасчета - Структура - параметры расчета себестоимости
//
Процедура ПодготовкаДанныхДляРешенияСЛУ_ОтклоненияВСтоимостиТоваров(ПараметрыРасчета) Экспорт
	
	РасчетСебестоимостиПротоколРасчета.НачалоЭтапаРасчета(ПараметрыРасчета, "ПодготовкаДанныхДляРешенияСЛУ_ОтклоненияВСтоимостиТоваров");
	
	// 1. Инициализация структуры данных этапа подготовки данных.
	РасчетСебестоимостиПрикладныеАлгоритмы.ИнициализироватьПодготовкуДанныхДляСледующихЭтапов(
		ПараметрыРасчета,
		"ВтДвиженияСебестоимостиТоваровПоПериодам, ВтДвиженияСебестоимостиТоваровПоПериодамДетальные,
		|ВтДвиженияПрочиеРасходыПоПериодам,
		|ВтОстаткиОтклоненийНаНачалоПериодаДетальные, ВТСвязиОтклоненийПредварительная,
		|ВтСвязиРаспределениеДопРасходов, ВтСвязиРаспределениеПостатейныхНаВыпуск,
		|ВтУзлыПрочиеРасходыНЗП,
		|ВТУзлыОтклонений, ВТСвязиОтклонений");
	
	Запрос = Новый Запрос;
	РасчетСебестоимостиПрикладныеАлгоритмы.ИнициализироватьСвойстваЗапроса(Запрос, ПараметрыРасчета);
	
	#Область МинимальныйПериод
	Запрос.Текст = "
	|ВЫБРАТЬ
	|	МИНИМУМ(НАЧАЛОПЕРИОДА(Т.МинимальныйПериод, МЕСЯЦ)) КАК МинимальныйПериод
	|ИЗ (
	|	ВЫБРАТЬ
	|		МИНИМУМ(Т.ПериодОтклонения) КАК МинимальныйПериод
	|	ИЗ
	|		ВТКэшРасчетныеОборотыОтклоненияВСтоимостиТоваров КАК Т
	|	ГДЕ
	|		Т.СлужебноеВидДвиженияПриход
	|		И Т.ПериодОтклонения <> ДАТАВРЕМЯ(1,1,1)
	|
	|	ОБЪЕДИНИТЬ ВСЕ
	|
	|	ВЫБРАТЬ
	|		МИНИМУМ(Т.ПериодОтклонения) КАК МинимальныйПериод
	|	ИЗ
	|		ВтСторноОтклоненийПрошлогоПериода КАК Т
	|	ГДЕ
	|		Т.ПериодОтклонения <> ДАТАВРЕМЯ(1,1,1)
	|
	|	ОБЪЕДИНИТЬ ВСЕ
	|
	|	ВЫБРАТЬ
	|		НАЧАЛОПЕРИОДА(ДД.ПериодОтклонения, МЕСЯЦ) КАК МинимальныйПериод
	|	ИЗ
	|		ВТКэшРасчетныеОборотыПрочиеРасходы КАК ДД
	|	ГДЕ
	|		ДД.ПериодОтклонения <> ДАТАВРЕМЯ(1,1,1)
	|		И ДД.ПериодОтклонения < &НачалоПериода
	|
	|	ОБЪЕДИНИТЬ ВСЕ
	|
	|	ВЫБРАТЬ
	|		НАЧАЛОПЕРИОДА(ДД.ПериодПоступления, МЕСЯЦ) КАК МинимальныйПериод
	|	ИЗ
	|		ДолиДополнительныхРасходов КАК ДД
	|	ГДЕ
	|		ДД.ПериодПоступления <> ДАТАВРЕМЯ(1,1,1)
	|		И ДД.ПериодПоступления < &НачалоПериода
	|) КАК Т
	|";
	
	РезультатЗапроса = РасчетСебестоимостиПрикладныеАлгоритмы.ВыполнитьЗапросСЗамеромДляПротокола(ПараметрыРасчета, Запрос, Истина,, Истина);
	Выборка = РезультатЗапроса.Выбрать();
	
	НачалоПериода = ПараметрыРасчета.РасчетныйПериод.НачалоПериода;
	Если Выборка.Следующий() Тогда
		МинимальныйПериод = ?(ЗначениеЗаполнено(Выборка.МинимальныйПериод), Выборка.МинимальныйПериод, НачалоПериода);
	Иначе
		МинимальныйПериод = НачалоПериода; 
	КонецЕсли;
	
	#КонецОбласти
	
	#Область ПоследниеНомераУзлов
	Запрос.Текст = "
	|ВЫБРАТЬ
	|	МАКСИМУМ(ЕСТЬNULL(Т.НомерУзлаДопРасходы, 0)) КАК НомерУзлаДопРасходы,
	|	МАКСИМУМ(ЕСТЬNULL(Т.НомерУзлаПостатейные, 0)) КАК НомерУзлаПостатейные
	|ИЗ (
	|	ВЫБРАТЬ
	|		МАКСИМУМ(Т.НомерУзла) КАК НомерУзлаДопРасходы,
	|		0 КАК НомерУзлаПостатейные
	|	ИЗ
	|		УзлыКорректировкиДополнительныхРасходов КАК Т
	|
	|	) КАК Т
	|;
	|";
	РезультатЗапроса = РасчетСебестоимостиПрикладныеАлгоритмы.ВыполнитьЗапросСЗамеромДляПротокола(ПараметрыРасчета, Запрос, Истина,, Истина);
	Выборка = РезультатЗапроса.Выбрать();
	
	НачалоПериода = ПараметрыРасчета.РасчетныйПериод.НачалоПериода;
	Если Выборка.Следующий() Тогда
		ПоследнийНомерУзла = Макс(Выборка.НомерУзлаДопРасходы, Выборка.НомерУзлаПостатейные);
	Иначе
		ПоследнийНомерУзла = 0; 
	КонецЕсли;
	
	#КонецОбласти
	
	ДопПараметры = ПараметрыРасчета.ДополнительныеПараметрыЗапросаЭтапа;
	ДопПараметры.Вставить("МинимальныйПериод", МинимальныйПериод);
	ДопПараметры.Вставить("МинимальныйПрошлыйПериод", Мин(МинимальныйПериод, ПараметрыРасчета.РасчетныйПериод.КонецПредыдущегоПериода));
	ДопПараметры.Вставить("ПоследнийНомерУзла", ПоследнийНомерУзла);
	
	// 2. Формирование временных таблиц.
	РасчетСебестоимостиПрикладныеАлгоритмы.ПодготовитьДанныеДляСледующихЭтапов(
		ПараметрыРасчета,
		ТекстЗапросаДляРешенияСЛУ_ОтклоненияВСтоимостиТоваров(ПараметрыРасчета));
	
	// 3. Завершаем этап подготовки данных. 
	РасчетСебестоимостиПрикладныеАлгоритмы.ЗавершитьПодготовкуДанныхДляСледующихЭтапов(ПараметрыРасчета);
	
	РасчетСебестоимостиПрикладныеАлгоритмы.УничтожитьВременныеТаблицы(ПараметрыРасчета, 
		"ВтДвиженияПрочиеРасходыПоПериодамПредварительная");
	
КонецПроцедуры

// Формирование текста запроса для расчета себестоимости прошлых периодов.
//
// Параметры:
//	ПараметрыРасчета - Структура - параметры расчета себестоимости
//	
// Возвращаемое значение:
// 	Строка - текст запроса
//
Функция ТекстЗапросаДляРешенияСЛУ_ОтклоненияВСтоимостиТоваров(ПараметрыРасчета = Неопределено) Экспорт
	
	ТекстыЗапросов = Новый Массив;
	ТекстыЗапросов.Добавить(ТекстВтОтклоненияКРаспределению()); // ВтОтклоненияКРаспределению
	ТекстыЗапросов.Добавить(ТекстВтДвиженияСебестоимостиТоваровПоПериодамДетальныеОтклонения()); // ВтДвиженияСебестоимостиТоваровПоПериодамДетальные
	ТекстыЗапросов.Добавить(ТекстВтДвиженияСебестоимостиТоваровПоПериодамСвернутые()); // ВтДвиженияСебестоимостиТоваровПоПериодамСвернутые
	ТекстыЗапросов.Добавить(ТекстВтСторноПеремещенийПрошлогоПериода()); // ВтСторноПеремещенийПрошлогоПериода
	ТекстыЗапросов.Добавить(ТекстВтЕстьДвиженияТоваров()); // ВтЕстьДвиженияТоваров
	ТекстыЗапросов.Добавить(ТекстВтУзлыКорректировкиПрошлыхПериодовПредварительнаяОтклонения()); // ВтУзлыКорректировкиПрошлыхПериодовПредварительная
	ТекстыЗапросов.Добавить(ТекстВтУзлыКорректировкиПрошлыхПериодовСгруппированнаяОтклонения()); // ВтУзлыКорректировкиПрошлыхПериодовСгруппированная
	ТекстыЗапросов.Добавить(ТекстВтУзлыКорректировкиПрошлыхПериодовОтклонения()); // ВтУзлыКорректировкиПрошлыхПериодов
	ТекстыЗапросов.Добавить(ТекстВтУзлыКорректировкиТекущегоПериода()); // ВтУзлыКорректировкиТекущегоПериода
	ТекстыЗапросов.Добавить(ТекстВтОстаткиОтклоненийНаНачалоПериода()); // ВтОстаткиОтклоненийНаНачалоПериодаДетальные, ВтОстаткиОтклоненийНаНачалоПериода
	ТекстыЗапросов.Добавить(ТекстВТУзлыОтклоненийПредварительнаяОтклонения()); // ВТУзлыОтклоненийПредварительная
	ТекстыЗапросов.Добавить(ТекстВТУзлыОтклоненийПронумерованнаяОтклонения()); // ВТУзлыОтклоненийПронумерованная
	ТекстыЗапросов.Добавить(ТекстКоэффициентыПриведенияУзловОтклонений()); // вт КоэффициентыПриведенияУзловОтклонений
	ТекстыЗапросов.Добавить(ТекстВТУзлыОтклоненийОтклонения()); // ВТУзлыОтклонений
	ТекстыЗапросов.Добавить(ТекстВтУзлыПрочиеРасходыНЗП()); // ВтУзлыПрочиеРасходыНЗП
	
	ТекстыЗапросов.Добавить(ТекстВтДвиженияСебестоимостиТоваровПоПериодамОтклонения()); // ВтДвиженияСебестоимостиТоваровПоПериодам
	ТекстыЗапросов.Добавить(ТекстВтДвиженияПрочиеРасходыПоПериодам()); // вт ВтДвиженияПрочиеРасходыПоПериодам
	
	ТекстыЗапросовСвязи = Новый Массив;
	ТекстыЗапросовСвязи.Добавить(ТекстВтСвязиДвиженияСебестоимостиТоваровПоПериодам()); // использует ВтДвиженияСебестоимостиТоваровПоПериодам
	ТекстыЗапросовСвязи.Добавить(ТекстСписаниеНоменклатурыНаПостатейныеРасходы()); // использует ВтДвиженияСебестоимостиТоваровПоПериодам
	ТекстыЗапросовСвязи.Добавить(ТекстСвязиСебестоимостиТоваровМеждуПериодамиОтклонения()); // использует ВтУзлыКорректировкиПрошлыхПериодов
	ТекстыЗапросовСвязи.Добавить(ТекстСвязиПрочихРасходовМеждуПериодами()); // использует ВтУзлыРасходовПрошлыхПериодов
	ТекстыЗапросовСвязи.Добавить(ТекстРаспределениеРасходовНаСебестоимостьТоваровОтклонения()); // использует ВтДвиженияПрочиеРасходыПоПериодам
	
	ТекстыЗапросовСвязи.Добавить(ТекстРаспределениеРасходовНаДругиеСтатьиРасходов()); // использует ВтДвиженияПрочиеРасходыПоПериодам
	ТекстВТСвязиОтклоненийПредварительная = СтрСоединить(ТекстыЗапросовСвязи, ОбщегоНазначения.ТекстОбъединитьВсе());
	ТекстВТСвязиОтклоненийПредварительная = ТекстВТСвязиОтклоненийПредварительная + "
	|ИНДЕКСИРОВАТЬ ПО
	|	НомерУзлаИсточник
	|";
	
	ТекстыЗапросов.Добавить(ТекстВТСвязиОтклоненийПредварительная); // вт ВТСвязиОтклоненийПредварительная
	ТекстыЗапросов.Добавить(ТекстВТСвязиОтклонений()); // ВТСвязиОтклонений
	
	ТекстЗапроса = СтрСоединить(ТекстыЗапросов, ОбщегоНазначения.РазделительПакетаЗапросов());	
	Если ПараметрыРасчета <> Неопределено Тогда
		ТекстЗапроса = РасчетСебестоимостиКорректировкаСтоимости.УстановитьРазрядностьЧиселВТекстеЗапроса(ПараметрыРасчета, ТекстЗапроса);
	КонецЕсли;
	
	Возврат ТекстЗапроса;
	
КонецФункции

Функция ТекстВтОтклоненияКРаспределению() // ВтОтклоненияКРаспределению
	Возврат "
		|ВЫБРАТЬ
		|	Т.ПериодОтклонения КАК ПериодОтклонения,
		|	Т.РазделУчета КАК РазделУчета,
		|	Т.Организация КАК Организация,
		|	Т.Номенклатура КАК Номенклатура,
		|	Т.Характеристика КАК Характеристика,
		|	Т.ВидЗапасов КАК ВидЗапасов,
		|	Т.НаправлениеДеятельности КАК НаправлениеДеятельности,
		|	Т.Подразделение КАК Подразделение,
		|	Т.МестоХранения КАК МестоХранения,
		|	Т.Сторно КАК Сторно,
		|	СУММА(Т.ОтклоненияВСтоимостиСНДС) КАК ОтклоненияВСтоимостиСНДС,
		|	СУММА(Т.ОтклоненияВСтоимостиБезНДС) КАК ОтклоненияВСтоимостиБезНДС,
		|	СУММА(Т.ОтклоненияВСтоимостиРегл) КАК ОтклоненияВСтоимостиРегл,
		|	СУММА(Т.ОтклоненияВСтоимостиУпр) КАК ОтклоненияВСтоимостиУпр,
		|	СУММА(Т.ДопРасходыСНДС) КАК ДопРасходыСНДС,
		|	СУММА(Т.ДопРасходыБезНДС) КАК ДопРасходыБезНДС,
		|	СУММА(Т.ДопРасходыРегл) КАК ДопРасходыРегл,
		|	СУММА(Т.ДопРасходыУпр) КАК ДопРасходыУпр,
		|	СУММА(Т.НДСРегл) КАК НДСРегл,
		|	СУММА(Т.НДСУпр) КАК НДСУпр,
		|	СУММА(Т.ПостояннаяРазница) КАК ПостояннаяРазница,
		|	СУММА(Т.ВременнаяРазница) КАК ВременнаяРазница,
		|	СУММА(Т.СтоимостьНУ) КАК СтоимостьНУ,
		|	СУММА(Т.НДД) КАК НДД
		|
		|ПОМЕСТИТЬ ВтОтклоненияКРаспределению
		|ИЗ (
		|	ВЫБРАТЬ
		|		Т.ПериодОтклонения КАК ПериодОтклонения,
		|		ЗНАЧЕНИЕ(Перечисление.РазделыУчетаСебестоимостиТоваров.ПустаяСсылка) КАК РазделУчета,
		|		Т.Организация КАК Организация,
		|		Т.Номенклатура КАК Номенклатура,
		|		Т.Характеристика КАК Характеристика,
		|		Т.ВидЗапасов КАК ВидЗапасов,
		|		Т.НаправлениеДеятельности КАК НаправлениеДеятельности,
		|		Т.Подразделение КАК Подразделение,
		|		Т.МестоХранения КАК МестоХранения,
		|		Т.Сторно,
		|		Т.ОтклоненияВСтоимостиСНДС КАК ОтклоненияВСтоимостиСНДС,
		|		Т.ОтклоненияВСтоимостиБезНДС КАК ОтклоненияВСтоимостиБезНДС,
		|		Т.ОтклоненияВСтоимостиРегл КАК ОтклоненияВСтоимостиРегл,
		|		Т.ОтклоненияВСтоимостиУпр КАК ОтклоненияВСтоимостиУпр,
		|		Т.ДопРасходыСНДС КАК ДопРасходыСНДС,
		|		Т.ДопРасходыБезНДС КАК ДопРасходыБезНДС,
		|		Т.ДопРасходыРегл КАК ДопРасходыРегл,
		|		Т.ДопРасходыУпр КАК ДопРасходыУпр,
		|		Т.НДСРегл КАК НДСРегл,
		|		Т.НДСУпр КАК НДСУпр,
		|		Т.ПостояннаяРазница КАК ПостояннаяРазница,
		|		Т.ВременнаяРазница КАК ВременнаяРазница,
		|		Т.ОтклоненияВСтоимостиРегл + Т.ДопРасходыРегл + Т.НДСРегл - Т.ПостояннаяРазница - Т.ВременнаяРазница КАК СтоимостьНУ,
		|		Т.НДД КАК НДД
		|	ИЗ
		|		ВТКэшРасчетныеОборотыОтклоненияВСтоимостиТоваров КАК Т
		|	ГДЕ
		|		Т.СлужебноеВидДвиженияПриход
		|
		|	ОБЪЕДИНИТЬ ВСЕ
		|
		|	ВЫБРАТЬ
		|		Т.ПериодОтклонения КАК ПериодОтклонения,
		|		Т.РазделУчета КАК РазделУчета,
		|		Т.Организация КАК Организация,
		|		Т.Номенклатура КАК Номенклатура,
		|		Т.Характеристика КАК Характеристика,
		|		Т.ВидЗапасов КАК ВидЗапасов,
		|		Т.НаправлениеДеятельности КАК НаправлениеДеятельности,
		|		Т.Подразделение КАК Подразделение,
		|		Т.МестоХранения КАК МестоХранения,
		|		ИСТИНА КАК Сторно,
		|		Т.ОтклоненияВСтоимостиСНДС КАК ОтклоненияВСтоимостиСНДС,
		|		Т.ОтклоненияВСтоимостиБезНДС КАК ОтклоненияВСтоимостиБезНДС,
		|		Т.ОтклоненияВСтоимостиРегл КАК ОтклоненияВСтоимостиРегл,
		|		Т.ОтклоненияВСтоимостиУпр КАК ОтклоненияВСтоимостиУпр,
		|		Т.ДопРасходыСНДС КАК ДопРасходыСНДС,
		|		Т.ДопРасходыБезНДС КАК ДопРасходыБезНДС,
		|		Т.ДопРасходыРегл КАК ДопРасходыРегл,
		|		Т.ДопРасходыУпр КАК ДопРасходыУпр,
		|		Т.НДСРегл КАК НДСРегл,
		|		Т.НДСУпр КАК НДСУпр,
		|		Т.ПостояннаяРазница КАК ПостояннаяРазница,
		|		Т.ВременнаяРазница КАК ВременнаяРазница,
		|		(Т.ОтклоненияВСтоимостиРегл + Т.ДопРасходыРегл + Т.НДСРегл - Т.ПостояннаяРазница - Т.ВременнаяРазница) КАК СтоимостьНУ,
		|		Т.НДД КАК НДД
		|	ИЗ
		|		ВтСторноОтклоненийПрошлогоПериода КАК Т
		|
		|	ОБЪЕДИНИТЬ ВСЕ
		|
		|	ВЫБРАТЬ
		|		Т.ПериодОтклонения КАК ПериодОтклонения,
		|		Т.РазделУчета КАК РазделУчета,
		|		(ВЫБОР
		|			КОГДА Т.КорОрганизация <> ЗНАЧЕНИЕ(Справочник.Организации.ПустаяСсылка)
		|				ТОГДА Т.КорОрганизация
		|			ИНАЧЕ Т.Организация КОНЕЦ) КАК Организация,
		|		Т.КорНоменклатура КАК Номенклатура,
		|		Т.КорХарактеристика КАК Характеристика,
		|		Т.КорВидЗапасов КАК ВидЗапасов,
		|		Т.КорНаправлениеДеятельности КАК НаправлениеДеятельности,
		|		Т.КорПодразделение КАК Подразделение,
		|		Т.КорМестоХранения КАК МестоХранения,
		|		ИСТИНА КАК Сторно,
		|		-Т.ОтклоненияВСтоимостиСНДС КАК ОтклоненияВСтоимостиСНДС,
		|		-Т.ОтклоненияВСтоимостиБезНДС КАК ОтклоненияВСтоимостиБезНДС,
		|		-Т.ОтклоненияВСтоимостиРегл КАК ОтклоненияВСтоимостиРегл,
		|		-Т.ОтклоненияВСтоимостиУпр КАК ОтклоненияВСтоимостиУпр,
		|		-Т.ДопРасходыСНДС КАК ДопРасходыСНДС,
		|		-Т.ДопРасходыБезНДС КАК ДопРасходыБезНДС,
		|		-Т.ДопРасходыРегл КАК ДопРасходыРегл,
		|		-Т.ДопРасходыУпр КАК ДопРасходыУпр,
		|		-Т.НДСРегл КАК НДСРегл,
		|		-Т.НДСУпр КАК НДСУпр,
		|		-Т.ПостояннаяРазница КАК ПостояннаяРазница,
		|		-Т.ВременнаяРазница КАК ВременнаяРазница,
		|		-(Т.ОтклоненияВСтоимостиРегл + Т.ДопРасходыРегл + Т.НДСРегл - Т.ПостояннаяРазница - Т.ВременнаяРазница) КАК СтоимостьНУ,
		|		-Т.НДД КАК НДД
		|	ИЗ
		|		ВтСторноОтклоненийПрошлогоПериода КАК Т
		|	ГДЕ
		|		Т.ЕстьКорЧасть
		|	) КАК Т
		|
		|СГРУППИРОВАТЬ ПО
		|	Т.ПериодОтклонения,
		|	Т.РазделУчета,
		|	Т.Организация,
		|	Т.Номенклатура,
		|	Т.Характеристика,
		|	Т.ВидЗапасов,
		|	Т.НаправлениеДеятельности,
		|	Т.Подразделение,
		|	Т.МестоХранения,
		|	Т.Сторно
		|
		|ИНДЕКСИРОВАТЬ ПО
		|	Номенклатура,
		|	Подразделение
		|;
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	Т.Организация КАК Организация,
		|	МИНИМУМ(Т.ПериодОтклонения) КАК ПериодОтклонения
		|
		|ПОМЕСТИТЬ МинимальныеПериодыПредварительная
		|ИЗ
		|	ВтОтклоненияКРаспределению КАК Т
		|СГРУППИРОВАТЬ ПО
		|	Т.Организация
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	Т.Организация КАК Организация,
		|	МИНИМУМ(Т.ПериодОтклонения) КАК ПериодОтклонения
		|ИЗ
		|	ВтОтклоненияПрочиеРасходыКРаспределению КАК Т
		|СГРУППИРОВАТЬ ПО
		|	Т.Организация
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ДД.КорОрганизация КАК Организация,
		|	НАЧАЛОПЕРИОДА(ДД.ПериодПоступления, МЕСЯЦ) КАК ПериодОтклонения
		|ИЗ
		|	ДолиДополнительныхРасходов КАК ДД
		|ГДЕ
		|	ДД.ПериодПоступления <> ДАТАВРЕМЯ(1,1,1)
		|	И ДД.ПериодПоступления < &НачалоПериода
		|;
		|ВЫБРАТЬ
		|	Т.Организация КАК Организация,
		|	МИНИМУМ(Т.ПериодОтклонения) КАК ПериодОтклонения
		|
		|ПОМЕСТИТЬ МинимальныеПериоды
		|ИЗ
		|	МинимальныеПериодыПредварительная КАК Т
		|СГРУППИРОВАТЬ ПО
		|	Т.Организация
		|";
КонецФункции
	
Функция ТекстВтДвиженияСебестоимостиТоваровПоПериодамДетальныеОтклонения() // ВтДвиженияСебестоимостиТоваровПоПериодамДетальные
	Возврат "
		|ВЫБРАТЬ
		|	ИСТИНА КАК ЭтоТекущийПериод,
		|	ВЫБОР
		|		КОГДА Т.КорАналитикаУчетаНоменклатуры.Номенклатура ЕСТЬ NULL
		|		 ИЛИ Т.КорРазделУчета = ЗНАЧЕНИЕ(Перечисление.РазделыУчетаСебестоимостиТоваров.ПустаяСсылка)
		// Условие проверки на реализация в другую организацию должны соответствовать функции ТекстВтПеремещенияСписания()
		// в общем модуле РасчетСебестоимостиРешениеСЛУ.
		|		 ИЛИ Т.ХозяйственнаяОперация В (
		|					ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.РеализацияТоваровВДругуюОрганизацию),
		|					ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.ЗакупкаУПоставщикаРеглУчет),
		|					ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.РеализацияКлиентуРеглУчет),
