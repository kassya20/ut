#Область СлужебныйПрограммныйИнтерфейс

// Выполняет обработку выбора строки в общем списке настроек
// 
// Параметры:
//  ПараметрыВыбора - см. НастройкиПлатежныхСистемКлиент.НовыйПараметрыОбработкиВыбораНастройки
// 
Процедура ПриОбработкеВыбораНастройки(ПараметрыВыбора) Экспорт

	ПараметрыВыбора.ИмяОткрываемойФормы = "Справочник.НастройкиПодключенияКПлатежнымСистемам.ФормаОбъекта";
	
КонецПроцедуры

// Выполняет обработку выбранного значения в общем списке настроек при нажатии кнопки контекстного меню "Изменить".
// 
// Параметры:
//  ПараметрыВыбора - см. НастройкиПлатежныхСистемКлиент.НовыйПараметрыОбработкиВыбораНастройкиДляИзменения
// 
Процедура ПриОбработкеВыбораНастройкиДляИзменения(ПараметрыВыбора) Экспорт
	
	ПараметрыВыбора.ИмяФормы = "Справочник.НастройкиПодключенияКПлатежнымСистемам.ФормаОбъекта";
	
КонецПроцедуры

// Вызывается при обработке навигационных ссылок в форме мастера создания нового подключения к платежной системе.
// 
// Параметры:
//  НавигационнаяСсылкаФорматированнойСтроки - Строка - значение гиперссылки форматированной строки.
//  СтандартнаяОбработка - Булево - признак выполнения стандартной обработки события.
//  ДополнительныеПараметры - Неопределено, Произвольный - любая дополнительная информация, необходимая для обработки
//    навигационной ссылки.
//
Процедура ПриОбработкеНавигационнойСсылки(
	НавигационнаяСсылкаФорматированнойСтроки,
	СтандартнаяОбработка,
	ДополнительныеПараметры = Неопределено) Экспорт
	
	// Общие
	Если НавигационнаяСсылкаФорматированнойСтроки = "open:userAgreement" Тогда
		СтандартнаяОбработка = Ложь;
		НастройкиПлатежныхСистемКлиент.ФормаПользовательскогоСоглашения(ЭтотОбъект);
			
	ИначеЕсли НавигационнаяСсылкаФорматированнойСтроки = "open:Log" Тогда
		СтандартнаяОбработка = Ложь;
		ПлатежныеСистемыКлиент.ОткрытьЖурналРегистрации();
		
	Иначе
		МодульНастройкиПлатежныхСистемКлиентСобытия = ОбщегоНазначенияКлиент.ОбщийМодуль("НастройкиПлатежныхСистемКлиентСобытия");
		МодульНастройкиПлатежныхСистемКлиентСобытия.ПриОбработкеНавигационнойСсылки(
			НавигационнаяСсылкаФорматированнойСтроки,
			СтандартнаяОбработка,
			ДополнительныеПараметры);
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти