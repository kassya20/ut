#Область ПрочиеПроцедурыИФункции

// Обрабатывает ответ сервиса с ошибкой.
// Если в РезультатЗапроса.ДанныхОтвета есть Соответствие, значит запрос дошел до банка и можно обрабатывать
// структуру ответа. Если в РезультатЗапроса.ДанныхОтвета Неопределено, значит запрос до банка не дошел.
// Ответ от нашего сервиса должен быть обработан ранее, менять данные нет смысла.
// 
// Параметры:
//  Результат - см. ПлатежныеСистемыСлужебный.НовыйРезультатСтатусОперацииСлужебный.
//  РезультатЗапроса - см. ПлатежныеСистемыСервис.ВыполнитьОперациюСервиса.
//  
Процедура ОбработатьОтветСОшибкой(Результат, РезультатЗапроса)
	
	ДанныеОшибки = Новый Структура("code, message, details");
	Если РезультатЗапроса.ДанныеОтвета <> Неопределено Тогда
		ДанныеОшибки.code = РезультатЗапроса.ДанныеОтвета.Получить("code");
		ДанныеОшибки.details = РезультатЗапроса.ДанныеОтвета.Получить("details");
		ДанныеОшибки.message = ФорматироватьСообщение(
			РезультатЗапроса.ДанныеОтвета.Получить("message"));
	КонецЕсли;
	
	Если ДанныеОшибки.code = Неопределено Тогда
		ЗаполнитьЗначенияСвойств(Результат, РезультатЗапроса);
		ПлатежныеСистемыСлужебный.ЗаписатьИнформациюВЖурналРегистрации(Результат.ИнформацияОбОшибке, Истина);
		Возврат;
	КонецЕсли;
	
	Если ДанныеОшибки.code = 7 Или ДанныеОшибки.code = 16 Тогда
		Результат.КодОшибки = НастройкиПлатежныхСистемСлужебный.КодОшибкиНеверныйЛогинИлиПароль();
		Результат.СообщениеОбОшибке = НСтр("ru = 'Параметры подключения к Ozon Pay указаны ошибочно либо недействительны.
			|Проверьте настройки подключения.'");
		
	ИначеЕсли ДанныеОшибки.code = 5 Тогда
		
		Результат.КодОшибки = НастройкиПлатежныхСистемСлужебный.КодОшибкиОбъектНеНайден();
		Результат.СообщениеОбОшибке = НСтр("ru = 'Не найдена операция с указанным идентификатором'");
	
	Иначе

		Детали = ДеталиОшибки(ДанныеОшибки.details);
		ЗанестиВЖурнал = Истина;
		ТекстДляПользователя = "";
		
		Если ДанныеОшибки.code = 3 Тогда
			Результат.КодОшибки = НастройкиПлатежныхСистемСлужебный.КодОшибкиНеверныйФорматЗапроса();
			Если Детали.ПревышениеСуммы Тогда
				ТекстДляПользователя = НСтр("ru = 'Сумма возврата превышает допустимую.'");
				ЗанестиВЖурнал = Ложь;
			Иначе
				ТекстДляПользователя = НСтр("ru = 'Ошибка в параметрах запроса в банк.
					|Подробности см. в журнале регистрации'");
			КонецЕсли;
		
		ИначеЕсли ДанныеОшибки.code = 9 Тогда
			Результат.КодОшибки  = НастройкиПлатежныхСистемСлужебный.КодОшибкиНеверныйФорматЗапроса();
			ТекстДляПользователя = НСтр("ru = 'Ошибка в параметрах запроса в банк.
				|Подробную информацию см. в журнале регистрации'");
			
		ИначеЕсли ДанныеОшибки.code = 13 Тогда
			Результат.КодОшибки  = НастройкиПлатежныхСистемСлужебный.КодОшибкиСервисВременноНеДоступен();
			ТекстДляПользователя = НСтр("ru = 'Ошибка сервиса банка.
				|Попробуйте выполнить операцию позже.
				|Если ошибка сохраниться, обратитесь в банк для решения возникшей проблемы.
				|Техническую информацию об ошибке см. в журнале регистрации'");
			
		Иначе
			Результат.КодОшибки  = НастройкиПлатежныхСистемСлужебный.КодОшибкиНеизвестнаяОшибка();
			ТекстДляПользователя = НСтр("ru = 'Неизвестная ошибка сервиса банка.
				|Обратитесь в банк для решения возникшей проблемы.
				|Техническую информацию об ошибке см. в журнале регистрации'");
			
		КонецЕсли;

		Если ЗанестиВЖурнал И ЗначениеЗаполнено(Детали.ОшибкиЖурнал) Тогда

			ТекстОшибки = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
				НСтр("ru = 'Сервис Ozon Pay вернул ошибку: 
					|Code: %1
					|Message: %2
					|Details:
					|%3
					|
					|X-Correlation-ID: %4'"),
				ДанныеОшибки.code,
				ДанныеОшибки.message,
				Детали.ОшибкиЖурнал,
				РезультатЗапроса.ИдентификаторЗапроса);
				
			ПлатежныеСистемыСлужебный.ЗаписатьИнформациюВЖурналРегистрации(
				ТекстОшибки,
				Истина);
			
		КонецЕсли;
		
		Результат.СообщениеОбОшибке = ТекстДляПользователя;
		
	КонецЕсли;
	
	Результат.ИнформацияОбОшибке = Результат.СообщениеОбОшибке;
	
КонецПроцедуры

// Формирует пустую таблицу с описанием операций по заказу.
// 
// Возвращаемое значение:
//  ТаблицаЗначений - таблица операций:
//    * ВнешнийИдентификатор - Строка - идентификатор операции в системе продавца.
//    * ИдентификаторТранзакции - Строка - идентификатор операции в системе банка.
//    * ТипОперации - Строка - тип операции.
//    * СтатусОперации - Строка - статус операции.
//    * ВремяОперации - Дата - время выполнения операции.
//    * СуммаОперации - Число - сумма операции.
//    
Функция НовыйТаблицаОперация()
	
	Результат = Новый ТаблицаЗначений();
	
	ТипСтрока = Новый ОписаниеТипов("Строка");
	
	Результат.Колонки.Добавить("ВнешнийИдентификатор", ТипСтрока);
	Результат.Колонки.Добавить("ИдентификаторТранзакции", ТипСтрока);
	Результат.Колонки.Добавить("ТипОперации", ТипСтрока);
	Результат.Колонки.Добавить("СтатусОперации", ТипСтрока);
	Результат.Колонки.Добавить("ВремяОперации", Новый ОписаниеТипов("Дата"));
	Результат.Колонки.Добавить("СуммаОперации", Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(15, 2)));
	
	Возврат Результат;
	
КонецФункции

// В сообщениях от Ozon Pay все сообщения идут с маленькой буквы.
// Метод меняет первую букву на заглавную и добавляет в конце точку (если требуется).
// 
// Параметры:
//  Текст - Строка - текст, который нужно обработать.
//  
// Возвращаемое значение:
//  Строка - результат преобразования.
// 
Функция ФорматироватьСообщение(Текст)

	Если Не ЗначениеЗаполнено(Текст)
		Или ТипЗнч(Текст) <> Тип("Строка") Тогда
		Возврат "";
	КонецЕсли;
	
	Текст = СокрЛП(Текст);
	Текст = ВРег(Лев(Текст, 1)) + Сред(Текст, 2);
	
	Если Прав(Текст, 1) <> "." Тогда
		Текст = Текст + ".";
	КонецЕсли;
	
	Возврат Текст;
	
КонецФункции

// Разбирает значение поля details из ответ сервиса с ошибкой.
//
// Параметры:
//  Детали - Произвольный - возвращенное значение параметра.
// 
// Возвращаемое значение:
//  Структура:
//   * ОшибкиЖурнал - Строка - подробная информация об ошибках для сохранения в журнал регистрации.
//       Строки вида "code: %1; field: %2; message: %3".
//   * ОшибкиПользователь - Строка - подробная информация для вывода пользователю. Состоит из строк, включающих
//       только данные поля message.
//   * ПревышениеСуммы - Булево - Истина, если в текстах ошибки есть текст "Сумма возврата больше остатка позиции".
//       Возникает, если сумма возврата больше доступной суммы.
// 
Функция ДеталиОшибки(Детали)
	
	Результат = Новый Структура;
	Результат.Вставить("ОшибкиЖурнал", "");
	Результат.Вставить("ОшибкиПользователь", "");
	Результат.Вставить("ПревышениеСуммы", Ложь);
	
	ОшибкиЖурнал = Новый Массив;
	ОшибкиПользователь = Новый Массив;
	Если ТипЗнч(Детали) <> Тип("Массив") Тогда
		Возврат Результат;
	КонецЕсли;
	
	Для Каждого Ошибка Из Детали Цикл
		ОписанияОшибок = Ошибка.Получить("violations");
		Если ТипЗнч(ОписанияОшибок) <> Тип("Массив") Тогда
			Продолжить;
		КонецЕсли;
		
		Для Каждого Описание Из ОписанияОшибок Цикл
			Поле = Описание.Получить("field");
			Код = Описание.Получить("code");
			ТекстСообщения = ФорматироватьСообщение(
				Описание.Получить("message"));
			
			Если ЗначениеЗаполнено(ТекстСообщения) Тогда
				СтрокаОшибки = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
					НСтр("ru = 'code: %1; field: %2; message: %3'"),
					Код,
					Поле,
					ТекстСообщения);
				ОшибкиЖурнал.Добавить(СтрокаОшибки);
				
				Если ОшибкиПользователь.Найти(ТекстСообщения) = Неопределено Тогда
					ОшибкиПользователь.Добавить(ТекстСообщения);
				КонецЕсли;
				
				Если СтрНайти(ВРег(ТекстСообщения), "СУММА ВОЗВРАТА БОЛЬШЕ ОСТАТКА ПОЗИЦИИ") > 0 Тогда // АПК:1297 фиксированный текст ответа сервиса.
					Результат.ПревышениеСуммы = Истина;
				КонецЕсли;
				
			КонецЕсли;
		КонецЦикла;
	КонецЦикла;
	
	Результат.ОшибкиЖурнал = СтрСоединить(ОшибкиЖурнал, Символы.ПС);
	Результат.ОшибкиПользователь = СтрСоединить(ОшибкиПользователь, Символы.ПС);
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти

#КонецОбласти