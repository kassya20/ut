	|	ТаблицаДанныхДокументов.Предыдущий = ДанныеСИсправлениями.Ссылка
	|;
	|/////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ ВтДанныеКорректировки
	|;
	|/////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ ВтДанныеПоПоследнимИзменениям
	|;
	|/////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ ВтДанныеПоПоследнимИзменениямСОснованием
	|";
	
	Запрос.Выполнить();
	
КонецПроцедуры

