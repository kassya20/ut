// Модифицирует текст запроса, добавляя условие исключения алкогольной продукции из выборки для передачи на ответственное хранение.
//
// Параметры:
//   ТекстЗапроса - Строка - текст запроса для модификации
Процедура ОтработатьОграниченияПоПередачеНаОтветственноеХранение(ТекстЗапроса) Экспорт

//++ Локализация

	// Ограничение: алкогольная продукция на ответхранение не передается. Других ограничений нет.
	ЧастиЗапроса = Новый Массив;
	КлючПоискаРазделителя = ";";
	ПозицияРазделителя = СтрНайти(ТекстЗапроса, КлючПоискаРазделителя, НаправлениеПоиска.СКонца);
	ЧастиЗапроса.Добавить(Лев(ТекстЗапроса, ПозицияРазделителя - 1));
	ТекстЗапроса = Сред(ТекстЗапроса, ПозицияРазделителя);
	КлючПоиска = "
	|ИЗ";
	ПозицияИЗ = СтрНайти(ТекстЗапроса, КлючПоиска);
	ЧастиЗапроса.Добавить(Лев(ТекстЗапроса, ПозицияИЗ - 1));
	ЧастиЗапроса.Добавить("
	|ПОМЕСТИТЬ ВременнаяТаблицаДляФильтраИС");
	ЧастиЗапроса.Добавить(Сред(ТекстЗапроса, ПозицияИЗ));
	ЧастиЗапроса.Добавить("
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	*
	|ИЗ
	|	ВременнаяТаблицаДляФильтраИС КАК ВременнаяТаблицаДляФильтраИС
	|	ЛЕВОЕ СОЕДИНЕНИЕ
	|	РегистрСведений.ОписаниеНоменклатурыИС КАК ОписаниеНоменклатурыИС
	|		ПО ВременнаяТаблицаДляФильтраИС.Номенклатура = ОписаниеНоменклатурыИС.Номенклатура
	|ГДЕ
	|	ЕСТЬNULL(ОписаниеНоменклатурыИС.КлючВидовПродукции.ВидПродукцииЕГАИС, ЗНАЧЕНИЕ(Справочник.ВидыПродукцииИС.ПустаяСсылка))
	|		= ЗНАЧЕНИЕ(Справочник.ВидыПродукцииИС.ПустаяСсылка)
	|");
	
	ТекстЗапроса = СтрСоединить(ЧастиЗапроса);
	
//-- Локализация

КонецПроцедуры

// Получить распоряжения.
// 
// Параметры:
//  ПроверяемыйДокумент - ДокументСсылка.ПередачаТоваровХранителю - Документ распоряжение
// 
// Возвращаемое значение:
//  Массив из ДокументСсылка - документы распоряжения
Функция ПолучитьРаспоряженияПоДокументу(ПроверяемыйДокумент) Экспорт
	
	МассивРаспоряженийНаОтгрузку = Новый Массив;

//++ Локализация

	МассивРаспоряженийНаОтгрузку.Добавить(ПроверяемыйДокумент);
	
	ТекстЗапроса = "ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	|	ПередачаТоваровХранителюТовары.ЗаказКлиента КАК Распоряжение
	|ИЗ
	|	Документ.ПередачаТоваровХранителю.Товары КАК ПередачаТоваровХранителюТовары
	|ГДЕ
	|	ПередачаТоваровХранителюТовары.Ссылка = &ПроверяемыйДокумент
	|ОБЪЕДИНИТЬ ВСЕ
	|ВЫБРАТЬ
	|	ПередачаТоваровХранителю.ЗаказКлиента
	|ИЗ
	|	Документ.ПередачаТоваровХранителю КАК ПередачаТоваровХранителю
	|ГДЕ
	|	ПередачаТоваровХранителю.Ссылка = &ПроверяемыйДокумент
	|";
	
	Запрос = Новый Запрос(ТекстЗапроса);
	
	Запрос.УстановитьПараметр("ПроверяемыйДокумент", ПроверяемыйДокумент);
	
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		Если ЗначениеЗаполнено(Выборка.Распоряжение) Тогда
			МассивРаспоряженийНаОтгрузку.Добавить(Выборка.Распоряжение);
		КонецЕсли;
	КонецЦикла;

//-- Локализация

	Возврат МассивРаспоряженийНаОтгрузку;
	
КонецФункции

#Область ФормированиеОтгруженнойМаркируемойПродукции

// Сформировать отгруженные марки.
// 
// Параметры:
//  МассивЗаказовКлиентов - Массив - заказов клиентов
//  ОтгруженныеМарки - ТаблицаЗначений - Отгруженные марки
Процедура СформироватьОтгруженныеМарки(МассивЗаказовКлиентов, ОтгруженныеМарки) Экспорт

	//++ Локализация
	УстановитьПривилегированныйРежим(Истина);
	ОтгруженныеМарки = ИнициализироватьТаблицуОтгруженныхМарок();

	ТаблицаОрдеров = ПолучитьОрдераПоРаспоряжению(МассивЗаказовКлиентов);
	Для Каждого Строка Из ТаблицаОрдеров Цикл

		ШтрихкодыУпаковокПоОрдеру = ШтрихкодированиеИСМП.ВложенныеШтрихкодыУпаковокПоДокументу(
			Строка.Ордер, Неопределено);
			
		Если ШтрихкодыУпаковокПоОрдеру.ЕстьОшибки Тогда
			Продолжить;
		ИначеЕсли ШтрихкодыУпаковокПоОрдеру.ДанныеКодовМаркировки = Неопределено Тогда
			Продолжить;
		КонецЕсли;
			
		Для Каждого МаркированныйТовар Из ШтрихкодыУпаковокПоОрдеру.ДанныеКодовМаркировки Цикл
			СтрокаДерева = МаркированныйТовар.СтрокаДерева;
			Пока СтрокаДерева.Родитель <> Неопределено Цикл
				СтрокаДерева = СтрокаДерева.Родитель;
			КонецЦикла;
			НоваяСтрока = ОтгруженныеМарки.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, МаркированныйТовар);
			НоваяСтрока.ШтрихкодУпаковки = СтрокаДерева.ШтрихкодУпаковки;
			НоваяСтрока.ЗаказКлиента = Строка.ДокументОтгрузки;
			НоваяСтрока.Склад = Строка.Склад;
		КонецЦикла;
		
	КонецЦикла;
	//-- Локализация
	
КонецПроцедуры

// Исключить из подобранных марок попавшие в другие документы реализации товаров
// 
// Параметры:
//  ЗаказыКлиентов - Массив Из ДокументСсылка.ЗаказКлиента - По которым необходимо выполнить исключение марок.
//  ОтгруженныеМарки - ТаблицаЗначений - Отгруженные марки.
//
Процедура ИсключитьРеализованныеМарки(ЗаказыКлиентов, ОтгруженныеМарки) Экспорт
	
	//++ Локализация
	Если НЕ ЗначениеЗаполнено(ОтгруженныеМарки) Тогда
		Возврат;
	КонецЕсли;
	
	УстановитьПривилегированныйРежим(Истина);
		
	ДокументыПередачи = ПередачиПоЗаказамКлиентов(ЗаказыКлиентов);
	
	Для Каждого Документ Из ДокументыПередачи Цикл
		
		ШтрихкодыУпаковокПоРеализации = ШтрихкодированиеИСМП.ВложенныеШтрихкодыУпаковокПоДокументу(
			Документ, Неопределено);
		
		Если ШтрихкодыУпаковокПоРеализации.ЕстьОшибки Тогда
			Продолжить;
		КонецЕсли; 
		
		Для Каждого МаркированныйТовар Из ШтрихкодыУпаковокПоРеализации.ВложенныеШтрихкоды.МаркированныеТовары Цикл
			
			ПараметрыОтбора = Новый Структура("ШтрихКодУпаковки", МаркированныйТовар.ШтрихКодУпаковки);
			НайденныеСтроки = ОтгруженныеМарки.НайтиСтроки(ПараметрыОтбора);
			
			Для Каждого НайденнаяСтрока Из НайденныеСтроки Цикл
				ОтгруженныеМарки.Удалить(НайденнаяСтрока);
			КонецЦикла;
			
		КонецЦикла;
	КонецЦикла;
	//-- Локализация
	
КонецПроцедуры

#КонецОбласти

