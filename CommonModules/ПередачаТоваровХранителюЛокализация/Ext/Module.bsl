	СтруктураДанныхДляПечати.Вставить("РезультатПоИсходнымДанным",   РезультатПоИсходнымДанным);
	СтруктураДанныхДляПечати.Вставить("Маркировка",                  Маркировка);
	СтруктураДанныхДляПечати.Вставить("МаркировкаДо",                МаркировкаДо);
	СтруктураДанныхДляПечати.Вставить("ПрослеживаемыеКомплектующие", ПрослеживаемыеКомплектующие);
	
	Возврат СтруктураДанныхДляПечати;
	
КонецФункции

Процедура ПолучитьИсходныеДокументы(МенеджерВременныхТаблиц)
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	Запрос.Текст =
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ТаблицаДанныхДокументов.Ссылка КАК Основной,
	|	ЦепочкаДокументов.Документ КАК Подчиненный,
	|	ЦепочкаДокументов.Документ.МоментВремени КАК МоментВремени
	|ПОМЕСТИТЬ ВтСвязанныеДокументы	
	|ИЗ
	|	ТаблицаДанныхДокументов КАК ТаблицаДанныхДокументов
	|ЛЕВОЕ СОЕДИНЕНИЕ
	|	ЦепочкаДокументовБезПредыдущего КАК ЦепочкаДокументов
	|ПО
	|	ЦепочкаДокументов.МоментВремени < ТаблицаДанныхДокументов.Ссылка.МоментВремени
	|;
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ДанныеДокументов.Ссылка КАК Ссылка,
	|	ДанныеДокументов.ИсправляемыйДокумент КАК ИсправляемыйДокумент,
	|	ТаблицаТовары.НомерСтроки КАК НомерСтроки,
	|	ТаблицаТовары.Номенклатура КАК Номенклатура,
	|	ТаблицаТовары.Характеристика КАК Характеристика,
	|	ТаблицаТовары.НоменклатураНабора КАК НоменклатураНабора,
	|	ТаблицаТовары.ХарактеристикаНабора КАК ХарактеристикаНабора,
	|	ТаблицаТовары.Серия КАК Серия,
	|	ТаблицаТовары.Назначение КАК Назначение,
	|	ТаблицаТовары.Цена КАК Цена,
	|	СУММА(ТаблицаТовары.Количество) КАК Количество,
	|	СУММА(ТаблицаТовары.Сумма) КАК Сумма
	|ПОМЕСТИТЬ ВтДанныеИсправляемогоДокумента
	|ИЗ
	|	Документ.ПередачаТоваровХранителю.Товары КАК ТаблицаТовары
	|ВНУТРЕННЕЕ СОЕДИНЕНИЕ
	|	ТаблицаДанныхДокументов КАК ДанныеДокументов
	|ПО
	|	ТаблицаТовары.Ссылка = ДанныеДокументов.ИсправляемыйДокумент
	|СГРУППИРОВАТЬ ПО
	|	ДанныеДокументов.Ссылка,
	|	ДанныеДокументов.ИсправляемыйДокумент,
	|	ТаблицаТовары.НомерСтроки,
	|	ТаблицаТовары.Номенклатура,
	|	ТаблицаТовары.Характеристика,
	|	ТаблицаТовары.НоменклатураНабора,
	|	ТаблицаТовары.ХарактеристикаНабора,
	|	ТаблицаТовары.Серия,
	|	ТаблицаТовары.Назначение,
	|	ТаблицаТовары.Цена	
	|;
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТаблицаДанных.Ссылка КАК Ссылка,
	|	ТаблицаДанных.ИсправляемыйДокумент КАК ИсправляемыйДокумент,
	|	ТаблицаДанных.НомерСтроки КАК НомерСтроки,
	|	ТаблицаДанных.Номенклатура КАК Номенклатура,
	|	ТаблицаДанных.Характеристика КАК Характеристика,
	|	ТаблицаДанных.НоменклатураНабора КАК НоменклатураНабора,
	|	ТаблицаДанных.ХарактеристикаНабора КАК ХарактеристикаНабора,
	|	ТаблицаДанных.Серия КАК Серия,
	|	ТаблицаДанных.Назначение КАК Назначение
	|ПОМЕСТИТЬ ВтДанныеКорректировки
	|ИЗ
	|	(ВЫБРАТЬ
	|		ИсправляемыеТовары.Ссылка КАК Ссылка,
	|		ИсправляемыеТовары.ИсправляемыйДокумент КАК ИсправляемыйДокумент,
	|		ИсправляемыеТовары.НомерСтроки КАК НомерСтроки,
	|		ИсправляемыеТовары.Номенклатура КАК Номенклатура,
	|		ИсправляемыеТовары.Характеристика КАК Характеристика,
	|		ИсправляемыеТовары.НоменклатураНабора КАК НоменклатураНабора,
	|		ИсправляемыеТовары.ХарактеристикаНабора КАК ХарактеристикаНабора,
	|		ИсправляемыеТовары.Серия КАК Серия,
	|		ИсправляемыеТовары.Назначение КАК Назначение,
	|		ИсправляемыеТовары.Количество КАК Количество,
	|		ИсправляемыеТовары.Сумма КАК Сумма
	|	ИЗ
	|		ВтДанныеИсправляемогоДокумента КАК ИсправляемыеТовары
	|		
	|	ОБЪЕДИНИТЬ ВСЕ	
	|
	|	ВЫБРАТЬ
	|		ТаблицаТовары.Ссылка КАК Ссылка,
	|		ДанныеДокументов.ИсправляемыйДокумент КАК ИсправляемыйДокумент,
	|		ТаблицаТовары.НомерСтроки КАК НомерСтроки,
	|		ТаблицаТовары.Номенклатура КАК Номенклатура,
	|		ТаблицаТовары.Характеристика КАК Характеристика,
	|		ТаблицаТовары.НоменклатураНабора КАК НоменклатураНабора,
	|		ТаблицаТовары.ХарактеристикаНабора КАК ХарактеристикаНабора,
	|		ТаблицаТовары.Серия КАК Серия,
	|		ТаблицаТовары.Назначение КАК Назначение,
	|		-ТаблицаТовары.Количество КАК Количество,
	|		-ТаблицаТовары.Сумма КАК Сумма
	|	ИЗ
	|		Документ.ПередачаТоваровХранителю.Товары КАК ТаблицаТовары
	|	ВНУТРЕННЕЕ СОЕДИНЕНИЕ
	|		ТаблицаДанныхДокументов КАК ДанныеДокументов
	|	ПО
	|		ТаблицаТовары.Ссылка = ДанныеДокументов.Ссылка
	|	) КАК ТаблицаДанных
	|СГРУППИРОВАТЬ ПО
	|	ТаблицаДанных.Ссылка,
	|	ТаблицаДанных.ИсправляемыйДокумент,
	|	ТаблицаДанных.НомерСтроки,
	|	ТаблицаДанных.Номенклатура,
	|	ТаблицаДанных.Характеристика,
	|	ТаблицаДанных.НоменклатураНабора,
	|	ТаблицаДанных.ХарактеристикаНабора,
	|	ТаблицаДанных.Серия,
	|	ТаблицаДанных.Назначение
	|ИМЕЮЩИЕ
	|	СУММА(ТаблицаДанных.Количество) <> 0 ИЛИ СУММА(ТаблицаДанных.Сумма) <> 0
	|;
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВтПредыдущиеДокументы.Основной КАК Основной,
	|	ШапкаОснования.Ссылка КАК ИсходныйДокумент,
	|	ШапкаОснования.МоментВремени КАК МоментВремени,
	|	ТаблицаДанныхДокументов.Номенклатура КАК Номенклатура,
	|	ТаблицаДанныхДокументов.Характеристика КАК Характеристика,
	|	ТаблицаДанныхДокументов.НоменклатураНабора КАК НоменклатураНабора,
	|	ТаблицаДанныхДокументов.ХарактеристикаНабора КАК ХарактеристикаНабора,
	|	ТаблицаДанныхДокументов.Серия КАК Серия,
	|	ТаблицаДанныхДокументов.Назначение КАК Назначение
	|ПОМЕСТИТЬ ВтДанныеПоПоследнимИзменениям
	|ИЗ
	|	ВтСвязанныеДокументы КАК ВтПредыдущиеДокументы
	|ВНУТРЕННЕЕ СОЕДИНЕНИЕ
	|	ВтДанныеКорректировки КАК ТаблицаДанныхДокументов
	|ПО
	|	ВтПредыдущиеДокументы.Основной = ТаблицаДанныхДокументов.Ссылка
	|ВНУТРЕННЕЕ СОЕДИНЕНИЕ
	|	Документ.ПередачаТоваровХранителю КАК ШапкаОснования
	|ПО
	|	ШапкаОснования.Ссылка = ВтПредыдущиеДокументы.Подчиненный
	|	И НЕ ШапкаОснования.Исправление
	|ВНУТРЕННЕЕ СОЕДИНЕНИЕ
	|	Документ.ПередачаТоваровХранителю.Товары КАК ТаблицаТовары
	|ПО
	|	ШапкаОснования.Ссылка = ТаблицаТовары.Ссылка
	|	И ТаблицаДанныхДокументов.Номенклатура = ТаблицаТовары.Номенклатура
	|	И ТаблицаДанныхДокументов.Характеристика = ТаблицаТовары.Характеристика
	|	И ТаблицаДанныхДокументов.НоменклатураНабора = ТаблицаТовары.НоменклатураНабора
	|	И ТаблицаДанныхДокументов.ХарактеристикаНабора = ТаблицаТовары.ХарактеристикаНабора
	|	И ТаблицаДанныхДокументов.Серия = ТаблицаТовары.Серия
	|	И ТаблицаДанныхДокументов.Назначение = ТаблицаТовары.Назначение
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ВтПредыдущиеДокументы.Основной КАК Основной,
	|	ШапкаОснования.Ссылка КАК ИсходныйДокумент,
	|	ШапкаОснования.МоментВремени КАК МоментВремени,
	|	ТаблицаДанныхДокументов.Номенклатура КАК Номенклатура,
	|	ТаблицаДанныхДокументов.Характеристика КАК Характеристика,
	|	ТаблицаДанныхДокументов.НоменклатураНабора КАК НоменклатураНабора,
	|	ТаблицаДанныхДокументов.ХарактеристикаНабора КАК ХарактеристикаНабора,
	|	ТаблицаДанныхДокументов.Серия КАК Серия,
	|	ТаблицаДанныхДокументов.Назначение КАК Назначение
	|ИЗ
	|	ВтСвязанныеДокументы КАК ВтПредыдущиеДокументы
	|ВНУТРЕННЕЕ СОЕДИНЕНИЕ
	|	ВтДанныеКорректировки КАК ТаблицаДанныхДокументов
	|ПО
	|	ВтПредыдущиеДокументы.Основной = ТаблицаДанныхДокументов.Ссылка
	|ВНУТРЕННЕЕ СОЕДИНЕНИЕ
	|	Документ.ПередачаТоваровХранителю КАК ШапкаОснования
	|ПО
	|	ШапкаОснования.Ссылка = ВтПредыдущиеДокументы.Подчиненный
	|	И ШапкаОснования.Исправление
	|	И ШапкаОснования.Ссылка <> ВтПредыдущиеДокументы.Основной
	|ВНУТРЕННЕЕ СОЕДИНЕНИЕ
	|	Документ.ПередачаТоваровХранителю.Товары КАК ТаблицаТовары
	|ПО
	|	ШапкаОснования.Ссылка = ТаблицаТовары.Ссылка
	|	И ТаблицаДанныхДокументов.Номенклатура = ТаблицаТовары.Номенклатура
	|	И ТаблицаДанныхДокументов.Характеристика = ТаблицаТовары.Характеристика
	|	И ТаблицаДанныхДокументов.НоменклатураНабора = ТаблицаТовары.НоменклатураНабора
	|	И ТаблицаДанныхДокументов.ХарактеристикаНабора = ТаблицаТовары.ХарактеристикаНабора
	|	И ТаблицаДанныхДокументов.Серия = ТаблицаТовары.Серия
	|	И ТаблицаДанныхДокументов.Назначение = ТаблицаТовары.Назначение
	|;
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТаблицаДанныхДокументов.Ссылка КАК Основной,
	|	ТаблицаДанныхДокументов.ИсправляемыйДокумент КАК ИсправляемыйДокумент,
	|	ЕСТЬNULL(ДанныеПоИзменениям.ИсходныйДокумент, ДанныеОснования.ИсправляемыйДокумент) КАК ИсходныйДокумент,
	|	ЕСТЬNULL(ДанныеПоИзменениям.МоментВремени, ДанныеОснования.ИсправляемыйДокумент.МоментВремени) КАК МоментВремени,
	|	ТаблицаДанныхДокументов.Номенклатура КАК Номенклатура,
	|	ТаблицаДанныхДокументов.Характеристика КАК Характеристика,
	|	ТаблицаДанныхДокументов.НоменклатураНабора КАК НоменклатураНабора,
	|	ТаблицаДанныхДокументов.ХарактеристикаНабора КАК ХарактеристикаНабора,
	|	ТаблицаДанныхДокументов.Серия КАК Серия,
	|	ТаблицаДанныхДокументов.Назначение КАК Назначение
	|ПОМЕСТИТЬ ВтДанныеПоПоследнимИзменениямСОснованием
	|ИЗ
	|	ВтДанныеКорректировки КАК ТаблицаДанныхДокументов
	|ЛЕВОЕ СОЕДИНЕНИЕ ВтДанныеПоПоследнимИзменениям КАК ДанныеПоИзменениям
	|	ПО ТаблицаДанныхДокументов.Ссылка = ДанныеПоИзменениям.Основной
	|	И ТаблицаДанныхДокументов.Номенклатура = ДанныеПоИзменениям.Номенклатура
	|	И ТаблицаДанныхДокументов.Характеристика = ДанныеПоИзменениям.Характеристика
	|	И ТаблицаДанныхДокументов.НоменклатураНабора = ДанныеПоИзменениям.НоменклатураНабора
	|	И ТаблицаДанныхДокументов.ХарактеристикаНабора = ДанныеПоИзменениям.ХарактеристикаНабора
	|	И ТаблицаДанныхДокументов.Серия = ДанныеПоИзменениям.Серия
	|	И ТаблицаДанныхДокументов.Назначение = ДанныеПоИзменениям.Назначение
	|ВНУТРЕННЕЕ СОЕДИНЕНИЕ
	|	Документ.ПередачаТоваровХранителю КАК ДанныеОснования
	|ПО
	|	ТаблицаДанныхДокументов.Ссылка = ДанныеОснования.Ссылка
	|;
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТаблицаДанныхДокументов.Основной КАК Основной,
	|	ТаблицаДанныхДокументов.ИсходныйДокумент КАК Предыдущий,
	|	ТаблицаДанныхДокументов.ИсправляемыйДокумент КАК ИсправляемыйДокумент,
	|	ДанныеОснования.Номер КАК НомерИсправления,
	|	ДанныеОснования.Дата КАК ДатаИсправления
	|ПОМЕСТИТЬ ВтИсправляемыеДокументы
	|ИЗ
	|	ВтДанныеПоПоследнимИзменениямСОснованием КАК ТаблицаДанныхДокументов
	|ВНУТРЕННЕЕ СОЕДИНЕНИЕ
	|	Документ.ПередачаТоваровХранителю КАК ДанныеОснования
	|ПО
	|	ТаблицаДанныхДокументов.ИсправляемыйДокумент = ДанныеОснования.Ссылка
	|ГДЕ
	|	ТаблицаДанныхДокументов.ИсходныйДокумент В
	|		(ВЫБРАТЬ ПЕРВЫЕ 1
	|			ВременнаяТаблица.ИсходныйДокумент
	|		ИЗ
	|			ВтДанныеПоПоследнимИзменениямСОснованием КАК ВременнаяТаблица
	|		ГДЕ
	|			ВременнаяТаблица.Основной = ТаблицаДанныхДокументов.Основной
	|			И ВременнаяТаблица.Номенклатура = ТаблицаДанныхДокументов.Номенклатура
	|			И ВременнаяТаблица.Характеристика = ТаблицаДанныхДокументов.Характеристика
	|			И ВременнаяТаблица.НоменклатураНабора = ТаблицаДанныхДокументов.НоменклатураНабора
	|			И ВременнаяТаблица.ХарактеристикаНабора = ТаблицаДанныхДокументов.ХарактеристикаНабора
	|			И ВременнаяТаблица.Серия = ТаблицаДанныхДокументов.Серия
	|			И ВременнаяТаблица.Назначение = ТаблицаДанныхДокументов.Назначение
	|		УПОРЯДОЧИТЬ ПО
	|			ВременнаяТаблица.МоментВремени УБЫВ
	|		)
	|;
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ДанныеДокумента.Ссылка КАК Ссылка,
	|	ДанныеДокумента.Дата КАК Дата,
	|	ДанныеДокумента.Номер КАК Номер,
	|	КОЛИЧЕСТВО(ДанныеДокумента.Ссылка) КАК НомерИсправления
	|ПОМЕСТИТЬ ДанныеСИсправлениями
	|ИЗ
	|	ВтИсправляемыеДокументы КАК ВтИсправляемыеДокументы
	|ВНУТРЕННЕЕ СОЕДИНЕНИЕ
	|	Документ.ПередачаТоваровХранителю КАК ДанныеДокумента
	|ПО
	|	ВтИсправляемыеДокументы.Предыдущий = ДанныеДокумента.Ссылка
	|	И ДанныеДокумента.Исправление
	|СГРУППИРОВАТЬ ПО
	|	ДанныеДокумента.Ссылка,
	|	ДанныеДокумента.Дата,
	|	ДанныеДокумента.Номер
	|;
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ТаблицаДанныхДокументов.Основной КАК Ссылка,
	|	ТаблицаДанныхДокументов.Предыдущий КАК ИсходныйДокумент,
	|	ЕСТЬNULL(ДанныеСИсправлениями.Номер, ДанныеОснования.Номер) КАК НомерСчетаФактуры,
	|	ЕСТЬNULL(ДанныеСИсправлениями.Дата, ДанныеОснования.Дата) КАК ДатаСчетаФактуры,
	|	ЕСТЬNULL(ДанныеСИсправлениями.НомерИсправления, НЕОПРЕДЕЛЕНО) КАК НомерИсправленияСчетаФактуры,
 	|	ДанныеОснования.Дата КАК ДатаИсправленияСчетаФактуры,
 	|	ТаблицаДанныхДокументов.НомерИсправления КАК НомерИсправления,
	|	ТаблицаДанныхДокументов.ДатаИсправления КАК ДатаИсправления
	|ПОМЕСТИТЬ ДанныеИсходныхДокументов
	|ИЗ
