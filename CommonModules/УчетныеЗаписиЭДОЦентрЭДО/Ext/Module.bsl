// @strict-types

#Область СлужебныйПрограммныйИнтерфейс

// Возвращает список доступных учетных записей ЭДО.
// 
// Параметры:
//  КлючевыеРеквизитыОрганизации - См. ИнтеграцияЭДО.КлючевыеРеквизитыОрганизации
// 
// Возвращаемое значение:
//  Массив из Строка
Функция ИдентификаторыУчетныхЗаписейЭДО(КлючевыеРеквизитыОрганизации) Экспорт
	
	Организация = ИнтеграцияЭДО.ОрганизацияПоКлючевымРеквизитам(КлючевыеРеквизитыОрганизации);
	
	СписокИдентификаторов = УчетныеЗаписиЭДО.СписокИдентификаторовУчетныхЗаписейОрганизацииСервисаЭДО(Организация);
	
	Возврат СписокИдентификаторов.ВыгрузитьЗначения();
	
КонецФункции

// Возвращает все идентификаторы учетных записей ЭДО.
// 
// Возвращаемое значение:
//  Массив из Строка
Функция ВсеИдентификаторыУчетныхЗаписейЭДО() Экспорт
	
	Возврат УчетныеЗаписиЭДО.СписокВсехУчетныхЗаписей().Выгрузить().ВыгрузитьКолонку("ИдентификаторЭДО");
	
КонецФункции

// Возвращает идентификаторы организации по данным сервиса 1С-ЭДО.
// 
// Параметры:
//  КлючевыеРеквизитыОрганизации - См. ИнтеграцияЭДО.КлючевыеРеквизитыОрганизации
// 
// Возвращаемое значение:
//  Массив из Структура:
//  * Идентификатор - Строка
//  * Наименование - Строка
Функция ИдентификаторыУчетныхЗаписейЭДОВСервисе1СЭДО(КлючевыеРеквизитыОрганизации) Экспорт
	
	СписокИдентификаторовВФорматеСервиса = Новый Массив; // Массив из Структура
	
	Если Не ЗначениеЗаполнено(КлючевыеРеквизитыОрганизации.ИНН) Тогда
		Возврат СписокИдентификаторовВФорматеСервиса;
	КонецЕсли;
	
	КонтекстДиагностики = ОбработкаНеисправностейБЭД.НовыйКонтекстДиагностики();
	СписокИдентификаторов = РаботаСАбонентамиЭДО.ПолучитьИдентификаторыВСервисе1СЭДОПоРеквизитам(
		КлючевыеРеквизитыОрганизации, КонтекстДиагностики);
	
	Если Не ЗначениеЗаполнено(СписокИдентификаторов) Тогда
		Возврат СписокИдентификаторовВФорматеСервиса;
	КонецЕсли;
	
	Для Каждого ЭлементСписка Из СписокИдентификаторов Цикл
		ЭлементСпискаВФорматеСервиса = Новый Структура;
		ЭлементСпискаВФорматеСервиса.Вставить("Идентификатор", ЭлементСписка.Значение);
		ЭлементСпискаВФорматеСервиса.Вставить("Наименование", Строка(ЭлементСписка.Представление));
		СписокИдентификаторовВФорматеСервиса.Добавить(ЭлементСпискаВФорматеСервиса);
	КонецЦикла;
	
	Возврат СписокИдентификаторовВФорматеСервиса;
	
КонецФункции

// Возвращает операторов электронного документооборота, которые доступны для подключения через 1С.
// 
// Возвращаемое значение:
//  Массив из Структура:
//  * Идентификатор - Строка
//  * Наименование - Строка
//  * ИНН - Строка
//  * КПП - Строка
//  * ОГРН - Строка
//  * ОтпечатокСертификата - Строка
//  * СпособОбмена - Строка
Функция ОператорыДляРегистрацииВЭДО() Экспорт
	
	ОператорыВФорматеСервиса = Новый Массив; // См. ОператорыДляРегистрацииВЭДО
	
	Операторы = СервисНастроекЭДО.ОператорыЭлектронногоДокументооборота();
	
	Для Каждого Оператор Из Операторы Цикл
		СпособОбмена = ОбщегоНазначения.ИмяЗначенияПеречисления(Оператор.СпособОбмена);
		ОператорВФорматеСервиса = Новый Структура;
		ОператорВФорматеСервиса.Вставить("Идентификатор", Оператор.Идентификатор);
		ОператорВФорматеСервиса.Вставить("Наименование", Оператор.Наименование);
		ОператорВФорматеСервиса.Вставить("ИНН", Оператор.ИНН);
		ОператорВФорматеСервиса.Вставить("КПП", Оператор.КПП);
		ОператорВФорматеСервиса.Вставить("ОГРН", Оператор.ОГРН);
		ОператорВФорматеСервиса.Вставить("ОтпечатокСертификата", Оператор.Сертификат);
		ОператорВФорматеСервиса.Вставить("СпособОбмена", СпособОбмена);
		ОператорыВФорматеСервиса.Добавить(ОператорВФорматеСервиса);
	КонецЦикла;
	
	Возврат ОператорыВФорматеСервиса;
	
КонецФункции

// Возвращает результаты создания заявок на регистрацию в сервисе ЭДО.
// 
// Параметры:
//  ДанныеОрганизации - Структура:
//  * НаименованиеСокращенное - Строка
//  * НаименованиеПолное - Строка
//  * ИНН - Строка
//  * КПП - Строка
//  * ОГРН - Строка
//  * ДатаОГРН - См. ОбщегоНазначенияБЭД.ДатаВФорматеISO
//  * СвидетельствоДатаВыдачи - См. ОбщегоНазначенияБЭД.ДатаВФорматеISO
//  * СвидетельствоСерияНомер - Строка
//  ДанныеЗаявки - Структура:
//  * Идентификатор - Строка
//  * ОператорЭДО - Строка - код оператора ЭДО.
//  * ИдентификаторЭДО - Строка - уникальный идентификатор участника в обмене электронными документами.
//  * АдресОрганизации - Строка
//  * АдресОрганизацииЗначение - Строка -  доступно с версии 2 программного интерфейса
//  * КодНалоговогоОргана - Строка - код налоговой инспекции, в которой зарегистрирована организация.
//  * ЭлектроннаяПочта - Строка
//  * СертификатыДляРегистрации - Массив из Строка
//  * ДоверенностиСертификатов - Массив из Структура:
//    ** ОтпечатокСертификата - Строка
//    ** ДанныеДоверенности - Структура:
//       *** Номер - Строка
//       *** ДанныеФайла - Строка
//       *** ДанныеПодписи - Строка
//       *** СтатусВРеестреФНС - Строка
//  * Назначение - Строка
//  * ПодробноеОписание - Строка
//  * ДатаПолученияДокументов - Число
//  * РежимПереходаВЦентрЭДО - Булево
// 
// Возвращаемое значение:
//  Структура:
//  * Успех - Булево
//  * Ошибка - Неопределено - ошибка отсутствует.
//           - Структура:
//  ** СертификатыУжеЗарегистрированы - Булево
//  ** ОтпечаткиСертификатовБезДоверенностей - Неопределено - отсутствуют сертификаты без доверенностей.
//                                           - Массив из Строка - набор отпечатков сертификатов, по которым не найдена доверенность.
//  ** ОжиданиеДругойЗаявки - Неопределено - ожидание отсутствует.
//                          - Строка - идентификатор ожидаемой заявки.
//  ** Представление - Строка
Функция СформироватьЗаявкуНаРегистрациюВЭДОДляСовместимости(ДанныеОрганизации, ДанныеЗаявки) Экспорт
	
	Результат = Новый Структура("Успех, Ошибка", Ложь, Неопределено);
	
	Если Не ЗначениеЗаполнено(ДанныеЗаявки.СертификатыДляРегистрации) Тогда
		Ошибка = НоваяОшибкаФормированияЗаявкиНаРегистрацию();
		Ошибка.Представление = НСтр("ru = 'Не указано ни одного сертификата для регистрации.'");
		Результат.Ошибка = Ошибка;
		Возврат Результат;
	КонецЕсли;
	
	Организация = ИнтеграцияЭДО.ОрганизацияПоКлючевымРеквизитам(ДанныеОрганизации);
	Если Не ЗначениеЗаполнено(Организация) Тогда
		Организация = СоздатьОрганизациюПоЗаявкеНаРегистрациюВЭДО(ДанныеОрганизации, ДанныеЗаявки);
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(Организация) Тогда
		Ошибка = НоваяОшибкаФормированияЗаявкиНаРегистрацию();
		Ошибка.Представление = НСтр("ru = 'Отсутствует организация для формирования заявки.'");
		Результат.Ошибка = Ошибка;
		Возврат Результат;
	КонецЕсли;
	
	СертификатыДляРегистрации = СертификатыИзФорматаСервиса(
		Организация, ДанныеЗаявки.СертификатыДляРегистрации);
	
	Если Не ЗначениеЗаполнено(СертификатыДляРегистрации) Тогда
		Ошибка = НоваяОшибкаФормированияЗаявкиНаРегистрацию();
		Ошибка.Представление = НСтр("ru = 'Ошибка конвертации сертификатов.'");
		Результат.Ошибка = Ошибка;
		Возврат Результат;
	КонецЕсли;
	
	ДополнитьСертификатамиУчетнойЗаписиДляРегистрацииВЭДО(
		СертификатыДляРегистрации, ДанныеЗаявки.ИдентификаторЭДО);
	
	Если Не ЗначениеЗаполнено(СертификатыДляРегистрации) Тогда
		Ошибка = НоваяОшибкаФормированияЗаявкиНаРегистрацию();
		Ошибка.СертификатыУжеЗарегистрированы = Истина;
		Результат.Ошибка = Ошибка;
		Возврат Результат;
	КонецЕсли;
	
	ДоверенностиСертификатов = ДоверенностиСертификатовИзФорматаСервиса(ДанныеЗаявки.ДоверенностиСертификатов);
	
	РезультатПроверкиДоверенностей = ПроверитьДоверенностиСертификатовДляРегистрации(
		ДанныеЗаявки.ОператорЭДО, Организация, СертификатыДляРегистрации, ДоверенностиСертификатов);
	
	Если ЗначениеЗаполнено(РезультатПроверкиДоверенностей.ОтпечаткиСертификатовБезДоверенностей) Тогда
		Ошибка =  НоваяОшибкаФормированияЗаявкиНаРегистрацию();
		Ошибка.ОтпечаткиСертификатовБезДоверенностей =
			РезультатПроверкиДоверенностей.ОтпечаткиСертификатовБезДоверенностей;
		Результат.Ошибка = Ошибка;
		Возврат Результат;
	КонецЕсли;
	
	ПараметрыРегистрации = СервисЭДОКлиентСервер.НовыеПараметрыРегистрацииВСервисе1СЭДО();
	ЗаполнитьЗначенияСвойств(ПараметрыРегистрации, ДанныеЗаявки);
	ПараметрыРегистрации.Организация = Организация;
	ПараметрыРегистрации.ИдентификаторОрганизации = ДанныеЗаявки.ИдентификаторЭДО;
	ПараметрыРегистрации.СертификатыПодписейОрганизации = СертификатыДляРегистрации;
	ПараметрыРегистрации.Доверенности = ДоверенностиСертификатов;
	
	ДанныеПакета = СервисЭДО.ДанныеДляРегистрационногоПакета1СЭДО(ПараметрыРегистрации);
	
	Если ЗначениеЗаполнено(ДанныеПакета.ТекстОшибки) Тогда
		Ошибка = НоваяОшибкаФормированияЗаявкиНаРегистрацию();
		Ошибка.Представление = ДанныеПакета.ТекстОшибки;
		Результат.Ошибка = Ошибка;
		Возврат Результат;
	КонецЕсли;
	
	ПараметрыУчетнойЗаписиЭДО = РегистрыСведений.ЗаявкиНаРегистрациюВЭДО.НовыеПараметрыУчетнойЗаписиЭДО();
	ПараметрыУчетнойЗаписиЭДО.Назначение = ДанныеЗаявки.Назначение;
	ПараметрыУчетнойЗаписиЭДО.ПодробноеОписание = ДанныеЗаявки.ПодробноеОписание;
	ПараметрыУчетнойЗаписиЭДО.ДатаПолученияДокументов = ДанныеЗаявки.ДатаПолученияДокументов;
	ПараметрыУчетнойЗаписиЭДО.РежимПереходаВЦентрЭДО = ДанныеЗаявки.РежимПереходаВЦентрЭДО;
	
	РезультатЗаписи = РегистрыСведений.ЗаявкиНаРегистрациюВЭДО.ЗаписатьЗаявкуНаРегистрациюВЭДО(
		ПараметрыРегистрации, ДанныеПакета, ПараметрыУчетнойЗаписиЭДО);
	
	Если РезультатЗаписи.Успех Тогда
		Результат.Успех = Истина;
	Иначе
		Ошибка = НоваяОшибкаФормированияЗаявкиНаРегистрацию();
		Ошибка.Представление = РезультатЗаписи.Ошибка;
		Результат.Ошибка = Ошибка;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Возвращает результаты создания заявок на регистрацию в сервисе ЭДО.
// 
// Параметры:
//  ДанныеОрганизации - Структура:
//  * НаименованиеСокращенное - Строка
//  * НаименованиеПолное - Строка
//  * ИНН - Строка
//  * КПП - Строка
//  * ОГРН - Строка
//  * СвидетельствоДатаВыдачи - См. ОбщегоНазначенияБЭД.ДатаВФорматеISO
//  * СвидетельствоСерияНомер - Строка
//  ДанныеЗаявки - Структура:
//  * Идентификатор - Строка
//  * ОператорЭДО - Строка - код оператора ЭДО.
//  * ИдентификаторЭДО - Строка - уникальный идентификатор участника в обмене электронными документами.
//  * АдресОрганизации - Строка
//  * АдресОрганизацииЗначение - Строка -  доступно с версии 2 программного интерфейса
//  * КодНалоговогоОргана - Строка - код налоговой инспекции, в которой зарегистрирована организация.
//  * ЭлектроннаяПочта - Строка
//  * СертификатыДляРегистрации - Массив из Строка
//  * ДоверенностиСертификатов - Массив из Структура:
//    ** ОтпечатокСертификата - Строка
//    ** ДанныеДоверенности - Строка - двоичные данные в формате base64.
//  * ДолжностиСертификатов - Массив из Структура:
//    ** ОтпечатокСертификата - Строка
//    ** Должность - Строка
//  * Назначение - Строка
//  * ПодробноеОписание - Строка
//  * ДатаПолученияДокументов - Число
//  * РежимПереходаВЦентрЭДО - Булево
// 
// Возвращаемое значение:
//  Структура:
//  * Успех - Булево
//  * Ошибка - Неопределено - ошибка отсутствует.
//           - Структура:
//  ** СертификатыУжеЗарегистрированы - Булево
//  ** ОтпечаткиСертификатовБезДоверенностей - Неопределено - отсутствуют сертификаты без доверенностей.
//                                           - Массив из Строка - набор отпечатков сертификатов, по которым не найдена доверенность.
//  ** ОжиданиеДругойЗаявки - Неопределено - ожидание отсутствует.
//                          - Строка - идентификатор ожидаемой заявки.
//  ** Представление - Строка
//  * ИдентификаторыДоверенностейСертификатов - Неопределено,Массив из Структура:
//    ** ОтпечатокСертификата - Строка
//    ** ИдентификаторДоверенности - Строка
Функция СформироватьЗаявкуНаРегистрациюВЭДО(ДанныеОрганизации, ДанныеЗаявки) Экспорт
	
	Результат = Новый Структура;
	Результат.Вставить("Успех", Ложь);
	Результат.Вставить("Ошибка", Неопределено);
	Результат.Вставить("ИдентификаторыДоверенностейСертификатов", Неопределено);
	
	Если Не ЗначениеЗаполнено(ДанныеЗаявки.СертификатыДляРегистрации) Тогда
		Ошибка = НоваяОшибкаФормированияЗаявкиНаРегистрацию();
		Ошибка.Представление = НСтр("ru = 'Не указано ни одного сертификата для регистрации.'");
		Результат.Ошибка = Ошибка;
		Возврат Результат;
	КонецЕсли;
	
	Организация = ИнтеграцияЭДО.ОрганизацияПоКлючевымРеквизитам(ДанныеОрганизации);
	Если Не ЗначениеЗаполнено(Организация) Тогда
		Организация = СоздатьОрганизациюПоЗаявкеНаРегистрациюВЭДО(
			ДанныеОрганизации, ДанныеЗаявки);
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(Организация) Тогда
		Ошибка = НоваяОшибкаФормированияЗаявкиНаРегистрацию();
		Ошибка.Представление = НСтр("ru = 'Отсутствует организация для формирования заявки.'");
		Результат.Ошибка = Ошибка;
		Возврат Результат;
	КонецЕсли;
	
	СертификатыДляРегистрации = СертификатыИзФорматаСервиса(
		Организация, ДанныеЗаявки.СертификатыДляРегистрации);
	
	Если Не ЗначениеЗаполнено(СертификатыДляРегистрации) Тогда
		Ошибка = НоваяОшибкаФормированияЗаявкиНаРегистрацию();
		Ошибка.Представление = НСтр("ru = 'Ошибка конвертации сертификатов.'");
		Результат.Ошибка = Ошибка;
		Возврат Результат;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ДанныеЗаявки.ИдентификаторЭДО)
		И Не ТребуетсяАктуализацияСертификатовВУчетнойЗаписи(СертификатыДляРегистрации,
		ДанныеЗаявки.ИдентификаторЭДО) Тогда
		Ошибка = НоваяОшибкаФормированияЗаявкиНаРегистрацию();
		Ошибка.СертификатыУжеЗарегистрированы = Истина;
		Результат.Ошибка = Ошибка;
		Возврат Результат;
	КонецЕсли;
	
	РезультатЗагрузкиДоверенностей = ЗагрузитьДоверенностиСертификатовЗаявкиНаРегистрацию(
		ДанныеЗаявки.ДоверенностиСертификатов);
	
	ДоверенностиСертификатов = РезультатЗагрузкиДоверенностей.ДоверенностиСертификатов;
	
	РезультатПроверкиДоверенностей = ПроверитьДоверенностиСертификатовДляРегистрации(
		ДанныеЗаявки.ОператорЭДО, Организация, СертификатыДляРегистрации, ДоверенностиСертификатов);
	
	Если ЗначениеЗаполнено(РезультатПроверкиДоверенностей.ОтпечаткиСертификатовБезДоверенностей) Тогда
		Ошибка =  НоваяОшибкаФормированияЗаявкиНаРегистрацию();
		Ошибка.ОтпечаткиСертификатовБезДоверенностей =
			РезультатПроверкиДоверенностей.ОтпечаткиСертификатовБезДоверенностей;
		Результат.Ошибка = Ошибка;
		Возврат Результат;
	КонецЕсли;
	
	ПараметрыРегистрации = СервисЭДОКлиентСервер.НовыеПараметрыРегистрацииВСервисе1СЭДО();
	ЗаполнитьЗначенияСвойств(ПараметрыРегистрации, ДанныеЗаявки);
	ПараметрыРегистрации.Организация = Организация;
	ПараметрыРегистрации.НаименованиеОрганизации = ДанныеОрганизации.НаименованиеСокращенное;
	ПараметрыРегистрации.ИННОрганизации = ДанныеОрганизации.ИНН;
	ПараметрыРегистрации.КППОрганизации = ДанныеОрганизации.КПП;
	ПараметрыРегистрации.ОГРНОрганизации = ДанныеОрганизации.ОГРН;
	ПараметрыРегистрации.ИдентификаторОрганизации = ДанныеЗаявки.ИдентификаторЭДО;
	ПараметрыРегистрации.СертификатыПодписейОрганизации = СертификатыДляРегистрации;
	ПараметрыРегистрации.Доверенности = ДоверенностиСертификатов;
	
	ДанныеПакета = СервисЭДО.ДанныеДляРегистрационногоПакета1СЭДО(ПараметрыРегистрации);
	
	Если ЗначениеЗаполнено(ДанныеПакета.ТекстОшибки) Тогда
		Ошибка = НоваяОшибкаФормированияЗаявкиНаРегистрацию();
		Ошибка.Представление = ДанныеПакета.ТекстОшибки;
		Результат.Ошибка = Ошибка;
		Возврат Результат;
	КонецЕсли;
	
	ПараметрыУчетнойЗаписиЭДО = РегистрыСведений.ЗаявкиНаРегистрациюВЭДО.НовыеПараметрыУчетнойЗаписиЭДО();
	ПараметрыУчетнойЗаписиЭДО.Назначение = ДанныеЗаявки.Назначение;
	ПараметрыУчетнойЗаписиЭДО.ПодробноеОписание = ДанныеЗаявки.ПодробноеОписание;
	ПараметрыУчетнойЗаписиЭДО.ДатаПолученияДокументов = ДанныеЗаявки.ДатаПолученияДокументов;
	ПараметрыУчетнойЗаписиЭДО.РежимПереходаВЦентрЭДО = ДанныеЗаявки.РежимПереходаВЦентрЭДО;
	ПараметрыУчетнойЗаписиЭДО.ДолжностиСертификатов = 
		ЗагрузитьДолжностиСертификатовИзЗаявкиНаРегистрацию(ДанныеЗаявки.ДолжностиСертификатов);
	
	РезультатЗаписи = РегистрыСведений.ЗаявкиНаРегистрациюВЭДО.ЗаписатьЗаявкуНаРегистрациюВЭДО(
		ПараметрыРегистрации, ДанныеПакета, ПараметрыУчетнойЗаписиЭДО);
	
	Если Не РезультатЗаписи.Успех Тогда
		Ошибка = НоваяОшибкаФормированияЗаявкиНаРегистрацию();
		Ошибка.Представление = РезультатЗаписи.Ошибка;
		Результат.Ошибка = Ошибка;
		Возврат Результат;
	КонецЕсли;
	
	Результат.Успех = Истина;
	Результат.ИдентификаторыДоверенностейСертификатов = РезультатЗагрузкиДоверенностей.ИдентификаторыДоверенностейСертификатов;
	
	Возврат Результат;
	
КонецФункции

// Заполнить подписанта данных на регистрацию ВЭДО.
// 
// Параметры:
//  ИдентификаторЗаявки - Строка
//  ОтпечатокСертификата - Строка
// 
// Возвращаемое значение:
//  Структура:
//  * Успех - Булево
//  * Ошибка - Неопределено,Строка
Функция ЗаполнитьПодписантаДанныхНаРегистрациюВЭДО(ИдентификаторЗаявки, ОтпечатокСертификата) Экспорт
	
	Результат = Новый Структура("Успех, Ошибка", Ложь, Неопределено);
	
	ЗаписьЗаявки = РегистрыСведений.ЗаявкиНаРегистрациюВЭДО.СоздатьМенеджерЗаписи();
	ЗаписьЗаявки.Идентификатор = ИдентификаторЗаявки;
	ЗаписьЗаявки.Прочитать();
	
	Если Не ЗаписьЗаявки.Выбран() Тогда
		Результат.Ошибка = СтрШаблон(НСтр("ru = 'Не найдена заявка для регистрации в ЭДО по идентификатору %1'"),
			ИдентификаторЗаявки);
		Возврат Результат;
	КонецЕсли;
	
	Если ЗаписьЗаявки.Статус <> Перечисления.СтатусыЗаявокНаРегистрациюВЭДО.Сформирована Тогда
		Результат.Ошибка = СтрШаблон(НСтр("ru = 'Изменение данных подписанта недоступно в статусе заявки ""%1""'"),
			ЗаписьЗаявки.Статус);
		Возврат Результат;
	КонецЕсли;
	
	СертификатПодписанта = ЭлектроннаяПодпись.СсылкаНаСертификат(ОтпечатокСертификата);
	Если Не ЗначениеЗаполнено(СертификатПодписанта) Тогда
		Результат.Ошибка = СтрШаблон(НСтр("ru = 'Не найден сертификат по отпечатку %1'"), ОтпечатокСертификата);
		Возврат Результат;
	КонецЕсли;
	
	СертификатыДляРегистрации = Новый Массив; // Массив из СправочникСсылка.СертификатыКлючейЭлектроннойПодписиИШифрования
	ДоверенностиПоСертификатам = Новый Соответствие;
	
	Выборка = РегистрыСведений.СертификатыЗаявокНаРегистрациюВЭДО.ВыборкаСертификатовЗаявки(ИдентификаторЗаявки);
	Пока Выборка.Следующий() Цикл
		СертификатыДляРегистрации.Добавить(Выборка.Сертификат);
		Если ЗначениеЗаполнено(Выборка.Доверенность) Тогда
			ДоверенностиПоСертификатам.Вставить(Выборка.Сертификат, Выборка.Доверенность);
		КонецЕсли;
	КонецЦикла;
	
	Если СертификатыДляРегистрации.Найти(СертификатПодписанта) = Неопределено Тогда
		Результат.Ошибка = НСтр("ru = 'Сертификат отсутствует в списке на регистрацию в ЭДО'");
		Возврат Результат;
	КонецЕсли;
	
	ПараметрыРегистрации = СервисЭДОКлиентСервер.НовыеПараметрыРегистрацииВСервисе1СЭДО();
	ПараметрыРегистрации.Идентификатор = ЗаписьЗаявки.Идентификатор;
	ПараметрыРегистрации.Организация = ЗаписьЗаявки.Организация;
	ПараметрыРегистрации.ОператорЭДО = ЗаписьЗаявки.ОператорЭДО;
	ПараметрыРегистрации.ИдентификаторОрганизации = ЗаписьЗаявки.ИдентификаторЭДО;
	ПараметрыРегистрации.АдресОрганизации = ЗаписьЗаявки.АдресОрганизации;
	ПараметрыРегистрации.АдресОрганизацииЗначение = ЗаписьЗаявки.АдресОрганизацииЗначение;
	ПараметрыРегистрации.КодНалоговогоОргана = ЗаписьЗаявки.КодНалоговогоОргана;
	ПараметрыРегистрации.СертификатПодписанта = СертификатПодписанта;
	ПараметрыРегистрации.СертификатыПодписейОрганизации = СертификатыДляРегистрации;
	ПараметрыРегистрации.Доверенности = ДоверенностиПоСертификатам;
	
	ДанныеПакета = СервисЭДО.ДанныеДляРегистрационногоПакета1СЭДО(ПараметрыРегистрации);
	
	Если ЗначениеЗаполнено(ДанныеПакета.ТекстОшибки) Тогда
		Результат.Ошибка = ДанныеПакета.ТекстОшибки;
		Возврат Результат;
	КонецЕсли;
	
	ЗаписьЗаявки.СертификатПодписанта = СертификатПодписанта;
	ЗаписьЗаявки.ДанныеЗаявки = Новый ХранилищеЗначения(ДанныеПакета.ДвоичныеДанныеДляОператораЭДО);
	ЗаписьЗаявки.ДанныеСоглашения = Новый ХранилищеЗначения(ДанныеПакета.ДвоичныеДанныеСоглашенияНаПодключениеЭДО);
	ЗаписьЗаявки.ДатаИзмененияСтатуса = ТекущаяДатаСеанса();
	ЗаписьЗаявки.Записать();
	
	Результат.Успех = Истина;
	
	Возврат Результат;
	
КонецФункции

// Возвращает данные для подписания на регистрацию ВЭДО.
// 
// Параметры:
//  ИдентификаторЗаявки - Строка
// 
// Возвращаемое значение:
//  Структура:
//  * Ошибка - Неопределено,Строка
//  * ДанныеДляПодписания - Неопределено,Структура:
//    ** ОтпечаткиСертификатов - Массив из Строка
//    ** ДанныеСоглашения - Строка
//    ** ДанныеДляРегистрации - Строка
Функция ПодготовитьДанныеДляПодписанияНаРегистрациюВЭДО(ИдентификаторЗаявки) Экспорт
	
	Результат = Новый Структура;
	Результат.Вставить("Ошибка", Неопределено);
	Результат.Вставить("ДанныеДляПодписания", Неопределено);
	
	ВыборкаДанных = РегистрыСведений.ЗаявкиНаРегистрациюВЭДО.ВыборкаДанныхДляПодписания(ИдентификаторЗаявки);
	Если Не ВыборкаДанных.Следующий() Тогда
		Результат.Ошибка = НСтр("ru = 'Не найдена заявка для регистрации в ЭДО'");
		Возврат Результат;
	КонецЕсли;
	
	Если ВыборкаДанных.Статус <> Перечисления.СтатусыЗаявокНаРегистрациюВЭДО.Сформирована Тогда
		Результат.Ошибка = НСтр("ru = 'Заявка для регистрации в ЭДО уже подписана'");
		Возврат Результат;
	КонецЕсли;
	
	ДанныеДляПодписания = НовыеДанныеДляПодписанияНаРегистрациюВЭДО();
	ДанныеДляПодписания.ОтпечаткиСертификатов =
		РегистрыСведений.СертификатыЗаявокНаРегистрациюВЭДО.ОтпечаткиСертификатовЗаявки(ИдентификаторЗаявки);
	
	ДвоичныеДанные = ВыборкаДанных.ДанныеСоглашения.Получить(); // ДвоичныеДанные
	ДанныеДляПодписания.ДанныеСоглашения = Base64Строка(ДвоичныеДанные);
	
	ДвоичныеДанные = ВыборкаДанных.ДанныеЗаявки.Получить(); // ДвоичныеДанные
	ДанныеДляПодписания.ДанныеДляРегистрации = Base64Строка(ДвоичныеДанные);
	
	Результат.ДанныеДляПодписания = ДанныеДляПодписания;
	
	Возврат Результат;
	
КонецФункции

// Добавить подписи данных на регистрацию ВЭДО.
// 
// Параметры:
//  ПодписиЗаявки - Структура:
//  * Идентификатор - Строка
//  * ПодписьСоглашения - Строка
//  * ПодписьДанныхДляРегистрации - Строка
//  * НомерДоверенности - Строка
// 
// Возвращаемое значение:
//  Структура:
//  * Успех - Булево
//  * Ошибка - Неопределено,Строка
Функция ДобавитьПодписиЗаявкиНаРегистрациюВЭДО(ПодписиЗаявки) Экспорт
	
	Результат = Новый Структура("Успех, Ошибка", Ложь, Неопределено);
	
	НаборЗаявок = РегистрыСведений.ЗаявкиНаРегистрациюВЭДО.СоздатьНаборЗаписей();
	НаборЗаявок.Отбор.Идентификатор.Установить(ПодписиЗаявки.Идентификатор);
	
	НаборЗаявок.Прочитать();
	
	Если Не ЗначениеЗаполнено(НаборЗаявок) Тогда
		Результат.Ошибка = СтрШаблон(НСтр("ru = 'Заявка с идентификатором %1 не найдена.'"),ПодписиЗаявки.Идентификатор);
		Возврат Результат;
	КонецЕсли;
	
	ПодписьДанныхДляРегистрации = Base64Значение(ПодписиЗаявки.ПодписьДанныхДляРегистрации);
	ПодписьСоглашения = Base64Значение(ПодписиЗаявки.ПодписьСоглашения);
	
	ЗаписьЗаявки = НаборЗаявок[0];
	ЗаписьЗаявки.ПодписьЗаявки = Новый ХранилищеЗначения(ПодписьДанныхДляРегистрации);
	ЗаписьЗаявки.ПодписьСоглашения = Новый ХранилищеЗначения(ПодписьСоглашения);
	ЗаписьЗаявки.Статус = Перечисления.СтатусыЗаявокНаРегистрациюВЭДО.Подписана;
	ЗаписьЗаявки.ДатаИзмененияСтатуса = ТекущаяДатаСеанса();
	
	НаборЗаявок.Записать();
	
	Результат.Успех = Истина;
	
	Возврат Результат;
	
КонецФункции

// Отправить заявку на регистрацию ВЭДО.
// 
// Параметры:
//  ИдентификаторЗаявки - Строка
// 
// Возвращаемое значение:
//  Структура:
//  * Успех - Булево
//  * Ошибка - Неопределено,Строка
Функция ОтправитьЗаявкуНаРегистрациюВЭДО(ИдентификаторЗаявки) Экспорт
	
	Результат = Новый Структура("Успех, Ошибка", Ложь, Неопределено);
	
	НаборЗаявок = РегистрыСведений.ЗаявкиНаРегистрациюВЭДО.СоздатьНаборЗаписей();
	НаборЗаявок.Отбор.Идентификатор.Установить(ИдентификаторЗаявки);
	
	НаборЗаявок.Прочитать();
	
	Если Не ЗначениеЗаполнено(НаборЗаявок) Тогда
		Результат.Ошибка = СтрШаблон(НСтр("ru = 'Заявка с идентификатором %1 не найдена.'"), ИдентификаторЗаявки);
		Возврат Результат;
	КонецЕсли;
	
	ЗаписьЗаявки = НаборЗаявок[0];
	
	ДанныеПакета = УчетныеЗаписиЭДО.НовыеДанныеДляРегистрационногоПакета1СЭДО();
	ДанныеПакета.РеквизитыПакета = РегистрыСведений.ЗаявкиНаРегистрациюВЭДО.РеквизитыРегистрационногоПакета(
		ИдентификаторЗаявки);
	ДанныеПакета.ДвоичныеДанныеДляОператораЭДО = ЗаписьЗаявки.ДанныеЗаявки.Получить();
	ДанныеПакета.ДвоичныеДанныеСоглашенияНаПодключениеЭДО = ЗаписьЗаявки.ДанныеСоглашения.Получить();
	ДанныеПакета.ПодписанныеДвоичныеДанныеДляОператораЭДО = ЗаписьЗаявки.ПодписьЗаявки.Получить();
	ДанныеПакета.ПодписанныеДвоичныеДанныеСоглашенияНаПодключениеЭДО = ЗаписьЗаявки.ПодписьСоглашения.Получить();
	ДанныеПакета.ДобавляемыйСертификат = ЗаписьЗаявки.СертификатПодписанта;
	
	ДанныеОператора = РегистрыСведений.ОператорыЭДО.АктуальныеДанныеОператораЭДО(ЗаписьЗаявки.ОператорЭДО);
	
	ДанныеПакета.ОператорЭДОСертификат = ДанныеОператора.Сертификат;
	
	ДвоичныеДанныеСертификата = КриптографияБЭД.СертификатИзСтрокиPEM(ДанныеОператора.Сертификат);
	
	СертификатКриптографии = Новый СертификатКриптографии(ДвоичныеДанныеСертификата);
	
	КонтекстДиагностики = ОбработкаНеисправностейБЭД.НовыйКонтекстДиагностики();
	
	ДанныеПакета.ЗашифрованныеДанныеОператораЭДО = КриптографияБЭД.Зашифровать(
		ДанныеПакета.ДвоичныеДанныеДляОператораЭДО, СертификатКриптографии, КонтекстДиагностики);
	
	Если ДанныеПакета.ЗашифрованныеДанныеОператораЭДО = Неопределено Тогда
		Результат.Ошибка = ОбработкаНеисправностейБЭД.ТекстОшибокКонтекстаДиагностики(КонтекстДиагностики);
		Возврат Результат;
	КонецЕсли;
	
	РезультатОтправки = СервисЭДО.ОтправитьРегистрационныйПакет1СЭДО(ДанныеПакета, КонтекстДиагностики);
	
	Если РезультатОтправки.ЕстьОшибки Тогда
		ЗаписьЗаявки.Статус = Перечисления.СтатусыЗаявокНаРегистрациюВЭДО.Отклонена;
		ЗаписьЗаявки.ПричинаОтклонения = ОбработкаНеисправностейБЭД.ТекстОшибокКонтекстаДиагностики(КонтекстДиагностики);
		Результат.Ошибка = ЗаписьЗаявки.ПричинаОтклонения;
	Иначе
		ЗаписьЗаявки.Статус = Перечисления.СтатусыЗаявокНаРегистрациюВЭДО.Отправлена;
		Результат.Успех = Истина;
	КонецЕсли;
	
	ЗаписьЗаявки.ДатаИзмененияСтатуса = ТекущаяДатаСеанса();
	
	НаборЗаявок.Записать();
	
	Возврат Результат;
	
КонецФункции

// Возвращает состояния регистрации в сервисе ЭДО.
// 
// Параметры:
//  ИдентификаторыЗаявок - Массив из Строка
// 
// Возвращаемое значение:
//  Массив из Структура:
//  * ИдентификаторЗаявки - Строка
//  * ВОбработке - Булево
//  * ИдентификаторЭДО - Неопределено,Строка
//  * Ошибка - Неопределено,Строка
Функция СостоянияРегистрацииЗаявокВЭДО(ИдентификаторыЗаявок) Экспорт
	
	СостоянияРегистрацииВФорматеСервиса = Новый Массив; // См. СостоянияРегистрацииЗаявокВЭДО
	
	ВыборкаСостояний = РегистрыСведений.ЗаявкиНаРегистрациюВЭДО.ВыборкаСостояний(ИдентификаторыЗаявок);
	
	ИдентификаторыЗаявокДляПроверки = Новый Массив; // Массив из Строка
	
	Пока ВыборкаСостояний.Следующий() Цикл
		
		Если ВыборкаСостояний.Статус = Перечисления.СтатусыЗаявокНаРегистрациюВЭДО.Отправлена Тогда
			ИдентификаторыЗаявокДляПроверки.Добавить(ВыборкаСостояний.Идентификатор);
			Продолжить;
		КонецЕсли;
		
		СостояниеЗаявкиВФорматеСервиса = НовоеСостояниеРегистрацииЗаявкиВФорматеСервиса();
		СостояниеЗаявкиВФорматеСервиса.ИдентификаторЗаявки = ВыборкаСостояний.Идентификатор;
		
		Если ЗначениеЗаполнено(ВыборкаСостояний.ИдентификаторЭДО) Тогда
			СостояниеЗаявкиВФорматеСервиса.ИдентификаторЭДО = ВыборкаСостояний.ИдентификаторЭДО;
		КонецЕсли;
		
		Если ЗначениеЗаполнено(ВыборкаСостояний.ПричинаОтклонения) Тогда
			СостояниеЗаявкиВФорматеСервиса.Ошибка = ВыборкаСостояний.ПричинаОтклонения;
		КонецЕсли;
		
		СостоянияРегистрацииВФорматеСервиса.Добавить(СостояниеЗаявкиВФорматеСервиса);
		
	КонецЦикла;
	
	Если Не ЗначениеЗаполнено(ИдентификаторыЗаявокДляПроверки) Тогда
		Возврат СостоянияРегистрацииВФорматеСервиса;
	КонецЕсли;
	
	РезультатПроверкиЗаявок = СервисЭДО.ПолучитьСостояниеРегистрацииВСервисе1СЭДО(ИдентификаторыЗаявокДляПроверки);
	
	ВыполненныеЗаявки = Новый Массив; // Массив из Строка
	
	Для Каждого СостояниеРегистрацииЗаявки Из РезультатПроверкиЗаявок.СостояниеРегистрации Цикл
		
		ИдентификаторЗаявки = СостояниеРегистрацииЗаявки.Ключ;
		СостояниеРегистрации = СостояниеРегистрацииЗаявки.Значение;
		
		РезультатОбработки = ОбработатьСостояниеРегистрацииЗаявки(
			ИдентификаторЗаявки, СостояниеРегистрации);
		
		СостояниеЗаявкиВФорматеСервиса = НовоеСостояниеРегистрацииЗаявкиВФорматеСервиса();
		СостояниеЗаявкиВФорматеСервиса.ИдентификаторЗаявки = ИдентификаторЗаявки;
		
		Если Не СостояниеРегистрации.Результат Тогда
			СостояниеЗаявкиВФорматеСервиса.Ошибка = СостояниеРегистрации.ОписаниеОшибки;
		ИначеЕсли ЗначениеЗаполнено(СостояниеРегистрации.ИдентификаторОрганизации) Тогда 
			СостояниеЗаявкиВФорматеСервиса.ИдентификаторЭДО = СостояниеРегистрации.ИдентификаторОрганизации;
			ВыполненныеЗаявки.Добавить(ИдентификаторЗаявки);
			СервисНастроекЭДО.ОтправитьДанныеАбонентаВСервисНастроек(СостояниеРегистрации.ИдентификаторОрганизации);
		Иначе 
			СостояниеЗаявкиВФорматеСервиса.ВОбработке = Истина;
		КонецЕсли;
		
		Если Не РезультатОбработки.Успех Тогда
			СостояниеЗаявкиВФорматеСервиса.ИдентификаторЭДО = Неопределено;
			СостояниеЗаявкиВФорматеСервиса.Ошибка = РезультатОбработки.Ошибка
		КонецЕсли;
		
		СостоянияРегистрацииВФорматеСервиса.Добавить(СостояниеЗаявкиВФорматеСервиса);
		
	КонецЦикла;
	
	Возврат СостоянияРегистрацииВФорматеСервиса;
	
КонецФункции

// Изменяет информацию об учетной записи ЭДО.
// 
// Параметры:
//  ИнформацияОбУчетнойЗаписиЭДО - Структура:
//  * ИдентификаторЭДО - Строка
//  * Наименование - Строка
//  * Назначение - Строка
//  * ПодробноеОписание - Строка
// 
// Возвращаемое значение:
//  Структура:
//  * Успех - Булево
//  * Ошибка - Неопределено,Строка
Функция ОбновитьИнформациюОбУчетнойЗаписиЭДО(ИнформацияОбУчетнойЗаписиЭДО) Экспорт
	
	Результат = Новый Структура;
	Результат.Вставить("Успех", Ложь);
	Результат.Вставить("Ошибка", Неопределено);
	
	НаборУчетныхЗаписей = РегистрыСведений.УчетныеЗаписиЭДО.СоздатьНаборЗаписей();
	НаборУчетныхЗаписей.Отбор.ИдентификаторЭДО.Установить(ИнформацияОбУчетнойЗаписиЭДО.ИдентификаторЭДО);
	
	НаборУчетныхЗаписей.Прочитать();
	
	Если Не ЗначениеЗаполнено(НаборУчетныхЗаписей) Тогда
		Результат.Ошибка = СтрШаблон(НСтр("ru = 'Учетная запись ЭДО с идентификатором %1 не найдена.'"),
			ИнформацияОбУчетнойЗаписиЭДО.ИдентификаторЭДО);
		Возврат Результат;
	КонецЕсли;
	
	УчетнаяЗапись = НаборУчетныхЗаписей[0];
	УчетнаяЗапись.НаименованиеУчетнойЗаписи = ИнформацияОбУчетнойЗаписиЭДО.Наименование;
	УчетнаяЗапись.НазначениеУчетнойЗаписи = ИнформацияОбУчетнойЗаписиЭДО.Назначение;
	УчетнаяЗапись.ПодробноеОписаниеУчетнойЗаписи = ИнформацияОбУчетнойЗаписиЭДО.ПодробноеОписание;
	
	НаборУчетныхЗаписей.Записать();
	
	РезультатОтправки = СервисНастроекЭДО.ОтправитьДанныеАбонентаВСервисНастроек(
		ИнформацияОбУчетнойЗаписиЭДО.ИдентификаторЭДО);
	
	Если РезультатОтправки.Результат Тогда
		Результат.Успех = Истина;
	Иначе
		Ошибки = ОбработкаНеисправностейБЭДКлиентСервер.ПолучитьОшибки(РезультатОтправки.КонтекстДиагностики);
		Если ЗначениеЗаполнено(Ошибки) Тогда
			Результат.Ошибка = Ошибки[0].КраткоеПредставлениеОшибки;
		Иначе
			Результат.Ошибка = СтрШаблон(НСтр("ru = 'Не удалось обновить информацию учетной записи ЭДО с идентификатором %1'"),
				ИнформацияОбУчетнойЗаписиЭДО.ИдентификаторЭДО);
		КонецЕсли;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Изменяет настройки уведомлений учетной записи ЭДО.
// 
// Параметры:
//  ИдентификаторУчетнойЗаписиЭДО - Строка
//  НастройкиУведомлений - Структура:
//  * АдресУведомлений - Строка
//  * УведомлятьОНовыхПриглашениях - Булево
//  * УведомлятьОбОтветахНаПриглашения - Булево
//  * УведомлятьОНовыхДокументах - Булево
//  * УведомлятьОНеОбработанныхДокументах - Булево
//  * УведомлятьОбОкончанииСрокаДействияСертификата - Булево
//  МаркерАвторизации - Структура:
//  * ИдентификаторУчетнойЗаписиЭДО - Строка
//  * ОтпечатокСертификата - Строка
//  * Данные - Строка - двоичные данные в формате base64.
// 
// Возвращаемое значение:
//  Структура:
//  * Успех - Булево
//  * Ошибка - Неопределено,Строка
Функция ОбновитьНастройкиУведомленийУчетнойЗаписиЭДО(ИдентификаторУчетнойЗаписиЭДО, НастройкиУведомлений, МаркерАвторизации) Экспорт
	
	Результат = Новый Структура;
	Результат.Вставить("Успех", Ложь);
	Результат.Вставить("Ошибка", Неопределено);
	
	НаборУчетныхЗаписей = РегистрыСведений.УчетныеЗаписиЭДО.СоздатьНаборЗаписей();
	НаборУчетныхЗаписей.Отбор.ИдентификаторЭДО.Установить(ИдентификаторУчетнойЗаписиЭДО);
	
	НаборУчетныхЗаписей.Прочитать();
	
	Если Не ЗначениеЗаполнено(НаборУчетныхЗаписей) Тогда
		Результат.Ошибка = СтрШаблон(НСтр("ru = 'Учетная запись ЭДО с идентификатором %1 не найдена.'"),
			ИдентификаторУчетнойЗаписиЭДО);
		Возврат Результат;
	КонецЕсли;
	
	ПараметрыУведомлений = СервисЭДОКлиентСервер.НовыеПараметрыУведомлений();
	ЗаполнитьЗначенияСвойств(ПараметрыУведомлений, НастройкиУведомлений);
	
	МаркерыАвторизации = ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(МаркерАвторизации);
	КлючиСинхронизации = СинхронизацияЭДОЦентрЭДО.КлючиСинхронизацииИзМаркеровАвторизации(МаркерыАвторизации);
	КлючСинхронизации = КлючиСинхронизации[ИдентификаторУчетнойЗаписиЭДО];
	
	РезультатОбновления = СервисЭДО.ОбновитьПараметрыУведомлений(ПараметрыУведомлений, КлючСинхронизации);
	
	Если Не РезультатОбновления.Результат Тогда
		Ошибки = ОбработкаНеисправностейБЭДКлиентСервер.ПолучитьОшибки(РезультатОбновления.КонтекстДиагностики);
		Если ЗначениеЗаполнено(Ошибки) Тогда
			Результат.Ошибка = Ошибки[0].КраткоеПредставлениеОшибки;
		Иначе
			Результат.Ошибка = СтрШаблон(НСтр("ru = 'Не удалось обновить настройки уведомлений учетной записи ЭДО с идентификатором %1'"),
				ИдентификаторУчетнойЗаписиЭДО);
		КонецЕсли;
		Возврат Результат;
	КонецЕсли;
	
	УчетнаяЗапись = НаборУчетныхЗаписей[0];
	ЗаполнитьЗначенияСвойств(УчетнаяЗапись, ПараметрыУведомлений);
	УчетнаяЗапись.ЭлектроннаяПочтаДляУведомлений = ПараметрыУведомлений.АдресУведомлений;
	НаборУчетныхЗаписей.Записать();
	
	Результат.Успех = Истина;
	
	Возврат Результат;
	
КонецФункции

// Возвращает настройки уведомлений по учетной записи ЭДО.
// 
// Параметры:
//  ИдентификаторУчетнойЗаписиЭДО - Строка
//  МаркерАвторизации - Структура:
//  * ИдентификаторУчетнойЗаписиЭДО - Строка
//  * ОтпечатокСертификата - Строка
//  * Данные - Строка - двоичные данные в формате base64.
// 
// Возвращаемое значение:
//  Структура:
//  * Настройки - Неопределено,Структура:
//  ** АдресУведомлений - Строка
//  ** УведомлятьОСобытиях - Булево
//  ** УведомлятьОНовыхПриглашениях - Булево
//  ** УведомлятьОбОтветахНаПриглашения - Булево
//  ** УведомлятьОНовыхДокументах - Булево
//  ** УведомлятьОНеобработанныхДокументах - Булево
//  ** УведомлятьОбОкончанииСрокаДействияСертификата - Булево
//  * Ошибка - Неопределено,Строка
Функция НастройкиУведомленийУчетнойЗаписиЭДО(ИдентификаторУчетнойЗаписиЭДО, МаркерАвторизации) Экспорт
	
	Результат = Новый Структура;
	Результат.Вставить("Настройки", Неопределено);
	Результат.Вставить("Ошибка", Неопределено);
	
	КлючСинхронизации = СинхронизацияЭДОЦентрЭДО.КлючСинхронизацииИзМаркераАвторизации(МаркерАвторизации);
	
	РезультатПолученияПараметров = СервисЭДО.ПолучитьПараметрыУведомлений(КлючСинхронизации);
	
	Если РезультатПолученияПараметров.ПараметрыУведомлений = Неопределено Тогда
		Результат.Ошибка = ОбработкаНеисправностейБЭД.ТекстОшибокКонтекстаДиагностики(
			РезультатПолученияПараметров.КонтекстДиагностики);
	Иначе
		Результат.Настройки = РезультатПолученияПараметров.ПараметрыУведомлений;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Возвращает маркеры авторизации по учетным записям ЭДО зашифрованные на сертификат.
// 
// Параметры:
//  ОтпечаткиСертификатов - Массив из Строка
//  ИдентификаторыУчетныхЗаписейЭДО - Неопределено
//                                  - Массив из Строка
// 
// Возвращаемое значение:
//  Структура:
//  * Ошибки - Неопределено
//           - Массив из Структура:
//             ** ИдентификаторУчетнойЗаписиЭДО - Строка
//             ** Тип - Строка
//             ** Текст - Строка
//  * ЗашифрованныеМаркеры - Массив из См. НовыйМаркерАвторизацииПоУчетнойЗаписиЭДО
Функция ПолучитьМаркерыАвторизацииПоУчетнымЗаписямЭДО(ОтпечаткиСертификатов, ИдентификаторыУчетныхЗаписейЭДО = Неопределено) Экспорт
	
	Результат = Новый Структура;
	Результат.Вставить("Ошибки", Неопределено);
	Результат.Вставить("ЗашифрованныеМаркеры", Новый Массив);
	
	Если Не ЗначениеЗаполнено(ОтпечаткиСертификатов) Тогда
		Возврат Результат;
	КонецЕсли;
	
	РезультатыПолученияОтпечатков = РезультатыПолученияОтпечатков(ОтпечаткиСертификатов);
	
	КонтекстДиагностики = ОбработкаНеисправностейБЭД.НовыйКонтекстДиагностики();
	
	ДанныеДляСинхронизации = СинхронизацияЭДОСлужебный.ДанныеДляСинхронизации(РезультатыПолученияОтпечатков,
		КонтекстДиагностики, ИдентификаторыУчетныхЗаписейЭДО);
	
	Результат.Ошибки = ОбработатьОшибкиСинхронизации(ДанныеДляСинхронизации);
	
	ЗашифрованныеМаркеры = Результат.ЗашифрованныеМаркеры; // Массив из см. НовыйМаркерАвторизацииПоУчетнойЗаписиЭДО
	
	Для Каждого Элемент Из ДанныеДляСинхронизации.КлючиСинхронизации Цикл
		КлючСинхронизации = Элемент.Значение;
		Сертификаты = КлючСинхронизации.Сертификаты;
		Для Каждого ДанныеСертификата Из Сертификаты Цикл
			Если ДанныеСертификата.МаркерЗашифрованный = Неопределено Тогда
				Продолжить;
			КонецЕсли;
			ЗашифрованныйМаркер = НовыйМаркерАвторизацииПоУчетнойЗаписиЭДО();
			ЗашифрованныйМаркер.ИдентификаторУчетнойЗаписиЭДО = КлючСинхронизации.ИдентификаторУчетнойЗаписи;
			ЗашифрованныйМаркер.ОтпечатокСертификата = ДанныеСертификата.Отпечаток;
			ЗашифрованныйМаркер.Данные = Base64Строка(ДанныеСертификата.МаркерЗашифрованный);
			ЗашифрованныеМаркеры.Добавить(ЗашифрованныйМаркер);
		КонецЦикла;
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

// Возвращает порцию сведений по учетным записям ЭДО.
// 
// Параметры:
//  МеткиВремениПоИдентификаторамЭДО - Массив из Структура:
//  * МеткаВремени - Число
//  * ИдентификаторЭДО - Строка
// 
// Возвращаемое значение:
//  Структура:
//  * ЭтоПоследний - Булево
//  * НаборДанных - см. ДанныеСинхронизацииУчетныхЗаписейЭДО
Функция ПорцияДанныхСинхронизацииУчетныхЗаписейЭДОПоМеткамВремени(МеткиВремениПоИдентификаторамЭДО) Экспорт
	
	ПорцияДанных = Новый Структура;
	ПорцияДанных.Вставить("ЭтоПоследний", Истина);
	ПорцияДанных.Вставить("НаборДанных", Новый Массив);
	
	Если Не ЗначениеЗаполнено(МеткиВремениПоИдентификаторамЭДО) Тогда
		Возврат ПорцияДанных;
	КонецЕсли;
	
	Если ЦентрЭДО.АвторизованСлужебныйПользователь() Тогда
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;
	
	Порция = 1000;
	
	НаборДанных = ДанныеСинхронизацииУчетныхЗаписейЭДОПоМеткамВремени(
		МеткиВремениПоИдентификаторамЭДО, Порция);
	
	ПорцияДанных.ЭтоПоследний = НаборДанных.Количество() < Порция;
	ПорцияДанных.НаборДанных = НаборДанных;
	
	Возврат ПорцияДанных;
	
КонецФункции

// Возвращает порцию сведений по учетным записям ЭДО.
// 
// Параметры:
//  МеткиВремениПоИдентификаторамЭДО - Массив из Структура:
//  * МеткаВремени - Число
//  * ИдентификаторЭДО - Строка
// 
// Возвращаемое значение:
//  Структура:
//  * ЭтоПоследний - Булево
//  * НаборДанных - см. ДанныеСинхронизацииУчетныхЗаписейЭДО
Функция ПорцияДанныхСинхронизацииУчетныхЗаписейЭДОПоМеткамВремениВерсия3(МеткиВремениПоИдентификаторамЭДО) Экспорт
	
	ПорцияДанных = Новый Структура;
	ПорцияДанных.Вставить("ЭтоПоследний", Истина);
	ПорцияДанных.Вставить("НаборДанных", Новый Массив);
	
	Если Не ЗначениеЗаполнено(МеткиВремениПоИдентификаторамЭДО) Тогда
		Возврат ПорцияДанных;
	КонецЕсли;
	
	Если ЦентрЭДО.АвторизованСлужебныйПользователь() Тогда
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;
	
	Порция = 1000;
	
	НаборДанных = ДанныеСинхронизацииУчетныхЗаписейЭДОПоМеткамВремениВерсия3(
		МеткиВремениПоИдентификаторамЭДО, Порция);
	
	ПорцияДанных.ЭтоПоследний = НаборДанных.Количество() < Порция;
	ПорцияДанных.НаборДанных = НаборДанных;
	
	Возврат ПорцияДанных;
	
КонецФункции

// Возвращает сведения по учетным записям ЭДО.
//
// Параметры:
//  ИдентификаторыЭДО - Массив из Строка
// 
// Возвращаемое значение:
//  См. ДанныеСинхронизацииУчетныхЗаписейЭДОПоИдентификаторам
Функция ДанныеСинхронизацииУчетныхЗаписейЭДО(ИдентификаторыЭДО) Экспорт
	
	Если Не ЗначениеЗаполнено(ИдентификаторыЭДО) Тогда
		Возврат Новый Массив;
	КонецЕсли;
	
	Если ЦентрЭДО.АвторизованСлужебныйПользователь() Тогда
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;
	
	ДанныеСинхронизации = ДанныеСинхронизацииУчетныхЗаписейЭДОПоИдентификаторам(ИдентификаторыЭДО);
	
	Возврат ДанныеСинхронизации;
	
КонецФункции

// Параметры:
//  ИдентификаторыЭДО - Массив из Строка
// 
// Возвращаемое значение:
//  Массив из Структура:
//  * ИдентификаторЭДО - Строка
//  * МеткаВремени - Неопределено,Число
Функция МеткиВремениУчетныхЗаписейЭДО(ИдентификаторыЭДО) Экспорт
	
	МеткиВремениВФорматеСервиса = Новый Массив; // См. МеткиВремениУчетныхЗаписейЭДО
	Для Каждого ИдентификаторЭДО Из ИдентификаторыЭДО Цикл
		МеткаВремени = МеткиВремениДанныхЭДО.МеткаВремениОбъекта(ИдентификаторЭДО,
			Перечисления.ТипыСинхронизацииСЦентромЭДО.УчетныеЗаписиЭДО, ИдентификаторЭДО);
		МеткаВремениВФорматеСервиса = Новый Структура("ИдентификаторЭДО, МеткаВремени",ИдентификаторЭДО, МеткаВремени);
		МеткиВремениВФорматеСервиса.Добавить(МеткаВремениВФорматеСервиса);
	КонецЦикла;
	
	Возврат МеткиВремениВФорматеСервиса;
	
КонецФункции

// Возвращает сведения по учетным записям ЭДО.
//
// Параметры:
//  ИдентификаторыЭДО - Массив из Строка
// 
// Возвращаемое значение:
//  См. ДанныеСинхронизацииУчетныхЗаписейЭДОПоИдентификаторам
Функция ДанныеСинхронизацииУчетныхЗаписейЭДОВерсия3(ИдентификаторыЭДО) Экспорт
	
	Если Не ЗначениеЗаполнено(ИдентификаторыЭДО) Тогда
		Возврат Новый Массив;
	КонецЕсли;
	
	Если ЦентрЭДО.АвторизованСлужебныйПользователь() Тогда
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;
	
	ДанныеСинхронизации = ДанныеСинхронизацииУчетныхЗаписейЭДОПоИдентификаторамВерсия3(ИдентификаторыЭДО);
	
	Возврат ДанныеСинхронизации;
	
КонецФункции

// Параметры:
//  ИдентификаторЭДО - Строка
//  СостояниеОбмена - Структура:
//  * ДатаПолученияДокументов - Неопределено,Число
//  * ДатаПолученияЭПД - Неопределено,Число
//  * ДатаПолученияПриглашений - Неопределено,Число
// 
// Возвращаемое значение:
//  Структура:
//  * Успех - Булево
//  * Ошибка - Неопределено,Строка
Функция УстановитьСостояниеОбменаЧерезОператораЭДО(ИдентификаторЭДО, СостояниеОбмена) Экспорт
	
	Результат = Новый Структура;
	Результат.Вставить("Успех", Истина);
	Результат.Вставить("Ошибка", Неопределено);
	
	НачатьТранзакцию();
	Попытка
		Поля = Новый Структура;
		Поля.Вставить("ИдентификаторОрганизации", ИдентификаторЭДО);
		ОбщегоНазначенияБЭД.УстановитьУправляемуюБлокировку(
			"РегистрСведений.СостоянияОбменовЭДЧерезОператоровЭДО", Поля);
		
		НаборЗаписей = РегистрыСведений.СостоянияОбменовЭДЧерезОператоровЭДО.СоздатьНаборЗаписей();
		НаборЗаписей.Отбор.ИдентификаторОрганизации.Установить(ИдентификаторЭДО);
		НаборЗаписей.Прочитать();
		Если НаборЗаписей.Количество() Тогда
			ЗаписьНабора = НаборЗаписей[0];
			Записать = Ложь;
			ДатаПолученияДокументов = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(
				СостояниеОбмена, "ДатаПолученияДокументов"); // Число
			Если ДатаПолученияДокументов <> Неопределено Тогда
				ЗаписьНабора.ДатаПолученияЭД = ДатаПолученияДокументов;
				Записать = Истина;
			КонецЕсли;
			ДатаПолученияЭПД = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(
				СостояниеОбмена, "ДатаПолученияЭПД"); // Число
			Если ДатаПолученияЭПД <> Неопределено Тогда
				ЗаписьНабора.ДатаПолученияЭПД = ДатаПолученияЭПД;
				Записать = Истина;
			КонецЕсли;
			ДатаПолученияПриглашений = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(
				СостояниеОбмена, "ДатаПолученияПриглашений"); // Число
			Если ДатаПолученияПриглашений <> Неопределено Тогда
				ЗаписьНабора.ДатаПоследнегоПолученияПриглашений = ДатаПолученияПриглашений;
				Записать = Истина;
			КонецЕсли;
			Если Записать Тогда
				НаборЗаписей.Записать();
			КонецЕсли;
		Иначе
			Результат.Успех = Ложь;
			Результат.Ошибка = НСтр("ru = 'Не найдена учетная запись ЭДО'");
		КонецЕсли;
		
		ЗафиксироватьТранзакцию();
	Исключение
		ОтменитьТранзакцию();
		ИмяСобытия = НСтр("ru = 'Изменение состояния обмена'", ОбщегоНазначения.КодОсновногоЯзыка());
		ЗаписьЖурналаРегистрации(ИмяСобытия, УровеньЖурналаРегистрации.Ошибка,,,
			ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
		Результат.Успех = Ложь;
		Результат.Ошибка = ОбработкаОшибок.КраткоеПредставлениеОшибки(ИнформацияОбОшибке());;
	КонецПопытки;
	
	Возврат Результат;
	
КонецФункции

// Параметры:
//  ИдентификаторЭДО - Строка
Процедура ПриУдаленииУчетнойЗаписи(ИдентификаторЭДО) Экспорт
	
	Если Не ЦентрЭДО.Использовать() Тогда
		Возврат;
	КонецЕсли;
	
	РегистрыСведений.ЗаявкиНаРегистрациюВЭДО.УдалитьПоИдентификаторуЭДО(ИдентификаторЭДО);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Возвращаемое значение:
//  Структура:
//  * СертификатыУжеЗарегистрированы - Булево
//  * ОтпечаткиСертификатовБезДоверенностей - Неопределено - отсутствуют сертификаты без доверенностей.
//                                - Массив из Строка - набор отпечатков сертификатов, по которым не найдена доверенность.
//  * ОжиданиеДругойЗаявки - Неопределено - ожидание отсутствует.
//                         - Строка - идентификатор ожидаемой заявки.
//  * Представление - Строка
Функция НоваяОшибкаФормированияЗаявкиНаРегистрацию()
	Ошибка = Новый Структура;
	Ошибка.Вставить("СертификатыУжеЗарегистрированы", Ложь);
	Ошибка.Вставить("ОтпечаткиСертификатовБезДоверенностей", Неопределено);
	Ошибка.Вставить("ОжиданиеДругойЗаявки", Неопределено);
	Ошибка.Вставить("Представление", "");
	Возврат Ошибка;
КонецФункции

// Параметры:
//  СертификатыДляРегистрации - Массив из СправочникСсылка.СертификатыКлючейЭлектроннойПодписиИШифрования
//  ИдентификаторЭДО - Строка
Процедура ДополнитьСертификатамиУчетнойЗаписиДляРегистрацииВЭДО(СертификатыДляРегистрации, ИдентификаторЭДО)
	
	Если Не ЗначениеЗаполнено(ИдентификаторЭДО) Тогда
		Возврат;
	КонецЕсли;
	
	СертификатыУчетнойЗаписи = РегистрыСведений.СертификатыУчетныхЗаписейЭДО.СертификатыУчетнойЗаписи(
		ИдентификаторЭДО).ВыгрузитьКолонку("Сертификат");
	
	НезарегистрированныеСертификаты = ОбщегоНазначенияКлиентСервер.РазностьМассивов(
		СертификатыДляРегистрации, СертификатыУчетнойЗаписи);
	
	Если ЗначениеЗаполнено(НезарегистрированныеСертификаты) Тогда
		СертификатыДляРегистрации = СертификатыУчетнойЗаписи;
		ОбщегоНазначенияКлиентСервер.ДополнитьМассив(СертификатыДляРегистрации, НезарегистрированныеСертификаты);
	Иначе
		СертификатыДляРегистрации = НезарегистрированныеСертификаты;
	КонецЕсли;
	
КонецПроцедуры

// Параметры:
//  СертификатыДляРегистрации - Массив из СправочникСсылка.СертификатыКлючейЭлектроннойПодписиИШифрования
//  ИдентификаторЭДО - Строка
Функция ТребуетсяАктуализацияСертификатовВУчетнойЗаписи(СертификатыДляРегистрации, ИдентификаторЭДО)
	
	Если Не ЗначениеЗаполнено(ИдентификаторЭДО) Тогда
		Возврат Ложь;
	КонецЕсли;
	
	СертификатыУчетнойЗаписи = РегистрыСведений.СертификатыУчетныхЗаписейЭДО.СертификатыУчетнойЗаписи(
		ИдентификаторЭДО).ВыгрузитьКолонку("Сертификат");
	
	Возврат Не ОбщегоНазначенияКлиентСервер.СпискиЗначенийИдентичны(СертификатыДляРегистрации, СертификатыУчетнойЗаписи);

КонецФункции

// Параметры:
//  Идентификатор - Строка
//  СостояниеРегистрации - Структура
// 
// Возвращаемое значение:
//  Структура:
//  * Успех - Булево
//  * Ошибка - Строка
Функция ОбработатьСостояниеРегистрацииЗаявки(Идентификатор, СостояниеРегистрации)
	
	Результат = Новый Структура("Успех, Ошибка", Ложь, "");
	
	НачатьТранзакцию();
	Попытка
		
		СтатусЗаявки = РегистрыСведений.ЗаявкиНаРегистрациюВЭДО.ЗаписатьСостояниеРегистрацииЗаявки(
			Идентификатор, СостояниеРегистрации);
		
		Если СтатусЗаявки = Перечисления.СтатусыЗаявокНаРегистрациюВЭДО.Выполнена Тогда
			РегистрыСведений.ЗаявкиНаРегистрациюВЭДО.ЗаписатьУчетнуюЗаписьЭДОПоЗаявке(Идентификатор);
		КонецЕсли;
		
		Результат.Успех = Истина;
		
		ЗафиксироватьТранзакцию();
	Исключение
		ОтменитьТранзакцию();
		Результат.Ошибка =  СтрШаблон(НСтр("ru = 'Неизвестная ошибка при обработке заявки на регистрацию %1'"),
				Идентификатор);
		ЗаписьЖурналаРегистрации(НСтр("ru = 'Обработка состояния регистрации в ЭДО'"),
			УровеньЖурналаРегистрации.Ошибка,,Идентификатор,
			ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
	КонецПопытки;
	
	Возврат Результат;
	
КонецФункции

// Параметры:
//  ДоверенностиСертификатовВФорматеСервиса - Массив из Структура:
//  * ОтпечатокСертификата - Строка
//  * ДанныеДоверенности - См. МашиночитаемыеДоверенностиЦентрЭДО.ДоверенностьПоДаннымВФорматеСервиса.ДанныеДоверенности
// 
// Возвращаемое значение:
//  Соответствие из КлючИЗначение:
//  * Ключ - СправочникСсылка.СертификатыКлючейЭлектроннойПодписиИШифрования
//  * Значение - ОпределяемыйТип.МашиночитаемаяДоверенность
Функция ДоверенностиСертификатовИзФорматаСервиса(ДоверенностиСертификатовВФорматеСервиса)
	
	Результат = Новый Соответствие;
	
	Если Не ЗначениеЗаполнено(ДоверенностиСертификатовВФорматеСервиса) Тогда
		Возврат Результат;
	КонецЕсли;
	
	ОтпечаткиСертификатов = ОбщегоНазначения.ВыгрузитьКолонку(
		ДоверенностиСертификатовВФорматеСервиса, "ОтпечатокСертификата");
	СертификатыПоОтпечаткам = КриптографияБЭД.СертификатыПоОтпечаткам(ОтпечаткиСертификатов);
	
	Для Каждого ДоверенностьСертификатаВФорматеСервиса Из ДоверенностиСертификатовВФорматеСервиса Цикл
		
		Сертификат = СертификатыПоОтпечаткам[ДоверенностьСертификатаВФорматеСервиса.ОтпечатокСертификата];
		Доверенность = МашиночитаемыеДоверенностиЦентрЭДО.ДоверенностьПоДаннымВФорматеСервиса(
			ДоверенностьСертификатаВФорматеСервиса.ДанныеДоверенности);
		Если ЗначениеЗаполнено(Сертификат) И ЗначениеЗаполнено(Доверенность) Тогда
			Результат.Вставить(Сертификат, Доверенность);
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

// Параметры:
//  ДоверенностиСертификатовВФорматеСервиса - Массив из Структура:
//  * ОтпечатокСертификата - Строка
//  * ДанныеДоверенности - Строка - двоичные данные в формате base64.
// 
// Возвращаемое значение:
//  Структура:
//  * ДоверенностиСертификатов - Соответствие из КлючИЗначение:
//    ** Ключ - СправочникСсылка.СертификатыКлючейЭлектроннойПодписиИШифрования
//    ** Значение - ОпределяемыйТип.МашиночитаемаяДоверенность
//  * ИдентификаторыДоверенностейСертификатов - Массив из Структура:
//    ** ОтпечатокСертификата - Строка
//    ** ИдентификаторДоверенности - Строка
Функция ЗагрузитьДоверенностиСертификатовЗаявкиНаРегистрацию(ДоверенностиСертификатовВФорматеСервиса)
	
	Результат = Новый Структура;
	Результат.Вставить("ДоверенностиСертификатов", Новый Соответствие);
	Результат.Вставить("ИдентификаторыДоверенностейСертификатов", Новый Массив);
	
	Если Не ЗначениеЗаполнено(ДоверенностиСертификатовВФорматеСервиса) Тогда
		Возврат Результат;
	КонецЕсли;
	
	ДоверенностиСертификатов = Результат.ДоверенностиСертификатов;
	ИдентификаторыДоверенностейСертификатов = Результат.ИдентификаторыДоверенностейСертификатов; // Массив из Структура
	ОтпечаткиСертификатов = ОбщегоНазначения.ВыгрузитьКолонку(
		ДоверенностиСертификатовВФорматеСервиса, "ОтпечатокСертификата");
	СертификатыПоОтпечаткам = КриптографияБЭД.СертификатыПоОтпечаткам(ОтпечаткиСертификатов);
	
	Для Каждого ДоверенностьСертификатаВФорматеСервиса Из ДоверенностиСертификатовВФорматеСервиса Цикл
		
		Сертификат = СертификатыПоОтпечаткам[ДоверенностьСертификатаВФорматеСервиса.ОтпечатокСертификата];
		Если Не ЗначениеЗаполнено(Сертификат) Тогда
			Продолжить;
		КонецЕсли;
		
		ДвоичныеДанныеДоверенности = Base64Значение(ДоверенностьСертификатаВФорматеСервиса.ДанныеДоверенности);
		РезультатЗагрузки = МашиночитаемыеДоверенности.ЗагрузитьМЧДИзФайла(ДвоичныеДанныеДоверенности);
		Доверенность = РезультатЗагрузки.МЧД;
		Если Не ЗначениеЗаполнено(Доверенность) Тогда
			Продолжить;
		КонецЕсли;
		
		ДоверенностиСертификатов.Вставить(Сертификат, Доверенность);
		
		ИдентификаторДоверенностиСертификата = Новый Структура("ОтпечатокСертификата, ИдентификаторДоверенности",
			ДоверенностьСертификатаВФорматеСервиса.ОтпечатокСертификата,
			МашиночитаемыеДоверенностиЦентрЭДО.ИдентификаторДоверенности(Доверенность));
		ИдентификаторыДоверенностейСертификатов.Добавить(ИдентификаторДоверенностиСертификата);
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

// Параметры:
//  ДолжностиСертификатовВФорматеСервиса - Массив из Структура:
//  * ОтпечатокСертификата - Строка
//  * Должность - Строка.
// 
// Возвращаемое значение:
//  Соответствие из КлючИЗначение:
//  * Ключ - СправочникСсылка.СертификатыКлючейЭлектроннойПодписиИШифрования
//  * Значение - Строка - Должность
Функция ЗагрузитьДолжностиСертификатовИзЗаявкиНаРегистрацию(ДолжностиСертификатовВФорматеСервиса)
	
	ДолжностиСертификатов = Новый Соответствие;
	
	Если Не ЗначениеЗаполнено(ДолжностиСертификатовВФорматеСервиса) Тогда
		Возврат ДолжностиСертификатов;
	КонецЕсли;
	
	ОтпечаткиСертификатов = ОбщегоНазначения.ВыгрузитьКолонку(
		ДолжностиСертификатовВФорматеСервиса, "ОтпечатокСертификата");
	СертификатыПоОтпечаткам = КриптографияБЭД.СертификатыПоОтпечаткам(ОтпечаткиСертификатов);
	Для Каждого ДолжностьСертификатаВФорматеСервиса Из ДолжностиСертификатовВФорматеСервиса Цикл
		
		Сертификат = СертификатыПоОтпечаткам[ДолжностьСертификатаВФорматеСервиса.ОтпечатокСертификата];
		Если Не ЗначениеЗаполнено(Сертификат) Тогда
			Продолжить;
		КонецЕсли;
		
		Должность = ДолжностьСертификатаВФорматеСервиса.Должность;
		Если Не ЗначениеЗаполнено(Должность) Тогда
			Продолжить;
		КонецЕсли;
		
		ДолжностиСертификатов.Вставить(Сертификат, Должность);
		
	КонецЦикла;
	
	Возврат ДолжностиСертификатов;
	
КонецФункции

// Параметры:
//  ОператорЭДО - Строка
//  Организация - СправочникСсылка.Организации
//  СертификатыДляРегистрации - Массив из СправочникСсылка.СертификатыКлючейЭлектроннойПодписиИШифрования
//  ДоверенностиСертификатов - Соответствие из КлючИЗначение:
//  * Ключ - СправочникСсылка.СертификатыКлючейЭлектроннойПодписиИШифрования
//  * Значение - ОпределяемыйТип.МашиночитаемаяДоверенность
// 
// Возвращаемое значение:
//  Структура:
//  * ОтпечаткиСертификатовБезДоверенностей - Массив из Строка
Функция ПроверитьДоверенностиСертификатовДляРегистрации(ОператорЭДО, Организация, СертификатыДляРегистрации,
	ДоверенностиСертификатов)
	
	ОтпечаткиСертификатовБезДоверенностей = Новый Массив; // Массив из Строка
	
	Результат = Новый Структура;
	Результат.Вставить("ОтпечаткиСертификатовБезДоверенностей", ОтпечаткиСертификатовБезДоверенностей);
	
	Если Не СинхронизацияЭДО.ПриРегистрацииПредставителяТребуетсяМЧД(ОператорЭДО) Тогда
		Возврат Результат;
	КонецЕсли;
	
	ИННОрганизации = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Организация, "ИНН"); // Строка
	
	СертификатыКриптографииПоСсылкам = КриптографияБЭД.СертификатыКриптографииПоСсылкам(СертификатыДляРегистрации);
	
	Для Каждого СертификатКриптографииПоСсылке Из СертификатыКриптографииПоСсылкам Цикл
		
		СсылкаНаСертификат = СертификатКриптографииПоСсылке.Ключ;
		СертификатКриптографии = СертификатКриптографииПоСсылке.Значение;
		СвойстваСубъектаСертификата = КриптографияБЭД.СвойстваСубъектаСертификата(СертификатКриптографии);
		СвойстваИздателяСертификата = КриптографияБЭД.СвойстваИздателяСертификата(СертификатКриптографии);
		
		ТребуетсяДоверенность = МашиночитаемыеДоверенности.ТребуетсяМашиночитаемаяДоверенность(ИННОрганизации,
			СвойстваСубъектаСертификата, СвойстваИздателяСертификата);
		
		Если Не ТребуетсяДоверенность Тогда
			Продолжить;
		КонецЕсли;
		
		Доверенность = ДоверенностиСертификатов[СсылкаНаСертификат];
		Если Не ЗначениеЗаполнено(Доверенность) Тогда
			Отпечаток = Base64Строка(СертификатКриптографии.Отпечаток);
			ОтпечаткиСертификатовБезДоверенностей.Добавить(Отпечаток);
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

// Параметры:
//  Организация - ОпределяемыйТип.Организация
//  СертификатыВФорматеСервиса - Массив из Строка
// 
// Возвращаемое значение:
//  Массив из СправочникСсылка.СертификатыКлючейЭлектроннойПодписиИШифрования
Функция СертификатыИзФорматаСервиса(Организация, СертификатыВФорматеСервиса)
	
	Сертификаты = Новый Массив; // См. СертификатыИзФорматаСервиса
	
	Если Не ЗначениеЗаполнено(СертификатыВФорматеСервиса) Тогда
		Возврат Сертификаты;
	КонецЕсли;
	
	Для Каждого СертификатВФорматеСервиса Из СертификатыВФорматеСервиса Цикл
		Сертификат = СертификатИзФорматаСервиса(Организация, СертификатВФорматеСервиса);
		Если ЗначениеЗаполнено(Сертификат) Тогда
			Сертификаты.Добавить(Сертификат);
		КонецЕсли;
	КонецЦикла;
	
	Возврат Сертификаты;
	
КонецФункции

// Параметры:
//  Организация - ОпределяемыйТип.Организация
//  СертификатВФорматеСервиса - Строка
// 
// Возвращаемое значение:
//  СправочникСсылка.СертификатыКлючейЭлектроннойПодписиИШифрования
Функция СертификатИзФорматаСервиса(Организация, СертификатВФорматеСервиса)
	Если ЗначениеЗаполнено(СертификатВФорматеСервиса) Тогда
		ДвоичныеДанныеСертификата = Base64Значение(СертификатВФорматеСервиса);
		Возврат КриптографияБЭД.НайтиСоздатьСертификатЭП(ДвоичныеДанныеСертификата, Организация);
	Иначе
		Возврат Справочники.СертификатыКлючейЭлектроннойПодписиИШифрования.ПустаяСсылка();
	КонецЕсли;
КонецФункции

// Возвращаемое значение:
//  Структура:
//  * ОтпечаткиСертификатов - Массив из Строка - сертификаты для регистрации.
//  * ДанныеСоглашения - Строка
//  * ДанныеДляРегистрации - Строка
Функция НовыеДанныеДляПодписанияНаРегистрациюВЭДО()
	ДанныеДляПодписания = Новый Структура;
	ДанныеДляПодписания.Вставить("ОтпечаткиСертификатов", Новый Массив);
	ДанныеДляПодписания.Вставить("ДанныеСоглашения", "");
	ДанныеДляПодписания.Вставить("ДанныеДляРегистрации", "");
	Возврат ДанныеДляПодписания;
КонецФункции

// Возвращаемое значение:
//  Структура:
//  * ИдентификаторЗаявки - Строка
//  * ВОбработке - Булево
//  * ИдентификаторЭДО - Неопределено,Строка
//  * Ошибка - Неопределено,Строка
Функция НовоеСостояниеРегистрацииЗаявкиВФорматеСервиса()
	СостояниеРегистрации = Новый Структура;
	СостояниеРегистрации.Вставить("ИдентификаторЗаявки", "");
	СостояниеРегистрации.Вставить("ВОбработке", Ложь);
	СостояниеРегистрации.Вставить("ИдентификаторЭДО", Неопределено);
	СостояниеРегистрации.Вставить("Ошибка", Неопределено);
	Возврат СостояниеРегистрации;
КонецФункции

// Параметры:
//  ОтпечаткиСертификатов - Массив из Строка
// 
// Возвращаемое значение:
//  См. КриптографияБЭДКлиентСервер.НовыеРезультатыПолученияОтпечатков
Функция РезультатыПолученияОтпечатков(ОтпечаткиСертификатов)
	
	РезультатПолученияОтпечатков = КриптографияБЭДКлиентСервер.НовыйРезультатПолученияОтпечатков();
	РезультатПолученияОтпечатков.Доступность = Истина;
	РезультатПолученияОтпечатков.Отпечатки = ОтпечаткиСертификатов;
	
	РезультатыПолученияОтпечатков = КриптографияБЭДКлиентСервер.НовыеРезультатыПолученияОтпечатков();
	РезультатыПолученияОтпечатков.Клиент = РезультатПолученияОтпечатков;
	РезультатыПолученияОтпечатков.Сервер = КриптографияБЭДКлиентСервер.НовыйРезультатПолученияОтпечатков();
	РезультатыПолученияОтпечатков.Облако = КриптографияБЭДКлиентСервер.НовыйРезультатПолученияОтпечатков();
	
	Возврат РезультатыПолученияОтпечатков;
	
КонецФункции

// Возвращаемое значение:
//  Структура - Новые данные сервиса для расшифровки:
//  * ИдентификаторУчетнойЗаписиЭДО - Строка
//  * ОтпечатокСертификата - Строка
//  * Данные - Строка - двоичные данные в формате base64.
Функция НовыйМаркерАвторизацииПоУчетнойЗаписиЭДО()
	ЗашифрованныйМаркер = Новый Структура;
	ЗашифрованныйМаркер.Вставить("ИдентификаторУчетнойЗаписиЭДО", "");
	ЗашифрованныйМаркер.Вставить("ОтпечатокСертификата", "");
	ЗашифрованныйМаркер.Вставить("Данные", "");
	Возврат ЗашифрованныйМаркер;
КонецФункции

// Параметры:
//  ДанныеОрганизации - См. УчетныеЗаписиЭДОЦентрЭДО.СформироватьЗаявкуНаРегистрациюВЭДО.ДанныеОрганизации
//  ДанныеЗаявки -  См. УчетныеЗаписиЭДОЦентрЭДО.СформироватьЗаявкуНаРегистрациюВЭДО.ДанныеЗаявки
//  
// Возвращаемое значение:
//  Неопределено,ОпределяемыйТип.Организация
Функция СоздатьОрганизациюПоЗаявкеНаРегистрациюВЭДО(ДанныеОрганизации, ДанныеЗаявки)
	
	Организация = Неопределено; // Неопределено,ОпределяемыйТип.Организация
	
	ПараметрыСоздания = ОбменСКонтрагентамиКлиентСервер.НовыйДанныеОрганизации();
	ЗаполнитьЗначенияСвойств(ПараметрыСоздания, ДанныеОрганизации);
	ПараметрыСоздания.Наименование = ДанныеОрганизации.НаименованиеСокращенное;
	ПараметрыСоздания.СвидетельствоДатаВыдачи = 
		ОбщегоНазначенияБЭД.ДатаИзФорматаISO(ДанныеОрганизации.СвидетельствоДатаВыдачи);
	
	// Свойство доступно, начиная с 3 версии программного интерфейса.
	ДатаОГРН = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ДанныеОрганизации, "ДатаОГРН", ""); // Строка
	Если ЗначениеЗаполнено(ДатаОГРН) Тогда
		ПараметрыСоздания.ДатаОГРН = ОбщегоНазначенияБЭД.ДатаИзФорматаISO(ДатаОГРН);
	КонецЕсли;
	
	ЭлектроннаяПочта = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ДанныеЗаявки, "ЭлектроннаяПочта", ""); // Строка
	ПараметрыСоздания.ЭлектроннаяПочта = ЭлектроннаяПочта;
	
	ПараметрыСоздания.ЮридическийАдрес = СтруктурированныйАдресОрганизацииПоЗаявкеНаРегистрациюВЭДО(ДанныеЗаявки);
	
	УстановитьПривилегированныйРежим(Истина);
	ОбменСКонтрагентамиПереопределяемый.СоздатьОрганизациюПоРеквизитам(ПараметрыСоздания, Организация);
	УстановитьПривилегированныйРежим(Ложь);
	
	Возврат Организация;
	
КонецФункции

// Параметры:
//  ДанныеЗаявки -  См. УчетныеЗаписиЭДОЦентрЭДО.СформироватьЗаявкуНаРегистрациюВЭДО.ДанныеЗаявки
//  
// Возвращаемое значение:
//  Строка
Функция СтруктурированныйАдресОрганизацииПоЗаявкеНаРегистрациюВЭДО(ДанныеЗаявки)
	
	СтруктурированныйАдрес = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ДанныеЗаявки, "АдресОрганизацииЗначение", ""); // Строка
	Если ЗначениеЗаполнено(СтруктурированныйАдрес) Тогда
		Возврат СтруктурированныйАдрес;
	КонецЕсли;
	
	ПредставлениеАдреса = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ДанныеЗаявки, "АдресОрганизации", ""); // Строка
	Если Не ЗначениеЗаполнено(ПредставлениеАдреса) Тогда
		Возврат "";
	КонецЕсли;
	
	СтруктурированныйАдрес = УправлениеКонтактнойИнформацией.КонтактнаяИнформацияПоПредставлению(
		ПредставлениеАдреса, Перечисления.ТипыКонтактнойИнформации.Адрес);
	
	Возврат СтруктурированныйАдрес;
	
КонецФункции

// Параметры:
//  ИдентификаторыЭДО - Массив из Строка
// 
// Возвращаемое значение:
//  См. ДанныеСинхронизацииУчетныхЗаписейЭДОПоДаннымЗапроса
Функция ДанныеСинхронизацииУчетныхЗаписейЭДОПоИдентификаторам(ИдентификаторыЭДО)
	
	Запрос = Новый Запрос;
	Запрос.Текст = ТекстЗапросаДанныхСинхронизацииУчетныхЗаписейЭДО();
	Запрос.УстановитьПараметр("ИдентификаторыЭДО", ИдентификаторыЭДО);
	
	РезультатыЗапроса = Запрос.ВыполнитьПакет();
	ДанныеЗапроса = Новый Структура("ВыборкаРеквизитов, СписокСертификатов",
		РезультатыЗапроса[0].Выбрать(), РезультатыЗапроса[1].Выгрузить());
	
	Возврат ДанныеСинхронизацииУчетныхЗаписейЭДОПоДаннымЗапроса(ДанныеЗапроса);
	
КонецФункции

// Параметры:
//  ИдентификаторыЭДО - Массив из Строка
// 
// Возвращаемое значение:
//  См. ДанныеСинхронизацииУчетныхЗаписейЭДОПоДаннымЗапроса
Функция ДанныеСинхронизацииУчетныхЗаписейЭДОПоИдентификаторамВерсия3(ИдентификаторыЭДО)
	
	Запрос = Новый Запрос;
	Запрос.Текст = ТекстЗапросаДанныхСинхронизацииУчетныхЗаписейЭДО();
	Запрос.УстановитьПараметр("ИдентификаторыЭДО", ИдентификаторыЭДО);
	
	РезультатыЗапроса = Запрос.ВыполнитьПакет();
	ДанныеЗапроса = Новый Структура("ВыборкаРеквизитов, СписокСертификатов",
		РезультатыЗапроса[0].Выбрать(), РезультатыЗапроса[1].Выгрузить());
	
	Возврат ДанныеСинхронизацииУчетныхЗаписейЭДОПоДаннымЗапросаВерсия3(ДанныеЗапроса);
	
КонецФункции

// Возвращаемое значение:
//  Строка
Функция ТекстЗапросаДанныхСинхронизацииУчетныхЗаписейЭДО()
	
	Возврат
		"ВЫБРАТЬ
		|	МеткиВремениДанныхЭДО.ИдентификаторОбъекта КАК ИдентификаторОбъекта,
		|	МеткиВремениДанныхЭДО.ИдентификаторЭДО КАК ИдентификаторЭДО,
		|	МеткиВремениДанныхЭДО.МеткаВремени КАК МеткаВремени,
		|	УчетныеЗаписиЭДО.НаименованиеУчетнойЗаписи КАК НаименованиеУчетнойЗаписи,
		|	УчетныеЗаписиЭДО.НазначениеУчетнойЗаписи КАК НазначениеУчетнойЗаписи,
		|	УчетныеЗаписиЭДО.ПодробноеОписаниеУчетнойЗаписи КАК ПодробноеОписаниеУчетнойЗаписи,
		|	УчетныеЗаписиЭДО.ОператорЭДО КАК ОператорЭДО,
		|	УчетныеЗаписиЭДО.ПредставлениеОператораЭДО КАК ПредставлениеОператораЭДО,
		|	УчетныеЗаписиЭДО.СпособОбменаЭД КАК СпособОбменаЭД,
		|	УчетныеЗаписиЭДО.ЭлектроннаяПочтаДляУведомлений КАК ЭлектроннаяПочтаДляУведомлений,
		|	УчетныеЗаписиЭДО.ОжидатьИзвещениеОПолучении КАК ОжидатьИзвещениеОПолучении,
		|	УчетныеЗаписиЭДО.УведомлятьОНовыхПриглашениях КАК УведомлятьОНовыхПриглашениях,
		|	УчетныеЗаписиЭДО.УведомлятьОбОтветахНаПриглашения КАК УведомлятьОбОтветахНаПриглашения,
		|	УчетныеЗаписиЭДО.УведомлятьОНовыхДокументах КАК УведомлятьОНовыхДокументах,
		|	УчетныеЗаписиЭДО.УведомлятьОНеОбработанныхДокументах КАК УведомлятьОНеОбработанныхДокументах,
		|	УчетныеЗаписиЭДО.УведомлятьОбОкончанииСрокаДействияСертификата КАК УведомлятьОбОкончанииСрокаДействияСертификата,
		|	УчетныеЗаписиЭДО.КодНалоговогоОргана КАК КодНалоговогоОргана,
		|	УчетныеЗаписиЭДО.АдресОрганизации КАК АдресОрганизации,
		|	УчетныеЗаписиЭДО.Организация.ИНН КАК ОрганизацияИНН,
		|	УчетныеЗаписиЭДО.Организация.КПП КАК ОрганизацияКПП
		|ИЗ
		|	РегистрСведений.УчетныеЗаписиЭДО КАК УчетныеЗаписиЭДО
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.МеткиВремениДанныхЭДО КАК МеткиВремениДанныхЭДО
		|		ПО МеткиВремениДанныхЭДО.ИдентификаторЭДО = УчетныеЗаписиЭДО.ИдентификаторЭДО
		|		И МеткиВремениДанныхЭДО.ТипДанных = ЗНАЧЕНИЕ(Перечисление.ТипыСинхронизацииСЦентромЭДО.УчетныеЗаписиЭДО)
		|		И МеткиВремениДанныхЭДО.ИдентификаторОбъекта = УчетныеЗаписиЭДО.ИдентификаторЭДО
		|ГДЕ
		|	УчетныеЗаписиЭДО.ИдентификаторЭДО В (&ИдентификаторыЭДО)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	СертификатыУчетныхЗаписейЭДО.ИдентификаторЭДО КАК ИдентификаторЭДО,
		|	СертификатыУчетныхЗаписейЭДО.Сертификат КАК Сертификат,
		|	СертификатыУчетныхЗаписейЭДО.Доверенность КАК Доверенность,
		|	СертификатыУчетныхЗаписейЭДО.Должность КАК Должность
		|ИЗ
		|	РегистрСведений.СертификатыУчетныхЗаписейЭДО КАК СертификатыУчетныхЗаписейЭДО
		|ГДЕ
		|	СертификатыУчетныхЗаписейЭДО.ИдентификаторЭДО В (&ИдентификаторыЭДО)";
		
КонецФункции

// Параметры:
//  МеткиВремениПоИдентификаторамЭДО - см. ЭлектронныеДокументыЭДОЦентрЭДО.ПорцияДанныхСинхронизацииДокументовЭДОПоМеткамВремени.МеткиВремениПоИдентификаторамЭДО
//  Порция - Число
// 
// Возвращаемое значение:
//  См. ДанныеСинхронизацииУчетныхЗаписейЭДОПоДаннымЗапроса
Функция ДанныеСинхронизацииУчетныхЗаписейЭДОПоМеткамВремени(МеткиВремениПоИдентификаторамЭДО, Порция)
	
	ОписаниеЗапроса = Новый Структура("Параметры, Тексты", Новый Структура, Новый Массив);
	
	МеткиВремениДанныхЭДО.ДобавитьТекстЗапросаИдентификаторовДанныхПоМеткамВремени(
		ОписаниеЗапроса, Перечисления.ТипыСинхронизацииСЦентромЭДО.УчетныеЗаписиЭДО,
		МеткиВремениПоИдентификаторамЭДО, Порция);
	
	ДобавитьТекстЗапросаДанныхУчетныхЗаписейЭДОИзВременнойТаблицыМетокВремени(ОписаниеЗапроса);
	
	Запрос = Новый Запрос;
	Запрос.Текст = СтрСоединить(ОписаниеЗапроса.Тексты, ОбщегоНазначения.РазделительПакетаЗапросов());
	Для Каждого Параметр Из ОписаниеЗапроса.Параметры Цикл
		Запрос.УстановитьПараметр(Параметр.Ключ, Параметр.Значение);
	КонецЦикла;
	
	РезультатыЗапроса = Запрос.ВыполнитьПакет();
	ДанныеЗапроса = Новый Структура("ВыборкаРеквизитов, СписокСертификатов",
		РезультатыЗапроса[1].Выбрать(), РезультатыЗапроса[2].Выгрузить());
	
	Возврат ДанныеСинхронизацииУчетныхЗаписейЭДОПоДаннымЗапроса(ДанныеЗапроса);
	
КонецФункции

// Параметры:
//  МеткиВремениПоИдентификаторамЭДО - см. ЭлектронныеДокументыЭДОЦентрЭДО.ПорцияДанныхСинхронизацииДокументовЭДОПоМеткамВремени.МеткиВремениПоИдентификаторамЭДО
//  Порция - Число
// 
// Возвращаемое значение:
//  См. ДанныеСинхронизацииУчетныхЗаписейЭДОПоДаннымЗапросаВерсия3
Функция ДанныеСинхронизацииУчетныхЗаписейЭДОПоМеткамВремениВерсия3(МеткиВремениПоИдентификаторамЭДО, Порция)
	
	ОписаниеЗапроса = Новый Структура("Параметры, Тексты", Новый Структура, Новый Массив);
	
	МеткиВремениДанныхЭДО.ДобавитьТекстЗапросаИдентификаторовДанныхПоМеткамВремени(
		ОписаниеЗапроса, Перечисления.ТипыСинхронизацииСЦентромЭДО.УчетныеЗаписиЭДО,
		МеткиВремениПоИдентификаторамЭДО, Порция);
	
	ДобавитьТекстЗапросаДанныхУчетныхЗаписейЭДОИзВременнойТаблицыМетокВремени(ОписаниеЗапроса);
	
	Запрос = Новый Запрос;
	Запрос.Текст = СтрСоединить(ОписаниеЗапроса.Тексты, ОбщегоНазначения.РазделительПакетаЗапросов());
	Для Каждого Параметр Из ОписаниеЗапроса.Параметры Цикл
		Запрос.УстановитьПараметр(Параметр.Ключ, Параметр.Значение);
	КонецЦикла;
	
	РезультатыЗапроса = Запрос.ВыполнитьПакет();
	ДанныеЗапроса = Новый Структура("ВыборкаРеквизитов, СписокСертификатов",
		РезультатыЗапроса[1].Выбрать(), РезультатыЗапроса[2].Выгрузить());
	
	Возврат ДанныеСинхронизацииУчетныхЗаписейЭДОПоДаннымЗапросаВерсия3(ДанныеЗапроса);
	
КонецФункции

// Параметры:
//  ОписаниеЗапроса - Структура:
//  * Параметры - Структура
//  * Тексты - Массив из Строка
Процедура ДобавитьТекстЗапросаДанныхУчетныхЗаписейЭДОИзВременнойТаблицыМетокВремени(ОписаниеЗапроса)
	
	ТекстЗапроса =
		"ВЫБРАТЬ
		|	МеткиВремени.ИдентификаторОбъекта КАК ИдентификаторОбъекта,
		|	МеткиВремени.ИдентификаторЭДО КАК ИдентификаторЭДО,
		|	МеткиВремени.МеткаВремени КАК МеткаВремени,
		|	УчетныеЗаписиЭДО.НаименованиеУчетнойЗаписи КАК НаименованиеУчетнойЗаписи,
		|	УчетныеЗаписиЭДО.НазначениеУчетнойЗаписи КАК НазначениеУчетнойЗаписи,
		|	УчетныеЗаписиЭДО.ПодробноеОписаниеУчетнойЗаписи КАК ПодробноеОписаниеУчетнойЗаписи,
		|	УчетныеЗаписиЭДО.ОператорЭДО КАК ОператорЭДО,
		|	УчетныеЗаписиЭДО.ПредставлениеОператораЭДО КАК ПредставлениеОператораЭДО,
		|	УчетныеЗаписиЭДО.СпособОбменаЭД КАК СпособОбменаЭД,
		|	УчетныеЗаписиЭДО.ЭлектроннаяПочтаДляУведомлений КАК ЭлектроннаяПочтаДляУведомлений,
		|	УчетныеЗаписиЭДО.ОжидатьИзвещениеОПолучении КАК ОжидатьИзвещениеОПолучении,
		|	УчетныеЗаписиЭДО.УведомлятьОНовыхПриглашениях КАК УведомлятьОНовыхПриглашениях,
		|	УчетныеЗаписиЭДО.УведомлятьОбОтветахНаПриглашения КАК УведомлятьОбОтветахНаПриглашения,
		|	УчетныеЗаписиЭДО.УведомлятьОНовыхДокументах КАК УведомлятьОНовыхДокументах,
		|	УчетныеЗаписиЭДО.УведомлятьОНеОбработанныхДокументах КАК УведомлятьОНеОбработанныхДокументах,
		|	УчетныеЗаписиЭДО.УведомлятьОбОкончанииСрокаДействияСертификата КАК УведомлятьОбОкончанииСрокаДействияСертификата,
		|	УчетныеЗаписиЭДО.КодНалоговогоОргана КАК КодНалоговогоОргана,
		|	УчетныеЗаписиЭДО.АдресОрганизации КАК АдресОрганизации,
		|	УчетныеЗаписиЭДО.Организация.ИНН КАК ОрганизацияИНН,
		|	УчетныеЗаписиЭДО.Организация.КПП КАК ОрганизацияКПП,
		|	УчетныеЗаписиЭДО.ПринятыУсловияИспользования КАК ПринятыУсловияИспользования
		|ИЗ
		|	ИдентификаторыДанныхПоМеткамВремени КАК МеткиВремени
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.УчетныеЗаписиЭДО КАК УчетныеЗаписиЭДО
		|		ПО МеткиВремени.ИдентификаторОбъекта = УчетныеЗаписиЭДО.ИдентификаторЭДО
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	СертификатыУчетныхЗаписейЭДО.ИдентификаторЭДО КАК ИдентификаторЭДО,
		|	СертификатыУчетныхЗаписейЭДО.Сертификат КАК Сертификат,
		|	СертификатыУчетныхЗаписейЭДО.Доверенность КАК Доверенность,
		|	СертификатыУчетныхЗаписейЭДО.Должность КАК Должность
		|ИЗ
		|	РегистрСведений.СертификатыУчетныхЗаписейЭДО КАК СертификатыУчетныхЗаписейЭДО
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ИдентификаторыДанныхПоМеткамВремени КАК МеткиВремени
		|		ПО МеткиВремени.ИдентификаторОбъекта = СертификатыУчетныхЗаписейЭДО.ИдентификаторЭДО";
	
	ОписаниеЗапроса.Тексты.Добавить(ТекстЗапроса);
	
КонецПроцедуры

// Параметры:
//  ДанныеЗапроса - Структура:
//  * ВыборкаРеквизитов - ВыборкаИзРезультатаЗапроса:
//    ** ИдентификаторОбъекта - Строка
//    ** ИдентификаторЭДО - Строка
//    ** МеткаВремени - Число
//    ** НаименованиеУчетнойЗаписи - Строка
//    ** НазначениеУчетнойЗаписи - Строка
//    ** ПодробноеОписаниеУчетнойЗаписи - Строка
//    ** ОператорЭДО - Строка
//    ** ПредставлениеОператораЭДО - Строка
//    ** СпособОбменаЭД - ПеречислениеСсылка.СпособыОбменаЭД
//    ** ЭлектроннаяПочтаДляУведомлений - Строка
//    ** ОжидатьИзвещениеОПолучении - Булево
//    ** УведомлятьОНовыхПриглашениях - Булево
//    ** УведомлятьОбОтветахНаПриглашения - Булево
//    ** УведомлятьОНовыхДокументах - Булево
//    ** УведомлятьОНеОбработанныхДокументах - Булево
//    ** УведомлятьОбОкончанииСрокаДействияСертификата - Булево
//    ** КодНалоговогоОргана - Строка
//    ** АдресОрганизации - Строка
//    ** ОрганизацияИНН - Строка
//    ** ОрганизацияКПП - Строка
//    ** ПринятыУсловияИспользования - Булево
//  * СписокСертификатов - ТаблицаЗначений:
//    ** ИдентификаторЭДО - Строка
//    ** Сертификат - см. РегистрСведений.СертификатыУчетныхЗаписейЭДО.Сертификат
//    ** Доверенность - см. РегистрСведений.СертификатыУчетныхЗаписейЭДО.Доверенность
// 
// Возвращаемое значение:
//  Массив из см. НовыеДанныеСинхронизацииУчетнойЗаписиЭДО
Функция ДанныеСинхронизацииУчетныхЗаписейЭДОПоДаннымЗапроса(ДанныеЗапроса)
	
	НаборДанных = Новый Массив; // Массив из см. НовыеДанныеСинхронизацииУчетнойЗаписиЭДО
	
	Выборка = ДанныеЗапроса.ВыборкаРеквизитов;
	СписокСертификатов = ДанныеЗапроса.СписокСертификатов;
	
	Сертификаты = Новый Массив; // Массив из см. РегистрСведений.СертификатыУчетныхЗаписейЭДО.Сертификат
	Доверенности = Новый Массив; // Массив из см. РегистрСведений.СертификатыУчетныхЗаписейЭДО.Доверенность
	Для Каждого Сведения Из СписокСертификатов Цикл
		ОбщегоНазначенияБЭД.ДобавитьУникальноеЗначение(Сертификаты, Сведения.Сертификат);
		ОбщегоНазначенияБЭД.ДобавитьУникальноеЗначение(Доверенности, Сведения.Доверенность);
	КонецЦикла;
	
	УстановитьПривилегированныйРежим(Истина);
	ДвоичныеДанныеСертификатов = КриптографияБЭД.ДвоичныеДанныеСертификатов(Сертификаты);
	УстановитьПривилегированныйРежим(Ложь);
	
	ОписанияСертификатовПоИдентификаторамЭДО = Новый Соответствие;
	
	Для Каждого Сведения Из СписокСертификатов Цикл
		ОписаниеСертификата = НовоеОписаниеСертификатаУчетнойЗаписиЭДО();
		ОписаниеСертификата.Данные = Base64Строка(ДвоичныеДанныеСертификатов[Сведения.Сертификат]);
		Если ЗначениеЗаполнено(Сведения.Доверенность) Тогда
			ОписаниеСертификата.Доверенность = МашиночитаемыеДоверенностиЦентрЭДО.ДанныеДоверенностиВФорматеСервиса(
				Сведения.Доверенность);
		КонецЕсли;
		ОписанияСертификатов = ОписанияСертификатовПоИдентификаторамЭДО[Сведения.ИдентификаторЭДО];
		Если ОписанияСертификатов = Неопределено Тогда
			ОписанияСертификатов = Новый Массив; // Массив из см. НовоеОписаниеСертификатаУчетнойЗаписиЭДО
			ОписанияСертификатовПоИдентификаторамЭДО.Вставить(Сведения.ИдентификаторЭДО, ОписанияСертификатов);
		КонецЕсли;
		ОписанияСертификатов.Добавить(ОписаниеСертификата);
	КонецЦикла;
	
	Пока Выборка.Следующий() Цикл
		
		ДанныеСинхронизации = НовыеДанныеСинхронизацииУчетнойЗаписиЭДО();
		ДанныеСинхронизации.Идентификатор = Выборка.ИдентификаторОбъекта;
		НаборДанных.Добавить(ДанныеСинхронизации);
		
		Состояние = НовоеСостояниеСинхронизацииУчетнойЗаписиЭДО();
		Состояние.ИдентификаторЭДО = Выборка.ИдентификаторЭДО;
		Состояние.МеткаВремени = Выборка.МеткаВремени;
		Состояние.Удаление = Не ЗначениеЗаполнено(Выборка.НаименованиеУчетнойЗаписи);
		ДанныеСинхронизации.Состояние = Состояние;
		
		Если Не ЗначениеЗаполнено(Выборка.НаименованиеУчетнойЗаписи) Тогда
			Продолжить;
		КонецЕсли;
		
		Описание = НовоеОписаниеУчетнойЗаписиЭДО();
		Описание.Идентификатор = Выборка.ИдентификаторЭДО;
		Описание.Наименование = Выборка.НаименованиеУчетнойЗаписи;
		Описание.Назначение = Выборка.НазначениеУчетнойЗаписи;
		Описание.ПодробноеОписание = Выборка.ПодробноеОписаниеУчетнойЗаписи;
		Описание.ОператорЭДО = Выборка.ОператорЭДО;
		Описание.ПредставлениеОператораЭДО = Выборка.ПредставлениеОператораЭДО;
		Описание.СпособОбмена = ОбщегоНазначения.ИмяЗначенияПеречисления(Выборка.СпособОбменаЭД);
		Описание.ЭлектроннаяПочтаДляУведомлений = Выборка.ЭлектроннаяПочтаДляУведомлений;
		Описание.ОжидатьИзвещениеОПолучении = Выборка.ОжидатьИзвещениеОПолучении;
		Описание.УведомлятьОНовыхПриглашениях = Выборка.УведомлятьОНовыхПриглашениях;
		Описание.УведомлятьОбОтветахНаПриглашения = Выборка.УведомлятьОбОтветахНаПриглашения;
		Описание.УведомлятьОНовыхДокументах = Выборка.УведомлятьОНовыхДокументах;
		Описание.УведомлятьОНеОбработанныхДокументах = Выборка.УведомлятьОНеОбработанныхДокументах;
		Описание.УведомлятьОбОкончанииСрокаДействияСертификата = Выборка.УведомлятьОбОкончанииСрокаДействияСертификата;
		Описание.КодНалоговогоОргана = Выборка.КодНалоговогоОргана;
		Описание.АдресОрганизации = Выборка.АдресОрганизации;
		Описание.Организация.ИНН = Выборка.ОрганизацияИНН;
		Описание.Организация.КПП = Выборка.ОрганизацияКПП;
		Описание.ПринятыУсловияИспользования = Выборка.ПринятыУсловияИспользования;
		
		ОписанияСертификатов = ОписанияСертификатовПоИдентификаторамЭДО[Выборка.ИдентификаторЭДО];
		Если ЗначениеЗаполнено(ОписанияСертификатов) Тогда
			Описание.Сертификаты = ОписанияСертификатов;
		КонецЕсли;
		
		ДанныеСинхронизации.Описание = Описание;
		
	КонецЦикла;
	
	Возврат НаборДанных;
	
КонецФункции

// Параметры:
//  ДанныеЗапроса - Структура:
//  * ВыборкаРеквизитов - ВыборкаИзРезультатаЗапроса:
//    ** ИдентификаторОбъекта - Строка
//    ** ИдентификаторЭДО - Строка
//    ** МеткаВремени - Число
//    ** НаименованиеУчетнойЗаписи - Строка
//    ** НазначениеУчетнойЗаписи - Строка
//    ** ПодробноеОписаниеУчетнойЗаписи - Строка
//    ** ОператорЭДО - Строка
//    ** ПредставлениеОператораЭДО - Строка
//    ** СпособОбменаЭД - ПеречислениеСсылка.СпособыОбменаЭД
//    ** ЭлектроннаяПочтаДляУведомлений - Строка
//    ** ОжидатьИзвещениеОПолучении - Булево
//    ** УведомлятьОНовыхПриглашениях - Булево
//    ** УведомлятьОбОтветахНаПриглашения - Булево
//    ** УведомлятьОНовыхДокументах - Булево
//    ** УведомлятьОНеОбработанныхДокументах - Булево
//    ** УведомлятьОбОкончанииСрокаДействияСертификата - Булево
//    ** КодНалоговогоОргана - Строка
//    ** АдресОрганизации - Строка
//    ** ОрганизацияИНН - Строка
//    ** ОрганизацияКПП - Строка
//    ** ПринятыУсловияИспользования - Булево
//  * СписокСертификатов - ТаблицаЗначений:
//    ** ИдентификаторЭДО - Строка
//    ** Сертификат - см. РегистрСведений.СертификатыУчетныхЗаписейЭДО.Сертификат
//    ** Доверенность - см. РегистрСведений.СертификатыУчетныхЗаписейЭДО.Доверенность
//    ** Должность - Строка
// 
// Возвращаемое значение:
//  Массив из см. НовыеДанныеСинхронизацииУчетнойЗаписиЭДО
Функция ДанныеСинхронизацииУчетныхЗаписейЭДОПоДаннымЗапросаВерсия3(ДанныеЗапроса)
	
	НаборДанных = Новый Массив; // Массив из см. НовыеДанныеСинхронизацииУчетнойЗаписиЭДО
	
	Выборка = ДанныеЗапроса.ВыборкаРеквизитов;
	СписокСертификатов = ДанныеЗапроса.СписокСертификатов;
	
	Сертификаты = Новый Массив; // Массив из см. РегистрСведений.СертификатыУчетныхЗаписейЭДО.Сертификат
	Доверенности = Новый Массив; // Массив из см. РегистрСведений.СертификатыУчетныхЗаписейЭДО.Доверенность
	Для Каждого Сведения Из СписокСертификатов Цикл
		ОбщегоНазначенияБЭД.ДобавитьУникальноеЗначение(Сертификаты, Сведения.Сертификат);
		ОбщегоНазначенияБЭД.ДобавитьУникальноеЗначение(Доверенности, Сведения.Доверенность);
	КонецЦикла;
	
	УстановитьПривилегированныйРежим(Истина);
	ДвоичныеДанныеСертификатов = КриптографияБЭД.ДвоичныеДанныеСертификатов(Сертификаты);
	УстановитьПривилегированныйРежим(Ложь);
	
	ОписанияСертификатовПоИдентификаторамЭДО = Новый Соответствие;
	
	Для Каждого Сведения Из СписокСертификатов Цикл
		ОписаниеСертификата = НовоеОписаниеСертификатаУчетнойЗаписиЭДОВерсия3();
		ОписаниеСертификата.Данные = Base64Строка(ДвоичныеДанныеСертификатов[Сведения.Сертификат]);
		Если ЗначениеЗаполнено(Сведения.Доверенность) Тогда
			ОписаниеСертификата.ИдентификаторДоверенности = МашиночитаемыеДоверенностиЦентрЭДО.ИдентификаторДоверенности(Сведения.Доверенность);
		КонецЕсли;
		ОписаниеСертификата.Должность = Сведения.Должность;
		ОписанияСертификатов = ОписанияСертификатовПоИдентификаторамЭДО[Сведения.ИдентификаторЭДО];
		Если ОписанияСертификатов = Неопределено Тогда
			ОписанияСертификатов = Новый Массив; // Массив из см. НовоеОписаниеСертификатаУчетнойЗаписиЭДОВерсия3
			ОписанияСертификатовПоИдентификаторамЭДО.Вставить(Сведения.ИдентификаторЭДО, ОписанияСертификатов);
		КонецЕсли;
		ОписанияСертификатов.Добавить(ОписаниеСертификата);
	КонецЦикла;
	
	Пока Выборка.Следующий() Цикл
		
		ДанныеСинхронизации = НовыеДанныеСинхронизацииУчетнойЗаписиЭДО();
		ДанныеСинхронизации.Идентификатор = Выборка.ИдентификаторОбъекта;
		НаборДанных.Добавить(ДанныеСинхронизации);
		
		Состояние = НовоеСостояниеСинхронизацииУчетнойЗаписиЭДО();
		Состояние.ИдентификаторЭДО = Выборка.ИдентификаторЭДО;
		Состояние.МеткаВремени = Выборка.МеткаВремени;
		Состояние.Удаление = Не ЗначениеЗаполнено(Выборка.НаименованиеУчетнойЗаписи);
		ДанныеСинхронизации.Состояние = Состояние;
		
		Если Не ЗначениеЗаполнено(Выборка.НаименованиеУчетнойЗаписи) Тогда
			Продолжить;
		КонецЕсли;
		
		Описание = НовоеОписаниеУчетнойЗаписиЭДО();
		Описание.Идентификатор = Выборка.ИдентификаторЭДО;
		Описание.Наименование = Выборка.НаименованиеУчетнойЗаписи;
		Описание.Назначение = Выборка.НазначениеУчетнойЗаписи;
		Описание.ПодробноеОписание = Выборка.ПодробноеОписаниеУчетнойЗаписи;
		Описание.ОператорЭДО = Выборка.ОператорЭДО;
		Описание.ПредставлениеОператораЭДО = Выборка.ПредставлениеОператораЭДО;
		Описание.СпособОбмена = ОбщегоНазначения.ИмяЗначенияПеречисления(Выборка.СпособОбменаЭД);
		Описание.ЭлектроннаяПочтаДляУведомлений = Выборка.ЭлектроннаяПочтаДляУведомлений;
		Описание.ОжидатьИзвещениеОПолучении = Выборка.ОжидатьИзвещениеОПолучении;
		Описание.УведомлятьОНовыхПриглашениях = Выборка.УведомлятьОНовыхПриглашениях;
		Описание.УведомлятьОбОтветахНаПриглашения = Выборка.УведомлятьОбОтветахНаПриглашения;
		Описание.УведомлятьОНовыхДокументах = Выборка.УведомлятьОНовыхДокументах;
		Описание.УведомлятьОНеОбработанныхДокументах = Выборка.УведомлятьОНеОбработанныхДокументах;
		Описание.УведомлятьОбОкончанииСрокаДействияСертификата = Выборка.УведомлятьОбОкончанииСрокаДействияСертификата;
		Описание.КодНалоговогоОргана = Выборка.КодНалоговогоОргана;
		Описание.АдресОрганизации = Выборка.АдресОрганизации;
		Описание.Организация.ИНН = Выборка.ОрганизацияИНН;
		Описание.Организация.КПП = Выборка.ОрганизацияКПП;
		Описание.ПринятыУсловияИспользования = Выборка.ПринятыУсловияИспользования;
		
		ОписанияСертификатов = ОписанияСертификатовПоИдентификаторамЭДО[Выборка.ИдентификаторЭДО];
		Если ЗначениеЗаполнено(ОписанияСертификатов) Тогда
			Описание.Сертификаты = ОписанияСертификатов;
		КонецЕсли;
		
		ДанныеСинхронизации.Описание = Описание;
		
	КонецЦикла;
	
	Возврат НаборДанных;
	
КонецФункции

// Возвращаемое значение:
//  Структура:
//  * Идентификатор - Строка
//  * Состояние - Неопределено
//              - см. НовоеСостояниеСинхронизацииУчетнойЗаписиЭДО
//  * Описание  - Неопределено
//              - см. НовоеОписаниеУчетнойЗаписиЭДО
Функция НовыеДанныеСинхронизацииУчетнойЗаписиЭДО()
	Данные = Новый Структура;
	Данные.Вставить("Идентификатор", "");
	Данные.Вставить("Состояние", Неопределено);
	Данные.Вставить("Описание", Неопределено);
	Возврат Данные;
КонецФункции

// Возвращаемое значение:
//  Структура:
//  * ИдентификаторЭДО - Строка 
//  * МеткаВремени - Число
//  * Удаление - Булево
Функция НовоеСостояниеСинхронизацииУчетнойЗаписиЭДО()
	Состояние = Новый Структура;
	Состояние.Вставить("ИдентификаторЭДО", "");
	Состояние.Вставить("МеткаВремени", 0);
	Состояние.Вставить("Удаление", Ложь);
	Возврат Состояние;
КонецФункции

// Возвращаемое значение:
//  Структура:
//  * Идентификатор - Строка
//  * Наименование - Строка
//  * Назначение - Строка
//  * ПодробноеОписание - Строка
//  * ОператорЭДО - Строка
//  * ПредставлениеОператораЭДО - Строка
//  * СпособОбмена - Строка
//  * ЭлектроннаяПочтаДляУведомлений - Строка
//  * ОжидатьИзвещениеОПолучении - Булево
//  * УведомлятьОНовыхПриглашениях - Булево
//  * УведомлятьОбОтветахНаПриглашения - Булево
//  * УведомлятьОНовыхДокументах - Булево
//  * УведомлятьОНеОбработанныхДокументах - Булево
//  * УведомлятьОбОкончанииСрокаДействияСертификата - Булево
//  * КодНалоговогоОргана - Строка
//  * АдресОрганизации - Строка
//  * Организация - Структура:
//  ** ИНН - Строка
//  ** КПП - Строка
//  * Сертификаты - Массив из см. НовоеОписаниеСертификатаУчетнойЗаписиЭДО
//  * ПринятыУсловияИспользования - Булево
Функция НовоеОписаниеУчетнойЗаписиЭДО()
	Описание = Новый Структура;
	Описание.Вставить("Идентификатор", "");
	Описание.Вставить("Наименование", "");
	Описание.Вставить("Назначение", "");
	Описание.Вставить("ПодробноеОписание", "");
	Описание.Вставить("ОператорЭДО", "");
	Описание.Вставить("ПредставлениеОператораЭДО", "");
	Описание.Вставить("СпособОбмена", "");
	Описание.Вставить("ЭлектроннаяПочтаДляУведомлений", "");
	Описание.Вставить("ОжидатьИзвещениеОПолучении", Ложь);
	Описание.Вставить("УведомлятьОНовыхПриглашениях", Ложь);
	Описание.Вставить("УведомлятьОбОтветахНаПриглашения", Ложь);
	Описание.Вставить("УведомлятьОНовыхДокументах", Ложь);
	Описание.Вставить("УведомлятьОНеОбработанныхДокументах", Ложь);
	Описание.Вставить("УведомлятьОбОкончанииСрокаДействияСертификата", Ложь);
	Описание.Вставить("КодНалоговогоОргана", "");
	Описание.Вставить("АдресОрганизации", "");
	Описание.Вставить("Организация", Новый Структура);
	Описание.Организация.Вставить("ИНН", "");
	Описание.Организация.Вставить("КПП", "");
	Описание.Вставить("Сертификаты", Новый Массив);
	Описание.Вставить("ПринятыУсловияИспользования", Ложь);
	
	Возврат Описание;
КонецФункции

// Возвращаемое значение:
//  Структура:
//  * Данные - Строка
//  * Доверенность - Неопределено
//                 - см. НовыеДанныеДоверенностиСертификатаУчетнойЗаписиЭДО
Функция НовоеОписаниеСертификатаУчетнойЗаписиЭДО()
	Описание = Новый Структура;
	Описание.Вставить("Данные", "");
	Описание.Вставить("Доверенность", Неопределено);
	Возврат Описание;
КонецФункции

// Возвращаемое значение:
//  Структура:
//  * Данные - Строка
//  * ИдентификаторДоверенности - Строка
//                 - см. НовыеДанныеДоверенностиСертификатаУчетнойЗаписиЭДО
//  * Должность - Строка
Функция НовоеОписаниеСертификатаУчетнойЗаписиЭДОВерсия3()
	
	Описание = Новый Структура;
	Описание.Вставить("Данные", "");
	Описание.Вставить("ИдентификаторДоверенности", "");
	Описание.Вставить("Должность", "");
	Возврат Описание;
	
КонецФункции

// Параметры:
//  ДанныеДляСинхронизации - см. СинхронизацияЭДОСлужебный.ДанныеДляСинхронизации
// 
// Возвращаемое значение:
//  Неопределено,Массив из Структура:
//  * ИдентификаторУчетнойЗаписиЭДО - Строка
//  * Тип - Строка
//  * Текст - Строка
Функция ОбработатьОшибкиСинхронизации(ДанныеДляСинхронизации) Экспорт
	
	ОшибкиПоУчетнымЗаписям = Новый Соответствие;
	УчетныеЗаписиЭДО.ОбработатьОшибкиСинхронизации(ДанныеДляСинхронизации, ОшибкиПоУчетнымЗаписям);
	Если Не ЗначениеЗаполнено(ОшибкиПоУчетнымЗаписям) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	ОшибкиВФорматеСервиса = Новый Массив; // Массив из Структура
	
	Для Каждого ОшибкаПоУчетнойЗаписи Из ОшибкиПоУчетнымЗаписям Цикл
		ОписаниеОбработаннойУчетнойЗаписи = ОшибкаПоУчетнойЗаписи.Значение; // См. ДиагностикаЭДОКлиентСервер.НовоеОписаниеОбработаннойУчетнойЗаписи
		ИнформацияОбОшибке = ОписаниеОбработаннойУчетнойЗаписи.ИнформацияОбОшибке;
		ОшибкаВФорматеСервиса = Новый Структура;
		ОшибкаВФорматеСервиса.Вставить("ИдентификаторУчетнойЗаписиЭДО", ОшибкаПоУчетнойЗаписи.Ключ);
		ОшибкаВФорматеСервиса.Вставить("Тип", ИнформацияОбОшибке.ВидОшибки);
		ОшибкаВФорматеСервиса.Вставить("Текст", Строка(ИнформацияОбОшибке.ПодробноеПредставление.Текст));
		ОшибкиВФорматеСервиса.Добавить(ОшибкаВФорматеСервиса);
	КонецЦикла;
	
	Возврат ОшибкиВФорматеСервиса;
	
КонецФункции

#КонецОбласти