
#Область ПрограммныйИнтерфейс

// Обрабатывает отсканированные штрихкоды:
//	- добавляет информацию об отсканированных штрихкодах в табличную часть объекта формы,
//	- вызывает помощник создания штрихкодов, если они не были найдены в информационной базе.
//
// Параметры:
//	Форма - ФормаКлиентскогоПриложения - форма для которой будут обработаны отсканированные штрихкоды.
//	Объект - ДанныеФормыСтруктура - объект формы, в табличную часть которого добавляется информация отсканированных
//									штрихкодов.
//	СтруктураПараметров - см. ШтрихкодированиеНоменклатурыКлиентСервер.ПараметрыОбработкиШтрихкодов.
//	КэшированныеЗначения - см. ПакетнаяОбработкаТабличнойЧастиКлиентСервер.ПолучитьСтруктуруКэшируемыеЗначения.
//
Процедура ОбработатьШтрихкоды(Форма, Объект, СтруктураПараметров, КэшированныеЗначения) Экспорт
	
	// Если нужно будет изменять количество, то данные формы нужно заблокировать
	// Если заблокировать не удастся - вылетит исключение.
	Если СтруктураПараметров.ИзменятьКоличество
		И СтруктураПараметров.БлокироватьДанныеФормы Тогда
		Форма.ЗаблокироватьДанныеФормыДляРедактирования();
	КонецЕсли;
	
	ИспользоватьУпаковочныеЛисты = ПолучитьФункциональнуюОпцию("ИспользоватьУпаковочныеЛисты");
	
	Модифицированность = Ложь;
	
	Если КэшированныеЗначения = Неопределено Тогда
		КэшированныеЗначения = ПакетнаяОбработкаТабличнойЧастиКлиентСервер.ПолучитьСтруктуруКэшируемыеЗначения();
	КонецЕсли;
	
	КэшированныеЗначения.ПравоРегистрацииШтрихкодовНоменклатурыДоступно = ПравоРегистрацииШтрихкодовНоменклатурыДоступно();
	
	ПрефиксыВесовыхШтрихкодов = ЗначениеНастроекПовтИсп.ПолучитьПрефиксыВесовыхШтрихкодов();
	
	Если ТипЗнч(СтруктураПараметров.Штрихкоды) = Тип("Массив") Тогда
		МассивШтрихкодов = СтруктураПараметров.Штрихкоды;
	Иначе
		МассивШтрихкодов = Новый Массив;
		МассивШтрихкодов.Добавить(СтруктураПараметров.Штрихкоды);
	КонецЕсли;
	
	ПолучитьДанныеПоШтрихкодам		= Не (МассивШтрихкодов.Количество() > 0
										И МассивШтрихкодов[0].Свойство("Номенклатура"));
	ШтрихкодыНоменклатуры			= Новый Массив;
	НеЗакэшированныеРанееШтрихкоды	= Новый Массив;
	
	Для Каждого ТекШтрихкод Из МассивШтрихкодов Цикл
		ТекШтрихкод.Штрихкод = ВРег(СокрЛП(ТекШтрихкод.Штрихкод));
		РегистрыСведений.ШтрихкодыНоменклатуры.ПреобразоватьВесовойШтрихкод(ТекШтрихкод, ПрефиксыВесовыхШтрихкодов);
		
		Если ПолучитьДанныеПоШтрихкодам Тогда
			Если Не ЗначениеЗаполнено(КэшированныеЗначения.Штрихкоды[ТекШтрихкод.Штрихкод])
				Или КэшированныеЗначения.Штрихкоды[ТекШтрихкод.Штрихкод].НеизвестныйШтрихкод Тогда
				
				НеЗакэшированныеРанееШтрихкоды.Добавить(ТекШтрихкод.Штрихкод);
				
			КонецЕсли;
		Иначе
			ШтрихкодыНоменклатуры.Добавить(ТекШтрихкод);
			НеЗакэшированныеРанееШтрихкоды.Добавить(ТекШтрихкод.Штрихкод);
		КонецЕсли;
	КонецЦикла;
	
	Если НеЗакэшированныеРанееШтрихкоды.Количество() > 0 Тогда
		Если ПолучитьДанныеПоШтрихкодам Тогда
			РегистрыСведений.ШтрихкодыНоменклатуры.ПолучитьДанныеПоШтрихкодамРасширенный(КэшированныеЗначения,
																						НеЗакэшированныеРанееШтрихкоды);
		Иначе
			РегистрыСведений.ШтрихкодыНоменклатуры.ПолучитьДанныеПоШтрихкодамНоменклатуры(КэшированныеЗначения,
																							ШтрихкодыНоменклатуры);
		КонецЕсли;
		
		Если ИспользоватьУпаковочныеЛисты
			И СтруктураПараметров.УчитыватьУпаковочныеЛисты Тогда
			
			Документы.УпаковочныйЛист.ДополнитьДанныеПоШтрихкодам(КэшированныеЗначения, НеЗакэшированныеРанееШтрихкоды);
			
		КонецЕсли;
	КонецЕсли;
	
	// Строки ТЧ для пакетной обработки.
	ДобавленныеТовары        = Новый Массив;
	ИзмененныеТовары         = Новый Массив;
	ДобавленныеКомплектующие = Новый Массив;
	ИзмененныеКомплектующие  = Новый Массив;
	ОбрабатываемыеСтроки     = Новый Массив;
	
	ТарыПоСтрокамТЧ = Новый Структура;
	ТарыПоСтрокамТЧ.Вставить("ДобавленныеТары", Новый Массив);
	ТарыПоСтрокамТЧ.Вставить("ИзмененныеТары", Новый Массив);
	
	// Данные строк ТЧ для постобработки.
	ДанныеСтрокТЧ                     = Новый Соответствие;
	ДанныеСтрокТЧКомплектующие        = Новый Соответствие;
	СтрокиДляОбработкиСерий           = Новый Массив;
	МассивСтрокСНаборами              = Новый Массив;
	МассивСтрокСУпЛистамиДляОбработки = Новый Массив;
	
	ТекущаяСтрока = Неопределено;
	
	Если СтруктураПараметров.ПараметрыПроверкиАссортимента <> Неопределено Тогда
		ПроверятьАссортимент = АссортиментСерверПовтИсп.КонтролироватьАссортимент(
			СтруктураПараметров.ПараметрыПроверкиАссортимента.Склад,
			СтруктураПараметров.ПараметрыПроверкиАссортимента.Дата);
		СтруктураПараметров.ПараметрыПроверкиАссортимента.Вставить("ПроверятьАссортимент", ПроверятьАссортимент);
	КонецЕсли;
	
	Назначения = Назначения(Объект, СтруктураПараметров, КэшированныеЗначения.Штрихкоды);
	
	ИспользоватьСерииНоменклатуры = СтруктураПараметров.ПараметрыУказанияСерий <> Неопределено
		И СтруктураПараметров.ПараметрыУказанияСерий.ИспользоватьСерииНоменклатуры;
	ДобавлятьТарыПоСтрокеТЧ = ПолучитьФункциональнуюОпцию("ИспользоватьМногооборотнуюТару")
		И СтруктураПараметров.ДополнятьТарой
		И СтруктураПараметров.ИзменятьКоличество
		И Не СтруктураПараметров.НеИспользоватьУпаковки
		И Не СтруктураПараметров.ТолькоУслуги
		И Не СтруктураПараметров.ТолькоРаботы
		И Не СтруктураПараметров.ТолькоТара;
	
	Если ИспользоватьСерииНоменклатуры Тогда
		ЗаполнитьИспользованиеГруппыСкладов(Объект, СтруктураПараметров);
		
		СкладыВТЧ = СтруктураПараметров.ИспользуетсяГруппаСкладов <> Ложь
					И НоменклатураСервер.СкладыУказываютсяВТабличнойЧасти(СтруктураПараметров.ПараметрыУказанияСерий);
		
		Если (Не СкладыВТЧ
				И СтруктураПараметров.ПараметрыУказанияСерий.ЭтоЗаказ)
			Или Не СтруктураПараметров.ПараметрыУказанияСерий.ЭтоЗаказ Тогда
			
			НоменклатураСервер.ЗаполнитьСкладПоПараметрамУказанияСерий(
				Объект,
				СтруктураПараметров,
				СтруктураПараметров.ПараметрыУказанияСерий);
			
		КонецЕсли;
	КонецЕсли;
	
	ШтрихкодыСерий = Новый Массив;
	НеКэшируемыеШтрихкоды = Новый Массив;
	
	// Сохраняется исходное значение параметра, которое может быть изменено по настройкам номенклатуры.
	НеИспользоватьУпаковки = СтруктураПараметров.НеИспользоватьУпаковки;
	
	Для Каждого ТекШтрихкод Из МассивШтрихкодов Цикл
		
		ДобавляемыеДанные = КэшированныеЗначения.Штрихкоды[ТекШтрихкод.Штрихкод];
		СтруктураПараметров.НеИспользоватьУпаковки = НеИспользоватьУпаковки;
		
		Если Не ПолучитьДанныеПоШтрихкодам
			И (ДобавляемыеДанные.НеуникальныйШтрихкод
				Или Не ДобавляемыеДанные.ПолученПоДаннымИБ) Тогда
			
			НеКэшируемыеШтрихкоды.Добавить(ТекШтрихкод.Штрихкод);
			
		КонецЕсли;
		
		Если ДобавляемыеДанные.НеизвестныйШтрихкод Тогда
			Если Не СтруктураПараметров.УчитыватьУпаковочныеЛисты Тогда
				ТекШтрихкод = ОбщегоНазначения.СкопироватьРекурсивно(ТекШтрихкод, Ложь);
				
				СтруктураПараметров.НеизвестныеШтрихкоды.Добавить(ТекШтрихкод);
				
				Если ДобавляемыеДанные.НеуникальныйШтрихкод
					И Не СтруктураПараметров.ИзменятьКоличество Тогда
					
					СтруктураПараметров.НеуникальныеШтрихкоды.Вставить(ТекШтрихкод.Штрихкод, Истина);
					
				КонецЕсли;
				
				Продолжить;
			КонецЕсли;
		ИначеЕсли ДобавляемыеДанные.ТипНоменклатуры <> Перечисления.ТипыНоменклатуры.Набор
			И Не СоответствуетУсловиям(ДобавляемыеДанные, СтруктураПараметров) Тогда
			
			Продолжить;
			
		КонецЕсли;
		
		Если ДобавляемыеДанные.ТипНоменклатуры <> Перечисления.ТипыНоменклатуры.Набор Тогда
			
			Если Не ДобавляемыеДанные.ШтрихкодНоменклатуры Тогда
				ШтрихкодыСерий.Добавить(ТекШтрихкод.Штрихкод);
			КонецЕсли;
			
			ДобавляемыеДанные.КоличествоПоШтрихкоду = ТекШтрихкод.Количество;
			ДобавляемыеДанные.ШтрихкодНеИзКэша      = НеЗакэшированныеРанееШтрихкоды.Найти(ТекШтрихкод.Штрихкод) <> Неопределено;
			РежимОбработки = "Товар";
			
			СтрокаТЧ = ДобавитьИзменитьСтрокуВТЧ(Объект,
												СтруктураПараметров,
												ДобавляемыеДанные,
												РежимОбработки,
												КэшированныеЗначения,
												МассивСтрокСУпЛистамиДляОбработки,
												Назначения);
			
			Если СтрокаТЧ <> Неопределено Тогда
				НеИспользоватьУпаковкиПодборТары = СтруктураПараметров.НеИспользоватьУпаковки;
				Если ДобавляемыеДанные.ПоставляетсяВМногооборотнойТаре Тогда
					НеИспользоватьУпаковкиПодборТары = Ложь;
				КонецЕсли;
				
				Данные = Новый Структура;
				Данные.Вставить("НеизвестныйШтрихкод",		ДобавляемыеДанные.НеизвестныйШтрихкод);
				Данные.Вставить("КоличествоШтрихкод",		ТекШтрихкод.Количество);
				Данные.Вставить("НеИспользоватьУпаковки",	НеИспользоватьУпаковкиПодборТары);
				Данные.Вставить("УпаковочныйЛист",			ДобавляемыеДанные.УпаковочныйЛист);
				Данные.Вставить("ДополнятьТарой",			ДобавлятьТарыПоСтрокеТЧ);
				Данные.Вставить("СтрокаДобавлена",			Ложь);
				
				ОшибкаДобавленияТовара = Ложь;
				
				Если ИспользоватьСерииНоменклатуры
					И (ДобавляемыеДанные.ВыполненныеДействия.Добавлено
						Или ДобавляемыеДанные.ВыполненныеДействия.Изменено)
					И Не (СтруктураПараметров.ПараметрыУказанияСерий.ИмяИсточникаЗначенийВФормеОбъекта = "ЭтаФорма"
						И Объект.ИмяФормы = "ОбщаяФорма.ПроверкаЗаполненияДокументов")
					И ЗаполнитьСериюВТЧСерии(ДобавляемыеДанные, СтруктураПараметров) Тогда
					
					ДанныеЗаполненияСерии = ДанныеЗаполненияСерииВТЧСерии(
												СтрокаТЧ,
												ДобавляемыеДанные,
												СтруктураПараметров);
					
					ОшибкаДобавленияТовара = ДанныеЗаполненияСерии.Количество > 1
												И Не ДанныеЗаполненияСерии.ИспользоватьКоличествоСерии;
					
					Если Не ОшибкаДобавленияТовара Тогда
						СтрокиДляОбработкиСерий.Добавить(ДанныеЗаполненияСерии);
						
						// Товары, идентифицируемые поэкземплярно в разрезе серий можно добавить в ТЧ Товары один раз.
						// Тара для таких товаров добавляется после обработки ТЧ Серии.
						Если ДобавлятьТарыПоСтрокеТЧ Тогда
							Данные.ДополнятьТарой = ДанныеЗаполненияСерии.ИспользоватьКоличествоСерии;
						КонецЕсли;
					Иначе
						ОтменаИзмененийВСтрокеСОшибкой(Объект, ДобавляемыеДанные, СтрокаТЧ, СтруктураПараметров);
						
						ПредставлениеНоменклатуры = НоменклатураКлиентСервер.ПредставлениеНоменклатуры(
														СокрЛП(Строка(СтрокаТЧ.Номенклатура)),
														СокрЛП(Строка(СтрокаТЧ.Характеристика)));
						
						ТекстСообщения = НСтр("ru = 'Отсканированное количество товара ""%1"" с серией ""%2"" по штрихкоду ""%3"" равно %4. Политика учета серий данного товара предусматривает, что количество по любой серии этого товара всегда будет равно 1.'");
						ТекстСообщения = СтрШаблон(ТекстСообщения,
													ПредставлениеНоменклатуры,
													СокрЛП(Строка(ДобавляемыеДанные.Серия)),
													ДобавляемыеДанные.Штрихкод,
													Формат(ДанныеЗаполненияСерии.Количество, "ЧН=0; ЧГ="));
						
						ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);
					КонецЕсли;
				КонецЕсли;
				
				Если ОшибкаДобавленияТовара Тогда
					Если ДобавляемыеДанные.ВыполненныеДействия.Изменено Тогда
						ОбрабатываемыеСтроки.Добавить(СтрокаТЧ);
						
						ДанныеСтрокТЧ.Вставить(СтрокаТЧ, Данные);
					КонецЕсли;
				Иначе
					Если ДобавляемыеДанные.ВыполненныеДействия.Добавлено Тогда
						Данные.СтрокаДобавлена = Истина;
						
						ДобавленныеТовары.Добавить(СтрокаТЧ);
					ИначеЕсли ДобавляемыеДанные.ВыполненныеДействия.Изменено Тогда
						ИзмененныеТовары.Добавить(СтрокаТЧ);
					КонецЕсли;
					
					ДанныеСтрокТЧ.Вставить(СтрокаТЧ, Данные);
				КонецЕсли;
				
			КонецЕсли;
			
		Иначе
			
			Если ПроверитьАссортимент(Объект, СтруктураПараметров, ДобавляемыеДанные) Тогда
				
				ДобавляемыеКомплектующие = Новый Массив;
				ОшибкаДобавленияКомплектующих = Ложь;
				
				Комплектующие = Комплектующие(ДобавляемыеДанные.Номенклатура, ДобавляемыеДанные.Характеристика);
				
				Если Не НаборСоответствуетУсловиям(ДобавляемыеДанные, СтруктураПараметров, Комплектующие) Тогда
					Продолжить;
				КонецЕсли;
				
				Для Каждого СтрокаКомплектующие Из Комплектующие Цикл
					
					Если Не СоответствуетУсловиям(СтрокаКомплектующие, СтруктураПараметров) Тогда
						ОшибкаДобавленияКомплектующих = Истина;
						Продолжить;
					КонецЕсли;
					
					СтрокаКомплектующие.КоличествоПоШтрихкоду = ТекШтрихкод.Количество;
					СтрокаКомплектующие.ШтрихкодНеИзКэша      = Истина;
					РежимОбработки = "КомплектующаяНабора";
					ДобавляемыеДанные.НеизвестныйШтрихкод = Ложь;
					
					СтрокаТЧ = ДобавитьИзменитьСтрокуВТЧ(Объект,
														СтруктураПараметров,
														СтрокаКомплектующие,
														РежимОбработки,
														КэшированныеЗначения);
					
					Если СтрокаТЧ <> Неопределено Тогда
						Данные = Новый Структура;
						Данные.Вставить("СтрокаТЧ", СтрокаТЧ);
						Данные.Вставить("ДобавляемыеДанные", СтрокаКомплектующие);
						ДобавляемыеКомплектующие.Добавить(Данные);
						ДанныеСтрокТЧКомплектующие.Вставить(СтрокаТЧ, Данные);
						
						Если СтрокаКомплектующие.ВыполненныеДействия.Добавлено Тогда
							ДобавленныеКомплектующие.Добавить(СтрокаТЧ);
						ИначеЕсли СтрокаКомплектующие.ВыполненныеДействия.Изменено Тогда
							ИзмененныеКомплектующие.Добавить(СтрокаТЧ);
						КонецЕсли;
					Иначе
						ОшибкаДобавленияКомплектующих = Истина;
					КонецЕсли;
				КонецЦикла;
				
				Если ОшибкаДобавленияКомплектующих
					И (ДобавляемыеДанные.ВариантРасчетаЦеныНабора = Перечисления.ВариантыРасчетаЦенНаборов.ЦенаЗадаетсяЗаНаборРаспределяетсяПоДолям
						Или ДобавляемыеДанные.ВариантРасчетаЦеныНабора = Перечисления.ВариантыРасчетаЦенНаборов.ЦенаЗадаетсяЗаНаборРаспределяетсяПоЦенам) Тогда
					Для Каждого Данные Из ДобавляемыеКомплектующие Цикл
						ОтменаИзмененийВСтрокеСОшибкой(Объект,
														Данные.ДобавляемыеДанные,
														Данные.СтрокаТЧ,
														СтруктураПараметров);
						
						Если Данные.ДобавляемыеДанные.ВыполненныеДействия.Изменено Тогда
							ОбрабатываемыеСтроки.Добавить(Данные.СтрокаТЧ);
						КонецЕсли;
					КонецЦикла;
				КонецЕсли;
				
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЦикла;
	
	СтруктураПараметров.НеИспользоватьУпаковки = НеИспользоватьУпаковки;
	
	// Подготовка строк ТЧ для выполнения пакетной обработки.
	ИзмененныеСтрокиТЧ = Новый Массив;
	ОбщегоНазначенияКлиентСервер.ДополнитьМассив(ИзмененныеСтрокиТЧ, ИзмененныеТовары);
	ОбщегоНазначенияКлиентСервер.ДополнитьМассив(ИзмененныеСтрокиТЧ, ИзмененныеКомплектующие);
	ОбщегоНазначенияКлиентСервер.ДополнитьМассив(ИзмененныеСтрокиТЧ, ОбрабатываемыеСтроки);
	
	ДобавленныеСтрокиТЧ = Новый Массив;
	ОбщегоНазначенияКлиентСервер.ДополнитьМассив(ДобавленныеСтрокиТЧ, ДобавленныеТовары);
	ОбщегоНазначенияКлиентСервер.ДополнитьМассив(ДобавленныеСтрокиТЧ, ДобавленныеКомплектующие);
	
	ДобавленныеИзмененныеСтрокиТЧ = Новый Массив;
	ОбщегоНазначенияКлиентСервер.ДополнитьМассив(ДобавленныеИзмененныеСтрокиТЧ, ИзмененныеТовары);
	ОбщегоНазначенияКлиентСервер.ДополнитьМассив(ДобавленныеИзмененныеСтрокиТЧ, ДобавленныеТовары);
	
	// Предварительное заполнение строк тар для единого вызова пакетных обработок.
	Если ДобавлятьТарыПоСтрокеТЧ Тогда
		ДополнитьТабличнуюЧастьТарой(Объект,
									СтруктураПараметров,
									КэшированныеЗначения,
									ДобавленныеИзмененныеСтрокиТЧ,
									ДанныеСтрокТЧ,
									ТарыПоСтрокамТЧ);
		
		ОбщегоНазначенияКлиентСервер.ДополнитьМассив(ИзмененныеСтрокиТЧ,  ТарыПоСтрокамТЧ.ИзмененныеТары);
		ОбщегоНазначенияКлиентСервер.ДополнитьМассив(ДобавленныеСтрокиТЧ, ТарыПоСтрокамТЧ.ДобавленныеТары);
	КонецЕсли;
	
	ПакетнаяОбработкаТабличнойЧастиСервер.ОбработатьСтрокиТЧ(ИзмененныеСтрокиТЧ,
		СтруктураПараметров.СтруктураДействийСИзмененнымиСтроками,
		Объект[СтруктураПараметров.ИмяТЧ],
		КэшированныеЗначения);
	ПакетнаяОбработкаТабличнойЧастиСервер.ОбработатьСтрокиТЧ(ДобавленныеСтрокиТЧ,
		СтруктураПараметров.СтруктураДействийСДобавленнымиСтроками,
		Объект[СтруктураПараметров.ИмяТЧ],
		КэшированныеЗначения);
	
	// Обработка строк ТЧ, учет серий для которых ведется в отдельной табличной части.
	СтрокиТЧИдентифицируемыеПоСерии = Новый Структура;
	СтрокиТЧИдентифицируемыеПоСерии.Вставить("ИзмененныеТовары", Новый Массив);
	СтрокиТЧИдентифицируемыеПоСерии.Вставить("ОбрабатываемыеСтроки", Новый Массив);
	
	ЗаполнитьСерии(Объект, СтрокиДляОбработкиСерий, СтруктураПараметров, ДанныеСтрокТЧ, СтрокиТЧИдентифицируемыеПоСерии);
	
	ИзмененныеСтрокиТЧ = Новый Массив;
	ОбщегоНазначенияКлиентСервер.ДополнитьМассив(ИзмененныеСтрокиТЧ,
												СтрокиТЧИдентифицируемыеПоСерии.ОбрабатываемыеСтроки);
	
	ДобавленныеСтрокиТЧ = Новый Массив;
	
	ТарыПоСтрокамТЧИдентифицируемыхПоСерии = Новый Структура;
	ТарыПоСтрокамТЧИдентифицируемыхПоСерии.Вставить("ДобавленныеТары", Новый Массив);
	ТарыПоСтрокамТЧИдентифицируемыхПоСерии.Вставить("ИзмененныеТары", Новый Массив);
	
	Если ДобавлятьТарыПоСтрокеТЧ Тогда
		ДополнитьТабличнуюЧастьТарой(Объект,
									СтруктураПараметров,
									КэшированныеЗначения,
									СтрокиТЧИдентифицируемыеПоСерии.ИзмененныеТовары,
									ДанныеСтрокТЧ,
									ТарыПоСтрокамТЧИдентифицируемыхПоСерии);
		
		ОбщегоНазначенияКлиентСервер.ДополнитьМассив(ИзмененныеСтрокиТЧ,
													ТарыПоСтрокамТЧИдентифицируемыхПоСерии.ИзмененныеТары);
		ОбщегоНазначенияКлиентСервер.ДополнитьМассив(ДобавленныеСтрокиТЧ,
													ТарыПоСтрокамТЧИдентифицируемыхПоСерии.ДобавленныеТары);
	КонецЕсли;
	
	ПакетнаяОбработкаТабличнойЧастиСервер.ОбработатьСтрокиТЧ(ИзмененныеСтрокиТЧ,
		СтруктураПараметров.СтруктураДействийСИзмененнымиСтроками,
		Объект[СтруктураПараметров.ИмяТЧ],
		КэшированныеЗначения);
	ПакетнаяОбработкаТабличнойЧастиСервер.ОбработатьСтрокиТЧ(ДобавленныеСтрокиТЧ,
		СтруктураПараметров.СтруктураДействийСДобавленнымиСтроками,
		Объект[СтруктураПараметров.ИмяТЧ],
		КэшированныеЗначения);
	
	// Постобработка товаров.
	Для Каждого СтрокаТЧ Из ДобавленныеИзмененныеСтрокиТЧ Цикл
		
		Данные = ДанныеСтрокТЧ.Получить(СтрокаТЧ);
		Если Не ЗначениеЗаполнено(Данные.УпаковочныйЛист)
			И Не Данные.НеизвестныйШтрихкод
			И ИспользоватьСерииНоменклатуры Тогда
			ПостобработкаСтатусовУказанияСерийСтрокиТЧ(СтрокаТЧ, Объект, СтруктураПараметров, КэшированныеЗначения);
		КонецЕсли;
		ПостобработкаСтрокиТЧТовара(СтрокаТЧ, Данные, Объект, СтруктураПараметров, КэшированныеЗначения);
		
		ТекущаяСтрока = СтрокаТЧ.ПолучитьИдентификатор();
		Модифицированность = Истина;
		
	КонецЦикла;
	
	// Постобработка тар.
	Если ДобавлятьТарыПоСтрокеТЧ
		И ИспользоватьСерииНоменклатуры Тогда
		ДобавленныеИзмененныеСтрокиТЧ = Новый Массив;
		ОбщегоНазначенияКлиентСервер.ДополнитьМассив(ДобавленныеИзмененныеСтрокиТЧ, ТарыПоСтрокамТЧ.ИзмененныеТары);
		ОбщегоНазначенияКлиентСервер.ДополнитьМассив(ДобавленныеИзмененныеСтрокиТЧ, ТарыПоСтрокамТЧ.ДобавленныеТары);
		ОбщегоНазначенияКлиентСервер.ДополнитьМассив(ДобавленныеИзмененныеСтрокиТЧ,
													ТарыПоСтрокамТЧИдентифицируемыхПоСерии.ИзмененныеТары);
		ОбщегоНазначенияКлиентСервер.ДополнитьМассив(ДобавленныеИзмененныеСтрокиТЧ,
													ТарыПоСтрокамТЧИдентифицируемыхПоСерии.ДобавленныеТары);
		
		Для Каждого СтрокаТЧ Из ДобавленныеИзмененныеСтрокиТЧ Цикл
			ПостобработкаСтатусовУказанияСерийСтрокиТЧ(СтрокаТЧ, Объект, СтруктураПараметров, КэшированныеЗначения);
		КонецЦикла;
	КонецЕсли;

	// Постобработка комплектующих.
	ДобавленныеИзмененныеСтрокиТЧ = Новый Массив;
	ОбщегоНазначенияКлиентСервер.ДополнитьМассив(ДобавленныеИзмененныеСтрокиТЧ, ИзмененныеКомплектующие);
	ОбщегоНазначенияКлиентСервер.ДополнитьМассив(ДобавленныеИзмененныеСтрокиТЧ, ДобавленныеКомплектующие);
	
	Для Каждого СтрокаТЧ Из ДобавленныеИзмененныеСтрокиТЧ Цикл
		Данные = ДанныеСтрокТЧ.Получить(СтрокаТЧ);
		
		// СтрокаТЧ товара может быть добавлена как комплектующая в составе набора и раннее была уже обработана.
		Если Данные <> Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		Данные = ДанныеСтрокТЧКомплектующие.Получить(СтрокаТЧ);
		
		Если Не ЗначениеЗаполнено(Данные.ДобавляемыеДанные.УпаковочныйЛист)
			И Не Данные.ДобавляемыеДанные.НеизвестныйШтрихкод
			И ИспользоватьСерииНоменклатуры Тогда
				
			ПостобработкаСтатусовУказанияСерийСтрокиТЧ(Данные.СтрокаТЧ, Объект, СтруктураПараметров, КэшированныеЗначения);
			
		КонецЕсли;
		
		ПостобработкаСтрокиТЧКомплектующейНабора(Данные.СтрокаТЧ, МассивСтрокСНаборами);
	КонецЦикла;

	Если СтруктураПараметров.РассчитыватьНаборы И ОбщегоНазначенияУТКлиентСервер.ЕстьРеквизитОбъекта(Объект, "Валюта") Тогда
		
		Если ОбщегоНазначенияУТКлиентСервер.ЕстьРеквизитОбъекта(Объект, "Соглашение") Тогда
			ПараметрыРасчета = Новый Структура;
			ПараметрыРасчета.Вставить("Дата", Объект.Дата);
			ПараметрыРасчета.Вставить("Валюта", Объект.Валюта);
			ПараметрыРасчета.Вставить("Соглашение", Объект.Соглашение);
			ПараметрыРасчета.Вставить("РассчитыватьНаборы", СтруктураПараметров.РассчитыватьНаборы);
			ПараметрыРасчета.Вставить("ПоляЗаполнения", "Цена, ВидЦены");
		Иначе
			ПараметрыРасчета = Новый Структура;
			ПараметрыРасчета.Вставить("Дата", Объект.Дата);
			ПараметрыРасчета.Вставить("Валюта", Объект.Валюта);
			ПараметрыРасчета.Вставить("ВидЦены", Объект.ВидЦены);
			ПараметрыРасчета.Вставить("РассчитыватьНаборы", СтруктураПараметров.РассчитыватьНаборы);
			ПараметрыРасчета.Вставить("ПоляЗаполнения", "Цена, ВидЦены");
			
		КонецЕсли;
		
		Если ОбщегоНазначенияУТКлиентСервер.ЕстьРеквизитОбъекта(Объект, "Организация") Тогда
			ПараметрыРасчета.Вставить("Организация", Объект.Организация);
		КонецЕсли;
		
		Если СтруктураПараметров.НеИспользоватьУпаковки
			И ЗначениеЗаполнено(СтруктураПараметров.ИмяКолонкиУпаковка) Тогда
			
			ПараметрКолонкиПоЗначению = Новый Структура(СтруктураПараметров.ИмяКолонкиУпаковка,
				Справочники.УпаковкиЕдиницыИзмерения.ПустаяСсылка());
			
			ПараметрыРасчета.Вставить("КолонкиПоЗначению", ПараметрКолонкиПоЗначению);
			
		КонецЕсли;
		
		ЦеныПредприятияЗаполнениеСервер.ЗаполнитьЦены(
			Объект[СтруктураПараметров.ИмяТЧ],
			МассивСтрокСНаборами, // Массив строк или структура отбора
			ПараметрыРасчета,
			СтруктураПараметров.СтруктураДействийСИзмененнымиСтроками);
	
	КонецЕсли;
	
	Если Модифицированность Тогда
		Форма.Модифицированность = Истина;
		Если ИспользоватьУпаковочныеЛисты
			И СтруктураПараметров.УчитыватьУпаковочныеЛисты Тогда
			Если СтруктураПараметров.ОтработатьИзменениеУпаковочныхЛистов Тогда
				УпаковочныеЛистыСервер.ДополнитьСтрокамиПоУпаковочнымЛистам(Форма, Объект[СтруктураПараметров.ИмяТЧ],
					МассивСтрокСУпЛистамиДляОбработки);
				НоменклатураСервер.ЗаполнитьСтатусыУказанияСерий(Форма.Объект, Форма.ПараметрыУказанияСерий, МассивСтрокСУпЛистамиДляОбработки);
			КонецЕсли;
			УпаковочныеЛистыСервер.ПеренумероватьСтроки(Форма, Объект[СтруктураПараметров.ИмяТЧ], Форма.МаксимальныйНомерСтроки);
			УпаковочныеЛистыСервер.ЗаполнитьСлужебныеРеквизиты(Форма, Объект[СтруктураПараметров.ИмяТЧ],
					СтруктураПараметров.СтруктураДействийСоСтрокамиИзУпаковочныхЛистов, МассивСтрокСУпЛистамиДляОбработки);
		КонецЕсли;
	КонецЕсли;
	
	Для Каждого Штрихкод Из НеКэшируемыеШтрихкоды Цикл
		КэшированныеЗначения.Штрихкоды.Удалить(Штрихкод);
	КонецЦикла;
	
	Если ШтрихкодыСерий.Количество() > 0 Тогда
		РегистрыСведений.ШтрихкодыНоменклатуры.ЗарегистрироватьШтрихкодыЭтикетокСерийНоменклатуры(
			ШтрихкодыСерий,
			КэшированныеЗначения);
	КонецЕсли;
	
	СтруктураПараметров.ТекущаяСтрока = ТекущаяСтрока;
	
КонецПроцедуры

// Возвращает признак доступности права регистрации штрихкодов номенклатуры.
//
// Возвращаемое значение:
//	Булево - Истина, если доступно право регистрации штрихкодов номенклатуры.
//
Функция ПравоРегистрацииШтрихкодовНоменклатурыДоступно() Экспорт
	
	Возврат ПравоДоступа("Изменение", Метаданные.РегистрыСведений.ШтрихкодыНоменклатуры);
	
КонецФункции

// Возвращает ссылку на номенклатуру, соответствующую переданному штрихкоду или Неопределено, если штрихкод не зарегистрирован.
//
// Параметры:
//	ПараметрыОбработки - см. ШтрихкодированиеНоменклатурыКлиентСервер.ПараметрыОбработкиШтрихкодов.
//	КэшированныеЗначения - см. ПакетнаяОбработкаТабличнойЧастиКлиентСервер.ПолучитьСтруктуруКэшируемыеЗначения.
//
// Возвращаемое значение:
//	СправочникСсылка.Номенклатура, Неопределено - результат поиска номенклатуры по штрихкоду.
//
Функция НоменклатураПоШтрихкоду(ПараметрыОбработки, КэшированныеЗначения) Экспорт
	
	Если КэшированныеЗначения = Неопределено Тогда
		КэшированныеЗначения = ПакетнаяОбработкаТабличнойЧастиКлиентСервер.ПолучитьСтруктуруКэшируемыеЗначения();
		КэшированныеЗначения.ПравоРегистрацииШтрихкодовНоменклатурыДоступно = ПравоРегистрацииШтрихкодовНоменклатурыДоступно();
	КонецЕсли;
	
	ПрефиксыВесовыхШтрихкодов		= ЗначениеНастроекПовтИсп.ПолучитьПрефиксыВесовыхШтрихкодов();
	НеЗакешированныеРанееШтрихкоды	= Новый Массив;
	
	ПараметрыОбработки.Штрихкоды.Штрихкод = ВРег(СокрЛП(ПараметрыОбработки.Штрихкоды.Штрихкод));
	
	РегистрыСведений.ШтрихкодыНоменклатуры.ПреобразоватьВесовойШтрихкод(ПараметрыОбработки.Штрихкоды,
																		ПрефиксыВесовыхШтрихкодов);
	
	Если Не ЗначениеЗаполнено(КэшированныеЗначения.Штрихкоды[ПараметрыОбработки.Штрихкоды.Штрихкод])
		Или КэшированныеЗначения.Штрихкоды[ПараметрыОбработки.Штрихкоды.Штрихкод].НеизвестныйШтрихкод Тогда
		
		НеЗакешированныеРанееШтрихкоды.Добавить(ПараметрыОбработки.Штрихкоды.Штрихкод);
		
	КонецЕсли;
	
	Если НеЗакешированныеРанееШтрихкоды.Количество() > 0 Тогда
		РегистрыСведений.ШтрихкодыНоменклатуры.ПолучитьДанныеПоШтрихкодам(КэшированныеЗначения,
																			НеЗакешированныеРанееШтрихкоды);
	КонецЕсли;
	
	ДобавляемыеДанные = КэшированныеЗначения.Штрихкоды[ПараметрыОбработки.Штрихкоды.Штрихкод];
	
	Если ДобавляемыеДанные.НеизвестныйШтрихкод Тогда
		ПараметрыОбработки.НеизвестныеШтрихкоды.Добавить(ПараметрыОбработки.Штрихкоды);
		
		Возврат Неопределено;
	Иначе
		Возврат ДобавляемыеДанные.Номенклатура;
	КонецЕсли;
	
КонецФункции

// Раскладывает переданный массив считанных штрихкодов по типам штрихкодов.
//
// Параметры:
//	Штрихкоды - Массив Из см. ШтрихкодированиеНоменклатурыКлиент.СтруктураДанныхШтрихкода - коллекция описания состава штрихкода.
//
// Возвращаемое значение:
//	Структура - коллекция описания типов штрихкодов, содержащая следующие свойства:
//		* БезТипа - Массив из см. ШтрихкодированиеНоменклатурыКлиент.СтруктураДанныхШтрихкода.
//
Функция СтруктураПоТипамШтрихкодов(Штрихкоды) Экспорт
	
	Результат = Новый Структура();
	Результат.Вставить("БезТипа", Новый Массив);
	
	Для Каждого СтрМас Из Штрихкоды Цикл
		
		Если Не НоменклатураЛокализация.ОтнестиШтрихкодКТипу(Результат, СтрМас) Тогда 
			Результат.БезТипа.Добавить(СтрМас);
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Результат;
КонецФункции

// Заполняет параметры условий по типам номенклатуры.
//
// Параметры:
//	СтруктураДействий - см. ШтрихкодированиеНоменклатурыКлиент.ПараметрыОбработкиШтрихкодов.
//	ТипыНоменклатуры - СписокЗначений из ПеречислениеСсылка.ТипыНоменклатуры,
//						Массив из ПеречислениеСсылка.ТипыНоменклатуры - данные по типам номенклатуры.
//
Процедура ОпределитьУсловияТиповНоменклатурОбработкиШтрихкодов(СтруктураДействий, ТипыНоменклатуры) Экспорт
	
	Если ТипЗнч(ТипыНоменклатуры) = Тип("СписокЗначений") Тогда
		ТипыНоменклатурыМассив = ТипыНоменклатуры.ВыгрузитьЗначения();
	Иначе
		ТипыНоменклатурыМассив = ТипыНоменклатуры;
	КонецЕсли;
	
	Если ТипыНоменклатурыМассив.Найти(Перечисления.ТипыНоменклатуры.Товар) <> Неопределено Тогда
		ЕстьРаботы = ТипыНоменклатурыМассив.Найти(Перечисления.ТипыНоменклатуры.Работа) <> Неопределено;
		ЕстьУслуги = ТипыНоменклатурыМассив.Найти(Перечисления.ТипыНоменклатуры.Услуга) <> Неопределено;
		ЕстьТара   = ТипыНоменклатурыМассив.Найти(Перечисления.ТипыНоменклатуры.МногооборотнаяТара) <> Неопределено;
		
		СтруктураДействий.ТолькоТоварыИРабота = ЕстьРаботы И Не ЕстьУслуги;
		СтруктураДействий.ТолькоТоварыИУслуги = Не ЕстьРаботы И ЕстьУслуги;
		СтруктураДействий.ТолькоТовары        = Не ЕстьРаботы И Не ЕстьУслуги;
		СтруктураДействий.ДополнятьТарой      = ЕстьТара
												И СтруктураДействий.ТолькоТовары;
		СтруктураДействий.ИспользоватьТаруВКачествеТовара = ЕстьТара
															И СтруктураДействий.ТолькоТовары;
	Иначе
		Если ТипыНоменклатурыМассив.Найти(Перечисления.ТипыНоменклатуры.Услуга) <> Неопределено Тогда
			СтруктураДействий.ТолькоУслуги = Истина;
		ИначеЕсли ТипыНоменклатурыМассив.Найти(Перечисления.ТипыНоменклатуры.Работа) <> Неопределено Тогда
			СтруктураДействий.ТолькоРаботы = Истина;
		ИначеЕсли ТипыНоменклатурыМассив.Найти(Перечисления.ТипыНоменклатуры.МногооборотнаяТара) <> Неопределено Тогда
			СтруктураДействий.ТолькоТара   = Истина;
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

// Извлекает из штрихкода информацию о номере и сроке годности.
// Работает только для штрихкодов, сгенерированных обработкой печати штрихкодов и номеров серий, сгенерированных формой
// регистрации серий.
//
// Параметры:
//	Штрихкод - Строка - штрихкод, из которого нужно извлечь информацию.
//	ЕстьПолеНомер - Булево - признак, что для серии, чей штрихкод передан, используется номер.
//	ЕстьПолеГоденДо - Булево - признак, что для серии, чей штрихкод передан, используется номер.
//	СообщатьОбОшибках - Булево - признак, необходимости вывода сообщения пользователю об ошибке получения сведений
//									реквизитов серии номенклатуры из штрихкода.
//
// Возвращаемое значение:
//	Структура:
//		* Номер - Строка - номер, извлеченный из штрихкода, если номера у серии нет - пустая строка.
//		* ГоденДо - Дата - дата срока годности, если срока годности у серии нет - пустая дата.
//		* ЕстьОшибка - Булево - признак наличия ошибки при получении сведений реквизитов серии номенклатуры из штрихкода.
//
Функция ИнформацияОСерииИзШтрихкода(Знач Штрихкод, ЕстьПолеНомер, ЕстьПолеГоденДо, СообщатьОбОшибках = Истина) Экспорт
	
	Результат = Новый Структура;
	Результат.Вставить("Номер",			"");
	Результат.Вставить("ГоденДо",		'00010101');
	Результат.Вставить("ЕстьОшибка",	Ложь);
	
	Штрихкод = СокрЛП(Штрихкод);
	
	Если ЕстьПолеНомер Тогда
		
		Результат.Номер = Штрихкод;
		
		Если ЕстьПолеГоденДо Тогда
			
			Если СтрДлина(Результат.Номер) >= 6 Тогда
				
				Если СтрДлина(Результат.Номер) >= 8 Тогда
					СрокГодностиИзШтрихкода	= Прав(Результат.Номер, 8);
					Результат.ГоденДо		= ДатаИзСтрокиШтрихкода(СрокГодностиИзШтрихкода);
					
					Если ЗначениеЗаполнено(Результат.ГоденДо) Тогда
						Результат.Номер = Лев(Результат.Номер,СтрДлина(Результат.Номер) - 8);
					КонецЕсли;
				КонецЕсли;
				
				Если Не ЗначениеЗаполнено(Результат.ГоденДо) Тогда
					
					СрокГодностиИзШтрихкода = Прав(Результат.Номер, 6);
					Результат.ГоденДо		= ДатаИзСтрокиШтрихкода(СрокГодностиИзШтрихкода);
					
					Если ЗначениеЗаполнено(Результат.ГоденДо) Тогда
						Результат.Номер = Лев(Результат.Номер, СтрДлина(Результат.Номер) - 6);
					КонецЕсли;
					
				КонецЕсли;
				
			КонецЕсли;
			
		КонецЕсли;
	Иначе
		
		Результат.ГоденДо = ДатаИзСтрокиШтрихкода(Штрихкод);
		
	КонецЕсли;
	
	Результат.ЕстьОшибка = Не ЗначениеЗаполнено(Результат.Номер)
							И Не ЗначениеЗаполнено(Результат.ГоденДо);
	
	Если СообщатьОбОшибках
		И Результат.ЕстьОшибка Тогда
		
		Если ЕстьПолеНомер
			И ЕстьПолеГоденДо Тогда
			ТекстСообщения = НСтр("ru = 'Ошибка преобразования штрихкода %Штрихкод% в номер серии и срок годности. Попробуйте повторить сканирование.'");
		ИначеЕсли ЕстьПолеНомер Тогда
			ТекстСообщения = НСтр("ru = 'Ошибка преобразования штрихкода %Штрихкод% в номер серии. Попробуйте повторить сканирование.'");
		Иначе 
			ТекстСообщения = НСтр("ru = 'Ошибка преобразования штрихкода %Штрихкод% в срок годности. Попробуйте повторить сканирование.'");
		КонецЕсли;
		
		ТекстСообщения = СтрЗаменить(ТекстСообщения, "%Штрихкод%", Штрихкод);
		
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

#Область RFID

// Выполняется обработка считанных RFID-меток.
//
// Параметры:
//	ДанныеМеток					- Массив из Структура	- данные меток.
//	ПараметрыОбработки			- см. ПараметрыОбработкиСчитанныхRFID.
//	ТЧСерии						- ТабличнаяЧасть		- табличная часть Серии.
//	ИдентификаторТекущейСтроки	- Число					- идентификатор.
// 
// Возвращаемое значение:
//	Структура - содержит свойства:
//		* ЗакрытьФорму - Булево - признак необходимости закрыть форму
//		* ИдентификаторТекущейСтроки - Число, Неопределено - идентификатор
//		* ДанныеСерии - СтрокаТабличнойЧасти, Неопределено - строка с серией.
//
Функция ОбработатьСчитываниеRFID(ДанныеМеток, ПараметрыОбработки, ТЧСерии = Неопределено, ИдентификаторТекущейСтроки = Неопределено) Экспорт
	
	НастройкиИспользованияСерий = ПараметрыОбработки.НастройкиИспользованияСерий;
	
	КорректноСчитанныеМетки = Новый Массив;
	
	Для Каждого Метка Из ДанныеМеток Цикл
		
		// Если TID не считался, то нельзя считать чтение метки успешным
		Если ЗначениеЗаполнено(Метка.TID) Тогда
			КорректноСчитанныеМетки.Добавить(Метка);
		КонецЕсли;
		
	КонецЦикла;
	
	Результат = Новый Структура;
	Результат.Вставить("ЗакрытьФорму", Ложь);
	Результат.Вставить("ИдентификаторТекущейСтроки", Неопределено);
	Результат.Вставить("ДанныеСерии", Неопределено);
	
	// От считывателя одна и та же метка могла приехать несколько раз
	// Поэтому сначала свернем приехавшие данные.
	ТаблицаМеток = ОбщегоНазначенияУТ.МассивВТаблицуЗначений(КорректноСчитанныеМетки);
	ИменаКолонок = Новый Массив;
	
	Для Каждого Колонка Из ТаблицаМеток.Колонки Цикл
		ИменаКолонок.Добавить(Колонка.Имя);
	КонецЦикла;
	
	ТаблицаМеток.Свернуть(СтрСоединить(ИменаКолонок,","));
	
	Если ТаблицаМеток.Количество() > 1 Тогда
		ТекстСообщения = НСтр("ru = 'Считалось сразу несколько RFID-метки. Оставьте в зоне действия считывателя только одну метку и повторите считывание.'");
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);
		Возврат Результат;
	КонецЕсли;
	
	ОбрабатываемаяСтрока = Неопределено;
	
	Если ТЧСерии = Неопределено Тогда
		ТЧСерии = Новый ТаблицаЗначений;
		ТЧСерии.Колонки.Добавить("Серия", Новый ОписаниеТипов("СправочникСсылка.СерииНоменклатуры"));
		ТЧСерии.Колонки.Добавить("Количество", ОбщегоНазначения.ОписаниеТипаЧисло(1));
		ТЧСерии.Колонки.Добавить("КоличествоУпаковок", ОбщегоНазначения.ОписаниеТипаЧисло(1));
		
		ТЧСерии.Колонки.Добавить("RFIDTID", Метаданные.ОпределяемыеТипы.RFIDTID.Тип);
		ТЧСерии.Колонки.Добавить("RFIDUser",ОбщегоНазначения.ОписаниеТипаСтрока(30));
		ТЧСерии.Колонки.Добавить("RFIDEPC",ОбщегоНазначения.ОписаниеТипаСтрока(30));
		ТЧСерии.Колонки.Добавить("EPCGTIN", Метаданные.ОпределяемыеТипы.GTIN.Тип);
		ТЧСерии.Колонки.Добавить("НужноЗаписатьМетку", Новый ОписаниеТипов("Булево"));
		ТЧСерии.Колонки.Добавить("ЗаполненRFIDTID", Новый ОписаниеТипов("Булево"));
		ТЧСерии.Колонки.Добавить("СтатусРаботыRFID", ОбщегоНазначения.ОписаниеТипаЧисло(1));
		
		Для Каждого Описание Из НастройкиИспользованияСерий.ОписанияИспользованияРеквизитовСерии Цикл
			Если Описание.ИмяНастройки <> "ИспользоватьRFIDМеткиСерии"
				И Описание.Использование Тогда
				МетаданныеРеквизита = Метаданные.Справочники.СерииНоменклатуры.Реквизиты.Найти(Описание.ИмяРеквизита);
				
				Если МетаданныеРеквизита = Неопределено Тогда
					ТекстИсключения = НСтр("ru = 'Реквизит %ИмяРеквизита% не найден среди реквизитов справочника """"Серии номенклатуры""""'");
					ТекстИсключения = СтрЗаменить(ТекстИсключения, "%ИмяРеквизита%", Описание.ИмяРеквизита);
					
					ВызватьИсключение ТекстИсключения;
				КонецЕсли;
				
				ТЧСерии.Колонки.Добавить(Описание.ИмяРеквизита, МетаданныеРеквизита.Тип);
			КонецЕсли;
			
		КонецЦикла;
	КонецЕсли;
	
	ТекущаяМетка = ТаблицаМеток[0];
	
	ОбрабатываемаяСтрока = ДобавитьСериюПоИнформацииОМетке(ТекущаяМетка, ПараметрыОбработки, ТЧСерии, ИдентификаторТекущейСтроки);	
	
	ПараметрыЗаполненияФлаговРаботыСМеткой = ПараметрыЗаполненияФлаговРаботыСМеткой();
	ПараметрыЗаполненияФлаговРаботыСМеткой.ТекущаяМетка = ТекущаяМетка;
	ПараметрыЗаполненияФлаговРаботыСМеткой.НастройкиИспользованияСерий = ПараметрыОбработки.НастройкиИспользованияСерий;
	ПараметрыЗаполненияФлаговРаботыСМеткой.ЗначенияПолейСвязи = ПараметрыОбработки.ЗначенияПолейСвязи;
	ЗаполнитьФлагиРаботыСМеткой(ОбрабатываемаяСтрока, ПараметрыЗаполненияФлаговРаботыСМеткой);
	
	Если ОбщегоНазначенияУТ.РежимОтладки() Тогда
		СтрокаМетки = "";
		
		Для Каждого Колонка Из ТаблицаМеток.Колонки Цикл
			СтрокаМетки = СтрокаМетки + Колонка.Имя + " " + ТаблицаМеток[0][Колонка.Имя] + " ";
		КонецЦикла;
		ОбщегоНазначения.СообщитьПользователю(СтрокаМетки);
	КонецЕсли;
	
	Если ОбрабатываемаяСтрока <> Неопределено Тогда
		Если ТипЗнч(ТЧСерии) <> Тип("ТаблицаЗначений") Тогда
			Результат.ИдентификаторТекущейСтроки = ОбрабатываемаяСтрока.ПолучитьИдентификатор();
		КонецЕсли;
		Результат.ДанныеСерии = ОбрабатываемаяСтрока;
	КонецЕсли;
	
	Возврат Результат;

КонецФункции

// Функция - Параметры обработки считанных RFID и КиЗ
// 
// Возвращаемое значение:
//	Структура - параметры обработки:
//	* СчитывательRFID - СправочникСсылка.ПодключаемоеОборудование - ссылка на считыватель RFID.
//	* УникальныйИдентификатор - УникальныйИдентификатор, Неопределено - уникальный идентификатор формы.
//	* НастройкиИспользованияСерий - см. Справочники.ВидыНоменклатуры.НастройкиИспользованияСерий.
//	* ПараметрыУказанияСерий - см. НоменклатураКлиентСервер.ПараметрыУказанияСерий.
//	* ЗначенияПолейСвязи - Структура - коллекция связи полей между ТЧ Товары и ТЧ Серии из ПараметрыУказанияСерий.ПоляСвязи:
//		** Ключ - Строка - имя реквизита без суффикса, например "Номенклатура".
//		** Значение - Строка - имя реквизита с суффиксом, например "НоменклатураОприходование".
//
Функция ПараметрыОбработкиСчитанныхRFID() Экспорт
	
	Результат = Новый Структура;
	Результат.Вставить("СчитывательRFID",             Справочники.ПодключаемоеОборудование.ПустаяСсылка());
	Результат.Вставить("УникальныйИдентификатор",     Неопределено);
	Результат.Вставить("НастройкиИспользованияСерий", Новый Структура);
	Результат.Вставить("ПараметрыУказанияСерий",      Новый Структура);
	Результат.Вставить("ЗначенияПолейСвязи",          Новый Структура);
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция ДобавитьИзменитьСтрокуВТЧ(Объект, СтруктураПараметров, ДобавляемыеДанные, РежимОбработки,
	КэшированныеЗначения, МассивСтрокСУпЛистамиДляОбработки = Неопределено, Назначения = Неопределено)
	
	ТабличнаяЧасть = Объект[СтруктураПараметров.ИмяТЧ];
	
	Тара							= РежимОбработки = "Тара";
	ЗаполнятьСерию					= Ложь;
	ОтборПоСерии					= Ложь;
	ИспользоватьУпаковочныеЛисты	= ПолучитьФункциональнуюОпцию("ИспользоватьУпаковочныеЛисты");
	ПараметрыУказанияСерий			= СтруктураПараметров.ПараметрыУказанияСерий;
	СкладыВТЧ						= СтруктураПараметров.ИспользуетсяГруппаСкладов <> Ложь
										И НоменклатураСервер.СкладыУказываютсяВТабличнойЧасти(ПараметрыУказанияСерий);
	ИспользоватьСерииНоменклатуры	= ПараметрыУказанияСерий <> Неопределено
										И ПараметрыУказанияСерий.ИспользоватьСерииНоменклатуры;
	СерияПоШтрихкоду				= ДобавляемыеДанные.Серия;
	ЭтоУпаковочныйЛист				= Не Тара
										И ЗначениеЗаполнено(ДобавляемыеДанные.УпаковочныйЛист);
	
	ДобавлятьТовар		= ПроверитьАссортимент(Объект, СтруктураПараметров, ДобавляемыеДанные, ЭтоУпаковочныйЛист);
	ИмяКолонкиУпаковка	= СтруктураПараметров.ИмяКолонкиУпаковка;
	ИменаРеквизитов		= "Номенклатура, Характеристика, ХарактеристикиИспользуются," + ИмяКолонкиУпаковка;
	ОтборПоУпаковкам	= Новый Структура(ИменаРеквизитов);
	
	Если Не Тара
		И ИспользоватьСерииНоменклатуры
		И ДобавляемыеДанные.СерииИспользуются Тогда
		
		ОтборПоСерии = СкладыВТЧ
						Или ПараметрыУказанияСерий.ЭтоЗаказ;
		
		Если Не ОтборПоСерии Тогда
			ОтборПоУпаковкам.Вставить("Серия");
			
			ЗаполнятьСерию = ЗаполнитьСериюВТЧТовары(ДобавляемыеДанные, СтруктураПараметров);
			
			Если Не ЗаполнятьСерию Тогда
				ДобавляемыеДанные.Серия = Справочники.СерииНоменклатуры.ПустаяСсылка();
			КонецЕсли;
		КонецЕсли;
		
	КонецЕсли;
	
	Если ИспользоватьУпаковочныеЛисты
		И СтруктураПараметров.УчитыватьУпаковочныеЛисты Тогда
		// Ищем только на текущем уровне.
		//	Если включен режим "По товарам", тогда ищем (и добавляем) только на верхнем уровне.
		ОтборПоУпаковкам.Вставить("УпаковочныйЛистРодитель", СтруктураПараметров.ТекущийУпаковочныйЛист);
	КонецЕсли;
	
	Если СтруктураПараметров.НеИскатьВОтмененныхСтроках И ТабличнаяЧасть.Количество() > 0
		И ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(ТабличнаяЧасть[0], "Отменено") Тогда
		ОтборПоУпаковкам.Вставить("Отменено", Ложь);
	КонецЕсли;

	Если ДобавляемыеДанные.Свойство("Номенклатура") И ЗначениеЗаполнено(ДобавляемыеДанные.Номенклатура) Тогда
		Если ДобавляемыеДанные.ИспользоватьУпаковки <> Неопределено Тогда
			ТекущаяНомеклатураИспользоватьУпаковки = ДобавляемыеДанные.ИспользоватьУпаковки;
		Иначе
			ТекущаяНомеклатураИспользоватьУпаковки = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДобавляемыеДанные.Номенклатура, "ИспользоватьУпаковки");
		КонецЕсли;
		
		Если Не ТекущаяНомеклатураИспользоватьУпаковки Тогда
			СтруктураПараметров.НеИспользоватьУпаковки = Истина;
		КонецЕсли;
	КонецЕсли;
	
	НайденныеСтроки = Новый Массив;
	
	Если ДобавляемыеДанные.НеизвестныйШтрихкод Тогда
		
		Если СтруктураПараметров.ШтрихкодыВТЧ Тогда
			
			Отбор = Новый Структура("Штрихкод, УпаковочныйЛистРодитель",
				ДобавляемыеДанные.Штрихкод, СтруктураПараметров.ТекущийУпаковочныйЛист);
			НайденныеСтроки = ТабличнаяЧасть.НайтиСтроки(Отбор);
			
		Иначе
			
			ДобавлятьТовар = Ложь;
			
		КонецЕсли;
		
		// Неизвестным может оказаться штрихкод, которому соответствует несколько упаковочных листов,
		//	при этом упаковочный лист уже может быть указан в ТЧ Товары, в этом случае нужно попробовать найти его.
		Если ИспользоватьУпаковочныеЛисты
			И СтруктураПараметров.УчитыватьУпаковочныеЛисты
			И НайденныеСтроки.Количество() = 0 Тогда
			
			Отбор			= Новый Структура("УпаковочныйЛистКод, УпаковочныйЛистРодитель",
												ДобавляемыеДанные.Штрихкод, СтруктураПараметров.ТекущийУпаковочныйЛист);
			НайденныеСтроки = ТабличнаяЧасть.НайтиСтроки(Отбор);
			
			Если НайденныеСтроки.Количество() = 0 Тогда
				ДобавлятьТовар = Ложь;
				
				НеизвестныйШтрихкод = Новый Структура("Штрихкод, Количество");
				НеизвестныйШтрихкод.Штрихкод	= ДобавляемыеДанные.Штрихкод;
				НеизвестныйШтрихкод.Количество	= ДобавляемыеДанные.КоличествоПоШтрихкоду;
				
				СтруктураПараметров.НеизвестныеШтрихкоды.Добавить(НеизвестныйШтрихкод);
			КонецЕсли;
			
		КонецЕсли;
		
	Иначе
		
		Если ЭтоУпаковочныйЛист Тогда
			Отбор = Новый Структура("УпаковочныйЛист", Истина);
			Отбор.Вставить("ЭтоУпаковочныйЛист", Истина);
		Иначе
			Если СтруктураПараметров.НеИспользоватьУпаковки
				Или Тара Тогда
				Отбор = ОбщегоНазначения.СкопироватьРекурсивно(ОтборПоУпаковкам, Ложь);
				Отбор.Удалить(ИмяКолонкиУпаковка);
			Иначе
				Отбор = ОтборПоУпаковкам;
			КонецЕсли;
			
			Если СтруктураПараметров.РассчитыватьНаборы Тогда
				Отбор.Вставить("НоменклатураНабора");
				Отбор.Вставить("ХарактеристикаНабора");
			КонецЕсли;
			
			Если СтруктураПараметров.ДобавлятьТолькоТоварСверхЗаказа Тогда
				Отбор.Вставить("КодСтроки", 0);
			КонецЕсли;
			
			Если Не Тара
				И ДобавляемыеДанные.ШтрихкодНеИзКэша 
				И ДобавляемыеДанные.НесколькоЕдиничныхУпаковок 
				И ДобавляемыеДанные.ЕдиничнаяУпаковка = Неопределено Тогда
				
				ТекстСообщения = НСтр("ru = 'У номенклатуры ""%Номенклатура%"" используется несколько упаковок с единицей измерения ""%ЕдиницаИзмерения%"" и коэффициентом 1. Для корректной привязки штрихкодов рекомендуется использовать одну единичную упаковку.'");
				ТекстСообщения = СтрЗаменить(ТекстСообщения, "%Номенклатура%", Строка(ДобавляемыеДанные.Номенклатура));
				ТекстСообщения = СтрЗаменить(ТекстСообщения, "%ЕдиницаИзмерения%", Строка(ДобавляемыеДанные.ЕдиницаИзмерения));
				ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);
			КонецЕсли;
			
		КонецЕсли;
		
		ЗаполнитьЗначенияСвойств(Отбор, ДобавляемыеДанные);
		НайденныеСтроки = ТабличнаяЧасть.НайтиСтроки(Отбор);
		КоличествоСтрок = НайденныеСтроки.Количество();
		
		Если ОтборПоСерии
			И КоличествоСтрок > 0 Тогда
			
			ПодобратьСериюВТЧТовары(ДобавляемыеДанные, СтруктураПараметров, НайденныеСтроки, ЗаполнятьСерию, СкладыВТЧ);
			
		ИначеЕсли КоличествоСтрок > 0 Тогда
			ДобавляемыеДанные.Серия = СерияПоШтрихкоду;
		КонецЕсли;
		
	КонецЕсли;
	
	СтрокаТЧ = Неопределено;
	
	Если Не СтруктураПараметров.ИзменятьКоличество Тогда
		Если НайденныеСтроки.Количество() = 0 Тогда
			
			Если ЭтоУпаковочныйЛист Тогда
				
				ТекстСообщения = НСтр("ru = 'В табличной части не найдена строка, содержащая ""%УпаковочныйЛист%""'");
				ТекстСообщения = СтрЗаменить(ТекстСообщения, "%УпаковочныйЛист%", ДобавляемыеДанные.УпаковочныйЛист);
				
			ИначеЕсли ДобавляемыеДанные.НеизвестныйШтрихкод Тогда
				
				Если СтруктураПараметров.ШтрихКодыВТЧ Тогда
					ТекстСообщения = НСтр("ru = 'В табличной части не найдена строка, содержащая штрихкод ""%Штрихкод%""'");
				ИначеЕсли ДобавляемыеДанные.НеуникальныйШтрихкод Тогда
					ТекстСообщения = НСтр("ru = 'Не удалось определить номенклатуру, так как штрихкоду ""%Штрихкод%"" соответствует несколько товаров'");
				ИначеЕсли ИспользоватьУпаковочныеЛисты
					И СтруктураПараметров.УчитыватьУпаковочныеЛисты Тогда
					
					ТекстСообщения = НСтр("ru = 'Номенклатура или упаковочный лист со штрихкодом ""%Штрихкод%"" не найдены'");
					
				Иначе
					ТекстСообщения = НСтр("ru = 'Номенклатура со штрихкодом ""%Штрихкод%"" не найдена'");
				КонецЕсли;
				
				ТекстСообщения = СтрЗаменить(ТекстСообщения, "%Штрихкод%", ДобавляемыеДанные.Штрихкод);
				
			Иначе
				ТекстСообщения = НСтр("ru = 'В табличной части не найдена строка с товаром ""%НазваниеТовара%""'");
				
				НазваниеТовара = НоменклатураКлиентСервер.ПредставлениеНоменклатуры(ДобавляемыеДанные.Номенклатура,
																					 ДобавляемыеДанные.Характеристика,
																					 ?(Тара, "",ДобавляемыеДанные.Упаковка));
				ТекстСообщения = СтрЗаменить(ТекстСообщения,"%НазваниеТовара%",НазваниеТовара);
			КонецЕсли;
			
			ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);
			
		Иначе
			СтрокаТЧ = НайденныеСтроки[ИндексНайденнойСтроки(НайденныеСтроки, ОтборПоСерии)];
		КонецЕсли;
		
		Возврат СтрокаТЧ;
		
	КонецЕсли;
	
	Если НайденныеСтроки.Количество() = 0
		И Не Тара
		И Не ЭтоУпаковочныйЛист
		И Не ДобавляемыеДанные.НеизвестныйШтрихкод Тогда 
		
		// Если для упаковки используется только одна упаковка с коэффициентом 1 и ед. изм. как в номенклатуре,
		// то попробуем найти строку с этой упаковкой:
		//	- если найдем, то увеличим в ней количество
		//	- если нет - добавим новую строку.
		//	- кроме элементов набора - в этом случае берем ту упаковку - которая указана
		Если ЗначениеЗаполнено(ДобавляемыеДанные.ЕдиничнаяУпаковка)
			И Не ЗначениеЗаполнено(ДобавляемыеДанные.Упаковка)
			И Не РежимОбработки = "КомплектующаяНабора" Тогда
			
			ЗаполнитьЗначенияСвойств(ОтборПоУпаковкам, ДобавляемыеДанные);
			
			Если СтруктураПараметров.НеИспользоватьУпаковки Тогда
				Отбор = ОбщегоНазначения.СкопироватьРекурсивно(ОтборПоУпаковкам, Ложь);
				Отбор.Удалить(ИмяКолонкиУпаковка);
			Иначе
				ОтборПоУпаковкам[ИмяКолонкиУпаковка] = ДобавляемыеДанные.ЕдиничнаяУпаковка;
				Отбор = ОтборПоУпаковкам;
			КонецЕсли;
			
			НайденныеСтроки = ТабличнаяЧасть.НайтиСтроки(Отбор);
			
		ИначеЕсли Не СтруктураПараметров.НеИспользоватьУпаковки
			И ЗначениеЗаполнено(ДобавляемыеДанные.ЕдиничнаяУпаковка)
			И ДобавляемыеДанные.ЕдиничнаяУпаковка = ДобавляемыеДанные.Упаковка Тогда
			
			ОтборПоУпаковкам[ИмяКолонкиУпаковка] = Справочники.УпаковкиЕдиницыИзмерения.ПустаяСсылка();
			НайденныеСтроки = ТабличнаяЧасть.НайтиСтроки(ОтборПоУпаковкам);
			
		ИначеЕсли РежимОбработки = "КомплектующаяНабора" Тогда
			
			Если СтруктураПараметров.НеИспользоватьУпаковки Тогда
				Отбор = ОбщегоНазначения.СкопироватьРекурсивно(ОтборПоУпаковкам, Ложь);
				Отбор.Удалить(ИмяКолонкиУпаковка);
			Иначе
				ОтборПоУпаковкам[ИмяКолонкиУпаковка] = ДобавляемыеДанные.Упаковка;
				Отбор = ОтборПоУпаковкам;
			КонецЕсли;
			
			НайденныеСтроки = ТабличнаяЧасть.НайтиСтроки(Отбор);
			
		КонецЕсли;
		
		Если ОтборПоСерии
			И НайденныеСтроки.Количество() > 0 Тогда
			
			ПодобратьСериюВТЧТовары(ДобавляемыеДанные, СтруктураПараметров, НайденныеСтроки, ЗаполнятьСерию, СкладыВТЧ);
			
		Иначе
			ДобавляемыеДанные.Серия = СерияПоШтрихкоду;
		КонецЕсли;
		
	КонецЕсли;
	
	Если ИспользоватьУпаковочныеЛисты
		И Не СтруктураПараметров.УчитыватьУпаковочныеЛисты
		И СтруктураПараметров.ТекущийУпаковочныйЛист <> Неопределено
		И НайденныеСтроки.Количество() > 0 Тогда
		
		// Удалим из найденных строки по другим упаковочным листам
		// Если в ТЧ уже есть строки с этим упаковочным листом - то в НайденныеСтроки[0] будет такая строка,
		// если таких строк нет, то или НайденныеСтроки очистится, или в НайденныеСтроки[0]
		// будет строка с пустым упаковочным листом.
		
		Индекс = НайденныеСтроки.Количество();
		СтрокаСНепустымУпаковочнымЛистом = Неопределено;
		
		Пока Индекс > 0 Цикл
			
			Индекс = Индекс - 1;
			
			СтрМас = НайденныеСтроки[Индекс];
			
			УпаковочныйЛистРодитель = СтрМас.УпаковочныйЛист;
			
			Если ЗначениеЗаполнено(УпаковочныйЛистРодитель) Тогда
				Если УпаковочныйЛистРодитель <> СтруктураПараметров.ТекущийУпаковочныйЛист Тогда
					НайденныеСтроки.Удалить(Индекс);
				Иначе
					СтрокаСНепустымУпаковочнымЛистом = Индекс;
				КонецЕсли;
			Иначе
				Если ЗначениеЗаполнено(СтрокаСНепустымУпаковочнымЛистом)
					Или (Не ЗначениеЗаполнено(СтрокаСНепустымУпаковочнымЛистом)
						И Индекс <> 0) Тогда
					НайденныеСтроки.Удалить(Индекс);
				КонецЕсли;
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЕсли;
	
	Если ИспользоватьУпаковочныеЛисты
		И СтруктураПараметров.ТекущийУпаковочныйЛист <> Неопределено
		И СтруктураПараметров.УчитыватьУпаковочныеЛисты Тогда
		
		ТекущийУпаковочныйЛистКод = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(
										СтруктураПараметров.ТекущийУпаковочныйЛист,
										"Код");
		
	КонецЕсли;
	
	ДанныеЕстьВТЧ = НайденныеСтроки.Количество() > 0;
	Если ДанныеЕстьВТЧ Тогда
		СтрокаТЧ = НайденныеСтроки[ИндексНайденнойСтроки(НайденныеСтроки, ОтборПоСерии)];
	КонецЕсли;
	
	Количество = ДобавляемыеДанные.КоличествоПоШтрихкоду * ДобавляемыеДанные.КоличествоУпаковок * ДобавляемыеДанные.Коэффициент;
	КоличествоУпаковок = ДобавляемыеДанные.КоличествоПоШтрихкоду * ДобавляемыеДанные.КоличествоУпаковок;
	
	Если Не (ДобавляемыеДанные.МаркируемаяПродукция И СтруктураПараметров.МаркируемаяПродукцияВТЧ)
		Или СтруктураПараметров.ЗагрузкаИзТСД Тогда
		Если Не СтруктураПараметров.НеИспользоватьУпаковки Тогда
			ДобавляемоеКоличество = КоличествоУпаковок;
		Иначе
			ДобавляемоеКоличество = Количество;
		КонецЕсли;
	Иначе
		ДобавляемоеКоличество = 0;
	КонецЕсли;
	
	ЗаполнятьНазначение = Назначения <> Неопределено
							И ЗаполнятьНазначение(СтруктураПараметров, ДобавляемыеДанные);
	Если Не Тара
		И ЗаполнятьНазначение Тогда
		
		ТекущееНазначение = ПодобратьНазначение(ДобавляемыеДанные,
			Назначения, СтруктураПараметров.ИмяКолонкиКоличество, НайденныеСтроки, Количество, ДанныеЕстьВТЧ);
		
	КонецЕсли;
	
	Если Не ДанныеЕстьВТЧ Тогда
		
		Если ДобавлятьТовар Тогда
			
			СтрокаТЧ = ТабличнаяЧасть.Добавить();
			ДобавляемыеДанные.ВыполненныеДействия.Добавлено	= Истина;
			ДобавляемыеДанные.ВыполненныеДействия.Изменено	= Ложь;
			
			Если СтруктураПараметров.ШтрихкодыВТЧ Тогда
				СтрокаТЧ.Штрихкод = ДобавляемыеДанные.Штрихкод;
			КонецЕсли;
			
			Если СтруктураПараметров.МаркируемаяПродукцияВТЧ 
				И ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(СтрокаТЧ, "МаркируемаяПродукция") Тогда
				СтрокаТЧ.МаркируемаяПродукция = ДобавляемыеДанные.МаркируемаяПродукция;
			КонецЕсли;
			
			Если ЭтоУпаковочныйЛист Тогда
				
				СтрокаТЧ.ЭтоУпаковочныйЛист = Истина;
				СтрокаТЧ.УпаковочныйЛист = ДобавляемыеДанные.УпаковочныйЛист;
				СтрокаТЧ[СтруктураПараметров.ИмяКолонкиКоличество] = 1;
				СтрокаТЧ.УпаковочныйЛистРодитель    = СтруктураПараметров.ТекущийУпаковочныйЛист;
				МассивСтрокСУпЛистамиДляОбработки.Добавить(СтрокаТЧ);
				
			ИначеЕсли ДобавляемыеДанные.НеизвестныйШтрихкод Тогда
				
				СтрокаТЧ[СтруктураПараметров.ИмяКолонкиКоличество] = ДобавляемыеДанные.КоличествоПоШтрихкоду;
				СтрокаТЧ.ШтрихкодНеОпределен = 1;
				
			Иначе
				
				Если СтруктураПараметров.ПараметрыУказанияСерий <> Неопределено Тогда 
					НоменклатураКлиентСервер.ОбновитьКешированныеЗначенияДляУчетаСерий(СтрокаТЧ,КэшированныеЗначения,
						СтруктураПараметров.ПараметрыУказанияСерий);
				КонецЕсли;
				
				Если СтруктураПараметров.РассчитыватьНаборы Тогда
					СтрокаТЧ.НоменклатураНабора = ДобавляемыеДанные.НоменклатураНабора;
					СтрокаТЧ.ХарактеристикаНабора = ДобавляемыеДанные.ХарактеристикаНабора;
				КонецЕсли;
				
				СтрокаТЧ.Номенклатура	= ДобавляемыеДанные.Номенклатура;
				СтрокаТЧ.Характеристика	= ДобавляемыеДанные.Характеристика;
				
				Если ЗаполнятьСерию Тогда
					СтрокаТЧ.Серия = ДобавляемыеДанные.Серия;
				ИначеЕсли ИспользоватьСерииНоменклатуры
					И ДобавляемыеДанные.СерииИспользуются Тогда
					
					Отгрузить = Истина;
					
					ЗаполнитьСтрокуТЧДляРасчетаСтатусаУказанияСерии(
						ТабличнаяЧасть,
						СтрокаТЧ,
						СтруктураПараметров,
						КэшированныеЗначения,
						Отгрузить);
					
					ЗаполнятьСерию = ЗаполнитьСериюВТЧТовары(ДобавляемыеДанные, СтруктураПараметров, Отгрузить);
					
					Если ЗаполнятьСерию Тогда
						СтрокаТЧ.Серия = ДобавляемыеДанные.Серия;
					КонецЕсли;
					
				КонецЕсли;
				
				Если Не Тара
					И Не СтруктураПараметров.НеИспользоватьУпаковки Тогда
					Если ЗначениеЗаполнено(ДобавляемыеДанные.ЕдиничнаяУпаковка)
						И Не РежимОбработки = "КомплектующаяНабора" Тогда
						СтрокаТЧ[ИмяКолонкиУпаковка] = ДобавляемыеДанные.ЕдиничнаяУпаковка;
					Иначе
						СтрокаТЧ[ИмяКолонкиУпаковка] = ДобавляемыеДанные.Упаковка;
					КонецЕсли;
				КонецЕсли;
				
				СтрокаТЧ.ХарактеристикиИспользуются = ДобавляемыеДанные.ХарактеристикиИспользуются;
				
				Если ИспользоватьУпаковочныеЛисты
					И СтруктураПараметров.ТекущийУпаковочныйЛист <> Неопределено Тогда
					Если СтруктураПараметров.УчитыватьУпаковочныеЛисты Тогда
						СтрокаТЧ.УпаковочныйЛистРодитель    = СтруктураПараметров.ТекущийУпаковочныйЛист;
						СтрокаТЧ.УпаковочныйЛистРодительКод = ТекущийУпаковочныйЛистКод;
					ИначеЕсли СтрокаТЧ.Свойство("НеОтгружать")
						И СтрокаТЧ.НеОтгружать = 0 Тогда
						СтрокаТЧ.УпаковочныйЛист = СтруктураПараметров.ТекущийУпаковочныйЛист;
					КонецЕсли;
				КонецЕсли;
				
				СтрокаТЧ[СтруктураПараметров.ИмяКолонкиКоличество] = ДобавляемоеКоличество;
				
			КонецЕсли;
			
		КонецЕсли;
		
	Иначе
		
		СтрокаТЧ = НайденныеСтроки[ИндексНайденнойСтроки(НайденныеСтроки, ОтборПоСерии)];
		
		Если СтруктураПараметров.ШтрихкодыВТЧ
			И Не ЗначениеЗаполнено(СтрокаТЧ.Штрихкод) Тогда
			СтрокаТЧ.Штрихкод = ДобавляемыеДанные.Штрихкод;
		КонецЕсли;
		
		Если ЭтоУпаковочныйЛист
			Или ДобавляемыеДанные.НеизвестныйШтрихкод
				И СтруктураПараметров.УчитыватьУпаковочныеЛисты
				И ЗначениеЗаполнено(СтрокаТЧ.УпаковочныйЛист) Тогда
			
			ТекстСообщения = НСтр("ru = '%УпаковочныйЛист% уже есть в табличной части.'");
			ТекстСообщения = СтрЗаменить(ТекстСообщения,"%УпаковочныйЛист%", СтрокаТЧ.УпаковочныйЛист);
			
			ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);
			
		Иначе
			Если СтруктураПараметров.ПараметрыУказанияСерий <> Неопределено Тогда 
				НоменклатураКлиентСервер.ОбновитьКешированныеЗначенияДляУчетаСерий(СтрокаТЧ,КэшированныеЗначения,
					СтруктураПараметров.ПараметрыУказанияСерий);
			КонецЕсли;
			
			Если ИспользоватьУпаковочныеЛисты
				И СтруктураПараметров.ТекущийУпаковочныйЛист <> Неопределено Тогда
				Если СтруктураПараметров.УчитыватьУпаковочныеЛисты Тогда
					СтрокаТЧ.УпаковочныйЛистРодитель    = СтруктураПараметров.ТекущийУпаковочныйЛист;
					СтрокаТЧ.УпаковочныйЛистРодительКод = ТекущийУпаковочныйЛистКод;
				ИначеЕсли  Не ЗначениеЗаполнено(СтрокаТЧ.УпаковочныйЛист)
					И СтрокаТЧ.Свойство("НеОтгружать")
					И СтрокаТЧ.НеОтгружать = 0 Тогда
					СтрокаТЧ.УпаковочныйЛист = СтруктураПараметров.ТекущийУпаковочныйЛист;
				КонецЕсли;
			КонецЕсли;
			
			СтрокаТЧ[СтруктураПараметров.ИмяКолонкиКоличество] = СтрокаТЧ[СтруктураПараметров.ИмяКолонкиКоличество]
				+ ДобавляемоеКоличество;
			
			ДобавляемыеДанные.ВыполненныеДействия.Добавлено	= Ложь;
			ДобавляемыеДанные.ВыполненныеДействия.Изменено	= Истина;
			
		КонецЕсли;
		
	КонецЕсли;
	
	Если ЗаполнятьНазначение Тогда
		СтрокаТЧ.Назначение = ТекущееНазначение;
	КонецЕсли;
	
	Если ЗаполнятьСерию Тогда
		СтруктураПараметров.МассивСтрокСПодобраннымиСериями.Добавить(СтрокаТЧ.ПолучитьИдентификатор());
	КонецЕсли;
	
	Если СтруктураПараметров.МаркируемаяПродукцияВТЧ
		И СтрокаТЧ <> Неопределено
		И ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(СтрокаТЧ, "МаркируемаяПродукция")
		И СтрокаТЧ.МаркируемаяПродукция Тогда
		СтруктураПараметров.МассивСтрокСАкцизнымиМарками.Добавить(СтрокаТЧ.ПолучитьИдентификатор());
	КонецЕсли;
	
	Возврат СтрокаТЧ;
	
КонецФункции

// Проверяет соответствуют ли номенклатура условиям.
//
// Параметры:
//	ДобавляемыеДанные - см. ПакетнаяОбработкаТабличнойЧастиКлиентСервер.ПолучитьСтруктуруКэшируемыеЗначения
//	СтруктураПараметров - см. ШтрихкодированиеНоменклатурыКлиентСервер.ПараметрыОбработкиШтрихкодов
//
// Возвращаемое значение:
//	Булево - номенклатура соответствует переданным условиям.
//
Функция СоответствуетУсловиям(ДобавляемыеДанные, СтруктураПараметров) Экспорт
	
	ЭтоУпаковочныйЛист = ЗначениеЗаполнено(ДобавляемыеДанные.УпаковочныйЛист);
	
	Если ЭтоУпаковочныйЛист
		И Не СтруктураПараметров.УчитыватьУпаковочныеЛисты Тогда
		
		ТекстСообщения = НСтр("ru = 'Штрихкод ""%Штрихкод%"" соответствует упаковочному листу. В этом документе не поддерживается работа со штрихкодами упаковочных листов.'");
		ТекстСообщения = СтрЗаменить(ТекстСообщения, "%Штрихкод%", ДобавляемыеДанные.Штрихкод);
		
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);
		
		Возврат Ложь;
		
	КонецЕсли;
	
	Если Не ЭтоУпаковочныйЛист
		И СтруктураПараметров.ТолькоТовары
		И ДобавляемыеДанные.ТипНоменклатуры <> Перечисления.ТипыНоменклатуры.МногооборотнаяТара
		И ДобавляемыеДанные.ТипНоменклатуры <> Перечисления.ТипыНоменклатуры.Товар Тогда
		
		НазваниеТовара = НоменклатураКлиентСервер.ПредставлениеНоменклатуры(ДобавляемыеДанные.Номенклатура,
																			ДобавляемыеДанные.Характеристика,
																			ДобавляемыеДанные.Упаковка);
		
		ТекстСообщения = НСтр("ru = 'Товар ""%НазваниеТовара%"" является услугой (работой). В данную табличную часть запрещено добавлять услуги (работы).'");
		ТекстСообщения = СтрЗаменить(ТекстСообщения, "%НазваниеТовара%", НазваниеТовара);
		
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);
		
		Возврат Ложь;
		
	КонецЕсли;
	
	Если Не ЭтоУпаковочныйЛист
		И СтруктураПараметров.ТолькоТоварыИРабота
		И ДобавляемыеДанные.ТипНоменклатуры <> Перечисления.ТипыНоменклатуры.МногооборотнаяТара
		И ДобавляемыеДанные.ТипНоменклатуры <> Перечисления.ТипыНоменклатуры.Товар
		И ДобавляемыеДанные.ТипНоменклатуры <> Перечисления.ТипыНоменклатуры.Работа Тогда
		
		НазваниеТовара = НоменклатураКлиентСервер.ПредставлениеНоменклатуры(ДобавляемыеДанные.Номенклатура,
																			ДобавляемыеДанные.Характеристика,
																			ДобавляемыеДанные.Упаковка);
		
		ТекстСообщения = НСтр("ru = 'Товар ""%НазваниеТовара%"" является услугой. В данную табличную часть запрещено добавлять услуги.'");
		ТекстСообщения = СтрЗаменить(ТекстСообщения, "%НазваниеТовара%", НазваниеТовара);
		
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);
		
		Возврат Ложь;
		
	КонецЕсли;
	
	Если Не ЭтоУпаковочныйЛист
		И СтруктураПараметров.ТолькоТоварыИУслуги
		И ДобавляемыеДанные.ТипНоменклатуры <> Перечисления.ТипыНоменклатуры.МногооборотнаяТара
		И ДобавляемыеДанные.ТипНоменклатуры <> Перечисления.ТипыНоменклатуры.Товар
		И ДобавляемыеДанные.ТипНоменклатуры <> Перечисления.ТипыНоменклатуры.Услуга Тогда
		
		НазваниеТовара = НоменклатураКлиентСервер.ПредставлениеНоменклатуры(ДобавляемыеДанные.Номенклатура,
																			ДобавляемыеДанные.Характеристика,
																			ДобавляемыеДанные.Упаковка);
		
		ТекстСообщения = НСтр("ru = 'Товар ""%НазваниеТовара%"" является работой. В данную табличную часть запрещено добавлять работы.'");
		ТекстСообщения = СтрЗаменить(ТекстСообщения, "%НазваниеТовара%", НазваниеТовара);
		
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);
		
		Возврат Ложь;
		
	КонецЕсли;
	
	Если СтруктураПараметров.ТолькоУслуги
		И ДобавляемыеДанные.ТипНоменклатуры <> Перечисления.ТипыНоменклатуры.Работа
		И ДобавляемыеДанные.ТипНоменклатуры <> Перечисления.ТипыНоменклатуры.Услуга Тогда
		
		НазваниеУслуги = НоменклатураКлиентСервер.ПредставлениеНоменклатуры(ДобавляемыеДанные.Номенклатура,
																			ДобавляемыеДанные.Характеристика,
																			ДобавляемыеДанные.Упаковка);
		
		ТекстСообщения = НСтр("ru = 'Номенклатура ""%НазваниеУслуги%"" является товаром (тарой). В данную табличную часть запрещено добавлять товары (тару).'");
		ТекстСообщения = СтрЗаменить(ТекстСообщения,  "%НазваниеУслуги%", НазваниеУслуги);
		
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);
		
		Возврат Ложь;
		
	КонецЕсли;
	
	Если СтруктураПараметров.ТолькоРаботы
		И ДобавляемыеДанные.ТипНоменклатуры <> Перечисления.ТипыНоменклатуры.Работа Тогда
		
		НазваниеТовара = НоменклатураКлиентСервер.ПредставлениеНоменклатуры(ДобавляемыеДанные.Номенклатура,
																			ДобавляемыеДанные.Характеристика,
																			ДобавляемыеДанные.Упаковка);
		
		ТекстСообщения = НСтр("ru = 'Номенклатура ""%НазваниеТовара%"" не является работой. В данную табличную часть разрешено добавлять только работы.'");
		ТекстСообщения = СтрЗаменить(ТекстСообщения, "%НазваниеТовара%", НазваниеТовара);
		
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);
		
		Возврат Ложь;
		
	КонецЕсли;
	
	Если СтруктураПараметров.ТолькоТара
		И ДобавляемыеДанные.ТипНоменклатуры <> Перечисления.ТипыНоменклатуры.МногооборотнаяТара Тогда
		
		НазваниеТары = НоменклатураКлиентСервер.ПредставлениеНоменклатуры(ДобавляемыеДанные.Номенклатура,
																			ДобавляемыеДанные.Характеристика,
																			ДобавляемыеДанные.Упаковка);
		
		ТекстСообщения = НСтр("ru = 'Номенклатура ""%НазваниеТары%"" не является тарой. В данную табличную часть можно добавлять только тару.'");
		ТекстСообщения = СтрЗаменить(ТекстСообщения, "%НазваниеТары%", НазваниеТары);
		
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);
		
		Возврат Ложь;
		
	КонецЕсли;
	
	Если СтруктураПараметров.ТолькоТовары
		И ДобавляемыеДанные.ТипНоменклатуры = Перечисления.ТипыНоменклатуры.МногооборотнаяТара
		И Не СтруктураПараметров.ИспользоватьТаруВКачествеТовара Тогда
		
		ТекстСообщения = НСтр("ru = 'Номенклатура ""%НазваниеТары%"" является тарой. В данную табличную часть можно добавлять только товары.'");
		
		НазваниеТары = НоменклатураКлиентСервер.ПредставлениеНоменклатуры(ДобавляемыеДанные.Номенклатура,
			ДобавляемыеДанные.Характеристика,
			ДобавляемыеДанные.Упаковка);
		
		ТекстСообщения = СтрЗаменить(ТекстСообщения,"%НазваниеТары%", НазваниеТары);
		
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
		
		Возврат Ложь;
		
	КонецЕсли;
	
	СоответствуетУсловиям = Истина;
	
	НоменклатураЛокализация.ПроверитьСоответствиеУказанияНоменклатурыУсловиям(
		ДобавляемыеДанные,
		СтруктураПараметров,
		СоответствуетУсловиям);
	
	Если Не СоответствуетУсловиям Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Возврат Истина;
	
КонецФункции

// Проверяет соответствуют ли комплектующие набора заданным параметрам.
//
// Параметры:
//	ДобавляемыеДанные - см. ПакетнаяОбработкаТабличнойЧастиКлиентСервер.ПолучитьСтруктуруКэшируемыеЗначения
//	СтруктураПараметров - см. ШтрихкодированиеНоменклатурыКлиентСервер.ПараметрыОбработкиШтрихкодов 
//	Комплектующие - Массив Из см. ПакетнаяОбработкаТабличнойЧастиКлиентСервер.СтруктураКэшируемойИнформацииПоШтрихкоду - комплектующие набора.
//
// Возвращаемое значение:
//	Булево - набор соответствует переданным условиям.
//
Функция НаборСоответствуетУсловиям(ДобавляемыеДанные, СтруктураПараметров, Комплектующие) Экспорт
	
	Для Каждого СтрокаКомплектующие Из Комплектующие Цикл
		
		Если СтруктураПараметров.ТолькоРаботы
			И СтрокаКомплектующие.ТипНоменклатуры <> Перечисления.ТипыНоменклатуры.Работа
			Тогда
			
			ТекстСообщения = НСтр("ru = 'Товар ""%НазваниеТовара%"" является набором и среди комплектующих имеет не только работы. В данную табличную часть можно добавлять только работы.'");
		
			НазваниеТовара = НоменклатураКлиентСервер.ПредставлениеНоменклатуры(ДобавляемыеДанные.Номенклатура,
																					 ДобавляемыеДанные.Характеристика,
																					 ДобавляемыеДанные.Упаковка);
		
			ТекстСообщения = СтрЗаменить(ТекстСообщения, "%НазваниеТовара%", НазваниеТовара);
		
			ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);
			
			Возврат Ложь;
			
		КонецЕсли;
			
		Если СтруктураПараметров.ТолькоУслуги
			И СтрокаКомплектующие.ТипНоменклатуры <> Перечисления.ТипыНоменклатуры.Услуга
			И СтрокаКомплектующие.ТипНоменклатуры <> Перечисления.ТипыНоменклатуры.Работа
			Тогда
			
			ТекстСообщения = НСтр("ru = 'Товар ""%НазваниеТовара%"" является набором и среди комплектующих имеет не только услуги и работы. В данную табличную часть можно добавлять только услуги и работы.'");
		
			НазваниеТовара = НоменклатураКлиентСервер.ПредставлениеНоменклатуры(ДобавляемыеДанные.Номенклатура,
																					 ДобавляемыеДанные.Характеристика,
																					 ДобавляемыеДанные.Упаковка);
		
			ТекстСообщения = СтрЗаменить(ТекстСообщения, "%НазваниеТовара%", НазваниеТовара);
		
			ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);
			
			Возврат Ложь;
			
		КонецЕсли;
		
		Если СтруктураПараметров.ТолькоТара
			И СтрокаКомплектующие.ТипНоменклатуры <> Перечисления.ТипыНоменклатуры.МногооборотнаяТара
			Тогда
			
			ТекстСообщения = НСтр("ru = 'Товар ""%НазваниеТовара%"" является набором и среди комплектующих имеет не только тару. В данную табличную часть можно добавлять только тару.'");
		
			НазваниеТовара = НоменклатураКлиентСервер.ПредставлениеНоменклатуры(ДобавляемыеДанные.Номенклатура,
																					 ДобавляемыеДанные.Характеристика,
																					 ДобавляемыеДанные.Упаковка);
		
			ТекстСообщения = СтрЗаменить(ТекстСообщения, "%НазваниеТовара%", НазваниеТовара);
		
			ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);
			
			Возврат Ложь;
			
		КонецЕсли;
		
		Если СтруктураПараметров.ТолькоТовары Тогда
			
			Отказ = Ложь;
			
			Если СтруктураПараметров.ИспользоватьТаруВКачествеТовара
				И СтрокаКомплектующие.ТипНоменклатуры <> Перечисления.ТипыНоменклатуры.Товар
				И СтрокаКомплектующие.ТипНоменклатуры <> Перечисления.ТипыНоменклатуры.МногооборотнаяТара Тогда
				
				Отказ = Истина;
				ТекстСообщения =
					НСтр("ru = 'Товар ""%НазваниеТовара%"" является набором и среди комплектующих имеет не только товары и тару. В данную табличную часть можно добавлять только товары и тару.'");
				
			ИначеЕсли Не СтруктураПараметров.ИспользоватьТаруВКачествеТовара
				И СтрокаКомплектующие.ТипНоменклатуры <> Перечисления.ТипыНоменклатуры.Товар Тогда
				
				Отказ = Истина;
				ТекстСообщения =
					НСтр("ru = 'Товар ""%НазваниеТовара%"" является набором и среди комплектующих имеет не только товары. В данную табличную часть можно добавлять только товары.'");
				
			КонецЕсли;
			
			Если Отказ Тогда
				
				НазваниеТовара = НоменклатураКлиентСервер.ПредставлениеНоменклатуры(ДобавляемыеДанные.Номенклатура,
					ДобавляемыеДанные.Характеристика,
					ДобавляемыеДанные.Упаковка);
				
				ТекстСообщения = СтрЗаменить(ТекстСообщения, "%НазваниеТовара%", НазваниеТовара);
				
				ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);
				
				Возврат Ложь;
				
			КонецЕсли;
			
		КонецЕсли;
		
		Если СтруктураПараметров.ТолькоТоварыИРабота
			И СтрокаКомплектующие.ТипНоменклатуры <> Перечисления.ТипыНоменклатуры.Товар
			И СтрокаКомплектующие.ТипНоменклатуры <> Перечисления.ТипыНоменклатуры.МногооборотнаяТара
			И СтрокаКомплектующие.ТипНоменклатуры <> Перечисления.ТипыНоменклатуры.Работа
			Тогда
			
			ТекстСообщения = НСтр("ru = 'Товар ""%НазваниеТовара%"" является набором и среди комплектующих имеет не только товары, тару и работы. В данную табличную часть можно добавлять только товары, тару и работы.'");
		
			НазваниеТовара = НоменклатураКлиентСервер.ПредставлениеНоменклатуры(ДобавляемыеДанные.Номенклатура,
																					 ДобавляемыеДанные.Характеристика,
																					 ДобавляемыеДанные.Упаковка);
		
			ТекстСообщения = СтрЗаменить(ТекстСообщения, "%НазваниеТовара%", НазваниеТовара);
		
			ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);
			
			Возврат Ложь;
			
		КонецЕсли;

		Если СтруктураПараметров.ТолькоТоварыИУслуги
			И СтрокаКомплектующие.ТипНоменклатуры <> Перечисления.ТипыНоменклатуры.Товар
			И СтрокаКомплектующие.ТипНоменклатуры <> Перечисления.ТипыНоменклатуры.МногооборотнаяТара
			И СтрокаКомплектующие.ТипНоменклатуры <> Перечисления.ТипыНоменклатуры.Услуга
			Тогда
			
			ТекстСообщения = НСтр("ru = 'Товар ""%НазваниеТовара%"" является набором и среди комплектующих имеет не только товары, тару и услуги. В данную табличную часть можно добавлять только товары, тару или услуги.'");
		
			НазваниеТовара = НоменклатураКлиентСервер.ПредставлениеНоменклатуры(ДобавляемыеДанные.Номенклатура,
																					 ДобавляемыеДанные.Характеристика,
																					 ДобавляемыеДанные.Упаковка);
		
			ТекстСообщения = СтрЗаменить(ТекстСообщения, "%НазваниеТовара%", НазваниеТовара);
		
			ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);
			
			Возврат Ложь;
			
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Истина;
	
КонецФункции

Функция ПроверитьАссортимент(Объект, СтруктураПараметров, ДобавляемыеДанные, ЭтоУпаковочныйЛист = Ложь)
	
	ДобавлятьТовар = Истина;
	
	Если СтруктураПараметров.ПараметрыПроверкиАссортимента = Неопределено
		Или Не СтруктураПараметров.ПараметрыПроверкиАссортимента.ПроверятьАссортимент
		Или ЭтоУпаковочныйЛист 
		Или ДобавляемыеДанные.НеизвестныйШтрихкод
		Или ЗначениеЗаполнено(ДобавляемыеДанные.НоменклатураНабора) Тогда
		
		Возврат ДобавлятьТовар;
		
	КонецЕсли;
	
	СтруктураСостоянияАссортимента = АссортиментСервер.СтруктураСостоянияАссортиментаТовараВФормате(ДобавляемыеДанные.Номенклатура,
																									СтруктураПараметров.ПараметрыПроверкиАссортимента.Склад,
																									Объект.Дата);
	
	Если Не СтруктураСостоянияАссортимента[СтруктураПараметров.ПараметрыПроверкиАссортимента.ИмяРесурсаАссортимента] Тогда
		ПредставлениеТовара =  НоменклатураКлиентСервер.ПредставлениеНоменклатуры(ДобавляемыеДанные.Номенклатура,
																				 ДобавляемыеДанные.Характеристика);
																				 
		ТекстСообщенияАссортимента = СтрЗаменить(СтруктураПараметров.ПараметрыПроверкиАссортимента.ТекстСообщения,
			"%1",
			ПредставлениеТовара);
		
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщенияАссортимента);
		
		ДобавлятьТовар = СтруктураПараметров.ПараметрыПроверкиАссортимента.РазрешатьДобавление;
		
	КонецЕсли;

	Возврат ДобавлятьТовар;
	
КонецФункции

// Возвращает массив вариантов комплектации по заданной номенклатуре и характеристике.
//
// Параметры:
//	Номенклатура - СправочникСсылка.Номенклатура - номенклатура, по которой необходимо подобрать вариант комплектации.
//	Характеристика - СправочникСсылка.ХарактеристикиНоменклатуры - характеристика номенклатуры.
//
// Возвращаемое значение:
//	Массив Из см. ПакетнаяОбработкаТабличнойЧастиКлиентСервер.СтруктураКэшируемойИнформацииПоШтрихкоду.
//
Функция Комплектующие(Номенклатура, Характеристика) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	МИНИМУМ(ТаблицаТовары.НомерСтроки)		КАК НомерСтроки,
	|	СправочникНоменклатура.Ссылка			КАК Номенклатура,
	|	СправочникНоменклатура.НаборУпаковок	КАК НаборУпаковок,
	|	СправочникНоменклатура.ЕдиницаИзмерения	КАК ЕдиницаИзмерения,
	|	ТаблицаТовары.Характеристика			КАК Характеристика,
	|	ЗНАЧЕНИЕ(Справочник.СерииНоменклатуры.ПустаяСсылка) КАК Серия,
	|	ТаблицаТовары.Упаковка					КАК Упаковка,
	|	СУММА(ТаблицаТовары.КоличествоУпаковок)	КАК КоличествоУпаковок
	|ПОМЕСТИТЬ КомплектующиеНабора
	|ИЗ
	|	Справочник.ВариантыКомплектацииНоменклатуры.Товары КАК ТаблицаТовары
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ВариантыКомплектацииНоменклатуры КАК ВариантыКомплектации
	|		ПО ТаблицаТовары.Ссылка = ВариантыКомплектации.Ссылка
	|			И ВариантыКомплектации.Владелец = &Владелец
	|			И ВариантыКомплектации.Характеристика = &Характеристика
	|			И ВариантыКомплектации.Основной
	|		
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК СправочникНоменклатура
	|		ПО ТаблицаТовары.Номенклатура = СправочникНоменклатура.Ссылка
	|
	|СГРУППИРОВАТЬ ПО
	|	СправочникНоменклатура.Ссылка,
	|	ТаблицаТовары.Характеристика,
	|	ТаблицаТовары.Упаковка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	КомплектующиеНабора.Номенклатура	КАК Номенклатура,
	|	УпаковкиНоменклатуры.Ссылка			КАК Упаковка
	|ПОМЕСТИТЬ УпаковкиНоменклатуры
	|ИЗ
	|	КомплектующиеНабора КАК КомплектующиеНабора
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.УпаковкиЕдиницыИзмерения КАК УпаковкиНоменклатуры
	|		ПО КомплектующиеНабора.Номенклатура = УпаковкиНоменклатуры.Владелец
	|			И КомплектующиеНабора.ЕдиницаИзмерения = УпаковкиНоменклатуры.ЕдиницаИзмерения
	|			И УпаковкиНоменклатуры.ТипИзмеряемойВеличины = ЗНАЧЕНИЕ(Перечисление.ТипыИзмеряемыхВеличин.Упаковка)
	|			И ЕСТЬNULL(УпаковкиНоменклатуры.Знаменатель, 0) <> 0
	|
	|ГДЕ
	|	НЕ УпаковкиНоменклатуры.ПометкаУдаления
	|	И КомплектующиеНабора.НаборУпаковок = ЗНАЧЕНИЕ(Справочник.НаборыУпаковок.ИндивидуальныйДляНоменклатуры)
	|	И ВЫРАЗИТЬ(УпаковкиНоменклатуры.Числитель / УпаковкиНоменклатуры.Знаменатель КАК ЧИСЛО(27, 11)) = 1
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	КомплектующиеНабора.Номенклатура	КАК Номенклатура,
	|	УпаковкиНоменклатуры.Ссылка			КАК Упаковка
	|ИЗ
	|	КомплектующиеНабора КАК КомплектующиеНабора
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.УпаковкиЕдиницыИзмерения КАК УпаковкиНоменклатуры
	|		ПО КомплектующиеНабора.НаборУпаковок = УпаковкиНоменклатуры.Владелец
	|			И КомплектующиеНабора.ЕдиницаИзмерения = УпаковкиНоменклатуры.ЕдиницаИзмерения
	|			И УпаковкиНоменклатуры.ТипИзмеряемойВеличины = ЗНАЧЕНИЕ(Перечисление.ТипыИзмеряемыхВеличин.Упаковка)
	|			И ЕСТЬNULL(УпаковкиНоменклатуры.Знаменатель, 0) <> 0
	|
	|ГДЕ
	|	НЕ УпаковкиНоменклатуры.ПометкаУдаления
	|	И КомплектующиеНабора.НаборУпаковок <> ЗНАЧЕНИЕ(Справочник.НаборыУпаковок.ИндивидуальныйДляНоменклатуры)
	|	И ВЫРАЗИТЬ(УпаковкиНоменклатуры.Числитель / УпаковкиНоменклатуры.Знаменатель КАК ЧИСЛО(27, 11)) = 1
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СправочникНоменклатура.Ссылка						КАК Номенклатура,
	|	СправочникНоменклатура.ТипНоменклатуры				КАК ТипНоменклатуры,
	|	ВЫБОР
	|		КОГДА ЕСТЬNULL(СправочникНоменклатура.ВладелецСерий, НЕОПРЕДЕЛЕНО) = ЗНАЧЕНИЕ(Справочник.ВидыНоменклатуры.ПустаяСсылка)
	|			ТОГДА ЕСТЬNULL(СправочникНоменклатура.ВидНоменклатуры.ИспользоватьКоличествоСерии, ЛОЖЬ)
	|		ИНАЧЕ СправочникНоменклатура.ВладелецСерий.ИспользоватьКоличествоСерии
	|	КОНЕЦ												КАК ИспользоватьКоличествоСерии,
	|	КомплектующиеНабора.Характеристика					КАК Характеристика,
	|	КомплектующиеНабора.Серия							КАК Серия,
	|	ЕСТЬNULL(СправочникНоменклатура.ВидНоменклатуры.ИспользоватьСерии, ЛОЖЬ) КАК СерииИспользуются,
	|	КомплектующиеНабора.Упаковка						КАК Упаковка,
	|	ЕСТЬNULL(СправочникУпаковок.ТипУпаковки, НЕОПРЕДЕЛЕНО) = ЗНАЧЕНИЕ(Перечисление.ТипыУпаковокНоменклатуры.ТоварноеМесто) КАК ТоварноеМесто,
	|	ЕСТЬNULL(&ТекстЗапросаКоэффициентУпаковки1, 1)		КАК Коэффициент,
	|	ВЫБОР
	|		КОГДА ЕСТЬNULL(СправочникНоменклатура.ИспользованиеХарактеристик, НЕОПРЕДЕЛЕНО) = ЗНАЧЕНИЕ(Перечисление.ВариантыИспользованияХарактеристикНоменклатуры.НеИспользовать)
	|			ТОГДА ЛОЖЬ
	|		ИНАЧЕ ИСТИНА
	|	КОНЕЦ												КАК ХарактеристикиИспользуются,
	|	СправочникНоменклатура.ИспользоватьУпаковки			КАК ИспользоватьУпаковки,
	|	МАКСИМУМ(УпаковкиНоменклатуры.Упаковка)				КАК ЕдиничнаяУпаковка,
	|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ УпаковкиНоменклатуры.Упаковка)	КАК КоличествоЕдиничныхУпаковок,
	|	КомплектующиеНабора.ЕдиницаИзмерения				КАК ЕдиницаИзмерения,
	|	КомплектующиеНабора.КоличествоУпаковок				КАК КоличествоУпаковок
	|ИЗ
	|	КомплектующиеНабора КАК КомплектующиеНабора
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК СправочникНоменклатура
	|		ПО КомплектующиеНабора.Номенклатура = СправочникНоменклатура.Ссылка
	|		
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.УпаковкиЕдиницыИзмерения КАК СправочникУпаковок
	|		ПО КомплектующиеНабора.Упаковка = СправочникУпаковок.Ссылка
	|		
	|		ЛЕВОЕ СОЕДИНЕНИЕ УпаковкиНоменклатуры КАК УпаковкиНоменклатуры
	|		ПО КомплектующиеНабора.Номенклатура = УпаковкиНоменклатуры.Номенклатура
	|
	|СГРУППИРОВАТЬ ПО
	|	КомплектующиеНабора.НомерСтроки,
	|	СправочникНоменклатура.Ссылка,
	|	ВЫБОР
	|		КОГДА ЕСТЬNULL(СправочникНоменклатура.ВладелецСерий, НЕОПРЕДЕЛЕНО) = ЗНАЧЕНИЕ(Справочник.ВидыНоменклатуры.ПустаяСсылка)
	|			ТОГДА ЕСТЬNULL(СправочникНоменклатура.ВидНоменклатуры.ИспользоватьКоличествоСерии, ЛОЖЬ)
	|		ИНАЧЕ СправочникНоменклатура.ВладелецСерий.ИспользоватьКоличествоСерии
	|	КОНЕЦ,
	|	КомплектующиеНабора.Характеристика,
	|	КомплектующиеНабора.Серия,
	|	ЕСТЬNULL(СправочникНоменклатура.ВидНоменклатуры.ИспользоватьСерии, ЛОЖЬ),
	|	КомплектующиеНабора.Упаковка,
	|	СправочникУпаковок.Ссылка,
	|	КомплектующиеНабора.ЕдиницаИзмерения,
	|	КомплектующиеНабора.КоличествоУпаковок
	|
	|УПОРЯДОЧИТЬ ПО
	|	КомплектующиеНабора.НомерСтроки";
	
	Запрос.Текст = СтрЗаменить(Запрос.Текст,
								"&ТекстЗапросаКоэффициентУпаковки1",
								Справочники.УпаковкиЕдиницыИзмерения.ТекстЗапросаКоэффициентаУпаковки(
									"КомплектующиеНабора.Упаковка",
									"СправочникНоменклатура"));
	
	Запрос.УстановитьПараметр("Владелец",		Номенклатура);
	Запрос.УстановитьПараметр("Характеристика",	Характеристика);
	
	УстановитьПривилегированныйРежим(Истина);
	Выборка = Запрос.Выполнить().Выбрать();
	УстановитьПривилегированныйРежим(Ложь);
	
	Данные = Новый Массив;
	
	Пока Выборка.Следующий() Цикл
		ТекДанные = ПакетнаяОбработкаТабличнойЧастиКлиентСервер.СтруктураКэшируемойИнформацииПоШтрихкоду();
		ЗаполнитьЗначенияСвойств(ТекДанные, Выборка);
		
		ТекДанные.НоменклатураНабора			= Номенклатура;
		ТекДанные.ХарактеристикаНабора			= Характеристика;
		ТекДанные.НеизвестныйШтрихкод			= Ложь;
		ТекДанные.ЕдиничнаяУпаковка				= ?(Выборка.КоличествоЕдиничныхУпаковок = 1
														И Выборка.Коэффициент = 1,
													Выборка.ЕдиничнаяУпаковка,
													Неопределено);
		ТекДанные.НесколькоЕдиничныхУпаковок	= Выборка.КоличествоЕдиничныхУпаковок > 1
													И Не Выборка.ТоварноеМесто;
		ТекДанные.ИспользоватьУпаковки			= Выборка.ИспользоватьУпаковки;
		
		Данные.Добавить(ТекДанные);
	КонецЦикла;
	
	Возврат Данные;

КонецФункции

// Возвращает таблицу, содержащую сведения о назначениях для товаров табличной части передаваемого объекта.
//
// Параметры:
//	Объект - ДанныеФормыСтруктура - объект формы, в табличную часть которого подбираются назначения, который содержит следующие свойства:
//				* Ссылка - ДокументСсылка, СправочникСсылка - ссылка на объект информационной базы.
//	СтруктураПараметров - см. ШтрихкодированиеНоменклатурыКлиентСервер.ПараметрыОбработкиШтрихкодов.
//	ЗакэшированныеШтрихкоды - см. ПакетнаяОбработкаТабличнойЧастиКлиентСервер.ПолучитьСтруктуруКэшируемыеЗначения.
//
// Возвращаемое значение:
//	ТаблицаЗначений - таблица, содержащая сведения об остатках назначений товаров на складе, которая имеет следующие колонки:
//		* Номенклатура - СправочникСсылка.Номенклатура - товар, для которого получаются сведения об остатках назначений.
//		* Характеристика - СправочникСсылка.ХарактеристикиНоменклатуры - характеристика товара, для которого получаются
//																			сведения об остатках назначений.
//		* Назначение - СправочникСсылка.Назначения - назначение товара.
//		* Потребность - Число - потребность товара под назначение на складе.
//		* Остаток - Число - остаток товара под назначение на складе.
//
Функция Назначения(Объект, СтруктураПараметров, ЗакэшированныеШтрихкоды) Экспорт
	
	Если Не СтруктураПараметров.ЗаполнятьНазначения
		Или Не СтруктураПараметров.ИзменятьКоличество Тогда
		Возврат Новый ТаблицаЗначений;
	КонецЕсли;
	
	Если ТипЗнч(СтруктураПараметров.Штрихкоды) = Тип("Массив") Тогда
		МассивШтрихкодов = СтруктураПараметров.Штрихкоды;
	Иначе
		МассивШтрихкодов = Новый Массив;
		МассивШтрихкодов.Добавить(СтруктураПараметров.Штрихкоды);
	КонецЕсли;
	
	Запрос = Новый Запрос();
	ПараметрыТекстаЗапроса = Справочники.Назначения.ПараметрыФормированияЗапросаДоступныхНазначений();
	ПараметрыТекстаЗапроса.УчестьУжеПодобранные              = Истина;
	ПараметрыТекстаЗапроса.ПоНесколькимТоварам               = Истина;
	ПараметрыТекстаЗапроса.УпорядочитьПоДатеЗаказаНазначения = Истина;
	Запрос.Текст = ОбщегоНазначения.МенеджерОбъектаПоСсылке(Объект.Ссылка).ТекстЗапросаДоступныхНазначений(ПараметрыТекстаЗапроса);
	
	ТаблицаТоваров = Новый ТаблицаЗначений;
	ТаблицаТоваров.Колонки.Добавить("Номенклатура", Новый ОписаниеТипов("СправочникСсылка.Номенклатура"));
	ТаблицаТоваров.Колонки.Добавить("Характеристика", Новый ОписаниеТипов("СправочникСсылка.ХарактеристикиНоменклатуры"));
	
	Для Каждого ТекШтрихкод Из МассивШтрихкодов Цикл
		ЗначениеИзКеша = ЗакэшированныеШтрихкоды[ТекШтрихкод.Штрихкод];
		
		Если ЗначениеИзКеша <> Неопределено
			И ЗначениеЗаполнено(ЗначениеИзКеша.Номенклатура) Тогда
			
			НоваяСтрока = ТаблицаТоваров.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, ЗначениеИзКеша);
			
		КонецЕсли;
	КонецЦикла;
	
	Запрос.УстановитьПараметр("ТаблицаТоваров", ТаблицаТоваров);
	Запрос.УстановитьПараметр("ТоварыДокумента",
		Объект[СтруктураПараметров.ИмяТЧ].Выгрузить(, "Номенклатура,Характеристика,Назначение,Количество"));
	Запрос.УстановитьПараметр("Распоряжение", Объект.Распоряжение);
	Запрос.УстановитьПараметр("Склад", Объект.Склад);
	Запрос.УстановитьПараметр("Регистратор", Объект.Ссылка);
	
	УстановитьПривилегированныйРежим(Истина);
	Назначения = Запрос.Выполнить().Выгрузить();
	УстановитьПривилегированныйРежим(Ложь);
	
	Назначения.Индексы.Добавить("Номенклатура, Характеристика");
	
	Возврат Назначения;
	
КонецФункции

Функция ЗаполнятьНазначение(СтруктураПараметров, ДобавляемыеДанные)
	
	Возврат СтруктураПараметров.ЗаполнятьНазначения
		И Не ДобавляемыеДанные.НеизвестныйШтрихкод
		И Не ЗначениеЗаполнено(ДобавляемыеДанные.УпаковочныйЛист)
		И СтруктураПараметров.ИзменятьКоличество;
	
КонецФункции

// Возвращает значение подобранного назначения, по заданным параметрам.
//
// Параметры:
//	ДобавляемыеДанные - Структура - коллекция, которая содержит сведения о товаре и имеет следующие свойства:
//							* Номенклатура - СправочникСсылка.Номенклатура - номенклатура.
//							* Характеристика - СправочникСсылка.ХарактеристикиНоменклатуры - характеристика товара.
//	Назначения - см. Назначения.
//	ИмяКолонкиКоличество - Строка - имя колонки в строке коллекции СтрокиТЧ.
//	МассивСтрокТЧ - Массив Из СтрокаТабличнойЧасти - коллекция строк табличной части объекта.
//	ДобавляемоеКоличество - Число - добавляемое количество в коллекцию СтрокиТЧ.
//	ДанныеЕстьВТЧ - Булево - Истина, если коллекция СтрокиТЧ содержит данные.
//
// Возвращаемое значение:
//	СправочникСсылка.Назначения - подобранное назначение.
//
Функция ПодобратьНазначение(ДобавляемыеДанные,
			Назначения, ИмяКолонкиКоличество, МассивСтрокТЧ, ДобавляемоеКоличество, ДанныеЕстьВТЧ) Экспорт
	
	ОтборНазначений = Новый Структура("Номенклатура, Характеристика",
		ДобавляемыеДанные.Номенклатура, ДобавляемыеДанные.Характеристика);
	НазначенияПоТовару = Назначения.Скопировать(ОтборНазначений);
	НазначенияПоТовару.Индексы.Добавить("Назначение");
	
	ТекущееНазначение = Справочники.Назначения.ПустаяСсылка();
	
	СтрокаСПустымНазначениемНулевымКоличеством = Неопределено;
	
	Если ДанныеЕстьВТЧ Тогда
		
		ДанныеЕстьВТЧ = Ложь;
		Индекс = МассивСтрокТЧ.Количество();
		Пока Не ДанныеЕстьВТЧ
			И Индекс > 0 Цикл
			Индекс = Индекс - 1;
			СтрокаТЧ = МассивСтрокТЧ[Индекс];
			Если ЗначениеЗаполнено(СтрокаТЧ.Назначение) Тогда
				СтрокаНазначения = НазначенияПоТовару.Найти(СтрокаТЧ.Назначение, "Назначение");
				Если СтрокаНазначения <> Неопределено
					И СтрокаНазначения.Остаток >= ДобавляемоеКоличество Тогда
					ДанныеЕстьВТЧ = Истина;
					ТекущееНазначение = СтрокаТЧ.Назначение;
					МассивСтрокТЧ.Вставить(0, СтрокаТЧ);
					МассивСтрокТЧ.Удалить(Индекс + 1);
				КонецЕсли;
			Иначе
				Если СтрокаТЧ[ИмяКолонкиКоличество] > 0 Тогда
					// Если в строке уже заполнено количество и нет назначения,
					// значит, пользователь сам контролирует заполнение назначений, либо назначений нет.
					ДанныеЕстьВТЧ = Истина;
					МассивСтрокТЧ.Вставить(0, СтрокаТЧ);
					МассивСтрокТЧ.Удалить(Индекс + 1);
				Иначе
					// Запомним строку с пустым назначением, но попробуем найти строку с заполненным назначением,
					// чтобы дозаполнить ее при возможности.
					СтрокаСПустымНазначениемНулевымКоличеством = СтрокаТЧ;
				КонецЕсли;
			КонецЕсли;
		КонецЦикла;
		
	КонецЕсли;
	
	Если Не ДанныеЕстьВТЧ Тогда
		
		Для Каждого Стр Из НазначенияПоТовару Цикл
			Если Стр.Остаток >= ДобавляемоеКоличество Тогда
				ТекущееНазначение = Стр.Назначение;
				Прервать;
			КонецЕсли;
		КонецЦикла;
		
		Если СтрокаСПустымНазначениемНулевымКоличеством <> Неопределено Тогда
			СтрокаТЧ = СтрокаСПустымНазначениемНулевымКоличеством;
			ДанныеЕстьВТЧ = Истина;
		КонецЕсли;
	КонецЕсли;
	
	Возврат ТекущееНазначение;
	
КонецФункции

Процедура ЗаполнитьИспользованиеГруппыСкладов(Объект, СтруктураПараметров)
	
	ПараметрыУказанияСерий = СтруктураПараметров.ПараметрыУказанияСерий;
	
	Если Не НоменклатураСервер.СкладыУказываютсяВТабличнойЧасти(ПараметрыУказанияСерий) Тогда
		Возврат;
	КонецЕсли;
	
	ИмяПоляСклад = ПараметрыУказанияСерий.ИмяПоляСклад;
	
	Если ПараметрыУказанияСерий.ИмяПоляСклад <> Неопределено
		И ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(Объект, ИмяПоляСклад) Тогда
		
		СтруктураПараметров.ИспользуетсяГруппаСкладов = Справочники.Склады.ЭтоГруппа(Объект[ИмяПоляСклад]);
		
	КонецЕсли;
	
КонецПроцедуры

Функция СтатусУказанияСерий(ДобавляемыеДанные, СтруктураПараметров)
	
	Склад = СтруктураПараметров.Склад;
	ПараметрыУказанияСерий = СтруктураПараметров.ПараметрыУказанияСерий;
	
	Если ТипЗнч(Склад) = Тип("Структура") Тогда
		КлючКэша = КлючКэшаСтатусаУказанияСерий(Склад);
	Иначе
		КлючКэша = Склад;
	КонецЕсли;
	
	СтатусУказанияСерий = ДобавляемыеДанные.СтатусыУказанияСерий.Получить(КлючКэша);
	
	Если СтатусУказанияСерий = Неопределено Тогда
		СтатусУказанияСерий = НоменклатураСервер.СтатусУказанияСерийПоУмолчанию(ДобавляемыеДанные.Номенклатура,
																				Склад,
																				ПараметрыУказанияСерий);
		
		ДобавляемыеДанные.СтатусыУказанияСерий.Вставить(КлючКэша, СтатусУказанияСерий);
	КонецЕсли;
	
	Возврат СтатусУказанияСерий;
	
КонецФункции

Функция КлючКэшаСтатусаУказанияСерий(Склад)
	
	КлючКэша		= "";
	ПустоеЗначение	= "ПустоеЗначение";
	
	КлючКэша = ?(ЗначениеЗаполнено(Склад.Отправитель),
				Строка(Склад.Отправитель.УникальныйИдентификатор()),
				ПустоеЗначение);
	КлючКэша = КлючКэша + ?(ЗначениеЗаполнено(Склад.Получатель),
							Строка(Склад.Получатель.УникальныйИдентификатор()),
							ПустоеЗначение);

	Возврат КлючКэша;
	
КонецФункции

Процедура ПодобратьСериюВТЧТовары(ДобавляемыеДанные, СтруктураПараметров, НайденныеСтроки, ЗаполнятьСерию, СкладыВТЧ)
	
	Индекс					= НайденныеСтроки.ВГраница();
	ПараметрыУказанияСерий	= СтруктураПараметров.ПараметрыУказанияСерий;
	ПерваяСтрокаБезСерии	= Неопределено;
	
	ИспользуютсяВариантыОбеспечения = ПараметрыУказанияСерий.ЭтоЗаказ
		И ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(НайденныеСтроки[0], "ВариантОбеспечения");
	
	Пока Индекс >= 0 Цикл
		СтрокаТЧ = НайденныеСтроки[Индекс];
		
		Если ПараметрыУказанияСерий.ЭтоЗаказ Тогда
			Если Не СкладыВТЧ Тогда
				СтатусУказанияСерий = СтатусУказанияСерий(ДобавляемыеДанные, СтруктураПараметров);
			Иначе
				Склад = СтруктураПараметров.Склад;
				СтруктураПараметров.Склад = СтрокаТЧ[ПараметрыУказанияСерий.ИмяПоляСклад];
				
				СтатусУказанияСерий = СтатусУказанияСерий(ДобавляемыеДанные, СтруктураПараметров);
				
				СтруктураПараметров.Склад = Склад;
			КонецЕсли;
		Иначе
			СтатусУказанияСерий = СтрокаТЧ.СтатусУказанияСерий;
		КонецЕсли;
		
		СерияУказываетсяВТЧТовары = СтатусУказанияСерий > 0
									И НоменклатураКлиентСервер.ВЭтомСтатусеСерииУказываютсяВТЧТовары(
										СтрокаТЧ.СтатусУказанияСерий,
										ПараметрыУказанияСерий);
		
		Если СерияУказываетсяВТЧТовары
			И СтрокаТЧ.Серия <> ДобавляемыеДанные.Серия Тогда
			
			НайденныеСтроки.Удалить(Индекс);
			
			Если ИспользуютсяВариантыОбеспечения
				И Не ЗначениеЗаполнено(СтрокаТЧ.Серия)
				И СтрокаТЧ.ВариантОбеспечения <> Перечисления.ВариантыОбеспечения.Отгрузить Тогда
				
				ПерваяСтрокаБезСерии = СтрокаТЧ;
				
			КонецЕсли;
			
			Индекс = Индекс - 1;
			
			Продолжить;
			
		КонецЕсли;
		
		Если СкладыВТЧ
			И Не ПараметрыУказанияСерий.ЭтоЗаказ Тогда
			
			СтруктураПараметров.Склад = СтрокаТЧ[ПараметрыУказанияСерий.ИмяПоляСклад];
			
		КонецЕсли;
		
		Если СерияУказываетсяВТЧТовары Тогда
			ЗаполнятьСерию = ЗначениеЗаполнено(ДобавляемыеДанные.Серия);
		КонецЕсли;
		
		Если Индекс <> 0 Тогда
			НайденныеСтроки.Вставить(0, СтрокаТЧ);
			НайденныеСтроки.Удалить(Индекс + 1);
		КонецЕсли;
		
		Прервать;
	КонецЦикла;
	
	// В заказах увеличиваем количество для распознанного товара с серий в первой строке без серии.
	// Расчет статуса указания серий в заказе зависит не только от склада хранения, но и от варианта обеспечения.
	Если НайденныеСтроки.Количество() = 0
		И ПерваяСтрокаБезСерии <> Неопределено Тогда
		
		НайденныеСтроки.Добавить(ПерваяСтрокаБезСерии);
		
	КонецЕсли;
	
КонецПроцедуры

Процедура ЗаполнитьСтрокуТЧДляРасчетаСтатусаУказанияСерии(ТабличнаяЧасть, СтрокаТЧ, СтруктураПараметров, КэшированныеЗначения, Отгрузить)
	
	ПараметрыУказанияСерий = СтруктураПараметров.ПараметрыУказанияСерий;
	
	Если Не (ПараметрыУказанияСерий <> Неопределено
		И ПараметрыУказанияСерий.ИспользоватьСерииНоменклатуры) Тогда
		
		Возврат;
		
	КонецЕсли;
	
	ДействияСоСтроками				= Новый Структура;
	ДействийСДобавленнымиСтроками	= СтруктураПараметров.СтруктураДействийСДобавленнымиСтроками;
	
	Если ПараметрыУказанияСерий.ЭтоЗаказ
		И ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(СтрокаТЧ, "ВариантОбеспечения") Тогда
		
		Если ДействийСДобавленнымиСтроками.Свойство("ПроверитьЗаполнитьОбеспечениеВДокументеПродажи") Тогда
			ДействияСоСтроками.Вставить(
				"ПроверитьЗаполнитьОбеспечениеВДокументеПродажи",
				ДействийСДобавленнымиСтроками.ПроверитьЗаполнитьОбеспечениеВДокументеПродажи);
		КонецЕсли;
		
		Если ДействийСДобавленнымиСтроками.Свойство("ЗаполнитьОтгрузитьДляВариантаОформленияЗаказПлюсРеализация") Тогда
			ДействияСоСтроками.Вставить(
				"ЗаполнитьОтгрузитьДляВариантаОформленияЗаказПлюсРеализация",
				ДействийСДобавленнымиСтроками.ЗаполнитьОтгрузитьДляВариантаОформленияЗаказПлюсРеализация);
		КонецЕсли;
		
		Отгрузить = ?(ДействияСоСтроками.Количество() > 0,
						Неопределено,
						Отгрузить);
		
	КонецЕсли;
	
	УстановитьПараметрыСклада = Ложь;
	
	Если СтруктураПараметров.ИспользуетсяГруппаСкладов <> Ложь
		И НоменклатураСервер.СкладыУказываютсяВТабличнойЧасти(ПараметрыУказанияСерий) Тогда
		
		Если ТабличнаяЧасть.Количество() > 1
			И ЗначениеЗаполнено(ТабличнаяЧасть[ТабличнаяЧасть.Количество() - 2][ПараметрыУказанияСерий.ИмяПоляСклад]) Тогда
			
			СтрокаТЧ[ПараметрыУказанияСерий.ИмяПоляСклад] =
				ТабличнаяЧасть[ТабличнаяЧасть.Количество() - 2][ПараметрыУказанияСерий.ИмяПоляСклад];
			
			СтруктураПараметров.Склад = СтрокаТЧ[ПараметрыУказанияСерий.ИмяПоляСклад];
			
		Иначе
			Если ДействийСДобавленнымиСтроками.Свойство("ЗаполнитьПолучателяПоНаправлениюВыпуска") Тогда
				УстановитьПараметрыСклада = Истина;
				
				ДействияСоСтроками.Вставить(
					"ЗаполнитьПолучателяПоНаправлениюВыпуска",
					ДействийСДобавленнымиСтроками.ЗаполнитьПолучателяПоНаправлениюВыпуска);
				
				Если ДействийСДобавленнымиСтроками.Свойство("ЗаполнитьНаправлениеВыпуска") Тогда
					ДействияСоСтроками.Вставить(
						"ЗаполнитьНаправлениеВыпуска",
						ДействийСДобавленнымиСтроками.ЗаполнитьНаправлениеВыпуска);
				КонецЕсли;
			КонецЕсли;
			
			Если ДействийСДобавленнымиСтроками.Свойство("ПроверитьЗаполнитьСкладПроизводства") Тогда
				УстановитьПараметрыСклада = Истина;
				
				ДействияСоСтроками.Вставить(
					"ПроверитьЗаполнитьСкладПроизводства",
					ДействийСДобавленнымиСтроками.ПроверитьЗаполнитьСкладПроизводства);
					
				Если ДействийСДобавленнымиСтроками.Свойство("ЗаполнитьПризнакЦеховаяКладовая") Тогда
					ДействияСоСтроками.Вставить(
						"ЗаполнитьПризнакЦеховаяКладовая",
						ДействийСДобавленнымиСтроками.ЗаполнитьПризнакЦеховаяКладовая);
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
		
	КонецЕсли;
	
	Если ДействияСоСтроками.Количество() > 0 Тогда
		ПакетнаяОбработкаТабличнойЧастиСервер.ОбработатьСтрокуТЧ(СтрокаТЧ, ДействияСоСтроками, КэшированныеЗначения);
		
		Если Отгрузить = Неопределено Тогда
			Отгрузить = СтрокаТЧ.ВариантОбеспечения = Перечисления.ВариантыОбеспечения.Отгрузить;
		КонецЕсли;
		
		Если УстановитьПараметрыСклада Тогда
			СтруктураПараметров.Склад = СтрокаТЧ[ПараметрыУказанияСерий.ИмяПоляСклад];
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

Функция ЗаполнитьСериюВТЧТовары(ДобавляемыеДанные, СтруктураПараметров, Отгрузить = Истина)
	
	ЗаполнитьСерию = Ложь;
	
	Если Отгрузить Тогда
		СтатусУказанияСерий	= СтатусУказанияСерий(ДобавляемыеДанные, СтруктураПараметров);
		ЗаполнитьСерию		= СтатусУказанияСерий > 0
								И ЗначениеЗаполнено(ДобавляемыеДанные.Серия)
								И НоменклатураКлиентСервер.ВЭтомСтатусеСерииУказываютсяВТЧТовары(
									СтатусУказанияСерий,
									СтруктураПараметров.ПараметрыУказанияСерий);
	КонецЕсли;
	
	Возврат ЗаполнитьСерию;
	
КонецФункции

Функция ЗаполнитьСериюВТЧСерии(ДобавляемыеДанные, СтруктураПараметров)
	
	ЗаполнитьСерию = Ложь;
	
	Если Не ДобавляемыеДанные.НеизвестныйШтрихкод
		И ЗначениеЗаполнено(ДобавляемыеДанные.Серия)
		И Не ЗначениеЗаполнено(ДобавляемыеДанные.УпаковочныйЛист) Тогда
		
		СтатусУказанияСерий = СтатусУказанияСерий(ДобавляемыеДанные, СтруктураПараметров);
		
		ЗаполнитьСерию = НоменклатураКлиентСервер.ВЭтомСтатусеСерииУказываютсяВТЧСерии(
							СтатусУказанияСерий,
							СтруктураПараметров.ПараметрыУказанияСерий);
		
	КонецЕсли;
	
	Возврат ЗаполнитьСерию;
	
КонецФункции

Функция ДанныеЗаполненияСерииВТЧСерии(СтрокаТЧ, ДобавляемыеДанные, СтруктураПараметров)
	
	ДобавляемоеКоличество = 0;
	
	Если СтруктураПараметров.ЗагрузкаИзТСД
		Или Не (ДобавляемыеДанные.МаркируемаяПродукция
				И СтруктураПараметров.МаркируемаяПродукцияВТЧ) Тогда
		
		Если Не СтруктураПараметров.НеИспользоватьУпаковки Тогда
			ДобавляемоеКоличество = ДобавляемыеДанные.КоличествоПоШтрихкоду * ДобавляемыеДанные.КоличествоУпаковок;
		Иначе
			ДобавляемоеКоличество = ДобавляемыеДанные.КоличествоПоШтрихкоду * ДобавляемыеДанные.КоличествоУпаковок
									* ДобавляемыеДанные.Коэффициент;
		КонецЕсли;
	КонецЕсли;
	
	ДанныеЗаполнения = ДанныеЗаполненияСерииВТЧСерииПоУмолчанию();
	ЗаполнитьЗначенияСвойств(ДанныеЗаполнения, ДобавляемыеДанные);
	ДанныеЗаполнения.СтрокаТЧ	= СтрокаТЧ;
	ДанныеЗаполнения.Количество	= ДобавляемоеКоличество;
	
	Возврат ДанныеЗаполнения;
	
КонецФункции

Функция ДанныеЗаполненияСерииВТЧСерииПоУмолчанию()
	
	ДанныеЗаполнения = Новый Структура;
	ДанныеЗаполнения.Вставить("СтрокаТЧ");
	ДанныеЗаполнения.Вставить("Серия");
	ДанныеЗаполнения.Вставить("Количество", 0);
	ДанныеЗаполнения.Вставить("ИспользоватьКоличествоСерии", Истина);
	
	Возврат ДанныеЗаполнения;
	
КонецФункции

Процедура ДополнитьТабличнуюЧастьТарой(Объект, СтруктураПараметров, КэшированныеЗначения, ДобавленныеИзмененныеСтрокиТЧ, ДанныеСтрокТЧ, ТарыПоСтрокамТЧ)
	
	Для Каждого СтрокаТЧ Из ДобавленныеИзмененныеСтрокиТЧ Цикл
		Данные = ДанныеСтрокТЧ.Получить(СтрокаТЧ);
		
		Если Не Данные.ДополнятьТарой Тогда
			Продолжить;
		КонецЕсли;
		
		ПостобработкаСтрокиТЧДобавлениеТар(СтрокаТЧ, Данные, Объект, СтруктураПараметров, КэшированныеЗначения,
			ТарыПоСтрокамТЧ);
	КонецЦикла;
	
КонецПроцедуры

Процедура ЗаполнитьСерии(Объект, СтрокиДляОбработкиСерий, СтруктураПараметров, ДанныеСтрокТЧ, СтрокиТЧ)
	
	Если СтрокиДляОбработкиСерий.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	ПоляСвязи				= Новый Массив;
	ПараметрыУказанияСерий	= СтруктураПараметров.ПараметрыУказанияСерий;
	
	Для Каждого ПолеСвязи Из ПараметрыУказанияСерий.ПоляСвязи Цикл
		ПоляСвязи.Добавить(ПолеСвязи);
	КонецЦикла;
	
	Серии			= Объект[ПараметрыУказанияСерий.ИмяТЧСерии];
	ТекстПолейСвязи = СтрСоединить(ПоляСвязи, ",");
	ИменаРеквизитов = "Номенклатура, Характеристика, Серия"
						+ ?(ЗначениеЗаполнено(ТекстПолейСвязи), ", " + ТекстПолейСвязи, "");
	
	ДобавлятьТарыПоСтрокеТЧ = ПолучитьФункциональнуюОпцию("ИспользоватьМногооборотнуюТару")
		И СтруктураПараметров.ДополнятьТарой
		И СтруктураПараметров.ИзменятьКоличество
		И Не СтруктураПараметров.НеИспользоватьУпаковки
		И Не СтруктураПараметров.ТолькоУслуги
		И Не СтруктураПараметров.ТолькоРаботы
		И Не СтруктураПараметров.ТолькоТара;
	
	ОтборСтрок = Новый Структура(ИменаРеквизитов);
	
	Для Каждого СтрокаДляОбработки Из СтрокиДляОбработкиСерий Цикл
		ТекущаяСтрока	= СтрокаДляОбработки.СтрокаТЧ;
		ДанныеСтроки	= ДанныеСтрокТЧ.Получить(ТекущаяСтрока);
		
		ЗаполнитьЗначенияСвойств(ОтборСтрок, ТекущаяСтрока);
		ОтборСтрок.Серия = СтрокаДляОбработки.Серия;
		
		НайденныеСерии = Серии.НайтиСтроки(ОтборСтрок);
		
		Отказ = Ложь;
		
		Если НайденныеСерии.Количество() > 0 Тогда
			Если Не СтрокаДляОбработки.ИспользоватьКоличествоСерии Тогда
				Если Не ДанныеСтроки.СтрокаДобавлена Тогда
					ТекущаяСтрока[СтруктураПараметров.ИмяКолонкиКоличество] = ТекущаяСтрока[СтруктураПараметров.ИмяКолонкиКоличество]
						- СтрокаДляОбработки.Количество;
					
					// Подготовка строк для пакетной обработки.
					СтрокиТЧ.ОбрабатываемыеСтроки.Добавить(ТекущаяСтрока);
					
					ПредставлениеНоменклатуры = НоменклатураКлиентСервер.ПредставлениеНоменклатуры(
													СокрЛП(Строка(ТекущаяСтрока.Номенклатура)),
													СокрЛП(Строка(ТекущаяСтрока.Характеристика)));
					
					ТекстСообщения = НСтр("ru = 'Товар ""%1"" с серией ""%2"" уже есть в табличной части. Политика учета серий данного товара предусматривает, что количество по любой серии этого товара всегда будет равно 1.'");
					ТекстСообщения = СтрШаблон(ТекстСообщения,
												ПредставлениеНоменклатуры,
												СокрЛП(Строка(СтрокаДляОбработки.Серия)));
					
					ОбщегоНазначения.СообщитьПользователю(ТекстСообщения, Неопределено, "", "", Отказ);
				КонецЕсли;
			Иначе
				СтрокаСерии = НайденныеСерии[0];
				СтрокаСерии.Количество = СтрокаСерии.Количество + СтрокаДляОбработки.Количество;
			КонецЕсли;
		Иначе
			НоваяСтрока = Серии.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, ТекущаяСтрока);
			
			НоваяСтрока.Серия		= СтрокаДляОбработки.Серия;
			НоваяСтрока.Количество	= СтрокаДляОбработки.Количество;
		КонецЕсли;
		
		Если Не Отказ
			И Не СтрокаДляОбработки.ИспользоватьКоличествоСерии Тогда
			// Для строк будет выполнен подбор тары.
			ДанныеСтроки.ДополнятьТарой = ДобавлятьТарыПоСтрокеТЧ;
			
			СтрокиТЧ.ИзмененныеТовары.Добавить(ТекущаяСтрока);
		КонецЕсли;
		
		ИдентификаторСтроки = ТекущаяСтрока.ПолучитьИдентификатор();
		
		Если СтруктураПараметров.МассивСтрокСПодобраннымиСериями.Найти(ИдентификаторСтроки) = Неопределено Тогда
			СтруктураПараметров.МассивСтрокСПодобраннымиСериями.Добавить(ИдентификаторСтроки);
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

Процедура ОтменаИзмененийВСтрокеСОшибкой(Объект, ДобавляемыеДанные, СтрокаТЧ, СтруктураПараметров)
	
	Если ДобавляемыеДанные.ВыполненныеДействия.Добавлено Тогда
		ТабличнаяЧасть = Объект[СтруктураПараметров.ИмяТЧ];
		ТабличнаяЧасть.Удалить(СтрокаТЧ);
	ИначеЕсли ДобавляемыеДанные.ВыполненныеДействия.Изменено Тогда
		Если Не СтруктураПараметров.НеИспользоватьУпаковки Тогда
			СтрокаТЧ[СтруктураПараметров.ИмяКолонкиКоличество] = СтрокаТЧ[СтруктураПараметров.ИмяКолонкиКоличество]
				- ДобавляемыеДанные.КоличествоПоШтрихкоду;
		Иначе
			СтрокаТЧ[СтруктураПараметров.ИмяКолонкиКоличество] = СтрокаТЧ[СтруктураПараметров.ИмяКолонкиКоличество]
				- ДобавляемыеДанные.КоличествоПоШтрихкоду * ДобавляемыеДанные.Коэффициент;
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

Функция ИндексНайденнойСтроки(НайденныеСтроки, ОтборПоСерии)
	
	Возврат ?(ОтборПоСерии, 0, НайденныеСтроки.ВГраница());
	
КонецФункции

Функция ДатаИзСтрокиШтрихкода(Знач Штрихкод)
	
	ШтрихкодДата = '00010101';	
	
	Если СтроковыеФункцииКлиентСервер.ТолькоЦифрыВСтроке(Штрихкод) Тогда
		
		Если СтрДлина(Штрихкод) = 8 Тогда
			
			Штрихкод = "20" + Сред(Штрихкод,5,2) + Сред(Штрихкод,3,2) + Лев(Штрихкод,2) + Прав(Штрихкод, 2) + "0000";
			
			Попытка
				ШтрихкодДата = Дата(Штрихкод);
			Исключение
				ШтрихкодДата = '00010101';
			КонецПопытки;
			
		ИначеЕсли СтрДлина(Штрихкод) = 6 Тогда
			
			Штрихкод = "20" + Сред(Штрихкод,5,2) + Сред(Штрихкод,3,2) + Лев(Штрихкод,2) + "000000";
			
			Попытка
				ШтрихкодДата = Дата(Штрихкод);
			Исключение
				ШтрихкодДата = '00010101';
			КонецПопытки;
			
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат ШтрихкодДата;
	
КонецФункции

#Область ПостобработкаСтрокТЧ

Процедура ПостобработкаСтрокиТЧДобавлениеТар(СтрокаТЧ, Данные, Объект, СтруктураПараметров, КэшированныеЗначения, ТарыПоСтрокамТЧ)
	
	Если Данные.НеИспользоватьУпаковки Тогда
		Возврат;
	КонецЕсли;
	
	ТаблицаТары = МногооборотнаяТараСервер.МногооборотнаяТараНоменклатуры(
					СтрокаТЧ.Номенклатура,
					СтрокаТЧ[СтруктураПараметров.ИмяКолонкиУпаковка]);
	
	Для Каждого СтрТабл Из ТаблицаТары Цикл
		ДобавляемыеДанные = ПакетнаяОбработкаТабличнойЧастиКлиентСервер.СтруктураКэшируемойИнформацииПоШтрихкоду();
		ЗаполнитьЗначенияСвойств(ДобавляемыеДанные, СтрТабл);
		ДобавляемыеДанные.КоличествоПоШтрихкоду	= Данные.КоличествоШтрихкод;
		ДобавляемыеДанные.НеизвестныйШтрихкод	= Ложь;
		
		СтрокаТары = ДобавитьИзменитьСтрокуВТЧ(Объект,
											СтруктураПараметров,
											ДобавляемыеДанные,
											"Тара",
											КэшированныеЗначения);
		
		Если СтрокаТары <> Неопределено Тогда
			Если ДобавляемыеДанные.ВыполненныеДействия.Добавлено Тогда
				ТарыПоСтрокамТЧ.ДобавленныеТары.Добавить(СтрокаТары);
			ИначеЕсли ДобавляемыеДанные.ВыполненныеДействия.Изменено Тогда
				ТарыПоСтрокамТЧ.ИзмененныеТары.Добавить(СтрокаТары);
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

Процедура ПостобработкаСтатусовУказанияСерийСтрокиТЧ(СтрокаТЧ, Объект, СтруктураПараметров, КэшированныеЗначения)
	
	ИдентификаторСтроки = СтрокаТЧ.ПолучитьИдентификатор();
	
	// В форме проверки заполнения документа отображаются только фин.серии, ТЧ Серии нет,
	// обработка серий произойдет при обработке строк ТЧ (выше).
	Если Не (СтруктураПараметров.ПараметрыУказанияСерий.ИмяИсточникаЗначенийВФормеОбъекта = "ЭтаФорма"
			И Объект.ИмяФормы = "ОбщаяФорма.ПроверкаЗаполненияДокументов") Тогда
		НоменклатураСервер.ЗаполнитьСтатусыУказанияСерийПриОкончанииРедактированияСтрокиТЧ(Объект,
																						СтруктураПараметров.ПараметрыУказанияСерий, 
																						СтрокаТЧ.ПолучитьИдентификатор(),
																						КэшированныеЗначения);
	КонецЕсли;
	
	Если СтрокаТЧ.СтатусУказанияСерий <> 0 Тогда
		Если СтруктураПараметров.МассивСтрокСПодобраннымиСериями.Найти(ИдентификаторСтроки) = Неопределено Тогда
			СтруктураПараметров.МассивСтрокССериями.Добавить(ИдентификаторСтроки);
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

Процедура ПостобработкаСтрокиТЧТовара(СтрокаТЧ, Данные, Объект, СтруктураПараметров, КэшированныеЗначения)
	
	Если СтруктураПараметров.ШтрихкодыВТЧ
		И СтруктураПараметров.ИзменятьКоличество
		И Не Данные.НеизвестныйШтрихкод Тогда
		СтрокаТЧ.ШтрихкодНеОпределен = 0;
	КонецЕсли;
	
КонецПроцедуры

Процедура ПостобработкаСтрокиТЧКомплектующейНабора(СтрокаТЧ, МассивСтрокСНаборами)
	
	Если ОбщегоНазначенияУТКлиентСервер.ЕстьРеквизитОбъекта(СтрокаТЧ, "ИндексНабора")
		И ОбщегоНазначенияУТКлиентСервер.ЕстьРеквизитОбъекта(СтрокаТЧ, "НоменклатураНабора")
		И ЗначениеЗаполнено(СтрокаТЧ.НоменклатураНабора) Тогда
		СтрокаТЧ.ИндексНабора = 1;
	КонецЕсли;
	МассивСтрокСНаборами.Добавить(СтрокаТЧ);
	
КонецПроцедуры

#КонецОбласти

#Область RFID

Функция ДобавитьСериюПоИнформацииОМетке(ТекущаяМетка, Параметры, ТЧСерии, ИдентификаторТекущейСтроки)
	
	ОбрабатываемаяСтрока = НоменклатураЛокализация.ДобавитьСериюПоИнформацииОМетке(ТекущаяМетка, Параметры, ТЧСерии, ИдентификаторТекущейСтроки);
	
	Если ОбрабатываемаяСтрока <> Неопределено Тогда
		Возврат ОбрабатываемаяСтрока;
	КонецЕсли;
	
	НастройкиИспользованияСерий = Параметры.НастройкиИспользованияСерий;
	ВидНоменклатуры             = НастройкиИспользованияСерий.ВладелецСерий;
	
	Если Не ЗначениеЗаполнено(ТекущаяМетка.TID) Тогда
		ТекстСообщения = НСтр("ru = 'Ошибка добавления серии по информации о RFID-метке: не заполнен TID.'");
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);
		Возврат Неопределено;
	ИначеЕсли Не НастройкиИспользованияСерий.ИспользоватьRFIDМеткиСерии Тогда
		ТекстСообщения = НСтр("ru = 'Ошибка добавления серии по информации о RFID-метке: для серий этого вида номенклатуры не используются метки.'");
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);
		Возврат Неопределено;
	КонецЕсли;
	
	НайденныеСтроки = ТЧСерии.НайтиСтроки(Новый Структура("RFIDTID", ТекущаяМетка.TID));
		
	ОбрабатываемаяСтрока = Неопределено;
	
	Если ИдентификаторТекущейСтроки <> Неопределено Тогда
		ТекущаяСтрока = ТЧСерии.НайтиПоИдентификатору(ИдентификаторТекущейСтроки);
	Иначе
		ТекущаяСтрока = Неопределено;
	КонецЕсли;
	
	// Для случая, когда информации о КиЗ в системе нет, поэтому мы считываем RFID и сканером номер КиЗ.
	Если НайденныеСтроки.Количество() = 0
		И ТекущаяСтрока <> Неопределено
		И Не ЗначениеЗаполнено(ТекущаяСтрока.RFIDTID)
		И (Не ЗначениеЗаполнено(ТекущаяСтрока.Номер)
			Или Не НастройкиИспользованияСерий.ИспользоватьНомерСерии 
			Или ТекущаяСтрока.Номер = ТекущаяМетка.СерийныйНомер) Тогда
		
		ОбрабатываемаяСтрока = ТекущаяСтрока;
		ОбрабатываемаяСтрока.RFIDTID = ТекущаяМетка.TID;
		Если ЗначениеЗаполнено(ТекущаяМетка.GTIN)
			И Не ЗначениеЗаполнено(ОбрабатываемаяСтрока.EPCGTIN) Тогда
			ОбрабатываемаяСтрока.EPCGTIN = СтроковыеФункцииКлиентСервер.УдалитьПовторяющиесяСимволы(ТекущаяМетка.GTIN, "0");
		КонецЕсли;
		
		Если ЗначениеЗаполнено(ТекущаяМетка.СерийныйНомер)
			И Не ЗначениеЗаполнено(ОбрабатываемаяСтрока.Номер) Тогда
			ОбрабатываемаяСтрока.Номер = ТекущаяМетка.СерийныйНомер;
		КонецЕсли;
		
		Возврат ОбрабатываемаяСтрока;	
	
	ИначеЕсли НайденныеСтроки.Количество() > 0 Тогда
		ОбрабатываемаяСтрока = НайденныеСтроки[0];
		
		Возврат ОбрабатываемаяСтрока;
	Иначе
		ШаблонВыборкиРеквизита = "	СерииНоменклатуры.%ИмяРеквизита% КАК %ИмяРеквизита%";
		
		МассивТекстов = Новый Массив;
		МассивТекстов.Добавить("	СерииНоменклатуры.Ссылка КАК Серия");
		
		Для Каждого Описание Из НастройкиИспользованияСерий.ОписанияИспользованияРеквизитовСерии Цикл
			ТекстРеквизита = СтрЗаменить(ШаблонВыборкиРеквизита, "%ИмяРеквизита%", Описание.ИмяРеквизита);
			МассивТекстов.Добавить(ТекстРеквизита);
		КонецЦикла;
		
		ТекстЗапросаЗапроса =
		"ВЫБРАТЬ
		|	&ТекстВыборкиРеквизитов
		|ИЗ
		|	Справочник.СерииНоменклатуры КАК СерииНоменклатуры
		|ГДЕ
		|	СерииНоменклатуры.ВидНоменклатуры = &ВидНоменклатуры
		|	И СерииНоменклатуры.RFIDTID = &TID";
		
		ТекстЗапросаЗапроса = СтрЗаменить(ТекстЗапросаЗапроса, "&ТекстВыборкиРеквизитов" ,СтрСоединить(МассивТекстов,","));
		
		Запрос = Новый Запрос;
		Запрос.УстановитьПараметр("TID", ТекущаяМетка.TID);
		Запрос.УстановитьПараметр("ВидНоменклатуры", ВидНоменклатуры);
		
		Выборка = Запрос.Выполнить().Выбрать();
		
		Если Выборка.Следующий() Тогда
			ОбрабатываемаяСтрока = ТЧСерии.Добавить();
			ЗаполнитьЗначенияСвойств(ОбрабатываемаяСтрока, Выборка);
			ОбрабатываемаяСтрока.Количество         = 1;
			ОбрабатываемаяСтрока.КоличествоУпаковок = 1;
		Иначе
			ОбрабатываемаяСтрока = ТЧСерии.Добавить();
			ОбрабатываемаяСтрока.RFIDTID = ТекущаяМетка.TID;
			
			Если ЗначениеЗаполнено(ТекущаяМетка.GTIN) Тогда
				ОбрабатываемаяСтрока.EPCGTIN = СтроковыеФункцииКлиентСервер.УдалитьПовторяющиесяСимволы(ТекущаяМетка.GTIN, "0");
			КонецЕсли;
			
			Если ЗначениеЗаполнено(ТекущаяМетка.СерийныйНомер)
				И  НастройкиИспользованияСерий.ИспользоватьНомерСерии Тогда
				ОбрабатываемаяСтрока.Номер = ТекущаяМетка.СерийныйНомер;
			КонецЕсли;
		КонецЕсли;	
				
	КонецЕсли;
		
	Возврат ОбрабатываемаяСтрока;
	
КонецФункции

// Функция - Параметры заполнения флагов работы с меткой
// 
// Возвращаемое значение:
//  Структура - содержит свойства:
//		* ТекущаяМетка - Структура - данные текущей метки RFID
//		* НастройкиИспользованияСерий - см. Справочники.ВидыНоменклатуры.НастройкиИспользованияСерий.
//		* ЗначенияПолейСвязи - Структура, ФиксированнаяСтруктура - коллекция полей связи.
//
Функция ПараметрыЗаполненияФлаговРаботыСМеткой() Экспорт
	
	Результат = Новый Структура;
	Результат.Вставить("ТекущаяМетка");
	Результат.Вставить("НастройкиИспользованияСерий");
	Результат.Вставить("ЗначенияПолейСвязи");
	
	Возврат Результат;
	
КонецФункции

// Заполняет флаги работы с меткой RFID.
//
// Параметры:
//	ОбрабатываемаяСтрока - ДанныеФормыЭлементКоллекции  - строка для обработки
//	ПараметрыЗаполненияФлаговРаботыСМеткой - см. ПараметрыЗаполненияФлаговРаботыСМеткой.
//
Процедура ЗаполнитьФлагиРаботыСМеткой(ОбрабатываемаяСтрока, ПараметрыЗаполненияФлаговРаботыСМеткой) Экспорт
	
	Если ОбрабатываемаяСтрока = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ОписаниеИспользованияНомера  = Неопределено;
	ОписаниеИспользованияRFIDEPC = Неопределено;
	ОписаниеИспользованияRFIDTID = Неопределено;
	
	ТекущаяМетка = ПараметрыЗаполненияФлаговРаботыСМеткой.ТекущаяМетка;
	НастройкиИспользованияСерий = ПараметрыЗаполненияФлаговРаботыСМеткой.НастройкиИспользованияСерий;
	
	Для Каждого Описание Из НастройкиИспользованияСерий.ОписанияИспользованияРеквизитовСерии Цикл
		Если Описание.ИмяРеквизита = "Номер" Тогда
			ОписаниеИспользованияНомера = Описание;
		ИначеЕсли Описание.ИмяРеквизита = "RFIDEPC" Тогда
			ОписаниеИспользованияRFIDEPC = Описание;
		ИначеЕсли Описание.ИмяРеквизита = "RFIDTID" Тогда
			ОписаниеИспользованияRFIDTID = Описание;
		КонецЕсли;
		
		Если ОписаниеИспользованияНомера <> Неопределено
			И ОписаниеИспользованияRFIDEPC <> Неопределено
			И ОписаниеИспользованияRFIDTID <> Неопределено Тогда
			Прервать;
		КонецЕсли;
		
	КонецЦикла;
	
	Если Не ОписаниеИспользованияRFIDTID.Использование Тогда
		Возврат;
	КонецЕсли;
	
	ОбрабатываемаяСтрока.ЗаполненRFIDTID = ЗначениеЗаполнено(ОбрабатываемаяСтрока.RFIDTID);
	
	Если ТекущаяМетка <> Неопределено Тогда
		ОбрабатываемаяСтрока.RFIDEPC = ТекущаяМетка.EPC;
	КонецЕсли;
	
	// Если есть метки, номер используется, но его нельзя менять вручную, значит его нужно генерировать по TID-метки
	Если (ОписаниеИспользованияНомера.Использование
		И Не ОписаниеИспользованияНомера.МожноРедактировать)
		И ОбрабатываемаяСтрока.ЗаполненRFIDTID Тогда
		
		РезультатРасчетаНомера = МенеджерОборудованияКлиентСервер.ПолучитьСерийныйНомерПоTID(ОбрабатываемаяСтрока.RFIDTID,
																								ОбрабатываемаяСтрока.RFIDEPC);	
		
		Если РезультатРасчетаНомера.Результат Тогда
			ОбрабатываемаяСтрока.Номер = Формат(РезультатРасчетаНомера.СерийныйНомер, "ЧГ=0");
		Иначе
			ОбрабатываемаяСтрока.Номер = "";
			
			ТекстСообщения = НСтр("ru = 'Номер серии должен быть сгенерирован по TID RFID-метки. При генерации произошла ошибка: %ТекстОшибки%. Обратитесь к администратору.'");
			ТекстСообщения = СтрЗаменить(ТекстСообщения, "%ТекстОшибки%", РезультатРасчетаНомера.ОписаниеОшибки); 
			
			ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);
		КонецЕсли;
		
	КонецЕсли;
	
	Если ПараметрыЗаполненияФлаговРаботыСМеткой.ЗначенияПолейСвязи.Свойство("GTIN") Тогда
		GTIN = ПараметрыЗаполненияФлаговРаботыСМеткой.ЗначенияПолейСвязи.GTIN;
	Иначе
		GTIN = ""
	КонецЕсли;
	
	Если Не ОписаниеИспользованияRFIDEPC.МожноРедактировать Тогда
		Если Не ПустаяСтрока(GTIN) 
			И ОбрабатываемаяСтрока.EPCGTIN <> GTIN
			И ОбрабатываемаяСтрока.ЗаполненRFIDTID Тогда
			
			ТекстСообщения = НСтр("ru = 'GTIN, считанный из RFID метки не соответствует GTIN из %1. Маркировка осуществляется персонифицированными %1, поэтому необходимо считать подходящую метку RFID-считывателем.'");
			ТекстСообщения = СтрШаблон(ТекстСообщения, "КиЗ");
			
			ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);
			
		КонецЕсли;
		ОбрабатываемаяСтрока.НужноЗаписатьМетку = Ложь;
		
	ИначеЕсли ЗначениеЗаполнено(GTIN)
		И ОписаниеИспользованияНомера.Использование 
		И ЗначениеЗаполнено(ОбрабатываемаяСтрока.Номер) Тогда
		
		// Если RFIDEPC можно писать, то запишем туда SGTIN96. Это возможно, если используются номера серий
		// и через значения полей связи передан GTIN. В ERP этот параметр передается только для ГИСМ
		
		ОбрабатываемаяСтрока.EPCGTIN = GTIN;
		
		Если СтроковыеФункцииКлиентСервер.СтрокаВЧисло(ОбрабатываемаяСтрока.Номер) <> Неопределено Тогда
			
			ДанныеEPC = МенеджерОборудованияКлиентСервер.СформироватьДанныеSGTIN96(ОбрабатываемаяСтрока.EPCGTIN,
																					ОбрабатываемаяСтрока.Номер, 1);
			
			Если (Не МенеджерОборудованияКлиентСервер.ПустойEPC(ДанныеEPC)
				Или Не МенеджерОборудованияКлиентСервер.ПустойEPC(ОбрабатываемаяСтрока.RFIDEPC)) Тогда
				ОбрабатываемаяСтрока.НужноЗаписатьМетку = ДанныеEPC <> ОбрабатываемаяСтрока.RFIDEPC;
			Иначе
				ОбрабатываемаяСтрока.НужноЗаписатьМетку = Ложь;
			КонецЕсли;
		Иначе
			ОбрабатываемаяСтрока.НужноЗаписатьМетку = Ложь;
		КонецЕсли;
		
	КонецЕсли;
	
	Если Не ОбрабатываемаяСтрока.ЗаполненRFIDTID Тогда
		ОбрабатываемаяСтрока.СтатусРаботыRFID = 0;
	ИначеЕсли ОбрабатываемаяСтрока.НужноЗаписатьМетку Тогда
		ОбрабатываемаяСтрока.СтатусРаботыRFID = 1;
	Иначе
		ОбрабатываемаяСтрока.СтатусРаботыRFID = 2;
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#КонецОбласти
