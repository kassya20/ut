
#Область ПрограммныйИнтерфейс

// Возвращает конструктор параметров установки картинок штампов в документ.
//
// Возвращаемое значение:
//  Структура:
//    * ПараметрыДокумента  - см. НовыеПараметрыФайла.
//    * ПараметрыШтампов    - Массив из см. НовыеПараметрыШтампа.
//    * СтратегииРазмещения - Массив из см. НоваяСтратегияРазмещенияШтампов.
//    * ПараметрыРезультата - см. НовыеПараметрыПолученияРезультата.
//
Функция НовыеПараметрыУстановкиШтамповВДокумент() Экспорт
	
	ПараметрыДобавления = Новый Структура;
	ПараметрыДобавления.Вставить("ПараметрыДокумента" , НовыеПараметрыФайла());
	ПараметрыДобавления.Вставить("ПараметрыШтампов"   , Новый Массив);
	ПараметрыДобавления.Вставить("СтратегииРазмещения", Новый Массив);
	ПараметрыДобавления.Вставить("ПараметрыРезультата", НовыеПараметрыПолученияРезультата());
	
	Возврат ПараметрыДобавления;
	
КонецФункции

// Возвращает конструктор параметров устанавливаемой картинки штампа.
//
// Возвращаемое значение:
//  Структура:
//    * ПараметрыФайла     - см. НовыеПараметрыФайла.
//    * Настройки          - см. НовыеНастройкиШтампа.
//    * ПараметрыУстановки - см. НовыеПараметрыУстановкиШтампа.
//
Функция НовыеПараметрыШтампа() Экспорт
	
	ПараметрыШтампа = Новый Структура;
	
	ПараметрыШтампа.Вставить("ПараметрыФайла"    , НовыеПараметрыФайла());
	ПараметрыШтампа.Вставить("Настройки"         , НовыеНастройкиШтампа());
	ПараметрыШтампа.Вставить("ПараметрыУстановки", НовыеПараметрыУстановкиШтампа());
	
	Возврат ПараметрыШтампа;
	
КонецФункции

// Возвращает конструктор параметров устанавливаемой картинки штампа.
//
// Возвращаемое значение:
//  Структура:
//    * ПоПозиционированию - Структура - Параметры установки штампов по позиционированию:
//       ** Позиции - Массив из см. НовыеПараметрыУстановкиШтампаПоПозиции.
//    * ПоТегам - Структура - Параметры установки штампов по тегам:
//       ** Теги - Массив из см. НовыеПараметрыТега.
//       ** АльтернативныйСпособУстановки - см. НовыеПараметрыУстановкиШтампа()
//                                        - Неопределено - Значение не инициализировано.
//            Параметры установки штампов, если теги в документе не найдены. Необязательное свойство.
//
Функция НовыеПараметрыУстановкиШтампа() Экспорт
	
	ПараметрыУстановкиШтампа = Новый Структура;
	
	ПараметрыУстановкиШтампаПоТегам = Новый Структура;
	ПараметрыУстановкиШтампаПоТегам.Вставить("Теги", Новый Массив);
	ПараметрыУстановкиШтампаПоТегам.Вставить("АльтернативныйСпособУстановки", Неопределено);
	
	ПараметрыУстановкиШтампаПоПозиции = Новый Структура;
	ПараметрыУстановкиШтампаПоПозиции.Вставить("Позиции", Новый Массив);
	
	ПараметрыУстановкиШтампа.Вставить("ПоПозиционированию", ПараметрыУстановкиШтампаПоПозиции);
	ПараметрыУстановкиШтампа.Вставить("ПоТегам"           , ПараметрыУстановкиШтампаПоТегам);
	
	Возврат ПараметрыУстановкиШтампа;
	
КонецФункции

// Возвращает конструктор параметров установки картинки штампа по позиционированию.
//
// Возвращаемое значение:
//  Структура:
//    * НаСтранице  - см. НовыеПараметрыРасположенияНаСтранице.
//    * НаСтраницах - см. НовыеПараметрыРасположенияНаСтраницах.
//
Функция НовыеПараметрыУстановкиШтампаПоПозиции() Экспорт
	
	ПараметрыШтампа = Новый Структура;
	
	ПараметрыШтампа.Вставить("НаСтранице" , НовыеПараметрыРасположенияНаСтранице());
	ПараметрыШтампа.Вставить("НаСтраницах", НовыеПараметрыРасположенияНаСтраницах());
	
	Возврат ПараметрыШтампа;
	
КонецФункции

// Возвращает конструктор параметров тега.
//
// Возвращаемое значение:
//  Структура:
//   * ЗначениеТега          - Строка - Текст, по позиции которого будет вставлена картинка штампа.
//   * ЗамещатьЗначениеТега  - Булево - Признак замещения тега картинкой штампа.
//   * СпособУстановкиШтампа - Строка - Способ установки картинки штампа в текстовое содержимое документа.
//       Значение по умолчанию: "НадТекстом".
//
Функция НовыеПараметрыТега() Экспорт
	
	ПараметрыШтампов = Новый Структура;
	ПараметрыШтампов.Вставить("ЗначениеТега"         , "");
	ПараметрыШтампов.Вставить("ЗамещатьЗначениеТега" , Ложь);
	ПараметрыШтампов.Вставить("СпособУстановкиШтампа", СпособУстановкиШтампаНадТекстом());
	
	Возврат ПараметрыШтампов;
	
КонецФункции

// Возвращает конструктор параметров множественного размещения картинок штампов по шаблонному значению позиционирования.
//
// Возвращаемое значение:
//   Размещение - см. НовоеРасположениеДляМножественногоРазмещения.
//   Статегия   - см. НоваяСтратегияРазмещения.
//
Функция НоваяСтратегияРазмещенияШтампов() Экспорт
	
	СтратегияРазмещения = Новый Структура;
	СтратегияРазмещения.Вставить("Размещение", НовоеРасположениеДляМножественногоРазмещения());
	СтратегияРазмещения.Вставить("Статегия"  , НоваяСтратегияРазмещения());
	
	Возврат СтратегияРазмещения;
	
КонецФункции

// Возвращает конструктор параметров файла.
//
// Возвращаемое значение:
//  Структура: 
//    * ДвоичныеДанные - ДвоичныеДанные - Двоичные данные файла.
//                     - Неопределено   - Значение не инициализировано.
//    * Расширение     - Строка         - Значение расширения файла.
//
Функция НовыеПараметрыФайла() Экспорт
	
	ПараметрыФайла = Новый Структура;
	
	ПараметрыФайла.Вставить("ДвоичныеДанные", Неопределено);
	ПараметрыФайла.Вставить("Расширение"    , "");
	
	Возврат ПараметрыФайла;
	
КонецФункции

