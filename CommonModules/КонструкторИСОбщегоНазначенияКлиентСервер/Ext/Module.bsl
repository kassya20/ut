// Возвращает перечень маркируемой продукции, оборот которой фиксируется в указанной подсистеме.
//
// Параметры:
//  ИмяПодсистемы - Строка - Имя подсистемы
//
// Возвращаемое значение:
//   Массив Из СправочникСсылка.ВидыПродукцииИС - список видов маркируемой продукции указанной подсистемы.
//
Функция ВидыПродукцииПоИмениПодсистемы(знач ИмяПодсистемы) Экспорт
	
	ИмяПодсистемы = ВРег(ИмяПодсистемы);
	
	Если ИмяПодсистемы = "ИСМП" Или ИмяПодсистемы = "ГИСМТ" Тогда
		Возврат ВидыПродукцииИСМП();
	ИначеЕсли ИмяПодсистемы = "ВЕТИС" Тогда
		Возврат ВидыПродукцииВетИС();
	ИначеЕсли ИмяПодсистемы = "ЕГАИС" Тогда
		Возврат ВидыПродукцииЕГАИС();
	ИначеЕсли ИмяПодсистемы = "ЗЕРНО" Тогда
		Возврат ВидыПродукцииЗЕРНО();
	ИначеЕсли ИмяПодсистемы = "САТУРН" Тогда
		Возврат ВидыПродукцииСАТУРН();
	КонецЕсли;
	
	Возврат Новый Массив;
	
КонецФункции

// Возвращает перечень учитываемой маркируемой продукции, оборот которой фиксируется в ИС МП.
//
// Параметры:
//  ВключатьТабачнуюПродукцию - Булево - Признак включения табачной продукции
//
// Возвращаемое значение:
//   Массив Из СправочникСсылка.ВидыПродукцииИС - список видов маркируемой продукции ИСМП.
//
Функция УчитываемыеВидыПродукцииИСМП(ВключатьТабачнуюПродукцию = Ложь) Экспорт
	
	ВидыПродукцииГИСМТ = ВидыПродукцииПоЭлементуКонструктора(
		ПредопределенноеЗначение(
			"Справочник.ЭлементыКонструктораВидовПродукцииИС.ВидыПродукцииГИСМТ"));
	
	Если Не ВключатьТабачнуюПродукцию Тогда
		ВидыПродукции = ОбщегоНазначенияКлиентСервер.РазностьМассивов(
			ВидыПродукцииГИСМТ,
			ВидыПродукцииМОТП());
	Иначе
		ВидыПродукции = ВидыПродукцииГИСМТ;
	КонецЕсли;

	Возврат ВидыПродукции;
	
КонецФункции

