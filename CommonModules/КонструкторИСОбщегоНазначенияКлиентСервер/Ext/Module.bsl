КонецФункции

// Возвращает зависимые виды продукции ИС для заданного значения.
//
// Параметры:
//  Значение - СправочникСсылка.ЭлементыКонструктораВидовПродукцииИС - Элемент конструктора, для которого необходимо получить зависимые виды продукции.
//
// Возвращаемое значение:
//  Массив Из СправочникСсылка.ВидыПродукцииИС
//
Функция ЗависимыеВидыПродукцииИС(Значение) Экспорт
	
	Возврат ВидыПродукцииПоЗначениюЭлементаКонструктора(
		ПредопределенноеЗначение(
			"Справочник.ЭлементыКонструктораВидовПродукцииИС.ЗависимыеВидыПродукцииИС"),
		Значение);
	
КонецФункции

// Возвращает зависимые элементы конструктора с атрибутами для заданного вида продукции.
//
// Параметры:
//  ВидПродукции - СправочникСсылка.ВидыПродукцииИС - Вид продукции, для которого необходимо получить зависимые элементы конструктора.
//
// Возвращаемое значение:
//  Соответствие Из КлючИЗначение
//   Ключ - СправочникСсылка.ЭлементыКонструктораВидовПродукцииИС - Элемент конструктора.
//   Значение - Структура - Атрибуты.
//
Функция ЗависимыеВидыПродукцииИССАтрибутами(ВидПродукции) Экспорт
	
	Результат = Новый Соответствие;
	
	ДанныеЭлемента = ДанныеЭлементаКонструктора(
		ПредопределенноеЗначение(
			"Справочник.ЭлементыКонструктораВидовПродукцииИС.ЗависимыеВидыПродукцииИС"));
	
	Значения = ДанныеЭлемента.ВидыПродукции[ВидПродукции];
	
	Если Значения <> Неопределено Тогда
		Для Каждого Значение Из Значения Цикл
			Атрибуты = Новый Структура("Обязательный,Значение");
			ЗаполнитьЗначенияСвойств(Атрибуты, Значение.Значение);
			Результат.Вставить(Значение.Ключ, Атрибуты);
		КонецЦикла;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Признак использования объемно-сортового учета для вида продукции.
// 
// Параметры:
//  ВидПродукции - СправочникСсылка.КлючиВидовПродукцииИС,
//                 СправочникСсылка.ВидыПродукцииИС,
//                 Массив из СправочникСсылка.ВидыПродукцииИС - виды продукции, для которых требуется получить значение.
// 
// Возвращаемое значение:
//   Булево - Признак использования объемно-сортового учета для вида продукции.
//
Функция ВидПродукцииИспользуетОбъемноСортовойУчет(ВидПродукции) Экспорт
	
	Возврат ИспользуетсяВидУпаковки(ВидПродукции,
		ПредопределенноеЗначение("Перечисление.ВидыУпаковокИС.ОбъемноСортовойУчет"));
	
КонецФункции

// Признак использования объемно-сортового учета для вида продукции по виду операции.
// 
// Параметры:
//  ВидыПродукции - СправочникСсылка.ТоварныеГруппыГИСМТ - Товарная группа,
//                               СправочникСсылка.ВидыПродукцииИС - Вид продукции,
//                               СправочникСсылка.КлючиВидовПродукцииИС - ключ видов продукции,
//                               Массив из СправочникСсылка.ВидыПродукцииИС.
//  ПараметрыСканирования - см. ШтрихкодированиеОбщегоНазначенияИС.ПараметрыСканирования
//  
// Возвращаемое значение:
//   Булево - Признак использования объемно-сортового учета для вида продукции.
//
Функция ПоддерживаетсяОбъемноСортовойУчет(ВидыПродукции, ПараметрыСканирования) Экспорт
	
	Если Не ИспользуетсяВидУпаковки(
		ВидыПродукции,
		ПредопределенноеЗначение("Перечисление.ВидыУпаковокИС.ОбъемноСортовойУчет")) Тогда
		
		Возврат Ложь;
		
	ИначеЕсли ПараметрыСканирования.ИСМП Тогда
		
		#Если Сервер Или ВнешнееСоединение Или ТолстыйКлиентОбычноеПриложение Тогда
		МодульКонструкторИСМПОбщегоНазначенияКлиентСервер = ОбщегоНазначенияИСПовтИсп.ОбщийМодуль("КонструкторИСМПОбщегоНазначенияКлиентСервер");
		#Иначе
		МодульКонструкторИСМПОбщегоНазначенияКлиентСервер = ОбщегоНазначенияКлиент.ОбщийМодуль("КонструкторИСМПОбщегоНазначенияКлиентСервер");
		#КонецЕсли
		
		Возврат МодульКонструкторИСМПОбщегоНазначенияКлиентСервер.ПоддерживаетсяОбъемноСортовойУчет(
			ВидыПродукции,
			ПараметрыСканирования.ВидОперацииИСМП);
