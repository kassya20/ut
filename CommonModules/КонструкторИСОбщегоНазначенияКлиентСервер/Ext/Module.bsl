#Область ПрограммныйИнтерфейс

#Область ЭлементыКонструктораВидовПродукции

// Возвращает вид продукции ключа по указанному имени подсистемы.
// 
// Параметры:
//  ВидПродукции - СправочникСсылка.КлючиВидовПродукцииИС,
//                 СправочникСсылка.ВидыПродукцииИС,
//                 Массив из СправочникСсылка.ВидыПродукцииИС - виды продукции, для которых требуется получить значение.
//  ИмяПодсистемы - Строка - имя подсистемы для которой необходимо получить вид продукции.
// 
// Возвращаемое значение:
//  СправочникСсылка.ВидыПродукцииИС,
//  Массив из СправочникСсылка.ВидыПродукцииИС - вид продукции.
Функция ВидПродукцииПоПодсистеме(ВидПродукции, ИмяПодсистемы) Экспорт
	
	ТипКлючиВидовПродукцииИС = Тип("СправочникСсылка.КлючиВидовПродукцииИС");
	Если ТипЗнч(ВидПродукции) = ТипКлючиВидовПродукцииИС Тогда
		Возврат ВидПродукцииКлючаПоПодсистеме(ВидПродукции, ИмяПодсистемы);
	ИначеЕсли ТипЗнч(ВидПродукции) = Тип("Массив") Тогда
		ВозвращаемоеЗначение = Новый Массив;
		ВидыПродукцииПоКлючам = Новый Соответствие;
		Для Каждого ЭлементМассива Из ВидПродукции Цикл
			Если ТипЗнч(ЭлементМассива) = ТипКлючиВидовПродукцииИС Тогда
				ВидПродукцииПоКлючу = ВидыПродукцииПоКлючам[ЭлементМассива];
				Если ВидПродукцииПоКлючу = Неопределено Тогда
					ВидПродукцииПоКлючу = ВидПродукцииКлючаПоПодсистеме(ЭлементМассива, ИмяПодсистемы);
					ВидыПродукцииПоКлючам[ЭлементМассива] = ВидПродукцииПоКлючу;
				КонецЕсли;
				ВозвращаемоеЗначение.Добавить(ВидПродукцииПоКлючу);
			Иначе
				ВозвращаемоеЗначение.Добавить(ЭлементМассива);
			КонецЕсли;
		КонецЦикла;
		ОбщегоНазначенияКлиентСервер.СвернутьМассив(ВозвращаемоеЗначение);
		Возврат ВозвращаемоеЗначение;
	Иначе
		Возврат ВидПродукции;
	КонецЕсли;
	
КонецФункции

// Возвращает признак принадлежности переданного в параметре вида продукции к продукции ИС МП.
//
// Параметры:
//  ВидПродукции - СправочникСсылка.КлючиВидовПродукцииИС,
//                 СправочникСсылка.ВидыПродукцииИС,
//                 Массив из СправочникСсылка.ВидыПродукцииИС - виды продукции, для которых требуется получить значение.
//  ВключатьТабачнуюПродукцию - Булево - Признак включения табачной продукции.
// Возвращаемое значение:
//  Булево - Принадлежность к виду продукции ИС МП.
//
Функция ЭтоПродукцияИСМП(ВидПродукции, ВключатьТабачнуюПродукцию = Ложь) Экспорт
	
	ВидыПродукцииИСМП = ВидыПродукцииИСМП(ВключатьТабачнуюПродукцию);
	
	ВидыПродукцииПоПодсистеме = ВидПродукцииПоПодсистеме(ВидПродукции, "ИСМП");
	
	Если ТипЗнч(ВидыПродукцииПоПодсистеме) = Тип("Массив") Тогда
		Для Каждого ВидПродукцииПоПодсистеме Из ВидыПродукцииПоПодсистеме Цикл
			Если ВидыПродукцииИСМП.Найти(ВидПродукцииПоПодсистеме) <> Неопределено Тогда
				Возврат Истина;
			КонецЕсли;
		КонецЦикла;
	Иначе
		Возврат ВидыПродукцииИСМП.Найти(ВидыПродукцииПоПодсистеме) <> Неопределено;
	КонецЕсли;
	
	Возврат Ложь;
	
КонецФункции

