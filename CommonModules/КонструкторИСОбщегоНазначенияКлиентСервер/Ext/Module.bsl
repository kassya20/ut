// Возвращает связанные с ЕГАИС виды продукции ГИС МТ.
//
// Возвращаемое значение:
//  Массив Из СправочникСсылка.ВидыПродукцииИС - Массив связанных видов продукции ГИС МТ.
Функция ВидыПродукцииИСМПЕГАИС() Экспорт
	
	Результат = Новый Массив;
	
	ВидыПродукцииИСМП = ВидыПродукцииИСМП();
	
	Для Каждого ВидПродукции Из ЗависимыеВидыПродукцииИС(
		ПредопределенноеЗначение(
			"Справочник.ЭлементыКонструктораВидовПродукцииИС.ВидыПродукцииЕГАИС")) Цикл
		
		Если ВидыПродукцииИСМП.Найти(ВидПродукции) <> Неопределено Тогда
			Результат.Добавить(ВидПродукции);
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

// Проверяет, является ли вид продукции ГИС МТ связанным с ЕГАИС
//
// Параметры:
//  ВидПродукции - СправочникСсылка.ВидыПродукцииИС - Вид продукции
//               - Массив Из СправочникСсылка.ВидыПродукцииИС - Массив видов продукции
//               - СправочникСсылка.КлючиВидовПродукцииИС - Ключ видов продукции
// Возвращаемое значение:
//  Булево - Истина, если вид продукции ГИС МТ связан с подконтрольной ЕГАИС продукцией.
Функция ЭтоВидПродукцииИСМПЕГАИС(Знач ВидПродукции) Экспорт
	
	ВидыПродукцииПодконтрольныеЕГАИС = ВидыПродукцииИСМПЕГАИС();
	
	Если ТипЗнч(ВидПродукции) = Тип("Массив") Тогда
		Для Каждого ВидПродукцииИзМассива Из ВидПродукции Цикл
			Если ВидыПродукцииПодконтрольныеЕГАИС.Найти(ВидПродукцииИзМассива) <> Неопределено Тогда
				Возврат Истина;
			КонецЕсли;
		КонецЦикла;
		Возврат Ложь;
	ИначеЕсли ТипЗнч(ВидПродукции) = Тип("СправочникСсылка.КлючиВидовПродукцииИС") Тогда
		ВидПродукции = ВидПродукцииКлючаПоПодсистеме(ВидПродукции, "ГИСМТ");
	КонецЕсли;
	
	Возврат ВидыПродукцииПодконтрольныеЕГАИС.Найти(ВидПродукции) <> Неопределено;
	
КонецФункции

// Это сырье ГИС МТ.
