// Получает суффикс вида продукции ключа справочника КлючиВидовПродукцииИС по элементу конструктора.
// 
// Параметры:
//   ЭлементКонструктора - СправочникСсылка.ЭлементыКонструктораВидовПродукцииИС - элемент конструктора.
//
// Возвращаемое значение:
//   Строка, Неопределено - Суффикс вида продукции.
Функция СуффиксВидаПродукцииПоЭлементуКонструктора(ЭлементКонструктора) Экспорт
	
	Если ЭлементКонструктора = ПредопределенноеЗначение(
		"Справочник.ЭлементыКонструктораВидовПродукцииИС.ВидыПродукцииГИСМТ") Тогда
		Возврат "ГИСМТ";
	ИначеЕсли ЭлементКонструктора = ПредопределенноеЗначение(
		"Справочник.ЭлементыКонструктораВидовПродукцииИС.ВидыПродукцииЕГАИС") Тогда
		Возврат "ЕГАИС";
	ИначеЕсли ЭлементКонструктора = ПредопределенноеЗначение(
		"Справочник.ЭлементыКонструктораВидовПродукцииИС.ВидыПродукцииВЕТИС") Тогда
		Возврат "ВЕТИС";
	ИначеЕсли ЭлементКонструктора = ПредопределенноеЗначение(
		"Справочник.ЭлементыКонструктораВидовПродукцииИС.ВидыПродукцииСАТУРН") Тогда
		Возврат "САТУРН";
	ИначеЕсли ЭлементКонструктора = ПредопределенноеЗначение(
		"Справочник.ЭлементыКонструктораВидовПродукцииИС.ВидыПродукцииЗЕРНО") Тогда
		Возврат "ЗЕРНО";
	КонецЕсли;	
	
	Возврат Неопределено;
	
КонецФункции

// Получает имя поля ключа видов продукции по имени подсистемы.
// 
// Параметры:
//   ИмяПодсистемы - Строка - имя подсистемы.
//
// Возвращаемое значение:
//   Массив из Строка - Имя поля вида продукции.
Функция ИмяПоляКлючаВидовПродукции(знач ИмяПодсистемы) Экспорт
	
	ИмяПодсистемы = ВРег(ИмяПодсистемы);
	
	Если ИмяПодсистемы = "ИСМП" Тогда
		ИмяПодсистемы = "ГИСМТ";
	КонецЕсли;
	
	Возврат "ВидПродукции"+ИмяПодсистемы;
	
КонецФункции

// Получает имена полей видов продукции из которых состоит ключ.
//
// Возвращаемое значение:
//   Массив из Строка - Имя поля вида продукции.
Функция ИменаПолейКлючаВидовПродукции() Экспорт
	
	Результат = Новый Массив;
	
	Суффиксы = СуффиксыВидовПродукции();
	Для Каждого Суффикс Из Суффиксы Цикл
		Результат.Добавить(ИмяПоляКлючаВидовПродукции(Суффикс));
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

// Возвращает виды продукции по ключу и указанным именам подсистем.
// 
// Параметры:
//  КлючВидовПродукции - СправочникСсылка.КлючиВидовПродукцииИС - ключ, для которого требуется получить виды продукции.
//  ИменаПодсистем - Неопределено - получить виды продукции всех посистем,
//                   Строка - имена подсистем, разделенных "," для которых необходимо получить виды продукции,
//                   Массив из Строка - имена подсистем для которых необходимо получить виды продукции.
// 
// Возвращаемое значение:
//  Массив из СправочникСсылка.ВидыПродукцииИС - виды продукции.
Функция ВидыПродукцииКлюча(КлючВидовПродукции, ИменаПодсистем = Неопределено) Экспорт
	
	Результат = Новый Массив;
	
	ДанныеКлюча = ДанныеКлючаВидовПродукции(КлючВидовПродукции);
	
	Если ДанныеКлюча <> Неопределено Тогда
		
		Если ИменаПодсистем = Неопределено Тогда
			ИменаПолейКлюча = Неопределено;
		ИначеЕсли ТипЗнч(ИменаПодсистем) = Тип("Строка") Тогда
			ИменаПолейКлюча = СтрРазделить(ИменаПодсистем, ",");
		Иначе
			ИменаПолейКлюча = ИменаПодсистем;
		КонецЕсли;
		
		Если ИменаПолейКлюча <> Неопределено Тогда
			Для Индекс = 0 По ИменаПолейКлюча.ВГраница() Цикл
				ИменаПолейКлюча[Индекс] = ИмяПоляКлючаВидовПродукции(СокрЛП(ИменаПолейКлюча[Индекс]));
			КонецЦикла;
		КонецЕсли;
		
		БезОтбора = ИменаПолейКлюча = Неопределено Или ИменаПолейКлюча.Количество() = 0;
		
		Для Каждого КлючИЗначение Из ДанныеКлюча Цикл
			Если ЗначениеЗаполнено(КлючИЗначение.Значение)
				И (БезОтбора
					Или ИменаПолейКлюча.Найти(КлючИЗначение.Ключ) <> Неопределено) Тогда
				Результат.Добавить(КлючИЗначение.Значение);
			КонецЕсли;
		КонецЦикла;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Возвращает вид продукции ключа по указанному имени подсистемы.
// 
// Параметры:
//  КлючВидовПродукции - СправочникСсылка.КлючиВидовПродукцииИС - ключ, для которого требуется получить вид продукции.
//  ИмяПодсистемы - Строка - имя подсистемы для которой необходимо получить вид продукции.
// 
// Возвращаемое значение:
//  СправочникСсылка.ВидыПродукцииИС - вид продукции.
Функция ВидПродукцииКлючаПоПодсистеме(КлючВидовПродукции, ИмяПодсистемы) Экспорт
	
	ВидыПродукцииКлюча = ВидыПродукцииКлюча(КлючВидовПродукции, ИмяПодсистемы);
	Если ВидыПродукцииКлюча.Количество() > 0 Тогда
		Возврат ВидыПродукцииКлюча[0];
	КонецЕсли;
	
	Возврат ПредопределенноеЗначение("Справочник.ВидыПродукцииИС.ПустаяСсылка");
	
КонецФункции

#КонецОбласти

// Возвращает признак того, что элемент конструктора по виду продукции содержит переданное значение.
// 
// Параметры:
//  ЭлементКонструктора - СправочникСсылка.ЭлементыКонструктораВидовПродукцииИС - элемент конструктора, для которого требуется получить данные.
//  ВидПродукции - СправочникСсылка.КлючиВидовПродукцииИС,
//                 СправочникСсылка.ВидыПродукцииИС,
//                 Массив из СправочникСсылка.ВидыПродукцииИС - виды продукции, для которых требуется получить значение.
//  Значение - ОпределяемыйТип.ЗначениеЭлементаКонструктораВидовПродукцииИС,
//             Массив из ОпределяемыйТип.ЗначениеЭлементаКонструктораВидовПродукцииИС,
//             Неопределено - значение, для которого требуется получить атрибуты.
//
// Возвращаемое значение:
//  Булево - Истина - если хотя одному из ВидПродукции в ЭлементКонструктора установлено переданное Значение.
//           Если значение не указано, тогда Истина - если хотя бы один из ВидПродукции включен в элемент конструктора.
//
Функция ЭлементКонструктораСодержитЗначение(ЭлементКонструктора, ВидПродукции, Значение = Неопределено) Экспорт
	
	ЗначенияЭлементаКонструктора = ЗначенияЭлементаКонструктораПоВидуПродукции(ЭлементКонструктора, ВидПродукции);
	
	Если ТипЗнч(ЗначенияЭлементаКонструктора) = Тип("Булево") Тогда
		Возврат ЗначенияЭлементаКонструктора;
	ИначеЕсли Значение = Неопределено Тогда
		Возврат ЗначенияЭлементаКонструктора.Количество() > 0;
	ИначеЕсли ТипЗнч(Значение) = Тип("Массив") Тогда
		Если Значение.Количество() = 0 Тогда
			Возврат ЗначенияЭлементаКонструктора.Количество() > 0;
		Иначе
			Для Каждого ЭлементМассива Из Значение Цикл
				Если ЗначенияЭлементаКонструктора.Найти(ЭлементМассива) <> Неопределено Тогда
					Возврат Истина;
				КонецЕсли;
			КонецЦикла;
			Возврат Ложь;
		КонецЕсли;
	Иначе
		Возврат ЗначенияЭлементаКонструктора.Найти(Значение) <> Неопределено;
	КонецЕсли;
	
КонецФункции

// Возвращает значения по элементу конструктора и виду продукции.
// 
// Параметры:
//  ЭлементКонструктора - СправочникСсылка.ЭлементыКонструктораВидовПродукцииИС - элемент конструктора, для которого требуется получить данные.
//  ВидПродукции - СправочникСсылка.КлючиВидовПродукцииИС,
//                 СправочникСсылка.ВидыПродукцииИС,
//                 Массив из СправочникСсылка.ВидыПродукцииИС - виды продукции, для которых требуется получить значение.
//
// Возвращаемое значение:
//  Булево - если не Параметризуется, Истина - если хотя бы один из ВидПродукции включен в элемент конструктора,
//  Массив из ОпределяемыйТип.ЗначениеЭлементаКонструктораВидовПродукцииИС - значение.
Функция ЗначенияЭлементаКонструктораПоВидуПродукции(ЭлементКонструктора, ВидПродукции) Экспорт
	
	КешРезультатовФункции = Неопределено;
	Результат = ОбщегоНазначенияИСКлиентСервер.ПрочитатьКеш(
		ОбщегоНазначенияИСКлиентСерверПовтИсп.ГлобальныйКеш(), ЭлементКонструктора, ВидПродукции, КешРезультатовФункции);
	Если Результат <> Неопределено Тогда
		Возврат Результат;
	КонецЕсли;
	
	Если ТипЗнч(ВидПродукции) = Тип("Массив")
		Или ТипЗнч(ВидПродукции) = Тип("ФиксированныйМассив") Тогда
		ВидыПродукции = ВидПродукции;
	ИначеЕсли ТипЗнч(ВидПродукции) = Тип("СправочникСсылка.КлючиВидовПродукцииИС") Тогда
		ВидыПродукции = ВидыПродукцииКлюча(ВидПродукции);
	Иначе
		ВидыПродукции = Новый Массив;
		ВидыПродукции.Добавить(ВидПродукции);
	КонецЕсли;
	
	ДанныеЭлемента = ДанныеЭлементаКонструктора(ЭлементКонструктора);
	
	Если Не ДанныеЭлемента.Параметризуется Тогда
		
		Результат = Ложь;
		
		Для Каждого ТекущийВидПродукции Из ВидыПродукции Цикл
			Значения = ДанныеЭлемента.ВидыПродукции[ТекущийВидПродукции];
			Если Значения <> Неопределено Тогда
				Результат = Истина;
				Прервать;
			КонецЕсли;
		КонецЦикла;
		
	Иначе
		
		Результат = Новый Массив;
		
		Для Каждого ТекущийВидПродукции Из ВидыПродукции Цикл
			Значения = ДанныеЭлемента.ВидыПродукции[ТекущийВидПродукции];
			Если Значения <> Неопределено Тогда
				Для Каждого КлючИЗначение Из Значения Цикл
					Если Результат.Найти(КлючИЗначение.Ключ) = Неопределено Тогда
						Результат.Добавить(КлючИЗначение.Ключ);
					КонецЕсли;
				КонецЦикла;
			КонецЕсли;
		КонецЦикла;
		
	КонецЕсли;
	
	Если КешРезультатовФункции <> Неопределено Тогда
		КешРезультатовФункции.Вставить(ВидПродукции, Результат);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Возвращает виды продукции по элементу конструктора.
// 
// Параметры:
//  ЭлементКонструктора - СправочникСсылка.ЭлементыКонструктораВидовПродукцииИС - элемент конструктора, для которого требуется получить виды продукции.
// 
// Возвращаемое значение:
//  Массив из СправочникСсылка.ВидыПродукцииИС - виды продукции по элементу конструктора.
Функция ВидыПродукцииПоЭлементуКонструктора(ЭлементКонструктора) Экспорт
	
	КешРезультатовФункции = Неопределено;
	Результат = ОбщегоНазначенияИСКлиентСервер.ПрочитатьКеш(
		ОбщегоНазначенияИСКлиентСерверПовтИсп.ГлобальныйКеш(), ЭлементКонструктора, "", КешРезультатовФункции);
	Если Результат <> Неопределено Тогда
		Возврат Результат;
	КонецЕсли;
	
	ДанныеЭлемента = ДанныеЭлементаКонструктора(ЭлементКонструктора);
	
	Результат = Новый Массив;
	Для Каждого КлючИЗначение Из ДанныеЭлемента.ВидыПродукции Цикл
		Результат.Добавить(КлючИЗначение.Ключ);
	КонецЦикла;
	
	Если КешРезультатовФункции <> Неопределено Тогда
		КешРезультатовФункции.Вставить("", Результат);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Возвращает виды продукции по значению и элементу конструктора.
// 
// Параметры:
//  ЭлементКонструктора - СправочникСсылка.ЭлементыКонструктораВидовПродукцииИС - элемент конструктора, для которого требуется получить данные.
//  Значение - ОпределяемыйТип.ЗначениеЭлементаКонструктораВидовПродукцииИС - значение, для которого требуется получить виды продукции.
// 
// Возвращаемое значение:
//  Массив из СправочникСсылка.ВидыПродукцииИС - виды продукции, для которых задано указанное значение и элемент конструктора.
Функция ВидыПродукцииПоЗначениюЭлементаКонструктора(ЭлементКонструктора, Значение) Экспорт
	
	ВидыПродукцииПоЗначениям = ВидыПродукцииПоЗначениямЭлементаКонструктора(ЭлементКонструктора);
	
	Результат = ВидыПродукцииПоЗначениям[Значение];
	Если Результат = Неопределено Тогда
		Результат = Новый Массив;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Возвращает значение указанного атрибута элемента конструктора.
// 
// Параметры:
//  ИмяАтрибута - Строка - имя атрибута, значение которого требуется получить.
//  ЭлементКонструктора - СправочникСсылка.ЭлементыКонструктораВидовПродукцииИС - элемент конструктора, для которого требуется получить данные.
//  ВидПродукции - СправочникСсылка.КлючиВидовПродукцииИС,
//                 СправочникСсылка.ВидыПродукцииИС,
//                 Массив из СправочникСсылка.ВидыПродукцииИС - виды продукции, для которых требуется получить значение.
//  Значение - ОпределяемыйТип.ЗначениеЭлементаКонструктораВидовПродукцииИС - значение, для которого требуется получить атрибуты.
//             Не требуется, если элемент конструктора не Параметризуется.
//  ВернутьПервоеЗначение - Булево - если Истина, тогда будет возвращено первое доступное значение,
//                                   если Ложь, тогда вернется массив всех доступных значений.
// 
// Возвращаемое значение:
//  Массив из Произвольный,
//  Произвольный - значение атрибута - зависит от входящего параметра ВернутьПервоеЗначение.
//
Функция ЗначениеАтрибутаЭлементаКонструктора(ИмяАтрибута, ЭлементКонструктора, ВидПродукции,
	Значение = Неопределено, ВернутьПервоеЗначение = Истина) Экспорт
	
	Атрибуты = АтрибутыЭлементаКонструктора(ЭлементКонструктора, ВидПродукции, Значение);
	
	Результат = Неопределено;
	Атрибуты.Свойство(ИмяАтрибута, Результат);
	
	Если ВернутьПервоеЗначение Тогда
		Если Результат <> Неопределено Тогда
			Результат = Результат[0];
		КонецЕсли;
	ИначеЕсли Результат = Неопределено Тогда
		Результат = Новый Массив;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Возвращает виды продукции по значению указанного атрибута элемента конструктора.
// 
// Параметры:
//  ИмяАтрибута - Строка - имя атрибута.
//  ЗначениеАтрибута - Произвольный - значение атрибута.
//  ЭлементКонструктора - СправочникСсылка.ЭлементыКонструктораВидовПродукцииИС - элемент конструктора, для которого требуется получить данные.
//  Значение - ОпределяемыйТип.ЗначениеЭлементаКонструктораВидовПродукцииИС - значение, для которого требуется получить атрибуты.
//             Не требуется, если элемент конструктора не Параметризуется.
// 
// Возвращаемое значение:
//  Массив из СправочникСсылка.ВидыПродукцииИС - виды продукции.
//
Функция ВидыПродукцииПоЗначениюАтрибута(ИмяАтрибута, ЗначениеАтрибута, ЭлементКонструктора, Значение = Неопределено) Экспорт
	
	Результат = Новый Массив;
	
	ДанныеЭлемента = ДанныеЭлементаКонструктора(ЭлементКонструктора);
	
	Если ДанныеЭлемента.Параметризуется Тогда
		Ключ = Значение;
	Иначе
		Ключ = КлючАтрибутовВидаПродукции();
	КонецЕсли;
	
	Для Каждого КлючИЗначение Из ДанныеЭлемента.ВидыПродукции Цикл
		Атрибуты = КлючИЗначение.Значение[Ключ];
		Если Атрибуты <> Неопределено Тогда
			Если Атрибуты.Свойство(ИмяАтрибута)
				И Атрибуты[ИмяАтрибута] = ЗначениеАтрибута Тогда
				Результат.Добавить(КлючИЗначение.Ключ);
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

// Поддерживается частичное выбытие
//
// Параметры:
//  ВидПродукцииТоварнаяГруппа - СправочникСсылка.ВидыПродукцииИС - Вид продукции, для которого определяется использование товарной группы.
//                             - Массив из СправочникСсылка.ВидыПродукцииИС - Виды продукции,
//                             - СправочникСсылка.ТоварныеГруппыГИСМТ - Товарная группа.
//  Операция - ПеречислениеСсылка.ВидыОперацийИСМП - Вид операции
//           - ПеречислениеСсылка.ВидыДокументовЕГАИС
//           - Неопределено
// Возвращаемое значение:
//  Булево - Истина, если частичное выбытие поддерживается в товарной группе.
Функция ПоддерживаетсяЧастичноеВыбытие(ВидПродукцииТоварнаяГруппа, Операция = Неопределено) Экспорт
	
	Возврат ЭлементКонструктораСодержитЗначение(
		ПредопределенноеЗначение(
			"Справочник.ЭлементыКонструктораВидовПродукцииИС.ЧастичноеВыбытие"),
			КонструкторИСМПОбщегоНазначенияКлиентСервер.ВидыПродукции(ВидПродукцииТоварнаяГруппа),
			Операция);
	
КонецФункции

#КонецОбласти

#КонецОбласти

#Область СлужебныйПрограммныйИнтерфейс

#Область КонструкторВидовПродукции

// Возвращает данные ключа видов продукции.
// 
// Параметры:
//  КлючВидовПродукции - СправочникСсылка.КлючиВидовПродукцииИС - ключ, для которого требуется получить данные.
// 
// Возвращаемое значение:
//  Структура из КлючИЗначение:
//    * Ключ     - Строка - имя поля ключа.
//    * Значение - СправочникСсылка.ВидыПродукцииИС- значение поля ключа.
//  Неопределено - если данные ключа не найдены.
Функция ДанныеКлючаВидовПродукции(КлючВидовПродукции) Экспорт
	
	КлючиВидовПродукции = ОбщегоНазначенияИСКлиентСерверПовтИсп.КлючиВидовПродукции();
	
	Возврат КлючиВидовПродукции[КлючВидовПродукции];
	
КонецФункции

// Возвращает данные по элементу конструктора.
// 
// Параметры:
//  ЭлементКонструктора - СправочникСсылка.ЭлементыКонструктораВидовПродукцииИС - элемент конструктора, для которого требуется получить данные.
// 
// Возвращаемое значение:
//  Структура из КлючИЗначение:
//   см. Справочники.ЭлементыКонструктораВидовПродукцииИС.ЭлементыКонструктора - возвращается элемент конструктора.
Функция ДанныеЭлементаКонструктора(ЭлементКонструктора) Экспорт
	
	ЭлементыКонструктора = ОбщегоНазначенияИСКлиентСерверПовтИсп.ЭлементыКонструктора();
	
	ДанныеЭлемента = ЭлементыКонструктора[ЭлементКонструктора];
	Если ДанныеЭлемента = Неопределено Тогда
		ДанныеЭлемента = Новый Структура;
		ДанныеЭлемента.Вставить("ВидыПродукции", Новый Соответствие);
		ДанныеЭлемента.Вставить("Параметризуется", Ложь);
	КонецЕсли;
	
	Возврат ДанныеЭлемента;
	
КонецФункции

// Возвращает виды продукции по элементу конструктора, собранные в соответствие, где ключем является значение,
//  значением массив видов продукции.
// 
// Параметры:
//  ЭлементКонструктора - СправочникСсылка.ЭлементыКонструктораВидовПродукцииИС -
//                         элемент конструктора, для которого требуется получить виды продукции по значению.
// 
// Возвращаемое значение:
//  Соответствие из КлючИЗначение:
//    * Ключ     - ОпределяемыйТип.ЗначениеЭлементаКонструктораВидовПродукцииИС - значение.
//    * Значение - Массив из СправочникСсылка.ВидыПродукцииИС - вид продукции, для которого задано значение.
Функция ВидыПродукцииПоЗначениямЭлементаКонструктора(ЭлементКонструктора) Экспорт
	
	ДанныеЭлемента = ДанныеЭлементаКонструктора(ЭлементКонструктора);
	
	Результат = Новый Соответствие;
	
	Если Не ДанныеЭлемента.Параметризуется Тогда
		Возврат Результат;
	КонецЕсли;
	
	Для Каждого КлючИЗначение Из ДанныеЭлемента.ВидыПродукции Цикл
		Для Каждого Значение Из КлючИЗначение.Значение Цикл
			Если Результат[Значение.Ключ] = Неопределено Тогда
				Результат.Вставить(Значение.Ключ, Новый Массив);
			КонецЕсли;
			Если Результат[Значение.Ключ].Найти(КлючИЗначение.Ключ) = Неопределено Тогда
				Результат[Значение.Ключ].Добавить(КлючИЗначение.Ключ);
			КонецЕсли;
		КонецЦикла;
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

// Возвращает атрибуты элемента конструктора.
// 
// Параметры:
//  ЭлементКонструктора - СправочникСсылка.ЭлементыКонструктораВидовПродукцииИС - элемент конструктора, для которого требуется получить данные.
//  ВидПродукции - СправочникСсылка.КлючиВидовПродукцииИС,
//                 СправочникСсылка.ВидыПродукцииИС,
//                 Массив из СправочникСсылка.ВидыПродукцииИС - виды продукции, для которых требуется получить значение.
//  Значение - ОпределяемыйТип.ЗначениеЭлементаКонструктораВидовПродукцииИС - значение, для которого требуется получить атрибуты.
//             Не требуется, если элемент конструктора не Параметризуется.
// 
// Возвращаемое значение:
//  Структура - из КлючИЗначение - имена и значения атрибутов:
//   * Ключ     - Строка - имя атрибута.
//   * Значение - Массив из Произвольный - значения атрибута.
//
Функция АтрибутыЭлементаКонструктора(ЭлементКонструктора, ВидПродукции, Значение = Неопределено) Экспорт
	
	Если ТипЗнч(ВидПродукции) = Тип("Массив") Тогда
		ВидыПродукции = ВидПродукции;
	ИначеЕсли ТипЗнч(ВидПродукции) = Тип("СправочникСсылка.КлючиВидовПродукцииИС") Тогда
		ВидыПродукции = ВидыПродукцииКлюча(ВидПродукции);
	Иначе
		ВидыПродукции = Новый Массив;
		ВидыПродукции.Добавить(ВидПродукции);
	КонецЕсли;
	
	Результат = Новый Структура;
	
	ДанныеЭлемента = ДанныеЭлементаКонструктора(ЭлементКонструктора);
	
	Если ДанныеЭлемента.Параметризуется Тогда
		Ключ = Значение;
	Иначе
		Ключ = КлючАтрибутовВидаПродукции();
	КонецЕсли;
	
	Для Каждого ТекущийВидПродукции Из ВидыПродукции Цикл
		Значения = ДанныеЭлемента.ВидыПродукции[ТекущийВидПродукции];
		Если Значения <> Неопределено Тогда
			Атрибуты = Значения[Ключ];
			Если Атрибуты <> Неопределено Тогда
				Для Каждого Атрибут Из Атрибуты Цикл
					Если Не Результат.Свойство(Атрибут.Ключ) Тогда
						Результат.Вставить(Атрибут.Ключ, Новый Массив);
					КонецЕсли;
					Если Результат[Атрибут.Ключ].Найти(Атрибут.Значение) = Неопределено Тогда
						Результат[Атрибут.Ключ].Добавить(Атрибут.Значение);
					КонецЕсли;
				КонецЦикла;
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

// Возвращает ключ атрибутов для вида продукции, если элемент конструктора не параметризуется
//
// Возвращаемое значение:
//   Строка - ключ атрибутов.
//
Функция КлючАтрибутовВидаПродукции() Экспорт
	
	Возврат "Атрибуты";
	
КонецФункции

// Возвращает значения элемента конструктора.
// 
// Параметры:
//  ЭлементКонструктора - СправочникСсылка.ЭлементыКонструктораВидовПродукцииИС - элемент конструктора, для которого требуется получить данные.
//  ВидПродукции - СправочникСсылка.КлючиВидовПродукцииИС,
//                 СправочникСсылка.ВидыПродукцииИС,
//                 Массив из СправочникСсылка.ВидыПродукцииИС - виды продукции, для которых требуется получить значение.
//  Значение - ОпределяемыйТип.ЗначениеЭлементаКонструктораВидовПродукцииИС - значение, для которого требуется получить атрибуты.
//             Не требуется, если элемент конструктора не Параметризуется.
// 
// Возвращаемое значение:
//  см. ОбщегоНазначенияИСВызовСервера.ЗначенияЭлементаКонструктора.
//
Функция ЗначенияЭлементаКонструктора(ЭлементКонструктора, ВидПродукции, Значение = Неопределено) Экспорт
	
	Если ТипЗнч(ВидПродукции) = Тип("Массив")
		Или ТипЗнч(ВидПродукции) = Тип("ФиксированныйМассив") Тогда
		ВидыПродукции = ВидПродукции;
	ИначеЕсли ТипЗнч(ВидПродукции) = Тип("СправочникСсылка.КлючиВидовПродукцииИС") Тогда
		ВидыПродукции = ВидыПродукцииКлюча(ВидПродукции);
	Иначе
		ВидыПродукции = Новый Массив;
		ВидыПродукции.Добавить(ВидПродукции);
	КонецЕсли;
	
	Возврат ОбщегоНазначенияИСВызовСервера.ЗначенияЭлементаКонструктора(ЭлементКонструктора, ВидыПродукции, Значение);
	
КонецФункции

#Область ЭлементыКонструктораВидовПродукции

// Представление вида упаковки по виду продукции.
// 
// Параметры:
//  ВидПродукции - СправочникСсылка.КлючиВидовПродукцииИС - ключ вида продукции,
//                 СправочникСсылка.ВидыПродукцииИС - вид продукции,
//                 Массив из СправочникСсылка.ВидыПродукцииИС - виды продукции,
//  ВидУпаковки - ПеречислениеСсылка.ВидыУпаковокИС - вид упаковки
//  Падеж - Строка - Падеж для склонения строки
//  ГрамматическоеЧисло - Строка - Единственное, Множественное
//  ЭтоОписаниеКоличества - Булево - признак получения представления для описания количества (сокращенно, нижний регистр)
// Возвращаемое значение:
//  Строка - представление вида упаковки
Функция ПредставлениеВидаУпаковкиПоВидуПродукции(ВидПродукции, ВидУпаковки, Падеж, ГрамматическоеЧисло, ЭтоОписаниеКоличества) Экспорт
	
	Результат   = "";
	ИмяАтрибута = "";
	
	АтрибутыВидовУпаковок = АтрибутыВидовУпаковок();
	Для Каждого КлючИЗначение Из АтрибутыВидовУпаковок Цикл
		
		ПараметрыАтрибута = КлючИЗначение.Значение;
		Если ПараметрыАтрибута.Падеж = Падеж
			И ПараметрыАтрибута.ГрамматическоеЧисло = ГрамматическоеЧисло
			И ПараметрыАтрибута.ЭтоОписаниеКоличества = ЭтоОписаниеКоличества Тогда
			
			ИмяАтрибута = КлючИЗначение.Ключ;
			
		КонецЕсли;
		
	КонецЦикла;
	
	Если Не ЗначениеЗаполнено(ИмяАтрибута)
		И ГрамматическоеЧисло <> "Единственное" Тогда
		ВызватьИсключение СтрШаблон(
			НСтр("ru = 'Внутренняя ошибка. Не описан атрибут описания количества для %1 %2'"),
			Падеж,
			ГрамматическоеЧисло);
	КонецЕсли;
	
	Если ТипЗнч(ВидПродукции) = Тип("СправочникСсылка.КлючиВидовПродукцииИС") Тогда
		ВидыПродукции = ВидыПродукцииКлюча(ВидПродукции);
	ИначеЕсли ТипЗнч(ВидПродукции) = Тип("Массив") Тогда
		ВидыПродукции = ВидПродукции;
	Иначе
		ВидыПродукции = Новый Массив;
		ВидыПродукции.Добавить(ВидПродукции);
	КонецЕсли;
	
	Если ВидыПродукции.Количество() = 0 Тогда
		Возврат Результат;
	КонецЕсли;
	
	ПредставленияВидовУпаковок = ОбщегоНазначенияИСКлиентСерверПовтИсп.ПредставленияВидовУпаковокПоВидамПродукции();
	
	ДанныеПоВидуПродукции = ПредставленияВидовУпаковок[ВидыПродукции[0]];
	Если ДанныеПоВидуПродукции = Неопределено Тогда
		Возврат Результат;
	КонецЕсли;
	ДанныеПоВидуУпаковки = ДанныеПоВидуПродукции[ВидУпаковки];
	Если ДанныеПоВидуУпаковки = Неопределено Тогда
		Возврат Результат;
	КонецЕсли;
	
	ЗначенияПути = Новый Массив;
	ЗначенияПути.Добавить(ВидыПродукции[0]);
	ЗначенияПути.Добавить(ВидУпаковки);
	ЗначенияПути.Добавить(Падеж);
	ЗначенияПути.Добавить(ГрамматическоеЧисло);
	ЗначенияПути.Добавить(ЭтоОписаниеКоличества);
	
	Результат = ОбщегоНазначенияИСКлиентСервер.ДанныеПоПутиВСоответствии(
		ПредставленияВидовУпаковок, ЗначенияПути, Результат);
	
	Если Не ЗначениеЗаполнено(Результат) Тогда
		Результат = ПредставлениеВидаУпаковкиПоУмолчанию(
			ВидУпаковки, ГрамматическоеЧисло, ЭтоОписаниеКоличества);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Атрибуты видов упаковок.
// 
// Возвращаемое значение:
//  Структура - Атрибуты видов упаковок:
// * ОписаниеКоличестваИменительныйЕдЧисло - Структура - :
// ** ОписаниеТипа - ОписаниеТипов - 
// ** Падеж - Строка - 
// ** ГрамматическоеЧисло - Строка - 
// ** ЭтоОписаниеКоличества - Булево - 
// * ОписаниеКоличестваИменительныйМнЧисло - Структура - :
// ** ОписаниеТипа - ОписаниеТипов - 
// ** Падеж - Строка - 
// ** ГрамматическоеЧисло - Строка - 
// ** ЭтоОписаниеКоличества - Булево - 
// * ОписаниеКоличестваРодительныйМнЧисло - Структура - :
// ** ОписаниеТипа - ОписаниеТипов - 
// ** Падеж - Строка - 
// ** ГрамматическоеЧисло - Строка - 
// ** ЭтоОписаниеКоличества - Булево - 
// * Представление - Структура - :
// ** ОписаниеТипа - ОписаниеТипов - 
// ** Падеж - Строка - 
// ** ГрамматическоеЧисло - Строка - 
// ** ЭтоОписаниеКоличества - Булево - 
Функция АтрибутыВидовУпаковок() Экспорт
	
	ОписаниеТипаСтрока = Новый ОписаниеТипов("Строка",,,, Новый КвалификаторыСтроки(50));
	
	ВозвращаемоеЗначение = Новый Структура();
	
	ДанныеОписания = Новый Структура;
	ДанныеОписания.Вставить("ОписаниеТипа",          ОписаниеТипаСтрока);
	ДанныеОписания.Вставить("Падеж",                 "Именительный");
	ДанныеОписания.Вставить("ГрамматическоеЧисло",   "Единственное");
	ДанныеОписания.Вставить("ЭтоОписаниеКоличества", Истина);
	ВозвращаемоеЗначение.Вставить("ОписаниеКоличестваИменительныйЕдЧисло", ДанныеОписания);
	
	ДанныеОписания = Новый Структура;
	ДанныеОписания.Вставить("ОписаниеТипа",         ОписаниеТипаСтрока);
	ДанныеОписания.Вставить("Падеж",                "Именительный");
	ДанныеОписания.Вставить("ГрамматическоеЧисло",  "Множественное");
	ДанныеОписания.Вставить("ЭтоОписаниеКоличества", Истина);
	ВозвращаемоеЗначение.Вставить("ОписаниеКоличестваИменительныйМнЧисло", ДанныеОписания);
	
	ДанныеОписания = Новый Структура;
	ДанныеОписания.Вставить("ОписаниеТипа",         ОписаниеТипаСтрока);
	ДанныеОписания.Вставить("Падеж",                "Родительный");
	ДанныеОписания.Вставить("ГрамматическоеЧисло",  "Множественное");
	ДанныеОписания.Вставить("ЭтоОписаниеКоличества", Истина);
	ВозвращаемоеЗначение.Вставить("ОписаниеКоличестваРодительныйМнЧисло", ДанныеОписания);
	
	ДанныеОписания = Новый Структура;
	ДанныеОписания.Вставить("ОписаниеТипа",          ОписаниеТипаСтрока);
	ДанныеОписания.Вставить("Падеж",                 "Именительный");
	ДанныеОписания.Вставить("ГрамматическоеЧисло",   "Единственное");
	ДанныеОписания.Вставить("ЭтоОписаниеКоличества", Ложь);
	ВозвращаемоеЗначение.Вставить("Представление", ДанныеОписания);
	
	Возврат ВозвращаемоеЗначение
	
КонецФункции

// Представление вида упаковки по умолчанию.
// 
// Параметры:
//  ВидУпаковки - ПеречислениеСсылка.ВидыУпаковокИС - Вид упаковки
//  ГрамматическоеЧисло - Строка - Грамматическое число
//  ЭтоОписаниеКоличества - Булево - Это описание количества
// 
// Возвращаемое значение:
//  Строка - Представление вида упаковки по умолчанию
Функция ПредставлениеВидаУпаковкиПоУмолчанию(ВидУпаковки, ГрамматическоеЧисло, ЭтоОписаниеКоличества) Экспорт
	
	ВидУпаковкиГрупповая       = ПредопределенноеЗначение("Перечисление.ВидыУпаковокИС.Групповая");
	ВидУпаковкиНабор           = ПредопределенноеЗначение("Перечисление.ВидыУпаковокИС.Набор");
	ВидУпаковкиПотребительская = ПредопределенноеЗначение("Перечисление.ВидыУпаковокИС.Потребительская");
	ВидУпаковкиЛогистическая   = ПредопределенноеЗначение("Перечисление.ВидыУпаковокИС.Логистическая");
	
	Если ВидУпаковки = ВидУпаковкиГрупповая
		И ГрамматическоеЧисло = "Единственное"
