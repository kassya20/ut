// Описание типов документов, которые исопльзуют шаблоны назначений СБП.
//
// Возвращаемое значение:
//  Соответствие из КлючИЗначение - Ключ - Тип документа, Значение - см. ДобавитьОписаниеТипаДокументаИспользующегоШаблоныНазначенияСБП
//
Функция ТипыДокументовИспользующиеШаблоныНазначенияСБП()
	Описания  = Новый Соответствие();
	
	ДобавитьОписаниеТипаДокументаИспользующегоШаблоныНазначенияСБП(Описания, 
		Тип("ДокументСсылка.ЧекККМ"), Метаданные.Документы.ЧекККМ);
	ДобавитьОписаниеТипаДокументаИспользующегоШаблоныНазначенияСБП(Описания, 
		Тип("ДокументСсылка.РеализацияПодарочныхСертификатов"), Метаданные.Документы.РеализацияПодарочныхСертификатов);
	ДобавитьОписаниеТипаДокументаИспользующегоШаблоныНазначенияСБП(Описания, 
		Тип("ДокументСсылка.ЗаказКлиента"), Метаданные.Документы.ЗаказКлиента);
	ДобавитьОписаниеТипаДокументаИспользующегоШаблоныНазначенияСБП(Описания, 
		Тип("ДокументСсылка.РеализацияТоваровУслуг"), Метаданные.Документы.РеализацияТоваровУслуг);
	ДобавитьОписаниеТипаДокументаИспользующегоШаблоныНазначенияСБП(Описания, 
		Тип("ДокументСсылка.АктВыполненныхРабот"), Метаданные.Документы.АктВыполненныхРабот);
	ДобавитьОписаниеТипаДокументаИспользующегоШаблоныНазначенияСБП(Описания, 
		Тип("ДокументСсылка.РеализацияУслугПрочихАктивов"), Метаданные.Документы.РеализацияУслугПрочихАктивов);
	ДобавитьОписаниеТипаДокументаИспользующегоШаблоныНазначенияСБП(Описания, 
		Тип("ДокументСсылка.ЗаказКлиента"), Метаданные.Документы.ЗаказКлиента);
	ДобавитьОписаниеТипаДокументаИспользующегоШаблоныНазначенияСБП(Описания, 
		Тип("ДокументСсылка.СчетНаОплатуКлиенту"), Метаданные.Документы.СчетНаОплатуКлиенту);

	Возврат Описания;
КонецФункции

// Описание параметров шаблонов назначений СБП по типам документов.
// 
// Параметры:
//  ТипДокумента - Тип - ДокументСсылка
//  
// Возвращаемое значение:
//   Массив из см. ДобавитьОписаниеПараметраШаблонаНазначенияСБП
//
Функция ПараметрыШаблонаНазначенияСБППоТипуДокумента(ТипДокумента)
	
	ПараметрыШаблона = Новый Массив();
	
	Если ТипДокумента = Тип("ДокументСсылка.ЧекККМ") Тогда
		
		ОписаниеПараметра = ДобавитьОписаниеПараметраШаблонаНазначенияСБП(ПараметрыШаблона);
		ОписаниеПараметра.Идентификатор = "[ДатаОплаты]";
		ОписаниеПараметра.Наименование = НСтр("ru = 'Дата оплаты'", ОбщегоНазначения.КодОсновногоЯзыка());
		ОписаниеПараметра.ПутьКДанным = Метаданные.Документы.ЧекККМ.СтандартныеРеквизиты.Дата.Имя;
		ОписаниеПараметра.Формат = "ДФ=dd.MM.yyyy";
		
		ОписаниеПараметра = ДобавитьОписаниеПараметраШаблонаНазначенияСБП(ПараметрыШаблона);
		ОписаниеПараметра.Идентификатор = "[Валюта]";
		ОписаниеПараметра.Наименование = НСтр("ru = 'Валюта'", ОбщегоНазначения.КодОсновногоЯзыка());
		ОписаниеПараметра.ПутьКДанным = Метаданные.Документы.ЧекККМ.Реквизиты.Валюта.Имя;

		ОписаниеПараметра = ДобавитьОписаниеПараметраШаблонаНазначенияСБП(ПараметрыШаблона);
		ОписаниеПараметра.Идентификатор = "[ОрганизацияНаименованиеПолное]";
		ОписаниеПараметра.Наименование = НСтр("ru = 'Полное наименование организации'", ОбщегоНазначения.КодОсновногоЯзыка());
		ОписаниеПараметра.ПутьКДанным = Метаданные.Документы.ЧекККМ.Реквизиты.Организация.Имя + "." +
										Метаданные.Справочники.Организации.Реквизиты.НаименованиеПолное.Имя;

		ОписаниеПараметра = ДобавитьОписаниеПараметраШаблонаНазначенияСБП(ПараметрыШаблона);
		ОписаниеПараметра.Идентификатор = "[ОрганизацияНаименованиеСокращенное]";
		ОписаниеПараметра.Наименование = НСтр("ru = 'Сокращенное наименование организации'", ОбщегоНазначения.КодОсновногоЯзыка());
		ОписаниеПараметра.ПутьКДанным = Метаданные.Документы.ЧекККМ.Реквизиты.Организация.Имя + "." +
										Метаданные.Справочники.Организации.Реквизиты.НаименованиеСокращенное.Имя;

		ОписаниеПараметра = ДобавитьОписаниеПараметраШаблонаНазначенияСБП(ПараметрыШаблона);
		ОписаниеПараметра.Идентификатор = "[Склад]";
		ОписаниеПараметра.Наименование = НСтр("ru = 'Наименование склада'", ОбщегоНазначения.КодОсновногоЯзыка());
		ОписаниеПараметра.ПутьКДанным = Метаданные.Документы.ЧекККМ.Реквизиты.Склад.Имя + "." +
										Метаданные.Справочники.Склады.СтандартныеРеквизиты.Наименование.Имя;

		ОписаниеПараметра = ДобавитьОписаниеПараметраШаблонаНазначенияСБП(ПараметрыШаблона);
		ОписаниеПараметра.Идентификатор = "[СуммаОплаты]";
		ОписаниеПараметра.Наименование = НСтр("ru = 'Сумма оплаты'", ОбщегоНазначения.КодОсновногоЯзыка());
		ОписаниеПараметра.ПутьКДанным = Метаданные.Документы.ЧекККМ.Реквизиты.СуммаДокумента.Имя;
		ОписаниеПараметра.Формат = "Л=ru_RU; ЧДЦ=2; ЧРД=.; ЧН=; ЧГ=0;";
		
	ИначеЕсли ТипДокумента = Тип("ДокументСсылка.РеализацияПодарочныхСертификатов") Тогда

		ОписаниеПараметра = ДобавитьОписаниеПараметраШаблонаНазначенияСБП(ПараметрыШаблона);
		ОписаниеПараметра.Идентификатор = "[ДатаОплаты]";
		ОписаниеПараметра.Наименование = НСтр("ru = 'Дата оплаты'", ОбщегоНазначения.КодОсновногоЯзыка());
		ОписаниеПараметра.ПутьКДанным = Метаданные.Документы.РеализацияПодарочныхСертификатов.СтандартныеРеквизиты.Дата.Имя;
		ОписаниеПараметра.Формат = "ДФ=dd.MM.yyyy";
		
		ОписаниеПараметра = ДобавитьОписаниеПараметраШаблонаНазначенияСБП(ПараметрыШаблона);
		ОписаниеПараметра.Идентификатор = "[Валюта]";
		ОписаниеПараметра.Наименование = НСтр("ru = 'Валюта'", ОбщегоНазначения.КодОсновногоЯзыка());
		ОписаниеПараметра.ПутьКДанным = Метаданные.Документы.РеализацияПодарочныхСертификатов.Реквизиты.Валюта.Имя;

		ОписаниеПараметра = ДобавитьОписаниеПараметраШаблонаНазначенияСБП(ПараметрыШаблона);
		ОписаниеПараметра.Идентификатор = "[ОрганизацияНаименованиеПолное]";
		ОписаниеПараметра.Наименование = НСтр("ru = 'Полное наименование организации'", ОбщегоНазначения.КодОсновногоЯзыка());
