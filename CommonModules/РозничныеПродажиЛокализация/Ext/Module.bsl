		УстановитьПривилегированныйРежим(Ложь);
	КонецЕсли;
	
	Возврат СтруктураДанныхДляПечати;
	
КонецФункции	

// Функция получает данные для формирования печатной формы КМ-3.
// 
// Параметры:
//  ПараметрыПечати	- Структура - Дополнительные настройки печати
//  МассивОбъектов - Массив Из ДокументСсылка - Ссылки на документы
// 
// Возвращаемое значение:
// 	Структура:
//		* РезультатЗапроса - Массив Из РезультатЗапроса - Содержит информацию для заполнения печатной формы
Функция ПолучитьДанныеДляПечатнойФормыКМ3(ПараметрыПечати, МассивОбъектов) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	// МассивОбъектов содержит документы одного вида.	
	МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	ОтветственныеЛицаСервер.СформироватьВременнуюТаблицуОтветственныхЛицДокументов(МассивОбъектов, МенеджерВременныхТаблиц);	
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Док.Ссылка КАК Ссылка,
	|	Док.Номер КАК Номер,
	|	Док.Дата КАК ДатаДокумента,
	|	Док.КассаККМ КАК КассаККМ,
	|	Док.КассаККМ.ТипКассы КАК ТипКассы,
	|	Док.КассаККМ.Представление КАК Покупатель,
	|	Док.Ответственный.ФизическоеЛицо КАК КассирККМ,
	|	Док.Валюта КАК Валюта,
	|	Док.Организация КАК Организация,
	|	ТаблицаОтветственныеЛица.РуководительНаименование КАК Руководитель,
	|	ТаблицаОтветственныеЛица.РуководительДолжность КАК ДолжностьРуководителя,
	|	ТаблицаОтветственныеЛица.ГлавныйБухгалтерНаименование КАК ГлавныйБухгалтер,
	|	Док.Организация.Представление КАК Поставщик,
	|	Док.КассаККМ.СерийныйНомер КАК СерийныйНомерККМ,
	|	Док.КассаККМ.РегистрационныйНомер КАК РегистрационныйНомерККМ,
	|	Док.КассаККМ.Наименование КАК ПредставлениеККМ
	|ИЗ
	|	Документ.ОтчетОРозничныхПродажах КАК Док
	|		ЛЕВОЕ СОЕДИНЕНИЕ ТаблицаОтветственныеЛица КАК ТаблицаОтветственныеЛица
	|		ПО Док.Ссылка = ТаблицаОтветственныеЛица.Ссылка
	|ГДЕ
	|	Док.Ссылка В(&МассивОбъектов)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	Док.Ссылка КАК Ссылка,
	|	Док.Номер КАК Номер,
	|	Док.Дата КАК ДатаДокумента,
	|	Док.КассаККМ КАК КассаККМ,
	|	Док.КассаККМ.ТипКассы КАК ТипКассы,
	|	Док.КассаККМ.Представление КАК Покупатель,
	|	Док.Ответственный.ФизическоеЛицо КАК КассирККМ,
	|	Док.Валюта КАК Валюта,
	|	Док.Организация КАК Организация,
	|	ТаблицаОтветственныеЛица.РуководительНаименование КАК Руководитель,
	|	ТаблицаОтветственныеЛица.РуководительДолжность КАК ДолжностьРуководителя,
	|	ТаблицаОтветственныеЛица.ГлавныйБухгалтерНаименование КАК ГлавныйБухгалтер,
	|	Док.Организация.Представление КАК Поставщик,
	|	Док.КассаККМ.СерийныйНомер КАК СерийныйНомерККМ,
	|	Док.КассаККМ.РегистрационныйНомер КАК РегистрационныйНомерККМ,
	|	Док.КассаККМ.Наименование КАК ПредставлениеККМ
	|ИЗ
	|	Документ.ОтчетОРозничныхВозвратах КАК Док
	|		ЛЕВОЕ СОЕДИНЕНИЕ ТаблицаОтветственныеЛица КАК ТаблицаОтветственныеЛица
	|		ПО Док.Ссылка = ТаблицаОтветственныеЛица.Ссылка
	|ГДЕ
	|	Док.Ссылка В(&МассивОбъектов)	
	|
	|УПОРЯДОЧИТЬ ПО
	|	Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ДокОтчетОРозничныхПродажах.Ссылка КАК Документ,
	|	ФискальныеОперации.НомерЧекаККМ КАК НомерЧека,
	|	ДокЧек.СуммаДокумента КАК СуммаДокумента
	|ИЗ
	|	Документ.ОтчетОРозничныхПродажах КАК ДокОтчетОРозничныхПродажах
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЧекККМВозврат КАК ДокЧек
	|		ПО ДокОтчетОРозничныхПродажах.КассоваяСмена = ДокЧек.КассоваяСмена
	|			И (ДокЧек.Проведен)
	|			И (ДокЧек.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыЧековККМ.Пробит))
	|		
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ФискальныеОперации КАК ФискальныеОперации
	|		ПО ФискальныеОперации.ДокументОснование = ДокЧек.ЧекККМ
	|ГДЕ
	|	ДокОтчетОРозничныхПродажах.Ссылка В(&МассивОбъектов)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ДокОтчетОРозничныхПродажах.Ссылка КАК Документ,
	|	ФискальныеОперации.НомерЧекаККМ КАК НомерЧека,
	|	ДокЧек.СуммаДокумента КАК СуммаДокумента
	|ИЗ
	|	Документ.ОтчетОРозничныхПродажах КАК ДокОтчетОРозничныхПродажах
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ВозвратПодарочныхСертификатов КАК ДокЧек
	|		ПО ДокОтчетОРозничныхПродажах.КассоваяСмена = ДокЧек.КассоваяСмена
	|			И (ДокЧек.Проведен)
	|			И (ДокЧек.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыЧековККМ.Пробит))
	|		
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ФискальныеОперации КАК ФискальныеОперации
	|		ПО ФискальныеОперации.ДокументОснование = ДокЧек.РеализацияПодарочныхСертификатов
	|ГДЕ
	|	ДокОтчетОРозничныхПродажах.Ссылка В(&МассивОбъектов)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ДокОтчетОРозничныхВозвратах.Ссылка КАК Документ,
	|	ФискальныеОперации.НомерЧекаККМ КАК НомерЧека,
	|	ДокЧек.СуммаДокумента КАК СуммаДокумента
	|ИЗ
	|	Документ.ОтчетОРозничныхВозвратах КАК ДокОтчетОРозничныхВозвратах
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЧекККМВозврат КАК ДокЧек
	|		ПО ДокОтчетОРозничныхВозвратах.КассоваяСмена = ДокЧек.КассоваяСмена
	|			И (ДокЧек.Проведен)
	|			И (ДокЧек.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыЧековККМ.Пробит))
	|		
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ФискальныеОперации КАК ФискальныеОперации
	|		ПО ФискальныеОперации.ДокументОснование = ДокЧек.ЧекККМ
	|ГДЕ
	|	ДокОтчетОРозничныхВозвратах.Ссылка В(&МассивОбъектов)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ДокОтчетОРозничныхВозвратах.Ссылка КАК Документ,
	|	ФискальныеОперации.НомерЧекаККМ КАК НомерЧека,
	|	ДокЧек.СуммаДокумента КАК СуммаДокумента
	|ИЗ
	|	Документ.ОтчетОРозничныхВозвратах КАК ДокОтчетОРозничныхВозвратах
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ВозвратПодарочныхСертификатов КАК ДокЧек
	|		ПО ДокОтчетОРозничныхВозвратах.КассоваяСмена = ДокЧек.КассоваяСмена
	|			И (ДокЧек.Проведен)
	|			И (ДокЧек.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыЧековККМ.Пробит))
	|		
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ФискальныеОперации КАК ФискальныеОперации
	|		ПО ФискальныеОперации.ДокументОснование = ДокЧек.РеализацияПодарочныхСертификатов
	|ГДЕ
	|	ДокОтчетОРозничныхВозвратах.Ссылка В(&МассивОбъектов)
	|УПОРЯДОЧИТЬ ПО
	|	Документ
	|ИТОГИ ПО
	|	Документ";
	
	Запрос.УстановитьПараметр("МассивОбъектов", МассивОбъектов);
	
	РезультатЗапроса = Запрос.ВыполнитьПакет();
	
	СтруктураДанныхДляПечати = Новый Структура("РезультатЗапроса", РезультатЗапроса);
	
	Если ПривилегированныйРежим() Тогда
		УстановитьПривилегированныйРежим(Ложь);
	КонецЕсли;
	
	Возврат СтруктураДанныхДляПечати;
	
КонецФункции

// Определяет по документу закупки, применяет ли организация Патент
// 
// Параметры:
//  ДокументЗакупки - ДокументСсылка - Документ закупки
// 
// Возвращаемое значение:
//  Булево - Документ закупки по Патенту
Функция ДокументЗакупкиПоПатенту(ДокументЗакупки) Экспорт
	
	ДокументЗакупкиПоПатенту = Ложь;
	
	Если ТипЗнч(ДокументЗакупки) = Тип("ДокументСсылка.ЗаказПоставщику")
		ИЛИ ТипЗнч(ДокументЗакупки) = Тип("ДокументСсылка.ПриобретениеТоваровУслуг")
		ИЛИ ТипЗнч(ДокументЗакупки) = Тип("ДокументСсылка.ПриобретениеУслугПрочихАктивов") Тогда
		
		ЗакупкаПодДеятельность = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДокументЗакупки, "ЗакупкаПодДеятельность");
		Если ЗакупкаПодДеятельность = Перечисления.ТипыНалогообложенияНДС.ПродажаПоПатенту Тогда
			ДокументЗакупкиПоПатенту = Истина;
		КонецЕсли;
	КонецЕсли;
	
	Возврат ДокументЗакупкиПоПатенту;
	
КонецФункции

// Возвращает заводской номер ФН
// 
// Параметры:
//  ИдентификаторУстройства - СправочникСсылка.ПодключаемоеОборудование - Идентификатор устройства
// 
// Возвращаемое значение:
//  Строка - номер ФН
Функция ЗаводскойНомерФискальногоНакопителя(ИдентификаторУстройства) Экспорт
	
	ЗаводскойНомерФН = "";

	Если ОбщегоНазначенияБПО.ИспользуетсяЧекопечатающиеУстройства() Тогда
		МодульОборудованиеЧекопечатающиеУстройства = ОбщегоНазначенияБПО.ОбщийМодуль("ОборудованиеЧекопечатающиеУстройства");
		ПараметрыРегистрации = МодульОборудованиеЧекопечатающиеУстройства.ПараметрыРегистрацииУстройства(ИдентификаторУстройства);
		Если ПараметрыРегистрации.Свойство("ЗаводскойНомерФН") И ЗначениеЗаполнено(ПараметрыРегистрации.ЗаводскойНомерФН) Тогда
			ЗаводскойНомерФН = ПараметрыРегистрации.ЗаводскойНомерФН;
		КонецЕсли;
	КонецЕсли;
	
	Возврат ЗаводскойНомерФН;
	
КонецФункции

// По переданному источнику данных вычисляет ключи видов продукции ИС для товарных позиций.
// 
// Параметры:
//  ИсточникТоварныхПозиций - ДокументСсылка.РеализацияТоваровУслуг, ДокументОбъект.РеализацияТоваровУслуг, ДокументСсылка.ЧекККМ, ДокументОбъект.ЧекККМ, Массив Из СправочникСсылка.Номенклатура - Источник откуда необходимо получить товарые позиции.
//
// Возвращаемое значение:
//  Соответствие Из КлючИЗначение:
//    *Ключ - СправочникСсылка.Номенклатура -
//    *Значение - СправочникСсылка.КлючиВидовПродукцииИС - Ключи видов продукции.
//
Функция КлючиВидовПродукцииИСТоварныхПозицийДокументаПродажи(ИсточникТоварныхПозиций) Экспорт
	
	ВидыПродукцииИС = Новый Соответствие;
	Запрос = Неопределено;
	Если ТипЗнч(ИсточникТоварныхПозиций) = Тип("ДокументСсылка.РеализацияТоваровУслуг") Тогда
		Запрос = Новый Запрос;
		Запрос.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	Товары.Номенклатура КАК Номенклатура,
		|	ЕСТЬNULL(ОписаниеНоменклатурыИС.КлючВидовПродукции, ЗНАЧЕНИЕ(Справочник.КлючиВидовПродукцииИС.ПустаяСсылка)) КАК
		|		ВидПродукцииИС
		|ИЗ
		|	Документ.РеализацияТоваровУслуг.Товары КАК Товары
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.ОписаниеНоменклатурыИС КАК ОписаниеНоменклатурыИС
		|		ПО Товары.Номенклатура = ОписаниеНоменклатурыИС.Номенклатура
		|ГДЕ
		|	Товары.Ссылка = &Ссылка
		|	И Товары.Номенклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Товар)
		|	И НЕ ОписаниеНоменклатурыИС.КлючВидовПродукции = ЗНАЧЕНИЕ(Справочник.КлючиВидовПродукцииИС.ПустаяСсылка)";
		Запрос.УстановитьПараметр("Ссылка", ИсточникТоварныхПозиций);
	
	ИначеЕсли ТипЗнч(ИсточникТоварныхПозиций) = Тип("ДокументСсылка.ЧекККМ") Тогда
		Запрос = Новый Запрос;
		Запрос.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	Товары.Номенклатура КАК Номенклатура,
		|	ЕСТЬNULL(ОписаниеНоменклатурыИС.КлючВидовПродукции, ЗНАЧЕНИЕ(Справочник.КлючиВидовПродукцииИС.ПустаяСсылка)) КАК
		|		ВидПродукцииИС
		|ИЗ
		|	Документ.ЧекККМ.Товары КАК Товары
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.ОписаниеНоменклатурыИС КАК ОписаниеНоменклатурыИС
		|		ПО Товары.Номенклатура = ОписаниеНоменклатурыИС.Номенклатура
		|ГДЕ
		|	Товары.Ссылка = &Ссылка
		|	И Товары.Номенклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Товар)
		|	И НЕ ОписаниеНоменклатурыИС.КлючВидовПродукции = ЗНАЧЕНИЕ(Справочник.КлючиВидовПродукцииИС.ПустаяСсылка)";
		Запрос.УстановитьПараметр("Ссылка", ИсточникТоварныхПозиций);
	
	ИначеЕсли ТипЗнч(ИсточникТоварныхПозиций) = Тип("ДокументОбъект.РеализацияТоваровУслуг") 
			Или ТипЗнч(ИсточникТоварныхПозиций) = Тип("ДокументОбъект.ЧекККМ") Тогда
			
		ТаблицаТоварыДляПроверки = ИсточникТоварныхПозиций.Товары.ВыгрузитьКолонки("Номенклатура");
		ТаблицаТоварыДляПроверки.Свернуть("Номенклатура");
		ТоварыДляПроверки = ТаблицаТоварыДляПроверки.ВыгрузитьКолонку("Номенклатура");

		Запрос = Новый Запрос;
		Запрос.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ОписаниеНоменклатурыИС.Номенклатура КАК Номенклатура,
		|	ОписаниеНоменклатурыИС.КлючВидовПродукции КАК ВидПродукцииИС
		|ИЗ
		|	РегистрСведений.ОписаниеНоменклатурыИС КАК ОписаниеНоменклатурыИС
		|ГДЕ
		|	ОписаниеНоменклатурыИС.Номенклатура В (&Номенклатура)";
		Запрос.УстановитьПараметр("Номенклатура", ТоварыДляПроверки);
		
	ИначеЕсли ТипЗнч(ИсточникТоварныхПозиций) = Тип("Массив") Тогда
		Запрос = Новый Запрос;
		Запрос.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ОписаниеНоменклатурыИС.Номенклатура КАК Номенклатура,
		|	ОписаниеНоменклатурыИС.КлючВидовПродукции КАК ВидПродукцииИС
		|ИЗ
		|	РегистрСведений.ОписаниеНоменклатурыИС КАК ОписаниеНоменклатурыИС
		|ГДЕ
		|	ОписаниеНоменклатурыИС.Номенклатура В (&Номенклатура)";
		Запрос.УстановитьПараметр("Номенклатура", ИсточникТоварныхПозиций);
		
	КонецЕсли;
	
	Если Не Запрос = Неопределено Тогда
		Выборка = Запрос.Выполнить().Выбрать();
		Пока Выборка.Следующий() Цикл
			ВидыПродукцииИС.Вставить(Выборка.Номенклатура, Выборка.ВидПродукцииИС);
		КонецЦикла;
	КонецЕсли;
	
	Возврат ВидыПродукцииИС;
КонецФункции

// Обработчик ПриИзмененииЭлемента
// Параметры:
//	Форма - ФормаКлиентскогоПриложения
//	Элемент - ЭлементыФормы
//	ДополнительныеПараметры - Структура
Процедура ПриИзмененииЭлемента(Форма, Элемент, ДополнительныеПараметры = Неопределено) Экспорт

#Область РозничнаяПродажаТабачнойПродукцииТолькоПоМРЦ

	КонтрольныеЭлементы = Новый Массив();
	КонтрольныеЭлементы.Добавить("Дата");
	КонтрольныеЭлементы.Добавить("Контрагент");
	КонтрольныеФормы = РозничныеПродажиКлиентСерверЛокализация.ФормыСоВстроеннымМеханизмомМРЦ();
	
	Если КонтрольныеЭлементы.Найти(Элемент) <> Неопределено
		И КонтрольныеФормы.Найти(Форма.ИмяФормы) <> Неопределено Тогда
		
		ИмяКонтрольногоРеквизита = РозничныеПродажиКлиентСерверЛокализация.ИмяРеквизитаИспользоватьРозничныеПродажиТабачнойПродукцииТолькоПоМРЦ();
		Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(Форма, ИмяКонтрольногоРеквизита) Тогда
			ТекДата = Форма.Объект.Дата;
			ТекКонтрагент = Форма.Объект.Контрагент;	// СправочникСсылка.Контрагенты
			ТекЮрФизЛицо = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ТекКонтрагент, "ЮрФизЛицо");
			
			Форма[ИмяКонтрольногоРеквизита] = КонтролироватьЦенуПродажиТабачнойПродукции(?(ЗначениеЗаполнено(ТекДата),ТекДата, ТекущаяДатаСеанса()))
				И ТекЮрФизЛицо = ПредопределенноеЗначение("Перечисление.ЮрФизЛицо.ФизЛицо");
		КонецЕсли;
		
	КонецЕсли;
	
#КонецОбласти
	
КонецПроцедуры

//-- Локализация

// Проверяет, допустимы ли в документе товары
// 
// Параметры:
//  ДокументСсылка - ДокументСсылка - Документ для проверки
// 
// Возвращаемое значение:
//  Булево - Допустимы товары без марок в документе
Функция ДопустимыТоварыБезМарокВДокументе(ДокументСсылка) Экспорт
	
	ДопустимыТоварыБезМарокДляДокумента = Ложь;
	
	//++ Локализация
	Если ТипЗнч(ДокументСсылка) = Тип("ДокументСсылка.ВозвратТоваровОтКлиента")
		ИЛИ ТипЗнч(ДокументСсылка) = Тип("ДокументСсылка.ЧекККМВозврат") Тогда
		
		ДопустимыТоварыБезМарокДляДокумента = Истина;
	КонецЕсли;
	//-- Локализация
	
	Возврат ДопустимыТоварыБезМарокДляДокумента;
	
КонецФункции

// Текст запроса для получения документов по распоряжению (заказу клиента)
// 
// Возвращаемое значение:
//  Строка - Текст запроса документы по распоряжению
Функция ТекстЗапросаДокументыПоРаспоряжению() Экспорт
	
	//@skip-check bsl-ql-hub
	ТекстЗапроса = "ВЫБРАТЬ
	|	ОбъектыРасчетов.Ссылка КАК ОбъектРасчетов
	|ПОМЕСТИТЬ ВТОбъектыРасчетов
	|ИЗ
	|	Справочник.ОбъектыРасчетов КАК ОбъектыРасчетов
	|ГДЕ
	|	ОбъектыРасчетов.Объект = &ОбъектРасчетов
	|	И НЕ ОбъектыРасчетов.ПометкаУдаления
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	РеализацияТоваровУслуг.Ссылка КАК Ссылка,
	|	РеализацияТоваровУслуг.Дата КАК Дата
	|ПОМЕСТИТЬ ВТДокументыПоРаспоряжению
	|ИЗ
	|	Документ.РеализацияТоваровУслуг КАК РеализацияТоваровУслуг
	|ГДЕ
	|	РеализацияТоваровУслуг.Проведен
	|	И РеализацияТоваровУслуг.ЗаказКлиента = &Распоряжение
	|
	|ОБЪЕДИНИТЬ
	|
	|ВЫБРАТЬ
	|	ПриходныйКассовыйОрдер.Ссылка,
	|	ПриходныйКассовыйОрдер.Ссылка.Дата
	|ИЗ
	|	Документ.ПриходныйКассовыйОрдер.РасшифровкаПлатежа КАК ПриходныйКассовыйОрдер
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТОбъектыРасчетов КАК ОбъектыРасчетов
	|		ПО ПриходныйКассовыйОрдер.ОбъектРасчетов = ОбъектыРасчетов.ОбъектРасчетов
	|			И (ПриходныйКассовыйОрдер.Ссылка.Проведен)
	|
	|ОБЪЕДИНИТЬ
	|
	|ВЫБРАТЬ
	|	ОперацияПоПлатежнойКарте.Ссылка,
	|	ОперацияПоПлатежнойКарте.Ссылка.Дата
	|ИЗ
	|	Документ.ОперацияПоПлатежнойКарте.РасшифровкаПлатежа КАК ОперацияПоПлатежнойКарте
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТОбъектыРасчетов КАК ОбъектыРасчетов
	|		ПО ОперацияПоПлатежнойКарте.ОбъектРасчетов = ОбъектыРасчетов.ОбъектРасчетов
	|			И (ОперацияПоПлатежнойКарте.Ссылка.Проведен)
	//++ Локализация
	|ОБЪЕДИНИТЬ
	|
	|ВЫБРАТЬ
	|	ОперацияПоЯндексКассе.Ссылка,
	|	ОперацияПоЯндексКассе.Ссылка.Дата
	|ИЗ
	|	Документ.ОперацияПоЯндексКассе КАК ОперацияПоЯндексКассе
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТОбъектыРасчетов КАК ОбъектыРасчетов
	|		ПО ОперацияПоЯндексКассе.ОбъектРасчетов = ОбъектыРасчетов.ОбъектРасчетов
	|			И (ОперацияПоЯндексКассе.Ссылка.Проведен)
	//-- Локализация
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ДокументыПоРаспоряжению.Ссылка КАК Ссылка,
	|	ДокументыПоРаспоряжению.Дата КАК Дата,
	|	НАЧАЛОПЕРИОДА(ДокументыПоРаспоряжению.Дата, ДЕНЬ) КАК ДатаДень
	|ИЗ
	|	ВТДокументыПоРаспоряжению КАК ДокументыПоРаспоряжению
	//++ Локализация
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ОчередьЧековККТ КАК ОчередьЧековККТ
	|		ПО ДокументыПоРаспоряжению.Ссылка = ОчередьЧековККТ.ДокументОснование
	|ГДЕ
	|	ОчередьЧековККТ.ДокументОснование ЕСТЬ NULL
	//-- Локализация
	|
	|УПОРЯДОЧИТЬ ПО
	|	ДокументыПоРаспоряжению.Дата УБЫВ
	|ИТОГИ ПО
	|	ДатаДень";
	
	Возврат ТекстЗапроса;
	
КонецФункции

// Возвращает систему налогообложения организации на дату
// 
// Параметры:
// 	Организация - СправочникСсылка.Организации - Организация, для которой определяется система налогообложения
// 	Дата - Дата - Дата, на которую определяется система налогообложения
// Возвращаемое значение:
// 	ПеречислениеСсылка.ТипыСистемНалогообложенияККТ - Система налогообложения для параметров фискальных чеков
Функция СистемаНалогообложенияФискальнойОперации(Организация, Дата = Неопределено) Экспорт
	
	Если ТипЗнч(Организация) <> Тип("СправочникСсылка.Организации")
		ИЛИ НЕ ЗначениеЗаполнено(Организация) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	ТекстЗапроса = "ВЫБРАТЬ
	|	Т.СистемаНалогообложения КАК СистемаНалогообложения,
	|	&ПараметрДляПодстановки КАК ОбъектНалогообложенияУСН
	|ИЗ
	|	РегистрСведений.НастройкиСистемыНалогообложения.СрезПоследних(&ТекущаяДата, Организация = &Организация) КАК Т
	|";
//++ Локализация
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&ПараметрДляПодстановки", "ЕСТЬNULL(Т2.ОбъектНалогообложенияУСН, НЕОПРЕДЕЛЕНО)");
	ТекстЗапроса = ТекстЗапроса + "
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.НастройкиУчетаУСН.СрезПоследних(&ТекущаяДата, Организация = &Организация) КАК Т2
	|		ПО Т.Организация = Т2.Организация
	|";
//-- Локализация

	Запрос = Новый Запрос(ТекстЗапроса);
	Запрос.УстановитьПараметр("ПараметрДляПодстановки", Неопределено);
	
	Если Дата = Неопределено Тогда
		Запрос.УстановитьПараметр("ТекущаяДата", ТекущаяДатаСеанса());
	Иначе
		Запрос.УстановитьПараметр("ТекущаяДата", Дата);
	КонецЕсли;
	
	РеквизитыОрганизации = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(
		Организация,
		"ГоловнаяОрганизация, ОбособленноеПодразделение");
		
	Если РеквизитыОрганизации.ОбособленноеПодразделение = Истина Тогда
		Запрос.УстановитьПараметр("Организация", РеквизитыОрганизации.ГоловнаяОрганизация);
	Иначе
		Запрос.УстановитьПараметр("Организация", Организация);
	КонецЕсли;
	
	ДанныеСистемыНалогообложения = Запрос.Выполнить().Выбрать();
	ДанныеСистемыНалогообложения.Следующий();
	
	СистемаНалогообложения = Неопределено;
	
	Если ДанныеСистемыНалогообложения.СистемаНалогообложения = Перечисления.СистемыНалогообложения.Общая Тогда
		
		СистемаНалогообложения = Перечисления.ТипыСистемНалогообложенияККТ.ОСН;

//++ Локализация		
	ИначеЕсли ДанныеСистемыНалогообложения.СистемаНалогообложения = Перечисления.СистемыНалогообложения.Упрощенная Тогда
		
		Если ДанныеСистемыНалогообложения.ОбъектНалогообложенияУСН = Перечисления.ОбъектыНалогообложенияПоУСН.Доходы Тогда
			
			СистемаНалогообложения = Перечисления.ТипыСистемНалогообложенияККТ.УСНДоход;
			
		ИначеЕсли ДанныеСистемыНалогообложения.ОбъектНалогообложенияУСН = Перечисления.ОбъектыНалогообложенияПоУСН.ДоходыМинусРасходы Тогда
			
			СистемаНалогообложения = Перечисления.ТипыСистемНалогообложенияККТ.УСНДоходРасход;
			
		КонецЕсли;
//-- Локализация
		
	КонецЕсли;
	
	Возврат СистемаНалогообложения;
	
КонецФункции

// Определяет, является ли номенклатура алкогольной продукцией, имеющая уникальный идентификатор (маркируовку)
// 
// Параметры:
//  Номенклатура - СправочникСсылка.Номенклатура - Проверяемая номенклатура
// 
// Возвращаемое значение:
//  Булево - Истина, если номенклатура является алкогольной продукцией, имеющая уникальный идентификатор (маркируовку)
Функция АлкогольнаяПродукцияЕГАИСМаркируемая(Номенклатура) Экспорт
	
	//++ Локализация
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Номенклатура.Ссылка КАК Ссылка,
	|	Номенклатура.ВидАлкогольнойПродукции КАК ВидПродукции,
	|	Номенклатура.ВидАлкогольнойПродукции.Маркируемый КАК ВидПродукцииМаркируемый
	|ИЗ
	|	Справочник.Номенклатура КАК Номенклатура
	|ГДЕ
	|	Номенклатура.Ссылка = &Номенклатура
	|	И Номенклатура.ВидАлкогольнойПродукции.Маркируемый = ИСТИНА";
	Запрос.УстановитьПараметр("Номенклатура", Номенклатура);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда
		Возврат Истина;
	Иначе
		Возврат Ложь;
	КонецЕсли;
	//-- Локализация
	
	//@skip-check bsl-legacy-check-method-for-statements-after-return
	Возврат Ложь;

КонецФункции

// Возвращает возможность печатать отдельный слип чек эквайринговой операции.
// Если Истина, то предполагается, что слип-чек эквайрингового терминала выводится отдельно и
// фискальный чек не содержит данные эквайринговой операции.
// 
// Возвращаемое значение:
// 	Булево
Функция ПечататьОтдельныйСлипЧекЭквайринговойОперации() Экспорт

	Результат = Ложь;
	
	//++ Локализация
	
	Результат = ПолучитьФункциональнуюОпцию("ПечататьОтдельныйСлипЧекЭквайринговойОперации");
	
	//-- Локализация
	
	Возврат Результат;

КонецФункции

// Проверяет, разрешена ли в документе продажа подарочного сертификата в зависимости
// от хозяйственной операции документа.
// 
// Параметры:
//  ХозяйственнаяОперация - ПеречислениеСсылка.ХозяйственныеОперации - Хозяйственная операция, по которой проверяется
//  	разрешена ли продажа подарочного сертификата в документе.
// 
// Возвращаемое значение:
//  Булево - Разрешена продажа подарочного сертификата в документе
Функция РазрешенаПродажаПодарочногоСертификатаВДокументе(ХозяйственнаяОперация) Экспорт
	
	РазрешенаПродажаПодарочногоСертификатаВДокументе = Ложь;
	
	//++ Локализация
	
	Если ПолучитьФункциональнуюОпцию("НоваяАрхитектураВзаиморасчетов")
		И ПолучитьФункциональнуюОпцию("ИспользоватьПодарочныеСертификаты")
		И (ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.ПоступлениеОплатыОтКлиента
			ИЛИ ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.ВозвратОплатыКлиенту) Тогда
		
		РазрешенаПродажаПодарочногоСертификатаВДокументе = Истина;
	КонецЕсли;
	//-- Локализация
	
	Возврат РазрешенаПродажаПодарочногоСертификатаВДокументе;
	
КонецФункции

// Записывает объект формы
// 
// Параметры:
//  Форма - ФормаКлиентскогоПриложения - Форма клиентского приложения:
//  * Объект - ДокументОбъект - Основной реквизит формы документа
//  ПараметрыФискализации - Структура -
//  ПараметрыЗаписи - Структура -
//  УспешноЗаписанДокумент - Булево - признак успешной записи документа
Процедура ЗаписатьФискальнуюОперацию(Форма, ПараметрыФискализации, ПараметрыЗаписи, УспешноЗаписанДокумент) Экспорт
	
	//++ Локализация
	Если Не УспешноЗаписанДокумент Тогда
		Возврат;
	КонецЕсли;
		
	Объект = Форма.Объект;
	Если (ТипЗнч(Объект.Ссылка) = Тип("ДокументСсылка.ЧекККМ")) Тогда
		ПараметрыСканирования = ШтрихкодированиеОбщегоНазначенияИС.ПараметрыСканирования(Форма);
		ОбщегоНазначенияИС.СписатьОстатокПоВскрытымПотребительскимУпаковкам(Объект, ПараметрыСканирования);
	КонецЕсли;
	//-- Локализация
	
КонецПроцедуры

// Проверяет данные маркированных товаров документа перед выполнением фискальной операции
//
// Параметры:
//  Объект - ДокументОбъект - Объект проверяемого документа
//  ДополнительныеПараметры - Структура Из КлючИЗначение - Произвольная структура для передачи данных из клиентского контекста
//
// Возвращаемое значение:
//  Булево - 
//
Функция ПроверкаДанныхМаркированногоТовараДокумента(Объект, ДополнительныеПараметры = Неопределено) Экспорт
	Результат = Истина;
	//++ Локализация

	Если ТипЗнч(Объект.Ссылка) = Тип("ДокументСсылка.КорректировкаРеализации") Тогда
		Результат = ПроверкаДанныхМаркированногоТовараДокументаКорректировкаРеализации(Объект, ДополнительныеПараметры);
	ИначеЕсли ТипЗнч(Объект.Ссылка) = Тип("ДокументСсылка.ЧекККМКоррекции") Тогда
		Результат = ПроверкаДанныхМаркированногоТовараДокументаЧекККМКоррекции(Объект, ДополнительныеПараметры);
	КонецЕсли;
	
	//-- Локализация
	Возврат Результат;
КонецФункции

#КонецОбласти

//++ Локализация

#Область РозничнаяПродажаТабачнойПродукцииТолькоПоМРЦ

// Обновляет реквизиты формы, при необходимости добавляет их. 
// Параметры:
//	Форма - ФормаКлиентскогоПриложения - список форм в методе РозничныеПродажиКлиентСерверЛокализация.ФормыСоВстроеннымМеханизмомМРЦ()
Процедура ОбновитьПризнакПродажиТабачнойПродукцииТолькоПоМРЦ(Форма) Экспорт
	
	ИзменитьФормуПродажаТабачнойПродукцииТолькоПоМРЦ(Форма);
	
КонецПроцедуры

// Признак вида продукции МРЦ
// Параметры:
//	Форма - ФормаКлиентскогоПриложения
//	СтрокаТЧ - СтрокаТабличнойЧасти:
//	*ВидПродукцииИС - СправочникСсылка.ВидыПродукцииИС
// Возвращаемое значение:
//	Булево
Функция ВСтрокеВидПродукцииСМРЦ(Форма, СтрокаТЧ) Экспорт
	
	Результат = Ложь;
	
	Если ТипЗнч(Форма) <> Тип("ФормаКлиентскогоПриложения") Тогда
		Возврат Результат;
	КонецЕсли;
	
	Если РозничныеПродажиКлиентСерверЛокализация.ФормыСоВстроеннымМеханизмомМРЦ().Найти(Форма.ИмяФормы) <> Неопределено
		И РозничныеПродажиКлиентСерверЛокализация.РозничныеПродажиТабачнойПродукцииТолькоПоМРЦ(Форма) Тогда
		
		Результат = Истина;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Отключение скидки для товара с МРЦ
// Параметры:
//	НоваяСтрока - СтрокаТабличнойЧасти
// Товар - см. СкидкиНаценкиСервер.ПрименитьЗначениеСкидкиКТовару.Товар
// ПараметрыРасчета - Структура:
//	*Объект - ДанныеФормыСтруктура:
//	**Контрагент - СправочникСсылка.Контрагенты
Процедура ПрименитьЗначениеСкидкиКТовару(НоваяСтрока, Товар, ПараметрыРасчета) Экспорт

	ТипВызывающегоОбъект = ТипЗнч(ПараметрыРасчета.Объект.Ссылка);
	Если ТипыОбъектовДляОчисткиСкидкиПоМРЦ().Найти(ТипВызывающегоОбъект) = Неопределено Тогда
		
		Возврат;
		
	КонецЕсли;
	
	Если КонтролироватьЦенуПродажиТабачнойПродукции(ПараметрыРасчета.Объект.Дата)
		И (ТипЗнч(ПараметрыРасчета.Объект.Ссылка) = Тип("ДокументСсылка.ЧекККМ")
			ИЛИ ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(ПараметрыРасчета.Объект, "Контрагент")
					И ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ПараметрыРасчета.Объект.Контрагент,"ЮрФизЛицо") = 
						ПредопределенноеЗначение("Перечисление.ЮрФизЛицо.ФизЛицо")) Тогда
		
		Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(Товар, "ВидПродукцииИС") Тогда
			Если КонструкторИСМПОбщегоНазначенияКлиентСервер.ДоступноПолеМРЦ(Товар.ВидПродукцииИС) Тогда
				НоваяСтрока.Действует = Ложь;
			КонецЕсли;
		Иначе
			ТекНоменклатура = Товар.Номенклатура;	// СправочникСсылка.Номенклатура
			ОписаниеНоменклатуры = ОбщегоНазначенияИС.ОписаниеНоменклатуры(ТекНоменклатура)[ТекНоменклатура];
			Если КонструкторИСМПОбщегоНазначенияКлиентСервер.ДоступноПолеМРЦ(ОписаниеНоменклатуры.КлючВидовПродукции) Тогда
				НоваяСтрока.Действует = Ложь;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;

КонецПроцедуры

// Определяет по дате документа, нужно ли в документе контролировать цену продажи табачной продукции по МРЦ
// 
// Параметры:
//	ДатаДокумента - Дата - Дата документа для определения, нужно ли в нем контролировать цену продажи табачной продукции
//	по РМЦ для.
// 
// Возвращаемое значение:
//  Булево - Контролировать МРЦДля табачной продукции локализация
Функция КонтролироватьЦенуПродажиТабачнойПродукции(ДатаДокумента) Экспорт
	
	КонтролироватьЦенуПродажиТабачнойПродукции = Ложь;
	
	ДатаКонтроля = ПолучитьФункциональнуюОпцию("ДатаРозничнойПродажиТабачнойПродукцииТолькоПоМРЦ");
	
	Если ЗначениеЗаполнено(ДатаКонтроля)
		И ДатаКонтроля <= ДатаДокумента Тогда
		
		КонтролироватьЦенуПродажиТабачнойПродукции = Истина;
	КонецЕсли;
	
	Возврат КонтролироватьЦенуПродажиТабачнойПродукции;
	
КонецФункции

// Определяет, нужно ли для переданного вида продукции ИС контролировать цену продажи по МРЦ
// 
// Параметры:
//  ВидПродукцииИС - СправочникСсылка.ВидыПродукцииИС - Вид продукции ИС
// 
// Возвращаемое значение:
//  Булево - Контролировать цену продажи по МРЦ для вида продукции ИС
Функция КонтролироватьЦенуПродажиПоМРЦДляВидаПродукцииИС(ВидПродукцииИС) Экспорт
	
	Возврат КонструкторИСМПОбщегоНазначенияКлиентСервер.ДоступноПолеМРЦ(ВидПродукцииИС);
	
КонецФункции

// Проверить в РМК корректность цены продажи м МРЦ для  табачной продукции.
// 
// Параметры:
//  Форма - ФормаКлиентскогоПриложения - Форма:
//	* Объект - ДокументОбъект.ЧекККМ, ДокументОбъект.РеализацияТоваровУслуг - Чек ККМ, Реализация товаров и услуг
//  ИмяТаблицыШтрихкодовУпаковок - Строка - Имя таблицы штрихкодов упаковок документа
//  КонтрольПоТекущейДате - Булево - Требуется контроль по текущей дате, вместо даты документа
//  УдалитьНекорректныеШтрихкодыУпаковок - Булево - Удалять из документа некорректные штрихкоды упаковок, если Истина
// 
// Возвращаемое значение:
//  Булево - Истина, нет ошибок в цене продажи и МРЦ
Функция ПроверитьКорректностьЦеныПродажиИМРЦТабачнойПродукции(Форма, ИмяТаблицыШтрихкодовУпаковок,
	КонтрольПоТекущейДате = Ложь, УдалитьНекорректныеШтрихкодыУпаковок = Ложь) Экспорт
	
	РезультатПроверки = Истина;
	
	ИмяРеквизитаФормыКонтроляПродажиПоМРЦ = РозничныеПродажиКлиентСерверЛокализация
		.ИмяРеквизитаИспользоватьРозничныеПродажиТабачнойПродукцииТолькоПоМРЦ();
	
	Если Форма.Объект.Товары.Количество() = 0 Тогда
		Возврат РезультатПроверки;
	ИначеЕсли КонтрольПоТекущейДате И Не КонтролироватьЦенуПродажиТабачнойПродукции(ТекущаяДатаСеанса()) Тогда
		Возврат РезультатПроверки;
	ИначеЕсли Не КонтрольПоТекущейДате
		И Не (ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(Форма, ИмяРеквизитаФормыКонтроляПродажиПоМРЦ)
			И Форма[ИмяРеквизитаФормыКонтроляПродажиПоМРЦ]) Тогда
		Возврат РезультатПроверки;
	КонецЕсли;
	
	НачалоЗамера = ОценкаПроизводительности.НачатьЗамерВремени();
	
	ПараметрыСканирования = ШтрихкодированиеОбщегоНазначенияИС.ПараметрыСканирования(Форма);
	
	ИмяКолонкиШтрихкодаУпаковки = РозничныеПродажиКлиентСерверЛокализация.РеквизитШтрихкодаПоТаблицеШтрихкодов(
		ИмяТаблицыШтрихкодовУпаковок);
	ШтрихкодыУпаковок = Форма.Объект[ИмяТаблицыШтрихкодовУпаковок].Выгрузить().ВыгрузитьКолонку(ИмяКолонкиШтрихкодаУпаковки);
	
	ИмяТаблицыТоваров = РозничныеПродажиКлиентСерверЛокализация.ТаблицаТоваровПоФормеМРЦ(Форма.ИмяФормы);
	РезультатПроверкиСкидок = ПроверитьИсправитьНаличиеСкидокОплатБонуснымиБаллами(Форма, ИмяТаблицыТоваров, , Истина);
	
	РезультатПроверкиМинимальнойЦены = ПроверитьШтрихкодыУпаковокНаМинимальнуюЦену(
		Форма,
		ШтрихкодыУпаковок,
		ПараметрыСканирования,
		Истина,
		УдалитьНекорректныеШтрихкодыУпаковок);
	
	ШтрихкодыУпаковок = Форма.Объект[ИмяТаблицыШтрихкодовУпаковок].Выгрузить().ВыгрузитьКолонку(ИмяКолонкиШтрихкодаУпаковки);
	ШтрихкодыУпаковокСМРЦ = ПолучитьШтрихкодыУпаковокСМРЦ(ШтрихкодыУпаковок, ПараметрыСканирования, Истина);
	
	РезультатПроверкиРозничнойЦены = ПроверитьКорректностьРозничнойЦеныПоМРЦ(
		Форма.Объект[ИмяТаблицыТоваров].Выгрузить(),
		ШтрихкодыУпаковокСМРЦ,
		Форма.Объект.ЦенаВключаетНДС);
		
	РезультатПроверки = РезультатПроверкиСкидок И РезультатПроверкиМинимальнойЦены И РезультатПроверкиРозничнойЦены;
	
	ИмяРеквизитаЕстьОшибкаВЦенеПоМРЦ = РозничныеПродажиКлиентСерверЛокализация.ИмяРеквизитаЕстьОшибкаВЦенеПоМРЦ();
	Если Не РезультатПроверки
		И ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(Форма, ИмяРеквизитаЕстьОшибкаВЦенеПоМРЦ) Тогда
		Форма[ИмяРеквизитаЕстьОшибкаВЦенеПоМРЦ] = Истина;
	КонецЕсли;
	
	Если РезультатПроверки Тогда
		// Дополнительно установить флаг МРЦ для товаров с корректной ценой
		Для Каждого СтрокаТовары Из Форма.Объект.Товары Цикл
			
			Если КонструкторИСМПОбщегоНазначенияКлиентСервер.ДоступноПолеМРЦ(СтрокаТовары.ВидПродукцииИС) Тогда
				Продолжить;
			КонецЕсли;
			
			ИмяРеквизитаУстановленаМРЦ = РозничныеПродажиКлиентСерверЛокализация.ИмяРеквизитаУстановленаМРЦ();
			Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(СтрокаТовары, ИмяРеквизитаУстановленаМРЦ)
				И ЗначениеЗаполнено(СтрокаТовары.Цена) Тогда
				СтрокаТовары[ИмяРеквизитаУстановленаМРЦ] = Истина;
			КонецЕсли;
			
		КонецЦикла;
	КонецЕсли;
	
	КлючеваяОперацияИмя = "МРЦ.ПроверкаКорректностиМРЦТабличнойЧасти";
	ОписаниеЛога = Новый Структура;
	ОписаниеЛога.Вставить("Документ", Строка(Форма.Объект.Ссылка));
	ОписаниеЛога.Вставить("Метод", "ПроверитьКорректностьЦеныПродажиИМРЦТабачнойПродукции");
	ОписаниеЛога.Вставить("Результат", РезультатПроверки);
	ОценкаПроизводительности.ЗакончитьЗамерВремени(КлючеваяОперацияИмя, 
		НачалоЗамера,
		ШтрихкодыУпаковокСМРЦ.Количество(), 
		ЗаписатьЗначениеJSON(ОписаниеЛога));
	
	Возврат РезультатПроверки;
	
КонецФункции

// Товары документа реализации с видами продукции ИС.
// 
// Параметры:
//  ДокументРеализации - ДокументСсылка.РеализацияТоваровУслуг - Документ реализации
//  ОтборПоВидуПродукцииИС - Массив Из ПеречислениеСсылка.ВидыПродукцииИС - Необязательный параметр
// 
// Возвращаемое значение:
//  ТаблицаЗначений - Товары документа реализации с видами продукции ИС:
//	* НомерСтроки - Число - Номер строки
//	* Номенклатура - СправочникСсылка.Номенклатура - Номенклатура
//	* Характеристика - СправочникСсылка.ХарактеристикиНоменклатуры - Характеристика
//	* Серия - СправочникСсылка.СерииНоменклатуры - Серия
//	* Цена - Число - Цена
//	* ВидПродукцииИС - СправочникСсылка.ВидыПродукцииИС - Вид продукции ИС
//	* Количество - Число - Количество
//	* СуммаАвтоматическойСкидки - Число - Сумма автоматической скидки
//	* ПроцентАвтоматическойСкидки - Число - Процент автоматической скидки
//	* СуммаРучнойСкидки - Число - Сумма ручной скидки
//	* ПроцентРучнойСкидки - Число - Процент ручной скидки
//	* СуммаБонусныхБалловКСписанию - Число - Сумма бонусных баллов к списанию
//	* СуммаБонусныхБалловКСписаниюВВалюте - Число - Сумма бонусных баллов к списанию в валюте
Функция ТоварыДокументаРеализацииСВидамиПродукцииИС(ДокументРеализации, ОтборПоВидуПродукцииИС = Неопределено) Экспорт
	
	Запрос = Новый Запрос;

	ТекстыЗапроса = Новый Массив;
	ТекстыЗапроса.Добавить(ПолучитьТекстЗапросаТоварыПоРеализацииТоваровУслугСВидамиПродукцииИСПоСсылке());
	
	ТекстЗапроса = 
	"ВЫБРАТЬ
	|	ТоварыДокумента.НомерСтроки,
	|	ТоварыДокумента.Номенклатура,
	|	ТоварыДокумента.Характеристика,
	|	ТоварыДокумента.Серия,
	|	ТоварыДокумента.Цена,
	|	ТоварыДокумента.ВидПродукцииИС,
	|	ТоварыДокумента.Количество,
	|	ТоварыДокумента.СуммаАвтоматическойСкидки,
	|	ТоварыДокумента.ПроцентАвтоматическойСкидки,
	|	ТоварыДокумента.СуммаРучнойСкидки,
	|	ТоварыДокумента.ПроцентРучнойСкидки,
	|	ТоварыДокумента.СуммаБонусныхБалловКСписанию,
	|	ТоварыДокумента.СуммаБонусныхБалловКСписаниюВВалюте,
	|	ТоварыДокумента.СуммаСНДС
	|ИЗ
	|	ТоварыДокумента КАК ТоварыДокумента
	|ГДЕ
	|	&ОтборПоВидуПродукцииИС
	|";	
	УсловиеОтбораПоВидуПродукцииИС = "ИСТИНА";
	Если ТипЗнч(ОтборПоВидуПродукцииИС) = Тип("Массив") И ОтборПоВидуПродукцииИС.Количество() Тогда
		УсловиеОтбораПоВидуПродукцииИС = "ТоварыДокумента.ВидПродукцииИС В (&ОтборПоВидуПродукцииИС)";
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&ОтборПоВидуПродукцииИС", УсловиеОтбораПоВидуПродукцииИС);
		Запрос.УстановитьПараметр("ОтборПоВидуПродукцииИС", ОтборПоВидуПродукцииИС); 
	КонецЕсли;
	ТекстыЗапроса.Добавить(ТекстЗапроса);
	
	ТекстЗапроса = СтрСоединить(ТекстыЗапроса, ОбщегоНазначения.РазделительПакетаЗапросов());
	Запрос.Текст = ТекстЗапроса;
	Запрос.УстановитьПараметр("ДокументСсылка", ДокументРеализации);
	
	Возврат Запрос.Выполнить().Выгрузить();
	
КонецФункции

// Проверить и исправить наличие скидок и оплат бонусными баллами.
// 
// Параметры:
//  Контекст - ФормаКлиентскогоПриложения, ДокументСсылка.РеализацияТоваровУслуг, ДокументОбъект.РеализацияТоваровУслуг -
//  	Форма или документ для проверки.
//  ИмяТаблицыТоваров - Строка - Имя таблицы товаров документа
//  ОчиститьСкидкиОплатуБонуснымиБаллами - Булево - Истина, очищаются скидки и оплаты бонусными баллами по товарам с МРЦ
//  СообщитьОбОшибках - Булево - Истина, сообщать об ошибках
// 
// Возвращаемое значение:
//  Булево - Реузльтат проверки наличия скидок оплат бонусными баллами
Функция ПроверитьИсправитьНаличиеСкидокОплатБонуснымиБаллами(Контекст, ИмяТаблицыТоваров, ОчиститьСкидкиОплатуБонуснымиБаллами = Ложь,
	СообщитьОбОшибках = Ложь) Экспорт
	
	РезультатПроверки = Истина;
	ОбрабатываемыеСтроки = Новый Массив;
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц();
	Запрос.УстановитьПараметр("ВидыПродукцииИС", КонструкторИСМПОбщегоНазначенияКлиентСервер.ВидыПродукцииКоторымДоступноПолеМРЦ());
	
	ТекстыЗапроса = Новый Массив;
	Если ТипЗнч(Контекст) = Тип("ДокументСсылка.РеализацияТоваровУслуг") Тогда
		
		ТекстЗапроса = ПолучитьТекстЗапросаТоварыПоРеализацииТоваровУслугСВидамиПродукцииИСПоСсылке();
		ТекстыЗапроса.Добавить(ТекстЗапроса);
		Запрос.УстановитьПараметр("ДокументСсылка", Контекст);
		
	ИначеЕсли ТипЗнч(Контекст) = Тип("ДокументОбъект.РеализацияТоваровУслуг") Тогда
		
		ТекстЗапроса = ПолучитьТекстЗапросаТоварыПоРеализацииТоваровУслугСВидамиПродукцииИСПоОбъекту();
		ТекстыЗапроса.Добавить(ТекстЗапроса);
		Запрос.УстановитьПараметр("ТоварыДокумента", Контекст[ИмяТаблицыТоваров].Выгрузить());
		
	Иначе
		
		ТекстЗапроса = 
		"ВЫБРАТЬ
		|	ТоварыДокумента.НомерСтроки,
		|	ТоварыДокумента.Номенклатура,
		|	ТоварыДокумента.Характеристика,
		|	ТоварыДокумента.Серия,
		|	ТоварыДокумента.Цена,
		|	ТоварыДокумента.ВидПродукцииИС,
		|	ТоварыДокумента.Количество,
		|	ТоварыДокумента.СуммаАвтоматическойСкидки,
		|	ТоварыДокумента.ПроцентАвтоматическойСкидки,
		|	ТоварыДокумента.СуммаРучнойСкидки,
		|	ТоварыДокумента.ПроцентРучнойСкидки,
		|	ТоварыДокумента.СуммаБонусныхБалловКСписанию,
		|	ТоварыДокумента.СуммаБонусныхБалловКСписаниюВВалюте
		|ПОМЕСТИТЬ ТоварыДокумента
		|ИЗ
		|	&ТоварыДокумента КАК ТоварыДокумента
		|";
		ТекстыЗапроса.Добавить(ТекстЗапроса);
		Запрос.УстановитьПараметр("ТоварыДокумента", Контекст.Объект[ИмяТаблицыТоваров].Выгрузить());
		
	КонецЕсли;
	
	ТекстЗапроса =
	"ВЫБРАТЬ
	|	ТоварыДокумента.НомерСтроки,
	|	ТоварыДокумента.Номенклатура,
	|	ТоварыДокумента.Номенклатура.Наименование,
	|	ТоварыДокумента.Характеристика,
	|	ТоварыДокумента.Характеристика.Наименование,
	|	ТоварыДокумента.Серия,
	|	ТоварыДокумента.Серия.Наименование,
	|	ТоварыДокумента.Цена,
	|	ТоварыДокумента.ВидПродукцииИС,
	|	ТоварыДокумента.Количество,
	|	ТоварыДокумента.СуммаАвтоматическойСкидки,
	|	ТоварыДокумента.ПроцентАвтоматическойСкидки,
	|	ТоварыДокумента.СуммаРучнойСкидки,
	|	ТоварыДокумента.ПроцентРучнойСкидки,
	|	ТоварыДокумента.СуммаБонусныхБалловКСписанию,
	|	ТоварыДокумента.СуммаБонусныхБалловКСписаниюВВалюте
	|ИЗ
	|	ТоварыДокумента КАК ТоварыДокумента
	|ГДЕ
	|	ТоварыДокумента.ВидПродукцииИС.ВидПродукцииГИСМТ В (&ВидыПродукцииИС)
	|	И ТоварыДокумента.Цена > 0
	|	И (ТоварыДокумента.СуммаАвтоматическойСкидки <> 0
	|		ИЛИ ТоварыДокумента.ПроцентАвтоматическойСкидки <> 0
	|		ИЛИ ТоварыДокумента.СуммаРучнойСкидки <> 0
	|		ИЛИ ТоварыДокумента.ПроцентРучнойСкидки <> 0
	|		ИЛИ ТоварыДокумента.СуммаБонусныхБалловКСписанию <> 0
	|		ИЛИ ТоварыДокумента.СуммаБонусныхБалловКСписаниюВВалюте <> 0)
	|
	|УПОРЯДОЧИТЬ ПО
	|	НомерСтроки";
	ТекстыЗапроса.Добавить(ТекстЗапроса);
	
	ТекстЗапроса = СтрСоединить(ТекстыЗапроса, ОбщегоНазначения.РазделительПакетаЗапросов());
	
	Запрос.Текст = ТекстЗапроса;
	ВыборкаЗапроса = Запрос.Выполнить().Выбрать();
	
	Пока ВыборкаЗапроса.Следующий() Цикл
		
		РезультатПроверки = Ложь;
		
		Если ОчиститьСкидкиОплатуБонуснымиБаллами
			И ТипЗнч(Контекст) <> Тип("ДокументСсылка.РеализацияТоваровУслуг") Тогда
			
			Если ТипЗнч(Контекст) = Тип("ДокументОбъект.РеализацияТоваровУслуг") Тогда
				СтрокаТЧДокумента = Контекст[ИмяТаблицыТоваров][ВыборкаЗапроса.НомерСтроки-1];
			Иначе
				СтрокаТЧДокумента = Контекст.Объект[ИмяТаблицыТоваров][ВыборкаЗапроса.НомерСтроки-1];
			КонецЕсли;
			
			СтрокаТЧДокумента.ПроцентАвтоматическойСкидки = 0;
			СтрокаТЧДокумента.СуммаАвтоматическойСкидки = 0;
			СтрокаТЧДокумента.ПроцентРучнойСкидки = 0;
			СтрокаТЧДокумента.СуммаРучнойСкидки = 0;
			СтрокаТЧДокумента.СуммаБонусныхБалловКСписанию = 0;
			СтрокаТЧДокумента.СуммаБонусныхБалловКСписаниюВВалюте = 0;
			
			ОбрабатываемыеСтроки.Добавить(СтрокаТЧДокумента);
			
		КонецЕсли;
		
		Если СообщитьОбОшибках Тогда
			
			НаименованиеТовара = НоменклатураКлиентСервер.ПредставлениеНоменклатурыДляПечати(
				ВыборкаЗапроса.НоменклатураНаименование,
				ВыборкаЗапроса.ХарактеристикаНаименование,,
				ВыборкаЗапроса.СерияНаименование);
			
			Если ОчиститьСкидкиОплатуБонуснымиБаллами
				И ТипЗнч(Контекст) <> Тип("ДокументСсылка.РеализацияТоваровУслуг") Тогда
				Шаблон = Нстр("ru = 'В строке №%1 для товара ""%2"" отменена:'");
			Иначе
				Шаблон = Нстр("ru = 'В строке №%1 для товара ""%2"" есть:'");
			КонецЕсли;
			
			ТекстСообщения = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
				Шаблон,
				ВыборкаЗапроса.НомерСтроки,
				НаименованиеТовара);
			
			Если ЗначениеЗаполнено(ВыборкаЗапроса.СуммаАвтоматическойСкидки) Тогда
				Шаблон = Нстр("ru = 'автоматическая скидка ""%1%"";'");
				
				ТекстСообщения = ТекстСообщения + " " + СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
					Шаблон,
					ВыборкаЗапроса.ПроцентАвтоматическойСкидки);
			КонецЕсли;
			
			Если ЗначениеЗаполнено(ВыборкаЗапроса.СуммаРучнойСкидки) Тогда
				Шаблон = Нстр("ru = 'ручная скидка ""%1%"";'");
				
				ТекстСообщения = ТекстСообщения + " " + СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
					Шаблон,
					ВыборкаЗапроса.ПроцентРучнойСкидки);
			КонецЕсли;
			
			Если ЗначениеЗаполнено(ВыборкаЗапроса.СуммаБонусныхБалловКСписанию) Тогда
				Шаблон = Нстр("ru = 'оплата бонусными баллами ""%1"";'");
				
				ТекстСообщения = ТекстСообщения + " " + СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
					Шаблон,
					ВыборкаЗапроса.СуммаБонусныхБалловКСписаниюВВалюте);
			КонецЕсли;
			
			Если ЗначениеЗаполнено(ВыборкаЗапроса.СуммаАвтоматическойСкидки)
				Или ЗначениеЗаполнено(ВыборкаЗапроса.СуммаРучнойСкидки)
				Или ЗначениеЗаполнено(ВыборкаЗапроса.СуммаБонусныхБалловКСписанию) Тогда
				
				ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);
			КонецЕсли;
			
		КонецЕсли;
		
		Если Не ОчиститьСкидкиОплатуБонуснымиБаллами И Не СообщитьОбОшибках Тогда
			Прервать;
		КонецЕсли;
		
	КонецЦикла;
	
	Если ОчиститьСкидкиОплатуБонуснымиБаллами
		И ТипЗнч(Контекст) <> Тип("ДокументСсылка.РеализацияТоваровУслуг") Тогда
		
		Если ТипЗнч(Контекст) = Тип("ДокументОбъект.РеализацияТоваровУслуг") Тогда
			ДокументОбъект = Контекст;
			ИмяФормы = "Документ.РеализацияТоваровУслуг.Форма.ФормаДокумента";
		Иначе
			ДокументОбъект = Контекст.Объект;
			ИмяФормы = Контекст.ИмяФормы;
		КонецЕсли;
		
		СтруктураПересчетаСуммы = ПакетнаяОбработкаТабличнойЧастиКлиентСервер.ПараметрыПересчетаСуммыНДСВСтрокеТЧ(ДокументОбъект);
		
		ВалютаРегламентированногоУчета = ЗначениеНастроекПовтИсп.ВалютаРегламентированногоУчетаОрганизации(ДокументОбъект.Организация);
		ВалютаУправленческогоУчета = Константы.ВалютаУправленческогоУчета.Получить();
		
		СтруктураДействий = Новый Структура;
		СтруктураДействий.Вставить("ПересчитатьСуммуРучнойСкидки");
		СтруктураДействий.Вставить("ПересчитатьСумму");
		СтруктураДействий.Вставить("ПересчитатьСуммуСУчетомРучнойСкидки", Новый Структура("Очищать", Ложь));
		СтруктураДействий.Вставить("ПересчитатьСуммуСУчетомАвтоматическойСкидки", Новый Структура("Очищать", Ложь));
		СтруктураДействий.Вставить("ПересчитатьСуммуСУчетомСкидкиБонуснымиБаллами");
		СтруктураДействий.Вставить("ПересчитатьСуммуНДС", СтруктураПересчетаСуммы);
		Если Не ИмяФормы = "Документ.ЧекККМ.Форма.ФормаДокументаРМК" Тогда
			СтруктураДействий.Вставить("ПересчитатьСуммуСНДС", СтруктураПересчетаСуммы);
		КонецЕсли;
		
		Если ИмяФормы = "Документ.РеализацияТоваровУслуг.Форма.ФормаДокумента" Тогда
			СтруктураДействий.Вставить("ОчиститьСуммуВзаиморасчетов");
			
			ПараметрыЗаполненияСуммыНДСРеглУпр = ПакетнаяОбработкаТабличнойЧастиКлиентСервер.ПараметрыЗаполненияСуммыНДСРеглУпр(
				ДокументОбъект.Валюта,
				ВалютаРегламентированногоУчета,
				ВалютаУправленческогоУчета);
			СтруктураДействий.Вставить("УстановитьСуммуНДСРеглУпр", ПараметрыЗаполненияСуммыНДСРеглУпр);
		КонецЕсли;
		
		Если Не ИмяФормы = "Документ.ЧекККМ.Форма.ФормаДокументаРМК"
			И Не ИмяФормы = "Документ.ЧекККМВозврат.Форма.ФормаДокументаРМК"
			И Не ТипЗнч(ДокументОбъект) = Тип("ДокументОбъект.РеализацияТоваровУслуг") Тогда
			ЗависимыеРеквизиты = Новый Структура(
				"БезВозвратнойТары",
				"Сумма,СуммаНДС,СуммаСНДС,СуммаАвтоматическойСкидки,СуммаРучнойСкидки,СуммаБонусныхБалловКСписаниюВВалюте");
			СтруктураДействий.Вставить("ЗаполнитьДубликатыЗависимыхРеквизитов", ЗависимыеРеквизиты);
		КонецЕсли;
		
		ПакетнаяОбработкаТабличнойЧастиСервер.ОбработатьСтрокиТЧ(
			ОбрабатываемыеСтроки,
			СтруктураДействий,
			ДокументОбъект[ИмяТаблицыТоваров]);
	
	КонецЕсли;
	
	Возврат РезультатПроверки;
	
КонецФункции

// Возвращает таблицу товаров с КМ и МРЦ по списку переданных КМ в метод.
// 
// Параметры:
//  ШтрихкодыУпаковок - Массив Из СправочникСсылка.ШтрихкодыУпаковокТоваров - Штрихкоды упаковок
//  ПараметрыСканирования - См. ШтрихкодированиеОбщегоНазначенияИСКлиентСервер.БазовыеПараметрыСканирования
//  БезШтрихкодовУпаковок - Булево - Признак сворачивания таблицы до товаров и значений МРЦ
// 
// Возвращаемое значение:
//  ТаблицаЗначений - Получить штрихкоды упаковок СМРЦ:
// * Номенклатура - СправочникСсылка.Номенклатура - 
// * Характеристика - СправочникСсылка.ХарактеристикиНоменклатуры - 
// * Серия - СправочникСсылка.СерииНоменклатуры - 
// * МРЦ - Число - 
// * ВидПродукцииИС - СправочникСсылка.КлючиВидовПродукцииИС - 
// * ШтрихкодУпаковки - СправочникСсылка.ШтрихкодыУпаковокТоваров - Без колонки, если параметр БезШтрихкодовУпаковок = Истина
// * Количество - Число - 
Функция ПолучитьШтрихкодыУпаковокСМРЦ(ШтрихкодыУпаковок, ПараметрыСканирования, БезШтрихкодовУпаковок = Ложь) Экспорт
	
	НачалоЗамера = ОценкаПроизводительности.НачатьЗамерВремени();
	
	ШтрихкодыУпаковокСМРЦ = Новый ТаблицаЗначений();
	ШтрихкодыУпаковокСМРЦ.Колонки.Добавить(
		"Номенклатура",
		Новый ОписаниеТипов("СправочникСсылка.Номенклатура"));
	ШтрихкодыУпаковокСМРЦ.Колонки.Добавить(
		"Характеристика",
		Новый ОписаниеТипов("СправочникСсылка.ХарактеристикиНоменклатуры"));
	ШтрихкодыУпаковокСМРЦ.Колонки.Добавить(
		"Серия",
		Новый ОписаниеТипов("СправочникСсылка.СерииНоменклатуры"));
	ШтрихкодыУпаковокСМРЦ.Колонки.Добавить(
		"МРЦ",
		РаботаСКурсамиВалют.ОписаниеТипаДенежногоПоля());
	ТипыВидовПродукции = Новый Массив;
	ТипыВидовПродукции.Добавить(Тип("СправочникСсылка.ВидыПродукцииИС"));
	ТипыВидовПродукции.Добавить(Тип("СправочникСсылка.КлючиВидовПродукцииИС"));
	ШтрихкодыУпаковокСМРЦ.Колонки.Добавить("ВидПродукцииИС", Новый ОписаниеТипов(ТипыВидовПродукции));
	ШтрихкодыУпаковокСМРЦ.Колонки.Добавить(
		"ШтрихкодУпаковки",
		Новый ОписаниеТипов("СправочникСсылка.ШтрихкодыУпаковокТоваров"));
	ШтрихкодыУпаковокСМРЦ.Колонки.Добавить(
		"Количество",
		РаботаСКурсамиВалют.ОписаниеТипаДенежногоПоля());
	
	ВложенныеШтрихкодыУпаковок = ШтрихкодированиеИС.ВложенныеШтрихкодыУпаковок(
		ШтрихкодыУпаковок,
		ПараметрыСканирования);
	
	КлючеваяОперацияИмя = "МРЦ.ПолучитьШтрихкодыУпаковокСМРЦ";
	ВесЗамера = ШтрихкодыУпаковок.Количество();
	ОписаниеЛога = Новый Структура;
	ОписаниеЛога.Вставить("Метод", "ПолучитьШтрихкодыУпаковокСМРЦ");
	ОписаниеЛога.Вставить("КоличествоМаркированныхТоваров", ВложенныеШтрихкодыУпаковок.МаркированныеТовары.Количество());
	
	Если ВложенныеШтрихкодыУпаковок.МаркированныеТовары.Количество() = 0 Тогда
		ОписаниеЛога.Вставить("Точка", 1);
		ОценкаПроизводительности.ЗакончитьЗамерВремени(КлючеваяОперацияИмя, 
			НачалоЗамера,
			ВесЗамера, 
			ЗаписатьЗначениеJSON(ОписаниеЛога));
		Возврат ШтрихкодыУпаковокСМРЦ;
	КонецЕсли;
	
	Для Каждого СтрокаМаркированныеТовары Из ВложенныеШтрихкодыУпаковок.МаркированныеТовары Цикл
		Если Не КонструкторИСМПОбщегоНазначенияКлиентСервер.ДоступноПолеМРЦ(СтрокаМаркированныеТовары.ВидПродукции)
			Или СтрокаМаркированныеТовары.СтрокаДерева = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		СтрокаТЧ = ШтрихкодыУпаковокСМРЦ.Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаТЧ, СтрокаМаркированныеТовары);
		
		СтрокаТЧ.ВидПродукцииИС = СтрокаМаркированныеТовары.ВидПродукции;
		СтрокаТЧ.Количество     = СтрокаМаркированныеТовары.Количество;
		СтрокаТЧ.МРЦ = Окр(СтрокаМаркированныеТовары.СтрокаДерева.МРЦ / СтрокаМаркированныеТовары.Количество, 2);
	КонецЦикла;
	
	Если БезШтрихкодовУпаковок Тогда
		ШтрихкодыУпаковокСМРЦ.Свернуть("Номенклатура, Характеристика, Серия, МРЦ, ВидПродукцииИС", "Количество");
	Иначе
		ШтрихкодыУпаковокСМРЦ.Свернуть("Номенклатура, Характеристика, Серия, МРЦ, ВидПродукцииИС, ШтрихкодУпаковки", "Количество");
	КонецЕсли;
	
	ОписаниеЛога.Вставить("Точка", 3);
	ОценкаПроизводительности.ЗакончитьЗамерВремени(КлючеваяОперацияИмя, 
		НачалоЗамера,
		ВесЗамера, 
		ЗаписатьЗначениеJSON(ОписаниеЛога));
	
	Возврат ШтрихкодыУпаковокСМРЦ;
	
КонецФункции

// Проверить штрихкоды упаковок на минимальную цену.
// 
// Параметры:
//  Контекст - ФормаКлиентскогоПриложения, ДокументСсылка.РеализацияТоваровУслуг - Форма или документ для проверки
//  ШтрихкодыУпаковок - Массив Из СправочникСсылка.ШтрихкодыУпаковокТоваров - Штрихкоды упаковок
//  ПараметрыСканирования - См. ШтрихкодированиеОбщегоНазначенияИСКлиентСервер.БазовыеПараметрыСканирования
//  СообщитьОбОшибках - Булево - Сообщать об ошибках, если Истина
//  УдалитьНекорректныеШтрихкодыУпаковок - Булево - Удалять из документа некорректные штрихкоды упаковок, если Истина
// 
// Возвращаемое значение:
//  Булево - Истина, если нет КМ с МРЦ, не прошедшую сверку с ЕМРЦ
Функция ПроверитьШтрихкодыУпаковокНаМинимальнуюЦену(Контекст, ШтрихкодыУпаковок, ПараметрыСканирования,
	СообщитьОбОшибках = Ложь, УдалитьНекорректныеШтрихкодыУпаковок = Ложь) Экспорт
	
	РезультатПроверки = Истина;
	
	НачалоЗамера = ОценкаПроизводительности.НачатьЗамерВремени();
	
	ТаблицаШтрихкодыУпаковок = Новый ТаблицаЗначений;
	ТаблицаШтрихкодыУпаковок.Колонки.Добавить("Штрихкод");
	Для Каждого СтрокаШтрихкодовУпаковок Из ШтрихкодыУпаковок Цикл
		НоваяСтрока = ТаблицаШтрихкодыУпаковок.Добавить();
		НоваяСтрока.Штрихкод = СтрокаШтрихкодовУпаковок;
	КонецЦикла;
	
	РезультатыПроверкиПоТабачнойПродукции = ОбщегоНазначенияИС.МинимальныеЦеныПодакцизныхТоваров(
		ПараметрыСканирования,,
		ТаблицаШтрихкодыУпаковок).РезультатыПроверкиПоТабачнойПродукции;
	
	ТабачнаяПродукцияКУдалениюКМ = Новый Массив;
	
	Для Каждого СтрокаРезультатаПроверкиМинимальныхЦен Из РезультатыПроверкиПоТабачнойПродукции Цикл
		
		Если Не СтрокаРезультатаПроверкиМинимальныхЦен.НарушениеМРЦ Тогда
			Продолжить;
		КонецЕсли;
		
		КоэффициентПересчетаИзУпаковки
			= СтрокаРезультатаПроверкиМинимальныхЦен.МинимальнаяРозничнаяЦенаУпаковки
			/ СтрокаРезультатаПроверкиМинимальныхЦен.МинимальнаяРозничнаяЦена;
		КоэффициентПересчетаИзУпаковки = Окр(КоэффициентПересчетаИзУпаковки, 0);
		
		НаименованиеТовара = НоменклатураКлиентСервер.ПредставлениеНоменклатурыДляПечати(
			Строка(СтрокаРезультатаПроверкиМинимальныхЦен.Номенклатура),
			Строка(СтрокаРезультатаПроверкиМинимальныхЦен.Характеристика),,
			Строка(СтрокаРезультатаПроверкиМинимальныхЦен.Серия));
		
		Если СообщитьОбОшибках Тогда
			
			Шаблон = Нстр("ru = 'Для ""%1"" подобран КМ ""%2"" со значением МРЦ ""%3"" меньше ЕМРЦ ""%4"".%5'");
			ТекстСообщения = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
				Шаблон,
				НаименованиеТовара,
				СтрокаРезультатаПроверкиМинимальныхЦен.КодМаркировки,
				СтрокаРезультатаПроверкиМинимальныхЦен.МРЦ / КоэффициентПересчетаИзУпаковки,
				СтрокаРезультатаПроверкиМинимальныхЦен.МинимальнаяРозничнаяЦена,
				" " + ?(УдалитьНекорректныеШтрихкодыУпаковок, Нстр("ru = 'КМ по товару удалены.'"), ""));
			ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);
			
		КонецЕсли;
		
		Если УдалитьНекорректныеШтрихкодыУпаковок
			И ТипЗнч(Контекст) = Тип("ФормаКлиентскогоПриложения") Тогда
			
			Если ТабачнаяПродукцияКУдалениюКМ.Найти(СтрокаРезультатаПроверкиМинимальныхЦен.Номенклатура) = Неопределено Тогда
				ТабачнаяПродукцияКУдалениюКМ.Добавить(СтрокаРезультатаПроверкиМинимальныхЦен.Номенклатура);
			КонецЕсли;
			
		КонецЕсли;
		
		РезультатПроверки = Ложь;
		
	КонецЦикла;
	
	Если УдалитьНекорректныеШтрихкодыУпаковок И ТабачнаяПродукцияКУдалениюКМ.Количество() > 0 Тогда
		
		ИмяТаблицыШтрихкодовУпаковок = РозничныеПродажиКлиентСерверЛокализация.ТаблицаШтрихкодовПоФормеМРЦ(
			Контекст.ИмяФормы);
		ТаблицаШтрихкодовУпаковок = Контекст.Объект[ИмяТаблицыШтрихкодовУпаковок]; // ТаблицаЗначений
		
		Запрос = Новый Запрос;
		Запрос.Текст =
		"ВЫБРАТЬ
		|	ВЫРАЗИТЬ(&ИмяКолонкиШтрихкодаУпаковки КАК Справочник.ШтрихкодыУпаковокТоваров) КАК ШтрихкодУпаковки
		|ПОМЕСТИТЬ ШтрихкодыУпаковок
		|ИЗ
		|	&ШтрихкодыУпаковок КАК ШтрихкодыУпаковок
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ШтрихкодыУпаковок.ШтрихкодУпаковки КАК ШтрихкодУпаковки
		|ИЗ
		|	ШтрихкодыУпаковок КАК ШтрихкодыУпаковок
		|ГДЕ
		|	ШтрихкодыУпаковок.ШтрихкодУпаковки.Номенклатура В (&НоменклатураОтбора)";
		Запрос.УстановитьПараметр("ШтрихкодыУпаковок", ТаблицаШтрихкодовУпаковок.Выгрузить());
		Запрос.УстановитьПараметр("НоменклатураОтбора", ТабачнаяПродукцияКУдалениюКМ);
		
		ИмяКолонкиШтрихкодаУпаковки = РозничныеПродажиКлиентСерверЛокализация.РеквизитШтрихкодаПоТаблицеШтрихкодов(
			ИмяТаблицыШтрихкодовУпаковок);
		Запрос.Текст = СтрЗаменить(
			Запрос.Текст,
			"&ИмяКолонкиШтрихкодаУпаковки", "ШтрихкодыУпаковок." + ИмяКолонкиШтрихкодаУпаковки);
		
		ВыборкаЗапроса = Запрос.Выполнить().Выбрать();
		
		Пока ВыборкаЗапроса.Следующий() Цикл
			
			СтрокиШтрихкодовКУдалению = ТаблицаШтрихкодовУпаковок.НайтиСтроки(Новый Структура(
				ИмяКолонкиШтрихкодаУпаковки,
				ВыборкаЗапроса.ШтрихкодУпаковки));
			
			Для Каждого СтрокаШтрихкодаКУдалению Из СтрокиШтрихкодовКУдалению Цикл
				ТаблицаШтрихкодовУпаковок.Удалить(СтрокаШтрихкодаКУдалению);
			КонецЦикла;
			
		КонецЦикла;
		
	КонецЕсли;
	
	КлючеваяОперацияИмя = "МРЦ.ПроверкаШК";
	ОписаниеЛога = Новый Структура;
	ОписаниеЛога.Вставить("Метод", "ПроверитьШтрихкодыУпаковокНаМинимальнуюЦену");
	ОписаниеЛога.Вставить("КоличествоКМсМРЦ", ТаблицаШтрихкодыУпаковок.Количество());
	ОценкаПроизводительности.ЗакончитьЗамерВремени(КлючеваяОперацияИмя, 
		НачалоЗамера,, 
		ЗаписатьЗначениеJSON(ОписаниеЛога));
	
	Возврат РезультатПроверки;
	
КонецФункции

// Проверить корректность розничной цены в РМК по МРЦ подобранных КМ.
// 
// Параметры:
//  ТоварыДокумента - ТаблицаЗначений - Товары документа
//  ШтрихкодыУпаковокСМРЦ - ТаблицаЗначений - Штрихкоды упаковок СМРЦ:
// * Номенклатура - СправочникСсылка.Номенклатура - 
// * Характеристика - СправочникСсылка.ХарактеристикиНоменклатуры - 
// * Серия - СправочникСсылка.СерииНоменклатуры - 
// * МРЦ - Число - 
// * ВидПродукцииИС - СправочникСсылка.КлючиВидовПродукцииИС - 
// * ШтрихкодУпаковки - СправочникСсылка.ШтрихкодыУпаковокТоваров - 
// * Количество - Число - Количество
//  ЦенаВключаетНДС - Булево - Цена включает НДС
//  СообщитьОбОшибках - Булево - Сообщить об ошибках
// 
// Возвращаемое значение:
//  Булево - Истина, если розничные цены соответствуют МРЦ
Функция ПроверитьКорректностьРозничнойЦеныПоМРЦ(ТоварыДокумента, ШтрихкодыУпаковокСМРЦ, ЦенаВключаетНДС = Истина,
	СообщитьОбОшибках = Истина) Экспорт
	
	РезультатПроверки = Истина;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ТоварыДокумента.НомерСтроки,
	|	ВЫРАЗИТЬ(ТоварыДокумента.Номенклатура КАК Справочник.Номенклатура) КАК Номенклатура,
	|	ВЫРАЗИТЬ(ТоварыДокумента.Характеристика КАК Справочник.ХарактеристикиНоменклатуры) КАК Характеристика,
	|	ВЫРАЗИТЬ(ТоварыДокумента.Серия КАК Справочник.СерииНоменклатуры) КАК Серия,
	|	ВЫРАЗИТЬ(ТоварыДокумента.Цена КАК ЧИСЛО(31, 2)) КАК Цена,
	|	ВЫРАЗИТЬ(&СуммаСНДС КАК ЧИСЛО(31, 2)) КАК Сумма,
	|	ВЫРАЗИТЬ(ТоварыДокумента.ВидПродукцииИС КАК Справочник.КлючиВидовПродукцииИС) КАК ВидПродукцииИС,
	|	ВЫРАЗИТЬ(ТоварыДокумента.Количество КАК ЧИСЛО(31, 3)) КАК Количество
	|ПОМЕСТИТЬ ТоварыДокумента
	|ИЗ
	|	&ТоварыДокумента КАК ТоварыДокумента
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	МИНИМУМ(ТоварыДокумента.НомерСтроки) КАК НомерСтроки,
	|	ТоварыДокумента.Номенклатура,
	|	ТоварыДокумента.Характеристика,
	|	ТоварыДокумента.Серия,
	|	ВЫРАЗИТЬ(ВЫБОР
	|		КОГДА &ЦенаВключаетНДС
	|			ТОГДА ТоварыДокумента.Цена
	|		КОГДА ТоварыДокумента.Количество = 0
	|			ТОГДА ТоварыДокумента.Сумма
	|		ИНАЧЕ ТоварыДокумента.Сумма / ТоварыДокумента.Количество
	|	КОНЕЦ КАК ЧИСЛО(31, 2)) КАК Цена,
	|	ТоварыДокумента.ВидПродукцииИС,
	|	СУММА(ТоварыДокумента.Количество) КАК Количество
	|ПОМЕСТИТЬ ТоварыДокументаСМРЦ
	|ИЗ
	|	ТоварыДокумента КАК ТоварыДокумента
	|ГДЕ
	|	ТоварыДокумента.ВидПродукцииИС.ВидПродукцииГИСМТ В (&ВидыПродукцииИС)
	|	И ТоварыДокумента.Цена > 0
	|СГРУППИРОВАТЬ ПО
	|	ТоварыДокумента.Номенклатура,
	|	ТоварыДокумента.Характеристика,
	|	ТоварыДокумента.Серия,
	|	ВЫРАЗИТЬ(ВЫБОР
	|		КОГДА &ЦенаВключаетНДС
	|			ТОГДА ТоварыДокумента.Цена
	|		КОГДА ТоварыДокумента.Количество = 0
	|			ТОГДА ТоварыДокумента.Сумма
	|		ИНАЧЕ ТоварыДокумента.Сумма / ТоварыДокумента.Количество
	|	КОНЕЦ КАК ЧИСЛО(31, 2)),
	|	ТоварыДокумента.ВидПродукцииИС
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Номенклатура,
	|	Характеристика,
	|	Серия,
	|	Цена
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВЫРАЗИТЬ(ШтрихкодыУпаковокСМРЦ.Номенклатура КАК Справочник.Номенклатура) КАК Номенклатура,
	|	ВЫРАЗИТЬ(ШтрихкодыУпаковокСМРЦ.Характеристика КАК Справочник.ХарактеристикиНоменклатуры) КАК Характеристика,
	|	ВЫРАЗИТЬ(ШтрихкодыУпаковокСМРЦ.Серия КАК Справочник.СерииНоменклатуры) КАК Серия,
	|	ВЫРАЗИТЬ(ШтрихкодыУпаковокСМРЦ.МРЦ КАК ЧИСЛО(31, 2)) КАК МРЦ,
	|	ВЫРАЗИТЬ(ШтрихкодыУпаковокСМРЦ.ВидПродукцииИС КАК Справочник.КлючиВидовПродукцииИС) КАК ВидПродукцииИС,
	|	ВЫРАЗИТЬ(ШтрихкодыУпаковокСМРЦ.Количество КАК ЧИСЛО(31, 3)) КАК Количество
	|ПОМЕСТИТЬ ШтрихкодыУпаковокСМРЦ
	|ИЗ
	|	&ШтрихкодыУпаковокСМРЦ КАК ШтрихкодыУпаковокСМРЦ
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Номенклатура,
	|	Характеристика,
	|	Серия,
	|	МРЦ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ШтрихкодыУпаковокСМРЦ.Номенклатура,
	|	ШтрихкодыУпаковокСМРЦ.Характеристика,
	|	ШтрихкодыУпаковокСМРЦ.Серия,
	|	ШтрихкодыУпаковокСМРЦ.МРЦ КАК МРЦ
	|ИЗ
	|	ШтрихкодыУпаковокСМРЦ КАК ШтрихкодыУпаковокСМРЦ
	|		ЛЕВОЕ СОЕДИНЕНИЕ ТоварыДокументаСМРЦ КАК ТоварыДокументаСМРЦ
	|		ПО ШтрихкодыУпаковокСМРЦ.Номенклатура = ТоварыДокументаСМРЦ.Номенклатура
	|		И ШтрихкодыУпаковокСМРЦ.Характеристика = ТоварыДокументаСМРЦ.Характеристика
	|		И ШтрихкодыУпаковокСМРЦ.Серия = ТоварыДокументаСМРЦ.Серия
	|		И ШтрихкодыУпаковокСМРЦ.МРЦ = ТоварыДокументаСМРЦ.Цена
	|ГДЕ
	|	ЕСТЬNULL(ТоварыДокументаСМРЦ.Количество, 0) - ЕСТЬNULL(ШтрихкодыУпаковокСМРЦ.Количество, 0) < 0
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТоварыДокументаСМРЦ.НомерСтроки КАК НомерСтроки,
	|	ЕСТЬNULL(ТоварыДокументаСМРЦ.Номенклатура, ШтрихкодыУпаковокСМРЦ.Номенклатура) КАК Номенклатура,
	|	ЕСТЬNULL(ТоварыДокументаСМРЦ.Номенклатура.Наименование, ШтрихкодыУпаковокСМРЦ.Номенклатура.Наименование) КАК НоменклатураНаименование,
	|	ЕСТЬNULL(ТоварыДокументаСМРЦ.Характеристика, ШтрихкодыУпаковокСМРЦ.Характеристика) КАК Характеристика,
	|	ЕСТЬNULL(ТоварыДокументаСМРЦ.Характеристика.Наименование, ШтрихкодыУпаковокСМРЦ.Характеристика.Наименование) КАК ХарактеристикаНаименование,
	|	ЕСТЬNULL(ТоварыДокументаСМРЦ.Серия, ШтрихкодыУпаковокСМРЦ.Серия) КАК Серия,
	|	ЕСТЬNULL(ТоварыДокументаСМРЦ.Серия.Наименование, ШтрихкодыУпаковокСМРЦ.Серия.Наименование) КАК СерияНаименование,
	|	ЕСТЬNULL(ТоварыДокументаСМРЦ.Цена, ШтрихкодыУпаковокСМРЦ.МРЦ) КАК ЦенаМРЦ,
	|	ЕСТЬNULL(ТоварыДокументаСМРЦ.ВидПродукцииИС, ШтрихкодыУпаковокСМРЦ.ВидПродукцииИС) КАК ВидПродукцииИС,
	|	ЕСТЬNULL(ТоварыДокументаСМРЦ.Количество, ШтрихкодыУпаковокСМРЦ.Количество) КАК Количество,
	|	ЕСТЬNULL(ТоварыДокументаСМРЦ.Количество, 0) - ЕСТЬNULL(ШтрихкодыУпаковокСМРЦ.Количество, 0) КАК Расхождение
	|ИЗ
	|	ТоварыДокументаСМРЦ КАК ТоварыДокументаСМРЦ
	|		ПОЛНОЕ СОЕДИНЕНИЕ ШтрихкодыУпаковокСМРЦ КАК ШтрихкодыУпаковокСМРЦ
	|		ПО ШтрихкодыУпаковокСМРЦ.Номенклатура = ТоварыДокументаСМРЦ.Номенклатура
	|		И ШтрихкодыУпаковокСМРЦ.Характеристика = ТоварыДокументаСМРЦ.Характеристика
	|		И ШтрихкодыУпаковокСМРЦ.Серия = ТоварыДокументаСМРЦ.Серия
	|		И ШтрихкодыУпаковокСМРЦ.МРЦ = ТоварыДокументаСМРЦ.Цена
	|ГДЕ
	|	НЕ ЕСТЬNULL(ТоварыДокументаСМРЦ.Количество, 0) - ЕСТЬNULL(ШтрихкодыУпаковокСМРЦ.Количество, 0) = 0
	|
	|УПОРЯДОЧИТЬ ПО
	|	НомерСтроки";
	Запрос.УстановитьПараметр("ТоварыДокумента", ТоварыДокумента);
	Запрос.УстановитьПараметр("ШтрихкодыУпаковокСМРЦ", ШтрихкодыУпаковокСМРЦ);
	Запрос.УстановитьПараметр("ВидыПродукцииИС", КонструкторИСМПОбщегоНазначенияКлиентСервер.ВидыПродукцииКоторымДоступноПолеМРЦ());
	Запрос.УстановитьПараметр("ЦенаВключаетНДС", ЦенаВключаетНДС);
	
	Если ТоварыДокумента.Колонки.Найти("СуммаСНДС") = Неопределено Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&СуммаСНДС", "ТоварыДокумента.Сумма");
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&СуммаСНДС", "ТоварыДокумента.СуммаСНДС");
	КонецЕсли;
	
	ПакетЗапросов = Запрос.ВыполнитьПакет();
	
	ТаблицаЛишнихЗначенийМРЦПоТоварам = ПакетЗапросов[3].Выгрузить();
	ТаблицаЛишнихЗначенийМРЦПоТоварам.Индексы.Добавить("Номенклатура, Характеристика, Серия");
	
	ВыборкаЗапроса = ПакетЗапросов[4].Выбрать();
	
	Пока ВыборкаЗапроса.Следующий() Цикл
		
		Если ВыборкаЗапроса.Расхождение < 0 Тогда
			Продолжить;
		КонецЕсли;
		
		РезультатПроверки = Ложь;
		
		Если Не СообщитьОбОшибках Тогда
			Прервать;
		КонецЕсли;
		
		Если ВыборкаЗапроса.НомерСтроки = NULL Тогда
			Продолжить;
		КонецЕсли;
		
		НаименованиеТовара = НоменклатураКлиентСервер.ПредставлениеНоменклатурыДляПечати(
			ВыборкаЗапроса.НоменклатураНаименование,
			ВыборкаЗапроса.ХарактеристикаНаименование,,
			ВыборкаЗапроса.СерияНаименование);
		
		СтруктураОтбора = Новый Структура;
		СтруктураОтбора.Вставить("Номенклатура",   ВыборкаЗапроса.Номенклатура);
		СтруктураОтбора.Вставить("Характеристика", ВыборкаЗапроса.Характеристика);
		СтруктураОтбора.Вставить("Серия",          ВыборкаЗапроса.Серия);
		МассивЛишнихМРЦПоТовару = ТаблицаЛишнихЗначенийМРЦПоТоварам.НайтиСтроки(СтруктураОтбора);
		
		ЗначенияМРЦПоТовару = "";
		Для Каждого СтрокаМассиваЛишнихМРЦПоТовару Из МассивЛишнихМРЦПоТовару Цикл
			ЗначенияМРЦПоТовару = ЗначенияМРЦПоТовару + СтрокаМассиваЛишнихМРЦПоТовару.МРЦ + "; ";
		КонецЦикла;
		ЗначенияМРЦПоТовару = Лев(ЗначенияМРЦПоТовару, СтрДлина(ЗначенияМРЦПоТовару)-2);
		
		СтруктураОтбора = Новый Структура;
		СтруктураОтбора.Вставить("Номенклатура",   ВыборкаЗапроса.Номенклатура);
		СтруктураОтбора.Вставить("Характеристика", ВыборкаЗапроса.Характеристика);
		СтруктураОтбора.Вставить("Серия",          ВыборкаЗапроса.Серия);
		СтруктураОтбора.Вставить("Цена",          ВыборкаЗапроса.ЦенаМРЦ);
		МассивТоваровСНекорректнойЦеной = ТоварыДокумента.НайтиСтроки(СтруктураОтбора);
		
		НомерСтроки = "№";
		Для Каждого СтрокаТовараСНекорректнойЦеной Из МассивТоваровСНекорректнойЦеной Цикл
			НомерСтроки = НомерСтроки + СтрокаТовараСНекорректнойЦеной.НомерСтроки + "; №";
		КонецЦикла;
		НомерСтроки = Лев(НомерСтроки, СтрДлина(НомерСтроки)-3);
		
		Шаблон = Нстр("ru = '%1 %2 для ""%3"" цена продажи ""%4"" не соответствует МРЦ (%5) в подобранных КМ'");
		ТекстСообщения = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
			Шаблон,
			?(МассивТоваровСНекорректнойЦеной.Количество() = 1, "В строке", "В строках"),
			НомерСтроки,
			НаименованиеТовара,
			ВыборкаЗапроса.ЦенаМРЦ,
			ЗначенияМРЦПоТовару);
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);
		
	КонецЦикла;
	
	Возврат РезультатПроверки;
	
КонецФункции

// Привести цены продажи к МРЦ из подобранных КМ
// 
// Параметры:
//  Форма - ФормаКлиентскогоПриложения - Форма
//  ШтрихкодыУпаковокСМРЦ - ТаблицаЗначений - Штрихкоды упаковок СМРЦ
Процедура ПривестиЦеныПродажиКМРЦ(Форма, ШтрихкодыУпаковокСМРЦ) Экспорт
	
	ТоварыДокумента = Форма.Объект.Товары.Выгрузить(); // ТаблицаЗначений
	ТоварыДокумента.Индексы.Добавить("Номенклатура, Характеристика, Серия");
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ТоварыДокумента.НомерСтроки,
	|	ТоварыДокумента.Номенклатура,
	|	ТоварыДокумента.Характеристика,
	|	ТоварыДокумента.Серия,
	|	ТоварыДокумента.Цена,
	|	ТоварыДокумента.ВидПродукцииИС,
	|	ТоварыДокумента.Количество
	|ПОМЕСТИТЬ ТоварыДокумента
	|ИЗ
	|	&ТоварыДокумента КАК ТоварыДокумента
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТоварыДокумента.Номенклатура,
	|	ТоварыДокумента.Характеристика,
	|	ТоварыДокумента.Серия,
	|	СУММА(ТоварыДокумента.Количество) КАК Количество
	|ПОМЕСТИТЬ ТоварыДокументаУникальные
	|ИЗ
	|	ТоварыДокумента КАК ТоварыДокумента
	|ГДЕ
	|	ТоварыДокумента.ВидПродукцииИС.ВидПродукцииГИСМТ В (&ВидыПродукцииИС)
	|СГРУППИРОВАТЬ ПО
	|	ТоварыДокумента.Номенклатура,
	|	ТоварыДокумента.Характеристика,
	|	ТоварыДокумента.Серия
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Номенклатура,
	|	Характеристика,
	|	Серия
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	МИНИМУМ(ТоварыДокумента.НомерСтроки) КАК НомерСтроки,
	|	ТоварыДокумента.Номенклатура,
	|	ТоварыДокумента.Характеристика,
	|	ТоварыДокумента.Серия,
	|	ТоварыДокумента.Цена,
	|	ТоварыДокумента.ВидПродукцииИС,
	|	СУММА(ТоварыДокумента.Количество) КАК Количество
	|ПОМЕСТИТЬ ТоварыДокументаСМРЦ
	|ИЗ
	|	ТоварыДокумента КАК ТоварыДокумента
	|ГДЕ
	|	ТоварыДокумента.ВидПродукцииИС.ВидПродукцииГИСМТ В (&ВидыПродукцииИС)
	|	И ТоварыДокумента.Цена > 0
	|СГРУППИРОВАТЬ ПО
	|	ТоварыДокумента.Номенклатура,
	|	ТоварыДокумента.Характеристика,
	|	ТоварыДокумента.Серия,
	|	ТоварыДокумента.Цена,
	|	ТоварыДокумента.ВидПродукцииИС
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Номенклатура,
	|	Характеристика,
	|	Серия,
	|	Цена
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ШтрихкодыУпаковокСМРЦ.Номенклатура,
	|	ШтрихкодыУпаковокСМРЦ.Характеристика,
	|	ШтрихкодыУпаковокСМРЦ.Серия,
	|	ШтрихкодыУпаковокСМРЦ.МРЦ,
	|	ШтрихкодыУпаковокСМРЦ.ВидПродукцииИС,
	|	ШтрихкодыУпаковокСМРЦ.Количество
	|ПОМЕСТИТЬ ШтрихкодыУпаковокСМРЦ
	|ИЗ
	|	&ШтрихкодыУпаковокСМРЦ КАК ШтрихкодыУпаковокСМРЦ
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Номенклатура,
	|	Характеристика,
	|	Серия,
	|	МРЦ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЕСТЬNULL(ТоварыДокументаСМРЦ.Номенклатура, ШтрихкодыУпаковокСМРЦ.Номенклатура) КАК Номенклатура,
	|	ЕСТЬNULL(ТоварыДокументаСМРЦ.Характеристика, ШтрихкодыУпаковокСМРЦ.Характеристика) КАК Характеристика,
	|	ЕСТЬNULL(ТоварыДокументаСМРЦ.Серия, ШтрихкодыУпаковокСМРЦ.Серия) КАК Серия
	|ПОМЕСТИТЬ ТоварыСРасхождениемЦен
	|ИЗ
	|	ТоварыДокументаСМРЦ КАК ТоварыДокументаСМРЦ
	|		ПОЛНОЕ СОЕДИНЕНИЕ ШтрихкодыУпаковокСМРЦ КАК ШтрихкодыУпаковокСМРЦ
	|		ПО ШтрихкодыУпаковокСМРЦ.Номенклатура = ТоварыДокументаСМРЦ.Номенклатура
	|		И ШтрихкодыУпаковокСМРЦ.Характеристика = ТоварыДокументаСМРЦ.Характеристика
	|		И ШтрихкодыУпаковокСМРЦ.Серия = ТоварыДокументаСМРЦ.Серия
	|		И ШтрихкодыУпаковокСМРЦ.МРЦ = ТоварыДокументаСМРЦ.Цена
	|ГДЕ
	|	НЕ ЕСТЬNULL(ТоварыДокументаСМРЦ.Количество, 0) - ЕСТЬNULL(ШтрихкодыУпаковокСМРЦ.Количество, 0) = 0
	|СГРУППИРОВАТЬ ПО
	|	ЕСТЬNULL(ТоварыДокументаСМРЦ.Номенклатура, ШтрихкодыУпаковокСМРЦ.Номенклатура),
	|	ЕСТЬNULL(ТоварыДокументаСМРЦ.Характеристика, ШтрихкодыУпаковокСМРЦ.Характеристика),
	|	ЕСТЬNULL(ТоварыДокументаСМРЦ.Серия, ШтрихкодыУпаковокСМРЦ.Серия)
	|ИНДЕКСИРОВАТЬ ПО
	|	Номенклатура,
	|	Характеристика,
	|	Серия
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////|
	|ВЫБРАТЬ
	|	ТоварыДокументаУникальные.Номенклатура,
	|	ТоварыДокументаУникальные.Характеристика,
	|	ТоварыДокументаУникальные.Серия,
	|	ТоварыДокументаУникальные.Количество
	|ИЗ
	|	ТоварыДокументаУникальные КАК ТоварыДокументаУникальные
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ТоварыСРасхождениемЦен КАК ТоварыСРасхождениемЦен
	|		ПО ТоварыДокументаУникальные.Номенклатура = ТоварыСРасхождениемЦен.Номенклатура
	|			И ТоварыДокументаУникальные.Характеристика = ТоварыСРасхождениемЦен.Характеристика
	|			И ТоварыДокументаУникальные.Серия = ТоварыСРасхождениемЦен.Серия
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ШтрихкодыУпаковокСМРЦ.Номенклатура,
	|	ШтрихкодыУпаковокСМРЦ.Характеристика,
	|	ШтрихкодыУпаковокСМРЦ.Серия,
	|	ШтрихкодыУпаковокСМРЦ.МРЦ,
	|	ШтрихкодыУпаковокСМРЦ.Количество
	|ИЗ
	|	ШтрихкодыУпаковокСМРЦ КАК ШтрихкодыУпаковокСМРЦ
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ТоварыСРасхождениемЦен КАК ТоварыСРасхождениемЦен
	|		ПО ШтрихкодыУпаковокСМРЦ.Номенклатура = ТоварыСРасхождениемЦен.Номенклатура
	|			И ШтрихкодыУпаковокСМРЦ.Характеристика = ТоварыСРасхождениемЦен.Характеристика
	|			И ШтрихкодыУпаковокСМРЦ.Серия = ТоварыСРасхождениемЦен.Серия
	|;";
	Запрос.УстановитьПараметр("ТоварыДокумента", ТоварыДокумента);
	Запрос.УстановитьПараметр("ШтрихкодыУпаковокСМРЦ", ШтрихкодыУпаковокСМРЦ);
	Запрос.УстановитьПараметр("ВидыПродукцииИС", КонструкторИСМПОбщегоНазначенияКлиентСервер.ВидыПродукцииКоторымДоступноПолеМРЦ());
	
	ПакетЗапросов = Запрос.ВыполнитьПакет();
	
	ТоварыДокументаУникальные = ПакетЗапросов[5].Выгрузить();
	ТоварыДокументаУникальные.Индексы.Добавить("Номенклатура, Характеристика, Серия");
	
	ШтрихкодыУпаковокСМРЦ = ПакетЗапросов[6].Выгрузить();
	ШтрихкодыУпаковокСМРЦ.Индексы.Добавить("Номенклатура, Характеристика, Серия");
	
	НачальнаяСтрокаСТоваром = Неопределено;
	ТекущийНомерСтрокиСТоваром = 0;
	КоличествоОстатокКРаспределению = 0;
	
	МассивИзмененныхСтрок = Новый Массив;
	
	Для Каждого СтрокаТоварыДокументаУникальные Из ТоварыДокументаУникальные Цикл
		
		СтруктураОтбора = Новый Структура;
		СтруктураОтбора.Вставить("Номенклатура",   СтрокаТоварыДокументаУникальные.Номенклатура);
		СтруктураОтбора.Вставить("Характеристика", СтрокаТоварыДокументаУникальные.Характеристика);
		СтруктураОтбора.Вставить("Серия",          СтрокаТоварыДокументаУникальные.Серия);
		МассивСтрокПоТовару = ТоварыДокумента.НайтиСтроки(СтруктураОтбора);
		
		НачальнаяСтрокаСТоваром = МассивСтрокПоТовару[0];
		ТекущийНомерСтрокиСТоваром = НачальнаяСтрокаСТоваром.НомерСтроки;
		КоличествоОстатокКРаспределению = СтрокаТоварыДокументаУникальные.Количество;
		
		КоличествоСтрок = МассивСтрокПоТовару.Количество();
		Для а = 1 По КоличествоСтрок Цикл
			СтрокаКУдалению = МассивСтрокПоТовару[КоличествоСтрок-а];
			Форма.Объект.Товары.Удалить(СтрокаКУдалению.НомерСтроки-1);
		КонецЦикла;
		
		Для Каждого СтрокаШтрихкодыУпаковокСМРЦ Из ШтрихкодыУпаковокСМРЦ Цикл
			
			СтрокаТЧ = Форма.Объект.Товары.Вставить(ТекущийНомерСтрокиСТоваром-1);
			ЗаполнитьЗначенияСвойств(СтрокаТЧ, НачальнаяСтрокаСТоваром);
			
			СтрокаТЧ.Упаковка = Справочники.УпаковкиЕдиницыИзмерения.ПустаяСсылка();
			СтрокаТЧ.Количество = СтрокаШтрихкодыУпаковокСМРЦ.Количество;
			СтрокаТЧ.КоличествоУпаковок = СтрокаШтрихкодыУпаковокСМРЦ.Количество;
			СтрокаТЧ.Цена = СтрокаШтрихкодыУпаковокСМРЦ.МРЦ;
			
			МассивИзмененныхСтрок.Добавить(СтрокаТЧ);
			
			ТекущийНомерСтрокиСТоваром = ТекущийНомерСтрокиСТоваром + 1;
			КоличествоОстатокКРаспределению = КоличествоОстатокКРаспределению - СтрокаТЧ.Количество;
			
		КонецЦикла;
		
		Если КоличествоОстатокКРаспределению > 0 Тогда
			
			СтрокаТЧ = Форма.Объект.Товары.Вставить(НачальнаяСтрокаСТоваром.НомерСтроки-1);
			ЗаполнитьЗначенияСвойств(СтрокаТЧ, НачальнаяСтрокаСТоваром);
			
			СтрокаТЧ.Упаковка = Справочники.УпаковкиЕдиницыИзмерения.ПустаяСсылка();
			СтрокаТЧ.Количество = КоличествоОстатокКРаспределению;
			СтрокаТЧ.КоличествоУпаковок = КоличествоОстатокКРаспределению;
			СтрокаТЧ.Цена = 0;
			
			МассивИзмененныхСтрок.Добавить(СтрокаТЧ);
			
		КонецЕсли;
		
	КонецЦикла;
	
	Если МассивИзмененныхСтрок.Количество() > 0 Тогда
		
		СтруктураПересчетаСуммы = ПакетнаяОбработкаТабличнойЧастиКлиентСервер.ПараметрыПересчетаСуммыНДСВСтрокеТЧ(Форма.Объект);
		
		СтруктураДействий = Новый Структура;
		СтруктураДействий.Вставить("ПересчитатьСумму");
		Если Не Форма.ИмяФормы = "Документ.ЧекККМВозврат.Форма.ФормаДокументаРМК" Тогда
			СтруктураДействий.Вставить("ПересчитатьСуммуРучнойСкидки");
			СтруктураДействий.Вставить("ПересчитатьСуммуСУчетомРучнойСкидки", Новый Структура("Очищать", Ложь));
			СтруктураДействий.Вставить("ПересчитатьСуммуСУчетомАвтоматическойСкидки", Новый Структура("Очищать", Ложь));
			СтруктураДействий.Вставить("ПересчитатьСуммуСУчетомСкидкиБонуснымиБаллами");
		КонецЕсли;
		СтруктураДействий.Вставить("ПересчитатьСуммуНДС", СтруктураПересчетаСуммы);
		Если Не Форма.ИмяФормы = "Документ.ЧекККМ.Форма.ФормаДокументаРМК"
			И Не Форма.ИмяФормы = "Документ.ЧекККМВозврат.Форма.ФормаДокументаРМК" Тогда
			СтруктураДействий.Вставить("ПересчитатьСуммуСНДС", СтруктураПересчетаСуммы);
		КонецЕсли;
		
		Если Форма.ИмяФормы = "Документ.РеализацияТоваровУслуг.Форма.ФормаДокумента" Тогда
			СтруктураДействий.Вставить("ОчиститьСуммуВзаиморасчетов");
			
			ПараметрыЗаполненияСуммыНДСРеглУпр = ПакетнаяОбработкаТабличнойЧастиКлиентСервер.ПараметрыЗаполненияСуммыНДСРеглУпр(
				Форма.Объект.Валюта,
				Форма.ВалютаРегламентированногоУчета,
				Форма.ВалютаУправленческогоУчета);
			СтруктураДействий.Вставить("УстановитьСуммуНДСРеглУпр", ПараметрыЗаполненияСуммыНДСРеглУпр);
		КонецЕсли;
		
		Если Не Форма.ИмяФормы = "Документ.ЧекККМ.Форма.ФормаДокументаРМК"
			И Не Форма.ИмяФормы = "Документ.ЧекККМВозврат.Форма.ФормаДокументаРМК" Тогда
			ЗависимыеРеквизиты = Новый Структура(
				"БезВозвратнойТары",
				"Сумма,СуммаНДС,СуммаСНДС,СуммаАвтоматическойСкидки,СуммаРучнойСкидки,СуммаБонусныхБалловКСписаниюВВалюте");
			СтруктураДействий.Вставить("ЗаполнитьДубликатыЗависимыхРеквизитов", ЗависимыеРеквизиты);
		КонецЕсли;
		
		ПакетнаяОбработкаТабличнойЧастиСервер.ОбработатьСтрокиТЧ(
			МассивИзмененныхСтрок,
			СтруктураДействий,
			Форма.Объект.Товары);
	
	КонецЕсли;
	
	// Дополнительно установить флаг МРЦ для товаров с корректной ценой
	Для Каждого СтрокаТовары Из Форма.Объект.Товары Цикл
		
		Если Не КонструкторИСМПОбщегоНазначенияКлиентСервер.ДоступноПолеМРЦ(СтрокаТовары.ВидПродукцииИС) Тогда
			Продолжить;
		КонецЕсли;
		
		ИмяРеквизитаУстановленаМРЦ = РозничныеПродажиКлиентСерверЛокализация.ИмяРеквизитаУстановленаМРЦ();
		Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(СтрокаТовары, ИмяРеквизитаУстановленаМРЦ)
			И ЗначениеЗаполнено(СтрокаТовары.Цена) Тогда
			СтрокаТовары[ИмяРеквизитаУстановленаМРЦ] = Истина;
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

// Привести цены продажи к МРЦ из подобранных КМ после закрытия формы подбора и проверки 
// 
// Параметры:
//  ДокументОбъект - ДокументОбъект.РеализацияТоваровУслуг - Документ, в котором исправляются цены
//  ТоварыСМРЦ - ТаблицаЗначений - Товары с МРЦ из подобранных КМ
Процедура ПривестиЦеныВДокументеКМРЦ(ДокументОбъект, ТоварыСМРЦ) Экспорт
	
	ДатаДокумента = ДокументОбъект.Дата;
	Если Не ЗначениеЗаполнено(ДатаДокумента) Тогда
		ДатаДокумента = ТекущаяДатаСеанса();
	КонецЕсли;
	
	Если Не КонтролироватьЦенуПродажиТабачнойПродукции(ДатаДокумента) Тогда
		Возврат;
	КонецЕсли;
	
	ОписанияGTIN = РегистрыСведений.ОписаниеGTINИС.ПолучитьОписание(ТоварыСМРЦ.ВыгрузитьКолонку("GTIN"));
	
	Для Каждого СтрокаТоваровСМРЦ Из ТоварыСМРЦ Цикл
		
		ОписаниеGTIN = ОписанияGTIN[СтрокаТоваровСМРЦ.GTIN];
		Если ОписаниеGTIN = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		Если ОписаниеGTIN.КоличествоПотребительскихУпаковок = 0
			Или ОписаниеGTIN.КоличествоПотребительскихУпаковок = 1 Тогда
			Продолжить;
		КонецЕсли;
		
		СтрокаТоваровСМРЦ.МРЦ = Окр(СтрокаТоваровСМРЦ.МРЦ / ОписаниеGTIN.КоличествоПотребительскихУпаковок, 2);
		
	КонецЦикла;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ВЫРАЗИТЬ(Товары.Номенклатура КАК Справочник.Номенклатура) КАК Номенклатура,
	|	ВЫРАЗИТЬ(Товары.Характеристика КАК Справочник.ХарактеристикиНоменклатуры) КАК Характеристика,
	|	ВЫРАЗИТЬ(Товары.Серия КАК Справочник.СерииНоменклатуры) КАК Серия,
	|	ВЫРАЗИТЬ(Товары.Количество КАК ЧИСЛО(31, 3)) КАК Количество,
	|	ВЫРАЗИТЬ(Товары.Цена КАК ЧИСЛО(31, 2)) КАК Цена,
	|	ВЫРАЗИТЬ(Товары.СтавкаНДС КАК Справочник.СтавкиНДС) КАК СтавкаНДС
	|ПОМЕСТИТЬ ТоварыПредварительно
	|ИЗ
	|	&Товары КАК Товары
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////1
	|ВЫБРАТЬ
	|	Товары.Номенклатура,
	|	Товары.Характеристика,
	|	Товары.Серия,
	|	СУММА(Товары.Количество) КАК Количество,
	|	Товары.Цена
	|ПОМЕСТИТЬ Товары
	|ИЗ
	|	ТоварыПредварительно КАК Товары
	|СГРУППИРОВАТЬ ПО
	|	Товары.Номенклатура,
	|	Товары.Характеристика,
	|	Товары.Серия,
	|	Товары.Цена
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////2
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Товары.Номенклатура,
	|	Товары.Характеристика,
	|	ВЫБОР
	|		КОГДА Товары.Серия = ЗНАЧЕНИЕ(Справочник.СерииНоменклатуры.ПустаяСсылка)
	|			ТОГДА ЛОЖЬ
	|		ИНАЧЕ ИСТИНА
	|	КОНЕЦ КАК ЕстьСерия
	|ПОМЕСТИТЬ ТоварыСерии
	|ИЗ
	|	Товары КАК Товары
	|СГРУППИРОВАТЬ ПО
	|	Товары.Номенклатура,
	|	Товары.Характеристика,
	|	ВЫБОР
	|		КОГДА Товары.Серия = ЗНАЧЕНИЕ(Справочник.СерииНоменклатуры.ПустаяСсылка)
	|			ТОГДА ЛОЖЬ
	|		ИНАЧЕ ИСТИНА
	|	КОНЕЦ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////3
	|ВЫБРАТЬ
	|	ВЫРАЗИТЬ(Подобрано.Номенклатура КАК Справочник.Номенклатура) КАК Номенклатура,
	|	ВЫРАЗИТЬ(Подобрано.Характеристика КАК Справочник.ХарактеристикиНоменклатуры) КАК Характеристика,
	|	ВЫРАЗИТЬ(Подобрано.Серия КАК Справочник.СерииНоменклатуры) КАК Серия,
	|	ВЫРАЗИТЬ(Подобрано.КоличествоПодобрано КАК ЧИСЛО(31, 3)) КАК Количество,
	|	ВЫРАЗИТЬ(Подобрано.МРЦ КАК ЧИСЛО(31, 2)) КАК МРЦ
	|ПОМЕСТИТЬ ПодобраноПредварительно
	|ИЗ
	|	&Подобрано КАК Подобрано
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////3
	|ВЫБРАТЬ
	|	Подобрано.Номенклатура,
	|	Подобрано.Характеристика,
	|	ВЫБОР
	|		КОГДА ТоварыСерии.ЕстьСерия = ИСТИНА
	|			ТОГДА Подобрано.Серия
	|		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.СерииНоменклатуры.ПустаяСсылка)
	|	КОНЕЦ КАК Серия,
	|	СУММА(Подобрано.Количество) КАК Количество,
	|	Подобрано.МРЦ
	|ПОМЕСТИТЬ Подобрано
	|ИЗ
	|	ПодобраноПредварительно КАК Подобрано
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ТоварыСерии КАК ТоварыСерии
	|		ПО Подобрано.Номенклатура = ТоварыСерии.Номенклатура
	|			И Подобрано.Характеристика = ТоварыСерии.Характеристика
	|ГДЕ
	|	Подобрано.МРЦ > 0
	|СГРУППИРОВАТЬ ПО
	|	Подобрано.Номенклатура,
	|	Подобрано.Характеристика,
	|	ВЫБОР
	|		КОГДА ТоварыСерии.ЕстьСерия = ИСТИНА
	|			ТОГДА Подобрано.Серия
	|		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.СерииНоменклатуры.ПустаяСсылка)
	|	КОНЕЦ,
	|	Подобрано.МРЦ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////4
	|ВЫБРАТЬ
	|	Товары.Номенклатура,
	|	Товары.Характеристика,
	|	Товары.Серия,
	|	Товары.Количество,
	|	Товары.Цена,
	|	0 КАК МРЦ
	|ПОМЕСТИТЬ МаркируемыеТовары
	|ИЗ
	|	Товары КАК Товары
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	Подобрано.Номенклатура,
	|	Подобрано.Характеристика,
	|	Подобрано.Серия,
	|	-Подобрано.Количество,
	|	0 КАК Цена,
	|	Подобрано.МРЦ
	|ИЗ
	|	Подобрано КАК Подобрано
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////5
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Товары.СтавкаНДС,
	|	ЕСТЬNULL(СтавкиНДС.Ставка, 0) КАК Ставка
	|ИЗ
	|	ТоварыПредварительно КАК Товары
	|	ЛЕВОЕ СОЕДИНЕНИЕ Справочник.СтавкиНДС КАК СтавкиНДС
	|	ПО Товары.СтавкаНДС = СтавкиНДС.Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////6
	|ВЫБРАТЬ
	|	Товары.Номенклатура,
	|	Товары.Характеристика,
	|	Товары.Серия,
	|	СУММА(Товары.Количество) КАК Недостача,
	|	Товары.Цена,
	|	Товары.МРЦ
	|ПОМЕСТИТЬ РезультатСверкиЦеныСМРЦ
	|ИЗ
	|	МаркируемыеТовары КАК Товары
	|СГРУППИРОВАТЬ ПО
	|	Товары.Номенклатура,
	|	Товары.Характеристика,
	|	Товары.Серия,
	|	Товары.Цена,
	|	Товары.МРЦ
	|ИМЕЮЩИЕ
	|	СУММА(Товары.Количество) <> 0
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////5
	|ВЫБРАТЬ
	|	Товары.Номенклатура,
	|	Товары.Характеристика,
	|	Товары.Серия,
	|	Товары.Недостача,
	|	Товары.Цена
	|ИЗ
	|	РезультатСверкиЦеныСМРЦ КАК Товары
	|ГДЕ
	|	Товары.Недостача > 0
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////5
	|ВЫБРАТЬ
	|	Товары.Номенклатура,
	|	Товары.Характеристика,
	|	Товары.Серия,
	|	-Товары.Недостача КАК Недостача,
	|	Товары.МРЦ
	|ИЗ
	|	РезультатСверкиЦеныСМРЦ КАК Товары
	|ГДЕ
	|	Товары.Недостача < 0
	|";
	Запрос.УстановитьПараметр("Товары", ДокументОбъект.Товары.Выгрузить());
	Запрос.УстановитьПараметр("Подобрано", ТоварыСМРЦ);
	
	ПакетЗапросов = Запрос.ВыполнитьПакет();
	Количество = ПакетЗапросов.ВГраница();
	
	РасхожденияТовары = ПакетЗапросов[Количество-1].Выгрузить();
	
	РасхожденияПодобрано = ПакетЗапросов[Количество].Выгрузить();
	РасхожденияПодобрано.Индексы.Добавить("Номенклатура, Характеристика, Серия");
	
	Если РасхожденияТовары.Количество() = 0
		И РасхожденияПодобрано.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	СтавкиНДССоЗначениями = ПакетЗапросов[Количество-3].Выгрузить();
	
	СтруктураОтбораТовары = Новый Структура;
	СтруктураОтбораТовары.Вставить("Номенклатура");
	СтруктураОтбораТовары.Вставить("Характеристика");
	СтруктураОтбораТовары.Вставить("Серия");
	СтруктураОтбораТовары.Вставить("Цена");
	
	СтруктураОтбораПодобрано = Новый Структура;
	СтруктураОтбораПодобрано.Вставить("Номенклатура");
	СтруктураОтбораПодобрано.Вставить("Характеристика");
	СтруктураОтбораПодобрано.Вставить("Серия");
	
	МассивПересчетаСуммовыхПоказателей = Новый Массив;
	
	Для Каждого СтрокаРасхожденияТовары Из РасхожденияТовары Цикл
		
		КоличествоРасхождения = СтрокаРасхожденияТовары.Недостача;
		
		ЗаполнитьЗначенияСвойств(СтруктураОтбораТовары, СтрокаРасхожденияТовары);
		СтрокиТоварыДокумента = ДокументОбъект.Товары.НайтиСтроки(СтруктураОтбораТовары);
		КоличествоСтрокТоваровДокумента = СтрокиТоварыДокумента.Количество();
		
		Для ТекущийНомерСтрокиТоваровДокумента = 1 По КоличествоСтрокТоваровДокумента Цикл
			
			Если КоличествоРасхождения = 0 Тогда
				Прервать;
			КонецЕсли;
			
			СтрокаТоварыДокумента = СтрокиТоварыДокумента[КоличествоСтрокТоваровДокумента-ТекущийНомерСтрокиТоваровДокумента];
			КоличествоВДокументе = СтрокаТоварыДокумента.Количество;
			
			ЗаполнитьЗначенияСвойств(СтруктураОтбораПодобрано, СтрокаРасхожденияТовары);
			СтрокиПодобрано = РасхожденияПодобрано.НайтиСтроки(СтруктураОтбораПодобрано);
			КоличествоСтрокПодобрано = СтрокиПодобрано.Количество();
			
			ЗначениеСтавкиНДС = 0;
			Если Не ДокументОбъект.ЦенаВключаетНДС Тогда
				СтрокаСтавкаНДССоЗначением = СтавкиНДССоЗначениями.Найти(
					СтрокаТоварыДокумента.СтавкаНДС, "СтавкаНДС");
				Если СтрокаСтавкаНДССоЗначением <> Неопределено Тогда
					ЗначениеСтавкиНДС = СтрокаСтавкаНДССоЗначением.Ставка;
				КонецЕсли;
			КонецЕсли;
			
			Для ТекущийНомерСтрокиПодобрано = 1 По КоличествоСтрокПодобрано Цикл
				
				Если КоличествоРасхождения = 0
					Или КоличествоВДокументе = 0 Тогда
					Прервать;
				КонецЕсли;
				
				СтрокаПодобрано = СтрокиПодобрано[КоличествоСтрокПодобрано-ТекущийНомерСтрокиПодобрано];
				КоличествоПодобрано = СтрокаПодобрано.Недостача;
				
				КоличествоКОбработке = 0;
				Если КоличествоРасхождения >= КоличествоВДокументе Тогда
					КоличествоКОбработке = Мин(КоличествоВДокументе, КоличествоПодобрано);
				Иначе
					КоличествоКОбработке = Мин(КоличествоРасхождения, КоличествоПодобрано);
				КонецЕсли;
				
				Если КоличествоВДокументе > КоличествоКОбработке Тогда
					
					СтрокаТоварыДокументаКопия = ДокументОбъект.Товары.Вставить(СтрокаТоварыДокумента.НомерСтроки);
					СтрокаТоварыДокумента.Упаковка = Справочники.УпаковкиЕдиницыИзмерения.ПустаяСсылка();
					СтрокаТоварыДокумента.Количество = СтрокаТоварыДокумента.Количество - КоличествоКОбработке;
					СтрокаТоварыДокумента.КоличествоУпаковок = СтрокаТоварыДокумента.Количество;
					
					ЗаполнитьЗначенияСвойств(СтрокаТоварыДокументаКопия, СтрокаТоварыДокумента);
					СтрокаТоварыДокументаКопия.Упаковка = Справочники.УпаковкиЕдиницыИзмерения.ПустаяСсылка();
					СтрокаТоварыДокументаКопия.Количество = КоличествоКОбработке;
					СтрокаТоварыДокументаКопия.КоличествоУпаковок = КоличествоКОбработке;
					СтрокаТоварыДокументаКопия.ВидЦены = Неопределено;
					СтрокаТоварыДокументаКопия.Цена = СтрокаПодобрано.МРЦ;
					СтрокаТоварыДокументаКопия.СуммаРучнойСкидки = 0;
					СтрокаТоварыДокументаКопия.СуммаАвтоматическойСкидки = 0;
					СтрокаТоварыДокументаКопия.ПроцентРучнойСкидки = 0;
					СтрокаТоварыДокументаКопия.ПроцентАвтоматическойСкидки = 0;
					СтрокаТоварыДокументаКопия.СуммаБонусныхБалловКСписанию = 0;
					СтрокаТоварыДокументаКопия.СуммаБонусныхБалловКСписаниюВВалюте = 0;
					
					Если Не ДокументОбъект.ЦенаВключаетНДС Тогда
						СтрокаТоварыДокументаКопия.Цена = СтрокаТоварыДокументаКопия.Цена * 100 / (100 + ЗначениеСтавкиНДС);
					КонецЕсли;
					
					МассивПересчетаСуммовыхПоказателей.Добавить(СтрокаТоварыДокументаКопия);
					
				Иначе
					
					СтрокаТоварыДокумента.Упаковка = Справочники.УпаковкиЕдиницыИзмерения.ПустаяСсылка();
					СтрокаТоварыДокумента.КоличествоУпаковок = СтрокаТоварыДокумента.Количество;
					СтрокаТоварыДокумента.ВидЦены = Неопределено;
					СтрокаТоварыДокумента.Цена = СтрокаПодобрано.МРЦ;
					СтрокаТоварыДокумента.СуммаРучнойСкидки                   = 0;
					СтрокаТоварыДокумента.СуммаАвтоматическойСкидки           = 0;
					СтрокаТоварыДокумента.ПроцентРучнойСкидки                 = 0;
					СтрокаТоварыДокумента.ПроцентАвтоматическойСкидки         = 0;
					СтрокаТоварыДокумента.СуммаБонусныхБалловКСписанию        = 0;
					СтрокаТоварыДокумента.СуммаБонусныхБалловКСписаниюВВалюте = 0;
					
					Если Не ДокументОбъект.ЦенаВключаетНДС Тогда
						СтрокаТоварыДокумента.Цена = СтрокаТоварыДокумента.Цена * 100 / (100 + ЗначениеСтавкиНДС);
					КонецЕсли;
					
				КонецЕсли;
				
				СтрокаПодобрано.Недостача = СтрокаПодобрано.Недостача - КоличествоКОбработке;
				Если СтрокаПодобрано.Недостача = 0 Тогда
					РасхожденияПодобрано.Удалить(СтрокаПодобрано);
				КонецЕсли;
				
				КоличествоРасхождения = КоличествоРасхождения - КоличествоКОбработке;
				КоличествоВДокументе = КоличествоВДокументе - КоличествоКОбработке;
				
				МассивПересчетаСуммовыхПоказателей.Добавить(СтрокаТоварыДокумента);
				
			КонецЦикла;
			
		КонецЦикла;
		
	КонецЦикла;
	
	Если МассивПересчетаСуммовыхПоказателей.Количество() > 0 Тогда
		
		ВалютаРегламентированногоУчета = ЗначениеНастроекПовтИсп.ВалютаРегламентированногоУчетаОрганизации(ДокументОбъект.Организация);
		ВалютаУправленческогоУчета = Константы.ВалютаУправленческогоУчета.Получить();
		
		СтруктураПересчетаСуммы = ПакетнаяОбработкаТабличнойЧастиКлиентСервер.ПараметрыПересчетаСуммыНДСВСтрокеТЧ(ДокументОбъект);
		
		СтруктураДействий = Новый Структура;
		СтруктураДействий.Вставить("ПересчитатьСумму");
		СтруктураДействий.Вставить("ПересчитатьСуммуНДС", СтруктураПересчетаСуммы);
		СтруктураДействий.Вставить("ПересчитатьСуммуСНДС", СтруктураПересчетаСуммы);
		СтруктураДействий.Вставить("ОчиститьСуммуВзаиморасчетов");
		
		ПараметрыЗаполненияСуммыНДСРеглУпр = ПакетнаяОбработкаТабличнойЧастиКлиентСервер.ПараметрыЗаполненияСуммыНДСРеглУпр(
			ДокументОбъект.Валюта,
			ВалютаРегламентированногоУчета,
			ВалютаУправленческогоУчета);
		СтруктураДействий.Вставить("УстановитьСуммуНДСРеглУпр", ПараметрыЗаполненияСуммыНДСРеглУпр);
		
		ПакетнаяОбработкаТабличнойЧастиСервер.ОбработатьСтрокиТЧ(
			МассивПересчетаСуммовыхПоказателей,
			СтруктураДействий,
			ДокументОбъект.Товары);
	
	КонецЕсли;
	
КонецПроцедуры

// Удалить штрихкоды упаковок по товарам с некорректной ценой по РМЦ
// 
// Параметры:
//  Форма - ФормаКлиентскогоПриложения - Форма
//  ШтрихкодыУпаковокСМРЦ - ТаблицаЗначений - Штрихкоды упаковок СМРЦ
Процедура УдалитьШтрихкодыУпаковокПоТоварамСНекорректнойЦеной(Форма, ШтрихкодыУпаковокСМРЦ) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ТоварыДокумента.НомерСтроки,
	|	ТоварыДокумента.Номенклатура,
	|	ТоварыДокумента.Характеристика,
	|	ТоварыДокумента.Серия,
	|	ТоварыДокумента.Цена,
	|	ТоварыДокумента.ВидПродукцииИС,
	|	ТоварыДокумента.Количество
	|ПОМЕСТИТЬ ТоварыДокумента
	|ИЗ
	|	&ТоварыДокумента КАК ТоварыДокумента
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ШтрихкодыУпаковокДокумента.НомерСтроки,
	|	ШтрихкодыУпаковокДокумента.АкцизнаяМарка КАК ШтрихкодУпаковки
	|ПОМЕСТИТЬ ШтрихкодыУпаковокДокумента
	|ИЗ
	|	&ШтрихкодыУпаковокДокумента КАК ШтрихкодыУпаковокДокумента
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	ШтрихкодУпаковки
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	МИНИМУМ(ТоварыДокумента.НомерСтроки) КАК НомерСтроки,
	|	ТоварыДокумента.Номенклатура,
	|	ТоварыДокумента.Характеристика,
	|	ТоварыДокумента.Серия,
	|	ТоварыДокумента.Цена,
	|	ТоварыДокумента.ВидПродукцииИС,
	|	СУММА(ТоварыДокумента.Количество) КАК Количество
	|ПОМЕСТИТЬ ТоварыДокументаСМРЦ
	|ИЗ
	|	ТоварыДокумента КАК ТоварыДокумента
	|ГДЕ
	|	ТоварыДокумента.ВидПродукцииИС.ВидПродукцииГИСМТ В (&ВидыПродукцииИС)
	|	И ТоварыДокумента.Цена > 0
	|СГРУППИРОВАТЬ ПО
	|	ТоварыДокумента.Номенклатура,
	|	ТоварыДокумента.Характеристика,
	|	ТоварыДокумента.Серия,
	|	ТоварыДокумента.Цена,
	|	ТоварыДокумента.ВидПродукцииИС
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Номенклатура,
	|	Характеристика,
	|	Серия,
	|	Цена
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ШтрихкодыУпаковокСМРЦ.Номенклатура,
	|	ШтрихкодыУпаковокСМРЦ.Характеристика,
	|	ШтрихкодыУпаковокСМРЦ.Серия,
	|	ШтрихкодыУпаковокСМРЦ.МРЦ,
	|	ШтрихкодыУпаковокСМРЦ.ВидПродукцииИС,
	|	ШтрихкодыУпаковокСМРЦ.ШтрихкодУпаковки,
	|	ШтрихкодыУпаковокСМРЦ.Количество
	|ПОМЕСТИТЬ ШтрихкодыУпаковокСМРЦ
	|ИЗ
	|	&ШтрихкодыУпаковокСМРЦ КАК ШтрихкодыУпаковокСМРЦ
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Номенклатура,
	|	Характеристика,
	|	Серия,
	|	МРЦ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЕСТЬNULL(ТоварыДокументаСМРЦ.Номенклатура, ШтрихкодыУпаковокСМРЦ.Номенклатура) КАК Номенклатура,
	|	ЕСТЬNULL(ТоварыДокументаСМРЦ.Характеристика, ШтрихкодыУпаковокСМРЦ.Характеристика) КАК Характеристика,
	|	ЕСТЬNULL(ТоварыДокументаСМРЦ.Серия, ШтрихкодыУпаковокСМРЦ.Серия) КАК Серия
	|ПОМЕСТИТЬ ТоварыСРасхождениемЦен
	|ИЗ
	|	ТоварыДокументаСМРЦ КАК ТоварыДокументаСМРЦ
	|		ПОЛНОЕ СОЕДИНЕНИЕ ШтрихкодыУпаковокСМРЦ КАК ШтрихкодыУпаковокСМРЦ
	|		ПО ШтрихкодыУпаковокСМРЦ.Номенклатура = ТоварыДокументаСМРЦ.Номенклатура
	|		И ШтрихкодыУпаковокСМРЦ.Характеристика = ТоварыДокументаСМРЦ.Характеристика
	|		И ШтрихкодыУпаковокСМРЦ.Серия = ТоварыДокументаСМРЦ.Серия
	|		И ШтрихкодыУпаковокСМРЦ.МРЦ = ТоварыДокументаСМРЦ.Цена
	|ГДЕ
	|	НЕ ЕСТЬNULL(ТоварыДокументаСМРЦ.Количество, 0) - ЕСТЬNULL(ШтрихкодыУпаковокСМРЦ.Количество, 0) = 0
	|СГРУППИРОВАТЬ ПО
	|	ЕСТЬNULL(ТоварыДокументаСМРЦ.Номенклатура, ШтрихкодыУпаковокСМРЦ.Номенклатура),
	|	ЕСТЬNULL(ТоварыДокументаСМРЦ.Характеристика, ШтрихкодыУпаковокСМРЦ.Характеристика),
	|	ЕСТЬNULL(ТоварыДокументаСМРЦ.Серия, ШтрихкодыУпаковокСМРЦ.Серия)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ШтрихкодыУпаковокСМРЦ.Номенклатура,
	|	ШтрихкодыУпаковокСМРЦ.Характеристика,
	|	ШтрихкодыУпаковокСМРЦ.Серия,
	|	ШтрихкодыУпаковокСМРЦ.МРЦ,
	|	ШтрихкодыУпаковокСМРЦ.ВидПродукцииИС,
	|	ШтрихкодыУпаковокСМРЦ.ШтрихкодУпаковки,
	|	ШтрихкодыУпаковокСМРЦ.Количество
	|ПОМЕСТИТЬ ШтрихкодыУпаковокКУдалению
	|ИЗ
	|	ШтрихкодыУпаковокСМРЦ КАК ШтрихкодыУпаковокСМРЦ
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ТоварыСРасхождениемЦен КАК ТоварыСРасхождениемЦен
	|		ПО ШтрихкодыУпаковокСМРЦ.Номенклатура = ТоварыСРасхождениемЦен.Номенклатура
	|			И ШтрихкодыУпаковокСМРЦ.Характеристика = ТоварыСРасхождениемЦен.Характеристика
	|			И ШтрихкодыУпаковокСМРЦ.Серия = ТоварыСРасхождениемЦен.Серия
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	ШтрихкодУпаковки
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ШтрихкодыУпаковокДокумента.ШтрихкодУпаковки
	|ИЗ
	|	ШтрихкодыУпаковокДокумента КАК ШтрихкодыУпаковокДокумента
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ШтрихкодыУпаковокТоваров КАК ШтрихкодыУпаковокТоваров
	|		ПО ШтрихкодыУпаковокДокумента.ШтрихкодУпаковки = ШтрихкодыУпаковокТоваров.Ссылка
	|ГДЕ
	|	ШтрихкодыУпаковокТоваров.Номенклатура В (ВЫБРАТЬ Номенклатура ИЗ ШтрихкодыУпаковокКУдалению)";
	Запрос.УстановитьПараметр("ТоварыДокумента", Форма.Объект.Товары.Выгрузить());
	Запрос.УстановитьПараметр("ШтрихкодыУпаковокДокумента", Форма.Объект.АкцизныеМарки.Выгрузить());
	Запрос.УстановитьПараметр("ШтрихкодыУпаковокСМРЦ", ШтрихкодыУпаковокСМРЦ);
	Запрос.УстановитьПараметр("ВидыПродукцииИС", КонструкторИСМПОбщегоНазначенияКлиентСервер.ВидыПродукцииКоторымДоступноПолеМРЦ());
	
	ВыборкаЗапроса = Запрос.Выполнить().Выбрать();
	
	Пока ВыборкаЗапроса.Следующий() Цикл
		СтрокиШтрихкодовКУдалению = Форма.Объект.АкцизныеМарки.НайтиСтроки(Новый Структура(
			"АкцизнаяМарка",
			ВыборкаЗапроса.ШтрихкодУпаковки));
		
		Для Каждого СтрокаШтрихкодаКУдалению Из СтрокиШтрихкодовКУдалению Цикл
			Форма.Объект.АкцизныеМарки.Удалить(СтрокаШтрихкодаКУдалению);
		КонецЦикла;
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти

#Область ОплатаЭСФСС

// Установить функциональную опцию оплаты ЭС ФСС в реквизите формы.
// 
// Параметры:
//  Форма - см. Документ.ЧекККМ.Форма.ФормаДокументаРМК,Документ.ЧекККМВозврат.Форма.ФормаДокументаРМК
Процедура УстановитьФункциональнуюОпциюОплатаЭСФСС(Форма) Экспорт
	
	Форма.ИспользоватьОплатуЭСФСС = ПолучитьФункциональнуюОпцию("ОплатаЭлектроннымиСертификатамиФСС");
	
КонецПроцедуры

// Настроить видимость элементов оплаты ЭС ФСС на форме панели администрирования УТ "Продажи"
// 
// Параметры:
//  Форма - ФормаКлиентскогоПриложения - Форма
Процедура ПанельАдминистрированияУТПродажиНастроитьВидимостьЭлементовОплатыЭСФСС(Форма) Экспорт
	
	Форма.Элементы.ГруппаПараметрыПодключенияНСПК.Видимость =
		ПолучитьФункциональнуюОпцию("ОплатаЭлектроннымиСертификатамиФСС");
	
КонецПроцедуры

// Заполнить основные параметры подключения к НСПК
// 
// Параметры:
//  Форма - ФормаКлиентскогоПриложения - Форма
Процедура ПанельАдминистрированияУТПродажиЗаполнитьПараметрыПодключенияНСПК(Форма) Экспорт
	
	Если НЕ ПолучитьФункциональнуюОпцию("ОплатаЭлектроннымиСертификатамиФСС") Тогда
		Возврат;
	КонецЕсли;
	
	ОбщиеПараметрыПодключенияНСПК = ЭлектронныеСертификатыНСПКУТ.ОбщиеПараметрыПодключенияНСПК();
	Форма.АдресСервисаНСПК = ОбщиеПараметрыПодключенияНСПК.АдресСервисаНСПК;
	Форма.КлючДоступаНСПК = ОбщиеПараметрыПодключенияНСПК.КлючДоступаНСПК;
	
	Форма.ПроксиСерверНСПК = ОбщиеПараметрыПодключенияНСПК.ПараметрыПроксиНСПК.Сервер;
	Форма.ПроксиПортНСПК = ОбщиеПараметрыПодключенияНСПК.ПараметрыПроксиНСПК.Порт;
	Форма.ПроксиПользовательНСПК = ОбщиеПараметрыПодключенияНСПК.ПараметрыПроксиНСПК.Пользователь;
	Форма.ПроксиПарольНСПК = ОбщиеПараметрыПодключенияНСПК.ПараметрыПроксиНСПК.Пароль;
	
	ВерсияКомпонентыНСПК = ЭлектронныеСертификатыНСПК.ВерсияВК();
	Форма.Элементы.ГруппаПараметрыПодключенияНСПК.Заголовок = СтрШаблон(
		НСтр("ru = 'Настройки подключения к сервису НСПК (компонента v. %1)'"), ВерсияКомпонентыНСПК);
	
КонецПроцедуры

// Записать параметры подключения к НСПК для "Кассы ККМ" 
// 
// Параметры:
//  Форма - ФормаКлиентскогоПриложения - Форма
//  ТекущийОбъект - СправочникОбъект.КассыККМ - Касса ККМ
Процедура КассаККМЗаписатьПараметрыПодключенияОрганизацииНСПК(Форма, ТекущийОбъект) Экспорт
	
	Если НЕ (ПолучитьФункциональнуюОпцию("ОплатаЭлектроннымиСертификатамиФСС")
		И Форма.Объект.ТипКассы = Перечисления.ТипыКассККМ.ФискальныйРегистратор) Тогда
		
		Возврат;
	КонецЕсли;
	
	КлючОрганизацииНСПК = "";
	Если Не ПустаяСтрока(Форма.КлючОрганизацииНСПК) Тогда 
		КлючОрганизацииНСПК = Форма.КлючОрганизацииНСПК;
	КонецЕсли;
	
	УстановитьПривилегированныйРежим(Истина);
	СтароеЗначениеПараметровПодключения = ЭлектронныеСертификатыНСПКУТ.ПараметрыПодключенияОрганизацииНСПК(Форма.Объект.Владелец);
	Если КлючОрганизацииНСПК <> СтароеЗначениеПараметровПодключения.КлючОрганизацииНСПК Тогда
		ОрганизацияОбъект = Форма.Объект.Владелец.ПолучитьОбъект(); // СправочникОбъект.Организации
		ОрганизацияОбъект.КлючОрганизацииНСПК = КлючОрганизацииНСПК;
		Попытка
			ОрганизацияОбъект.Записать();
		Исключение
			ИнформацияОбОшибке = ИнформацияОбОшибке();
			ШаблонТекстаОшибки = НСтр("ru = 'Не удалось записать данные о ключе организации %1 для подключения к НСПК по кассе ККМ %2 по причине:
			|%3'");
			ТекстОшибки = СтрШаблон(ШаблонТекстаОшибки, Форма.Объект.Владелец, Форма.Объект.Ссылка, ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке));
			ВызватьИсключение ТекстОШибки;
		КонецПопытки;
		УстановитьПривилегированныйРежим(Ложь);
	КонецЕсли;
	
КонецПроцедуры

// Возвращает сумму оплаты электронными сертификатам ФСС по документу
// 
// Параметры:
//  ОплатыПлатежнойКартой - ТаблицаЗначений - Оплаты платежной картой:
//  * ВидОплаты - ПеречислениеСсылка.ТипыПлатежнойСистемыККТ -
//  * Сумма - Число - 
// 
// Возвращаемое значение:
//  Число - сумма оплаты электронными сертификатами ФСС по документу
Функция СуммаОплатыЭСФССПоДокументу(ОплатыПлатежнойКартой) Экспорт
	
	СуммаОплатыЭСФСС = 0;
	
	Для Каждого СтрокаТЗ Из ОплатыПлатежнойКартой Цикл
		
		Если СтрокаТЗ.ВидОплаты = Перечисления.ТипыПлатежнойСистемыККТ.СертификатНСПК Тогда
			СуммаОплатыЭСФСС = СуммаОплатыЭСФСС + СтрокаТЗ.Сумма;
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат СуммаОплатыЭСФСС;
	
КонецФункции

// Возвращает сумму оплаты СБП по документу
// 
// Параметры:
//  ОплатыПлатежнойКартой - ТаблицаЗначений - Оплаты платежной картой:
//  * ВидОплаты - ПеречислениеСсылка.ТипыПлатежнойСистемыККТ -
//  * Сумма - Число - 
//  * СтатусОплатыСБП - ПеречислениеСсылка.ТипыСтатусовОплатыСБП - 
//  ТолькоОплатаВыполнена - Булево - Истина - Выполнена
// 
// Возвращаемое значение:
//  Число - сумма оплаты СБП по документу
Функция СуммаОплатыСБППоДокументу(ОплатыПлатежнойКартой, ТолькоОплатаВыполнена = Ложь) Экспорт
	
	СуммаОплатыСБП = 0;
	
	Для Каждого СтрокаТЗ Из ОплатыПлатежнойКартой Цикл
		
		Если СтрокаТЗ.ВидОплаты = Перечисления.ТипыПлатежнойСистемыККТ.СистемаБыстрыхПлатежей Тогда
			
			Если ТолькоОплатаВыполнена И СтрокаТЗ.СтатусОплатыСБП = Перечисления.ТипыСтатусовОплатыСБП.Выполнена
				ИЛИ Не ТолькоОплатаВыполнена Тогда
				
				СуммаОплатыСБП = СуммаОплатыСБП + СтрокаТЗ.Сумма;
			КонецЕсли;
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат СуммаОплатыСБП;
	
КонецФункции

#КонецОбласти

#Область ОплатаСБП

// Установить признак возможности использования оплаты СБП на формах РМК.
// 
// Параметры:
//  Форма - см. Документ.ЧекККМ.Форма.ФормаДокументаРМК,
//  			Документ.ЧекККМВозврат.ФормаДокументаРМК,
//  			Документ.РеализацияПодарочныхСертификатов.Форма.ФормаДокументаРМК,
//				Документ.ВозвратПодарочныхСертификатов.Форма.ФормаДокументаРМК .
Процедура УстановитьВозможностьИспользованиеОплатыСБПНаФормахРМК(Форма) Экспорт
	
	Форма.ИспользоватьОплатуСБП = ДляОрганизацииНастроеноПодключениеСБП(
		Форма.Объект.Организация,
		Форма.Объект.КассаККМ);
	
КонецПроцедуры

// Проверяет наличие настроек интеграции с СБП для организации.
// 
// Параметры:
//  Организация - СправочникСсылка.Организации
//  КассаККМ - СправочникСсылка.КассыККМ
//
// Возвращаемое значение:
//  Булево - 
//
Функция ДляОрганизацииНастроеноПодключениеСБП(Организация, КассаККМ) Экспорт

	Результат = Ложь;
	Если Справочники.НастройкиРМК.СписокДоговоровИПодключенийСБП(Организация, КассаККМ).Количество() > 0 Тогда
		Результат = Истина;
	КонецЕсли;
	Возврат Результат;
	
КонецФункции

// Получить из платежной системы идентификатор оплаты в платежной системе.
// 
// Параметры:
//  ПараметрыПроцедуры - Структура - Параметры процедуры
//  АдресРезультата - Строка - Адрес результата
Процедура ИдентификаторОплатыВПлатежнойСистеме(ПараметрыПроцедуры, АдресРезультата) Экспорт
	
	ПередВыполнениемОперацииВПлатежнойСистеме(ПараметрыПроцедуры.ДокументОплаты);
	
	РезультатОперации = ПереводыСБПc2b.ДинамическаяСсылка(
		ПараметрыПроцедуры.ДокументОплаты,
		ПараметрыПроцедуры.НастройкаПодключения,
		ПараметрыПроцедуры);
	
	Если ТипЗнч(РезультатОперации) = Тип("Структура") Тогда
		РезультатОперации.Вставить("ДокументОплаты", ПараметрыПроцедуры.ДокументОплаты);
	КонецЕсли;
	
	ПоместитьВоВременноеХранилище(РезультатОперации, АдресРезультата);
	
КонецПроцедуры

// Получить статус оплаты в платежной системе.
// 
// Параметры:
//  ПараметрыПроцедуры - Структура - Параметры процедуры
//  АдресРезультата - Строка - Адрес результата
Процедура СтатусОплатыВПлатежнойСистеме(ПараметрыПроцедуры, АдресРезультата) Экспорт
	
	ПередВыполнениемОперацииВПлатежнойСистеме(ПараметрыПроцедуры.ДокументОплаты);
	
	РезультатОперации = ПереводыСБПc2b.СтатусОплаты(
		ПараметрыПроцедуры.ДокументОплаты,
		Неопределено);
	
	Если ТипЗнч(РезультатОперации) = Тип("Структура") Тогда
		РезультатОперации.Вставить("СуммаОперации", СуммаОперации(ПараметрыПроцедуры.ДокументОплаты));
	КонецЕсли;
	
	ПоместитьВоВременноеХранилище(РезультатОперации, АдресРезультата);
	
КонецПроцедуры

// Выполнить возврат оплаты в платежной системе
// 
// Параметры:
//  ПараметрыПроцедуры - Структура - Параметры процедуры
//  АдресРезультата - Строка - Адрес результата
Процедура ВыполнитьВозвратОплаты(ПараметрыПроцедуры, АдресРезультата) Экспорт
	
	ПередВыполнениемОперацииВПлатежнойСистеме(ПараметрыПроцедуры.ДокументВозврата);
	
	ОбъектОплаты = ?(ЗначениеЗаполнено(ПараметрыПроцедуры.ИдентификаторОплаты),
			ПараметрыПроцедуры.ИдентификаторОплаты,
			ПараметрыПроцедуры.ДокументОплаты);
	
	РезультатОперации = ПереводыСБПc2b.ВозвратОплаты(
		ПараметрыПроцедуры.ДокументВозврата,
		ОбъектОплаты,
		ПараметрыПроцедуры.НастройкаПодключения,
		ПараметрыПроцедуры.БанкКлиента,
		ПараметрыПроцедуры);
	
	Если ТипЗнч(РезультатОперации) = Тип("Структура") Тогда
		РезультатОперации.Вставить("ДокументВозврата", ПараметрыПроцедуры.ДокументВозврата);
	КонецЕсли;
		
	ПоместитьВоВременноеХранилище(РезультатОперации, АдресРезультата);
	
КонецПроцедуры

// Получить статус возврата оплаты в платежной системе.
// 
// Параметры:
//  ПараметрыПроцедуры - Структура - Параметры процедуры
//  АдресРезультата - Строка - Адрес результата
Процедура СтатусВозвратаОплатыВПлатежнойСистеме(ПараметрыПроцедуры, АдресРезультата) Экспорт
	
	ПередВыполнениемОперацииВПлатежнойСистеме(ПараметрыПроцедуры.ДокументВозврата);
	
	РезультатОперации = ПереводыСБПc2b.СтатусВозврата(
		ПараметрыПроцедуры.ДокументВозврата,
		Неопределено);
	
	Если ТипЗнч(РезультатОперации) = Тип("Структура") Тогда
		РезультатОперации.Вставить("СуммаОперации", СуммаОперации(ПараметрыПроцедуры.ДокументВозврата));
	КонецЕсли;
	
	ПоместитьВоВременноеХранилище(РезультатОперации, АдресРезультата);
	
КонецПроцедуры

// Подтверждает возврат оплаты и возвращает результат подтверждения
// 
// Параметры:
//  ДокументВозврата - ДокументСсылка - Документ возврата
// 
// Возвращаемое значение:
//  см. ПереводыСБПc2b.ПодтвердитьВозврат
Функция ПодтвердитьВозвратОплаты(ДокументВозврата) Экспорт
	
	ПередВыполнениемОперацииВПлатежнойСистеме(ДокументВозврата);
	
	Возврат ПереводыСБПc2b.ПодтвердитьВозврат(
		ДокументВозврата,
		Неопределено);
	
КонецФункции

// Активирует кассовую ссылку для приема оплаты
// 
// Параметры:
//  ПараметрыПроцедуры - Структура:
//  	*ДокументОплаты - см. ПереводыСБПc2b.АктивироватьКассовуюСсылку.ДокументОперации 
//  	*ДанныеСсылки - см. ПереводыСБПc2b.АктивироватьКассовуюСсылку.ДанныеСсылки 
//  	*ТорговаяТочка - см. ПереводыСБПc2b.АктивироватьКассовуюСсылку.НастройкаПодключения 
//  АдресРезультата - Строка - Адрес результата
Процедура АктивироватьКассовуюСсылку(ПараметрыПроцедуры, АдресРезультата) Экспорт
	
	ПередВыполнениемОперацииВПлатежнойСистеме(ПараметрыПроцедуры.ДокументОплаты);
	
	РезультатОперации = ПереводыСБПc2b.АктивироватьКассовуюСсылку(
		ПараметрыПроцедуры.ДокументОплаты,
		ПараметрыПроцедуры.ДанныеСсылки,
		ПараметрыПроцедуры.ТорговаяТочка,
		ПараметрыПроцедуры);
		
	Если ТипЗнч(РезультатОперации) = Тип("Структура") Тогда
		РезультатОперации.Вставить("ДокументОплаты", ПараметрыПроцедуры.ДокументОплаты);
	КонецЕсли;
	
	ПоместитьВоВременноеХранилище(РезультатОперации, АдресРезультата);
	
КонецПроцедуры

// Деактивирует кассовую ссылку, оплата по ней становится невозможной
// 
// Параметры:
//  ПараметрыПроцедуры - Структура:
//  	*ДанныеСсылки - см. ПереводыСБПc2b.ДеактивироватьКассовуюСсылку.ДанныеСсылки 
//  	*ТорговаяТочка - см. ПереводыСБПc2b.ДеактивироватьКассовуюСсылку.НастройкаПодключения 
//  АдресРезультата - Строка - Адрес результата
Процедура ДеактивироватьКассовуюСсылку(ПараметрыПроцедуры, АдресРезультата) Экспорт
	
	ПередВыполнениемОперацииВПлатежнойСистеме(ПараметрыПроцедуры.ДокументОплаты);
	
	РезультатОперации = ПереводыСБПc2b.ДеактивироватьКассовуюСсылку(
		ПараметрыПроцедуры.ДанныеСсылки,
		ПараметрыПроцедуры.ТорговаяТочка);
		
	Если ТипЗнч(РезультатОперации) = Тип("Структура") Тогда
		РезультатОперации.Вставить("ДокументОплаты", ПараметрыПроцедуры.ДокументОплаты);
	КонецЕсли;
	
	ПоместитьВоВременноеХранилище(РезультатОперации, АдресРезультата);
	
КонецПроцедуры

// Определяет настройку подключения к платежной системе по договору подключения.
// 
// Параметры:
//  ДоговорПодключения - СправочникСсылка.ДоговорыЭквайринга - Договор подключения к платежной системе
//  Магазин - СправочникСсылка.Склады - Магазин подключения к платежной ссылке
// 
// Возвращаемое значение:
//  СправочникСсылка.НастройкиПодключенияКСистемеБыстрыхПлатежей - Настройка подключения к платежной системе
Функция НастройкаПодключения(ДоговорПодключения, Магазин) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	НастройкиИнтеграцииСПлатежнымиСистемамиУТ.Договор,
	|	НастройкиИнтеграцииСПлатежнымиСистемамиУТ.Магазин,
	|	НастройкиИнтеграцииСПлатежнымиСистемамиУТ.Интеграция
	|ИЗ
	|	РегистрСведений.НастройкиИнтеграцииСПлатежнымиСистемамиУТ КАК НастройкиИнтеграцииСПлатежнымиСистемамиУТ
	|ГДЕ
	|	НастройкиИнтеграцииСПлатежнымиСистемамиУТ.Договор = &ДоговорПодключения
	|	И НастройкиИнтеграцииСПлатежнымиСистемамиУТ.Интеграция.Используется";
	Запрос.УстановитьПараметр("ДоговорПодключения", ДоговорПодключения);

	УстановитьПривилегированныйРежим(Истина);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	УстановитьПривилегированныйРежим(Ложь);
	
	ИнтеграцияОбщая = Неопределено;
	
	Пока Выборка.Следующий() Цикл
		Если ЗначениеЗаполнено(Магазин) Тогда
			Если ЗначениеЗаполнено(Выборка.Магазин) Тогда
				Если Выборка.Магазин = Магазин
					Или Магазин.ПринадлежитЭлементу(Выборка.Магазин) Тогда
					Возврат Выборка.Интеграция;
				КонецЕсли;
			Иначе
				ИнтеграцияОбщая = Выборка.Интеграция;
			КонецЕсли;
		Иначе
			Возврат Выборка.Интеграция;
		КонецЕсли;
	КонецЦикла;
	
	Возврат ИнтеграцияОбщая;
	
КонецФункции

// Настройки подключения к платежной системе по договору подключения.
// 
// Параметры:
//  ДоговорПодключения - СправочникСсылка.ДоговорыЭквайринга - Договор подключения к платежной системе
// 
// Возвращаемое значение:
//  ТаблицаЗначений - Настройка подключения к платежной системе:
//	* Договор - СправочникСсылка.ДоговорыЭквайринга - 
//	* Магазин - СправочникСсылка.Склады - 
//	* НастройкаПодключения - СправочникСсылка.НастройкиПодключенияКСистемеБыстрыхПлатежей -
Функция НастройкиПодключения(ДоговорПодключения) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	НастройкиИнтеграцииСПлатежнымиСистемамиУТ.Договор,
	|	НастройкиИнтеграцииСПлатежнымиСистемамиУТ.Магазин,
	|	НастройкиИнтеграцииСПлатежнымиСистемамиУТ.Интеграция КАК НастройкаПодключения
	|ИЗ
	|	РегистрСведений.НастройкиИнтеграцииСПлатежнымиСистемамиУТ КАК НастройкиИнтеграцииСПлатежнымиСистемамиУТ
	|ГДЕ
	|	НастройкиИнтеграцииСПлатежнымиСистемамиУТ.Договор = &ДоговорПодключения";
	Запрос.УстановитьПараметр("ДоговорПодключения", ДоговорПодключения);

	УстановитьПривилегированныйРежим(Истина);
	
	Возврат Запрос.Выполнить().Выгрузить();
	
КонецФункции

// Определяет договор подключения к платежной системе по настройке подключения.
// 
// Параметры:
//  НастройкаПодключения - СправочникСсылка.НастройкиПодключенияКСистемеБыстрыхПлатежей - Настройка подключения к платежной системе
//  ТолькоДействующийДоговор - Булево - Подбирать только действующий договор.
// 
// Возвращаемое значение:
//  СправочникСсылка.ДоговорыЭквайринга - договор подключения к платежной системе
//
Функция ДоговорПодключения(НастройкаПодключения, ТолькоДействующийДоговор = Ложь) Экспорт
	
	Результат = Неопределено;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	НастройкиИнтеграцииСПлатежнымиСистемамиУТ.Договор,
	|	НастройкиИнтеграцииСПлатежнымиСистемамиУТ.Интеграция
	|ИЗ
	|	РегистрСведений.НастройкиИнтеграцииСПлатежнымиСистемамиУТ КАК НастройкиИнтеграцииСПлатежнымиСистемамиУТ
	|ГДЕ
	|	НастройкиИнтеграцииСПлатежнымиСистемамиУТ.Интеграция = &НастройкаПодключения
	|	И (&ВсеДоговора 
	|		ИЛИ НастройкиИнтеграцииСПлатежнымиСистемамиУТ.Договор.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыДоговоровКонтрагентов.Действует))";
	
	Запрос.УстановитьПараметр("НастройкаПодключения", НастройкаПодключения);
	Запрос.УстановитьПараметр("ВсеДоговора", Не ТолькоДействующийДоговор);
	
	УстановитьПривилегированныйРежим(Истина);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	УстановитьПривилегированныйРежим(Ложь);

	Если Выборка.Следующий() Тогда
		Результат =  Выборка.Договор;
	КонецЕсли;
	
	Возврат Результат;
КонецФункции

// Определяет сумму, по который была выполнена последняя операции в платежной системе.
// Метод следует использовать для отложенного получения статуса выполнения операции.
//
// Параметры:
//  ДокументОперации - ОпределяемыйТип.ДокументОперацииСБП - документ оплаты или возврата,
//      по которому были выполнены операции в платежных системах.
//
// Возвращаемое значение:
//  Число - Сумма последней операции с платежной системой
Функция СуммаОперации(ДокументОперации) Экспорт
	
	СуммаОплаты = 0;
	
	ДанныеОперацииПоДокументу = ПереводыСБПc2b.ОперацииПоДокументу(ДокументОперации);
	Если Не ДанныеОперацииПоДокументу.ДанныеОпераций.Количество() Тогда
		СуммаОплаты = ДанныеОперацииПоДокументу.Сумма;
	КонецЕсли;
	
	Возврат СуммаОплаты;
	
КонецФункции

// Заполнение массива шаблонов сообщений по типам документов.
// 
// Параметры:
//  Шаблоны - Массив Из Структура - Шаблоны
//
Процедура ПриОпределенииПредопределенныхШаблоновСообщенийСБППоТипам(Шаблоны) Экспорт
	
	ДобавитьШаблонЗаказКлиента(Шаблоны);
	ДобавитьШаблонСчетНаОплатуКлиенту(Шаблоны);
	ДобавитьШаблонАктВыполненныхРабот(Шаблоны);
	ДобавитьШаблонРеализацияТоваровУслуг(Шаблоны);
	ДобавитьШаблонРеализацияУслугПрочихАктивов(Шаблоны);
	
КонецПроцедуры

// См. СистемаБыстрыхПлатежейПереопределяемый.ПриОпределенииНастроекПодключения.
//
Процедура ПриОпределенииНастроекПодключенияСБП(Настройки) Экспорт
	
	// Подключение шаблонов назначения платежей для типов документов
	Для Каждого ОписаниеПараметров Из ТипыДокументовИспользующиеШаблоныНазначенияСБП() Цикл
		НовыйШаблон = Настройки.c2b.ШаблоныНазначений.Добавить();
		НовыйШаблон.ОбъектМетаданных = ОписаниеПараметров.Значение.Имя;
		НовыйШаблон.Идентификатор = ОписаниеПараметров.Значение.Имя;
		НовыйШаблон.Наименование = ОписаниеПараметров.Значение.Синоним;
		
		НовыйШаблонПараметры = НовыйШаблон.Параметры; // Массив
		Для Каждого ПараметрШаблона Из ПараметрыШаблонаНазначенияСБППоТипуДокумента(ОписаниеПараметров.Ключ) Цикл
			ОписаниеПараметра = Новый Структура("Наименование, Идентификатор");
			ЗаполнитьЗначенияСвойств(ОписаниеПараметра, ПараметрШаблона);
			НовыйШаблонПараметры.Добавить(ОписаниеПараметра);
		КонецЦикла;
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти

#Область БиблиотекаПодключаемогоОборудования

// Управление видимостью элементов формы админиистрирования настроек работы с подключаемым оборудованием.
// 
// Параметры:
//  Форма - ФормаКлиентскогоПриложения -
//
Процедура УправлениеВидимостьюЭлементовНастроекЖурналовОперацийБПО(Форма) Экспорт
	
	Форма.Элементы.ГруппаОперацииОчередьЧеков.Видимость = Истина;
	Форма.Элементы.ГруппаОперацииПроверкиКМ.Видимость = Истина;
	
КонецПроцедуры

// Обрабатывает результат подтверждения возраста покупателя через мессенджер Макс.
// 
// Параметры:
//  Форма - ФормаКлиентскогоПриложения -
//  Результат - см. МенеджерОборудованияКлиент.ТипРезультатаПроверкиВозрастаВМакс
//  ДополнительныеПараметры - Структура из КлючИЗначение
//
Процедура ОбработатьРезультатПодтвержденияВозрастаПокупателяЧерезМакс(Форма, Результат, ДополнительныеПараметры) Экспорт

	ТипыРезультатаПроверки = ДополнительныеПараметры.ТипРезультатаПроверкиВозрастаВМакс;
	ИмяРеквизитаСостояниеПроверки = РозничныеПродажиКлиентСерверЛокализация.ИмяРеквизитаСостояниеПроверкиВозрастаПокупателя();
	Если Результат.Результат = ТипыРезультатаПроверки.ВозрастПодтвержден Тогда
		Форма[ИмяРеквизитаСостояниеПроверки] = 3;
	ИначеЕсли Результат.Результат = ТипыРезультатаПроверки.ПозватьСотрудника Тогда
		Форма[ИмяРеквизитаСостояниеПроверки] = 5;
	ИначеЕсли Результат.Результат = ТипыРезультатаПроверки.Отмена Тогда
		Форма[ИмяРеквизитаСостояниеПроверки] = 4;
	ИначеЕсли Результат.Результат = ТипыРезультатаПроверки.Ошибка Тогда
		Если ЗначениеЗаполнено(Результат.ОписаниеОшибки) Тогда
			ОбщегоНазначения.СообщитьПользователю(Результат.ОписаниеОшибки);
		КонецЕсли;
		Форма[ИмяРеквизитаСостояниеПроверки] = 5;
	КонецЕсли;
	
	ОбновитьНастройкиФормыДляПроверкиВозрастаПокупателя(Форма);
КонецПроцедуры

#КонецОбласти

//-- Локализация

#Область КомиссионерВЧеке

// Возвращает перечень запросов (в виде списка) для составления пакетного запроса. 
// Последний запрос в списке фактически является результирующим. Состав полей последнего запроса:
//	   Номенклатура - СправочникСсылка.Номенклатура
//	   Характеристика - СправочникСсылка.ХарактеристикиНоменклатуры
//	   Серия - СправочникСсылка.СерииНоменклатуры
//	   Комитент - СправочникСсылка.Организации,СправочникСсылка.Контрагенты.
//
// Параметры:
//	Организация - СправочникСсылка.Организации
//	Склад - СправочникСсылка.Склады
//	ИмяТаблицыКлючей - Строка - Имя ВТ, в которой будут переданы строки с ключами данных, пустая строка - для обмена(все товары). Обязательные колонки:
//	 *Номенклатура - СправочникСсылка.Номенклатура
//	 *Характеристика - СправочникСсылка.ХарактеристикиНоменклатуры
//	 *Серия - СправочникСсылка.СерииНоменклатуры
//	СуффиксИменВТ - Строка - Окончание имен всех ВТ пакета, для исключения конфликтов имен в общем пакете
//	
// Возвращаемое значение:
//	Структура - Структура со свойствами:
//	*ПараметрыЗапроса - Структура - Структура со свойствами:
//	 **Ключ - Строка
//	*ПакетЗапросов - СписокЗначений из ЭлементСпискаЗначений:
//	 **Представление - Строка - Имя временной таблицы, создаваемой в запросе
//	 **Значение - Строка - Текст единичного запроса
//
Функция ЗапросДанныхКомитентовПоТоварам(Знач Организация, Знач Склад, Знач ИмяТаблицыКлючей = "", Знач СуффиксИменВТ = "") Экспорт
	
	ИспользоватьКомиссию = Истина;
	//++ Локализация
	ИспользоватьКомиссию = ПолучитьФункциональнуюОпцию("ИспользоватьКомиссиюПриЗакупках");
	//-- Локализация
	ИспользоватьИнтеркампани = 
		ИспользоватьКомиссию И ПолучитьФункциональнуюОпцию("ИспользоватьПередачиТоваровМеждуОрганизациями");
	ЭтоЗапросОбмена = ПустаяСтрока(ИмяТаблицыКлючей);
	Если НЕ ИспользоватьКомиссию И НЕ ЭтоЗапросОбмена Тогда
		
		ТекстЗапроса = 
		"ВЫБРАТЬ
		|	ЗНАЧЕНИЕ(Справочник.Номенклатура.ПустаяСсылка) КАК Номенклатура,
		|	ЗНАЧЕНИЕ(Справочник.ХарактеристикиНоменклатуры.ПустаяСсылка) КАК Характеристика,
		|	ЗНАЧЕНИЕ(Справочник.СерииНоменклатуры.ПустаяСсылка) КАК Серия,
		|	НЕОПРЕДЕЛЕНО КАК Комитент
		|ПОМЕСТИТЬ ДанныеОстатковВключаяКомитентов_ПодменныйСуффикс
		|ГДЕ
		|	ЛОЖЬ";
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "_ПодменныйСуффикс", СокрЛП(СуффиксИменВТ));
		
		ЗапросыПакета = Новый СписокЗначений;
		ЗапросыПакета.Добавить(ТекстЗапроса, "ДанныеОстатковВключаяКомитентов"+СокрЛП(СуффиксИменВТ)); 
		Результат = Новый Структура("ПараметрыЗапроса, ПакетЗапросов", Новый Структура, ЗапросыПакета);
		
		Возврат Результат;
		
	КонецЕсли; 
	
	СуффикИменПоУмолчанию = "ДанныеКомитентовПоТоварам";
	СуффиксИмен = ?(ПустаяСтрока(СуффиксИменВТ), СуффикИменПоУмолчанию, СуффиксИменВТ);
	
	ПараметрыЗапросаИсходные = Новый Структура();
	
	ПараметрыЗапросаИсходные.Вставить("ОтборОрганизацияПродавец_ПодменныйСуффикс", Организация);
	ПараметрыЗапросаИсходные.Вставить("ОтборМестоХраненияПродавца_ПодменныйСуффикс", Склад);
	ПараметрыЗапросаИсходные.Вставить("НижняяДатаОткрытыхСмен_ПодменныйСуффикс", ТекущаяДатаСеанса()-60*60*24*2);
	
	СпособыПередачиТоваров = Новый Массив;
	СпособыПередачиТоваров.Добавить(Перечисления.СпособыПередачиТоваров.Продажа);
	//++ Локализация
	Если ИспользоватьКомиссию Тогда
		СпособыПередачиТоваров.Добавить(Перечисления.СпособыПередачиТоваров.ПередачаНаКомиссию);
	КонецЕсли;
	//-- Локализация
	ПараметрыЗапросаИсходные.Вставить("СпособыПередачиТоваров_ПодменныйСуффикс", СпособыПередачиТоваров);
	
	ОтборТипыЗапасов = Новый Массив;
	ОтборТипыЗапасов.Добавить(Перечисления.ТипыЗапасов.Товар);
	//++ Локализация
	Если ИспользоватьКомиссию Тогда
		ОтборТипыЗапасов.Добавить(Перечисления.ТипыЗапасов.КомиссионныйТовар);
	КонецЕсли;
	//-- Локализация
	ОтборТипыЗапасов.Добавить(Перечисления.ТипыЗапасов.ТоварНаХраненииСПравомПродажи);
	ПараметрыЗапросаИсходные.Вставить("ОтборТипыЗапасов_ПодменныйСуффикс", ОтборТипыЗапасов);
	
		ПараметрыЗапросаИсходные.Вставить("УсловиеИсключенияЗапроса_Интеркампани_ПодменныйСуффикс", ИспользоватьИнтеркампани);
	
	ЗапросыПакета = Новый СписокЗначений;
	ПараметрыЗапросаФинальные = Новый Структура;
	
	ПодменыИмен = Новый СписокЗначений();
	ПодменыИмен.Добавить("#КоллекцияТовары", ИмяТаблицыКлючей);
	Для Каждого Элем Из ПараметрыЗапросаИсходные Цикл
		НовоеИмяКлюча = СтрЗаменить(Элем.Ключ, "_ПодменныйСуффикс", СуффиксИмен);
		ПодменыИмен.Добавить(Элем.Ключ, НовоеИмяКлюча);
		ПараметрыЗапросаФинальные.Вставить(НовоеИмяКлюча,Элем.Значение);
	КонецЦикла;
	
	ТекстЗапроса = 
	"ВЫБРАТЬ
	|	НастройкаПередачиТоваровМеждуОрганизациями.ОрганизацияПродавец КАК ОрганизацияПродавец,
	|	НастройкаПередачиТоваровМеждуОрганизациями.СпособПередачиТоваров КАК СпособПередачиТоваров,
	|	НастройкаПередачиТоваровМеждуОрганизациями.ОрганизацияВладелец КАК ОрганизацияВладелец,
	|	НастройкаПередачиТоваровМеждуОрганизациями.ТипЗапасов КАК ТипЗапасовВладельца
	|ПОМЕСТИТЬ НастройкиПередачи_ПодменныйСуффикс
	|ИЗ
	|	РегистрСведений.НастройкаПередачиТоваровМеждуОрганизациями КАК НастройкаПередачиТоваровМеждуОрганизациями
	|ГДЕ
	|	НастройкаПередачиТоваровМеждуОрганизациями.ОрганизацияПродавец = &ОтборОрганизацияПродавец_ПодменныйСуффикс
	|	И НастройкаПередачиТоваровМеждуОрганизациями.СпособПередачиТоваров В(&СпособыПередачиТоваров_ПодменныйСуффикс)
	|	И &УсловиеИсключенияЗапроса_Интеркампани_ПодменныйСуффикс
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	ОрганизацияВладелец
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ ПЕРВЫЕ 1
	|	ИСТИНА КАК ЕстьЗаписи
	|ПОМЕСТИТЬ ЕстьНастройкиПередачи_ПодменныйСуффикс
	|ИЗ
	|	НастройкиПередачи_ПодменныйСуффикс КАК НастройкиПередачи
	|ГДЕ
	|	&УсловиеИсключенияЗапроса_Интеркампани_ПодменныйСуффикс
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ДокЧек.Ссылка КАК Ссылка,
	|	ДокЧек.Организация КАК Организация,
	|	NULL КАК СвязьСторно
	|ПОМЕСТИТЬ ЧекиОткрытыхСмен_ПодменныйСуффикс
	|ИЗ
	|	Документ.ЧекККМ КАК ДокЧек
	|	ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.КассоваяСмена КАК ДокСмена
	|	ПО ДокЧек.КассоваяСмена = ДокСмена.Ссылка
	|ГДЕ
	|	ДокЧек.Склад = &ОтборМестоХраненияПродавца_ПодменныйСуффикс
	|	И ДокЧек.Организация = &ОтборОрганизацияПродавец_ПодменныйСуффикс
	|	И ДокЧек.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыЧековККМ.Пробит)
	|	И ДокСмена.ОкончаниеКассовойСмены = ДАТАВРЕМЯ(1, 1, 1)
	|	И ДокЧек.Дата > &НижняяДатаОткрытыхСмен_ПодменныйСуффикс
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ДокЧек.Ссылка КАК Чек,
	|	ДокЧек.Организация КАК Организация,
	|	NULL
	|ИЗ
	|	Документ.ЧекККМВозврат КАК ДокЧек
	|	ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.КассоваяСмена КАК ДокСмена
	|	ПО ДокЧек.КассоваяСмена = ДокСмена.Ссылка
	|ГДЕ
	|	ДокЧек.Склад = &ОтборМестоХраненияПродавца_ПодменныйСуффикс
	|	И ДокЧек.Организация = &ОтборОрганизацияПродавец_ПодменныйСуффикс
	|	И ДокЧек.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыЧековККМ.Пробит)
	|	И ДокСмена.ОкончаниеКассовойСмены = ДАТАВРЕМЯ(1, 1, 1)
	|	И ДокЧек.Дата > &НижняяДатаОткрытыхСмен_ПодменныйСуффикс
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ 
	|	ДокЧек.ЧекККМ КАК Чек,
	|	ДокЧек.Организация КАК Организация,
	|	ДокЧек.Ссылка
	|ИЗ
	|	Документ.ЧекККМКоррекции КАК ДокЧек
	|	ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.КассоваяСмена КАК ДокСмена
	|	ПО ДокЧек.КассоваяСмена = ДокСмена.Ссылка
	|	ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЧекККМ КАК ЧекСторнируемый
	|	ПО ДокЧек.ЧекККМ = ЧекСторнируемый.Ссылка
	|ГДЕ
	|	ДокЧек.Склад = &ОтборМестоХраненияПродавца_ПодменныйСуффикс
	|	И ДокЧек.Организация = &ОтборОрганизацияПродавец_ПодменныйСуффикс
	|	И ДокЧек.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыЧековККМ.Пробит)
	|	И ДокСмена.ОкончаниеКассовойСмены = ДАТАВРЕМЯ(1, 1, 1)
	|	И ДокЧек.Дата > &НижняяДатаОткрытыхСмен_ПодменныйСуффикс
	|	И ЧекСторнируемый.Склад = &ОтборМестоХраненияПродавца_ПодменныйСуффикс
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ДокЧек.Ссылка КАК Чек,
	|	ДокЧек.Организация КАК Организация,
	|	ДокЧек.ЧекККМ
	|ИЗ
	|	Документ.ЧекККМКоррекции КАК ДокЧек
	|	ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.КассоваяСмена КАК ДокСмена
	|	ПО ДокЧек.КассоваяСмена = ДокСмена.Ссылка
	|ГДЕ
	|	ДокЧек.Склад = &ОтборМестоХраненияПродавца_ПодменныйСуффикс
	|	И ДокЧек.Организация = &ОтборОрганизацияПродавец_ПодменныйСуффикс
	|	И ДокЧек.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыЧековККМ.Пробит)
	|	И ДокСмена.ОкончаниеКассовойСмены = ДАТАВРЕМЯ(1, 1, 1)
	|	И ДокЧек.Дата > &НижняяДатаОткрытыхСмен_ПодменныйСуффикс
	|
	|ИНДЕКСИРОВАТЬ ПО 
	|	Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Чек.Ссылка КАК Чек,
	|	Чек.СвязьСторно КАК СвязьСторно,
	|	Чек.Организация КАК Организация,
	|	ЧекТовары.Номенклатура КАК Номенклатура,
	|	ЧекТовары.Характеристика КАК Характеристика,
	|	ЧекТовары.Серия КАК Серия,
	|	ЧекТовары.Комитент КАК КомитентЧека,
	|	ВЫБОР
	|		КОГДА ТИПЗНАЧЕНИЯ(ЧекТовары.Комитент) = ТИП(Справочник.Контрагенты)
	|			ТОГДА ЗНАЧЕНИЕ(Перечисление.ТипыЗапасов.КомиссионныйТовар)
	|		ИНАЧЕ ЗНАЧЕНИЕ(Перечисление.ТипыЗапасов.Товар)
	|	КОНЕЦ КАК ТипЗапаса,
	|	ВЫБОР
