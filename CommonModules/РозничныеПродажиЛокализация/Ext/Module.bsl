		ОписаниеПараметра.Идентификатор = "[Договор]";
		ОписаниеПараметра.Наименование = НСтр("ru = 'Договор'", ОбщегоНазначения.КодОсновногоЯзыка());
		ОписаниеПараметра.ПутьКДанным = Метаданные.Документы.СчетНаОплатуКлиенту.Реквизиты.Договор.Имя + "." +
										Метаданные.Справочники.ДоговорыКонтрагентов.СтандартныеРеквизиты.Наименование.Имя;

		ОписаниеПараметра = ДобавитьОписаниеПараметраШаблонаНазначенияСБП(ПараметрыШаблона);
		ОписаниеПараметра.Идентификатор = "[СуммаДокумента]";
		ОписаниеПараметра.Наименование = НСтр("ru = 'Сумма документа'", ОбщегоНазначения.КодОсновногоЯзыка());
		ОписаниеПараметра.ПутьКДанным = Метаданные.Документы.СчетНаОплатуКлиенту.Реквизиты.СуммаДокумента.Имя;
		ОписаниеПараметра.Формат = "Л=ru_RU; ЧДЦ=2; ЧРД=.; ЧН=; ЧГ=0;";

		ОписаниеПараметра = ДобавитьОписаниеПараметраШаблонаНазначенияСБП(ПараметрыШаблона);
		ОписаниеПараметра.Идентификатор = "[Менеджер]";
		ОписаниеПараметра.Наименование = НСтр("ru = 'Менеджер'", ОбщегоНазначения.КодОсновногоЯзыка());
		ОписаниеПараметра.ПутьКДанным = Метаданные.Документы.СчетНаОплатуКлиенту.Реквизиты.Менеджер.Имя + "." +
										Метаданные.Справочники.Пользователи.СтандартныеРеквизиты.Наименование.Имя;

		ОписаниеПараметра = ДобавитьОписаниеПараметраШаблонаНазначенияСБП(ПараметрыШаблона);
		ОписаниеПараметра.Идентификатор = "[НазначениеПлатежа]";
		ОписаниеПараметра.Наименование = НСтр("ru = 'Назначение платежа'", ОбщегоНазначения.КодОсновногоЯзыка());
		ОписаниеПараметра.ПутьКДанным = Метаданные.Документы.СчетНаОплатуКлиенту.Реквизиты.НазначениеПлатежа.Имя;

	КонецЕсли;
	
	Возврат ПараметрыШаблона;
КонецФункции

// Описание параметра щаблона назначения СБП.
// Параметры:
//  ПараметрыШаблона - Массив из см. ДобавитьОписаниеПараметраШаблонаНазначенияСБП
//  
// Возвращаемое значение:
//  Структура:
//	 * Идентификатор - Строка - Идентификатор параметра, должен быть заключен в []
//	 * Наименование - Строка - Представление параметра
//	 * ПутьКДанным - Строка - Имя реквизита объекта метаданных, можно использовать обращение через одну ".".
//	 * Формат - Строка - Строка описывающая формат, к которому нужно привести значение, используется для типов Дата и Число
//
Функция ДобавитьОписаниеПараметраШаблонаНазначенияСБП(ПараметрыШаблона)
	ОписаниеПараметра = Новый Структура;
	ОписаниеПараметра.Вставить("Идентификатор", "");
	ОписаниеПараметра.Вставить("Наименование", "");
	ОписаниеПараметра.Вставить("ПутьКДанным", "");
	ОписаниеПараметра.Вставить("Формат", "");
	
	ПараметрыШаблона.Добавить(ОписаниеПараметра);
	Возврат ОписаниеПараметра;
КонецФункции


// Добавляет в коллекцию описаний типов документов, подключенных к механизму Шаблоны назначений СБП новое описание.
// Параметры:
//  ОписанияТиповДокументов - Соответствие из КлючИЗначение - Ключ - тип документа, значение - см. ДобавитьОписаниеТипаДокументаИспользующегоШаблоныНазначенияСБП
//  ТипДокумента - Тип - 
//  ОбъектМетаданных - ОбъектМетаданныхДокумент -
//  
// Возвращаемое значение:
//  Структура:
//	 * Имя - Строка
//	 * Синоним - Строка
//
Функция ДобавитьОписаниеТипаДокументаИспользующегоШаблоныНазначенияСБП(ОписанияТиповДокументов, ТипДокумента, ОбъектМетаданных)
	ОписаниеТипаДокумента = Новый Структура;
	ОписаниеТипаДокумента.Вставить("Имя", ОбъектМетаданных.Имя);
	ОписаниеТипаДокумента.Вставить("Синоним", ОбъектМетаданных.Синоним);
	
	ОписанияТиповДокументов.Вставить(ТипДокумента, ОписаниеТипаДокумента);
	Возврат ОписаниеТипаДокумента;
КонецФункции

// Заполняет назначение платежа заказа на оплату по шаблону назначения.
// Параметры:
//  ДокументОплаты - ДокументСсылка
//	ЗаказНаОплату - см. ПереводыСБПc2bПереопределяемый.ПриФормированииЗаказаНаОплатуСБП
//  
Процедура ЗаполнитьНазначениеПлатежаПоШаблонуНазначенияСБП(ДокументОплаты, ЗаказНаОплату) Экспорт
	
	ТипыПодключенныхДокументов = ТипыДокументовИспользующиеШаблоныНазначенияСБП();
	ОписаниеТипаДокумента = ТипыПодключенныхДокументов[ТипЗнч(ДокументОплаты)]; // см. ДобавитьОписаниеТипаДокументаИспользующегоШаблоныНазначенияСБП
	Если ОписаниеТипаДокумента <> Неопределено Тогда
		
		Отбор = Новый Структура;
		Отбор.Вставить("Идентификатор", ОписаниеТипаДокумента.Имя);
		НайденныеСтроки = ЗаказНаОплату.ШаблоныНазначений.НайтиСтроки(Отбор);
		Если НайденныеСтроки.Количество() <> 0 Тогда
			ШаблонНазначения = НайденныеСтроки[0];
			ТекстНазначенияПлатежа = ШаблонНазначения.НазначениеПлатежа;
			
			ПараметрыШаблона = ПараметрыШаблонаНазначенияСБППоТипуДокумента(ТипЗнч(ДокументОплаты));
			Если ПараметрыШаблона.Количество() Тогда
				МассивРеквизитов = Новый Массив;
				Для Каждого ПараметрШаблона Из ПараметрыШаблона Цикл
					Если ЗначениеЗаполнено(ПараметрШаблона.ПутьКДанным) Тогда
						МассивРеквизитов.Добавить(ПараметрШаблона.ПутьКДанным);
					КонецЕсли;
				КонецЦикла;
				
				ЗначенияПараметровШаблона = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ДокументОплаты, МассивРеквизитов, Истина);
				Для Каждого ПараметрШаблона Из ПараметрыШаблона Цикл
					ПутьКДанным = СтрЗаменить(ПараметрШаблона.ПутьКДанным, ".", "");
					Если ЗначениеЗаполнено(ПутьКДанным) Тогда
						ЗначениеПараметра = Неопределено;
						Если ЗначенияПараметровШаблона.Свойство(ПутьКДанным, ЗначениеПараметра) И ЗначениеПараметра <> Неопределено Тогда
							Если ЗначениеЗаполнено(ПараметрШаблона.Формат) Тогда
								ЗначениеПараметраСтрокой = Формат(ЗначениеПараметра, ПараметрШаблона.Формат);
							Иначе
								ЗначениеПараметраСтрокой = Формат(ЗначениеПараметра);
							КонецЕсли;
							ТекстНазначенияПлатежа = СтрЗаменить(ТекстНазначенияПлатежа, ПараметрШаблона.Идентификатор, ЗначениеПараметраСтрокой);
						КонецЕсли;
					КонецЕсли;
				КонецЦикла;
			КонецЕсли;
			ЗаказНаОплату.НазначениеПлатежа = ТекстНазначенияПлатежа;
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

#Область РозничнаяПродажаМаркированнойПродукции

#Область РозничнаяПродажаТабачнойПродукцииТолькоПоМРЦ

Функция ТипыОбъектовДляОчисткиСкидкиПоМРЦ()

	Результат = Новый Массив;
	Результат.Добавить(Тип("ДокументСсылка.ЗаказКлиента"));
	Результат.Добавить(Тип("ДокументСсылка.ЗаявкаНаВозвратТоваровОтКлиента"));
	Результат.Добавить(Тип("ДокументСсылка.РеализацияТоваровУслуг"));
	Результат.Добавить(Тип("ДокументСсылка.ЧекККМ"));
	
	Возврат Результат;

КонецФункции

// Параметры:
//	Форма - ФормаКлиентскогоПриложения - список форм в методе РозничныеПродажиКлиентСерверЛокализация.ФормыСоВстроеннымМеханизмомМРЦ()
Процедура ИзменитьФормуПродажаТабачнойПродукцииТолькоПоМРЦ(Форма)
	
	Если РозничныеПродажиКлиентСерверЛокализация.ФормыСоВстроеннымМеханизмомМРЦ().Найти(Форма.ИмяФормы) <> Неопределено Тогда
		
		КонтрольныйРеквизит = РозничныеПродажиКлиентСерверЛокализация.ИмяРеквизитаИспользоватьРозничныеПродажиТабачнойПродукцииТолькоПоМРЦ();
		// Добавление реквизита
		Если Не ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(Форма, КонтрольныйРеквизит) Тогда
			
			ДобавляемыеРеквизиты = Новый Массив;
			НовРеквизит = Новый РеквизитФормы(КонтрольныйРеквизит, Новый ОписаниеТипов("Булево"));
			ДобавляемыеРеквизиты.Добавить(НовРеквизит);
			
			Если Форма.ИмяФормы = "Документ.ЧекККМ.Форма.ФормаДокументаРМК"
				Или Форма.ИмяФормы = "Документ.ЧекККМВозврат.Форма.ФормаДокументаРМК"
				Или Форма.ИмяФормы = "Документ.РеализацияТоваровУслуг.Форма.ФормаДокумента" Тогда
				
				ИмяТЧ = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку("Объект.%1", 
					РозничныеПродажиКлиентСерверЛокализация.ТаблицаТоваровПоФормеМРЦ(Форма.ИмяФормы));
				ИмяНовогоРеквизитаФормы = РозничныеПродажиКлиентСерверЛокализация.ИмяРеквизитаУстановленаМРЦ();
				НовКолонка = Новый РеквизитФормы(ИмяНовогоРеквизитаФормы, Новый ОписаниеТипов("Булево"), 
					ИмяТЧ, НСтр("ru = 'Установлена МРЦ'"));
				ДобавляемыеРеквизиты.Добавить(НовКолонка);
				
				ИмяНовогоРеквизитаФормы = РозничныеПродажиКлиентСерверЛокализация.ИмяРеквизитаЕстьОшибкаВЦенеПоМРЦ();
				НовРеквизит = Новый РеквизитФормы(ИмяНовогоРеквизитаФормы, Новый ОписаниеТипов("Булево"));
				ДобавляемыеРеквизиты.Добавить(НовРеквизит);
				
			КонецЕсли;
			
			Форма.ИзменитьРеквизиты(ДобавляемыеРеквизиты);
		
		КонецЕсли;
		
		// Заполнение реквизита
		КонтрольноеЗначение = Ложь;
		Если Форма.ИмяФормы = "Обработка.ПодборТоваровВДокументПродажи.Форма.Форма"
			Или Форма.ИмяФормы = "Справочник.БонусныеПрограммыЛояльности.Форма.ОплатаБонуснымиБаллами" Тогда
			Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(Форма.Параметры, КонтрольныйРеквизит) Тогда
				КонтрольноеЗначение = Форма.Параметры[КонтрольныйРеквизит];
			КонецЕсли;
		ИначеЕсли Форма.ИмяФормы = "Документ.ЧекККМ.Форма.ФормаДокументаРМК"
			ИЛИ Форма.ИмяФормы = "Документ.ЧекККМВозврат.Форма.ФормаДокументаРМК" Тогда
			КонтрольноеЗначение = КонтролироватьЦенуПродажиТабачнойПродукции(ТекущаяДатаСеанса());
		Иначе
			ТекДата = ?(ЗначениеЗаполнено(Форма.Объект.Дата),Форма.Объект.Дата, ТекущаяДатаСеанса());
			ТекКонтрагент = Форма.Объект.Контрагент;	// СправочникСсылка.Контрагенты
			ТекЮрФизЛицо = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ТекКонтрагент, "ЮрФизЛицо");
			КонтрольноеЗначение = КонтролироватьЦенуПродажиТабачнойПродукции(ТекДата)
				И ТекЮрФизЛицо = ПредопределенноеЗначение("Перечисление.ЮрФизЛицо.ФизЛицо");
		КонецЕсли;
		
		Форма[КонтрольныйРеквизит] = КонтрольноеЗначение;
		
	КонецЕсли;
	
КонецПроцедуры

// Получить текст запроса товары по реализации товаров услуг с видами продукции ИС по ссылке
// 
// Возвращаемое значение:
//  Строка - Текст запроса получения товаров по реализации товаров услуг с указанием вида продукции ИС
Функция ПолучитьТекстЗапросаТоварыПоРеализацииТоваровУслугСВидамиПродукцииИСПоСсылке()
	
	ТекстЗапроса = 
	"ВЫБРАТЬ
	|	ТоварыДокумента.НомерСтроки,
	|	ТоварыДокумента.Номенклатура,
	|	ТоварыДокумента.Характеристика,
	|	ТоварыДокумента.Серия,
	|	ТоварыДокумента.Цена,
	|	ЕСТЬNULL(ОписаниеНоменклатурыИС.КлючВидовПродукции, ЗНАЧЕНИЕ(Справочник.КлючиВидовПродукцииИС.ПустаяСсылка)) ВидПродукцииИС,
	|	ТоварыДокумента.Количество,
	|	ТоварыДокумента.СуммаАвтоматическойСкидки,
	|	ТоварыДокумента.ПроцентАвтоматическойСкидки,
	|	ТоварыДокумента.СуммаРучнойСкидки,
	|	ТоварыДокумента.ПроцентРучнойСкидки,
	|	ТоварыДокумента.СуммаБонусныхБалловКСписанию,
	|	ТоварыДокумента.СуммаБонусныхБалловКСписаниюВВалюте,
	|	ТоварыДокумента.СуммаСНДС
	|ПОМЕСТИТЬ ТоварыДокумента
	|ИЗ
	|	Документ.РеализацияТоваровУслуг.Товары КАК ТоварыДокумента
	|	ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ОписаниеНоменклатурыИС КАК ОписаниеНоменклатурыИС
	|	ПО ТоварыДокумента.Номенклатура = ОписаниеНоменклатурыИС.Номенклатура
	|ГДЕ
	|	ТоварыДокумента.Ссылка = &ДокументСсылка
	|";
	
	Возврат ТекстЗапроса;
	
КонецФункции

// Получить текст запроса товары по реализации товаров услуг с видами продукции ИС по объекту
// 
// Возвращаемое значение:
//  Строка - Текст запроса получения товаров по реализации товаров услуг с указанием вида продукции ИС
Функция ПолучитьТекстЗапросаТоварыПоРеализацииТоваровУслугСВидамиПродукцииИСПоОбъекту()
	
	ТекстЗапроса = 
	"ВЫБРАТЬ
	|	ТоварыДокумента.НомерСтроки,
	|	ВЫРАЗИТЬ(ТоварыДокумента.Номенклатура КАК Справочник.Номенклатура) КАК Номенклатура,
	|	ТоварыДокумента.Характеристика,
	|	ТоварыДокумента.Серия,
	|	ТоварыДокумента.Цена,
	|	ТоварыДокумента.Количество,
	|	ТоварыДокумента.СуммаАвтоматическойСкидки,
	|	ТоварыДокумента.ПроцентАвтоматическойСкидки,
	|	ТоварыДокумента.СуммаРучнойСкидки,
	|	ТоварыДокумента.ПроцентРучнойСкидки,
	|	ТоварыДокумента.СуммаБонусныхБалловКСписанию,
	|	ТоварыДокумента.СуммаБонусныхБалловКСписаниюВВалюте
	|ПОМЕСТИТЬ ТоварыДокументаБезВидаПродукцииИС
	|ИЗ
	|	&ТоварыДокумента КАК ТоварыДокумента
	|;
	|
	|////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТоварыДокумента.НомерСтроки,
	|	ТоварыДокумента.Номенклатура,
	|	ТоварыДокумента.Характеристика,
	|	ТоварыДокумента.Серия,
	|	ТоварыДокумента.Цена,
	|	ЕСТЬNULL(ОписаниеНоменклатурыИС.КлючВидовПродукции, ЗНАЧЕНИЕ(Справочник.КлючиВидовПродукцииИС.ПустаяСсылка)) КАК ВидПродукцииИС,
	|	ТоварыДокумента.Количество,
	|	ТоварыДокумента.СуммаАвтоматическойСкидки,
	|	ТоварыДокумента.ПроцентАвтоматическойСкидки,
	|	ТоварыДокумента.СуммаРучнойСкидки,
	|	ТоварыДокумента.ПроцентРучнойСкидки,
	|	ТоварыДокумента.СуммаБонусныхБалловКСписанию,
	|	ТоварыДокумента.СуммаБонусныхБалловКСписаниюВВалюте
	|ПОМЕСТИТЬ ТоварыДокумента
	|ИЗ
	|	ТоварыДокументаБезВидаПродукцииИС КАК ТоварыДокумента
	|	ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ОписаниеНоменклатурыИС КАК ОписаниеНоменклатурыИС
	|	ПО ТоварыДокумента.Номенклатура = ОписаниеНоменклатурыИС.Номенклатура";
	
	Возврат ТекстЗапроса;
	
КонецФункции

#КонецОбласти

#Область ПроверкаВозрастаПокупателя

Процедура НастроитьФормуДляПодтвержденияВозрастаПокупателя(Форма, ТекущийОбъект = Неопределено) Экспорт
	
	Если Форма.ИмяФормы = "Документ.ЧекККМ.Форма.ФормаДокументаРМК" 
		Или Форма.ИмяФормы = "Обработка.ПредпросмотрЧека.Форма.Форма" 
			И (ТипЗнч(Форма.ДокументСсылка) = Тип("ДокументСсылка.АктВыполненныхРабот")
				Или ТипЗнч(Форма.ДокументСсылка) = Тип("ДокументСсылка.РеализацияТоваровУслуг")
				Или ТипЗнч(Форма.ДокументСсылка) = Тип("ДокументСсылка.РеализацияУслугПрочихАктивов")) Тогда
		
		// Реквизит для хранения состояния функциональной опции
		ИмяКонтрольногоРеквизита = 
			РозничныеПродажиКлиентСерверЛокализация.ИмяРеквизитаИспользоватьПодтверждениеВозрастаЧерезМакс();
		
		// Реквизит для контроля необходимости отображения состояния проверки возраста покупателя
		ИмяРеквизитаЕстьТоварыТребующиеПодтвержденияВозраста = 
			РозничныеПродажиКлиентСерверЛокализация.ИмяРеквизитаЕстьТоварыТребующиеПодтвержденияВозрастаПокупателя();
		// Реквизит для хранения состояния проверки возраста покупателя
		ИмяРеквизитаСостояниеПроверкиВозраста = 
			РозничныеПродажиКлиентСерверЛокализация.ИмяРеквизитаСостояниеПроверкиВозрастаПокупателя();

		ФормаБылаНастроена = ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(Форма, ИмяКонтрольногоРеквизита);
		// Добавление реквизитов, элементов формы 
		Если Не ФормаБылаНастроена Тогда
			ДобавляемыеРеквизиты = Новый Массив;
			
			// Добавляем реквизит для хранения состояния функциональной опции
			НовРеквизит = Новый РеквизитФормы(ИмяКонтрольногоРеквизита, Новый ОписаниеТипов("Булево"));
			ДобавляемыеРеквизиты.Добавить(НовРеквизит);
			
			// Добавляем реквизит для контроля необходимости отображения состояния проверки возраста покупателя
			НовРеквизит = Новый РеквизитФормы(ИмяРеквизитаЕстьТоварыТребующиеПодтвержденияВозраста, Новый ОписаниеТипов("Булево"));
			ДобавляемыеРеквизиты.Добавить(НовРеквизит);
			
			// Добавляем реквизит для хранения состояния проверки возраста покупателя
			НовРеквизит = Новый РеквизитФормы(ИмяРеквизитаСостояниеПроверкиВозраста,
											Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(1, 0, ДопустимыйЗнак.Неотрицательный)));
			ДобавляемыеРеквизиты.Добавить(НовРеквизит);
		
			// Добавляем декорацию для отображения состояния проверки возраста покупателя
			ИмяЭлементаФормыСостояниеПроверкиВозрастаПокупателя = 
				РозничныеПродажиКлиентСерверЛокализация.ИмяЭлементаФормыСостояниеПроверкиВозрастаПокупателя(Форма.ИмяФормы);
			ЭлементФормыСостояниеПроверки = Форма.Элементы.Найти(ИмяЭлементаФормыСостояниеПроверкиВозрастаПокупателя);
			Если ЭлементФормыСостояниеПроверки = Неопределено Тогда
				// На подключенной форме должна присутствовать эта группа элементов
				ИмяГруппыСостояниеПроверкиВозрастаПокупателя = "ЛокализацияГруппаСостояниеПроверкиВозрастаПокупателя";
				ГруппаСостояниеПроверкиВозрастаПокупателя = Форма.Элементы[ИмяГруппыСостояниеПроверкиВозрастаПокупателя];
				ЭлементФормыСостояниеПроверки = Форма.Элементы.Добавить(ИмяЭлементаФормыСостояниеПроверкиВозрастаПокупателя, 
														Тип("ДекорацияФормы"), 
														ГруппаСостояниеПроверкиВозрастаПокупателя); // ДекорацияФормы
				ЭлементФормыСостояниеПроверки.Вид = ВидДекорацииФормы.Надпись;
			КонецЕсли;
			ЭлементФормыСостояниеПроверки.УстановитьДействие("ОбработкаНавигационнойСсылки", 
											РозничныеПродажиКлиентСерверЛокализация.ИмяОбработчикаНавигационнойСсылкиЭлементаФормыСостояниеПроверкиВозрастаПокупателя());
		
			// Добавляем команду подтверждения возраста через Макс
			ИмяКомандыПодтверждениеВозрастаПокупателя = 
				РозничныеПродажиКлиентСерверЛокализация.ИмяКомандыПодтверждениеВозрастаПокупателяЧерезМакс();
			ФормаКоманды = Форма.Команды; // КомандыФормы
			НоваяКоманда = ФормаКоманды.Добавить(ИмяКомандыПодтверждениеВозрастаПокупателя);
			НоваяКоманда.Действие = 
				РозничныеПродажиКлиентСерверЛокализация.ИмяДействияПодтверждениеВозрастаПокупателяЧерезМакс();
			НоваяКоманда.Заголовок = НСтр("ru = 'Подтверждение возраста'");
			НоваяКоманда.Картинка = БиблиотекаКартинок.ЛоготипМаксБПО;
			
			// Добавляем кнопку для подтверждения возраста через Макс
			ИмяКнопкиПодтверждениеВозрастаПокупателяЧерезМакс = РозничныеПродажиКлиентСерверЛокализация.ИмяКнопкиПодтверждениеВозрастаПокупателяЧерезМакс();
			Если Форма.Элементы.Найти(ИмяКнопкиПодтверждениеВозрастаПокупателяЧерезМакс) = Неопределено Тогда
				// На подключенной форме должна присутствовать эта группа элементов					
				ИмяГруппыЛокализованныхКоманд = "ЛокализацияГруппаКоманд";
				ГруппаЛокализованныхКоманд = Форма.Элементы[ИмяГруппыЛокализованныхКоманд];
				
				Кнопка = Форма.Элементы.Добавить(ИмяКнопкиПодтверждениеВозрастаПокупателяЧерезМакс, 
												Тип("КнопкаФормы"), 
												ГруппаЛокализованныхКоманд);
												
				Кнопка.ИмяКоманды = ИмяКомандыПодтверждениеВозрастаПокупателя;
				Кнопка.ПоложениеВКоманднойПанели = ПоложениеКнопкиВКоманднойПанели.ВДополнительномПодменю;
			КонецЕсли;
			
			Форма.ИзменитьРеквизиты(ДобавляемыеРеквизиты);

		КонецЕсли;
		
		// Инициализация значений
		Если Не ФормаБылаНастроена Или ТекущийОбъект <> Неопределено И ЗначениеЗаполнено(ТекущийОбъект.Ссылка) Тогда
			Форма[ИмяРеквизитаСостояниеПроверкиВозраста] = 0;
			Форма[ИмяРеквизитаЕстьТоварыТребующиеПодтвержденияВозраста] = Ложь;
			
			КлючиВидовПродукцииИСНоменклатуры = Новый Соответствие;
			Если Форма.ИмяФормы = "Обработка.ПредпросмотрЧека.Форма.Форма"
				И ТипЗнч(Форма.ДокументСсылка) = Тип("ДокументСсылка.РеализацияТоваровУслуг") Тогда
				КлючиВидовПродукцииИСНоменклатуры = КлючиВидовПродукцииИСТоварныхПозицийДокументаПродажи(Форма.ДокументСсылка);
			ИначеЕсли Форма.ИмяФормы = "Документ.ЧекККМ.Форма.ФормаДокументаРМК" Тогда
				ФормаОбъект = Форма.Объект; // ДокументОбъект
				Если ЗначениеЗаполнено(ФормаОбъект.Ссылка) Тогда
					КлючиВидовПродукцииИСНоменклатуры = КлючиВидовПродукцииИСТоварныхПозицийДокументаПродажи(ФормаОбъект.Ссылка);
				КонецЕсли;
			КонецЕсли;
			Если КлючиВидовПродукцииИСНоменклатуры.Количество() Тогда
				КлючиВидовПродукцииИСДляПроверки = Новый Массив;
				Для Каждого КлючВидаПродукции Из КлючиВидовПродукцииИСНоменклатуры Цикл
					Если КлючиВидовПродукцииИСДляПроверки.Найти(КлючВидаПродукции.Значение) = Неопределено Тогда
						Для Каждого ВидПродукции Из КонструкторИСОбщегоНазначенияКлиентСервер.ВидыПродукцииКлюча(КлючВидаПродукции.Значение) Цикл
							Если КлючиВидовПродукцииИСДляПроверки.Найти(ВидПродукции) = Неопределено Тогда
								КлючиВидовПродукцииИСДляПроверки.Добавить(ВидПродукции);
							КонецЕсли;
						КонецЦикла;
					КонецЕсли;
				КонецЦикла;
				Форма[ИмяРеквизитаЕстьТоварыТребующиеПодтвержденияВозраста] = КонструкторИСОбщегоНазначенияКлиентСервер.ПроверятьВозраст(КлючиВидовПродукцииИСДляПроверки);
			КонецЕсли;

			Если ПолучитьФункциональнуюОпцию(ИмяКонтрольногоРеквизита) Тогда
				Форма[ИмяКонтрольногоРеквизита] = Истина;
			КонецЕсли;
			ОбновитьНастройкиФормыДляПроверкиВозрастаПокупателя(Форма);
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

Процедура ОбновитьНастройкиФормыДляПроверкиВозрастаПокупателя(Форма) Экспорт
	
	ИмяРеквизитаЕстьТоварыТребующиеПодтвержденияВозрастаПокупателя = 
			РозничныеПродажиКлиентСерверЛокализация.ИмяРеквизитаЕстьТоварыТребующиеПодтвержденияВозрастаПокупателя();
	ИмяРеквизитаСостояниеПроверкиВозрастаПокупателя = РозничныеПродажиКлиентСерверЛокализация.ИмяРеквизитаСостояниеПроверкиВозрастаПокупателя();
	ВидимостьКнопкиПодтверждениеВозрастаПоУмолчанию = 
		ПолучитьФункциональнуюОпцию(РозничныеПродажиКлиентСерверЛокализация.ИмяРеквизитаИспользоватьПодтверждениеВозрастаЧерезМакс());
	ДоступностьКнопкиПодтверждениеВозрастаПоУмолчанию = ВидимостьКнопкиПодтверждениеВозрастаПоУмолчанию;
	Если Форма.ИмяФормы = "Документ.ЧекККМ.Форма.ФормаДокументаРМК" И Форма.Объект.Товары.Количество() = 0 Тогда
		ДоступностьКнопкиПодтверждениеВозрастаПоУмолчанию = Ложь;
	КонецЕсли;
	КодСостоянияПроверки = Форма[ИмяРеквизитаСостояниеПроверкиВозрастаПокупателя];
	Если КодСостоянияПроверки = 0 Тогда
		Если Форма[ИмяРеквизитаЕстьТоварыТребующиеПодтвержденияВозрастаПокупателя] = Истина Тогда
			Если Форма[РозничныеПродажиКлиентСерверЛокализация.ИмяРеквизитаИспользоватьПодтверждениеВозрастаЧерезМакс()] = Истина Тогда
				КодСостоянияПроверки = 2;
			Иначе
				КодСостоянияПроверки = 1;
			КонецЕсли;
		КонецЕсли;
	ИначеЕсли (КодСостоянияПроверки = 1 Или КодСостоянияПроверки = 2
			Или ДоступностьКнопкиПодтверждениеВозрастаПоУмолчанию = Ложь)
			И Форма[ИмяРеквизитаЕстьТоварыТребующиеПодтвержденияВозрастаПокупателя] = Ложь Тогда
		КодСостоянияПроверки = 0;
	КонецЕсли;
	Если КодСостоянияПроверки <> Форма[ИмяРеквизитаСостояниеПроверкиВозрастаПокупателя] Тогда
		Форма[ИмяРеквизитаСостояниеПроверкиВозрастаПокупателя] = КодСостоянияПроверки;
	КонецЕсли;
	
	ОформитьЭлементФормыСостояниеПроверкиВозрастаПокупателя(Форма);

	КнопкаПодтверждениеВозраста = Форма.Элементы[РозничныеПродажиКлиентСерверЛокализация.ИмяКнопкиПодтверждениеВозрастаПокупателяЧерезМакс()];
	КнопкаПодтверждениеВозраста.Видимость = ВидимостьКнопкиПодтверждениеВозрастаПоУмолчанию; 
	КнопкаПодтверждениеВозраста.Доступность = ДоступностьКнопкиПодтверждениеВозрастаПоУмолчанию;
	
КонецПроцедуры

// Оформление декорации состояние проверки возраста покупателя.
// Если используется поле ввода, то на форме должен быть объявлен одноименный реквизит для хранения данных,
// связанный с этим элементом формы.
//
// Параметры:
//  Форма - ФормаКлиентскогоПриложения -
//
Процедура ОформитьЭлементФормыСостояниеПроверкиВозрастаПокупателя(Форма) Экспорт
	
	ИмяЭлементаФормы = 
		РозничныеПродажиКлиентСерверЛокализация.ИмяЭлементаФормыСостояниеПроверкиВозрастаПокупателя(Форма.ИмяФормы);
	ЭлементФормы = Форма.Элементы[ИмяЭлементаФормы]; // ДекорацияФормы, ПолеФормы
	ЭлементФормы.Видимость = Ложь;
	
	ЗаголовокДекорации = Новый ФорматированнаяСтрока(
								НСтр("ru = 'Подтверждение возраста не требуется'"),
								ШрифтыСтиля.ЖирныйШрифт,
								ЦветаСтиля.ГиперссылкаЦвет);
	
	//  КодСостояния - Число - 0 проверка не требуется
	//                         1 проверка требуется, не включен механизм проверки
	//                         2 проверка требуется, включен механизм проверки
	//                         3 проверка прошла успешно, возраст подтвержден
	//                         4 проверка не пройдена, возраст не подтвержден
	//                         5 проверка не пройдена, произошла ошибка
	КодСостояния = Форма[РозничныеПродажиКлиентСерверЛокализация.ИмяРеквизитаСостояниеПроверкиВозрастаПокупателя()];
	Если КодСостояния = 1 Тогда
		ЭлементФормы.Видимость = Истина;
		ЗаголовокДекорации = Новый ФорматированнаяСтрока(
									НСтр("ru = 'Требуется подтверждение возраста'"),
									ШрифтыСтиля.ЖирныйШрифт,
									WebЦвета.Красный);
	ИначеЕсли КодСостояния = 2 Тогда
		ЭлементФормы.Видимость = Истина;
		ЗаголовокДекорации = Новый ФорматированнаяСтрока(
									НСтр("ru = 'Требуется подтверждение возраста'"),
									ШрифтыСтиля.ЖирныйШрифт,
									WebЦвета.Красный,
									,
									РозничныеПродажиКлиентСерверЛокализация.ИмяДействияПодтверждениеВозрастаПокупателяЧерезМакс());
	ИначеЕсли КодСостояния = 3 Тогда
		ЭлементФормы.Видимость = Истина;
		ЗаголовокДекорации = Новый ФорматированнаяСтрока(
									НСтр("ru = 'Возраст покупателя подтвержден'"),
									ШрифтыСтиля.ОбычныйШрифтТекста,
									WebЦвета.НейтральноСиний);
	ИначеЕсли КодСостояния = 4 Тогда
		ЭлементФормы.Видимость = Истина;
		ЗаголовокДекорации = Новый ФорматированнаяСтрока(
									НСтр("ru = 'Возраст покупателя не подтвержден'"),
									ШрифтыСтиля.ЖирныйШрифт,
									WebЦвета.Красный);
	ИначеЕсли КодСостояния = 5 Тогда
		ЭлементФормы.Видимость = Истина;
		ЗаголовокДекорации = Новый ФорматированнаяСтрока(
									НСтр("ru = 'Ошибка при подтверждении возраста, повторить операцию'"),
									ШрифтыСтиля.ЖирныйШрифт,
									WebЦвета.Коричневый,
									,
									РозничныеПродажиКлиентСерверЛокализация.ИмяДействияПодтверждениеВозрастаПокупателяЧерезМакс());
	КонецЕсли;
	
	Если ТипЗнч(ЭлементФормы) = Тип("ДекорацияФормы") Тогда
		ЭлементФормы.Заголовок = ЗаголовокДекорации;
	ИначеЕсли ТипЗнч(ЭлементФормы) = Тип("ПолеФормы") Тогда
		Форма[ИмяЭлементаФормы] = ЗаголовокДекорации;
	Иначе
		ЭлементФормы.Видимость = Ложь;
	КонецЕсли;

КонецПроцедуры

#КонецОбласти

// Функция проверяет, что ИНН комитента, указанный для номенклатурной позиции в строке таблицы присутствует среди ИНН 
// поставщиков комиссионного товара, указанных в данных фискального чека продажи.
// Возвращает Истина, если ИНН во всех строках присутствуют в данных фискального чека продажи, иначе - Ложь.
//
// Параметры:
//	ТаблицаДляПроверки - ТаблицаЗначений - Таблица значений с данными для проверки. Колонки:
//	  *Номенклатура - СправочникСсылка.Номенклатура - 
//	  *Характеристика - СправочникСсылка.ХарактеристикиНоменклатуры - 
//	  *Серия - СправочникСсылка.СерииНоменклатуры - 
//	  *Комитент - СправочникСсылка.Организации, СправочникСсылка.Контрагенты, Неопределено - 
//	  *ИННКомитента - Строка -
//	ДанныеИсходнойФискальнойОперации - см. ОборудованиеЧекопечатающиеУстройства.ДанныеФискальнойОперации
//
// Возвращаемое значение:
//	Булево
//
Функция ИННКомитентаВТаблицеСоответствуетИсходному(ТаблицаДляПроверки, ДанныеИсходнойФискальнойОперации) Экспорт
	РезультатПроверки = Истина;
	Если ТаблицаДляПроверки.Количество() = 0 Тогда
		Возврат РезультатПроверки;
	КонецЕсли;

	ДанныеЧекаXML = Неопределено;
	Если ТипЗнч(ДанныеИсходнойФискальнойОперации.ДанныеXML) = Тип("ХранилищеЗначения") Тогда
		ДанныеЧекаXML = ДанныеИсходнойФискальнойОперации.ДанныеXML.Получить();
	КонецЕсли;
	Если ЗначениеЗаполнено(ДанныеЧекаXML) Тогда
		
		// Обрабатываем данные о маркировке, нам нужны данные только о поставщиках маркированных товаров
		ДанныеЧека = ОборудованиеЧекопечатающиеУстройства.ЗагрузитьДанныеФискализацииИзXML(ДанныеЧекаXML, Истина);
		ДанныеПоставщиковМаркированныхТоваровИзЧека = Новый Соответствие;
		ЕстьМаркированныеТовары = Ложь;
		// Свойство обязательное
		Для Каждого ПозицияЧека Из ДанныеЧека.ПозицииЧека Цикл
			Если ПозицияЧека.Свойство("ПризнакАгентаПоПредметуРасчета") 
				И ПозицияЧека.ПризнакАгентаПоПредметуРасчета = Перечисления.ПризнакиАгента.Комиссионер
				И ПозицияЧека.Свойство("КонтрольнаяМарка") 
				И ЗначениеЗаполнено(ПозицияЧека.КонтрольнаяМарка) Тогда
				ЕстьМаркированныеТовары = Истина;
				// Свойство обязательное, если не указано, то ККТ не пробьет чек.
				Если ЗначениеЗаполнено(ПозицияЧека.ДанныеПоставщика.ИНН) Тогда
					ДанныеПоставщиковМаркированныхТоваровИзЧека.Вставить(ПозицияЧека.ДанныеПоставщика.ИНН, ПозицияЧека.ДанныеПоставщика.Наименование); 
				КонецЕсли;
			КонецЕсли;
		КонецЦикла;
		Если ДанныеПоставщиковМаркированныхТоваровИзЧека.Количество() Тогда
			Для Каждого СтрокаДляПроверки Из ТаблицаДляПроверки Цикл
				Если ДанныеПоставщиковМаркированныхТоваровИзЧека.Получить(СтрокаДляПроверки.ИННКомитента) = Неопределено Тогда
					СтрокиПозиции = Новый Массив;
					СтрокиПозиции.Добавить(Строка(СтрокаДляПроверки.Номенклатура));
					Если ЗначениеЗаполнено(СтрокаДляПроверки.Характеристика) Тогда
						СтрокиПозиции.Вставить(Строка(СтрокаДляПроверки.Характеристика));
					КонецЕсли;
					Если ЗначениеЗаполнено(СтрокаДляПроверки.Серия) Тогда
						СтрокиПозиции.Вставить("Серия №:" + Строка(СтрокаДляПроверки.Серия));
					КонецЕсли;
					ПредставлениеПозиции = СтрСоединить(СтрокиПозиции, "/");
					ШаблонТекстаОшибки = НСтр("ru = 'Для маркированного товара ""%1"" ИНН %2 комитента %3 отличается от указанного в документе-основании.'");
					ТекстОшибки = СтрШаблон(ШаблонТекстаОшибки, ПредставлениеПозиции, СтрокаДляПроверки.ИННКомитента, СтрокаДляПроверки.Комитент);
					ОбщегоНазначения.СообщитьПользователю(ТекстОшибки);
					РезультатПроверки = Ложь;
				КонецЕсли;
			КонецЦикла;
		ИначеЕсли ЕстьМаркированныеТовары Тогда
			// Сообщение выводится информационно
			ОбщегоНазначения.СообщитьПользователю(НСтр("ru = 'Не найдено данных о владельцах маркированного товара в XML чека продажи. Проверка не выполнялась.'"));
			РезультатПроверки = Истина;
		КонецЕсли;
	Иначе
		// Сообщение выводится информационно
		ОбщегоНазначения.СообщитьПользователю(НСтр("ru = 'Не удалось получить данные о владельцах маркированного товара для проверки из XML чека продажи. Проверка не выполнялась.'"));
		РезультатПроверки = Истина;
	КонецЕсли;
	
	Возврат РезультатПроверки;
КонецФункции

// Проверяет данные маркированных товаров документа перед выполнением фискальной операции
//
// Параметры:
//  Объект - ДокументОбъект.КорректировкаРеализации - Объект документа КорректировкаРеализации
//  ДополнительныеПараметры - Структура Из КлючИЗначение - Произвольная структура для передачи данных из клиентского контекста
//
// Возвращаемое значение:
//  Булево - 
//
Функция ПроверкаДанныхМаркированногоТовараДокументаКорректировкаРеализации(Объект, ДополнительныеПараметры = Неопределено)
	Результат = Истина;
	
	ДанныеФискальногоЧекаРТУ = ФормированиеФискальныхЧековСервер.ДанныеПробитогоФискальногоЧекаПоДокументу(Объект.ДокументОснование);
	Если ДанныеФискальногоЧекаРТУ = Неопределено Тогда
		Возврат Результат;
	КонецЕсли;
	
	Если Не КорректировкаРеализацииЛокализация.ДокументСодержитМаркированныйТовар(Объект.Ссылка) Тогда
		Возврат Результат;
	КонецЕсли;
	
	Если Не (ЗначениеЗаполнено(Объект.ДокументОснование)
		И ТипЗнч(Объект.ДокументОснование) = Тип("ДокументСсылка.РеализацияТоваровУслуг")) Тогда
		ОбщегоНазначения.СообщитьПользователю(НСтр("ru = 'Операция коррекции маркированной продукции на ККТ не поддерживается.'"));
		
		Результат = Ложь;
		Возврат Результат;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ТаблицаРасхождений.Номенклатура КАК Номенклатура,
	|	ТаблицаРасхождений.Характеристика КАК Характеристика,
	|	ТаблицаРасхождений.Серия КАК Серия,
	|	СУММА(ТаблицаРасхождений.Количество) КАК КоличествоИзменение,
	|	МАКСИМУМ(ТаблицаРасхождений.КоличествоПродано) КАК КоличествоПродано,
	|	МАКСИМУМ(ТаблицаРасхождений.НомерСтроки) КАК НомерСтроки,
	|	МАКСИМУМ(ТаблицаРасхождений.ЭтоРеализация) КАК ЭтоРеализация,
	|	МАКСИМУМ(ТаблицаРасхождений.ЭтоКорректировка) КАК ЭтоКорректировка
	|ИЗ
	|	(ВЫБРАТЬ
	|		ТоварыРеализацияТоваровУслуг.Номенклатура КАК Номенклатура,
	|		ТоварыРеализацияТоваровУслуг.Характеристика КАК Характеристика,
	|		ТоварыРеализацияТоваровУслуг.Серия КАК Серия,
	|		ТоварыРеализацияТоваровУслуг.Количество КАК Количество,
	|		ТоварыРеализацияТоваровУслуг.Количество КАК КоличествоПродано,
	|		ТоварыРеализацияТоваровУслуг.НомерСтроки КАК НомерСтроки,
	|		1 КАК ЭтоРеализация,
	|		0 КАК ЭтоКорректировка
	|	ИЗ
	|		Документ.РеализацияТоваровУслуг.Товары КАК ТоварыРеализацияТоваровУслуг
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.ОписаниеНоменклатурыИС КАК ОписаниеНоменклатурыИС
	|		ПО ТоварыРеализацияТоваровУслуг.Номенклатура = ОписаниеНоменклатурыИС.Номенклатура
	|		И ОписаниеНоменклатурыИС.КлючВидовПродукции.ВидПродукцииГИСМТ <> ЗНАЧЕНИЕ(Справочник.ВидыПродукцииИС.ПустаяСсылка)
	|	ГДЕ
	|		ТоварыРеализацияТоваровУслуг.Ссылка = &ДокументОснование
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ
	|		ТоварыКорректировкаРеализации.Номенклатура,
	|		ТоварыКорректировкаРеализации.Характеристика,
	|		ТоварыКорректировкаРеализации.Серия,
	|		-ТоварыКорректировкаРеализации.Количество,
	|		0,
	|		ТоварыКорректировкаРеализации.НомерСтроки,
	|		0,
	|		1
	|	ИЗ
	|		Документ.КорректировкаРеализации.Товары КАК ТоварыКорректировкаРеализации
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.ОписаниеНоменклатурыИС КАК ОписаниеНоменклатурыИС
	|		ПО ТоварыКорректировкаРеализации.Номенклатура = ОписаниеНоменклатурыИС.Номенклатура
	|		И ОписаниеНоменклатурыИС.КлючВидовПродукции.ВидПродукцииГИСМТ <> ЗНАЧЕНИЕ(Справочник.ВидыПродукцииИС.ПустаяСсылка)
	|	ГДЕ
	|		ТоварыКорректировкаРеализации.Ссылка = &Ссылка) КАК ТаблицаРасхождений
	|
	|СГРУППИРОВАТЬ ПО
	|	ТаблицаРасхождений.Номенклатура,
	|	ТаблицаРасхождений.Характеристика,
	|	ТаблицаРасхождений.Серия
	|
	|ИМЕЮЩИЕ
	|	СУММА(ТаблицаРасхождений.Количество) <> 0
	|
	|УПОРЯДОЧИТЬ ПО
	|	НомерСтроки
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ШтрихкодыУпаковокКорректировки.ШтрихкодУпаковки КАК ШтрихкодУпаковки,
	|	ШтрихкодыУпаковокКорректировки.ШтрихкодУпаковки.Номенклатура КАК Номенклатура,
	|	ШтрихкодыУпаковокКорректировки.ШтрихкодУпаковки.Характеристика КАК Характеристика,
	|	ШтрихкодыУпаковокКорректировки.ШтрихкодУпаковки.Серия КАК Серия
	|ИЗ
	|	Документ.КорректировкаРеализации.ШтрихкодыУпаковок КАК ШтрихкодыУпаковокКорректировки
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.РеализацияТоваровУслуг.ШтрихкодыУпаковок КАК ШтрихкодыУпаковокРеализации
	|		ПО (ШтрихкодыУпаковокРеализации.Ссылка = &ДокументОснование)
	|			И ШтрихкодыУпаковокКорректировки.ШтрихкодУпаковки = ШтрихкодыУпаковокРеализации.ШтрихкодУпаковки
	|ГДЕ
	|	ШтрихкодыУпаковокКорректировки.Ссылка = &Ссылка
	|	И ШтрихкодыУпаковокРеализации.ШтрихкодУпаковки ЕСТЬ NULL
	|ИТОГИ ПО
	|	Номенклатура,
	|	Характеристика,
	|	Серия,
	|	ШтрихкодУпаковки
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ВидыЗапасов.Номенклатура КАК Номенклатура,
	|	ВидыЗапасов.Характеристика КАК Характеристика,
	|	ВидыЗапасов.Серия КАК Серия,
	|	ВидыЗапасов.Комитент КАК Комитент,
	|	ВидыЗапасов.ИННКомитента КАК ИННКомитента
	|ИЗ
	|	(ВЫБРАТЬ
	|		ВидыЗапасовКорректировкаВыручки.АналитикаУчетаНоменклатуры.Номенклатура КАК Номенклатура,
	|		ВидыЗапасовКорректировкаВыручки.АналитикаУчетаНоменклатуры.Характеристика КАК Характеристика,
	|		ВидыЗапасовКорректировкаВыручки.АналитикаУчетаНоменклатуры.Серия КАК Серия,
	|		ВидыЗапасовКорректировкаВыручки.ВидЗапасов.Контрагент КАК Комитент,
	|		ВЫБОР
	|			КОГДА ВидыЗапасовКорректировкаВыручки.ВидЗапасов.Контрагент = НЕОПРЕДЕЛЕНО
	|				ТОГДА """"
	|			ИНАЧЕ ВидыЗапасовКорректировкаВыручки.ВидЗапасов.Контрагент.ИНН
	|		КОНЕЦ КАК ИННКомитента
	|	ИЗ
	|		Документ.КорректировкаРеализации.ВидыЗапасовКорректировкаВыручки КАК ВидыЗапасовКорректировкаВыручки
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.ОписаниеНоменклатурыИС КАК ОписаниеНоменклатурыИС
	|		ПО ВидыЗапасовКорректировкаВыручки.АналитикаУчетаНоменклатуры.Номенклатура = ОписаниеНоменклатурыИС.Номенклатура
	|		И ОписаниеНоменклатурыИС.КлючВидовПродукции.ВидПродукцииГИСМТ <> ЗНАЧЕНИЕ(Справочник.ВидыПродукцииИС.ПустаяСсылка)
	|	ГДЕ
	|		ВидыЗапасовКорректировкаВыручки.Ссылка = &Ссылка
	|		И ВидыЗапасовКорректировкаВыручки.ВидЗапасов.ТипЗапасов = ЗНАЧЕНИЕ(Перечисление.ТипыЗапасов.КомиссионныйТовар)
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ
	|		ВидыЗапасовСписание.АналитикаУчетаНоменклатуры.Номенклатура,
	|		ВидыЗапасовСписание.АналитикаУчетаНоменклатуры.Характеристика,
	|		ВидыЗапасовСписание.АналитикаУчетаНоменклатуры.Серия,
	|		ВидыЗапасовСписание.ВидЗапасов.Контрагент,
	|		ВЫБОР
	|			КОГДА ВидыЗапасовСписание.ВидЗапасов.Контрагент = НЕОПРЕДЕЛЕНО
	|				ТОГДА """"
	|			ИНАЧЕ ВидыЗапасовСписание.ВидЗапасов.Контрагент.ИНН
	|		КОНЕЦ
	|	ИЗ
	|		Документ.КорректировкаРеализации.ВидыЗапасовСписание КАК ВидыЗапасовСписание
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.ОписаниеНоменклатурыИС КАК ОписаниеНоменклатурыИС
	|		ПО ВидыЗапасовСписание.АналитикаУчетаНоменклатуры.Номенклатура = ОписаниеНоменклатурыИС.Номенклатура
	|		И ОписаниеНоменклатурыИС.КлючВидовПродукции.ВидПродукцииГИСМТ <> ЗНАЧЕНИЕ(Справочник.ВидыПродукцииИС.ПустаяСсылка)
	|	ГДЕ
	|		ВидыЗапасовСписание.Ссылка = &Ссылка
	|		И ВидыЗапасовСписание.ВидЗапасов.ТипЗапасов = ЗНАЧЕНИЕ(Перечисление.ТипыЗапасов.КомиссионныйТовар)) КАК ВидыЗапасов";

	Запрос.УстановитьПараметр("Ссылка", Объект.Ссылка);
	Запрос.УстановитьПараметр("ДокументОснование", Объект.ДокументОснование);
	
	РезультатыЗапроса = Запрос.ВыполнитьПакет();
	РезультатПроверкиТоваров = РезультатыЗапроса[0];
	РезультатПроверкиКМ = РезультатыЗапроса[1];
	РезультатДляПроверкиИННКомитента = РезультатыЗапроса[2];
	
	Если Не РезультатПроверкиТоваров.Пустой() Тогда
		Результат = Ложь;
		ВыборкаРасхождений = РезультатПроверкиТоваров.Выбрать();
		Пока ВыборкаРасхождений.Следующий() Цикл
			СтрокиПозиции = Новый Массив;
			СтрокиПозиции.Добавить(Строка(ВыборкаРасхождений.Номенклатура));
			Если ЗначениеЗаполнено(ВыборкаРасхождений.Характеристика) Тогда
				СтрокиПозиции.Добавить(Строка(ВыборкаРасхождений.Номенклатура));
			КонецЕсли;
			Если ЗначениеЗаполнено(ВыборкаРасхождений.Серия) Тогда
				СтрокиПозиции.Добавить("Серия №:" + Строка(ВыборкаРасхождений.Серия));
			КонецЕсли;
			ПредставлениеПозиции = СтрСоединить(СтрокиПозиции, "/");
			Если ВыборкаРасхождений.ЭтоРеализация = 0 Тогда
				ШаблонТекстаОшибки = НСтр("ru = 'В стр. №%1 указан маркированный товар ""%2"", отсутствующий в документе-основании.'");
				ТекстОшибки = СтрШаблон(ШаблонТекстаОшибки, ВыборкаРасхождений.НомерСтроки, ПредставлениеПозиции);
				ОбщегоНазначения.СообщитьПользователю(ТекстОшибки);
			ИначеЕсли ВыборкаРасхождений.ЭтоКорректировка = 0 Тогда
				ШаблонТекстаОшибки = НСтр("ru = 'Удален маркированный товар ""%1"", присутствующий в документе-основании.'");
				ТекстОшибки = СтрШаблон(ШаблонТекстаОшибки, ПредставлениеПозиции);  
				ОбщегоНазначения.СообщитьПользователю(ТекстОшибки);
			ИначеЕсли ВыборкаРасхождений.КоличествоИзменение <> 0 Тогда
				ШаблонТекстаОшибки = НСтр("ru = 'Изменено количество маркированного товара ""%1"" с %2 на %3'");
				ТекстОшибки = СтрШаблон(ШаблонТекстаОшибки, 
										ПредставлениеПозиции, 
										Строка(ВыборкаРасхождений.КоличествоПродано), 
										Строка(ВыборкаРасхождений.КоличествоПродано - ВыборкаРасхождений.КоличествоИзменение));
				ОбщегоНазначения.СообщитьПользователю(ТекстОшибки);
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
	Если Не РезультатПроверкиКМ.Пустой() Тогда
		Результат = Ложь;
		ВыборкаПоНоменклатуре = РезультатПроверкиКМ.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		Пока ВыборкаПоНоменклатуре.Следующий() Цикл
			ВыборкаПоХарактеристике = ВыборкаПоНоменклатуре.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
			Пока ВыборкаПоХарактеристике.Следующий() Цикл
				ВыборкаПоСерии = ВыборкаПоХарактеристике.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
				Пока ВыборкаПоСерии.Следующий() Цикл
					МассивПредставленийКМ = Новый Массив;
					ВыборкаПоКМ = ВыборкаПоСерии.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
					Пока ВыборкаПоКМ.Следующий()Цикл
						МассивПредставленийКМ.Добавить(Строка(ВыборкаПоКМ.ШтрихкодУпаковки));
					КонецЦикла;
					Если МассивПредставленийКМ.Количество() Тогда
						СтрокиПозиции = Новый Массив;
						СтрокиПозиции.Добавить(Строка(ВыборкаПоСерии.Номенклатура));
						Если ЗначениеЗаполнено(ВыборкаПоСерии.Характеристика) Тогда
							СтрокиПозиции.Добавить(Строка(ВыборкаПоСерии.Характеристика));
						КонецЕсли;
						Если ЗначениеЗаполнено(ВыборкаПоСерии.Серия) Тогда
							СтрокиПозиции.Добавить("Серия №:" + Строка(ВыборкаПоСерии.Серия));
						КонецЕсли;
						ПредставлениеПозиции = СтрСоединить(СтрокиПозиции, "/");
						ШаблонТекстаОшибки = НСтр("ru = 'Для маркированного товара ""%1"" присутствуют коды маркировки, которых нет в документе-основании:'");
						МассивПредставленийКМ.Вставить(0, СтрШаблон(ШаблонТекстаОшибки, ПредставлениеПозиции));
						ТекстОшибки = СтрСоединить(МассивПредставленийКМ, Символы.ПС);
						ОбщегоНазначения.СообщитьПользователю(ТекстОшибки);
					КонецЕсли;
				КонецЦикла;
			КонецЦикла;
		КонецЦикла;
	КонецЕсли;
	
	Если Не РезультатДляПроверкиИННКомитента.Пустой() Тогда
		Результат = ИННКомитентаВТаблицеСоответствуетИсходному(РезультатДляПроверкиИННКомитента.Выгрузить(), ДанныеФискальногоЧекаРТУ) И Результат;
	КонецЕсли;
	
	Возврат Результат;
КонецФункции

// Проверяет данные маркированных товаров документа перед выполнением фискальной операции
//
// Параметры:
//  Объект - ДокументОбъект.ЧекККМКоррекции - Объект документа ЧекККМКоррекции
//  ДополнительныеПараметры - Структура Из КлючИЗначение - Произвольная структура для передачи данных из клиентского контекста
//
// Возвращаемое значение:
//  Булево - 
//
Функция ПроверкаДанныхМаркированногоТовараДокументаЧекККМКоррекции(Объект, ДополнительныеПараметры = Неопределено)
	Результат = Истина;
	
	ДанныеФискальногоЧекаККМ = ФормированиеФискальныхЧековСервер.ДанныеПробитогоФискальногоЧекаПоДокументу(Объект.ЧекККМ);
	Если ДанныеФискальногоЧекаККМ = Неопределено Тогда
		Возврат Результат;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Товары.Номенклатура КАК Номенклатура,
	|	Товары.Характеристика КАК Характеристика,
	|	Товары.Серия КАК Серия,
	|	Товары.Комитент КАК Комитент
	|ПОМЕСТИТЬ ТоварыИсходнаяТаблица
	|ИЗ
	|	&ТаблицаТовары КАК Товары
	|ГДЕ
	|	Товары.Комитент <> НЕОПРЕДЕЛЕНО
	|	И Товары.Комитент <> ЗНАЧЕНИЕ(Справочник.Контрагенты.ПустаяСсылка)
	|	И Товары.Комитент <> ЗНАЧЕНИЕ(Справочник.Организации.ПустаяСсылка)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Товары.Номенклатура КАК Номенклатура,
	|	Товары.Характеристика КАК Характеристика,
	|	Товары.Серия КАК Серия,
	|	Товары.Комитент КАК Комитент,
	|	Товары.Комитент.ИНН КАК ИННКомитента
	|ИЗ
	|	ТоварыИсходнаяТаблица КАК Товары
	|	ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.ОписаниеНоменклатурыИС КАК ОписаниеНоменклатурыИС
	|	ПО Товары.Номенклатура = ОписаниеНоменклатурыИС.Номенклатура
	|	И ОписаниеНоменклатурыИС.КлючВидовПродукции.ВидПродукцииГИСМТ <> ЗНАЧЕНИЕ(Справочник.ВидыПродукцииИС.ПустаяСсылка)";

	Запрос.УстановитьПараметр("ТаблицаТовары", Объект.Товары.Выгрузить());
	
	РезультатДляПроверкиИННКомитента = Запрос.Выполнить();
	Если Не РезультатДляПроверкиИННКомитента.Пустой() Тогда
		Результат = ИННКомитентаВТаблицеСоответствуетИсходному(РезультатДляПроверкиИННКомитента.Выгрузить(), ДанныеФискальногоЧекаККМ);
	КонецЕсли;
	
	Возврат Результат;
КонецФункции

#КонецОбласти

//-- Локализация

#Область КомиссионерВЧеке

// Представляет входящий текст пакетного запроса как список значений, где текст атомарного запроса это значении элемента,
// а имя создаваемой таблицы - это представление элемента списка. 
// Параметры:
//	ТекстПакетногоЗапроса - Строка - 	граничные условия декомпозиции пакетного запроса:
//			1) Разделитель запросов ";" размещается на отдельной строке.
// 			2) имя создаваемой таблицы размещается на отдельной строке вместе с ключевым литералом "ПОМЕСТИТЬ".
//
// Возвращаемое значение:
// СписокЗначений из Строка. 
// 	*значение - это текст атомарного запроса, 
// 	*представление - имя создаваемой временной таблицы этим запросом
Функция РазбитьПакетныйЗапрос(Знач ТекстПакетногоЗапроса)
	
	ТекстПакета = СокрЛП(ТекстПакетногоЗапроса);
	СписокЗапросов = Новый СписокЗначений;
	
	ТекЗапрос = "";
	ИмяНовойВТ = "";
	
	Для СчСтроки = 1 По СтрЧислоСтрок(ТекстПакета) Цикл
		
		ТекСтрока = СтрПолучитьСтроку(ТекстПакета, СчСтроки);
		СтрокаСодержимое = СокрЛП(ТекСтрока);
		
		Если СтрНачинаетсяС(СтрокаСодержимое, ";") Тогда
			// это разделитель запросов
			Если НЕ ПустаяСтрока(ТекЗапрос) Тогда
				СписокЗапросов.Добавить(ТекЗапрос, ИмяНовойВТ);
				ТекЗапрос = "";
				ИмяНовойВТ = "";
			КонецЕсли;
			
			Продолжить;
			
		ИначеЕсли СтрНачинаетсяС(ВРег(СтрокаСодержимое), "ПОМЕСТИТЬ") Тогда
			// это имя ВТ
			ИмяНовойВТ = СокрЛП(Сред(СтрокаСодержимое, 10));
		КонецЕсли;
		ТекЗапрос = ТекЗапрос + Символы.ПС + ТекСтрока;
	КонецЦикла;
	Если НЕ ПустаяСтрока(ТекЗапрос) Тогда
		СписокЗапросов.Добавить(ТекЗапрос, ИмяНовойВТ);
	КонецЕсли;
	
	Возврат СписокЗапросов;
КонецФункции

#КонецОбласти

#КонецОбласти