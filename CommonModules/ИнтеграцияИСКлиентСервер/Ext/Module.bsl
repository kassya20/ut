Функция ЗаменитьНечитаемыеСимволы(Знач ИсходнаяСтрока, ЗаменятьПробел = Истина, ЗаменятьНа = "") Экспорт
	
	НечитаемыеСимволы = Новый Массив();
	НечитаемыеСимволы.Добавить(Символы.ВК);
	НечитаемыеСимволы.Добавить(Символы.ВТаб);
	НечитаемыеСимволы.Добавить(Символы.НПП);
	НечитаемыеСимволы.Добавить(Символы.ПС);
	НечитаемыеСимволы.Добавить(Символы.ПФ);
	НечитаемыеСимволы.Добавить(Символы.Таб);
	НечитаемыеСимволы.Добавить(Символ(182)); // символ параграфа
	НечитаемыеСимволы.Добавить(Символ(176)); // символ градуса
	
	Если ЗаменятьПробел Тогда
		НечитаемыеСимволы.Добавить(" ");
	КонецЕсли;
	
	Для Каждого НечитаемыйСимвол Из НечитаемыеСимволы Цикл
		ИсходнаяСтрока = СтрЗаменить(ИсходнаяСтрока, НечитаемыйСимвол, ЗаменятьНа);
	КонецЦикла;
	
	Возврат ИсходнаяСтрока;
	
КонецФункции

Функция ПредставлениеНаименования(Наименование, ОкружатьКавычками = Истина, МаксимальнаяДлина = 30) Экспорт

	Результат = Наименование;
	
	Если СтрДлина(Результат) > МаксимальнаяДлина Тогда
		Результат = Лев(Результат, МаксимальнаяДлина) + "...";
	КонецЕсли;
	
	Если ОкружатьКавычками Тогда
		Если Лев(Результат, 1) <> """" Тогда
			Результат = """" + Результат;
		КонецЕсли;
		Если Прав(Результат, 1) <> """" Тогда
			Результат = Результат + """";
		КонецЕсли;
	КонецЕсли;
	
	Возврат Результат;

КонецФункции

Функция СтрокаДляРасчетаХешаСоставаУпаковки(Параметры) Экспорт
	
	СтрокаДляРасчетаХеша = "";
	Если ЗначениеЗаполнено(Параметры.Номенклатура) Тогда
		СтрокаДляРасчетаХеша = СтрокаДляРасчетаХеша + Строка(Параметры.Номенклатура.УникальныйИдентификатор());
		Если ЗначениеЗаполнено(Параметры.Характеристика) Тогда
			СтрокаДляРасчетаХеша = СтрокаДляРасчетаХеша + Строка(Параметры.Характеристика.УникальныйИдентификатор());
		КонецЕсли;
	Иначе
		СтрокаДляРасчетаХеша = СтрокаДляРасчетаХеша + Параметры.GTIN;
	КонецЕсли;
	
	Возврат СтрокаДляРасчетаХеша;
	
КонецФункции

Функция ПредставлениеКоличестваСоставаУпаковкиДляРасчетаХеша(Упаковка, РодительКоличествоПредставление) Экспорт
	
	Если Упаковка.КоличествоУпаковок > 0 Тогда
		КоличествоПредставление = Формат(Упаковка.КоличествоУпаковок, "ЧДЦ=0; ЧРГ=;");
	Иначе
		КоличествоПредставление = Формат(Упаковка.Коэффициент, "ЧДЦ=0; ЧРГ=;");
	КонецЕсли;
	Если РодительКоличествоПредставление <> "" Тогда
		КоличествоПредставление = КоличествоПредставление + "*" + РодительКоличествоПредставление;
	КонецЕсли;
	
	Возврат КоличествоПредставление;
	
КонецФункции

Функция ПредставлениеСоставаУпаковки(Упаковка, РодительскаяУпаковка) Экспорт
	
	Если РодительскаяУпаковка = Неопределено Тогда
		Возврат Упаковка.Наименование;
	Иначе
		Возврат СтрШаблон("%1 - %2 %3",
			Упаковка.Наименование, Упаковка.КоличествоУпаковок, РодительскаяУпаковка.Представление);
	КонецЕсли;
	
КонецФункции

#КонецОбласти

#Область РаботаСПолямимСоставногоТипа

Функция ПутьКДаннымИзСтроки(Форма, Путь) Экспорт
	
	Если Путь = "" Тогда
		Возврат Форма;
	КонецЕсли;
	
	ПутьКДанным = Форма;
	Массив = СтрРазделить(Путь, ".");
	Для Каждого Имя Из Массив Цикл
		ПутьКДанным = ПутьКДанным[Имя];
	КонецЦикла;
	
	Возврат ПутьКДанным;
	
КонецФункции

#КонецОбласти

#Область НастройкаИнтеграцииСФГИС

Функция ИспользуетсяПодсистемаИнтеграцииСФГИС(Форма, Суффикс) Экспорт
	
	Возврат Форма["ИспользуетсяПодсистема"+Суффикс]
		Или Суффикс = КонструкторИСОбщегоНазначенияКлиентСервер.СуффиксПодсистемыМеркурийДляКлючаВидовПродукции()
			И КонструкторИСМПКлиентСервер.ЭтоСырьеГИСМТ(Форма.ВидПродукцииГИСМТ);
		
КонецФункции

Функция ДанныеПодсистемДляНастройкиИнтеграцииСФГИС(Форма) Экспорт
	
	ДанныеПодсистем = Новый Соответствие;
	
	Для Каждого Суффикс Из КонструкторИСОбщегоНазначенияКлиентСервер.СуффиксыВидовПродукцииСПредставлением() Цикл
		Если ИспользуетсяПодсистемаИнтеграцииСФГИС(Форма, Суффикс.Значение) Тогда
			ДанныеПодсистемы = Новый Структура;
			ДанныеПодсистемы.Вставить("Представление", Суффикс.Представление);
			ДанныеПодсистемы.Вставить("ВидыПродукцииПоИмениПодсистемы",
				КонструкторИСОбщегоНазначенияКлиентСервер.ВидыПродукцииПоИмениПодсистемы(Суффикс.Значение));
			ДанныеПодсистем.Вставить(Суффикс.Значение, ДанныеПодсистемы);
		КонецЕсли;
	КонецЦикла;
	
	Возврат ДанныеПодсистем;
	
КонецФункции

Процедура НастроитьРежимВыбораЭлементаВидаПродукцииКлюча(Форма, ВидыПродукции, Суффикс, ВидПродукцииИмяЭлемента) Экспорт
	
	ВидПродукцииИмяРеквизита = "ВидПродукции"+Суффикс;
	
	Массив = Новый Массив;
	Массив.Добавить(Новый ПараметрВыбора("ОтборПоПодсистеме", Суффикс));
	Форма.Элементы[ВидПродукцииИмяЭлемента].ПараметрыВыбора = Новый ФиксированныйМассив(Массив);
	
	Форма.Элементы[ВидПродукцииИмяЭлемента].СписокВыбора.Очистить();
	
	Если ВидыПродукции.Количество() > 10 Тогда
		
		Форма.Элементы[ВидПродукцииИмяЭлемента].КнопкаВыбора = Истина;
		Форма.Элементы[ВидПродукцииИмяЭлемента].РежимВыбораИзСписка = Ложь;
		
	Иначе
		
		Форма.Элементы[ВидПродукцииИмяЭлемента].КнопкаВыбора = Ложь;
		Форма.Элементы[ВидПродукцииИмяЭлемента].РежимВыбораИзСписка = Истина;
		Для Каждого ВидПродукции Из ВидыПродукции Цикл
			Форма.Элементы[ВидПродукцииИмяЭлемента].СписокВыбора.Добавить(ВидПродукции);
		КонецЦикла;
		
		Если ЗначениеЗаполнено(Форма[ВидПродукцииИмяРеквизита])
			И Форма.Элементы[ВидПродукцииИмяЭлемента].СписокВыбора.НайтиПоЗначению(Форма[ВидПродукцииИмяРеквизита]) = Неопределено Тогда
			Форма.Элементы[ВидПродукцииИмяЭлемента].СписокВыбора.Добавить(Форма[ВидПродукцииИмяРеквизита]);
		КонецЕсли;
		
		Форма.Элементы[ВидПродукцииИмяЭлемента].СписокВыбора.СортироватьПоПредставлению();
		
	КонецЕсли;
	
КонецПроцедуры

Функция ЗависимыеВидыПродукции(ДанныеВидовПродукции, СуффиксВидаПродукции = Неопределено) Экспорт
	
	Результат = Новый Соответствие;
	
	ДанныеЭлемента = КонструкторИСОбщегоНазначенияКлиентСервер.ДанныеЭлементаКонструктора(
		ПредопределенноеЗначение(
			"Справочник.ЭлементыКонструктораВидовПродукцииИС.ЗависимыеВидыПродукцииИС"));
	
	Если СуффиксВидаПродукции = Неопределено Тогда
		СуффиксыВидовПродукции = КонструкторИСОбщегоНазначенияКлиентСервер.СуффиксыВидовПродукции();
	Иначе
		СуффиксыВидовПродукции = Новый Массив;
		СуффиксыВидовПродукции.Добавить(СуффиксВидаПродукции);
	КонецЕсли;
	
	Для Каждого Суффикс Из СуффиксыВидовПродукции Цикл
		ВидПродукции = ДанныеВидовПродукции["ВидПродукции"+Суффикс];
		Если ЗначениеЗаполнено(ВидПродукции) Тогда
			РезультатПоВидуПродукции = Новый Соответствие;
			Значения = ДанныеЭлемента.ВидыПродукции[ВидПродукции];
			Если Значения <> Неопределено Тогда
				Для Каждого Значение Из Значения Цикл
					СуффиксКлюча = КонструкторИСОбщегоНазначенияКлиентСервер.СуффиксВидаПродукцииПоЭлементуКонструктора(Значение.Ключ);
					Атрибуты = Новый Структура("Обязательный,Значение");
					ЗаполнитьЗначенияСвойств(Атрибуты, Значение.Значение);
					Если Атрибуты.Обязательный = Неопределено Тогда
						Атрибуты.Обязательный = Ложь;
					КонецЕсли;
					ТекущиеАтрибуты = РезультатПоВидуПродукции[СуффиксКлюча];
					Если ТекущиеАтрибуты = Неопределено Тогда
						РезультатПоВидуПродукции.Вставить(СуффиксКлюча, Атрибуты);
					Иначе
						Если Не ТекущиеАтрибуты.Обязательный
							И Атрибуты.Обязательный Тогда
							ТекущиеАтрибуты.Обязательный = Истина;
						КонецЕсли;
						Если Не ЗначениеЗаполнено(ТекущиеАтрибуты.Значение)
							И ЗначениеЗаполнено(Атрибуты.Значение) Тогда
							ТекущиеАтрибуты.Значение = Атрибуты.Значение;
						КонецЕсли;
					КонецЕсли;
				КонецЦикла;
			КонецЕсли;
			Результат.Вставить(Суффикс, РезультатПоВидуПродукции);
		КонецЕсли;
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Функция ДоступныеПодсистемыПоЗависимымВидамПродукции(ЗависимыеВидыПродукции) Экспорт
	
	Если ЗависимыеВидыПродукции.Количество() = 0 Тогда
		
		ДоступныеПодсистемы = КонструкторИСОбщегоНазначенияКлиентСервер.СуффиксыВидовПродукции();
		
	Иначе
		
		ДоступныеПодсистемы = Новый Массив;
		Если ЗависимыеВидыПродукции.Количество() = 1 Тогда
			
			Для Каждого КлючИЗначение Из ЗависимыеВидыПродукции Цикл
				Если ДоступныеПодсистемы.Найти(КлючИЗначение.Ключ) = Неопределено Тогда
					ДоступныеПодсистемы.Добавить(КлючИЗначение.Ключ);
				КонецЕсли;
				Для Каждого КлючИЗначениеВложенный Из КлючИЗначение.Значение Цикл
					Если ДоступныеПодсистемы.Найти(КлючИЗначениеВложенный.Ключ) = Неопределено Тогда
						ДоступныеПодсистемы.Добавить(КлючИЗначениеВложенный.Ключ);
					КонецЕсли;
				КонецЦикла;
			КонецЦикла;
			ЗависимыеВидыПродукции = ЗависимыеВидыПродукции[КлючИЗначение.Ключ];
			
		Иначе
			
			Для Каждого КлючИЗначение Из ЗависимыеВидыПродукции Цикл
				Если ДоступныеПодсистемы.Найти(КлючИЗначение.Ключ) = Неопределено Тогда
					ДоступныеПодсистемы.Добавить(КлючИЗначение.Ключ);
				КонецЕсли;
			КонецЦикла;
			
			ЗависимыеВидыПродукцииПоПодсистемам = Новый Соответствие;
			ПодсистемыПоВидамПродукции = Новый Соответствие;
			Для Каждого КлючИЗначение Из ЗависимыеВидыПродукции Цикл
				Для Каждого КлючИЗначениеВложенный Из КлючИЗначение.Значение Цикл
					
					Если ПодсистемыПоВидамПродукции[КлючИЗначениеВложенный.Ключ] = Неопределено Тогда
						ПодсистемыПоВидамПродукции.Вставить(КлючИЗначениеВложенный.Ключ, 1);
					Иначе
						ПодсистемыПоВидамПродукции[КлючИЗначениеВложенный.Ключ] =
							ПодсистемыПоВидамПродукции[КлючИЗначениеВложенный.Ключ] + 1;
					КонецЕсли;
					
					Атрибуты = КлючИЗначениеВложенный.Значение;
					ТекущиеАтрибуты = ЗависимыеВидыПродукцииПоПодсистемам[КлючИЗначениеВложенный.Ключ];
					Если ТекущиеАтрибуты = Неопределено Тогда
						ЗависимыеВидыПродукцииПоПодсистемам.Вставить(КлючИЗначениеВложенный.Ключ, Атрибуты);
					Иначе
						Если Не ТекущиеАтрибуты.Обязательный
							И Атрибуты.Обязательный Тогда
							ТекущиеАтрибуты.Обязательный = Истина;
						КонецЕсли;
						Если Не ЗначениеЗаполнено(ТекущиеАтрибуты.Значение)
							И ЗначениеЗаполнено(Атрибуты.Значение) Тогда
							ТекущиеАтрибуты.Значение = Атрибуты.Значение;
						КонецЕсли;
					КонецЕсли;
					
				КонецЦикла;
			КонецЦикла;
			
			КоличествоВидовПродукции = ЗависимыеВидыПродукции.Количество();
			Для Каждого КлючИЗначение Из ПодсистемыПоВидамПродукции Цикл
				Если КлючИЗначение.Значение = КоличествоВидовПродукции
					И ДоступныеПодсистемы.Найти(КлючИЗначение.Ключ) = Неопределено Тогда
					ДоступныеПодсистемы.Добавить(КлючИЗначение.Ключ);
				КонецЕсли;
			КонецЦикла;
			
			ЗависимыеВидыПродукции = ЗависимыеВидыПродукцииПоПодсистемам;
			
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат ДоступныеПодсистемы;
	
КонецФункции

#КонецОбласти

#Область УпаковкиЕдиницыИзмерения

Функция ИнициализироватьКоэффициентВесОбъемУпаковки() Экспорт
	
	Результат = Новый Структура;
	Результат.Вставить("Коэффициент", 0);
	Результат.Вставить("Вес",         0);
	Результат.Вставить("Объем",       0);
	Результат.Вставить("ТипИзмеряемойВеличиныВес",   Ложь);
	Результат.Вставить("ТипИзмеряемойВеличиныОбъем", Ложь);
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти

