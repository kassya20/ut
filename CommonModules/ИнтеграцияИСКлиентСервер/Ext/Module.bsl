//Формирует представление строки номенклатуры. Переопределяется.
//   Значение по-умолчанию: непустые представления составляющих, через запятую.
//
//Параметры:
//   Номенклатура   - ОпределяемыйТип.Номенклатура               - ссылка на номенклатуру.
//   Характеристика - ОпределяемыйТип.ХарактеристикаНоменклатуры - ссылка на характеристику номенклатуры.
//   Упаковка       - ОпределяемыйТип.Упаковка                   - ссылка на упаковку.
//   Серия          - ОпределяемыйТип.СерияНоменклатуры          - ссылка на серию номенклатуры.
//   ПоУмолчанию    - Строка                                     - Значение, если номенклатура не заполнена.
//
//Возвращаемое значение:
//   Строка - представление строки номенклатуры
//
Функция ПредставлениеНоменклатуры(Номенклатура, Характеристика, Упаковка = Неопределено, Серия = Неопределено, ПоУмолчанию = Неопределено) Экспорт
	
	Представление = "";
	ИнтеграцияИСКлиентСерверПереопределяемый.ЗаполнитьПредставлениеНоменклатуры(
		Представление, Номенклатура, Характеристика, Упаковка, Серия);
	
	Если Представление = "" Тогда
		МассивФормированияПредставления = Новый Массив;
		Если ЗначениеЗаполнено(Номенклатура) Тогда
			МассивФормированияПредставления.Добавить(СокрЛП(Номенклатура));
		КонецЕсли;
		Если ЗначениеЗаполнено(Характеристика) Тогда
			МассивФормированияПредставления.Добавить(СокрЛП(Характеристика));
		КонецЕсли;
		Если ЗначениеЗаполнено(Упаковка) Тогда
			МассивФормированияПредставления.Добавить(СокрЛП(Упаковка));
		КонецЕсли;
		Если ЗначениеЗаполнено(Серия) Тогда
			МассивФормированияПредставления.Добавить(СокрЛП(Серия));
		КонецЕсли;
		Представление = СтрСоединить(МассивФормированияПредставления, ", ");
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(Представление) И ЗначениеЗаполнено(ПоУмолчанию) Тогда
		Представление = Строка(ПоУмолчанию);
	КонецЕсли;
	
	Возврат Представление;
	
КонецФункции

#КонецОбласти

#Область УпаковкиЕдиницыИзмерения

// Возвращает коэффициент упаковки, вес упаковки в килограммах, объем упаковки в литрах и тип измеряемой величины.
// 
// Параметры:
//  Номенклатура - ОпределяемыйТип.Номенклатура - Номенклатура
//  Упаковка - ОпределяемыйТип.Упаковка, ОпределяемыйТип.ЕдиницаИзмерения, Неопределено - Упаковка
//  КэшированныеЗначения - Неопределено - кэшированные значения не используются,
//                         Структура - кэшированные значения:
//                          Ключ - "КоэффициентВесОбъемУпаковки", Значение - Соответствие:
//                          Ключ - Номенклатура,                  Значение - Соответствие:
//                          Ключ - Упаковка,                      Значение - Структура:
//                           Ключ - "Коэффициент", Значение - Число,
//                           Ключ - "Вес",         Значение - Число,
//                           Ключ - "Объем",       Значение - Число.
//                           Ключ - "ТипИзмеряемойВеличиныВес"   - Значение - Булево.
//                           Ключ - "ТипИзмеряемойВеличиныОбъем" - Значение - Булево.
// Возвращаемое значение:
//  Структура - Структура со свойствами:
//   * Коэффициент - Число - Коэффициент упаковки.
//   * Вес         - Число - Вес упаковки в килограммах.
//   * Объем       - Число - Объем упаковки в литрах.
//   * ТипИзмеряемойВеличиныВес   - Булево - Устанавливается в значение Истина, если единица измерения номенклатуры
//                                           или упаковка, является единицой измерения веса.
//   * ТипИзмеряемойВеличиныОбъем - Булево - Устанавливается в значение Истина, если единица измерения номенклатуры
//                                           или упаковка, является единицой измерения объема.
//
Функция КоэффициентВесОбъемУпаковки(Номенклатура, Упаковка = Неопределено, КэшированныеЗначения = Неопределено) Экспорт
	
	Если Не ЗначениеЗаполнено(Номенклатура) Тогда
		Возврат ИнициализироватьКоэффициентВесОбъемУпаковки();
	КонецЕсли;
	
	ИспользоватьКэшированныеЗначения = КэшированныеЗначения <> Неопределено;
	
	Если ИспользоватьКэшированныеЗначения Тогда
		
		Если Не КэшированныеЗначения.Свойство("КоэффициентВесОбъемУпаковки") Тогда
			КэшированныеЗначения.Вставить("КоэффициентВесОбъемУпаковки", Новый Соответствие);
		КонецЕсли;
		
		ДанныеНоменклатуры = КэшированныеЗначения.КоэффициентВесОбъемУпаковки[Номенклатура];
		Если ДанныеНоменклатуры = Неопределено Тогда
			КэшированныеЗначения.КоэффициентВесОбъемУпаковки.Вставить(Номенклатура, Новый Соответствие);
			ДанныеНоменклатуры = КэшированныеЗначения.КоэффициентВесОбъемУпаковки[Номенклатура];
		КонецЕсли;
		
		Если Упаковка = Неопределено Тогда
			КлючУпаковки = ИнтеграцияИСКлиентСерверПовтИсп.ПустоеЗначениеУпаковки();
			Если КлючУпаковки = Неопределено Тогда
				КлючУпаковки = "";
			КонецЕсли;
		Иначе
			КлючУпаковки = Упаковка;
		КонецЕсли;
		
		ДанныеУпаковки = ДанныеНоменклатуры[КлючУпаковки];
		
	Иначе
		ДанныеУпаковки = Неопределено;
	КонецЕсли;
	
	Если ДанныеУпаковки = Неопределено Тогда
		Результат = ИнтеграцияИСВызовСервера.КоэффициентВесОбъемУпаковки(Номенклатура, Упаковка);
		Если ИспользоватьКэшированныеЗначения Тогда
			ДанныеНоменклатуры.Вставить(КлючУпаковки, Результат);
		КонецЕсли;
	Иначе
		Результат = ИнициализироватьКоэффициентВесОбъемУпаковки();
		ЗаполнитьЗначенияСвойств(Результат, ДанныеУпаковки);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ПолучитьДанныеУпаковки(Данные, Номенклатура, Упаковка = Неопределено) Экспорт
	
	Если Не ЗначениеЗаполнено(Номенклатура) Тогда
		Возврат ИнициализироватьКоэффициентВесОбъемУпаковки();
	КонецЕсли;
	
	Если Упаковка = Неопределено Тогда
		КлючУпаковки = ИнтеграцияИСКлиентСерверПовтИсп.ПустоеЗначениеУпаковки();
		Если КлючУпаковки = Неопределено Тогда
			КлючУпаковки = "";
		КонецЕсли;
	Иначе
		КлючУпаковки = Упаковка;
	КонецЕсли;
	
	ДанныеНоменклатуры = Данные[Номенклатура];
	Если ДанныеНоменклатуры <> Неопределено Тогда
		ДанныеУпаковки = ДанныеНоменклатуры[КлючУпаковки];
		Если ДанныеУпаковки <> Неопределено Тогда
			Результат = ИнициализироватьКоэффициентВесОбъемУпаковки();
			ЗаполнитьЗначенияСвойств(Результат, ДанныеУпаковки);
		КонецЕсли;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Возвращает вес упаковки в килограммах.
// 
// Параметры:
//  Номенклатура - ОпределяемыйТип.Номенклатура - Номенклатура
//  Упаковка - ОпределяемыйТип.Упаковка, Неопределено - Упаковка
//  КэшированныеЗначения - Неопределено, Структура - кэшированные значения см.КоэффициентВесОбъемУпаковки
// Возвращаемое значение:
//  Число - Вес упаковки в килограммах
Функция ВесУпаковки(Номенклатура, Упаковка = Неопределено, КэшированныеЗначения = Неопределено) Экспорт
	
	Если Не ЗначениеЗаполнено(Номенклатура) Тогда
		Возврат 0;
	КонецЕсли;
	
	Возврат КоэффициентВесОбъемУпаковки(Номенклатура, Упаковка, КэшированныеЗначения).Вес;
	
КонецФункции

// Возвращает объем упаковки в литрах.
// 
// Параметры:
//  Номенклатура - ОпределяемыйТип.Номенклатура - Номенклатура
//  Упаковка - ОпределяемыйТип.Упаковка, Неопределено - Упаковка
//  КэшированныеЗначения - Неопределено, Структура - кэшированные значения см.КоэффициентВесОбъемУпаковки
// Возвращаемое значение:
//  Число - Объем упаковки в литрах
Функция ОбъемУпаковки(Номенклатура, Упаковка = Неопределено, КэшированныеЗначения = Неопределено) Экспорт
	
	Если Не ЗначениеЗаполнено(Номенклатура) Тогда
		Возврат 0;
	КонецЕсли;
	
	Возврат КоэффициентВесОбъемУпаковки(Номенклатура, Упаковка, КэшированныеЗначения).Объем;
	
КонецФункции

#КонецОбласти

#Область НастройкаИнтеграцииСФГИС

// Настраивает элементы формы интеграции с ФГИС.
//
// Параметры:
//   Форма - ФормаКлиентскогоПриложения.
//
Процедура НастроитьЭлементыФормыИнтеграцииСФГИС(Форма) Экспорт
	
	ДанныеПодсистемФГИС = Новый Структура;
	ДанныеПодсистемФГИС.Вставить("ИмяПодсистемы", "");
	ДанныеПодсистемФГИС.Вставить("ВидПродукции",  Неопределено);
	
	ДанныеПодсистем = ДанныеПодсистемДляНастройкиИнтеграцииСФГИС(Форма);
	
	КоличествоПодсистем = ДанныеПодсистем.Количество();
	Если КоличествоПодсистем = 0 Тогда
		Форма.ДанныеПодсистемФГИС = Новый ФиксированнаяСтруктура(ДанныеПодсистемФГИС);
		Возврат;
	КонецЕсли;
	
	СуффиксПодсистемыМаркировки = КонструкторИСОбщегоНазначенияКлиентСервер.СуффиксПодсистемыМаркировкиДляКлючаВидовПродукции();
	ДанныеГИСМТ = ДанныеПодсистем[СуффиксПодсистемыМаркировки];
	
	Если ДанныеГИСМТ <> Неопределено Тогда
		КоличествоПодсистем = КоличествоПодсистем - 1;
		НастроитьРежимВыбораЭлементаВидаПродукцииКлюча(
			Форма,
			ДанныеГИСМТ.ВидыПродукцииПоИмениПодсистемы,
			СуффиксПодсистемыМаркировки,
			"ВидПродукции"+СуффиксПодсистемыМаркировки);
	КонецЕсли;
	
	Если КоличествоПодсистем = 0 Тогда
		Форма.ДанныеПодсистемФГИС = Новый ФиксированнаяСтруктура(ДанныеПодсистемФГИС);
		Возврат;
	КонецЕсли;
	
	Если КоличествоПодсистем = 1 Тогда
		
		Для Каждого ДанныеФГИС Из ДанныеПодсистем Цикл
			Если ДанныеФГИС.Ключ <> СуффиксПодсистемыМаркировки Тогда
				Прервать;
			КонецЕсли;
		КонецЦикла;
		
		ДанныеПодсистемФГИС.ИмяПодсистемы = ДанныеФГИС.Ключ;
		
		КоличествоВидовПродукции = ДанныеФГИС.Значение.ВидыПродукцииПоИмениПодсистемы.Количество();
		
		Форма.Элементы.ВидыПродукцииФГИС.Видимость = Форма.ТребуетсяОбновлениеКлассификатораВидовПродукции;
		
		Если КоличествоВидовПродукции = 1 Тогда
			ДанныеПодсистемФГИС.ВидПродукции = ДанныеФГИС.Значение.ВидыПродукцииПоИмениПодсистемы[0];
			Форма.Элементы.ФлагФГИС.Видимость = Истина;
			Форма.Элементы.ВидПродукцииФГИС.Видимость = Ложь;
			Форма.Элементы.ФлагФГИС.Заголовок = ДанныеФГИС.Значение.Представление;
		Иначе
			Форма.Элементы.ФлагФГИС.Видимость = Ложь;
			Форма.Элементы.ВидПродукцииФГИС.Видимость = Истина;
			Форма.Элементы.ВидПродукцииФГИС.Заголовок = ДанныеФГИС.Значение.Представление;
			НастроитьРежимВыбораЭлементаВидаПродукцииКлюча(
				Форма,
				ДанныеФГИС.Значение.ВидыПродукцииПоИмениПодсистемы,
				ДанныеФГИС.Ключ,
				"ВидПродукцииФГИС");
		КонецЕсли;
		
	Иначе
		
		Форма.Элементы.ФлагФГИС.Видимость = Ложь;
		Форма.Элементы.ВидПродукцииФГИС.Видимость = Ложь;
		Форма.Элементы.ВидыПродукцииФГИС.Видимость = Истина;
		
	КонецЕсли;
	
	Если Форма.ТребуетсяОбновлениеКлассификатораВидовПродукции Тогда
		Форма.Элементы.ВидПродукцииГИСМТ.Видимость = Ложь
	КонецЕсли;
	
	Форма.ДанныеПодсистемФГИС = Новый ФиксированнаяСтруктура(ДанныеПодсистемФГИС);
	
КонецПроцедуры

// Настраивает элементы формы интеграции с ФГИС по указанным в форме видам продукции.
//
// Параметры:
//   Форма - ФормаКлиентскогоПриложения.
//
Процедура НастроитьЭлементыФормыИнтеграцииСФГИСПоВидамПродукцииКлюча(Форма) Экспорт
	
	СуффиксыВидовПродукции = КонструкторИСОбщегоНазначенияКлиентСервер.СуффиксыВидовПродукции();
	СуффиксПодсистемыМаркировки = КонструкторИСОбщегоНазначенияКлиентСервер.СуффиксПодсистемыМаркировкиДляКлючаВидовПродукции();
	
	Если Не ЗначениеЗаполнено(Форма.ДанныеПодсистемФГИС.ИмяПодсистемы) Тогда
		
		ДанныеПодсистем = ДанныеПодсистемДляНастройкиИнтеграцииСФГИС(Форма);
		
		МассивПредставлений = Новый Массив;
		
		Для Каждого Суффикс Из СуффиксыВидовПродукции Цикл
			ДанныеФГИС = ДанныеПодсистем[Суффикс];
			Если ДанныеФГИС <> Неопределено
				И ЗначениеЗаполнено(Форма["ВидПродукции"+Суффикс]) Тогда
				Если Суффикс = СуффиксПодсистемыМаркировки Тогда
					МассивПредставлений.Добавить(НСтр("ru = 'ГИС МТ'"));
				Иначе
						Если ДанныеФГИС.ВидыПродукцииПоИмениПодсистемы.Количество() = 1 Тогда
							МассивПредставлений.Добавить(ДанныеФГИС.Представление);
						Иначе
							МассивПредставлений.Добавить(СтрШаблон("%1 (%2)",
								ДанныеФГИС.Представление,
								Строка(Форма["ВидПродукции"+Суффикс])));
						КонецЕсли;
				КонецЕсли;
			КонецЕсли;
		КонецЦикла;
		
		Если МассивПредставлений.Количество() = 0 Тогда
			Если Форма.ТребуетсяОбновлениеКлассификатораВидовПродукции Тогда
				Форма.ВидыПродукцииФГИС = Новый ФорматированнаяСтрока(
					НСтр("ru = 'Требуется обновление классификатора настроек видов продукции БГосИС'"),,,,
					"ОбновлениеКлассификаторов");
			Иначе
				Форма.ВидыПродукцииФГИС = Новый ФорматированнаяСтрока(
					НСтр("ru = 'не используется'"),,,,
					"ВидыПродукцииФГИС");
			КонецЕсли;
		Иначе
			Форма.ВидыПродукцииФГИС = Новый ФорматированнаяСтрока(
				СтрСоединить(МассивПредставлений, ", "),,,,
				"ВидыПродукцииФГИС");
		КонецЕсли;
	
	ИначеЕсли Форма.ТребуетсяОбновлениеКлассификатораВидовПродукции Тогда
		Форма.ВидыПродукцииФГИС = Новый ФорматированнаяСтрока(
			НСтр("ru = 'Требуется обновление классификатора настроек видов продукции БГосИС'"),,,,
			"ОбновлениеКлассификаторов");
	КонецЕсли;
	
	СвойстваЭлементов = Новый Структура;
	СвойстваЭлементов.Вставить("ГруппаИнтеграцияФГИС",   Ложь);
	СвойстваЭлементов.Вставить("ФлагФГИС",               Ложь);
	СвойстваЭлементов.Вставить("ВидПродукцииФГИС",       Ложь);
	СвойстваЭлементов.Вставить("ОбязательноеЗаполнение", Ложь);
	
	ЗависимыеВидыПродукции = ЗависимыеВидыПродукции(Форма);
	ДоступныеПодсистемы = ДоступныеПодсистемыПоЗависимымВидамПродукции(ЗависимыеВидыПродукции);
	
	Для Каждого Суффикс Из СуффиксыВидовПродукции Цикл
		
		Если ИспользуетсяПодсистемаИнтеграцииСФГИС(Форма, Суффикс) Тогда
			
			ЭтоМаркировка = Суффикс = СуффиксПодсистемыМаркировки;
			
			ВидПродукцииИмяЭлемента = "ВидПродукции"+Суффикс;
			Если ЗависимыеВидыПродукции[Суффикс] = Неопределено Тогда
				Атрибуты = Неопределено;
			Иначе
				Атрибуты = ЗависимыеВидыПродукции[Суффикс];
			КонецЕсли;
			
			ОбязательноеЗаполнение = Атрибуты <> Неопределено И Атрибуты.Обязательный;
			
			ВидыПродукцииПоИмениПодсистемы = КонструкторИСОбщегоНазначенияКлиентСервер.ВидыПродукцииПоИмениПодсистемы(Суффикс);
			Если Атрибуты <> Неопределено
				И ЗначениеЗаполнено(Атрибуты.Значение) Тогда
				ВидыПродукции = Новый Массив;
				ВидыПродукции.Добавить(Атрибуты.Значение);
			Иначе
				ВидыПродукции = ВидыПродукцииПоИмениПодсистемы;
			КонецЕсли;
			
			КоличествоВидовПродукции = ВидыПродукции.Количество();
			ПодсистемаДоступнаПоВидуПродукции = ДоступныеПодсистемы.Найти(Суффикс) <> Неопределено;
			
			ДоступнаГруппаЭлементов = КоличествоВидовПродукции > 0
				И (ЗначениеЗаполнено(Форма[ВидПродукцииИмяЭлемента]) Или ПодсистемаДоступнаПоВидуПродукции);
			
			Если ЭтоМаркировка Тогда
				Форма.Элементы[ВидПродукцииИмяЭлемента].Доступность = ДоступнаГруппаЭлементов
					И (Атрибуты = Неопределено Или Не Атрибуты.Обязательный Или Не ЗначениеЗаполнено(Атрибуты.Значение));
				Форма.Элементы[ВидПродукцииИмяЭлемента].ОтметкаНезаполненного = ОбязательноеЗаполнение;
				Форма.Элементы[ВидПродукцииИмяЭлемента].АвтоОтметкаНезаполненного = ОбязательноеЗаполнение;
			Иначе
				СвойстваЭлементов.ГруппаИнтеграцияФГИС = СвойстваЭлементов.ГруппаИнтеграцияФГИС
					Или ДоступнаГруппаЭлементов;
				СвойстваЭлементов.ФлагФГИС = СвойстваЭлементов.ФлагФГИС
					Или Атрибуты = Неопределено Или Не Атрибуты.Обязательный;
				СвойстваЭлементов.ВидПродукцииФГИС = СвойстваЭлементов.ВидПродукцииФГИС
					Или Атрибуты = Неопределено Или Не Атрибуты.Обязательный Или Не ЗначениеЗаполнено(Атрибуты.Значение);
				СвойстваЭлементов.ОбязательноеЗаполнение = СвойстваЭлементов.ОбязательноеЗаполнение
					Или ОбязательноеЗаполнение;
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЦикла;
	
	Форма.Элементы.ГруппаИнтеграцияФГИС.Доступность = СвойстваЭлементов.ГруппаИнтеграцияФГИС;
	Форма.Элементы.ФлагФГИС.Доступность = СвойстваЭлементов.ФлагФГИС;
	Форма.Элементы.ВидПродукцииФГИС.Доступность = СвойстваЭлементов.ВидПродукцииФГИС;
	Форма.Элементы.ВидПродукцииФГИС.ОтметкаНезаполненного = СвойстваЭлементов.ОбязательноеЗаполнение;
	Форма.Элементы.ВидПродукцииФГИС.АвтоОтметкаНезаполненного = СвойстваЭлементов.ОбязательноеЗаполнение;
	
КонецПроцедуры

#КонецОбласти

Функция ПреобразоватьИдентификаторВСД(ИдентификаторПроисхожденияВЕТИССтрокой) Экспорт
	
	Если СтрДлина(ИдентификаторПроисхожденияВЕТИССтрокой) = 39 Тогда
		
		ИдентификаторПроисхожденияВЕТИССтрокой = НРег(ИдентификаторПроисхожденияВЕТИССтрокой);
		ИдентификаторПроисхожденияВЕТИССтрокой = СтрЗаменить(ИдентификаторПроисхожденияВЕТИССтрокой, "-", "");
		ИдентификаторПроисхожденияВЕТИССтрокой = Лев(ИдентификаторПроисхожденияВЕТИССтрокой,8)
			+ "-" + Сред(ИдентификаторПроисхожденияВЕТИССтрокой, 9, 4)
			+ "-" + Сред(ИдентификаторПроисхожденияВЕТИССтрокой, 13, 4)
			+ "-" + Сред(ИдентификаторПроисхожденияВЕТИССтрокой, 17, 4)
			+ "-" + Сред(ИдентификаторПроисхожденияВЕТИССтрокой, 21, 12);
		
		Возврат ИдентификаторПроисхожденияВЕТИССтрокой;
		
	Иначе
		Возврат ИдентификаторПроисхожденияВЕТИССтрокой;
	КонецЕсли;
	
КонецФункции

