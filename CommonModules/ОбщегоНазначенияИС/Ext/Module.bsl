	Обработчики.Вставить("ПараметрыЛогированияЗапросовСАТУРН", "ИнтеграцияСАТУРН.УстановитьПараметрыСеанса");
	Обработчики.Вставить("ДанныеКлючаСессииИСМП",              "ОбщегоНазначенияИСМП.УстановитьПараметрыСеанса");
