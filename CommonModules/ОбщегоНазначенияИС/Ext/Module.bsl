#Область JWT

// Расшифровать токен JWT.
// 
// Параметры:
//  Токен - Строка
// ПреобразовыватьВСоответствие - Булево - Признак преобразования в соответствие.
// Возвращаемое значение:
//  Структура - данные токена JWT:
// * РезультатРасшифровки - Неопределено - 
// * ТекстОшибки - Строка - 
// * Данные - Неопределено - 
Функция РасшифроватьТокенJWT(Токен, ПреобразовыватьВСоответствие = Ложь) Экспорт
	
	ВозвращаемоеЗначение = Новый Структура;
	ВозвращаемоеЗначение.Вставить("РезультатРасшифровки", Неопределено);
	ВозвращаемоеЗначение.Вставить("ТекстОшибки",          "");
	ВозвращаемоеЗначение.Вставить("Данные",               Неопределено);
	
	ЭлементыТокена = СтрРазделить(Токен, ".");
	Если ЭлементыТокена.Count() <> 3 Тогда
		ВозвращаемоеЗначение.ТекстОшибки = НСтр("ru = 'Токен не соответствует формату JWT'");
		Возврат ВозвращаемоеЗначение;
	КонецЕсли;
	
	ЭлементТокенаДанные = ЭлементыТокена[1];
	
	ВозвращаемоеЗначение.Данные = ОбщегоНазначенияИСКлиентСервер.ТекстJSONВОбъект(
		ПолучитьСтрокуИзДвоичныхДанных(
			ДвоичныеДанныеЭлементаТокенаJWT(ЭлементТокенаДанные)),
		ПреобразовыватьВСоответствие);
	
	Возврат ВозвращаемоеЗначение;
	
КонецФункции

#КонецОбласти

// Выполняет установку параметров сеанса. Вызывается из модуля сеанса.
//
// Параметры:
//  ИмяПараметра			 - Строка - имя параметра сеанса.
//  УстановленныеПараметры	 - Массив из Строка - все установленные параметры сеанса.
//
Процедура УстановитьПараметрыСеанса(ИмяПараметра, УстановленныеПараметры) Экспорт
	
	Если ИмяПараметра = Метаданные.ПараметрыСеанса.ПараметрСеансаИС.Имя Тогда
		ПараметрыСеанса.ПараметрСеансаИС = ПараметрСеансаИС(Истина);
		Если ТипЗнч(УстановленныеПараметры) = Тип("Массив") Тогда
			УстановленныеПараметры.Добавить(ИмяПараметра);
		ИначеЕсли ТипЗнч(УстановленныеПараметры) = Тип("Структура") Тогда
			УстановленныеПараметры.Вставить(ИмяПараметра);
		КонецЕсли;
	ИначеЕсли ИмяПараметра = Метаданные.ПараметрыСеанса.НастройкиРазбораКодаМаркировкиИС.Имя Тогда
		ПараметрыСеанса.НастройкиРазбораКодаМаркировкиИС =
			Новый ФиксированнаяСтруктура(
				РазборКодаМаркировкиИССлужебный.ИнициализироватьКэшНастроекРазбораКодаМаркировки());
		Если ТипЗнч(УстановленныеПараметры) = Тип("Массив") Тогда
			УстановленныеПараметры.Добавить(ИмяПараметра);
		ИначеЕсли ТипЗнч(УстановленныеПараметры) = Тип("Структура") Тогда
			УстановленныеПараметры.Вставить(ИмяПараметра);
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

// Параметры сеанса.
// 
// Параметры:
//  Инициализация - Булево - Инициализация
// 
// Возвращаемое значение:
//  ФиксированнаяСтруктура - Параметры сеанса:
// * ТребуетсяОбработкаПриПереходеНаКонструктор - Соответствие из КлючИЗначение - 
Функция ПараметрСеансаИС(Инициализация = Ложь) Экспорт
	
	Если Инициализация Тогда
		ПараметрыСеансаИС = Новый Структура;
		ПараметрыСеансаИС.Вставить("ТребуетсяОбработкаПриПереходеНаКонструктор", Новый Соответствие);
		Возврат ОбщегоНазначения.СкопироватьРекурсивно(ПараметрыСеансаИС, Истина);
	Иначе
		//@skip-check constructor-function-return-section
		Возврат ПараметрыСеанса.ПараметрСеансаИС;
	КонецЕсли;
	
КонецФункции

#КонецОбласти

// см. ОбщегоНазначенияПереопределяемый.ПриДобавленииСерверныхОповещений
Процедура ПриДобавленииСерверныхОповещений(Оповещения) Экспорт
	
	Если ЭтоРасширеннаяВерсияГосИС() Тогда
		Если ПодсистемаСуществует("ЗЕРНО") Тогда
			МодульИнтеграцияЗЕРНО = ОбщегоНазначения.ОбщийМодуль("ИнтеграцияЗЕРНО");
			МодульИнтеграцияЗЕРНО.ПриДобавленииСерверныхОповещений(Оповещения);
		КонецЕсли;
		Если ПодсистемаСуществует("ИСМП")
			И ЭтоРасширеннаяВерсияГосИС("ИСМП") Тогда
			МодульСоответствиеТребованиямГИСМТ = ОбщегоНазначения.ОбщийМодуль("СоответствиеТребованиямГИСМТ");
			МодульСоответствиеТребованиямГИСМТ.ПриДобавленииСерверныхОповещений(Оповещения);
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

// см. ПользователиПереопределяемый.ПриОпределенииНазначенияРолей
Процедура ПриОпределенииНазначенияРолей(НазначениеРолей) Экспорт

	НазначениеРолей.ТолькоДляВнешнихПользователей.Добавить("БазовыеПраваВнешнегоПользователяИС");
	НазначениеРолей.ТолькоДляПользователейСистемы.Добавить("ДобавлениеИзменениеЭлементовКонструктораВидовПродукцииИС");
	
	Если ПодсистемаСуществует("ИСМП") Тогда
		НазначениеРолей.ТолькоДляПользователейСистемы.Добавить("ДобавлениеИзменениеЭлементовКонструктораВидовПродукцииИСМП");
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

// Настроить подключаемое оборудование.
// 
// Параметры:
//  Форма - ФормаКлиентскогоПриложения
//  ПоддерживаемыеТипыПодключаемогоОборудования - Строка - поддерживаемые типы подключаемого оборудования
//  ПрефиксыЭлементовФормы - Строка - Префиксы элементов формы
Процедура НастроитьПодключаемоеОборудование(Форма, ПоддерживаемыеТипыПодключаемогоОборудования, ПрефиксыЭлементовФормы = "Товары") Экспорт
	
	ОбщегоНазначенияИСПереопределяемый.НастроитьПодключаемоеОборудование(Форма, ПрефиксыЭлементовФормы);
	
	ВерсияБПО = МенеджерОборудования.ВерсияБиблиотеки();
	
	Если ОбщегоНазначенияКлиентСервер.СравнитьВерсии(ВерсияБПО, "3.2.1.0") >= 0 Тогда
		
		МодульМенеджерОборудованияКлиентСервер = ОбщегоНазначения.ОбщийМодуль("МенеджерОборудованияКлиентСервер");
		МодульМенеджерОборудования             = ОбщегоНазначения.ОбщийМодуль("МенеджерОборудования");

		ТипыОборудования = МодульМенеджерОборудованияКлиентСервер.ПараметрыТипыОборудования();
		ТипыОборудования.СканерШтрихкода = (СтрНайти(ПоддерживаемыеТипыПодключаемогоОборудования, "СканерШтрихкода") > 0);
		ТипыОборудования.СчитывательRFID = (СтрНайти(ПоддерживаемыеТипыПодключаемогоОборудования, "СчитывательRFID") > 0);

		МодульМенеджерОборудования.ПриСозданииНаСервере(Форма, ТипыОборудования);
		
	КонецЕсли;
	
КонецПроцедуры

// Если в объекте заполнено значение реквизита, а в списке выбора, связанном с данным реквизитом,
// значение отсутствует, тогда такое значение необходимо добавит в список выбора.
// 
// Параметры:
//  Форма - ФормаКлиентскогоПриложения
Процедура НастроитьСпискиВыбораФормыОбъекта(Форма) Экспорт
	
	Если Не ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(Форма, "Объект")
		Или Не ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(Форма.Объект, "Ссылка")
		Или Форма.Объект.Ссылка.Пустая() Тогда
		Возврат;
	КонецЕсли;
	
	Для Каждого Элемент Из Форма.Элементы Цикл
		Если ТипЗнч(Элемент) = Тип("ПолеФормы")
			И Элемент.Вид = ВидПоляФормы.ПолеВвода
			И Элемент.РежимВыбораИзСписка
			И ТипЗнч(Элемент.Родитель) <> Тип("ТаблицаФормы") Тогда
			ПутьКДанным = Элемент.ПутьКДанным;
			Если Лев(ПутьКДанным, 6) = "Объект" Тогда
				Значение = Форма.Объект[Сред(Элемент.ПутьКДанным, 8)];
			Иначе
				Значение = Форма[Элемент.ПутьКДанным];
			КонецЕсли;
			Если ЗначениеЗаполнено(Значение)
				И Элемент.СписокВыбора.НайтиПоЗначению(Значение) = Неопределено Тогда
				Элемент.СписокВыбора.Добавить(Значение);
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

#Область КлассификаторНастроекВидовПродукций

// Классификатор настроек видов продукций загружен.
// 
// Возвращаемое значение:
//  Булево - Классификатор настроек видов продукций загружен
Функция КлассификаторНастроекВидовПродукцийЗагружен() Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	ЗначенияЭлементовКонструктораВидовПродукцииИС.ЭлементКонструктора
		|ИЗ
		|	РегистрСведений.ЗначенияЭлементовКонструктораВидовПродукцииИС КАК ЗначенияЭлементовКонструктораВидовПродукцииИС
		|ГДЕ
		|	НЕ ЗначенияЭлементовКонструктораВидовПродукцииИС.ВидПродукции.ПометкаУдаления
		|	И НЕ ЗначенияЭлементовКонструктораВидовПродукцииИС.ВидПродукции.Предопределенный
		|	И ЗначенияЭлементовКонструктораВидовПродукцииИС.ВидПродукции.ХешСуммаПоставляемыхДанных <> """"";
	
	Результат = Не Запрос.Выполнить().Пустой();
	
	Возврат Результат;
	
КонецФункции

// Загружает классификатор через интернет-поддержку или из макета.
// 
// Возвращаемое значение:
//  Строка - текст ошибки загрузки при наличии
Функция ЗагрузитьКлассификаторНастроекВидовПродукций() Экспорт
	
	Результат = "";
	
	Если ОбщегоНазначения.РазделениеВключено() Тогда
		Результат = НСтр("ru = 'Отсутствуют классификаторы настроек видов продукции. Обратитесь к администратору.'");
		Возврат Результат;
	КонецЕсли;
	
	ИдентификаторКлассификатора = ИдентификаторКлассификатораВидовПродукцииИС();
	ВерсияКлассификатора        = РаботаСКлассификаторами.ВерсияКлассификатора(ИдентификаторКлассификатора);
	
	Если ВерсияКлассификатора = Неопределено Тогда
		ТребуемаяВерсияБиблиотекиБИП = МинимальнаяВерсияБиблиотекиИнтернетПоддержки();
		ТекущаяВерсияБиблиотекиБИП   = ИнтернетПоддержкаПользователейКлиентСервер.ВерсияБиблиотеки();
		СравнениеВерсийБиблиотекиБИП = ОбщегоНазначенияКлиентСервер.СравнитьВерсии(ТребуемаяВерсияБиблиотекиБИП,
			ТекущаяВерсияБиблиотекиБИП);
			
		ОписаниеКлассификаторовИС = Новый Массив;
		КлассификаторыКДобавлению = Новый Массив;
		
		ЗаполнитьОписаниеКлассификаторов(ОписаниеКлассификаторовИС, Истина, Ложь);
		
		Для Каждого ОписаниеКлассификатора Из ОписаниеКлассификаторовИС Цикл
			Если ОписаниеКлассификатора.Идентификатор = ИдентификаторКлассификатора Тогда
				КлассификаторыКДобавлению.Добавить(ОписаниеКлассификатора);
				Прервать;
			КонецЕсли;
		КонецЦикла;
		
		Если СравнениеВерсийБиблиотекиБИП > 0 Тогда
			ДобавитьКлассификаторы(КлассификаторыКДобавлению);
		Иначе
			МодульРаботаСКлассификаторами = ОбщегоНазначения.ОбщийМодуль("РаботаСКлассификаторами");
		//@skip-check bsl-legacy-check-static-feature-access-for-unknown-left-part
			МодульРаботаСКлассификаторами.ДобавитьКлассификаторы(КлассификаторыКДобавлению);
		КонецЕсли;
		
	КонецЕсли;
	
	Классификаторы = Новый Массив;
	Классификаторы.Добавить(ИдентификаторКлассификатора);
	
	УстановитьПривилегированныйРежим(Истина);
	РезультатОбновления = РаботаСКлассификаторами.ОбновитьКлассификаторы(Классификаторы);
	
	Если ЗначениеЗаполнено(РезультатОбновления.КодОшибки) Тогда
		НачатьТранзакцию();
		
		Попытка
			РезультатОбновления = ПервоначальноеЗаполнениеКлассификаторовВидовПродукции(Истина);
			Если Не РезультатОбновления.УспешнаяЗагрузка Тогда
				Результат = РезультатОбновления.СообщениеОбОшибке;
				ОтменитьТранзакцию();
			Иначе
				ЗафиксироватьТранзакцию();
			КонецЕсли;

		Исключение
			Результат = ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
			ОтменитьТранзакцию();
			
		КонецПопытки;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Начать загрузку классификатора настроек видов продукции.
// 
// Параметры:
//  УникальныйИдентификатор - УникальныйИдентификатор
// 
// Возвращаемое значение:
//  см. ДлительныеОперации.ВыполнитьВФоне
Функция НачатьЗагрузкуКлассификатораНастроекВидовПродукции(УникальныйИдентификатор) Экспорт
	
	ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияВФоне(УникальныйИдентификатор);
	ПараметрыВыполнения.НаименованиеФоновогоЗадания = НСтр("ru = 'Загрузка классификатора настроек видов продукции'");
	
	ПараметрыФоновогоЗадания = Новый Структура;
	
	Если ОбщегоНазначенияИСМП.ЭтоРасширеннаяВерсияГосИС() Тогда
		МодульИнтеграцияИСПереопределяемый = ОбщегоНазначения.ОбщийМодуль("ИнтеграцияИСПереопределяемый");
		МодульИнтеграцияИСПереопределяемый.НастроитьДлительнуюОперацию(ПараметрыФоновогоЗадания, ПараметрыВыполнения);
	КонецЕсли;
	
	ДлительнаяОперация = ДлительныеОперации.ВыполнитьВФоне(
		"ОбщегоНазначенияИС.ЗагрузкаКлассификатораНастроекВидовПродукцииДлительнаяОперация",
		ПараметрыФоновогоЗадания, ПараметрыВыполнения);
	
	Возврат ДлительнаяОперация;
	
КонецФункции

// Загрузка классификатора настроек видов продукции длительная операция.
// 
// Параметры:
//  ПараметрыФоновогоЗадания - Структура
//  АдресРезультата - Строка
Процедура ЗагрузкаКлассификатораНастроекВидовПродукцииДлительнаяОперация(ПараметрыФоновогоЗадания, АдресРезультата) Экспорт
	
	ВозвращаемоеЗначение = Новый Структура;
	ВозвращаемоеЗначение.Вставить("ЕстьОшибки",                     Ложь);
	ВозвращаемоеЗначение.Вставить("ТекстОшибки",                    "");
	
	Если КлассификаторНастроекВидовПродукцийЗагружен() Тогда
		ПоместитьВоВременноеХранилище(ВозвращаемоеЗначение, АдресРезультата);
		Возврат;
	КонецЕсли;
	
	ОшибкаЗагрузкиКлассификатора = ЗагрузитьКлассификаторНастроекВидовПродукций();
	
	Если ЗначениеЗаполнено(ОшибкаЗагрузкиКлассификатора) Тогда
		ВозвращаемоеЗначение.ЕстьОшибки  = Истина;
		ВозвращаемоеЗначение.ТекстОшибки = ОшибкаЗагрузкиКлассификатора;
		ПоместитьВоВременноеХранилище(ВозвращаемоеЗначение, АдресРезультата);
		Возврат;
	КонецЕсли;
	
	ПоместитьВоВременноеХранилище(ВозвращаемоеЗначение, АдресРезультата);
	
КонецПроцедуры

#КонецОбласти

// Ведется учет продукции ИС.
// 
// Возвращаемое значение:
//  Булево - Ведется учет продукции ИС
Функция ВедетсяУчетПродукцииИС() Экспорт
		
	ВедетсяУчетПродукцииИС    = Ложь;
	ФункциональнаяОпцияВЕТИС  = "ВестиУчетПодконтрольныхТоваровВЕТИС";
	ФункциональнаяОпцияЗерно  = "ВестиУчетЗернаИПродуктовПереработкиЗЕРНО";
	ФункциональнаяОпцияСатурн = "ВестиУчетПестицидовАгрохимикатовТукосмесейСАТУРН";
	ФункциональнаяОпцияИСМП   = ?(ЭтоРасширеннаяВерсияГосИС(), "ВестиУчетМаркируемойПродукцииИСМП",
		"ВестиУчетМаркируемойПродукцииИСМПРМК");
	ФункциональнаяОпцияЕГАИС  = ?(ЭтоРасширеннаяВерсияГосИС(), "ВестиСведенияДляДекларацийПоАлкогольнойПродукции",
		"ВестиСведенияДляДекларацийПоАлкогольнойПродукцииРМК");
	
	Если ПодсистемаСуществует("ВЕТИС") И ПолучитьФункциональнуюОпцию(ФункциональнаяОпцияВЕТИС)
		Или ПодсистемаСуществует("ЕГАИС") И ПолучитьФункциональнуюОпцию(ФункциональнаяОпцияЕГАИС)
		Или ПодсистемаСуществует("ЗЕРНО") И ПолучитьФункциональнуюОпцию(ФункциональнаяОпцияЗерно)
		Или ПодсистемаСуществует("ИСМП") И ПолучитьФункциональнуюОпцию(ФункциональнаяОпцияИСМП)
		Или ПодсистемаСуществует("САТУРН") И ПолучитьФункциональнуюОпцию(ФункциональнаяОпцияСатурн) Тогда
		ВедетсяУчетПродукцииИС = Истина;
	КонецЕсли;
	
	Возврат ВедетсяУчетПродукцииИС;
	
КонецФункции

// См. СтандартныеПодсистемыСервер.ПриОпределенииМетодовРазрешенныхДляВызоваКакПроизвольныйКод
Процедура ПриОпределенииМетодовРазрешенныхДляВызоваКакПроизвольныйКод(Методы) Экспорт

	Методы.Вставить("ЗагрузкаКлассификатораНастроекВидовПродукцииДлительнаяОперация", Истина);
	Методы.Вставить("Пауза", Истина);
	Методы.Вставить("УстановитьПараметрыСеанса");

КонецПроцедуры

#Область СправочникиИКлассификаторы

// Переопределяются алгоритмы обработки файла загруженного
// из сервиса классификаторов. После обработки файла нельзя удалять
// временного хранилища, т.к. при необходимости он будет сохранен в
// кэше для последующего использования.
//
// Параметры:
//  Идентификатор           - Строка - идентификатор классификатора в сервисе классификаторов.
//                            Определяется в процедуре ПриДобавленииКлассификаторов.
//  Версия                  - Число - номер загруженной версии;
//  Адрес                   - Строка - адрес двоичных данных файла обновления во
//                            временном хранилище;
//  Обработан               - Булево - если Ложь, при обработке файла обновления были ошибки
//                            и его необходимо загрузить повторно;
//  ДополнительныеПараметры - Структура - содержит дополнительные параметры обработки.
//                            Необходимо использовать для передачи значений в переопределяемый
//                            метод РаботаСКлассификаторамиВМоделиСервисаПереопределяемый.ПриОбработкеОбластиДанных
//                            и метод ИнтеграцияПодсистемБИП.ПриОбработкеОбластиДанных..
// Пример:
//	Если Идентификатор = "CentralBankRefinancingRate" Тогда
//		Обработан = РегистрыСведений.СтавкиРефинансирования.ОбновитьДанныеРегистраИзФайла(Адрес, ДополнительныеПараметры);
//	КонецЕсли;
//
//@skip-warning
Процедура ПриЗагрузкеКлассификатора(Идентификатор, Версия, Адрес, Обработан, ДополнительныеПараметры) Экспорт
	
	Если ПодсистемаСуществует("ЗЕРНО") Тогда
		МодульИнтеграцияЗЕРНО = ОбщегоНазначения.ОбщийМодуль("ИнтеграцияЗЕРНО");
		МодульИнтеграцияЗЕРНО.ПриЗагрузкеКлассификатора(Идентификатор, Версия, Адрес, Обработан, ДополнительныеПараметры);
	КонецЕсли;
	
	Если ПодсистемаСуществует("ВетИС") Тогда
		МодульИнтеграцияВЕТИС = ОбщегоНазначения.ОбщийМодуль("ИнтеграцияВЕТИС");
		МодульИнтеграцияВЕТИС.ПриЗагрузкеКлассификатора(Идентификатор, Версия, Адрес, Обработан, ДополнительныеПараметры);
	КонецЕсли;
	
	Если ПодсистемаСуществует("ЕГАИС") Тогда
		МодульОбщегоНазначенияЕГАИС = ОбщегоНазначения.ОбщийМодуль("ОбщегоНазначенияЕГАИС");
		МодульОбщегоНазначенияЕГАИС.ПриЗагрузкеКлассификатора(Идентификатор, Версия, Адрес, Обработан, ДополнительныеПараметры);
	КонецЕсли;
	
	ПриЗагрузкеКлассификатораИС(Идентификатор, Версия, Адрес, Обработан, ДополнительныеПараметры);
	
КонецПроцедуры

// Переопределяются номер версии классификатора, который уже загружен в информационную базу.
// При начале использовании подсистемы "РаботаСКлассификаторами" или при подключении нового
// классификатора к сервису, неизвестно какой номер версии классификатора загружен в ИБ,
// поэтому при очередной итерации обновления данных из сервиса данные будут загружены повторно.
// Чтобы избежать повторной загрузки, необходимо указать задать начальный номер версии.
// Метод будет вызван при попытке загрузить версию классификатора, у которого установлена
// версия равная 0.
//
// Параметры:
//  Идентификатор        - Строка - идентификатор классификатора в сервисе классификаторов.
//                         Определяется в процедуре ПриДобавленииКлассификаторов.
//  НачальныйНомерВерсии - Число - номер версии загруженного классификатора.
//
// Пример:
//	Если Идентификатор = "CentralBankRefinancingRate" Тогда
//		НачальныйНомерВерсии = РегистрыСведений.СтавкиРефинансирования.НомерЗагруженнойВерсии();
//	КонецЕсли;
//
//@skip-warning
Процедура ПриОпределенииНачальногоНомераВерсииКлассификатора(Идентификатор, НачальныйНомерВерсии) Экспорт
	
	Если ПодсистемаСуществует("ЗЕРНО") Тогда
		МодульИнтеграцияЗЕРНО = ОбщегоНазначения.ОбщийМодуль("ИнтеграцияЗЕРНО");
		МодульИнтеграцияЗЕРНО.ПриОпределенииНачальногоНомераВерсииКлассификатора(Идентификатор, НачальныйНомерВерсии);
	КонецЕсли;
	
	Если ПодсистемаСуществует("ВетИС") Тогда
		МодульИнтеграцияВЕТИС = ОбщегоНазначения.ОбщийМодуль("ИнтеграцияВЕТИС");
		МодульИнтеграцияВЕТИС.ПриОпределенииНачальногоНомераВерсииКлассификатора(Идентификатор, НачальныйНомерВерсии);
	КонецЕсли;
	
	Если ПодсистемаСуществует("ЕГАИС") Тогда
		МодульОбщегоНазначенияЕГАИС = ОбщегоНазначения.ОбщийМодуль("ОбщегоНазначенияЕГАИС");
		МодульОбщегоНазначенияЕГАИС.ПриОпределенииНачальногоНомераВерсииКлассификатора(Идентификатор, НачальныйНомерВерсии);
	КонецЕсли;
	
	ПриОпределенииНачальногоНомераВерсииКлассификатораИС(Идентификатор, НачальныйНомерВерсии);
	
КонецПроцедуры

// Переопределяется список и настройки классификаторов обновления которых необходимо
// загружать из сервиса классификаторов. Для получения идентификатора необходимо
// перевести наименование объекта метаданных, данные которого планируется обновлять,
// на английский язык. При переводе рекомендуется использовать профессиональные
// программы перевода текста, либо воспользоваться услугами переводчика, т.к. при
// обнаружении смысловых ошибок в идентификаторе потребуется заводить новый классификатор
// и изменять код конфигурации.
//
// Параметры:
//  Классификаторы  - Массив из Структура - содержит настройки загрузки классификаторов.
//                    Состав настроек см. функцию РаботаСКлассификаторами.ОписаниеКлассификатора.
//
// Пример:
//	Описатель = РаботаСКлассификаторами.ОписаниеКлассификатора();
//	Описатель.Наименование               = НСтр("ru = 'Ставки рефинансирования'");
//	Описатель.Идентификатор              = "CentralBankRefinancingRate";
//	Описатель.ОбновлятьАвтоматически     = Истина;
//	Описатель.ОбщиеДанные                = Истина;
//	Описатель.СохранятьФайлВКэш          = Ложь;
//	Описатель.ОбработкаРазделенныхДанных = Ложь;
//	Классификаторы.Добавить(Описатель);
//
//@skip-warning
Процедура ПриДобавленииКлассификаторов(Классификаторы) Экспорт
	
	Если ПодсистемаСуществует("ЗЕРНО") Тогда
		МодульИнтеграцияЗЕРНО = ОбщегоНазначения.ОбщийМодуль("ИнтеграцияЗЕРНО");
		МодульИнтеграцияЗЕРНО.ПриДобавленииКлассификаторов(Классификаторы);
	КонецЕсли;
	
	Если ПодсистемаСуществует("ВетИС") Тогда
		МодульИнтеграцияВЕТИС = ОбщегоНазначения.ОбщийМодуль("ИнтеграцияВЕТИС");
		МодульИнтеграцияВЕТИС.ПриДобавленииКлассификаторов(Классификаторы);
	КонецЕсли;
	
	Если ПодсистемаСуществует("ЕГАИС") Тогда
		МодульОбщегоНазначенияЕГАИС = ОбщегоНазначения.ОбщийМодуль("ОбщегоНазначенияЕГАИС");
		МодульОбщегоНазначенияЕГАИС.ПриДобавленииКлассификаторов(Классификаторы);
	КонецЕсли;
	
	ПриДобавленииКлассификаторовИС(Классификаторы);
	
КонецПроцедуры

// см. РаботаСКлассификаторамиВМоделиСервисаПереопределяемый.ПриОпределенииИдентификаторовКлассификаторов
Процедура ПриОпределенииИдентификаторовКлассификаторовВМоделиСервиса(Идентификаторы) Экспорт
	
	Если ПодсистемаСуществует("ЗЕРНО") Тогда
		МодульИнтеграцияЗЕРНО = ОбщегоНазначения.ОбщийМодуль("ИнтеграцияЗЕРНО");
		МодульИнтеграцияЗЕРНО.ПриОпределенииИдентификаторовКлассификаторовВМоделиСервиса(Идентификаторы);
	КонецЕсли;
	
	Если ПодсистемаСуществует("ВетИС") Тогда
		МодульИнтеграцияВЕТИС = ОбщегоНазначения.ОбщийМодуль("ИнтеграцияВЕТИС");
		МодульИнтеграцияВЕТИС.ПриОпределенииИдентификаторовКлассификаторовВМоделиСервиса(Идентификаторы);
	КонецЕсли;
	
	Если ПодсистемаСуществует("ЕГАИС") Тогда
		МодульОбщегоНазначенияЕГАИС = ОбщегоНазначения.ОбщийМодуль("ОбщегоНазначенияЕГАИС");
		МодульОбщегоНазначенияЕГАИС.ПриОпределенииИдентификаторовКлассификаторовВМоделиСервиса(Идентификаторы);
	КонецЕсли;
	
	ПриОпределенииИдентификаторовКлассификаторовВМоделиСервисаИС(Идентификаторы);
	
КонецПроцедуры

Функция ПервоначальноеЗаполнениеКлассификаторовВидовПродукции(БезусловноеЗаполнение=Ложь, ПолнаяЗагрузка=Ложь) Экспорт

    РезультатОбновления = ИнициализироватьРезультатыОбновленияКлассификаторовВидовПродукцииИС();
	РазделениеВключено  = ОбщегоНазначения.РазделениеВключено();
	
	Если Не БезусловноеЗаполнение Тогда
		Если Не РазделениеВключено И Не ВедетсяУчетПродукцииИС() Тогда
			Возврат РезультатОбновления;
		КонецЕсли;
	КонецЕсли;
	
	Идентификатор                   = ИдентификаторКлассификатораВидовПродукцииИС();
	СохраненнаяВерсияКлассификатора = РегистрыСведений.ПоставляемыеДанныеКлассификаторовВидовПродукцииИС.СохраненныеДанныеКлассификаторовВидовПродукцииИС(
		Идентификатор);
	
	Если СохраненнаяВерсияКлассификатора <> Неопределено Тогда
		АдресКлассификаторов = СохраненнаяВерсияКлассификатора;	
	Иначе
		ДвоичныеДанныеКлассификаторов = ПолучитьОбщийМакет("КлассификаторыВидовПродукцииИС");
		АдресКлассификаторов          = ПоместитьВоВременноеХранилище(ДвоичныеДанныеКлассификаторов);
	КонецЕсли;
	
	АдресДополнительногоКлассификатора = ДополнительныйМакетОбновленияКлассификатораВидовПродукцииИС();
	Если АдресДополнительногоКлассификатора <> Неопределено Тогда
		АдресКлассификаторов = АдресДополнительногоКлассификатора;
	КонецЕсли;
	
	ПараметрыЗагрузки = ПараметрыЗагрузкиКлассификаторовИС();
	
	ПараметрыЗагрузки.ПолнаяЗагрузка = ПолнаяЗагрузка;
	
	ОбновлениеКлассификаторовВидовПродукцииИС(АдресКлассификаторов, ПараметрыЗагрузки, РезультатОбновления);
	
	Если СохраненнаяВерсияКлассификатора <> Неопределено Тогда
		РегистрыСведений.ПоставляемыеДанныеКлассификаторовВидовПродукцииИС.ОбновитьПризнакЧастичнойЗагрузкиКлассификаторовВидовПродукцииИС(
			Идентификатор, РезультатОбновления.ДанныеЗагруженыЧастично);
	КонецЕсли;
	
	Возврат РезультатОбновления;
	
КонецФункции

// см. РаботаВМоделиСервисаПереопределяемый.ПриВключенииРазделенияПоОбластямДанных
Процедура ПриВключенииРазделенияПоОбластямДанных() Экспорт
	
	ТребуемаяВерсияБиблиотекиБИП = МинимальнаяВерсияБиблиотекиИнтернетПоддержки();
	ТекущаяВерсияБиблиотекиБИП   = ИнтернетПоддержкаПользователейКлиентСервер.ВерсияБиблиотеки();
	СравнениеВерсийБиблиотекиБИП = ОбщегоНазначенияКлиентСервер.СравнитьВерсии(ТребуемаяВерсияБиблиотекиБИП,
		ТекущаяВерсияБиблиотекиБИП);
	
	Классификаторы = Новый Массив;
	
	ЗаполнитьОписаниеКлассификаторов(Классификаторы, Истина, Ложь);
	
	Если ПодсистемаСуществует("ЕГАИС") Тогда
		МодульОбщегоНазначенияЕГАИС = ОбщегоНазначения.ОбщийМодуль("ОбщегоНазначенияЕГАИС");
		МодульОбщегоНазначенияЕГАИС.ЗаполнитьОписаниеКлассификаторов(Классификаторы, Истина);
	КонецЕсли;
	
	Если ПодсистемаСуществует("ВетИС") Тогда
		МодульИнтеграцияВЕТИС = ОбщегоНазначения.ОбщийМодуль("ИнтеграцияВЕТИС");
		МодульИнтеграцияВЕТИС.ЗаполнитьОписаниеКлассификаторов(Классификаторы, Истина);
	КонецЕсли;
	
	Если ПодсистемаСуществует("ЗЕРНО") Тогда
		МодульИнтеграцияЗЕРНО = ОбщегоНазначения.ОбщийМодуль("ИнтеграцияЗЕРНО");
		МодульИнтеграцияЗЕРНО.ЗаполнитьОписаниеКлассификаторов(Классификаторы, Истина);
	КонецЕсли;
	
	Если СравнениеВерсийБиблиотекиБИП > 0 Тогда
		ДобавитьКлассификаторы(Классификаторы);
	Иначе
		МодульРаботаСКлассификаторами = ОбщегоНазначения.ОбщийМодуль("РаботаСКлассификаторами");
		//@skip-check bsl-legacy-check-static-feature-access-for-unknown-left-part
		МодульРаботаСКлассификаторами.ДобавитьКлассификаторы(Классификаторы);
	КонецЕсли;
	
КонецПроцедуры

Функция МинимальнаяВерсияБиблиотекиИнтернетПоддержки()
	Возврат "2.8.3.0";
КонецФункции

Процедура ДобавитьКлассификаторы(Классификаторы)
	
	Для каждого Классификатор Из Классификаторы Цикл
		Запись = РегистрыСведений.ВерсииКлассификаторов.СоздатьМенеджерЗаписи();
		ЗаполнитьЗначенияСвойств(Запись, Классификатор);
		Запись.Записать();
	КонецЦикла;
	
КонецПроцедуры

#Область КлассификаторыИС

// Идентификаторы классификаторов.
// 
// Параметры:
//  УчитыватьОпции - Булево - Добавлять идентификаторы с учетом включенных опций
// 
// Возвращаемое значение:
//  Соответствие - Идентификаторы классификаторов
Функция ИдентификаторыКлассификаторов(Знач УчитыватьОпции=Ложь) Экспорт
	
	РазделениеВключено      = ОбщегоНазначения.РазделениеВключено();
	Идентификаторы          = Новый Соответствие();
	ВестиУчетПродукцииЕГАИС = Ложь;
	ВестиУчетПродукцииИСМП  = Ложь;
	
	Если РазделениеВключено Тогда
		УчитыватьОпции = Ложь;
	КонецЕсли;
	
	Если УчитыватьОпции Тогда
		Если ПодсистемаСуществует("ЕГАИС") Тогда
			МодульОбщегоНазначенияЕГАИС = ОбщегоНазначения.ОбщийМодуль("ОбщегоНазначенияЕГАИС");
			ВестиУчетПродукцииЕГАИС     = МодульОбщегоНазначенияЕГАИС.ИспользуетсяМаркируемаяПродукция();
		КонецЕсли;

		Если ПодсистемаСуществует("ИСМП") Тогда
			МодульОбщегоНазначенияИСМП = ОбщегоНазначения.ОбщийМодуль("ОбщегоНазначенияИСМП");
			ВестиУчетПродукцииИСМП     = МодульОбщегоНазначенияИСМП.ИспользуетсяМаркируемаяПродукция();
		КонецЕсли;
	КонецЕсли;
	
	Если Не УчитыватьОпции Или ВестиУчетПродукцииЕГАИС Или ВестиУчетПродукцииИСМП Тогда
		Идентификаторы.Вставить(
		"MinimalPricesForExcisableProducts", Новый Структура("Наименование, ВидКлассификатора", НСтр(
			"ru = 'Минимальные цены для алкогольной и табачной продукции ИС'"),
			"РегистрСведений.МинимальныеЦеныПодакцизныхТоваровИС"));
	КонецЕсли;
	
	ИдентификаторыВидовПродукции = ИдентификаторыКлассификатораВидовПродукцииИС(УчитыватьОпции);
	Для Каждого Идентификатор Из ИдентификаторыВидовПродукции Цикл
		Идентификаторы.Вставить(Идентификатор.Ключ, Идентификатор.Значение);
	КонецЦикла;
	
	Возврат Идентификаторы;
	
КонецФункции

// см. РаботаСКлассификаторамиПереопределяемый.ПриДобавленииКлассификаторов
Процедура ПриДобавленииКлассификаторовИС(Классификаторы)
	
	РазделениеВключено = ОбщегоНазначения.РазделениеВключено();
	
	ЗаполнитьОписаниеКлассификаторов(Классификаторы, РазделениеВключено, Истина);
	
КонецПроцедуры

// см. РаботаСКлассификаторамиПереопределяемый.ПриЗагрузкеКлассификатора
Процедура ПриЗагрузкеКлассификатораИС(Идентификатор, Версия, Адрес, Обработан, ДополнительныеПараметры)
	
	ИдентификаторыКлассификаторов = ИдентификаторыКлассификаторов();
	ДанныеКлассификатора          = ИдентификаторыКлассификаторов[Идентификатор];
	
	Если ДанныеКлассификатора = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ИдентификаторВидовПродукцииИС = ИдентификаторКлассификатораВидовПродукцииИС();
	
	Если Идентификатор = ИдентификаторВидовПродукцииИС Тогда
		ПриЗагрузкеКлассификатораВидовПродукцииИС(Идентификатор, Версия, Адрес, Обработан, ДополнительныеПараметры);
	Иначе
		ДвоичныеДанные      = ПолучитьИзВременногоХранилища(Адрес); // - ДвоичныеДанные
		ВременныеФайлы      = Новый Массив;
		ФайлыКлассификатора = Новый Массив;

		Попытка

			ПотокЧтения = ДвоичныеДанные.ОткрытьПотокДляЧтения();

			ЧтениеZIP = Новый ЧтениеZIPФайла(ПотокЧтения);
		
		//@skip-check missing-temporary-file-deletion
			ВременныйКаталог = ПолучитьИмяВременногоФайла("cat");
			СоздатьКаталог(ВременныйКаталог);

			Для Каждого ЭлементАрхива Из ЧтениеZIP.Элементы Цикл
				ИмяВременногоФайла = ОбъединитьПути(ВременныйКаталог, ЭлементАрхива.ПолноеИмя);
				ФайлыКлассификатора.Добавить(ИмяВременногоФайла);
				ВременныеФайлы.Добавить(ИмяВременногоФайла);
				ЧтениеZIP.Извлечь(ЭлементАрхива, ВременныйКаталог);
			КонецЦикла;

			ЧтениеZIP.Закрыть();
			ПотокЧтения.Закрыть();

		Исключение
			ТекстОшибки = СтрШаблон(
			НСтр("ru = 'Ошибка подготовки исходных файлов для загрузки классификатора ИС %1:
				 |%2'", ОбщегоНазначения.КодОсновногоЯзыка()), ДанныеКлассификатора.ВидКлассификатора,
				ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
			ТекстОписанияОшибки = СтрШаблон(
			НСтр("ru = 'Ошибка подготовки исходных файлов для загрузки классификатора ИС %1:
				 |%2'", ОбщегоНазначения.КодОсновногоЯзыка()), ДанныеКлассификатора.ВидКлассификатора,
				ОбработкаОшибок.КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));
			ОбщегоНазначенияИСВызовСервера.ЗаписатьОшибкуВЖурналРегистрации(
			ТекстОшибки, НСтр("ru = 'Работа с классификаторами ИС'", ОбщегоНазначения.КодОсновногоЯзыка()));
			ВызватьИсключение ТекстОписанияОшибки;
		КонецПопытки;

		МенеджерОбъекта = ОбщегоНазначения.МенеджерОбъектаПоПолномуИмени(ДанныеКлассификатора.ВидКлассификатора);
		МенеджерОбъекта.ПриЗагрузкеКлассификатора(Идентификатор, Версия, Адрес, Обработан, ДополнительныеПараметры,
			ФайлыКлассификатора);

		Если ЗначениеЗаполнено(ВременныйКаталог) Тогда
			ВременныеФайлы.Добавить(ВременныйКаталог);
		КонецЕсли;
		Для Каждого ИмяВременногоФайла Из ВременныеФайлы Цикл
			УдалитьФайлы(ИмяВременногоФайла);
		КонецЦикла;

	КонецЕсли;
	
КонецПроцедуры

// см. РаботаСКлассификаторамиПереопределяемый.ПриОпределенииНачальногоНомераВерсииКлассификатора
Процедура ПриОпределенииНачальногоНомераВерсииКлассификатораИС(Идентификатор, НачальныйНомерВерсии)
	
	Возврат;
	
КонецПроцедуры

// см. РаботаСКлассификаторамиВМоделиСервисаПереопределяемый.ПриОпределенииИдентификаторовКлассификаторов
Процедура ПриОпределенииИдентификаторовКлассификаторовВМоделиСервисаИС(Идентификаторы)
	
	ИдентификаторыКлассификаторов = ИдентификаторыКлассификаторов();
	
	Для Каждого КлючИЗначение Из ИдентификаторыКлассификаторов Цикл
		
		Идентификаторы.Добавить(КлючИЗначение.Ключ);
		
	КонецЦикла;
	
КонецПроцедуры

// см. РаботаСКлассификаторами.ОписаниеКлассификатора
Процедура ЗаполнитьОписаниеКлассификаторов(Классификаторы, СохранятьФайлВКэш, УчитыватьОпции)
	
	ИдентификаторыКлассификаторов = ИдентификаторыКлассификаторов(УчитыватьОпции);
	
	Для Каждого КлючИЗначение Из ИдентификаторыКлассификаторов Цикл
		
		Описатель = РаботаСКлассификаторами.ОписаниеКлассификатора();
		Описатель.Наименование               = КлючИЗначение.Значение.Наименование;
		Описатель.Идентификатор              = КлючИЗначение.Ключ;
		Описатель.ОбновлятьАвтоматически     = Истина;
		Описатель.ОбщиеДанные                = Истина;
		Описатель.СохранятьФайлВКэш          = СохранятьФайлВКэш;
		Описатель.ОбработкаРазделенныхДанных = Ложь;
		
		Классификаторы.Добавить(Описатель);
		
	КонецЦикла;
	
КонецПроцедуры

// Текст запроса проверки необходимости загрузки классификаторов ИС.
// 
// Параметры:
//  Классификатор - Строка
// 
// Возвращаемое значение:
//  Строка - Текст запроса проверки необходимости загрузки классификаторов ИС
Функция ТекстЗапросаПроверкиНеобходимостиЗагрузкиКлассификаторовИС(Классификатор) Экспорт
	
	ТекстЗапроса = "";
	
	Если Классификатор = "MinimalPricesForExcisableProducts" Тогда
		ТекстЗапроса = "ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	МинимальныеЦеныПодакцизныхТоваровИС.МинимальнаяЦена КАК МинимальнаяЦена
		|ИЗ
		|	РегистрСведений.МинимальныеЦеныПодакцизныхТоваровИС КАК МинимальныеЦеныПодакцизныхТоваровИС";
	ИначеЕсли Классификатор = ИдентификаторКлассификатораВидовПродукцииИС() Тогда
		ТекстЗапроса = ТекстЗапросаПроверкиНеобходимостиЗагрузкиКлассификатораВидовПродукцииИС();
	КонецЕсли;
	
	Возврат ТекстЗапроса;
	
КонецФункции

#Область КлассификаторВидовПродукцииИС

// Возвращает идентификаторы классификатора видов продукции БГосИС с учетом включенного разделения данных и настроек учета продукции.
//
// Параметры:
//   УчитыватьОпции - Булево - признак необходимости учета функциональной опции использования ИС
//
// Возвращаемое значение:
//   Соответствие:
//     * Ключ - Строка - идентификатор классификатора
//     * Значение - Структура:
//         ** Наименование - Строка - наименование классификатора
//         ** ВидКлассификатора - Строка, Неопределено - вид классификатора (если указан)
Функция ИдентификаторыКлассификатораВидовПродукцииИС(Знач УчитыватьОпции=Ложь) Экспорт
	
	РазделениеВключено     = ОбщегоНазначения.РазделениеВключено();
	Идентификаторы         = Новый Соответствие;
	ВедетсяУчетПродукцииИС = Ложь;
	
	Если РазделениеВключено Тогда
		УчитыватьОпции = Ложь;
	КонецЕсли;
	
	Если УчитыватьОпции Тогда
		ВедетсяУчетПродукцииИС = ВедетсяУчетПродукцииИС();
	КонецЕсли;
	
	Если Не УчитыватьОпции Или ВедетсяУчетПродукцииИС Тогда
		Идентификаторы.Вставить(
		"ClassifierOfProductTypeSettingsBGosIS", Новый Структура("Наименование, ВидКлассификатора", НСтр(
			"ru = 'Классификатор настроек видов продукции БГосИС'")));
	КонецЕсли;
	
	Возврат Идентификаторы;
	
КонецФункции

// см. РаботаСКлассификаторамиПереопределяемый.ПриЗагрузкеКлассификатора
Процедура ПриЗагрузкеКлассификатораВидовПродукцииИС(Идентификатор, Версия, Адрес, Обработан, ДополнительныеПараметры) Экспорт
	
	ИдентификаторыКлассификаторов = ИдентификаторыКлассификаторов();
	ДанныеКлассификатора          = ИдентификаторыКлассификаторов[Идентификатор];
	
	Если ДанныеКлассификатора = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ПараметрыЗагрузки   = ПараметрыЗагрузкиКлассификаторовИС();
	РезультатОбновления = ИнициализироватьРезультатыОбновленияКлассификаторовВидовПродукцииИС();
	
	Если ДополнительныеПараметры.Свойство("ПараметрыЗагрузки") Тогда
		ЗаполнитьЗначенияСвойств(ПараметрыЗагрузки, ДополнительныеПараметры.ПараметрыЗагрузки);
	КонецЕсли;
	
	НачатьТранзакцию();
	
	Попытка
		ОбновлениеКлассификаторовВидовПродукцииИС(Адрес, ПараметрыЗагрузки, РезультатОбновления);
		
		Если Не РезультатОбновления.УспешнаяЗагрузка Тогда
			ВызватьИсключение РезультатОбновления.СообщениеОбОшибке;
		КонецЕсли;
		
		Обработан = Истина;
		
		ЗафиксироватьТранзакцию();
		
	Исключение
		ОтменитьТранзакцию();
		
		ТекстСообщения = СтрШаблон(
			НСтр("ru = 'Не удалось загрузить классификаторы %1 по причине:
				 |%2'"), ДанныеКлассификатора.ВидКлассификатора, ОбработкаОшибок.ПодробноеПредставлениеОшибки(
				ИнформацияОбОшибке()));
				
		ВызватьИсключение ТекстСообщения;
		
	КонецПопытки;
	
	РегистрыСведений.ПоставляемыеДанныеКлассификаторовВидовПродукцииИС.ДобавитьПоставляемыеДанныеКлассификаторовВидовПродукцииИС(
		Идентификатор, Версия, Адрес, РезультатОбновления.ДанныеЗагруженыЧастично);
	
	ОбновитьПовторноИспользуемыеЗначения();
	
	Если Не ОбщегоНазначения.РазделениеВключено() Тогда
		РегистрыСведений.ОписаниеНоменклатурыИС.ЗаполнитьОтсутствующиеКлючиПоИдентификаторамВидовПродукции();
	КонецЕсли;
	
КонецПроцедуры

// Обновляет классификаторы видов продукции, товарных групп и справочников ИС из ZIP-архива.
//
// Параметры:
//   Адрес - Строка - адрес во временном хранилище ZIP-архива с классификаторами
//   ПараметрыЗагрузки - Структура - параметры обновления классификаторов
//   РезультатОбновления - Структура - структура для записи результатов обновления, содержит сообщения об ошибках и признак успешной загрузки
Процедура ОбновлениеКлассификаторовВидовПродукцииИС(Адрес, ПараметрыЗагрузки, РезультатОбновления)
	
	Если ОбщегоНазначения.ЭтоПодчиненныйУзелРИБ() Тогда
		Возврат;
	КонецЕсли;
	
	ДвоичныеДанные      = ПолучитьИзВременногоХранилища(Адрес);
	ВременныеФайлы      = Новый Массив();
	ФайлыКлассификатора = Новый Соответствие();
	ДанныеДляЗагрузки   = Новый Соответствие();
	РасширеннаяВерсия   = ЭтоРасширеннаяВерсияГосИС();
	
	Попытка
		ПотокЧтения = ДвоичныеДанные.ОткрытьПотокДляЧтения();

		ЧтениеZIP = Новый ЧтениеZIPФайла(ПотокЧтения);
		
		//@skip-check missing-temporary-file-deletion
		ВременныйКаталог = ПолучитьИмяВременногоФайла("cat");
		СоздатьКаталог(ВременныйКаталог);

		Для Каждого ЭлементАрхива Из ЧтениеZIP.Элементы Цикл
			ИмяВременногоФайла = ОбъединитьПути(ВременныйКаталог, ЭлементАрхива.ПолноеИмя);
			ФайлыКлассификатора.Вставить(ЭлементАрхива.ИмяБезРасширения, ИмяВременногоФайла);
			ВременныеФайлы.Добавить(ИмяВременногоФайла);
			ЧтениеZIP.Извлечь(ЭлементАрхива, ВременныйКаталог);
		КонецЦикла;

		ЧтениеZIP.Закрыть();
		ПотокЧтения.Закрыть();

	Исключение
		ТекстОшибки = ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
		РезультатОбновления.СообщениеОбОшибке = ТекстОшибки;
		РезультатОбновления.УспешнаяЗагрузка  = Ложь;
	КонецПопытки;
	
	Если Не ФайлыКлассификатора.Количество() Тогда
		Возврат;
	КонецЕсли;
	
	Попытка
		
		Для Каждого ФайлКлассификатора Из ФайлыКлассификатора Цикл
			Чтение = Новый ЧтениеJSON;
			Чтение.ОткрытьФайл(ФайлКлассификатора.Значение);	
			ДанныеКлассификатора = ПрочитатьJSON(Чтение);	
			ДанныеДляЗагрузки.Вставить(ФайлКлассификатора.Ключ, ДанныеКлассификатора);
			Чтение.Закрыть();
		КонецЦикла;
		
	Исключение
		ТекстОшибки = СтрШаблон(
			НСтр("ru = 'Внутренняя ошибка. Не удалось прочитать исходные данные классификатора %1
			|%2'"),
			"",
			ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
		
		РезультатОбновления.СообщениеОбОшибке = ТекстОшибки;
		РезультатОбновления.УспешнаяЗагрузка  = Ложь;
	КонецПопытки;
	
	Если ЗначениеЗаполнено(ВременныйКаталог) Тогда
		ВременныеФайлы.Добавить(ВременныйКаталог);
	КонецЕсли;
	Для Каждого ИмяВременногоФайла Из ВременныеФайлы Цикл
		УдалитьФайлы(ИмяВременногоФайла);
	КонецЦикла;
	
	Если ДанныеДляЗагрузки.Количество() Тогда
		
		УстановитьПривилегированныйРежим(Истина);
		
		ДанныеОбновленияВидовПродукции = ДанныеДляЗагрузки["ProductTypes"];
		Если ДанныеОбновленияВидовПродукции <> Неопределено Тогда
			Справочники.ВидыПродукцииИС.ПриЗагрузкеКлассификатора(ДанныеОбновленияВидовПродукции, ПараметрыЗагрузки,
				РезультатОбновления);
		КонецЕсли;
		
		ДанныеОбновленияТоварныхГрупп = ДанныеДляЗагрузки["ProductGroups"];
		Если ДанныеОбновленияТоварныхГрупп <> Неопределено Тогда
			Справочники.ТоварныеГруппыГИСМТ.ПриЗагрузкеКлассификатора(ДанныеОбновленияТоварныхГрупп, ПараметрыЗагрузки,
				РезультатОбновления);
		КонецЕсли;
		
		ДанныеОбновленияПричиныВывода = ДанныеДляЗагрузки["WithdrawalReasons"];
		Если ДанныеОбновленияПричиныВывода <> Неопределено И РасширеннаяВерсия Тогда
			МенеджерОбъекта = ОбщегоНазначения.МенеджерОбъектаПоПолномуИмени("Справочник.ПричиныВыводаИзОборотаИСМП");
			МенеджерОбъекта.ПриЗагрузкеКлассификатора(ДанныеОбновленияПричиныВывода, ПараметрыЗагрузки,
				РезультатОбновления);
		КонецЕсли;

		ДанныеОбновленияВидовВозвратаВОборот = ДанныеДляЗагрузки["TypesOfReturns"];
		Если ДанныеОбновленияВидовВозвратаВОборот <> Неопределено И РасширеннаяВерсия Тогда
			МенеджерОбъекта = ОбщегоНазначения.МенеджерОбъектаПоПолномуИмени("Справочник.ВидыВозвратаВОборотИСМП");
			МенеджерОбъекта.ПриЗагрузкеКлассификатора(ДанныеОбновленияВидовВозвратаВОборот, ПараметрыЗагрузки,
				РезультатОбновления);
		КонецЕсли;

		ДанныеОбновленияШаблоновРазбораКМ = ДанныеДляЗагрузки["KMTemplates"];
		Если ДанныеОбновленияШаблоновРазбораКМ <> Неопределено Тогда
			Справочники.ШаблоныРазбораКодовМаркировкиИСМП.ПриЗагрузкеКлассификатора(ДанныеОбновленияШаблоновРазбораКМ, ПараметрыЗагрузки,
				РезультатОбновления);
		КонецЕсли;

		ДанныеОбновленияШаблоновКМСУЗ = ДанныеДляЗагрузки["SUZTemplates"];
		Если ДанныеОбновленияШаблоновКМСУЗ <> Неопределено Тогда
			Справочники.ШаблоныКодовМаркировкиСУЗ.ПриЗагрузкеКлассификатора(ДанныеОбновленияШаблоновКМСУЗ, ПараметрыЗагрузки,
				РезультатОбновления);
		КонецЕсли;

		ДанныеОбновленияМестПрименения = ДанныеДляЗагрузки["PlacesOfApplication"];
		Если ДанныеОбновленияМестПрименения <> Неопределено Тогда
			Справочники.МестаПримененияЭлементовКонструктораВидовПродукцииИС.ПриЗагрузкеКлассификатора(
				ДанныеОбновленияМестПрименения, ПараметрыЗагрузки, РезультатОбновления);
		КонецЕсли;

		ДанныеОбновленияМестПримененияЭК = ДанныеДляЗагрузки["PlacesOfConstructorElements"];
		Если ДанныеОбновленияМестПримененияЭК <> Неопределено Тогда
			РегистрыСведений.МестаПримененияЭлементовКонструктораВидовПродукцииИС.ПриЗагрузкеКлассификатора(
				ДанныеОбновленияМестПримененияЭК, ПараметрыЗагрузки, РезультатОбновления);
		КонецЕсли;

		ДанныеОбновленияДоступныхЗначений = ДанныеДляЗагрузки["AvailableValues"];
		Если ДанныеОбновленияДоступныхЗначений <> Неопределено Тогда
			РегистрыСведений.ДоступныеЗначенияЭлементовКонструктораВидовПродукцииИС.ПриЗагрузкеКлассификатора(
				ДанныеОбновленияДоступныхЗначений, ПараметрыЗагрузки, РезультатОбновления);
		КонецЕсли;

		ДанныеОбновленияМестЗначений = ДанныеДляЗагрузки["AvailableValuesPlaces"];
		Если ДанныеОбновленияМестЗначений <> Неопределено Тогда
			РегистрыСведений.ДоступныеЗначенияПоМестамПримененияЭлементовКонструктораВидовПродукцииИС.ПриЗагрузкеКлассификатора(
				ДанныеОбновленияМестЗначений, ПараметрыЗагрузки, РезультатОбновления);
		КонецЕсли;

		ДанныеОбновленияЭлементовКонструктора = ДанныеДляЗагрузки["ConstructorElements"];
		Если ДанныеОбновленияЭлементовКонструктора <> Неопределено Тогда
			Если ПараметрыЗагрузки.ЗагрузкаИзменений Тогда
				РегистрыСведений.ЗначенияПользователяЭлементовКонструктораВидовПродукцииИС.ПриЗагрузкеКлассификатора(
					ДанныеОбновленияЭлементовКонструктора, ПараметрыЗагрузки, РезультатОбновления);
			Иначе
				РегистрыСведений.ЗначенияЭлементовКонструктораВидовПродукцииИС.ПриЗагрузкеКлассификатора(
					ДанныеОбновленияЭлементовКонструктора, ПараметрыЗагрузки, РезультатОбновления);
			КонецЕсли;
		КонецЕсли;
		
		ДанныеОбновленияКодовТНВЭД = ДанныеДляЗагрузки["TNVED"];
		Если ДанныеОбновленияКодовТНВЭД <> Неопределено Тогда
			Справочники.ТНВЭДПоВидамПродукцииИС.ПриЗагрузкеКлассификатора(ДанныеОбновленияКодовТНВЭД,
				ПараметрыЗагрузки, РезультатОбновления);
		КонецЕсли;
		
		ДанныеОбновленияКодовОКПД = ДанныеДляЗагрузки["OKPD"];
		Если ДанныеОбновленияКодовОКПД <> Неопределено Тогда
			Справочники.ОКПД2ПоВидамПродукцииИС.ПриЗагрузкеКлассификатора(ДанныеОбновленияКодовОКПД, ПараметрыЗагрузки,
				РезультатОбновления);
		КонецЕсли;
		
		ДанныеОбновленияТНВЭДОКПД2 = ДанныеДляЗагрузки["TNVEDOKPD2"];
		Если ДанныеОбновленияТНВЭДОКПД2 <> Неопределено Тогда
			РегистрыСведений.СоответствиеТНВЭДиОКПД2ИС.ПриЗагрузкеКлассификатора(ДанныеОбновленияТНВЭДОКПД2, ПараметрыЗагрузки,
				РезультатОбновления);
		КонецЕсли;

		КонфликтыОбновления = ПараметрыЗагрузки.КонфликтыОбновления;

		Если КонфликтыОбновления.Количество() И ОбщегоНазначения.ПодсистемаСуществует("ПрикладнаяГосИС") Тогда
			МенеджерРегистраКонфликтов = ОбщегоНазначения.ОбщийМодуль("РегистрыСведений.КонфликтыОбновленияНастроекИС");
			МенеджерРегистраКонфликтов.ЗаписатьКонфликтыПриОбновлении(КонфликтыОбновления);
		КонецЕсли;
		
		Если Не ОбщегоНазначения.РазделениеВключено() Тогда
			
			Если Не ПараметрыЗагрузки.ЗагрузкаИзменений Тогда
				РегистрыСведений.ЗначенияПользователяЭлементовКонструктораВидовПродукцииИС.СинхронизироватьЗначенияСОсновнымРегистром();
			КонецЕсли;
			
			ИмяОповещения = "СтандартныеПодсистемы.БазоваяФункциональность.ПовторноИспользуемыеЗначенияУстарели";
			Попытка
				СерверныеОповещения.ОтправитьСерверноеОповещение(ИмяОповещения, Неопределено,, Истина);
			Исключение
				ТекстОшибки = СтрШаблон(
					"Ошибка при отправке серверного оповещения при обновлении классификаторов:
					|%1",
					ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
				ЗаписьЖурналаРегистрации(
					"ГБосИС.ОтправкаСерверногоОповещениПриОбновленииКлассификаторов",
					УровеньЖурналаРегистрации.Ошибка,,,
					ТекстОшибки);
			КонецПопытки;
			
		КонецЕсли;
		
	КонецЕсли;
		
КонецПроцедуры

// см. ОбщегоНазначенияИСКлиентСервер.ИдентификаторКлассификатораВидовПродукцииИС
Функция ИдентификаторКлассификатораВидовПродукцииИС() Экспорт
	
	Возврат ОбщегоНазначенияИСКлиентСервер.ИдентификаторКлассификатораВидовПродукцииИС();
	
КонецФункции

// Параметры загрузки классификаторов ИС.
// 
// Возвращаемое значение:
//  Структура - Параметры загрузки классификаторов ИС:
// * Идентификаторы - ТаблицаЗначений - Таблица идентификаторов классификаторов:
// ** ИмяТаблицы - Строка(100) - Имя таблицы метаданных
// ** Идентификатор - Строка(36) - Идентификатор элемента
// ** Наименование - Строка(150) - Наименование элемента
// ** Код - Строка(9) - Код элемента
// ** КлючЗначения - Строка(50) - Ключ значения
// ** Ссылка - СправочникСсылка.ЭлементыКонструктораВидовПродукцииИС - Ссылка на элемент справочника
// * ЗагрузкаИзменений - Булево - Признак загрузки изменений
// * КонфликтыОбновления - Соответствие - Соответствие конфликтов обновления
// * РежимОтладки - Булево - Признак режима отладки
// * ПолнаяЗагрузка - Булево - Обязательное обновление всех элементов справочников
Функция ПараметрыЗагрузкиКлассификаторовИС() Экспорт
	
	ПараметрыЗагрузки = Новый Структура;
	
	Идентификаторы = Новый ТаблицаЗначений;
	Идентификаторы.Колонки.Добавить("ИмяТаблицы",    ОбщегоНазначения.ОписаниеТипаСтрока(100));
	Идентификаторы.Колонки.Добавить("Идентификатор", ОбщегоНазначения.ОписаниеТипаСтрока(36));
	Идентификаторы.Колонки.Добавить("Наименование",  ОбщегоНазначения.ОписаниеТипаСтрока(150));
	Идентификаторы.Колонки.Добавить("Код",           ОбщегоНазначения.ОписаниеТипаСтрока(9));
	Идентификаторы.Колонки.Добавить("КлючЗначения",  ОбщегоНазначения.ОписаниеТипаСтрока(50));
	Идентификаторы.Колонки.Добавить("Ссылка",        Справочники.ТипВсеСсылки());
	
	ЭлементыКонструктора = Справочники.ЭлементыКонструктораВидовПродукцииИС.ПараметрыЭлементовКонструктора();
	ИмяТаблицыЭлементов  = Метаданные.Справочники.ЭлементыКонструктораВидовПродукцииИС.ПолноеИмя();
	
	Для каждого КлючИЗначение Из ЭлементыКонструктора Цикл
		ДанныеЭлемента = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(КлючИЗначение.Ключ, "ЭтоГруппа, ИмяПредопределенныхДанных");
		
		Если ДанныеЭлемента.ЭтоГруппа Тогда
			Продолжить;
		КонецЕсли;
		
		СтрокаИдентификаторов = Идентификаторы.Добавить();
		
		СтрокаИдентификаторов.ИмяТаблицы   = ИмяТаблицыЭлементов;
		СтрокаИдентификаторов.Наименование = ДанныеЭлемента.ИмяПредопределенныхДанных;
		СтрокаИдентификаторов.Ссылка       = КлючИЗначение.Ключ;
		
	КонецЦикла;
	
	Идентификаторы.Индексы.Добавить("ИмяТаблицы, Наименование");
	Идентификаторы.Индексы.Добавить("ИмяТаблицы, Идентификатор, Наименование");
	Идентификаторы.Индексы.Добавить("ИмяТаблицы, Идентификатор, Наименование, КлючЗначения");
	
	ПараметрыЗагрузки.Вставить("Идентификаторы",      Идентификаторы);
	ПараметрыЗагрузки.Вставить("ЗагрузкаИзменений",   Ложь);
	ПараметрыЗагрузки.Вставить("ПолнаяЗагрузка",      Ложь);
	ПараметрыЗагрузки.Вставить("КонфликтыОбновления", Новый Соответствие);
	ПараметрыЗагрузки.Вставить("РежимОтладки",        Ложь );
	
	Возврат ПараметрыЗагрузки;
	
КонецФункции

// Возвращает структуру для хранения результатов обновления классификаторов видов продукции ИС.
//
// Возвращаемое значение:
//   Структура:
//     * УспешнаяЗагрузка - Булево - признак успешной загрузки
//     * СообщениеОбОшибке - Строка - текст ошибки при неудачной загрузке
//     * ДанныеЗагруженыЧастично - Булево - признак частичной загрузки данных
Функция ИнициализироватьРезультатыОбновленияКлассификаторовВидовПродукцииИС() Экспорт
	
	РезультатОбновления = Новый Структура;
	РезультатОбновления.Вставить("УспешнаяЗагрузка",        Истина);
	РезультатОбновления.Вставить("СообщениеОбОшибке",       "");
	РезультатОбновления.Вставить("ДанныеЗагруженыЧастично", Ложь);
	
	Возврат РезультатОбновления;
		
КонецФункции

// Определяет действия при загрузке элементов классификатора на основе хеш-сумм и параметров загрузки.
//
// Параметры:
//   ПараметрыЗагрузки - Структура - параметры загрузки, должны содержать свойство ЗагрузкаИзменений
//   СуществующийОбъектСсылка - СправочникСсылка, Неопределено - ссылка на существующий объект или Неопределено
//   ХешСумма - Строка - текущая хеш-сумма объекта в информационной базе
//   ХешСуммаПоставляемыхДанных - Строка - хеш-сумма поставляемых данных
//   ХешСуммаЗагружаемыхДанных - Строка - хеш-сумма загружаемых данных
//
// Возвращаемое значение:
//   Структура - структура с флагами дальнейших действий:
//     * СоздатьЭлемент - Булево - признак необходимости создания нового элемента
//     * ТребуетсяОбновление - Булево - признак необходимости обновления элемента
//     * ЗафиксироватьКонфликт - Булево - признак необходимости фиксации конфликта
//     * КоллизияИзменений - Булево - признак наличия коллизии изменений
Функция ПараметрыОбновленияЭлементовПриЗагрузкеКлассификатора(ПараметрыЗагрузки, СуществующийОбъектСсылка, ХешСумма,
	ХешСуммаПоставляемыхДанных, ХешСуммаЗагружаемыхДанных) Экспорт

	ДальнейшиеДействия = Новый Структура;
	ДальнейшиеДействия.Вставить("СоздатьЭлемент",        Ложь);
	ДальнейшиеДействия.Вставить("ТребуетсяОбновление",   Ложь);
	ДальнейшиеДействия.Вставить("ЗафиксироватьКонфликт", Ложь);
	ДальнейшиеДействия.Вставить("КоллизияИзменений",     Ложь);

	Если СуществующийОбъектСсылка = Неопределено Тогда
		ДальнейшиеДействия.СоздатьЭлемент = Истина;
	Иначе
		Если ПараметрыЗагрузки.ПолнаяЗагрузка Тогда
			ДальнейшиеДействия.ТребуетсяОбновление = Истина;
			
		ИначеЕсли ПараметрыЗагрузки.ЗагрузкаИзменений Тогда
			Если ХешСумма <> ХешСуммаЗагружаемыхДанных Тогда
				Если ХешСумма <> ХешСуммаПоставляемыхДанных Тогда
					ДальнейшиеДействия.КоллизияИзменений = Истина;
				Иначе
					ДальнейшиеДействия.ТребуетсяОбновление = Истина;
				КонецЕсли;
			КонецЕсли;

		Иначе
			Если ХешСуммаПоставляемыхДанных = "" Тогда
				Если ХешСумма = "" Тогда
					ДальнейшиеДействия.ТребуетсяОбновление = Истина;
				ИначеЕсли ХешСумма <> ХешСуммаЗагружаемыхДанных Тогда
					ДальнейшиеДействия.ЗафиксироватьКонфликт = Истина;
				Иначе
					ДальнейшиеДействия.ТребуетсяОбновление = Истина;
				КонецЕсли;
			ИначеЕсли ХешСуммаПоставляемыхДанных <> ХешСуммаЗагружаемыхДанных Тогда
				Если ХешСуммаЗагружаемыхДанных = ХешСумма Тогда
					ДальнейшиеДействия.ТребуетсяОбновление = Истина;
				ИначеЕсли ХешСуммаПоставляемыхДанных <> ХешСумма Тогда
					ДальнейшиеДействия.ЗафиксироватьКонфликт = Истина;
				Иначе
					ДальнейшиеДействия.ТребуетсяОбновление = Истина;
				КонецЕсли;
			КонецЕсли;

		КонецЕсли;

	КонецЕсли;

	Возврат ДальнейшиеДействия;

КонецФункции

// Добавляет элемент в список конфликтов при обновлении с указанием загружаемых данных и хеш-суммы.
//
// Параметры:
//   СписокКонфликтов - Соответствие - список формируемых конфликтов обновления
//   ЭлементКонфликта - СправочникСсылка - ключ, по которому добавляется информация о конфликте
//   ЗагружаемыеДанные - Структура - данные, которые загружаются при обновлении
Процедура ДобавитьЭлементДляЗаписиКонфликтаПриОбновлении(СписокКонфликтов, ЭлементКонфликта, ЗагружаемыеДанные) Экспорт

	ПоставляемыеДанныеТекст = ОбщегоНазначенияИСКлиентСервер.ОбъектВТекстJSON(ЗагружаемыеДанные);
	
	Если ПоставляемыеДанныеТекст <> Неопределено Тогда
		СтруктураКонфликта = Новый Структура;
		СтруктураКонфликта.Вставить("ЗагружаемыеДанные", ПоставляемыеДанныеТекст);
		СтруктураКонфликта.Вставить("ХешСуммаПоставляемыхДанных", ЗагружаемыеДанные.ХешСуммаПоставляемыхДанных);

		СписокКонфликтов.Вставить(ЭлементКонфликта, СтруктураКонфликта);
		
	КонецЕсли;
	
КонецПроцедуры

// Список исключений подсистемы БРМК.
