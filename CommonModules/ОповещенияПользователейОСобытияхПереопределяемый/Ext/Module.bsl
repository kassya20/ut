		ОповещенияПользователейОСобытиях.ОписаниеГруппыВидовОповещений("9ca9ef1c-d839-4fae-b1e9-ec578486c184", 
			НСтр("ru = 'Продажи'", ОбщегоНазначения.КодОсновногоЯзыка())));
	
	ГруппыВидовОповещений.Вставить("Закупки",
		ОповещенияПользователейОСобытиях.ОписаниеГруппыВидовОповещений("9ed8539b-1da7-4801-966d-bab6969a3968", 
			НСтр("ru = 'Закупки'", ОбщегоНазначения.КодОсновногоЯзыка())));
	
	ГруппыВидовОповещений.Вставить("Казначейство",
		ОповещенияПользователейОСобытиях.ОписаниеГруппыВидовОповещений("dee8a453-b373-40cc-9096-830f95f0f4fd", 
			НСтр("ru = 'Казначейство'", ОбщегоНазначения.КодОсновногоЯзыка())));

	ГруппыВидовОповещений.Вставить("ВзаиморасчетыСКлиентами",
		ОповещенияПользователейОСобытиях.ОписаниеГруппыВидовОповещений("b2f42f53-94a6-4f6d-99f9-ab78f91074d6", 
			НСтр("ru = 'Взаиморасчеты с клиентами'", ОбщегоНазначения.КодОсновногоЯзыка())));
	
	ГруппыВидовОповещений.Вставить("ВзаиморасчетыСПоставщиками",
		ОповещенияПользователейОСобытиях.ОписаниеГруппыВидовОповещений("105818a5-b852-4e3a-aeff-60487133f51d", 
			НСтр("ru = 'Взаиморасчеты с поставщиками'", ОбщегоНазначения.КодОсновногоЯзыка())));
			
	ГруппыВидовОповещений.Вставить("ДоговорыКонтрагентов",
		ОповещенияПользователейОСобытиях.ОписаниеГруппыВидовОповещений("75d39378-7656-4717-816c-494b8f04cc47", 
			НСтр("ru = 'Договоры контрагентов'", ОбщегоНазначения.КодОсновногоЯзыка())));
	
	ОповещенияПользователейОСобытияхЛокализация.ДополнитьГруппыВидовОповещений(ГруппыВидовОповещений);
	
