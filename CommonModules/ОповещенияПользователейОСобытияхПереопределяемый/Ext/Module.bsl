// Дополняет массив объектами с описанием видов оповещений.
// 
// Параметры:
//  МассивОбъектов - Массив из Строка - Источники оповещений исключения
Процедура ДополнитьОбъектыСОписаниемВидовОповещений(МассивОбъектов) Экспорт
	
	МассивОбъектов.Добавить(Метаданные.Справочники.ДоговорыКонтрагентов.ПолноеИмя());
	МассивОбъектов.Добавить(Метаданные.Справочники.СоглашенияСКлиентами.ПолноеИмя());
	МассивОбъектов.Добавить(Метаданные.Справочники.СоглашенияСПоставщиками.ПолноеИмя());
	
	МассивОбъектов.Добавить(Метаданные.Документы.ЗаявкаНаРасходованиеДенежныхСредств.ПолноеИмя());
	
	МассивОбъектов.Добавить(Метаданные.РегистрыНакопления.ДенежныеСредстваКВыплате.ПолноеИмя());
	МассивОбъектов.Добавить(Метаданные.РегистрыНакопления.ЗаказыПоставщикам.ПолноеИмя());
	МассивОбъектов.Добавить(Метаданные.РегистрыНакопления.РаспоряженияНаОтгрузкуИВозврат.ПолноеИмя());
	МассивОбъектов.Добавить(Метаданные.РегистрыНакопления.РасчетыСКлиентами.ПолноеИмя());
	МассивОбъектов.Добавить(Метаданные.РегистрыНакопления.РасчетыСКлиентамиПланОплат.ПолноеИмя());
	МассивОбъектов.Добавить(Метаданные.РегистрыНакопления.РасчетыСПоставщиками.ПолноеИмя());
	МассивОбъектов.Добавить(Метаданные.РегистрыНакопления.РасчетыСПоставщикамиПланОплат.ПолноеИмя());
	МассивОбъектов.Добавить(Метаданные.РегистрыНакопления.ТоварыКОтгрузке.ПолноеИмя());
	МассивОбъектов.Добавить(Метаданные.РегистрыНакопления.ТоварыКПоступлению.ПолноеИмя());
	
	МассивОбъектов.Добавить(Метаданные.РегистрыСведений.СостоянияЗаказовКлиентов.ПолноеИмя());
	МассивОбъектов.Добавить(Метаданные.РегистрыСведений.СостоянияЗаказовПоставщикам.ПолноеИмя());
	
	ОповещенияПользователейОСобытияхЛокализация.ДополнитьОбъектыСОписаниемВидовОповещений(МассивОбъектов);
	
КонецПроцедуры

// Формирует массив объектов с описанием видов оповещений.
