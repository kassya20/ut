#Область СлужебныйПрограммныйИнтерфейс

// Признак использования любой доставки в системе
// 
// Возвращаемое значение:
//  Булево 
//
Функция ИспользуетсяДоставка() Экспорт
	
	Возврат ПолучитьФункциональнуюОпцию("ИспользоватьУправлениеДоставкой");
	
КонецФункции

// Признак использования доставки версии 2.0 в системе
// 
// Возвращаемое значение:
//  Булево 
//
Функция ИспользуетсяДоставка20() Экспорт
	
	Возврат ПолучитьФункциональнуюОпцию("ИспользоватьУправлениеДоставкой")
			И ПолучитьФункциональнуюОпцию("НеИспользоватьУправлениеДоставкой25");
	
КонецФункции

// Признак использования доставки версии 2.5 в системе
// 
// Возвращаемое значение:
//  Булево 
//
Функция ИспользуетсяДоставка25() Экспорт
	
	Возврат ПолучитьФункциональнуюОпцию("ИспользоватьУправлениеДоставкой")
			И ПолучитьФункциональнуюОпцию("НеИспользоватьУправлениеДоставкой20");
	
КонецФункции

