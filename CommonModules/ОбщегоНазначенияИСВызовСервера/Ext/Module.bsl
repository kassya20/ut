#Область КонструкторВидовПродукции

Функция ПредставленияВидовУпаковокПоВидамПродукции() Экспорт
	
	Склонения = Новый Соответствие;
	
	ЭлементКонструктора        = ПредопределенноеЗначение("Справочник.ЭлементыКонструктораВидовПродукцииИС.ВидыУпаковок");
	ДанныеЭлемента             = КонструкторИСОбщегоНазначенияКлиентСервер.ДанныеЭлементаКонструктора(ЭлементКонструктора);
	АтрибутыВидовУпаковок      = КонструкторИСОбщегоНазначенияКлиентСервер.АтрибутыВидовУпаковок();
	ДанныеЭлемента             = ОбщегоНазначения.СкопироватьРекурсивно(ДанныеЭлемента);
	ДанныеЭлемента.ВидыПродукции.Вставить(Справочники.ВидыПродукцииИС.ПустаяСсылка(), Новый Соответствие());
	
	Кеш = Новый Соответствие;
	
	Для Каждого КлючИЗначение Из ДанныеЭлемента.ВидыПродукции Цикл
		
		ВидПродукции = КлючИЗначение.Ключ;
		Значения     = КлючИЗначение.Значение;
		
		Для Каждого ВидУпаковки Из Перечисления.ВидыУпаковокИС Цикл
			
			ЗначенияАтрибутовПоВидуУпаковки = Значения[ВидУпаковки];
			
			Для Каждого АтрибутыВидовУпаковки Из АтрибутыВидовУпаковок Цикл
				
				ИмяАтрибута       = АтрибутыВидовУпаковки.Ключ;
				ПараметрыАтрибута = АтрибутыВидовУпаковки.Значение;
				
				ПредставлениеВидаУпаковки = "";
				Если ЗначенияАтрибутовПоВидуУпаковки <> Неопределено
					И ЗначенияАтрибутовПоВидуУпаковки.Свойство(ИмяАтрибута)  Тогда
					ПредставлениеВидаУпаковки = ЗначенияАтрибутовПоВидуУпаковки[ИмяАтрибута];
				КонецЕсли;
				
				Если Не ЗначениеЗаполнено(ПредставлениеВидаУпаковки) Тогда
					ПредставлениеВидаУпаковки = КонструкторИСОбщегоНазначенияКлиентСервер.ПредставлениеВидаУпаковкиПоУмолчанию(
						ВидУпаковки,
						ПараметрыАтрибута.ГрамматическоеЧисло,
						ПараметрыАтрибута.ЭтоОписаниеКоличества);
				КонецЕсли;
				
				КлючКеша = ПредставлениеВидаУпаковки + "|" + ПараметрыАтрибута.Падеж;
				ЗначениеИзКеша = Кеш[КлючКеша];
				Если ЗначениеИзКеша <> Неопределено Тогда
					ПредставлениеВидаУпаковки = ЗначениеИзКеша;
				Иначе
					ЗначенияСклонений = ПолучитьСклоненияСтроки(
						ПредставлениеВидаУпаковки,
						"Л=ru_RU",
						СтрШаблон("ПД=%1", ПараметрыАтрибута.Падеж));
					Если ЗначенияСклонений.Количество() Тогда
						ПредставлениеВидаУпаковки = ЗначенияСклонений[0];
					КонецЕсли;
					Кеш.Вставить(КлючКеша, ПредставлениеВидаУпаковки);
				КонецЕсли;
				
				ЗначенияПути = Новый Массив;
				ЗначенияПути.Добавить(ВидПродукции);
				ЗначенияПути.Добавить(ВидУпаковки);
				ЗначенияПути.Добавить(ПараметрыАтрибута.Падеж);
				ЗначенияПути.Добавить(ПараметрыАтрибута.ГрамматическоеЧисло);
				ЗначенияПути.Добавить(ПараметрыАтрибута.ЭтоОписаниеКоличества);
				
				ОбщегоНазначенияИСКлиентСервер.УстановитьДанныеПоПутиВСоответствии(
					Склонения, ЗначенияПути, ПредставлениеВидаУпаковки);
					
			КонецЦикла;
			
		КонецЦикла;
		
	КонецЦикла;
	
	Возврат Склонения;
	
КонецФункции

