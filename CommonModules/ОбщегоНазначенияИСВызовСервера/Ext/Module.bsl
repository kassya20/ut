КонецФункции

// Возвращает значения элемента конструктора.
// 
// Параметры:
//  ЭлементКонструктора - СправочникСсылка.ЭлементыКонструктораВидовПродукцииИС - элемент конструктора, для которого требуется получить данные.
//  ВидыПродукции - Массив из СправочникСсылка.ВидыПродукцииИС - виды продукции, для которых требуется получить значение.
//  Значение - ОпределяемыйТип.ЗначениеЭлементаКонструктораВидовПродукцииИС - значение, для которого требуется получить атрибуты.
//             Не требуется, если элемент конструктора не Параметризуется.
// 
// Возвращаемое значение:
//  Структура:
//   * Значение             - Булево - Истина - задано "предопределенное" значение, Ложь - "предопределенное" значение задано не было.
//   * ЗначениеПользователя - Булево, Неопределено - Истина - пользователь установил значение, Ложь - пользователь удалил значение,
//                            Неопределено - пользователь не изменял значение.
//
Функция ЗначенияЭлементаКонструктора(ЭлементКонструктора, ВидыПродукции, Значение = Неопределено) Экспорт
	
	Результат = Новый Структура;
	Результат.Вставить("Значение", Ложь);
	Результат.Вставить("ЗначениеПользователя", Неопределено);
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ЭлементКонструктора", ЭлементКонструктора);
	Запрос.УстановитьПараметр("ВидыПродукции",       ВидыПродукции);
	Запрос.УстановитьПараметр("Значение",            Значение);
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	ИСТИНА
	|ИЗ
	|	РегистрСведений.ЗначенияЭлементовКонструктораВидовПродукцииИС КАК Значения
	|ГДЕ
	|	Значения.ЭлементКонструктора = &ЭлементКонструктора
	|	И Значения.ВидПродукции В (&ВидыПродукции)
	|	И Значения.Значение = &Значение
	|;
	|ВЫБРАТЬ ПЕРВЫЕ 1
	|	Значения.ПометкаУдаления
	|ИЗ
	|	РегистрСведений.ЗначенияПользователяЭлементовКонструктораВидовПродукцииИС КАК Значения
	|ГДЕ
	|	Значения.ЭлементКонструктора = &ЭлементКонструктора
	|	И Значения.ВидПродукции В (&ВидыПродукции)
	|	И Значения.Значение = &Значение";
	РезультатЗапроса = Запрос.ВыполнитьПакет();
	
	Выборка = РезультатЗапроса[0].Выбрать();
	Если Выборка.Следующий() Тогда
		Результат.Значение = Истина;
	КонецЕсли;
	
	Выборка = РезультатЗапроса[1].Выбрать();
	Если Выборка.Следующий() Тогда
		Результат.ЗначениеПользователя = Не Выборка.ПометкаУдаления;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

