Функция ТекстЗапросаДляРаспределениеПартийНДСПоДопРасходам(ПараметрыРасчета) Экспорт
	
	ТекстЗапроса = "";
	
	Если ЗначениеЗаполнено(ПараметрыРасчета) Тогда
		ЕстьТаблицаДопРасходов = РасчетСебестоимостиПрикладныеАлгоритмы.ВременнаяТаблицаСуществует(ПараметрыРасчета, "ВТДопРасходыДляРаспределения");
		ЕстьТаблицаПриходыТоваровНДС = РасчетСебестоимостиПрикладныеАлгоритмы.ВременнаяТаблицаСуществует(ПараметрыРасчета, "ПриходыТоваровНДС");
	Иначе
		ЕстьТаблицаДопРасходов = Ложь;
		ЕстьТаблицаПриходыТоваровНДС = Ложь;
	КонецЕсли;
	
	// выборка данных
	Если НЕ ЕстьТаблицаПриходыТоваровНДС Тогда
	 	ТекстЗапроса = ТекстЗапроса + ТекстИнициализацияПартийНДСОбщая() + ОбщегоНазначения.РазделительПакетаЗапросов();
	 	ТекстЗапроса = ТекстЗапроса + ТекстИсправленныеДокументыНДС() + ОбщегоНазначения.РазделительПакетаЗапросов();
	 	ТекстЗапроса = ТекстЗапроса + ТекстКорректировкиДоВводаОстатков() + ОбщегоНазначения.РазделительПакетаЗапросов();
	 	ТекстЗапроса = ТекстЗапроса + ТекстПриходыТоваровНДС() + ОбщегоНазначения.РазделительПакетаЗапросов();
	КонецЕсли;
	Если НЕ ЕстьТаблицаДопРасходов Тогда
	 	ТекстЗапроса = ТекстЗапроса + ТекстРаспределениеДопРасходов() + ОбщегоНазначения.РазделительПакетаЗапросов();
	КонецЕсли;
	
	ТекстЗапроса = ТекстЗапроса
		+ ТекстДопРасходыДляРаспределенияРасширенная()
		+ ОбщегоНазначения.РазделительПакетаЗапросов()
		+ ТекстДопРасходыДляРаспределенияРегл()
		+ ОбщегоНазначенияУТ.РазделительЗапросовВОбъединении() + ТекстДопРасходыДляРаспределенияУпр()
		+ ОбщегоНазначения.РазделительПакетаЗапросов()
		+ ТекстБазаДопРасходыРегл()
		+ ОбщегоНазначенияУТ.РазделительЗапросовВОбъединении() + ТекстБазаДопРасходыУпр()
		+ "";
		
	Возврат ТекстЗапроса;
	
КонецФункции

