Функция ЭтоПодготовкаДанныхДляУчетаНДСиУСН(Контекст) Экспорт
	
	Результат = Ложь;
	
	//++ Локализация

	// Этап 11
	Результат = Контекст = "ПодготовкаДанныхДляУчетаНДСиУСН"
		// Этап 11.1.2
		Или Контекст = "ПодготовкаДанныхДляУчетаНДСиУСН_ДопРасходы"
		// Этап 11.1.3
		Или Контекст = "ПодготовкаДанныхДляУчетаНДСиУСН_Постатейные";
	//-- Локализация
	
	Возврат Результат;
	
