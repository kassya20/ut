#Область ПроцедурыЭтапа_РасчетОтклонениеВыпускаФИФОСкользящая

Функция ТекстЗапросаКорректировкаОтклоненийВыпуска(ПараметрыРасчета) Экспорт
	Возврат
		"ВЫБРАТЬ
		|	Т.Организация,
		|	Т.КорПартия КАК Партия,
		|	Т.КорАналитикаУчетаПартий КАК АналитикаУчетаПартий,
		|	Т.КорВидЗапасов КАК ВидЗапасов,
		|	Т.КорАналитикаУчетаНоменклатуры КАК АналитикаУчетаНоменклатурыДокументаПоступления,
		|	Т.Регистратор КАК ДокументПоступления,
		|
		|	СУММА(Т.Количество) КАК Количество,
		|	СУММА(ВЫБОР КОГДА Т.РасчетСебестоимости ТОГДА -1 ИНАЧЕ 1 КОНЕЦ
		|	  * (Т.СтоимостьРегл + Т.ДопРасходыРегл + Т.ПостатейныеПостоянныеРегл + Т.ПостатейныеПеременныеРегл)) КАК СтоимостьБезНДСРегл,
		|	СУММА(ВЫБОР КОГДА Т.РасчетСебестоимости ТОГДА -1 ИНАЧЕ 1 КОНЕЦ
		|	  * (Т.СтоимостьУпр + Т.ДопРасходыУпр + Т.ПостатейныеПостоянныеУпр + Т.ПостатейныеПеременныеУпр)) КАК СтоимостьБезНДСУпр
		|ПОМЕСТИТЬ ВТКорректировкаОтклоненийВыпускаПредварительная
		|ИЗ
		|	ВТКэшРасчетныеОборотыСебестоимостьТоваров КАК Т
		|ГДЕ
		|	Т.Организация В (&ОрганизацииСУчетомПартийНДСВерсии24)
		|	И Т.Организация В (&ОрганизацииИспользуютСписаниеОтклоненийНаПродажи)
		|	И НЕ Т.СлужебноеВидДвиженияПриход
		|	И Т.РазделУчета = ЗНАЧЕНИЕ(Перечисление.РазделыУчетаСебестоимостиТоваров.ВыпускПродукции)
		|	И Т.КорПартия <> НЕОПРЕДЕЛЕНО
		|	И НЕ Т.Сторно
		|СГРУППИРОВАТЬ ПО
		|	Т.Организация,
		|	Т.КорПартия,
		|	Т.КорАналитикаУчетаПартий,
		|	Т.КорВидЗапасов,
		|	Т.КорАналитикаУчетаНоменклатуры,
		|	Т.Регистратор
		|ИМЕЮЩИЕ
		|	МАКСИМУМ(Т.РасчетСебестоимости) = ИСТИНА
		|	И МИНИМУМ(Т.РасчетСебестоимости) = ЛОЖЬ
		|
		|ИНДЕКСИРОВАТЬ ПО
		|	АналитикаУчетаНоменклатурыДокументаПоступления
		|;
		|////////////////////////////////////////////////////////////////////////////////
		|
		|ВЫБРАТЬ
		|	&НачалоПериода КАК ПериодРегистрации,
		|	Т.Организация,
		|	Т.Партия,
		|	Т.АналитикаУчетаПартий,
		|	Т.ВидЗапасов,
		|	КлючиАналитики.Номенклатура КАК Номенклатура,
		|	КлючиАналитики.Характеристика КАК Характеристика,
		|
		|	ЛОЖЬ КАК ЗатратыПредыдущихПеределов,
		|	Т.АналитикаУчетаНоменклатурыДокументаПоступления,
		|	ЗНАЧЕНИЕ(Справочник.КлючиАналитикиУчетаНоменклатуры.ПустаяСсылка) КАК АналитикаУчетаНоменклатурыНЗП,
		|	Т.ДокументПоступления,
		|	Т.АналитикаУчетаПартий КАК АналитикаУчетаПартийДокументаПоступления,
		|
		|	ВЫРАЗИТЬ(Т.СтоимостьБезНДСРегл / Т.Количество КАК ЧИСЛО (31,10)) КАК СтоимостьБезНДСРегл,
		|	ВЫРАЗИТЬ(Т.СтоимостьБезНДСУпр / Т.Количество КАК ЧИСЛО (31,10)) КАК СтоимостьБезНДСУпр
		|ПОМЕСТИТЬ ВТКорректировкаОтклоненийВыпуска
		|ИЗ
		|	ВТКорректировкаОтклоненийВыпускаПредварительная КАК Т
		|	ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.КлючиАналитикиУчетаНоменклатуры КАК КлючиАналитики
		|		ПО Т.АналитикаУчетаНоменклатурыДокументаПоступления = КлючиАналитики.Ссылка
		|ГДЕ
		|	Т.Количество <> 0
		|	И (Т.СтоимостьБезНДСРегл <> 0
		|		ИЛИ Т.СтоимостьБезНДСУпр <> 0)
		|";
	
КонецФункции

#КонецОбласти

