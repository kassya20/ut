Функция ТекстЗапросаДляПартийНДС_Постатейные()
	
	// ВТ Данные.
	МассивТекстовЗапроса = Новый Массив();
	МассивТекстовЗапроса.Добавить(ТекстОписаниеДанныхДляПартийНДСиУСН());
	МассивТекстовЗапроса.Добавить(ТекстРаспределениеПостатейныхЗатрат());
	МассивТекстовЗапроса.Добавить(ТекстСписаниеПостатейныхЗатратНаВыпуск());
	МассивТекстовЗапроса.Добавить(ТекстСписаниеПостатейныхЗатрат()); // использует ВТСписаниеПостатейныхЗатрат
	МассивТекстовЗапроса.Добавить(ТекстПриходыСебестоимостиТоваровДляДопРасходов()); // использует ПриходыТоваровНДС
	МассивТекстовЗапроса.Добавить(ТекстДетализацияПартийТоваровДляНДСиУСНДвиженияВТекущемПериоде()); // использует ВТДетализацияПартийТоваровДляНДСиУСН
	
	ТекстЗапроса = 	СтрСоединить(МассивТекстовЗапроса, ОбщегоНазначенияУТ.РазделительЗапросовВОбъединении());
	Возврат ТекстЗапроса;
КонецФункции

Функция ТекстРаспределениеПостатейныхЗатрат()
	ТекстЗапроса = "
	|ВЫБРАТЬ
	|	""ТекстРаспределениеПостатейныхЗатрат"" КАК ЗапросИсточник,
