		|	ЗНАЧЕНИЕ(Перечисление.ТипыЗаписейПартий.Прошлое) КАК ТипЗаписи,
		|	ЛОЖЬ КАК ЭтоСторно,
		|	0 КАК Приоритет,
		|	ДД.КоличествоПоДокументу					КАК Знаменатель,
		|	0 											КАК ЗнаменательДляИсточников,
		|	ИСТИНА КАК РасчетЗавершен,
		|	ДД.АналитикаУчетаНоменклатуры.Номенклатура 	КАК Номенклатура,
		|	ДД.КорВидДеятельностиНДС 					КАК НалогообложениеПартии,
		|	
		|	ДД.Период,
		|	ДД.Регистратор,
		|	ЗНАЧЕНИЕ(Документ.РегистраторРасчетаСебестоимости.ПустаяСсылка) КАК РегистраторСебестоимости,
		|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход) КАК ВидДвижения,
		|	ДД.Организация,
		|	ДД.РазделУчета,
		|	ДД.АналитикаУчетаНоменклатуры,
		|	ДД.ВидЗапасов,
		|	ДД.Партия,
		|	ДД.АналитикаФинансовогоУчета,
		|	ДД.КорВидДеятельностиНДС КАК ВидДеятельностиНДС,
		|	ЗНАЧЕНИЕ(Перечисление.ТипыНалогообложенияНДС.ПустаяСсылка) КАК ВидДеятельностиНДССебестоимости,
		|	ДД.АналитикаУчетаПартий,
		|	ДД.ДокументПоступления,
		|
		|	ДД.Количество,
		|	(ВЫБОР
		|		КОГДА ДД.КоличествоПоДокументу = ДД.Количество ИЛИ ДД.Количество = 0
		|			ТОГДА ДД.СтоимостьБезНДС
		|		ИНАЧЕ ВЫРАЗИТЬ(ДД.КоличествоПоДокументу * (ДД.СтоимостьБезНДС / ДД.Количество) КАК ЧИСЛО(31,2))
		|		КОНЕЦ) КАК СтоимостьБезНДС,
		|	(ВЫБОР
		|		КОГДА ДД.КоличествоПоДокументу = ДД.Количество ИЛИ ДД.Количество = 0
		|			ТОГДА ДД.НДС
		|		ИНАЧЕ ВЫРАЗИТЬ(ДД.КоличествоПоДокументу * (ДД.НДС / ДД.Количество) КАК ЧИСЛО(31,2))
		|		КОНЕЦ) КАК НДС,
