			);
		
		РасчетСебестоимостиПрикладныеАлгоритмы.ЗаполнитьНомераСтрокВременнойТаблицы(
			ПараметрыРасчета,
			ПараметрыНумерации,
			ИмяТаблицыРезультатаПредварительная,
			ИмяТаблицыРезультата);
		
	Иначе
		
		Запрос.Текст =
		"ВЫБРАТЬ
		|	Т.ЕстьЦена,
		|	Т.ТипЗаписи,
		|	Т.Период,
