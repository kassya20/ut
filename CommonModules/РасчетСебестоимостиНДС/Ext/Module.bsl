	ИначеЕсли ЗначениеЗаполнено(ПараметрыРасчета.ОрганизацииБезДетализацииДоДокументовПоступления) Тогда
		
		Запрос.Текст =
		"ВЫБРАТЬ
		|	Т.ЭтоОстаткиПостатейныеПеременные,
		|	Т.ЭтоОстаткиПостатейныеПостоянные,
		// Аналитики партий НДС
		|	Т.АналитикаУчетаНоменклатурыДокументаПоступления,
		|	ВЫБОР КОГДА Т.Организация В (&ОрганизацииБезДетализацииДоДокументовПоступления)
		|			И НЕ Т.ЭтоОстатки И (Т.НДСРегл = 0 И Т.НДСУпр = 0)
		|		ТОГДА НЕОПРЕДЕЛЕНО
		|		ИНАЧЕ Т.ДокументПоступления
		|	КОНЕЦ КАК ДокументПоступления,
		|	ВЫБОР КОГДА Т.Организация В (&ОрганизацииБезДетализацииДоДокументовПоступления)
		|			И НЕ Т.ЭтоОстатки И (Т.НДСРегл = 0 И Т.НДСУпр = 0)
		|		ТОГДА ЗНАЧЕНИЕ(Справочник.КлючиАналитикиУчетаПартий.ПустаяСсылка)
		|		ИНАЧЕ Т.АналитикаУчетаПартийДокументаПоступления
		|	КОНЕЦ КАК АналитикаУчетаПартийДокументаПоступления,
		|	Т.ЗатратыПредыдущихПеределов,
		|	Т.ЭтоДопРасходы,
		|	Т.ЭтоПеременныеДопРасходы,
		|	
		// Аналитики себестоимости
		|	Т.Организация,
		|	Т.РазделУчета,
		|	Т.АналитикаУчетаНоменклатуры,
		|	Т.ВидЗапасов,
		|	Т.Партия,
		|	Т.АналитикаУчетаПартий,
		|	Т.ВидДеятельностиНДС,
		|	Т.АналитикаФинансовогоУчета,
		|
		// Прочие поля
		|	Т.СтатьяРасходов,
		|	Т.АналитикаРасходов,
		|
		// Ресурсы
		|	ВЫБОР КОГДА СУММА(Т.ЗнакСтоимостьСНДС * Т.СтоимостьСНДС) < 0 ТОГДА -1 ИНАЧЕ 1 КОНЕЦ КАК ЗнакСтоимостьСНДС,
		|	ВЫБОР КОГДА СУММА(Т.ЗнакСтоимостьБезНДС * Т.СтоимостьБезНДС) < 0 ТОГДА -1 ИНАЧЕ 1 КОНЕЦ КАК ЗнакСтоимостьБезНДС,
		|	ВЫБОР КОГДА СУММА(Т.ЗнакСтоимостьБезНДСРегл * Т.СтоимостьБезНДСРегл) < 0 ТОГДА -1 ИНАЧЕ 1 КОНЕЦ КАК ЗнакСтоимостьБезНДСРегл,
		|	ВЫБОР КОГДА СУММА(Т.ЗнакНДСРегл * Т.НДСРегл) < 0 ТОГДА -1 ИНАЧЕ 1 КОНЕЦ КАК ЗнакНДСРегл,
		|	ВЫБОР КОГДА СУММА(Т.ЗнакСтоимостьБезНДСУпр * Т.СтоимостьБезНДСУпр) < 0 ТОГДА -1 ИНАЧЕ 1 КОНЕЦ КАК ЗнакСтоимостьБезНДСУпр,
		|	ВЫБОР КОГДА СУММА(Т.ЗнакНДСУпр * Т.НДСУпр) < 0 ТОГДА -1 ИНАЧЕ 1 КОНЕЦ КАК ЗнакНДСУпр,
		|
		|	ВЫБОР КОГДА СУММА(Т.ЗнакСтоимостьСНДС * Т.СтоимостьСНДС) < 0 ТОГДА -СУММА(Т.ЗнакСтоимостьСНДС * Т.СтоимостьСНДС) ИНАЧЕ СУММА(Т.ЗнакСтоимостьСНДС * Т.СтоимостьСНДС) КОНЕЦ КАК СтоимостьСНДС,
		|	ВЫБОР КОГДА СУММА(Т.ЗнакСтоимостьБезНДС * Т.СтоимостьБезНДС) < 0 ТОГДА -СУММА(Т.ЗнакСтоимостьБезНДС * Т.СтоимостьБезНДС) ИНАЧЕ СУММА(Т.ЗнакСтоимостьБезНДС * Т.СтоимостьБезНДС) КОНЕЦ КАК СтоимостьБезНДС,
		|	ВЫБОР КОГДА СУММА(Т.ЗнакСтоимостьБезНДСРегл * Т.СтоимостьБезНДСРегл) < 0 ТОГДА -СУММА(Т.ЗнакСтоимостьБезНДСРегл * Т.СтоимостьБезНДСРегл) ИНАЧЕ СУММА(Т.ЗнакСтоимостьБезНДСРегл * Т.СтоимостьБезНДСРегл) КОНЕЦ КАК СтоимостьБезНДСРегл,
		|	ВЫБОР КОГДА СУММА(Т.ЗнакНДСРегл * Т.НДСРегл) < 0 ТОГДА -СУММА(Т.ЗнакНДСРегл * Т.НДСРегл) ИНАЧЕ СУММА(Т.ЗнакНДСРегл * Т.НДСРегл) КОНЕЦ КАК НДСРегл,
		|	ВЫБОР КОГДА СУММА(Т.ЗнакСтоимостьБезНДСУпр * Т.СтоимостьБезНДСУпр) < 0 ТОГДА -СУММА(Т.ЗнакСтоимостьБезНДСУпр * Т.СтоимостьБезНДСУпр) ИНАЧЕ СУММА(Т.ЗнакСтоимостьБезНДСУпр * Т.СтоимостьБезНДСУпр) КОНЕЦ КАК СтоимостьБезНДСУпр,
		|	ВЫБОР КОГДА СУММА(Т.ЗнакНДСУпр * Т.НДСУпр) < 0 ТОГДА -СУММА(Т.ЗнакНДСУпр * Т.НДСУпр) ИНАЧЕ СУММА(Т.ЗнакНДСУпр * Т.НДСУпр) КОНЕЦ КАК НДСУпр
		|ПОМЕСТИТЬ ДанныеДляРасчетаСокращенная
		|ИЗ
		|	ИмяТаблицыДанных КАК Т
		|СГРУППИРОВАТЬ ПО
		|	Т.ЭтоОстаткиПостатейныеПеременные,
		|	Т.ЭтоОстаткиПостатейныеПостоянные,
		|	Т.АналитикаУчетаНоменклатурыДокументаПоступления,
		|	ВЫБОР КОГДА Т.Организация В (&ОрганизацииБезДетализацииДоДокументовПоступления)
		|			И НЕ Т.ЭтоОстатки И (Т.НДСРегл = 0 И Т.НДСУпр = 0)
		|		ТОГДА НЕОПРЕДЕЛЕНО
		|		ИНАЧЕ Т.ДокументПоступления
		|	КОНЕЦ,
		|	ВЫБОР КОГДА Т.Организация В (&ОрганизацииБезДетализацииДоДокументовПоступления)
		|			И НЕ Т.ЭтоОстатки И (Т.НДСРегл = 0 И Т.НДСУпр = 0)
		|		ТОГДА ЗНАЧЕНИЕ(Справочник.КлючиАналитикиУчетаПартий.ПустаяСсылка)
		|		ИНАЧЕ Т.АналитикаУчетаПартийДокументаПоступления
		|	КОНЕЦ,
		|	Т.ЗатратыПредыдущихПеределов,
		|	Т.ЭтоДопРасходы,
		|	Т.ЭтоПеременныеДопРасходы,
		|	Т.Организация,
		|	Т.РазделУчета,
		|	Т.АналитикаУчетаНоменклатуры,
		|	Т.ВидЗапасов,
		|	Т.Партия,
		|	Т.АналитикаУчетаПартий,
		|	Т.ВидДеятельностиНДС,
		|	Т.АналитикаФинансовогоУчета,
		|	Т.СтатьяРасходов,
		|	Т.АналитикаРасходов
		|
		// Индексы должны соответствовать свойству ИндексыРегистра из описания регистра себестоимости
		|ИНДЕКСИРОВАТЬ ПО
		|	АналитикаУчетаНоменклатуры,
		|	Организация,
		|	Партия
		|";
		
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "ИмяТаблицыДанных", ИмяТаблицыДанных);
		
		РасчетСебестоимостиПрикладныеАлгоритмы.ВыполнитьЗапросСЗамеромДляПротокола(ПараметрыРасчета, Запрос);
		
		ИмяТаблицыДанных = "ДанныеДляРасчетаСокращенная";
		
	КонецЕсли;
	
	ЕстьПостатейные = РасчетСебестоимостиПовтИсп.РаспределятьПостатейныеЗатратыРекурсивно()
		И РасчетСебестоимостиПрикладныеАлгоритмы.ВременнаяТаблицаСуществует(ПараметрыРасчета, "СвязиСЛУ_ПостатейныеРасходыОрганизаций");
	
	Если НЕ РасчетСебестоимостиПрикладныеАлгоритмы.ВременнаяТаблицаСуществует(ПараметрыРасчета, "ВтСвязиУзловКорректировкиСебестоимостиСоСписаниемНДС") Тогда
	 
		Запрос.Текст =
		"ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	Т.НомерУзла,
		|	ВЫБОР КОГДА Т.ВидДеятельностиНДС В (&ТипыНалогообложенияНДСНеУчитываетсяВСтоимости)
		|		ТОГДА ИСТИНА
		|		ИНАЧЕ ЛОЖЬ
		|	КОНЕЦ КАК ИсточникСписанияНДС,
		|	ВЫБОР КОГДА Т.ВидДеятельностиНДС В (&ТипыНалогообложенияНДСУчитываетсяВСтоимости)
		|		ТОГДА ИСТИНА
		|		ИНАЧЕ ЛОЖЬ
		|	КОНЕЦ КАК ПриемникСписанияНДС,
		|	ВЫБОР КОГДА ЛОЖЬ ТОГДА ЛОЖЬ // для удобства расстановки тегов
		//++ Локализация
		|		КОГДА УчетнаяПолитика.ВариантУчетаНДСПриИзмененииВидаДеятельности = ЗНАЧЕНИЕ(Перечисление.ВариантыУчетаНДСПриИзмененииВидаДеятельностиНаНеоблагаемую.ВключатьВСтоимостьИлиРасходыВЗависимостиОтПериода)
		|			ТОГДА ИСТИНА
		//-- Локализация
		|		ИНАЧЕ ЛОЖЬ
		|	КОНЕЦ КАК СписаниеНДСЗависитОтПериодаДокументаПоступления
		|ПОМЕСТИТЬ ВтУзлыКорректировкиСебестоимостиДляСписанияНДС
		|ИЗ
		|	ВтУзлыКорректировкиСебестоимости КАК Т
		//++ Локализация
		|	ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТНастройкиУчетаНДС КАК УчетнаяПолитика
		|		ПО Т.Организация = УчетнаяПолитика.Организация
		//-- Локализация
		|ГДЕ
		|	ЛОЖЬ
		//++ Локализация
		|	ИЛИ УчетнаяПолитика.ВариантУчетаНДСПриИзмененииВидаДеятельности <> ЗНАЧЕНИЕ(Перечисление.ВариантыУчетаНДСПриИзмененииВидаДеятельностиНаНеоблагаемую.ВключатьВСтоимость)
		//-- Локализация
		|ИНДЕКСИРОВАТЬ ПО
		|	НомерУзла
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	Т.НомерУзлаИсточник КАК НомерУзлаИсточник,
		|	Т.НомерУзлаПриемник КАК НомерУзлаПриемник,
		|	Т.Вес,
		|	0 КАК ВесУпр,
		|	ВЫБОР КОГДА ЕСТЬNULL(УзлыИсточники.ИсточникСписанияНДС, ЛОЖЬ)
		|	  И ЕСТЬNULL(УзлыПриемники.ПриемникСписанияНДС, ЛОЖЬ)
		|		ТОГДА ИСТИНА
		|		ИНАЧЕ ЛОЖЬ
		|	КОНЕЦ КАК СменаВидаДеятельностиНДС,
		|	ЕСТЬNULL(УзлыИсточники.СписаниеНДСЗависитОтПериодаДокументаПоступления, ЛОЖЬ) КАК СписаниеНДСЗависитОтПериодаДокументаПоступления
		|ПОМЕСТИТЬ ВтСвязиУзловКорректировкиСебестоимостиСоСписаниемНДС
		|ИЗ
		|	ВтСвязиУзловКорректировкиСебестоимости КАК Т
		|	ЛЕВОЕ СОЕДИНЕНИЕ ВтУзлыКорректировкиСебестоимостиДляСписанияНДС КАК УзлыИсточники
		|		ПО УзлыИсточники.НомерУзла = Т.НомерУзлаИсточник
		|	ЛЕВОЕ СОЕДИНЕНИЕ ВтУзлыКорректировкиСебестоимостиДляСписанияНДС КАК УзлыПриемники
		|		ПО УзлыПриемники.НомерУзла = Т.НомерУзлаПриемник
		|
		|ИНДЕКСИРОВАТЬ ПО
		|	НомерУзлаИсточник
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	Т.НомерУзлаИсточник КАК НомерУзлаИсточник,
		|	Т.НомерУзлаПриемник КАК НомерУзлаПриемник
		|ПОМЕСТИТЬ ВтСвязиУзловКорректировкиСебестоимостиСоСменойПартии
		|ИЗ
		|	ВтСвязиУзловКорректировкиСебестоимости КАК Т
		|	ЛЕВОЕ СОЕДИНЕНИЕ ВтУзлыКорректировкиСебестоимости КАК УзлыИсточники
		|		ПО УзлыИсточники.НомерУзла = Т.НомерУзлаИсточник
		|	ЛЕВОЕ СОЕДИНЕНИЕ ВтУзлыКорректировкиСебестоимости КАК УзлыПриемники
		|		ПО УзлыПриемники.НомерУзла = Т.НомерУзлаПриемник
		|ГДЕ
		|	УзлыИсточники.Партия <> УзлыПриемники.Партия
		|ИНДЕКСИРОВАТЬ ПО
		|	НомерУзлаИсточник
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	Т.НомерУзлаИсточник КАК НомерУзлаИсточник,
		|	Т.НомерУзлаПриемник КАК НомерУзлаПриемник
		|ПОМЕСТИТЬ ВтСвязиУзловКорректировкиСебестоимостиСтоимостьРегл
		|ИЗ
		|	ВтСвязиУзловКорректировкиСебестоимости КАК Т
		|ГДЕ
		|	Т.НеПеремещатьСтоимостьРегл
		|ИНДЕКСИРОВАТЬ ПО
		|	НомерУзлаИсточник
		|";
		
		РасчетСебестоимостиПрикладныеАлгоритмы.ВыполнитьЗапросСЗамеромДляПротокола(ПараметрыРасчета, Запрос);
		
	КонецЕсли;
	
	Если ЕстьПостатейные Тогда
		
		РасчетСебестоимостиПрикладныеАлгоритмы.УничтожитьВременныеТаблицы(ПараметрыРасчета,
			"ВтСвязиУзловКорректировкиСебестоимостиСоСписаниемНДС, ВтСвязиУзловКорректировкиСебестоимостиСоСменойПартии, ВтВесаУзловПостатейные, ВТУзлыКорректировкиНЗП");
		
		Запрос.Текст =
		"ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	Т.НомерУзлаИсточник КАК НомерУзлаИсточник,
		|	Т.НомерУзлаПриемник КАК НомерУзлаПриемник,
		|	-Т.ВесДугиРегл КАК Вес,
		|	-Т.ВесДугиУпр КАК ВесУпр,
		|	ВЫБОР КОГДА ЕСТЬNULL(УзлыИсточники.ИсточникСписанияНДС, ЛОЖЬ)
		|	  И ЕСТЬNULL(УзлыПриемники.ПриемникСписанияНДС, ЛОЖЬ)
		|		ТОГДА ИСТИНА
		|		ИНАЧЕ ЛОЖЬ
		|	КОНЕЦ КАК СменаВидаДеятельностиНДС,
		|	ЕСТЬNULL(УзлыИсточники.СписаниеНДСЗависитОтПериодаДокументаПоступления, ЛОЖЬ) КАК СписаниеНДСЗависитОтПериодаДокументаПоступления
		|ПОМЕСТИТЬ ВтСвязиУзловКорректировкиСебестоимостиСоСписаниемНДС
		|ИЗ
		|	СвязиСЛУ_ПостатейныеРасходыОрганизаций КАК Т
		|	ЛЕВОЕ СОЕДИНЕНИЕ ВтУзлыКорректировкиСебестоимостиДляСписанияНДС КАК УзлыИсточники
		|		ПО УзлыИсточники.НомерУзла = Т.НомерУзлаИсточник
		|	ЛЕВОЕ СОЕДИНЕНИЕ ВтУзлыКорректировкиСебестоимостиДляСписанияНДС КАК УзлыПриемники
		|		ПО УзлыПриемники.НомерУзла = Т.НомерУзлаПриемник
		|ГДЕ
		|	Т.НомерУзлаИсточник <> Т.НомерУзлаПриемник
		|
		|ИНДЕКСИРОВАТЬ ПО
		|	НомерУзлаИсточник
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Т.НомерУзлаИсточник КАК НомерУзла,
		|	Т.ВесДугиРегл КАК Вес,
		|	Т.ВесДугиУпр КАК ВесУпр
		|ПОМЕСТИТЬ ВтВесаУзловПостатейные
		|ИЗ
		|	СвязиСЛУ_ПостатейныеРасходыОрганизаций КАК Т
		|ГДЕ
		|	Т.НомерУзлаИсточник = Т.НомерУзлаПриемник
		|
		|ИНДЕКСИРОВАТЬ ПО
		|	НомерУзла
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	Т.НомерУзлаИсточник КАК НомерУзлаИсточник,
		|	Т.НомерУзлаПриемник КАК НомерУзлаПриемник
		|ПОМЕСТИТЬ ВтСвязиУзловКорректировкиСебестоимостиСоСменойПартии
		|ИЗ
		|	СвязиСЛУ_ПостатейныеРасходыОрганизаций КАК Т
		|	ЛЕВОЕ СОЕДИНЕНИЕ ВтУзлыКорректировкиСебестоимости КАК УзлыИсточники
		|		ПО УзлыИсточники.НомерУзла = Т.НомерУзлаИсточник
		|	ЛЕВОЕ СОЕДИНЕНИЕ ВтУзлыКорректировкиСебестоимости КАК УзлыПриемники
		|		ПО УзлыПриемники.НомерУзла = Т.НомерУзлаПриемник
		|ГДЕ
		|	Т.НомерУзлаИсточник <> Т.НомерУзлаПриемник
		|	И (УзлыИсточники.Партия ЕСТЬ NULL
		|		ИЛИ УзлыПриемники.Партия ЕСТЬ NULL
		|		ИЛИ УзлыИсточники.Партия <> УзлыПриемники.Партия)
		|ИНДЕКСИРОВАТЬ ПО
		|	НомерУзлаИсточник
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
