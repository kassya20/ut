		|		КОГДА ДД.КоличествоПоДокументу = ДД.Количество ИЛИ ДД.Количество = 0
		|			ТОГДА ДД.СтоимостьБезНДС
		|		ИНАЧЕ ВЫРАЗИТЬ(ДД.КоличествоПоДокументу * (ДД.СтоимостьБезНДС / ДД.Количество) КАК ЧИСЛО(31,2))
		|		КОНЕЦ) КАК СтоимостьБезНДСУпр,
		|	(ВЫБОР
		|		КОГДА ДД.КоличествоПоДокументу = ДД.Количество ИЛИ ДД.Количество = 0
		|			ТОГДА ДД.НДСУпр
		|		ИНАЧЕ ВЫРАЗИТЬ(ДД.КоличествоПоДокументу * (ДД.НДСУпр / ДД.Количество) КАК ЧИСЛО(31,2))
		|		КОНЕЦ) КАК НДСУпр,
		|
		|	НЕОПРЕДЕЛЕНО КАК ХозяйственнаяОперация,
		|	НЕОПРЕДЕЛЕНО КАК КорВидДеятельностиНДС,
		|	НЕОПРЕДЕЛЕНО КАК КорРазделУчета,
		|	НЕОПРЕДЕЛЕНО КАК КорАналитикаУчетаНоменклатуры,
		|	НЕОПРЕДЕЛЕНО КАК КорВидЗапасов,
		|	НЕОПРЕДЕЛЕНО КАК КорОрганизация,
		|	НЕОПРЕДЕЛЕНО КАК КорПартия,
		|	НЕОПРЕДЕЛЕНО КАК КорАналитикаФинансовогоУчета,
		|	НЕОПРЕДЕЛЕНО КАК Подразделение,
		|	НЕОПРЕДЕЛЕНО КАК СтатьяРасходовАктивов,
		|	НЕОПРЕДЕЛЕНО КАК АналитикаРасходов,
		|	НЕОПРЕДЕЛЕНО КАК АналитикаАктивов,
		|	НЕОПРЕДЕЛЕНО КАК КорСтатьяРасходов,
		|	НЕОПРЕДЕЛЕНО КАК КорАналитикаРасходов,
