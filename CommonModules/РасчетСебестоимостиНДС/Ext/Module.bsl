#Область ПрограммныйИнтерфейс

#Область ЭтапыРасчета

//++ Локализация

// Этап "ПодготовкаДанныхДляУчетаНДСиУСН"
//
// Параметры:
//	ПараметрыРасчета - Структура - параметры расчета себестоимости
//
Процедура ПодготовкаДанныхДляУчетаНДСиУСН(ПараметрыРасчета) Экспорт
	
	РасчетСебестоимостиПротоколРасчета.НачалоЭтапаРасчета(ПараметрыРасчета, "ПодготовкаДанныхДляУчетаНДСиУСН");
	
	// 1. Инициализация структуры данных для расчета
	//	- формирует структуру ПараметрыРасчета.РаспределениеПартий.
	РасчетСебестоимостиПрикладныеАлгоритмы.ИнициализироватьРаспределениеПартий(
		ПараметрыРасчета,
		ТаблицаДляРаспределенияПартийНДС(ПараметрыРасчета),
		ОписаниеЦепочекПартийНДС(ПараметрыРасчета),
		ОписаниеДвиженийПартийНДС(ПараметрыРасчета),
		ОписаниеНезаписываемыхПартийНДС(ПараметрыРасчета));
		
	// 2. Получение исходных данных для расчета
	// 	- формирует временную таблицу Данные.
	ПолучитьДанныеДляПартийНДС(ПараметрыРасчета);
	
	// 3. Получение цепочек из исходных данных
	// 	- формирует временные таблицы Источники и Приемники.
	РасчетСебестоимостиПрикладныеАлгоритмы.ПостроитьЦепочкиДвижений(ПараметрыРасчета);
	
	// 4. Заполнение партий в цепочках
	// 	- заполняет таблицу ПараметрыРасчета.РаспределениеПартий.РасчетныеПартии.
	РасчетСебестоимостиПрикладныеАлгоритмы.РассчитатьПартииПоЦепочкам(ПараметрыРасчета);
	
	// 5. Помещение данных в таблицу-приемник и очистка вспомогательных временных таблиц.
	//	- формирует временную таблицу ВТДетализацияПартийТоваровДляНДСиУСН
	РасчетСебестоимостиПрикладныеАлгоритмы.ЗавершитьРаспределениеПартий(ПараметрыРасчета);
	
КонецПроцедуры

//-- Локализация

// Этап "ПодготовкаДанныхДляУчетаНДСиУСН_ДопРасходы"
//
// Параметры:
//	ПараметрыРасчета - Структура - параметры расчета себестоимости
//
Процедура ПодготовкаДанныхДляУчетаНДСиУСН_ДопРасходы(ПараметрыРасчета) Экспорт
	
	РасчетСебестоимостиПротоколРасчета.НачалоЭтапаРасчета(ПараметрыРасчета, "ПодготовкаДанныхДляУчетаНДСиУСН_ДопРасходы");
	
	// 1. Инициализация структуры данных для расчета
	//	- формирует структуру ПараметрыРасчета.РаспределениеПартий.
	РасчетСебестоимостиПрикладныеАлгоритмы.ИнициализироватьРаспределениеПартий(
		ПараметрыРасчета,
		ТаблицаДляРаспределенияПартийНДС(ПараметрыРасчета),
		ОписаниеЦепочекПартийНДС(ПараметрыРасчета),
		ОписаниеДвиженийПартийНДС_ДопРасходы(ПараметрыРасчета),
		ОписаниеНезаписываемыхПартийНДС(ПараметрыРасчета));
		
	// 2. Получение исходных данных для расчета
	// 	- формирует временную таблицу Данные.
	ПолучитьДанныеДляПартийНДС_ДопРасходы(ПараметрыРасчета);

	//++ Локализация
	
	// 3. Получение цепочек из исходных данных
	// 	- формирует временные таблицы Источники и Приемники.
	РасчетСебестоимостиПрикладныеАлгоритмы.ПостроитьЦепочкиДвижений(ПараметрыРасчета);
	
	// 4. Заполнение партий в цепочках
	// 	- заполняет таблицу ПараметрыРасчета.РаспределениеПартий.РасчетныеПартии.
	РасчетСебестоимостиПрикладныеАлгоритмы.РассчитатьПартииПоЦепочкам(ПараметрыРасчета);
	
	//-- Локализация
	
	// 5. Помещение данных в таблицу-приемник и очистка вспомогательных временных таблиц.
	//	- формирует временную таблицу ВТДетализацияПартийТоваровДляНДСиУСН_ДопРасходы
	РасчетСебестоимостиПрикладныеАлгоритмы.ЗавершитьРаспределениеПартий(ПараметрыРасчета);
	
КонецПроцедуры

//++ Локализация

// Этап "ПодготовкаДанныхДляУчетаНДСиУСН_Постатейные"
//
// Параметры:
//	ПараметрыРасчета - Структура - параметры расчета себестоимости
//
Процедура ПодготовкаДанныхДляУчетаНДСиУСН_Постатейные(ПараметрыРасчета) Экспорт
	
	РасчетСебестоимостиПротоколРасчета.НачалоЭтапаРасчета(ПараметрыРасчета, "ПодготовкаДанныхДляУчетаНДСиУСН_Постатейные");
	
	// 1. Инициализация структуры данных для расчета
	//	- формирует структуру ПараметрыРасчета.РаспределениеПартий.
	РасчетСебестоимостиПрикладныеАлгоритмы.ИнициализироватьРаспределениеПартий(
		ПараметрыРасчета,
		ТаблицаДляРаспределенияПартийНДС(ПараметрыРасчета),
		ОписаниеЦепочекПартийНДС(ПараметрыРасчета),
		ОписаниеДвиженийПартийНДС_Постатейные(ПараметрыРасчета),
		ОписаниеНезаписываемыхПартийНДС(ПараметрыРасчета));
		
	// 2. Получение исходных данных для расчета
	// 	- формирует временную таблицу Данные.
	ПолучитьДанныеДляПартийНДС_Постатейные(ПараметрыРасчета);
	
	// 3. Получение цепочек из исходных данных
	// 	- формирует временные таблицы Источники и Приемники.
	РасчетСебестоимостиПрикладныеАлгоритмы.ПостроитьЦепочкиДвижений(ПараметрыРасчета);
	
	// 4. Заполнение партий в цепочках
	// 	- заполняет таблицу ПараметрыРасчета.РаспределениеПартий.РасчетныеПартии.
	РасчетСебестоимостиПрикладныеАлгоритмы.РассчитатьПартииПоЦепочкам(ПараметрыРасчета);
	
	// 5. Помещение данных в таблицу-приемник и очистка вспомогательных временных таблиц.
	// 	- формирует движения по регистру ДетализацияПартийТоваровДляНДСиУСН
	РасчетСебестоимостиПрикладныеАлгоритмы.ЗавершитьРаспределениеПартий(ПараметрыРасчета);
	
КонецПроцедуры

//-- Локализация

// Этап "РаспределениеПартийНДСФИФОСкользящая"
//
// Параметры:
//	ПараметрыРасчета - Структура - параметры расчета себестоимости
//
Процедура РаспределениеПартийНДСФИФОСкользящая(ПараметрыРасчета) Экспорт
	
	РасчетСебестоимостиПротоколРасчета.НачалоЭтапаРасчета(ПараметрыРасчета, "РаспределениеПартийНДСФИФОСкользящая");
	
	СуществующиеВТ = РасчетСебестоимостиПрикладныеАлгоритмы.ПолучитьПереченьСуществующихВременныхТаблиц(ПараметрыРасчета);
	
	// 1. Инициализация структуры данных этапа подготовки данных.
	РасчетСебестоимостиПрикладныеАлгоритмы.ИнициализироватьПодготовкуДанныхДляСледующихЭтапов(
		ПараметрыРасчета,
		"ПриходыТоваровНДС2_4, ВТКоэффициентыДопРасходов, ВТПолностьюВыбывшиеТовары, ПриходыТоваровНДС2_4_ДляРешенияСЛУ, ВТКорректировкаЦенОстатковНЗП, ПериодПредыдущегоРассчитанногоПериода");
		
	ИнициализироватьТаблицыДляДокументовВводаОстатков(ПараметрыРасчета);
	
	// 2. Формирование временных таблиц.
	РасчетСебестоимостиПрикладныеАлгоритмы.ПодготовитьДанныеДляСледующихЭтапов(
		ПараметрыРасчета,
		ТекстЗапросаПодготовкаДанныхРаспределенияНДС(ПараметрыРасчета));
		
	// 3. Завершаем этап подготовки данных. 
	РасчетСебестоимостиПрикладныеАлгоритмы.ЗавершитьПодготовкуДанныхДляСледующихЭтапов(ПараметрыРасчета);
	
	РаспределитьНДСПоСебестоимости(ПараметрыРасчета, "ПриходыТоваровНДС2_4_ДляРешенияСЛУ");
	
	// Уничтожим ненужные временные таблицы.
	НовыеВТ = РасчетСебестоимостиПрикладныеАлгоритмы.ПолучитьПереченьСуществующихВременныхТаблиц(
		ПараметрыРасчета,
		СуществующиеВТ + ", ПриходыТоваровНДС2_4, ВТКоэффициентыДопРасходов, ВТПолностьюВыбывшиеТовары, ПериодПредыдущегоРассчитанногоПериода");
	
	РасчетСебестоимостиПрикладныеАлгоритмы.УничтожитьВременныеТаблицы(ПараметрыРасчета, НовыеВТ);
	
	СформироватьСтоимостьПартийНДСНаКонецПериода(ПараметрыРасчета, 1);
	
КонецПроцедуры

// Этап "РаспределениеПартийНДСПоДопРасходам"
//
// Параметры:
//	ПараметрыРасчета - Структура - параметры расчета себестоимости
//
Процедура РаспределениеПартийНДСПоДопРасходам(ПараметрыРасчета) Экспорт
	
	РасчетСебестоимостиПротоколРасчета.НачалоЭтапаРасчета(ПараметрыРасчета, "РаспределениеПартийНДСПоДопРасходам");
	
	#Область РаспределениеДопРасходовПоБазе
	
	Если ЗначениеЗаполнено(ПараметрыРасчета) Тогда
		ЕстьТаблицаДопРасходов = РасчетСебестоимостиПрикладныеАлгоритмы.ВременнаяТаблицаСуществует(ПараметрыРасчета, "ВТДопРасходыДляРаспределения");
	Иначе
		ЕстьТаблицаДопРасходов = Ложь;
	КонецЕсли;
	
	// 1. Инициализация структуры данных этапа подготовки данных.
	РасчетСебестоимостиПрикладныеАлгоритмы.ИнициализироватьПодготовкуДанныхДляСледующихЭтапов(
		ПараметрыРасчета,
		"ДанныеДопРасходыДляРаспределения, БазаДопРасходыДляРаспределения,
		|ВТДопРасходыДляРаспределенияРасширенная"
			+ ?(ЕстьТаблицаДопРасходов, "", ", ВТДопРасходыДляРаспределения"));

	// 2. Формирование временных таблиц.
	РасчетСебестоимостиПрикладныеАлгоритмы.ПодготовитьДанныеДляСледующихЭтапов(
		ПараметрыРасчета,
		ТекстЗапросаДляРаспределениеПартийНДСПоДопРасходам(ПараметрыРасчета));
		
	// 3. Завершаем этап подготовки данных. 
	РасчетСебестоимостиПрикладныеАлгоритмы.ЗавершитьПодготовкуДанныхДляСледующихЭтапов(ПараметрыРасчета);
	
	// Распределим доп. расходы по базе методом уменьшаемого остатка
	СуществующиеВТ = РасчетСебестоимостиПрикладныеАлгоритмы.ПолучитьПереченьСуществующихВременныхТаблиц(ПараметрыРасчета);
	
	// Инициализируем распределение
	ПараметрыРаспределения = РасчетСебестоимостиУниверсальныеАлгоритмы.ИнициализироватьПараметрыРаспределенияМетодомУменьшаемогоОстатка(
		"ДанныеДопРасходыДляРаспределения",
		"БазаДопРасходыДляРаспределения",
		"Организация, Подразделение, НаправлениеДеятельности, СтатьяРасходовАктивов, АналитикаРасходов, РеглУчет, ЕстьСуммы");
	ПараметрыРаспределения.ВозможныОтрицательныеБазисы = Истина;
		
	РасчетСебестоимостиУниверсальныеАлгоритмы.ИнициализироватьЧисловыеПоляРаспределенияМетодомУменьшаемогоОстатка(
		ПараметрыРаспределения,
		"СтоимостьСНДС, СтоимостьБезНДС, СтоимостьБезНДСРегл, НДСРегл, СтоимостьБезНДСУпр, НДСУпр",
		"Знаменатель",
		"Знаменатель");
		
	РасчетСебестоимостиУниверсальныеАлгоритмы.ИнициализироватьПрочиеПоляРаспределенияМетодомУменьшаемогоОстатка(
		ПараметрыРаспределения,
		"ДокументПоступления, АналитикаУчетаПартийДокументаПоступления, СтатьяРасходовАктивов, АналитикаРасходов,
			|АналитикаСписанияНДС, Подразделение, КорВидДеятельностиНДС, РеглУчет, ЕстьСуммы
			|",
		"ЭтоСторно, Сторно, Период, ПериодПоступления, Регистратор, ВидДвижения, Организация, АналитикаУчетаНоменклатуры, ВидЗапасов,
			|КорАналитикаУчетаНоменклатуры, КорВидЗапасов, Партия, АналитикаУчетаПартий, ВидДеятельностиНДС, НаправлениеДеятельности,
			|НаВыбытие, ХозяйственнаяОперация, КорОрганизация, КорПартия, КорАналитикаУчетаПартий, КорНаправлениеДеятельности,
			|АналитикаАктивов, КорСтатьяРасходов, КорАналитикаРасходов, КорПодразделение,  СтатьяСписанияНДС, РазделУчета, АналитикаФинансовогоУчета, ИдентификаторФинЗаписи",
		, // НеВключатьПоляИсточника
		, // НеВключатьПоляБазы
		"ЗнаменательДляСортировки, ИдентификаторФинЗаписи" // ПоляСортировкиБазы
		);
		
	// Распределяем
	РасчетСебестоимостиПрикладныеАлгоритмы.РаспределитьМетодомУменьшаемогоОстаткаСЗамеромВремени(
		ПараметрыРасчета,
		ПараметрыРаспределения,
		"РаспределитьМетодомУменьшаемогоОстатка",
		"РаспределениеПартийНДСПоДопРасходам");
		
	РасчетСебестоимостиПрикладныеАлгоритмы.УничтожитьВременныеТаблицы(ПараметрыРасчета, "ДанныеДопРасходыДляРаспределения, БазаДопРасходыДляРаспределения");
	
	#КонецОбласти

	#Область ПодготовкаДанныхРаспределенияНДС
	
	Запрос = Новый Запрос;
	РасчетСебестоимостиПрикладныеАлгоритмы.ИнициализироватьСвойстваЗапроса(Запрос, ПараметрыРасчета);
	
	Запрос.УстановитьПараметр("ЭтоЛокализованнаяВерсия", ПараметрыРасчета.ЭтоЛокализованнаяВерсия);
	
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Т.Организация,
	|	Т.ВариантУчетаНДСПриИзмененииВидаДеятельности,
	|	Т.СтатьяРасходовНеНДС,
	|	Т.АналитикаРасходовНеНДС,
	|	Т.СтатьяРасходовЕНВД,
	|	Т.АналитикаРасходовЕНВД
	|ПОМЕСТИТЬ ВТНастройкиУчетаНДСПриИзмененииВидаДеятельности
	|ИЗ
	|	РегистрСведений.НастройкиУчетаНДС.СрезПоследних(&НачалоПериода, Организация В (&МассивОрганизаций)) КАК Т
	|ГДЕ
	|	Т.ВариантУчетаНДСПриИзмененииВидаДеятельности В
	|		(ЗНАЧЕНИЕ(Перечисление.ВариантыУчетаНДСПриИзмененииВидаДеятельностиНаНеоблагаемую.ВключатьВПрочиеРасходы),
	|		 ЗНАЧЕНИЕ(Перечисление.ВариантыУчетаНДСПриИзмененииВидаДеятельностиНаНеоблагаемую.ВключатьВСтоимостьИлиРасходыВЗависимостиОтПериода))
	|	И НЕ &ЭтоЛокализованнаяВерсия
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Т.Организация,
	|	Т.Подразделение,
	|	Т.НаправлениеДеятельности,
	|	Т.СтатьяРасходовАктивов,
	|	Т.АналитикаРасходов,
	|	Т.ДокументПоступления,
	|	Т.АналитикаУчетаПартийДокументаПоступления,
	|	Т.ЭтоСторно,
	|	Т.Сторно,
	|	Т.Период,
	|	Т.ПериодПоступления,
	|	Т.Регистратор,
	|	Т.ВидДвижения,
	|	Т.АналитикаУчетаНоменклатуры,
	|	Т.ВидЗапасов,
	|	Т.КорАналитикаУчетаНоменклатуры,
	|	Т.КорВидЗапасов,
	|	Т.Партия,
	|	Т.АналитикаУчетаПартий,
	|	Т.ВидДеятельностиНДС,
	|	Т.РазделУчета,
	|	Т.АналитикаФинансовогоУчета,
	|	Т.НаВыбытие,
	|	Т.ХозяйственнаяОперация,
	|	Т.КорВидДеятельностиНДС,
	|	Т.КорОрганизация,
	|	Т.КорПартия,
	|	Т.КорАналитикаУчетаПартий,
	|	Т.КорНаправлениеДеятельности,
	|	Т.АналитикаАктивов,
	|	Т.КорСтатьяРасходов,
	|	Т.КорАналитикаРасходов,
	|	Т.КорПодразделение,
	|	ВЫБОР
	|		КОГДА НастройкиНДС.ВариантУчетаНДСПриИзмененииВидаДеятельности ЕСТЬ NULL
	|			ТОГДА Т.СтатьяСписанияНДС
	|		КОГДА НастройкиНДС.ВариантУчетаНДСПриИзмененииВидаДеятельности = ЗНАЧЕНИЕ(Перечисление.ВариантыУчетаНДСПриИзмененииВидаДеятельностиНаНеоблагаемую.ВключатьВПрочиеРасходы)
	|			ТОГДА
	|				ВЫБОР
