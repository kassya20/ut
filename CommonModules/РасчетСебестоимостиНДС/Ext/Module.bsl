Процедура ДополнитьЭтапыСПодготовкойДанныхДляСледующихЭтапов(СписокЭтапов) Экспорт
	
	СписокЭтапов.Добавить("РаспределениеПартийНДСФИФОСкользящая");
	СписокЭтапов.Добавить("СформироватьСтоимостьПартийНДСНаКонецПериода");
	СписокЭтапов.Добавить("РаспределениеПартийНДСПоДопРасходам");
	СписокЭтапов.Добавить("ВключитьИсключитьНДСВСтоимостьСредняяЗаМесяц");
	СписокЭтапов.Добавить("ВключитьИсключитьНДСВСтоимостьСреднескользящая");
	СписокЭтапов.Добавить("ВключитьИсключитьНДСВСтоимостьСреднескользящая_СписаниеНаРасходы");
	
КонецПроцедуры

Процедура ТекстЗапросаДляРасчетаЭтапа(ИмяЭтапа, ПараметрыРасчета, ТекстЗапроса) Экспорт
	
	Если ИмяЭтапа = "ПодготовкаДанныхДляПартийПрочихРасходов" Тогда
		ТекстЗапроса = ТекстЗапросаДляПартийПрочихРасходов(ПараметрыРасчета);
		
	ИначеЕсли ИмяЭтапа = "РаспределениеПартийНДСФИФОСкользящая" Тогда
		ТекстЗапроса = ТекстЗапросаПодготовкаДанныхРаспределенияНДС(ПараметрыРасчета);
		
	ИначеЕсли ИмяЭтапа = "СформироватьСтоимостьПартийНДСНаКонецПериода" Тогда
		ТекстЗапроса = ТекстЗапросаВТОборотыСтоимостьПартийНДС(ПараметрыРасчета);
		
	ИначеЕсли ИмяЭтапа = "РаспределениеПартийНДСПоДопРасходам" Тогда
		ТекстЗапроса = ТекстЗапросаДляРаспределениеПартийНДСПоДопРасходам(ПараметрыРасчета);
		
	ИначеЕсли ИмяЭтапа = "РасчетОтклонениеВыпускаФИФОСкользящая" Тогда
		ТекстЗапроса = ТекстЗапросаКорректировкаОтклоненийВыпуска(ПараметрыРасчета);
		
	ИначеЕсли ИмяЭтапа = "ПодготовкаДанныхДляУчетаНДСиУСН_ДопРасходы" Тогда
		ТекстЗапроса = ТекстЗапросаДляПартийНДС_ДопРасходы(ПараметрыРасчета)
		
	//++ Локализация
	ИначеЕсли ИмяЭтапа = "ПодготовкаДанныхДляВключенияИсключенияНДСДопРасходовВСтоимость24" Тогда
		ТекстЗапроса = ТекстЗапросаДляВключенияИсключенияНДСДопРасходов(ПараметрыРасчета);
		
	ИначеЕсли ИмяЭтапа = "ПодготовкаДанныхДляВключенияИсключенияНДСДопРасходовВСтоимостьСреднескользящая"
	 ИЛИ ИмяЭтапа = "ВключитьИсключитьНДСВСтоимостьСреднескользящая_СписаниеНаРасходы" Тогда
		ТекстЗапроса = ТекстЗапросаДляВключенияИсключенияНДСДопРасходовСреднескользящая(ПараметрыРасчета);
		
	ИначеЕсли ИмяЭтапа = "ПодготовкаДанныхДляПрочихРасходов" Тогда
		ТекстЗапроса = ТекстЗапросаДляПрочихРасходов(ПараметрыРасчета);
	
	ИначеЕсли ИмяЭтапа = "ПодготовкаДанныхДляУчетаНДСиУСН" Тогда
		ТекстЗапроса = ТекстЗапросаДляПартийНДС();
	
	ИначеЕсли ИмяЭтапа = "ПодготовкаДанныхДляУчетаНДСиУСН_Постатейные" Тогда
		ТекстЗапроса = ТекстЗапросаДляПартийНДС_Постатейные()
			
	ИначеЕсли ИмяЭтапа = "ПодготовкаДанныхДляДетализацииПартийТоваровДляНДСиУСН" Тогда
		ТекстЗапроса = ТекстЗапросаДляДетализацииПартийТоваровДляНДСиУСН(ПараметрыРасчета);
	
	ИначеЕсли ИмяЭтапа = "РаспределениеПартийНДСПоПартиямПрочихРасходов" Тогда
		ТекстЗапроса = ТекстЗапросаДляРаспределениеПартийНДСПоПартиямПрочихРасходов(ПараметрыРасчета);
		
	ИначеЕсли ИмяЭтапа = "ПодготовкаДанныхДляПартийНДСКРаспределению" Тогда
		ТекстЗапроса =  ТекстЗапросаДляПартийНДСКРаспределению(ПараметрыРасчета);
		
	ИначеЕсли ИмяЭтапа = "ВключитьИсключитьНДСВСтоимостьСредняяЗаМесяц" Тогда
		ТекстЗапроса =  ТекстЗапросаВключитьИсключитьНДСВСтоимость();
		
	ИначеЕсли ИмяЭтапа = "ВключитьИсключитьНДСВСтоимостьСреднескользящая" Тогда
		ТекстЗапроса =  ТекстЗапросаВключитьИсключитьНДСВСтоимостьСреднескользящая();
		
	//-- Локализация
		
	КонецЕсли;
	
КонецПроцедуры

