// Формирование строки подключения к сервису.
// 
// Параметры:
//  УчетнаяЗапись - СправочникСсылка.УчетныеЗаписиЭлектронныхТорговыхПлощадок - Учетная запись ЭТП
//  РазделУчета - строка - "Поставщики" или "Покупатели"
// 
// Возвращаемое значение:
//  Строка - Строка подключения к сервису этп
Функция СтрокаПодключенияКСервису(УчетнаяЗапись, РазделУчета) Экспорт

	РеквизитыУЗ = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(УчетнаяЗапись, "Сервер");
	
	Параметры = Новый Структура;
	Параметры.Вставить("Сервер", РеквизитыУЗ.Сервер);
	
	ДополнительныеПараметры = Новый Структура;
	ДополнительныеПараметры.Вставить("ВидЭТП", ПолучитьВидЭТПИлиРазделУчета(РазделУчета, Истина));
	ДополнительныеПараметры.Вставить("РазделУчета", РазделУчета);
	Параметры.Вставить("ДополнительныеПараметры", ДополнительныеПараметры);
	
	ДанныеДляПодключения = ИнтеграцияСЭлектроннымиТорговымиПлощадками.ПараметрыРаботыССервисомАвторизации(Параметры);

	СтрокаПодключения = ДанныеДляПодключения.Протокол + "://" + ДанныеДляПодключения.Сервер;
	Если ДанныеДляПодключения.Порт <> "" Тогда
	 	СтрокаПодключения = СтрокаПодключения + ":"+ДанныеДляПодключения.Порт;
	КонецЕсли;

	Возврат СтрокаПодключения;
	
КонецФункции

// Проверить связь с ЭТП Бидзаар в фоне.
// 
// Параметры:
//  ПараметрыОперации - Структура - Параметры операции
// 
// Возвращаемое значение:
//  Неопределено, Структура - см. ДлительныеОперации.ВыполнитьВФоне
//
Функция ПроверитьСвязьСЭТПБидзаарВФоне(ПараметрыОперации) Экспорт

	Если ПараметрыОперации.ВидЭТП <> Перечисления.ВидыЭлектронныхТорговыхПлощадок.БидзаарПокупатели
		И ПараметрыОперации.ВидЭТП <> Перечисления.ВидыЭлектронныхТорговыхПлощадок.БидзаарПоставщики Тогда
			Возврат Неопределено;
	КонецЕсли;
		
	Если Не ЗначениеЗаполнено(ПараметрыОперации.УчетнаяЗапись) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Если ПараметрыОперации.ВидЭТП = Перечисления.ВидыЭлектронныхТорговыхПлощадок.БидзаарПокупатели Тогда
		ИспользоватьИнтеграцию = ПолучитьФункциональнуюОпцию("ИспользоватьИнтеграциюСЭТПБидзаарДляПокупателей");
		ИмяПроцедуры = "ИнтеграцияСЭлектроннымиТорговымиПлощадками.ПроверитьСвязьСЭТПБидзаарДляПокупателей";
	ИначеЕсли ПараметрыОперации.ВидЭТП = Перечисления.ВидыЭлектронныхТорговыхПлощадок.БидзаарПоставщики Тогда
		ИспользоватьИнтеграцию = ПолучитьФункциональнуюОпцию("ИспользоватьИнтеграциюСЭТПБидзаарДляПоставщиков");
		ИмяПроцедуры = "ИнтеграцияСЭлектроннымиТорговымиПлощадками.ПроверитьСвязьСЭТПБидзаарДляПоставщиков";
	КонецЕсли;

	Если Не ИспользоватьИнтеграцию Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияВФоне(Новый УникальныйИдентификатор);
	ПараметрыВыполнения.НаименованиеФоновогоЗадания = НСтр("ru = 'Проверка связи с ЭТП Бидзаар'");
	ПараметрыВыполнения.ОжидатьЗавершение = 0;
	ПараметрыВыполнения.ЗапуститьВФоне = Истина;

	Возврат ДлительныеОперации.ВыполнитьВФоне(ИмяПроцедуры, ПараметрыОперации, ПараметрыВыполнения);

КонецФункции

