// 
// Возвращаемое значение:
//  Булево - Доступно право настройки авторизации бидзаар
Функция ДоступноПравоНастройкиАвторизацииБидзаар() Экспорт
	Возврат ИнтеграцияСЭлектроннымиТорговымиПлощадками.ДоступноПравоНастройкиАвторизацииБидзаар();
КонецФункции

// Проверяет, поддерживается ли валюта (ссылка на справочник) сервисом "Бидзаар".
//
// Параметры:
//  Валюта - СправочникСсылка.Валюты - Ссылка на проверяемую валюту.
//
// Возвращаемое значение:
//  Булево - Истина, если валюта поддерживается сервисом;
//           Ложь в противном случае.
//
Функция ПроверитьВалютуБидзаар(Валюта) Экспорт
	ДанныеВалюты = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Валюта, "Наименование, Код");
	//Проверка валидности буквенного кода валюты в сервисе Бидзаар
	Если Не ИнтеграцияСЭлектроннымиТорговымиПлощадками.ПроверитьБуквенныйКодВалютыБидзаар(ДанныеВалюты.Наименование) Тогда
		//Получение буквенного кода валюты из классификатора по цифровому коду
		ДанныеВалютыПоКлассификатору = ИнтеграцияСЭлектроннымиТорговымиПлощадками.ДанныеВалютыПоКлассификатору(ДанныеВалюты.Код);
		Если ДанныеВалютыПоКлассификатору = Неопределено
			Или Не ИнтеграцияСЭлектроннымиТорговымиПлощадками.ПроверитьБуквенныйКодВалютыБидзаар(ДанныеВалютыПоКлассификатору.КодВалютыБуквенный) Тогда
			
			Возврат Ложь;
		КонецЕсли;
	КонецЕсли;
	Возврат Истина;
КонецФункции

// Возвращает данные для открытия результата опроса сервиса "Бидзаар" для документа.
//
// Параметры:
//  Документ - ДокументСсылка.ЗапросКоммерческихПредложенийПоставщиков - Ссылка на документ.
//
// Возвращаемое значение:
//  Структура:
//   * ЭтоБидзаар - Булево - признак указывает на публикацию документа в сервис "Бидзаар"
//   * ПроведениеОпроса - ДокументСсылка.НазначениеОпросов - ссылка на документ опроса
//   * ОписаниеВариантаОтчета - Структура - см. ВариантОтчетаРезультатОпроса()
Функция ПолучитьДанныеОткрытияРезультатОпросаБизаар(Документ) Экспорт
	
	ДанныеДокумента = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Документ,
		"ПроведениеОпроса, ЗапрашиватьПредложенияПоставщиков");
	
	ЭтоБидзаар = ДанныеДокумента.ЗапрашиватьПредложенияПоставщиков =
		КоммерческиеПредложенияДокументыКлиентСервер.СпособРазмещенияБидзаар();
	
	Результат = Новый Структура;
	Результат.Вставить("ЭтоБидзаар", ЭтоБидзаар);
	Результат.Вставить("ПроведениеОпроса", ДанныеДокумента.ПроведениеОпроса);
	Результат.Вставить("ОписаниеВариантаОтчета", ВариантОтчетаРезультатОпроса());
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Возвращает вариант отчета для макета результата опроса Бидзаар и текст ошибки
//
// Возвращаемое значение:
//   Структура:
//     * ВариантОтчета - см. ВариантыОтчетов.ВариантОтчета()
//     * ТекстОшибки - Строка - текст ошибки поиска варианта отчета
Функция ВариантОтчетаРезультатОпроса()
	
	Результат = Новый Структура("ВариантОтчета, ТекстОшибки", Неопределено, "");
	
	Отчет = Неопределено;
	ДоступныеОтчеты = ВариантыОтчетов.ОтчетыТекущегоПользователя();
	Для Каждого ДоступныйОтчет Из ДоступныеОтчеты Цикл
		Если ДоступныйОтчет.ПолноеИмя = Метаданные.Отчеты.АналитическийОтчетПоАнкетированию.ПолноеИмя() Тогда
			Отчет = ДоступныйОтчет.Ссылка;
		КонецЕсли;
	КонецЦикла;
	
	Если Отчет = Неопределено Тогда
		Результат.ТекстОшибки = НСтр("ru = 'Вариант отчета не найден'");
	Иначе
		Результат.ВариантОтчета = ВариантыОтчетов.ВариантОтчета(Отчет, Метаданные.Документы.ЗапросКоммерческихПредложенийПоставщиков.Макеты.РезультатОпросаБидзаар.Имя);
		Если Результат.ВариантОтчета = Неопределено Тогда
			Результат.ТекстОшибки = НСтр("ru = 'Вариант отчета не найден'");
		КонецЕсли;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти