#Область ПараметрыСканирования

// Включает поддержку алкогольной продукции и заполняет параметры сканирования с учетом ее специфики.
// 
// Параметры:
//  ПараметрыСканирования - (См. ПараметрыСканирования).
//  Контекст - Неопределено, ФормаКлиентскогоПриложения, ДокументСсылка - Контекст
//  ВидыПродукции - Массив Из СправочникСсылка.ВидыПродукцииИС - Вид продукции, по которому будут инициализированы параметры сканирования.
//  ФормаВыбора - ФормаКлиентскогоПриложения - форма выбора.
Процедура ЗаполнитьПараметрыСканирования(ПараметрыСканирования, Контекст, ВидыПродукции, ФормаВыбора) Экспорт
	
	ВидыПродукцииЕГАИС = КонструкторИСОбщегоНазначенияКлиентСервер.ВидыПродукцииЕГАИС();
	Если ЗначениеЗаполнено(ВидыПродукции) Тогда
		ВидыПродукцииЕГАИС = ОбщегоНазначенияИСКлиентСервер.ПересечениеМассивов(ВидыПродукцииЕГАИС, ВидыПродукции);
	КонецЕсли;

	Если ВидыПродукцииЕГАИС.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	Если Контекст = Неопределено Тогда
		
		ВключитьПоддержкуАлкогольнойПродукции(ПараметрыСканирования, ВидыПродукцииЕГАИС);
		Возврат;
		
	КонецЕсли;
	
	ЗаполнитьРасширенныеПараметрыСканированияПоДокументам(ПараметрыСканирования, Контекст, ВидыПродукцииЕГАИС, ФормаВыбора);
	
КонецПроцедуры

//Дополняет свойства параметров сканирования необходимых для работы с алкогольной продукцией.
//
//Параметры:
//   ПараметрыСканирования - (См. ШтрихкодированиеОбщегоНазначенияИСКлиент.ПараметрыСканирования).
//   Контекст - Произвольный - источник данных,
//   ФормаВыбора - Неопределено, ФормаКлиентскогоПриложения - альтернативный источник данных.
//
Процедура ЗаполнитьБазовыеПараметрыСканирования(ПараметрыСканирования, Контекст, ФормаВыбора = Неопределено) Экспорт
	
	Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(Контекст, "ОрганизацияЕГАИС")
		И ЗначениеЗаполнено(Контекст.ОрганизацияЕГАИС) Тогда
		ПараметрыСканирования.ОрганизацияЕГАИС = Контекст.ОрганизацияЕГАИС;
	КонецЕсли;
	
	Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(Контекст, "ДанныеВыбораПоМаркируемойПродукции") Тогда
		ПараметрыСканирования.ИспользуютсяДанныеВыбораПоМаркируемойПродукции = Истина;
		ПараметрыСканирования.ДанныеВыбораПоМаркируемойПродукции = Контекст.ДанныеВыбораПоМаркируемойПродукции;
	КонецЕсли;
	
