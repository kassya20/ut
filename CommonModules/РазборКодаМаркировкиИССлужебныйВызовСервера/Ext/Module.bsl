#Область НастройкиРазбораКодаМаркировки

Функция НастройкиРазбораКодаМаркировки(ВидыПродукции = Неопределено, ТолькоУчитываемыеВидыПродукции = Истина) Экспорт
	Возврат РазборКодаМаркировкиИССлужебный.ОбщиеНастройкиРазбораКодаМаркировки(Ложь, ВидыПродукции, ТолькоУчитываемыеВидыПродукции);
КонецФункции

// Рассчитывает хеш видов продукции
//
// Параметры:
//   Значения - Неопределено, СправочникСсылка.ВидыПродукцииИС, Массив из СправочникСсылка.ВидыПродукцииИС - виды продукции
// Возвращаемое значение:
//    Строка - Хеш элементов
//
Функция ХешВидовПродукции(Значения) Экспорт
	
	Список = Новый СписокЗначений;
	
	Если ТипЗнч(Значения) = Тип("СправочникСсылка.ВидыПродукцииИС") Тогда
		Если Не Значения.Пустая() Тогда
			Возврат Строка(Значения.УникальныйИдентификатор());
		КонецЕсли;
	ИначеЕсли ТипЗнч(Значения) = Тип("Массив") Тогда
		Для Каждого Значение Из Значения Цикл
			Если ТипЗнч(Значение) = Тип("СправочникСсылка.ВидыПродукцииИС") И Не Значение.Пустая() Тогда
				Список.Добавить(Значение);
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
	КоличествоЭлементов = Список.Количество();
	Если КоличествоЭлементов > 0 Тогда
		
		Если КоличествоЭлементов > 1 Тогда
			Список.СортироватьПоЗначению();
		КонецЕсли;
		
		Результат = ОбщегоНазначенияИС.ХэшСуммаСтроки(ЗначениеВСтрокуВнутр(Список.ВыгрузитьЗначения()));
	
	Иначе
		Результат = "";
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

