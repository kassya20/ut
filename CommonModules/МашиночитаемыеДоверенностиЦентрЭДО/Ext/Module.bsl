// @strict-types

#Область СлужебныйПрограммныйИнтерфейс

// Параметры:
//  ДанныеФайлаМЧД - Строка - двоичные данные в формате base64.
// 
// Возвращаемое значение:
//  Структура:
//  * Идентификатор - Строка
//  * Ошибки - Неопределено,Массив из см. ЦентрЭДО.НоваяОшибкаВФорматеСервиса
Функция СоздатьЧерновикДоверенности(ДанныеФайлаМЧД) Экспорт
	
	Результат = Новый Структура;
	Результат.Вставить("Идентификатор", "");
	Результат.Вставить("Ошибки", Неопределено);
	
	ДоверенностьОбъект = Справочники.МЧД003.СоздатьЭлемент();
	
	ДвоичныеДанныеФайлаМЧД =  Base64Значение(ДанныеФайлаМЧД);
	
	ДоверенностьОбъект.ЗаполнитьПоДаннымФайла(ДвоичныеДанныеФайлаМЧД);
	
	ДоверенностьОбъект.Записать();
	
	Результат.Идентификатор = ЦентрЭДО.ИдентификаторОбъекта(ДоверенностьОбъект.Ссылка);
	
	Возврат Результат;
	
КонецФункции

// Параметры:
//  ИдентификаторДоверенности - Строка
//  ДанныеФайлаМЧД - Строка - двоичные данные в формате base64.
// 
// Возвращаемое значение:
//  Структура:
//  * Успех - Булево
//  * Ошибки - Неопределено,Массив из См. ЦентрЭДО.НоваяОшибкаВФорматеСервиса
Функция ОбновитьЧерновикДоверенности(ИдентификаторДоверенности, ДанныеФайлаМЧД) Экспорт
	
	Результат = Новый Структура;
	Результат.Вставить("Успех", Ложь);
	Результат.Вставить("Ошибки", Неопределено);
	
	Доверенность = ДоверенностьПоИдентификатору(ИдентификаторДоверенности);
	
	ДоверенностьОбъект = Доверенность.ПолучитьОбъект();
	
	ДвоичныеДанныеФайлаМЧД =  Base64Значение(ДанныеФайлаМЧД);
	
	ДоверенностьОбъект.ЗаполнитьПоДаннымФайла(ДвоичныеДанныеФайлаМЧД);
	
	ДоверенностьОбъект.Записать();
	
	Результат.Успех = Истина;
	
	Возврат Результат;
	
КонецФункции

// Параметры:
//  ИдентификаторДоверенности - Строка
//  ОтпечаткиСертификатов - Массив из Строка
// 
// Возвращаемое значение:
//  Структура:
//  * Ошибки - Неопределено,Массив из см. ЦентрЭДО.НоваяОшибкаВФорматеСервиса
//  * ДанныеДляПодписания - Неопределено,Структура:
//    ** ОтпечаткиСертификатов - Массив из Строка
//    ** Данные - Строка - ДвоичныеДанные в формате base64.
Функция ПодготовитьДанныеДляПодписанияДоверенности(ИдентификаторДоверенности, ОтпечаткиСертификатов) Экспорт
	
	КонтекстДиагностики = ОбработкаНеисправностейБЭД.НовыйКонтекстДиагностики();
	
	Доверенность = ДоверенностьПоИдентификатору(ИдентификаторДоверенности);
	
	Доверенности = ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(Доверенность);
	
	РезультатыПолученияОтпечатков = РезультатыПолученияОтпечатков(ОтпечаткиСертификатов);
	
	ДанныеДляПодписания = МашиночитаемыеДоверенности.ДанныеДляПодписания(
		Доверенности, РезультатыПолученияОтпечатков, Истина, Ложь, КонтекстДиагностики);
	
	Возврат РезультатПодготовкиДанныхДляПодписанияВФорматеСервиса(ДанныеДляПодписания, КонтекстДиагностики);
	
КонецФункции

// Параметры:
//  ИдентификаторДоверенности - Строка
//  Подпись - Строка - данные подписи в формате base64.
// 
// Возвращаемое значение:
//  См. РезультатДобавленияПодписиВФорматеСервиса
Функция ДобавитьПодписьДоверенности(ИдентификаторДоверенности, Подпись) Экспорт
	
	Доверенность = ДоверенностьПоИдентификатору(ИдентификаторДоверенности);
	
	СвойстваПодписи = ЭлектроннаяПодписьКлиентСервер.НовыеСвойстваПодписи();
	СвойстваПодписи.Подпись = Base64Значение(Подпись);
	
	КонтекстДиагностики = ОбработкаНеисправностейБЭД.НовыйКонтекстДиагностики();
	
	РезультатДобавленияПодписи = МашиночитаемыеДоверенности.ДобавитьПодпись(
		Доверенность, СвойстваПодписи, КонтекстДиагностики);
	
	Возврат РезультатДобавленияПодписиВФорматеСервиса(РезультатДобавленияПодписи, КонтекстДиагностики);
	
КонецФункции

// Параметры:
//  ИдентификаторДоверенности - Строка
// 
// Возвращаемое значение:
//  Структура:
//  * Ошибки - Неопределено,Массив из см. ЦентрЭДО.НоваяОшибкаВФорматеСервиса
//  * ИдентификаторТранзакции - Строка
Функция ЗарегистрироватьДоверенностьВРеестреФНС(ИдентификаторДоверенности) Экспорт
	
	Доверенность = ДоверенностьПоИдентификатору(ИдентификаторДоверенности);
	
	РезультатРегистрации = МашиночитаемыеДоверенности.ОтправитьНаРегистрацию(Доверенность);
	
	Возврат РезультатРегистрацииВРеестреФНСВФорматеСервиса(РезультатРегистрации);
	
КонецФункции

// Возвращает статусы доверенности.
//
// Параметры:
//  НомерДоверенности - Строка
//  ИННДоверителя - Строка
// 
// Возвращаемое значение:
//  - Неопределено
//  - Структура:
//  * Подписана - Булево
//  * Верна - Булево
//  * Отозвана - Булево
//  * ДатаОтзыва - Дата
//  * СтатусВРеестреФНС - Неопределено
//                      - Строка
Функция СтатусыДоверенности(НомерДоверенности, ИННДоверителя) Экспорт
	
	РеквизитыСостояния = НовыеСтатусыДоверенности();
	
	Доверенность = ДоверенностьПоДоверителю(НомерДоверенности, ИННДоверителя);
	
	РеквизитыДоверенности = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Доверенность,
		"Подписана, Верна, Отозвана, ДатаОтзыва, СтатусВРеестреФНС");
	
	ЗаполнитьЗначенияСвойств(РеквизитыСостояния, РеквизитыДоверенности,,"СтатусВРеестреФНС");
	
	Если ЗначениеЗаполнено(РеквизитыДоверенности.СтатусВРеестреФНС) Тогда
		РеквизитыСостояния.СтатусВРеестреФНС = ОбщегоНазначения.ИмяЗначенияПеречисления(
			РеквизитыДоверенности.СтатусВРеестреФНС);
	КонецЕсли;
	
	Возврат РеквизитыСостояния;
	
КонецФункции

// Параметры:
//  ИдентификаторДоверенности - Строка
// 
// Возвращаемое значение:
//  Структура:
//  * Верна - Булево
//  * Причина - Строка
//  * Ошибки - Неопределено,Массив из см. ЦентрЭДО.НоваяОшибкаВФорматеСервиса
Функция ПроверитьДоверенность(ИдентификаторДоверенности) Экспорт
	
	КонтекстДиагностики = ОбработкаНеисправностейБЭД.НовыйКонтекстДиагностики();
	
	Доверенность = ДоверенностьПоИдентификатору(ИдентификаторДоверенности);
	
	ДанныеФайлаДоверенностиИПодписи = МашиночитаемыеДоверенности.ДанныеФайлаДоверенностиИПодписи(Доверенность);
	
	ДанныеДляПроверки = МашиночитаемыеДоверенностиКлиентСервер.НовыеДанныеДляПроверкиМЧД();
	ДанныеДляПроверки.ДанныеДоверенности = ДанныеФайлаДоверенностиИПодписи.ДанныеФайла;
	ДанныеДляПроверки.ДанныеПодписи = ДанныеФайлаДоверенностиИПодписи.ДанныеПодписи;
	
	РезультатПроверки = МашиночитаемыеДоверенности.ПроверитьДоверенность(ДанныеДляПроверки, КонтекстДиагностики);
	
	Возврат РезультатПроверкиДоверенностиВФорматеСервиса(РезультатПроверки, КонтекстДиагностики);
	
КонецФункции

// Параметры:
//  ИдентификаторДоверенности - Строка
// 
// Возвращаемое значение:
//  Структура:
//  * Ошибка - Неопределено,Строка
//  * Статус - Неопределено,Строка
//  * ДатаОбновления - см. ОбщегоНазначенияБЭД.ДатаВФорматеISO
//  * ДатаОтзыва - см. ОбщегоНазначенияБЭД.ДатаВФорматеISO
Функция ОбновитьСтатусДоверенности(ИдентификаторДоверенности) Экспорт
	
	Доверенность = ДоверенностьПоИдентификатору(ИдентификаторДоверенности);
	
	РезультатОбновления = МашиночитаемыеДоверенности.ОбновитьСтатусМЧДИзРеестраФНС(Доверенность);
	
	Возврат РезультатОбновленияСтатусаДоверенностиВФорматеСервиса(РезультатОбновления);
	
КонецФункции

// Возвращает визуализацию доверенности.
// 
// Параметры:
//  НомерДоверенности - Строка
//  ИННДоверителя - Строка
// 
// Возвращаемое значение:
//  - ТабличныйДокумент
Функция ВизуализацияДоверенности(НомерДоверенности, ИННДоверителя) Экспорт
	
	Доверенность = ДоверенностьПоДоверителю(НомерДоверенности, ИННДоверителя);
	
	ДанныеФайлаДоверенностиИПодписи = МашиночитаемыеДоверенности.ДанныеФайлаДоверенностиИПодписи(Доверенность);
	
	РезультатФормирования = МашиночитаемыеДоверенности.ТабличныйДокументМЧД(ДанныеФайлаДоверенностиИПодписи.ДанныеФайла);
	Если РезультатФормирования <> Неопределено Тогда
		Визуализация = РезультатФормирования.ПредставлениеДокумента;
	КонецЕсли;
	
	Поток = Новый ПотокВПамяти;
	Визуализация.Записать(Поток);
	ДвоичныеДанные = Поток.ЗакрытьИПолучитьДвоичныеДанные();
	
	ВизуализацияВФорматеСервиса = Base64Строка(ДвоичныеДанные);
	
	Возврат ВизуализацияВФорматеСервиса;
	
КонецФункции

// Параметры:
//  ИдентификаторДоверенности - Строка
//  ОтпечаткиСертификатов - Массив из Строка
// 
// Возвращаемое значение:
//  Структура:
//  * Ошибки - Неопределено,Массив из см. ЦентрЭДО.НоваяОшибкаВФорматеСервиса
//  * ДанныеДляПодписания - Неопределено,Структура:
//    ** ОтпечаткиСертификатов - Массив из Строка
//    ** Данные - Строка - ДвоичныеДанные в формате base64.
Функция ПодготовитьДанныеДляПодписанияЗаявленияНаОтменуДоверенности(ИдентификаторДоверенности, ОтпечаткиСертификатов) Экспорт
	
	КонтекстДиагностики = ОбработкаНеисправностейБЭД.НовыйКонтекстДиагностики();
	
	Доверенность = ДоверенностьПоИдентификатору(ИдентификаторДоверенности);
	
	Доверенности = ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(Доверенность);
	
	РезультатыПолученияОтпечатков = РезультатыПолученияОтпечатков(ОтпечаткиСертификатов);
	
	ДанныеДляПодписания = МашиночитаемыеДоверенности.ДанныеДляПодписания(
		Доверенности, РезультатыПолученияОтпечатков, Ложь, Истина, КонтекстДиагностики);
	
	Возврат РезультатПодготовкиДанныхДляПодписанияВФорматеСервиса(ДанныеДляПодписания, КонтекстДиагностики);
	
КонецФункции

// Параметры:
//  ИдентификаторДоверенности - Строка
//  Подпись - Строка - данные подписи в формате base64.
// 
// Возвращаемое значение:
//  Структура:
//  * Добавлена - Булево
//  * Ошибки - Неопределено,Массив из см. ЦентрЭДО.НоваяОшибкаВФорматеСервиса
Функция ДобавитьПодписьЗаявленияНаОтменуДоверенности(ИдентификаторДоверенности, Подпись) Экспорт
	
	КонтекстДиагностики = ОбработкаНеисправностейБЭД.НовыйКонтекстДиагностики();
	
	Доверенность = ДоверенностьПоИдентификатору(ИдентификаторДоверенности);
	
	СвойстваПодписи = ЭлектроннаяПодписьКлиентСервер.НовыеСвойстваПодписи();
	СвойстваПодписи.Подпись = Base64Значение(Подпись);
	
	КонтекстДиагностики = ОбработкаНеисправностейБЭД.НовыйКонтекстДиагностики();
	
	РезультатДобавленияПодписи = МашиночитаемыеДоверенности.ДобавитьПодписьЗаявленияНаОтмену(
		Доверенность, СвойстваПодписи, КонтекстДиагностики);
	
	Возврат РезультатДобавленияПодписиЗаявленияНаОтменуВФорматеСервиса(РезультатДобавленияПодписи, КонтекстДиагностики);
	
КонецФункции

// Параметры:
//  ИдентификаторДоверенности - Строка
// 
// Возвращаемое значение:
//  Структура:
//  * Ошибки - Неопределено,Массив из см. ЦентрЭДО.НоваяОшибкаВФорматеСервиса
//  * ИдентификаторТранзакции - Строка
Функция ОтправитьЗаявлениеНаОтменуДоверенности(ИдентификаторДоверенности) Экспорт
	
	КонтекстДиагностики = ОбработкаНеисправностейБЭД.НовыйКонтекстДиагностики();
	
	Доверенность = ДоверенностьПоИдентификатору(ИдентификаторДоверенности);
	
	РезультатОтправки = МашиночитаемыеДоверенности.ОтправитьЗаявлениеНаОтмену(Доверенность, КонтекстДиагностики);
	
	Возврат РезультатОтправкиЗаявленияНаОтменуВФорматеСервиса(РезультатОтправки, КонтекстДиагностики);
	
КонецФункции

// Параметры:
//  ИдентификаторДоверенности - Строка
//  Значение - Булево
// 
// Возвращаемое значение:
//  Структура:
//  * Успех - Булево
//  * Ошибки - Неопределено,Массив из см. ЦентрЭДО.НоваяОшибкаВФорматеСервиса
Функция УстановитьПометкуДоверенностьВерна(ИдентификаторДоверенности, Значение) Экспорт
	
	Доверенность = ДоверенностьПоИдентификатору(ИдентификаторДоверенности);
	
	РезультатУстановкиПометки = МашиночитаемыеДоверенности.УстановитьПометкуВерна(Доверенность, Значение);
	
	Возврат РезультатУстановкиПометкиДоверенностьВерна(РезультатУстановкиПометки);
	
КонецФункции

// Параметры:
//  ИдентификаторДоверенности - Строка
//  Значение - Булево
//  ДатаОтзываВФорматеISO - см. ОбщегоНазначенияБЭД.ДатаВФорматеISO
// 
// Возвращаемое значение:
//  Структура:
//  * Успех - Булево
//  * Ошибки - Неопределено,Массив из см. ЦентрЭДО.НоваяОшибкаВФорматеСервиса
Функция УстановитьПометкуДоверенностьОтозвана(ИдентификаторДоверенности, Значение, ДатаОтзываВФорматеISO) Экспорт
	
	Доверенность = ДоверенностьПоИдентификатору(ИдентификаторДоверенности);
	
	ДатаОтзыва = ОбщегоНазначенияБЭД.ДатаИзФорматаISO(ДатаОтзываВФорматеISO);
	
	РезультатУстановкиПометки = МашиночитаемыеДоверенности.УстановитьПометкуОтозвана(Доверенность, Значение, ДатаОтзыва);
	
	Возврат РезультатУстановкиПометкиДоверенностьОтозвана(РезультатУстановкиПометки);
	
КонецФункции

// Параметры:
//  МеткаВремени - Число
// 
// Возвращаемое значение:
//  Структура:
//  * ЭтоПоследний - Булево
//  * НаборДанных - см. ДанныеСинхронизацииСтатусовДоверенностей
Функция ПорцияДанныхСинхронизацииСтатусовДоверенностейПоМеткеВремени(МеткаВремени) Экспорт
	
	ПорцияДанных = Новый Структура;
	ПорцияДанных.Вставить("ЭтоПоследний", Истина);
	ПорцияДанных.Вставить("НаборДанных", Новый Массив);
	
	Если ЦентрЭДО.АвторизованСлужебныйПользователь() Тогда
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;
	
	МеткаВремениПоИдентификаторуЭДО = Новый Структура("МеткаВремени, ИдентификаторЭДО", МеткаВремени, "");
	МеткиВремениПоИдентификаторамЭДО = ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(МеткаВремениПоИдентификаторуЭДО);
	Порция = 1000;
	
	Выборка = МеткиВремениДанныхЭДО.ВыборкаИдентификаторовДанныхПоМеткамВремени(
		Перечисления.ТипыСинхронизацииСЦентромЭДО.СтатусыДоверенностей, МеткиВремениПоИдентификаторамЭДО, Порция);
	
	НаборДанных = ДанныеСинхронизацииСтатусовДоверенностейПоВыборкеМетокВремени(Выборка);
	
	ПорцияДанных.ЭтоПоследний = НаборДанных.Количество() < Порция;
	ПорцияДанных.НаборДанных = НаборДанных;
	
	Возврат ПорцияДанных;
	
КонецФункции

// Параметры:
//  ИдентификаторыДоверенностей - Массив из Строка
// 
// Возвращаемое значение:
//  Массив из см. НовыеДанныеСинхронизации
Функция ДанныеСинхронизацииСтатусовДоверенностей(ИдентификаторыДоверенностей) Экспорт
	
	Выборка = МеткиВремениДанныхЭДО.ВыбратьМеткиВремениОбъектов(
		"", Перечисления.ТипыСинхронизацииСЦентромЭДО.СтатусыДоверенностей, ИдентификаторыДоверенностей);
	
	НаборДанных = ДанныеСинхронизацииСтатусовДоверенностейПоВыборкеМетокВремени(Выборка);
	
	Возврат НаборДанных;
	
КонецФункции

// Параметры:
//  ИдентификаторДоверенности - Строка
// 
// Возвращаемое значение:
//  Структура:
//  * Ошибка - Неопределено,Строка
//  * Данные - Неопределено,Строка - двоичные данные в формате base64.
//  * Статус - Неопределено,Структура: см. СтатусДоверенности
Функция ПолучитьДанныеДоверенности(ИдентификаторДоверенности) Экспорт
	
	Результат = Новый Структура;
	Результат.Вставить("Ошибка", Неопределено);
	Результат.Вставить("Данные", Неопределено);
	Результат.Вставить("Статус", Неопределено);
	
	Доверенность = ДоверенностьПоИдентификатору(ИдентификаторДоверенности);
	
	РезультатВыгрузки = МашиночитаемыеДоверенности.ВыгрузитьДанныеДоверенности(Доверенность);
	
	Если РезультатВыгрузки.Ошибка Тогда
		Результат.Ошибка = РезультатВыгрузки.ТекстОшибки;
		Возврат Результат;
	КонецЕсли;
	
	Результат.Данные = Base64Строка(РезультатВыгрузки.ОписаниеФайла.ДвоичныеДанные);
	Результат.Статус = СтатусДоверенности(Доверенность);
	
	Возврат Результат;
	
КонецФункции

// Параметры:
//  НомерДоверенности - Строка
//  ИННДоверителя - Строка
//  ИННПредставителя - Строка
// 
// Возвращаемое значение:
//  Структура:
//  * Ошибка - Неопределено,Строка
//  * ИдентификаторДоверенности - Неопределено,Строка
//  * Данные - Неопределено,Строка
//  * Статус - Неопределено
//           - см. СтатусДоверенности
Функция ПолучитьДанныеДоверенностиИзРеестраФНС(НомерДоверенности, ИННДоверителя, ИННПредставителя) Экспорт
	
	Результат = Новый Структура;
	Результат.Вставить("Ошибка", Неопределено);
	Результат.Вставить("ИдентификаторДоверенности", Неопределено);
	Результат.Вставить("Данные", Неопределено);
	Результат.Вставить("Статус", Неопределено);
	
	СведенияДоверенности = МашиночитаемыеДоверенности.ПолучитьСведенияДоверенностиНаСервереМЧД(
		НомерДоверенности, ИННДоверителя, ИННПредставителя);
	
	Если СведенияДоверенности.Ошибка Тогда
		Результат.Ошибка = СведенияДоверенности.ТекстОшибки;
		Возврат Результат;
	КонецЕсли;
	
	ПолныеДанные = СведенияДоверенности.ПолныеДанные;
	
	ДанныеДляЗагрузки = МашиночитаемыеДоверенностиКлиентСервер.НовыеДанныеДляЗагрузкиМЧД();
	ДанныеДляЗагрузки.ДанныеДоверенности = ПолныеДанные.ДанныеВыгрузки;
	ДанныеДляЗагрузки.ДанныеПодписи = ПолныеДанные.ДанныеПодписи;
	ДанныеДляЗагрузки.ДанныеПодписиЗаявленияНаОтмену = ПолныеДанные.ДанныеПодписиЗаявленияНаОтмену;
	
	ТребуетсяПроверкаМЧДНаКлиенте = Ложь;
	ОбновлятьСуществующий = Истина;
	
	ЧастичныеДанные = СведенияДоверенности.ЧастичныеДанные;
	Статус = МашиночитаемыеДоверенности.СтатусДоверенностиИзЧастичныхДанных(ЧастичныеДанные);
	
	ДополнительныеСведения = МашиночитаемыеДоверенностиКлиентСервер.ДополнительныеСведенияПоЗагрузкеМЧД();
	ДополнительныеСведения.СтатусВРеестреФНС = Статус.СтатусВРеестреФНС;
	ДополнительныеСведения.ДатаОбновленияСтатуса = Статус.ДатаПолученияСтатуса;
	ДополнительныеСведения.ДатаОтзыва = Статус.ДатаОтзыва;
	
	РезультатЗагрузки = МашиночитаемыеДоверенности.ЗагрузитьМЧДИзФайла(ДанныеДляЗагрузки, ТребуетсяПроверкаМЧДНаКлиенте,
		ОбновлятьСуществующий, ДополнительныеСведения);
	
	Если ЗначениеЗаполнено(РезультатЗагрузки.ТекстОшибки) Тогда
		Результат.Ошибка = РезультатЗагрузки.ТекстОшибки;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(РезультатЗагрузки.МЧД) Тогда
		Возврат Результат;
	КонецЕсли;
	
	РезультатВыгрузки = МашиночитаемыеДоверенности.ВыгрузитьДанныеДоверенности(РезультатЗагрузки.МЧД);
	
	Если РезультатВыгрузки.Ошибка Тогда
		Результат.Ошибка = РезультатВыгрузки.ТекстОшибки;
		Возврат Результат;
	КонецЕсли;
	
	Результат.ИдентификаторДоверенности = ИдентификаторДоверенности(РезультатЗагрузки.МЧД);
	Результат.Данные = Base64Строка(РезультатВыгрузки.ОписаниеФайла.ДвоичныеДанные);
	Результат.Статус = СтатусДоверенности(РезультатЗагрузки.МЧД);
	
	Возврат Результат;
	
КонецФункции

// Параметры:
//  ДанныеДоверенности - Структура:
//   * Данные - Строка - двоичные данные в формате base64
//   * Статус - см. НовыйСтатусДоверенности
// 
// Возвращаемое значение:
//  Структура:
//  * Успех - Булево
//  * Ошибка - Строка
//  * ИдентификаторДоверенности - Неопределено,Строка
//  * Статус - Неопределено,Структура:
//    ** СтатусВРеестреФНС - Строка
//    ** ДатаОбновления - см. ОбщегоНазначенияБЭД.ДатаВФорматеISO
//    ** ДатаОтзыва - см. ОбщегоНазначенияБЭД.ДатаВФорматеISO
Функция ЗагрузитьДанныеДоверенности(ДанныеДоверенности) Экспорт
	
	Результат = Новый Структура;
	Результат.Вставить("Успех", Ложь);
	Результат.Вставить("Ошибка", "");
	Результат.Вставить("ИдентификаторДоверенности", Неопределено);
	Результат.Вставить("Статус", Неопределено);
	
	ДвоичныеДанныеДоверенности = Base64Значение(ДанныеДоверенности.Данные);
	
	Попытка
		
		НачатьТранзакцию();
		
		РезультатЗагрузки = МашиночитаемыеДоверенности.ЗагрузитьМЧДИзФайла(ДвоичныеДанныеДоверенности);
		
		Если Не ЗначениеЗаполнено(РезультатЗагрузки.МЧД) Тогда
			ВызватьИсключение(РезультатЗагрузки.ТекстОшибки);
		КонецЕсли;
		
		СтатусВФорматеСервиса = Новый Структура("СтатусВРеестреФНС, ДатаОбновления, ДатаОтзыва", "", Дата(1,1,1), Дата(1,1,1));
		ЗаполнитьЗначенияСвойств(СтатусВФорматеСервиса, ДанныеДоверенности.Статус);
		
		СтатусВРеестреФНС = СтатусВРеестреФНСИзФорматаСервиса(ДанныеДоверенности.Статус.СтатусВРеестреФНС);
		
		НовыйСтатусВРеестреФНС = МашиночитаемыеДоверенности.НовыйСтатусВРеестреФНС();
		ЗаполнитьЗначенияСвойств(НовыйСтатусВРеестреФНС, ДанныеДоверенности.Статус);
		НовыйСтатусВРеестреФНС.СтатусВРеестреФНС = СтатусВРеестреФНС;
		
		МенеджерДоверенности = МашиночитаемыеДоверенности.СправочникМЧД(РезультатЗагрузки.МЧД);
		СтатусУстановлен = МенеджерДоверенности.УстановитьСтатус(РезультатЗагрузки.МЧД, НовыйСтатусВРеестреФНС);
		
		Если ЗначениеЗаполнено(СтатусВРеестреФНС) Тогда
			СтатусВФорматеСервиса.СтатусВРеестреФНС = ОбщегоНазначения.ИмяЗначенияПеречисления(СтатусВРеестреФНС);
		КонецЕсли;
		
		Если Не СтатусУстановлен Тогда
			ВызватьИсключение(НСтр("ru='Не удалось установить статус доверенности'"));
		КонецЕсли;
		
		ЗафиксироватьТранзакцию();
	Исключение
		
		ОтменитьТранзакцию();
		
		ПодробноеОписание = ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
		
		ПодсистемаРегистрацииОшибок = ОбщегоНазначенияБЭДКлиентСервер.ПодсистемыБЭД().ОбменСКонтрагентами;
		ОбщегоНазначенияБЭД.ЗаписатьВЖурналРегистрации(ПодробноеОписание, ПодсистемаРегистрацииОшибок,
			УровеньЖурналаРегистрации.Ошибка);
		
		Результат.Ошибка = ПодробноеОписание;
		
		Возврат Результат;
	КонецПопытки;
	
	Результат.ИдентификаторДоверенности = ИдентификаторДоверенности(РезультатЗагрузки.МЧД);
	Результат.Статус = СтатусВФорматеСервиса;
	Результат.Успех = Истина;
	
	Возврат Результат;
	
КонецФункции

// Параметры:
//  ИдентификаторыДоверенностей - Массив из Строка
// 
// Возвращаемое значение:
//  Массив из Структура:
//  * ИдентификаторДоверенности - Строка
//  * ВидЗапроса - Строка
//  * ДатаСоздания - см. ОбщегоНазначенияБЭД.ДатаВФорматеISO
//  * ДатаПоследнейПопытки - см. ОбщегоНазначенияБЭД.ДатаВФорматеISO
//  * НомерПопытки - Число
Функция СтатусыОтложенныхЗапросовВРеестрФНСПоДоверенностям(ИдентификаторыДоверенностей) Экспорт
	
	УникальныеИдентификаторы = Новый Массив; // Массив из УникальныйИдентификатор
	Для Каждого ИдентификаторДоверенности Из ИдентификаторыДоверенностей Цикл
		УникальныеИдентификаторы.Добавить(Новый УникальныйИдентификатор(ИдентификаторДоверенности));
	КонецЦикла;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ
		|	ОчередьЗапросов.Доверенность КАК Доверенность,
		|	ОчередьЗапросов.ВидЗапроса КАК ВидЗапроса,
		|	ОчередьЗапросов.ДатаСоздания КАК ДатаСоздания,
		|	ОчередьЗапросов.ДатаПоследнейПопытки КАК ДатаПоследнейПопытки,
		|	ОчередьЗапросов.НомерПопытки КАК НомерПопытки
		|ИЗ
		|	РегистрСведений.ОчередьЗапросовВРеестрМЧДЭДО КАК ОчередьЗапросов
		|ГДЕ
		|	УНИКАЛЬНЫЙИДЕНТИФИКАТОР(ОчередьЗапросов.Доверенность) В (&УникальныеИдентификаторы)";
		
	Запрос.УстановитьПараметр("УникальныеИдентификаторы", УникальныеИдентификаторы);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	СтатусыЗапросов = Новый Массив; // См. СтатусыОтложенныхЗапросовВРеестрФНСПоДоверенностям
	
	ОбработанныеДоверенности = Новый Соответствие;
	
	Пока Выборка.Следующий() Цикл
		
		ИдентификаторДоверенности = ИдентификаторДоверенности(Выборка.Доверенность);
		ОбработанныеДоверенности.Вставить(ИдентификаторДоверенности, Истина);
		
		СтатусЗапроса = НовыйСтатусОтложенногоЗапросаВРеестрФНС();
		СтатусЗапроса.ИдентификаторДоверенности = ИдентификаторДоверенности;
		СтатусЗапроса.ВидЗапроса = Выборка.ВидЗапроса;
		СтатусЗапроса.ДатаСоздания = ОбщегоНазначенияБЭД.ДатаВФорматеISO(Выборка.ДатаСоздания);
		СтатусЗапроса.ДатаПоследнейПопытки = ОбщегоНазначенияБЭД.ДатаВФорматеISO(Выборка.ДатаПоследнейПопытки);
		СтатусЗапроса.НомерПопытки = Выборка.НомерПопытки;
		СтатусыЗапросов.Добавить(СтатусЗапроса);
		
	КонецЦикла;
	
	Для Каждого ИдентификаторДоверенности Из ИдентификаторыДоверенностей Цикл
		
		Если ОбработанныеДоверенности[ИдентификаторДоверенности] <> Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		СтатусЗапроса = НовыйСтатусОтложенногоЗапросаВРеестрФНС();
		СтатусЗапроса.ИдентификаторДоверенности = ИдентификаторДоверенности;
		СтатусыЗапросов.Добавить(СтатусЗапроса);
		
	КонецЦикла;
	
	Возврат СтатусыЗапросов;
	
КонецФункции

#Область УстаревшиеПроцедурыИФункции

// Параметры:
//  ДанныеДоверенности - См. НовыеДанныеДоверенностиВФорматеСервиса
// 
// Возвращаемое значение:
//  Структура:
//  * Успех - Булево
//  * Ошибка - Неопределено,Строка
Функция ЗагрузитьДоверенность(ДанныеДоверенности) Экспорт
	
	Результат = Новый Структура;
	Результат.Вставить("Успех", Ложь);
	Результат.Вставить("Ошибка", Неопределено);
	
	Если Не ЗначениеЗаполнено(ДанныеДоверенности) Тогда
		Результат.Ошибка = НСтр("ru='Некорректные данные доверенности'");
		Возврат Результат
	КонецЕсли;
	
	РезультатЗагрузки = ЗагрузитьПоДаннымВФорматеСервиса(ДанныеДоверенности);
	
	Если ЗначениеЗаполнено(РезультатЗагрузки.МЧД) Тогда
		Результат.Успех = Истина;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(РезультатЗагрузки.ТекстОшибки) Тогда
		Результат.Ошибка = РезультатЗагрузки.ТекстОшибки;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Параметры:
//  НомерДоверенности - Строка
//  ИННДоверителя - Строка
//  ИННПредставителя - Строка
// 
// Возвращаемое значение:
//  Структура:
//  * Ошибка - Неопределено
//           - Строка
//  * ОписаниеДоверенности - Неопределено
//                         - Структура:
//  ** НомерДоверенности - Строка
//  ** ХэшДанных - Строка
//  ** СтатусВРеестре - Строка
Функция ЗагрузитьДоверенностьИзРеестраФНС(НомерДоверенности, ИННДоверителя, ИННПредставителя) Экспорт
	
	Результат = Новый Структура;
	Результат.Вставить("Ошибка", Неопределено);
	Результат.Вставить("ОписаниеДоверенности", Неопределено);
	
	СведенияДоверенности = МашиночитаемыеДоверенности.ПолучитьСведенияДоверенностиНаСервереМЧД(
		НомерДоверенности, ИННДоверителя, ИННПредставителя);
	
	Если СведенияДоверенности.Ошибка Тогда
		Результат.Ошибка = СведенияДоверенности.ТекстОшибки;
		Возврат Результат;
	КонецЕсли;
	
	ПолныеДанные = СведенияДоверенности.ПолныеДанные;
	
	ДанныеДляЗагрузки = МашиночитаемыеДоверенностиКлиентСервер.НовыеДанныеДляЗагрузкиМЧД();
	ДанныеДляЗагрузки.ДанныеДоверенности = ПолныеДанные.ДанныеВыгрузки;
	ДанныеДляЗагрузки.ДанныеПодписи = ПолныеДанные.ДанныеПодписи;
	ДанныеДляЗагрузки.ДанныеПодписиЗаявленияНаОтмену = ПолныеДанные.ДанныеПодписиЗаявленияНаОтмену;
	
	ТребуетсяПроверкаМЧДНаКлиенте = Ложь;
	ОбновлятьСуществующий = Истина;
	
	ЧастичныеДанныеМЧД = СведенияДоверенности.ЧастичныеДанные; // См. МашиночитаемыеДоверенности.ПолучитьЧастичныеДанныеДоверенностиНаСервереМЧД
	СтатусМЧД = ЧастичныеДанныеМЧД.СтатусДоверенности;
	СтатусВРеестреФНС = МашиночитаемыеДоверенностиКлиентСервер.СтатусВРеестреФНС(СтатусМЧД);
	
	ДополнительныеСведения = МашиночитаемыеДоверенностиКлиентСервер.ДополнительныеСведенияПоЗагрузкеМЧД();
	ДополнительныеСведения.СтатусВРеестреФНС = СтатусВРеестреФНС;
	
	РезультатЗагрузки = МашиночитаемыеДоверенности.ЗагрузитьМЧДИзФайла(ДанныеДляЗагрузки, ТребуетсяПроверкаМЧДНаКлиенте,
		ОбновлятьСуществующий, ДополнительныеСведения);
	
	ОписаниеДоверенности = НовоеОписаниеДоверенности();
	ОписаниеДоверенности.НомерДоверенности = НомерДоверенности;
	
	Если ЗначениеЗаполнено(РезультатЗагрузки.ТекстОшибки) Тогда
		Результат.Ошибка = РезультатЗагрузки.ТекстОшибки;
		Возврат Результат;
	КонецЕсли; 
	
	ОписаниеДоверенности.ХэшДанных = ОбщегоНазначения.КонтрольнаяСуммаСтрокой(ПолныеДанные.ДанныеВыгрузки);
	
	ОписаниеДоверенности.СтатусВРеестре = ОбщегоНазначения.ИмяЗначенияПеречисления(СтатусВРеестреФНС);
	
	Результат.ОписаниеДоверенности = ОписаниеДоверенности;
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

#Область ДанныеДоверенностиВФорматеСервиса

// Параметры:
//  Доверенность - ОпределяемыйТип.МашиночитаемаяДоверенность
// 
// Возвращаемое значение:
//  См. НовыеДанныеДоверенностиВФорматеСервиса
Функция ДанныеДоверенностиВФорматеСервиса(Доверенность) Экспорт
	
	НомерИСтатусДоверенности = НомерИСтатусДоверенности(Доверенность);
	ДанныеФайлаДоверенностиИПодписи = МашиночитаемыеДоверенности.ДанныеФайлаДоверенностиИПодписи(Доверенность);
	
	ДанныеВФорматеСервиса = НовыеДанныеДоверенностиВФорматеСервиса();
	ДанныеВФорматеСервиса.Номер = НомерИСтатусДоверенности.НомерДоверенности;
	ДанныеВФорматеСервиса.ДанныеФайла = Base64Строка(ДанныеФайлаДоверенностиИПодписи.ДанныеФайла);
	ДанныеВФорматеСервиса.ДанныеПодписи = Base64Строка(ДанныеФайлаДоверенностиИПодписи.ДанныеПодписи);
	Если ЗначениеЗаполнено(НомерИСтатусДоверенности.СтатусВРеестреФНС) Тогда
		ДанныеВФорматеСервиса.СтатусВРеестреФНС = ОбщегоНазначения.ИмяЗначенияПеречисления(
			НомерИСтатусДоверенности.СтатусВРеестреФНС);
	КонецЕсли;
	
	Возврат ДанныеВФорматеСервиса;
	
КонецФункции

// Возвращаемое значение:
//  Структура:
//  * Номер - Строка
//  * ДанныеФайла - Строка
//  * ДанныеПодписи - Строка
//  * СтатусВРеестреФНС - Строка
Функция НовыеДанныеДоверенностиВФорматеСервиса()
	Описание = Новый Структура;
	Описание.Вставить("Номер", "");
	Описание.Вставить("ДанныеФайла", "");
	Описание.Вставить("ДанныеПодписи", "");
	Описание.Вставить("СтатусВРеестреФНС", "");
	Возврат Описание;
КонецФункции

// Параметры:
//  Доверенность - ОпределяемыйТип.МашиночитаемаяДоверенность
// 
// Возвращаемое значение:
//  Структура:
//  * НомерДоверенности - Строка
//  * СтатусВРеестреФНС - ПеречислениеСсылка.СтатусыМашиночитаемойДоверенностиВРеестреФНС 
Функция НомерИСтатусДоверенности(Доверенность)
	//@skip-check constructor-function-return-section
	Возврат ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Доверенность, "НомерДоверенности, СтатусВРеестреФНС");
КонецФункции

#КонецОбласти

#Область ДоверенностьИзФорматаСервиса

// Параметры:
//  ДанныеДоверенности - Структура:
//  * Номер - Строка
//  * ДанныеФайла - Строка
//  * ДанныеПодписи - Строка
//  * СтатусВРеестреФНС - Строка
//  
// Возвращаемое значение:
//  Неопределено,ОпределяемыйТип.МашиночитаемаяДоверенность
Функция ДоверенностьПоДаннымВФорматеСервиса(ДанныеДоверенности) Экспорт
	
	Доверенность = Неопределено;
	
	Если Не ЗначениеЗаполнено(ДанныеДоверенности) Тогда
		Возврат Доверенность
	КонецЕсли;
	
	Доверенность = МашиночитаемыеДоверенности.ПолучитьДоверенностьИзЖурналаПоНомеру(ДанныеДоверенности.Номер);
	Если ЗначениеЗаполнено(Доверенность) Тогда
		Возврат Доверенность;
	КонецЕсли;
	
	РезультатЗагрузки = ЗагрузитьПоДаннымВФорматеСервиса(ДанныеДоверенности);
	
	Возврат РезультатЗагрузки.МЧД;
	
КонецФункции

// Параметры:
//  ДанныеДоверенности - Структура:
//  * Номер - Строка
//  * ДанныеФайла - Строка
//  * ДанныеПодписи - Строка
//  * СтатусВРеестреФНС - Строка
//  
// Возвращаемое значение:
//  См. МашиночитаемыеДоверенности.ЗагрузитьМЧДИзФайла
Функция ЗагрузитьПоДаннымВФорматеСервиса(ДанныеДоверенности)
	
	ДанныеДляЗагрузки = МашиночитаемыеДоверенностиКлиентСервер.НовыеДанныеДляЗагрузкиМЧД();
	ДанныеДляЗагрузки.ДанныеДоверенности = Base64Значение(ДанныеДоверенности.ДанныеФайла);
	ДанныеДляЗагрузки.ДанныеПодписи = Base64Значение(ДанныеДоверенности.ДанныеПодписи);
	СтатусВРеестреФНС = СтатусВРеестреФНСИзФорматаСервиса(ДанныеДоверенности.СтатусВРеестреФНС);
	
	ДополнительныеСведения = Неопределено;
	Если ЗначениеЗаполнено(СтатусВРеестреФНС) Тогда
		ДополнительныеСведения = МашиночитаемыеДоверенностиКлиентСервер.ДополнительныеСведенияПоЗагрузкеМЧД();
		ДополнительныеСведения.СтатусВРеестреФНС = СтатусВРеестреФНС;
	КонецЕсли;
	
	ТребуетсяПроверкаМЧДНаКлиенте = Ложь;
	ОбновлятьСуществующий = Ложь;
	РезультатЗагрузки = МашиночитаемыеДоверенности.ЗагрузитьМЧДИзФайла(ДанныеДляЗагрузки,
		ТребуетсяПроверкаМЧДНаКлиенте, ОбновлятьСуществующий, ДополнительныеСведения);
	
	Возврат РезультатЗагрузки;
	
КонецФункции

// Параметры:
//  СтатусВФорматеСервиса - Строка
//  МетаданныеПеречисления - ОбъектМетаданныхПеречисление
// 
// Возвращаемое значение:
//  ПеречислениеСсылка.СтатусыМашиночитаемойДоверенностиВРеестреФНС
Функция СтатусВРеестреФНСИзФорматаСервиса(СтатусВФорматеСервиса, МетаданныеПеречисления = Неопределено)
	
	Если МетаданныеПеречисления = Неопределено Тогда
		МетаданныеПеречисления = Метаданные.Перечисления.СтатусыМашиночитаемойДоверенностиВРеестреФНС;
	КонецЕсли;
	
	Возврат ОбщегоНазначенияБЭД.ЗначениеПеречисленияПоИмени(СтатусВФорматеСервиса, МетаданныеПеречисления);
	
КонецФункции

#КонецОбласти

// Возвращаемое значение:
//  Структура:
//  * Подписана - Булево
//  * Верна - Булево
//  * ОшибкаПроверки - Неопределено,Строка
//  * СтатусВРеестреФНС - Строка
//  * ОшибкаРеестраФНС - Неопределено,Строка
//  * ДатаОтзыва - см. ОбщегоНазначенияБЭД.ДатаВФорматеISO
//  * ДатаПолученияСтатуса - см. ОбщегоНазначенияБЭД.ДатаВФорматеISO
//  * СтатусыОтложенныхЗапросов - Массив из см. НовыйСтатусОтложенногоЗапроса
Функция НовыйСтатусДоверенности()
	
	Свойства = Новый Структура;
	Свойства.Вставить("Подписана", Ложь);
	Свойства.Вставить("Верна", Ложь);
	Свойства.Вставить("ОшибкаПроверки", Неопределено);
	Свойства.Вставить("СтатусВРеестреФНС", "");
	Свойства.Вставить("ОшибкаРеестраФНС", Неопределено);
	Свойства.Вставить("ДатаОтзыва", "");
	Свойства.Вставить("ДатаПолученияСтатуса", "");
	Свойства.Вставить("СтатусыОтложенныхЗапросов", Новый Массив);
	Возврат Свойства;
	
КонецФункции

// Параметры:
//  Доверенность - ОпределяемыйТип.МашиночитаемаяДоверенность
// 
// Возвращаемое значение:
//  - Неопределено
//  - См. НовыйСтатусДоверенности
Функция СтатусДоверенности(Доверенность)
	
	СтатусДоверенности = НовыйСтатусДоверенности();
	
	ВыборкиДанных = ВыбратьДанныеСтатусаДоверенности(Доверенность);
	ВыборкаРеквизитов = ВыборкиДанных.ВыборкаРеквизитов;
	ВыборкаСтатусовЗапросов = ВыборкиДанных.ВыборкаСтатусовЗапросов;
	
	Если ВыборкаРеквизитов.Следующий() Тогда
		СтатусДоверенности.Подписана = ВыборкаРеквизитов.Подписана;
		СтатусДоверенности.Верна = ВыборкаРеквизитов.Верна;
		Если ЗначениеЗаполнено(ВыборкаРеквизитов.ТекстОшибкиПроверкиМЧД) Тогда
			СтатусДоверенности.ОшибкаПроверки = ВыборкаРеквизитов.ТекстОшибкиПроверкиМЧД;
		КонецЕсли;
		Если ЗначениеЗаполнено(ВыборкаРеквизитов.СтатусВРеестреФНС) Тогда
			СтатусДоверенности.СтатусВРеестреФНС = ОбщегоНазначения.ИмяЗначенияПеречисления(ВыборкаРеквизитов.СтатусВРеестреФНС);
		КонецЕсли;
		Если ЗначениеЗаполнено(ВыборкаРеквизитов.ОписаниеОшибкиРегистрации) Тогда
			СтатусДоверенности.ОшибкаРеестраФНС = ВыборкаРеквизитов.ОписаниеОшибкиРегистрации;
		КонецЕсли;
		СтатусДоверенности.ДатаОтзыва = ОбщегоНазначенияБЭД.ДатаВФорматеISO(ВыборкаРеквизитов.ДатаОтзыва);
		СтатусДоверенности.ДатаПолученияСтатуса = ОбщегоНазначенияБЭД.ДатаВФорматеISO(ВыборкаРеквизитов.ДатаОбновленияСтатуса);
	Иначе
		Возврат Неопределено;
	КонецЕсли;
	
	Пока ВыборкаСтатусовЗапросов.Следующий() Цикл
		СтатусОтложенногоЗапроса = НовыйСтатусОтложенногоЗапроса();
		СтатусОтложенногоЗапроса.ВидЗапроса = ВыборкаСтатусовЗапросов.ВидЗапроса;
		СтатусОтложенногоЗапроса.ДатаСоздания = ОбщегоНазначенияБЭД.ДатаВФорматеISO(
			ВыборкаСтатусовЗапросов.ДатаСоздания);
		СтатусОтложенногоЗапроса.ДатаПоследнейПопытки = ОбщегоНазначенияБЭД.ДатаВФорматеISO(
			ВыборкаСтатусовЗапросов.ДатаПоследнейПопытки);
		СтатусОтложенногоЗапроса.НомерПопытки = ВыборкаСтатусовЗапросов.НомерПопытки;
		СтатусДоверенности.СтатусыОтложенныхЗапросов.Добавить(СтатусОтложенногоЗапроса);
	КонецЦикла;
	
	Возврат СтатусДоверенности;
	
КонецФункции

// Параметры:
//  Доверенность - СправочникСсылка.МЧД003,СправочникСсылка.МашиночитаемыеДоверенностиОрганизаций,СправочникСсылка.МашиночитаемыеДоверенностиКонтрагентов
// 
// Возвращаемое значение:
//  Строка
Функция ИдентификаторДоверенности(Доверенность) Экспорт
	
	Возврат Строка(Доверенность.УникальныйИдентификатор());
	
КонецФункции

// Параметры:
//  Идентификатор - Строка
// 
// Возвращаемое значение:
//  Неопределено,СправочникСсылка.МЧД003
Функция ДоверенностьПоИдентификатору(Идентификатор) Экспорт
	
	УникальныйИдентификатор = Новый УникальныйИдентификатор(Идентификатор);
	
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	МЧД003.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.МЧД003 КАК МЧД003
		|ГДЕ
		|	УНИКАЛЬНЫЙИДЕНТИФИКАТОР(МЧД003.Ссылка) = &УникальныйИдентификатор";
	
	Запрос.УстановитьПараметр("УникальныйИдентификатор", УникальныйИдентификатор);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда
		Возврат Выборка.Ссылка;
	Иначе
		Возврат Неопределено;
	КонецЕсли;
	
КонецФункции

// Параметры:
//  ОтпечаткиСертификатов - Массив из Строка
// 
// Возвращаемое значение:
//  См. КриптографияБЭДКлиентСервер.НовыеРезультатыПолученияОтпечатков
Функция РезультатыПолученияОтпечатков(ОтпечаткиСертификатов)
	
	РезультатПолученияОтпечатков = КриптографияБЭДКлиентСервер.НовыйРезультатПолученияОтпечатков();
	РезультатПолученияОтпечатков.Доступность = Истина;
	РезультатПолученияОтпечатков.Отпечатки = ОтпечаткиСертификатов;
	
	РезультатыПолученияОтпечатков = КриптографияБЭДКлиентСервер.НовыеРезультатыПолученияОтпечатков();
	РезультатыПолученияОтпечатков.Клиент = РезультатПолученияОтпечатков;
	РезультатыПолученияОтпечатков.Сервер = КриптографияБЭДКлиентСервер.НовыйРезультатПолученияОтпечатков();
	РезультатыПолученияОтпечатков.Облако = КриптографияБЭДКлиентСервер.НовыйРезультатПолученияОтпечатков();
	
	Возврат РезультатыПолученияОтпечатков;
	
КонецФункции

// Параметры:
//  ДанныеДляПодписания - см. МашиночитаемыеДоверенности.ДанныеДляПодписания
//  КонтекстДиагностики - см. ОбработкаНеисправностейБЭД.НовыйКонтекстДиагностики
//
// Возвращаемое значение:
//  Структура:
//  * Ошибки - Неопределено,Массив из см. ЦентрЭДО.НоваяОшибкаВФорматеСервиса
//  * ДанныеДляПодписания - Неопределено,Структура:
//    ** ОтпечаткиСертификатов - Массив из Строка
//    ** Данные - Строка - ДвоичныеДанные в формате base64.
Функция РезультатПодготовкиДанныхДляПодписанияВФорматеСервиса(ДанныеДляПодписания, КонтекстДиагностики)
	
	Результат = Новый Структура;
	Результат.Вставить("Ошибки", Неопределено);
	Результат.Вставить("ДанныеДляПодписания", Неопределено);
	
	Ошибки = ЦентрЭДО.ВыгрузитьОшибкиВФорматеСервиса(КонтекстДиагностики);
	Если ЗначениеЗаполнено(Ошибки) Тогда
		Результат.Ошибки = Ошибки;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(ДанныеДляПодписания) Тогда
		Возврат Результат;
	КонецЕсли;
	
	ОписаниеНабораДанных = ДанныеДляПодписания[0];
	НаборДанных = ОписаниеНабораДанных.НаборДанных;
	
	Если Не ЗначениеЗаполнено(НаборДанных) Тогда
		Возврат Результат;
	КонецЕсли;
	
	ДвоичныеДанные = НаборДанных[0].Данные;
	ДвоичныеДанныеВФорматеСервиса = Base64Строка(ДвоичныеДанные);
	
	ОтпечаткиПоСертификатам = КриптографияБЭД.ОтпечаткиСертификатов(ОписаниеНабораДанных.Сертификаты);
	Отпечатки = ОбщегоНазначения.ВыгрузитьКолонку(ОтпечаткиПоСертификатам, "Значение");
	
	ДанныеДляПодписанияВФорматеСервиса = Новый Структура;
	ДанныеДляПодписанияВФорматеСервиса.Вставить("ОтпечаткиСертификатов", Отпечатки);
	ДанныеДляПодписанияВФорматеСервиса.Вставить("Данные", ДвоичныеДанныеВФорматеСервиса);
	
	Результат.ДанныеДляПодписания = ДанныеДляПодписанияВФорматеСервиса;
	
	Возврат Результат;
	
КонецФункции

// Параметры:
//  РезультатДобавления - см. МашиночитаемыеДоверенности.ДобавитьПодпись
//  КонтекстДиагностики - см. ОбработкаНеисправностейБЭД.НовыйКонтекстДиагностики
// 
// Возвращаемое значение:
//  Структура:
//  * Добавлена - Булево
//  * Верна - Булево
//  * Ошибки - Неопределено,Массив из см. ЦентрЭДО.НоваяОшибкаВФорматеСервиса
Функция РезультатДобавленияПодписиВФорматеСервиса(РезультатДобавления, КонтекстДиагностики)
	
	РезультатВФорматеСервиса = Новый Структура;
	РезультатВФорматеСервиса.Вставить("Добавлена", Ложь);
	РезультатВФорматеСервиса.Вставить("Верна", Ложь);
	РезультатВФорматеСервиса.Вставить("Ошибки", Неопределено);
	
	РезультатВФорматеСервиса.Добавлена = РезультатДобавления.Добавлена;
	РезультатВФорматеСервиса.Верна = РезультатДобавления.Верна;
	
	Ошибки = ЦентрЭДО.ВыгрузитьОшибкиВФорматеСервиса(КонтекстДиагностики);
	
	Если ЗначениеЗаполнено(РезультатДобавления.ОшибкаПроверки) Тогда
		Ошибка = ЦентрЭДО.НоваяОшибкаВФорматеСервиса();
		Ошибка.Тип = КриптографияБЭДКлиентСервер.ИдентификаторВидаОшибкиКриптография();
		Ошибка.Кратко = НСтр("ru = 'Подпись невалидна'");
		Ошибка.Подробно = РезультатДобавления.ОшибкаПроверки;
		Ошибки.Добавить(Ошибка);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Ошибки) Тогда
		РезультатВФорматеСервиса.Ошибки = Ошибки;
	КонецЕсли;
	
	Возврат РезультатВФорматеСервиса;
	
КонецФункции

// Параметры:
//  РезультатРегистрации - см. МашиночитаемыеДоверенности.ОтправитьНаРегистрацию
// 
// Возвращаемое значение:
//  Структура:
//  * Ошибки - Неопределено,Массив из см. ЦентрЭДО.НоваяОшибкаВФорматеСервиса
//  * ИдентификаторТранзакции - Строка
Функция РезультатРегистрацииВРеестреФНСВФорматеСервиса(РезультатРегистрации)
	
	РезультатВФорматеСервиса = Новый Структура;
	РезультатВФорматеСервиса.Вставить("Ошибки", Неопределено);
	РезультатВФорматеСервиса.Вставить("ИдентификаторТранзакции", "");
	
	Ошибки = ЦентрЭДО.ВыгрузитьОшибкиВФорматеСервиса(РезультатРегистрации.КонтекстДиагностики);
	
	Если ЗначениеЗаполнено(РезультатРегистрации.ОписаниеОшибкиРегистрации) Тогда
		Ошибка = ЦентрЭДО.НоваяОшибкаВФорматеСервиса();
		Ошибка.Тип = ОбработкаНеисправностейБЭДКлиентСервер.ВидОшибкиНеизвестнаяОшибка().Идентификатор;
		Ошибка.Кратко = РезультатРегистрации.ОписаниеОшибкиРегистрации;
		Ошибки.Добавить(Ошибка);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Ошибки) Тогда
		РезультатВФорматеСервиса.Ошибки = Ошибки;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(РезультатРегистрации.ИдентификаторТранзакции) Тогда
		РезультатВФорматеСервиса.ИдентификаторТранзакции = РезультатРегистрации.ИдентификаторТранзакции;
	КонецЕсли;
	
	Возврат РезультатВФорматеСервиса;
	
КонецФункции

// Параметры:
//  РезультатПроверки - см. МашиночитаемыеДоверенности.ПроверитьДоверенность
//  КонтекстДиагностики - см. ОбработкаНеисправностейБЭД.НовыйКонтекстДиагностики
// 
// Возвращаемое значение:
//  Структура:
//  * Верна - Булево
//  * Причина - Строка
//  * Ошибки - Неопределено,Массив из см. ЦентрЭДО.НоваяОшибкаВФорматеСервиса
Функция РезультатПроверкиДоверенностиВФорматеСервиса(РезультатПроверки, КонтекстДиагностики)
	
	РезультатВФорматеСервиса = Новый Структура;
	РезультатВФорматеСервиса.Вставить("Верна", Ложь);
	РезультатВФорматеСервиса.Вставить("Причина", "");
	РезультатВФорматеСервиса.Вставить("Ошибки", Неопределено);
	
	РезультатВФорматеСервиса.Верна = РезультатПроверки.Результат;
	РезультатВФорматеСервиса.Причина = РезультатПроверки.ТекстОшибки;
	
	Ошибки = ЦентрЭДО.ВыгрузитьОшибкиВФорматеСервиса(КонтекстДиагностики);
	Если ЗначениеЗаполнено(Ошибки) Тогда
		РезультатВФорматеСервиса.Ошибки = Ошибки;
	КонецЕсли;
	
	Возврат РезультатВФорматеСервиса;
	
КонецФункции

// Параметры:
//  РезультатОбновления - см. МашиночитаемыеДоверенности.ОбновитьСтатусМЧДИзРеестраФНС
// 
// Возвращаемое значение:
//  Структура:
//  * Ошибка - Неопределено,Строка
//  * Статус - Неопределено,Строка
//  * ДатаОбновления - см. ОбщегоНазначенияБЭД.ДатаВФорматеISO
//  * ДатаОтзыва - см. ОбщегоНазначенияБЭД.ДатаВФорматеISO
Функция РезультатОбновленияСтатусаДоверенностиВФорматеСервиса(РезультатОбновления)
	
	РезультатВФорматеСервиса = Новый Структура;
	РезультатВФорматеСервиса.Вставить("Ошибка", Неопределено);
	РезультатВФорматеСервиса.Вставить("Статус", Неопределено);
	РезультатВФорматеСервиса.Вставить("ДатаОбновления", "");
	РезультатВФорматеСервиса.Вставить("ДатаОтзыва", "");
	
	Если ЗначениеЗаполнено(РезультатОбновления.ТекстОшибки) Тогда
		РезультатВФорматеСервиса.Ошибка = РезультатОбновления.ТекстОшибки;
	КонецЕсли;
	
	СтатусВРеестреФНС = РезультатОбновления.СтатусВРеестреФНС; // См. МашиночитаемыеДоверенности.НовыйСтатусВРеестреФНС
	Если ЗначениеЗаполнено(СтатусВРеестреФНС) Тогда
		РезультатВФорматеСервиса.Статус = ОбщегоНазначения.ИмяЗначенияПеречисления(СтатусВРеестреФНС.СтатусВРеестреФНС);
		РезультатВФорматеСервиса.ДатаОбновления = ОбщегоНазначенияБЭД.ДатаВФорматеISO(
			СтатусВРеестреФНС.ДатаПолученияСтатуса);
		Если ЗначениеЗаполнено(СтатусВРеестреФНС.ДатаОтзыва) Тогда
			РезультатВФорматеСервиса.ДатаОтзыва = ОбщегоНазначенияБЭД.ДатаВФорматеISO(СтатусВРеестреФНС.ДатаОтзыва);
		КонецЕсли;
	КонецЕсли;
	
	Возврат РезультатВФорматеСервиса;
	
КонецФункции

// Возвращаемое значение:
//  Структура:
// * НомерДоверенности - Строка
// * ХэшДанных - Строка
// * СтатусВРеестре - Строка
Функция НовоеОписаниеДоверенности()
	ОписаниеДоверенности = Новый Структура;
	ОписаниеДоверенности.Вставить("НомерДоверенности", "");
	ОписаниеДоверенности.Вставить("ХэшДанных", "");
	ОписаниеДоверенности.Вставить("СтатусВРеестре", "");
