// Параметры:
//  ОтборДоверенностей - ТаблицаЗначений:
//  * Индекс - Число
//  * УникальныйИдентификатор - УникальныйИдентификатор
// 
// Возвращаемое значение:
//  Структура:
//  * ВыборкаРеквизитов - ВыборкаИзРезультатаЗапроса:
//    ** Индекс - Число
//    ** СтатусВРеестреФНС - ПеречислениеСсылка.СтатусыМашиночитаемойДоверенностиВРеестреФНС
//    ** ОписаниеОшибкиРегистрации - Строка
//    ** ДатаОтзыва - Дата
//    ** ДатаОбновленияСтатуса - Дата
//    ** Подписана - Булево
//    ** Верна - Булево
//    ** ТекстОшибкиПроверкиМЧД - Строка
//  * ВыборкаСтатусовЗапросов - ВыборкаИзРезультатаЗапроса:
//    ** Индекс - Число
//    ** ВидЗапроса - Строка
//    ** ДатаСоздания - Дата
//    ** ДатаПоследнейПопытки - Дата
//    ** НомерПопытки - Число
Функция ВыбратьДанныеСтатусовДоверенностей(ОтборДоверенностей)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ОтборДоверенностей.Индекс КАК Индекс,
		|	ОтборДоверенностей.УникальныйИдентификатор КАК УникальныйИдентификатор
		|ПОМЕСТИТЬ ОтборДоверенностей
		|ИЗ
		|	&ОтборДоверенностей КАК ОтборДоверенностей
		|
		|ИНДЕКСИРОВАТЬ ПО
		|	УникальныйИдентификатор
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ОтборДоверенностей.Индекс КАК Индекс,
		|	МашиночитаемыеДоверенностиОрганизаций.СтатусВРеестреФНС КАК СтатусВРеестреФНС,
		|	МашиночитаемыеДоверенностиОрганизаций.ОписаниеОшибкиРегистрации КАК ОписаниеОшибкиРегистрации,
		|	МашиночитаемыеДоверенностиОрганизаций.ДатаОтзыва КАК ДатаОтзыва,
		|	МашиночитаемыеДоверенностиОрганизаций.ДатаОбновленияСтатуса КАК ДатаОбновленияСтатуса,
		|	МашиночитаемыеДоверенностиОрганизаций.Подписана КАК Подписана,
		|	МашиночитаемыеДоверенностиОрганизаций.Верна КАК Верна,
		|	МашиночитаемыеДоверенностиОрганизаций.ТекстОшибкиПроверкиМЧД КАК ТекстОшибкиПроверкиМЧД
		|ИЗ
		|	Справочник.МашиночитаемыеДоверенностиОрганизаций КАК МашиночитаемыеДоверенностиОрганизаций
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ОтборДоверенностей КАК ОтборДоверенностей
		|		ПО УНИКАЛЬНЫЙИДЕНТИФИКАТОР(МашиночитаемыеДоверенностиОрганизаций.Ссылка) = ОтборДоверенностей.УникальныйИдентификатор
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	ОтборДоверенностей.Индекс,
		|	МашиночитаемыеДоверенностиКонтрагентов.СтатусВРеестреФНС,
		|	"""",
		|	МашиночитаемыеДоверенностиКонтрагентов.ДатаОтзыва,
		|	МашиночитаемыеДоверенностиКонтрагентов.ДатаОбновленияСтатуса,
		|	МашиночитаемыеДоверенностиКонтрагентов.Подписана,
		|	МашиночитаемыеДоверенностиКонтрагентов.Верна,
		|	МашиночитаемыеДоверенностиКонтрагентов.ТекстОшибкиПроверкиМЧД
		|ИЗ
		|	Справочник.МашиночитаемыеДоверенностиКонтрагентов КАК МашиночитаемыеДоверенностиКонтрагентов
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ОтборДоверенностей КАК ОтборДоверенностей
		|		ПО УНИКАЛЬНЫЙИДЕНТИФИКАТОР(МашиночитаемыеДоверенностиКонтрагентов.Ссылка) = ОтборДоверенностей.УникальныйИдентификатор
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	ОтборДоверенностей.Индекс,
		|	МЧД003.СтатусВРеестреФНС,
		|	МЧД003.ОписаниеОшибкиРегистрации,
		|	МЧД003.ДатаПрекращения,
		|	МЧД003.ДатаОбновленияСтатуса,
		|	МЧД003.Подписана,
		|	МЧД003.Верна,
		|	МЧД003.ТекстОшибкиПроверкиМЧД
		|ИЗ
		|	Справочник.МЧД003 КАК МЧД003
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ОтборДоверенностей КАК ОтборДоверенностей
		|		ПО УНИКАЛЬНЫЙИДЕНТИФИКАТОР(МЧД003.Ссылка) = ОтборДоверенностей.УникальныйИдентификатор
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ОтборДоверенностей.Индекс КАК Индекс,
		|	ОчередьЗапросов.ВидЗапроса КАК ВидЗапроса,
		|	ОчередьЗапросов.ДатаСоздания КАК ДатаСоздания,
		|	ОчередьЗапросов.ДатаПоследнейПопытки КАК ДатаПоследнейПопытки,
		|	ОчередьЗапросов.НомерПопытки КАК НомерПопытки
		|ИЗ
		|	РегистрСведений.ОчередьЗапросовВРеестрМЧДЭДО КАК ОчередьЗапросов
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ОтборДоверенностей КАК ОтборДоверенностей
		|		ПО УНИКАЛЬНЫЙИДЕНТИФИКАТОР(ОчередьЗапросов.Доверенность) = ОтборДоверенностей.УникальныйИдентификатор
		|";
	
	Запрос.УстановитьПараметр("ОтборДоверенностей", ОтборДоверенностей);
	
	РезультатыЗапроса = Запрос.ВыполнитьПакет();
	
	ВыборкиДанных = Новый Структура("ВыборкаРеквизитов, ВыборкаСтатусовЗапросов",
		РезультатыЗапроса[1].Выбрать(), РезультатыЗапроса[2].Выбрать());
	
	Возврат ВыборкиДанных;
	
КонецФункции

