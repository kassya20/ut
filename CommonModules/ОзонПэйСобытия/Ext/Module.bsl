#Область СлужебныйПрограммныйИнтерфейс

// Определяет видимость подсистемы в общем списке настроек подключения к платежным системам, доступность изменения
// настроек и видимость кассовых ссылок.
// 
// Параметры:
//  ВидимостьПодсистемы - Булево - признак видимости подсистемы в списке. Не рекомендуется изменять данный параметр,
//    поскольку форма может открываться в режиме видимости только одной подсистемы.
//  ДоступностьНастроек - Булево - признак доступности для пользователя возможности изменения настроек подключения.
//
Процедура ПриПодготовкеПараметровФормыСпискаНастроек(
		ВидимостьПодсистемы,
		ДоступностьНастроек) Экспорт
	
	Если ВидимостьПодсистемы Тогда
		ДоступностьНастроек = ПлатежныеСистемы.НастройкаПодключенияДоступна();
	КонецЕсли;
	
КонецПроцедуры

// Вызывается при заполнении описания платежных систем.
// 
// Параметры:
//   ПлатежныеСистемы - см. НастройкиПлатежныхСистемПовтИсп.ОписаниеПлатежныхСервисов
//   
Процедура ПриДобавленииОписанияПлатежныхСервисов(ПлатежныеСистемы) Экспорт

	Описание = НастройкиПлатежныхСистемСлужебный.НовыйОписаниеПлатежнойСистемы(
		ПредопределенноеЗначение("Перечисление.ПлатежныеСервисы.ОзонПэй"),
		"ИнтернетПоддержкаПользователей.ПлатежныеСистемы.ОзонПэй",
		НСтр("ru = 'Ozon Pay'"),
		"ЛоготипОзонПэйЧБ",
		6);

	Описание.ЗаголовокСписка      = НСтр("ru = 'Настройки подключения к Ozon Pay'");
	Описание.ЗаголовокПодключения = НСтр("ru = 'Подключение к Ozon Pay'");
	Описание.Логотип              = "ЛоготипОзонПэй";
	
	// Значения по умолчанию, если не получится загрузить значения из сервиса
	ОписаниеПоУмолчанию = ОзонПэйСлужебный.ОписаниеПоУмолчанию();
	ЗаполнитьЗначенияСвойств(Описание, ОписаниеПоУмолчанию);
	
	ПлатежныеСистемы.Вставить(
		НастройкиПлатежныхСистемКлиентСервер.ИмяПодсистемыОзонПэй(),
		Описание);
	
КонецПроцедуры

// см. ПлатежныеСистемыСобытия.ПриПодготовкеЗапроса_tokens_request
// 
Процедура ПриПодготовкеЗапроса_tokens_request(ПараметрыАутентификации, ЗаписьДанныхСообщения) Экспорт
	
	Если ПараметрыАутентификации.ДанныеАутентификации = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ЗаписьДанныхСообщения.ЗаписатьИмяСвойства("accessKey");
	ЗаписьДанныхСообщения.ЗаписатьЗначение(ПараметрыАутентификации.ДанныеАутентификации.Токен);
	
	ЗаписьДанныхСообщения.ЗаписатьИмяСвойства("signKey");
	ЗаписьДанныхСообщения.ЗаписатьЗначение(ПараметрыАутентификации.ДанныеАутентификации.СекретныйКлюч);
	
КонецПроцедуры

// См. ПлатежныеСистемыСобытия.ПриОпределенииСпособаОплаты
Процедура ПриОпределенииСпособаОплаты(Знач СпособОплатыСервис, СпособОплаты) Экспорт
	
	СпособОплатыСервис = ВРег(СокрЛП(СпособОплатыСервис));
	Если СпособОплатыСервис = "OPERATION_PAY_TYPE_UNSPECIFIED" Тогда
		СпособОплаты = ПлатежныеСистемыКлиентСервер.СпособОплатыНеУказан();
	ИначеЕсли СпособОплатыСервис = "OZON_CARD" Тогда
		СпособОплаты = ПлатежныеСистемыКлиентСервер.СпособОплатыОзонКарта();
	ИначеЕсли СпособОплатыСервис = "BANK_CARD" Тогда
		СпособОплаты = ПлатежныеСистемыКлиентСервер.СпособОплатыБанковскаяКарта();
	ИначеЕсли СпособОплатыСервис = "SBP" Тогда
		СпособОплаты = ПлатежныеСистемыКлиентСервер.СпособОплатыСБП();
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

