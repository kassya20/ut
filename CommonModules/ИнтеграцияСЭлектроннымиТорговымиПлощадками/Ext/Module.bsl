//   * UserEmail - Строка - зарегистрированный в Бидзаар Email пользователя
//   * ТокенДоступа - строка - актуальный токен доступа
//   * Сервер - строка - адрес сервера
//   * СтрокаПоиска - строка - строка поиска для фильтрации ключевых слов. Если не указана, возвращаются все ключевые слова
//   * МинимальноеКоличествоИспользованийТега - число - Минимальное количество использований тега для включения в результат
//   * НомерСтраницы - число - номер страницы для постраничной выборки (отсчет с нуля)
//   * КоличествоКлючевыхСловНаСтранице - число - количество ключевых слов на одной странице
//   * ДополнительныеПараметры - структура - значения вспомогательных параметров
// 
// Возвращаемое значение:
//  Структура - см. НовыйЗапросСервиса()
//
Функция ЗапросСервисаКлючевыеСловаБидзаар(ПараметрыЗапроса)

	ЗапросСервиса = НовыйЗапросСервиса();

	//Трансляция дополнительных параметров запроса в описание запроса
	ДополнительныеПараметры = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ПараметрыЗапроса,
		"ДополнительныеПараметры", Новый Структура); // Структура
	Для Каждого ДополнительныйПараметр Из ДополнительныеПараметры Цикл
		ЗапросСервиса.ДополнительныеПараметры.Вставить(ДополнительныйПараметр.Ключ, ДополнительныйПараметр.Значение);
	КонецЦикла;
	
	//Данные для вызова http-запроса
	ЗапросСервиса.Наименование = НСтр("ru = 'Получение ключевых слов Бидзаар'");
	ЗапросСервиса.Сервер = ПараметрыЗапроса.Сервер;
	ЗапросСервиса.Адрес = "/api/connector/v" + ВерсияAPIБидзаар() + "/tags";
	
	СтрокаПоиска = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ПараметрыЗапроса,"СтрокаПоиска"); // Строка
	МинимальноеКоличествоИспользованийТега = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ПараметрыЗапроса,
		"МинимальноеКоличествоИспользованийТега"); // Число
	НомерСтраницы = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ПараметрыЗапроса,"НомерСтраницы"); // Число
	КоличествоКлючевыхСловНаСтранице = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ПараметрыЗапроса, 
		"КоличествоКлючевыхСловНаСтранице"); // Число
	
	МассивПараметров = Новый Массив; // Массив из строка
	Если СтрокаПоиска <> Неопределено Тогда
		МассивПараметров.Добавить("searchCriteria=" + КодироватьСтроку(СтрокаПоиска,
			 СпособКодированияСтроки.КодировкаURL));		
	КонецЕсли;
	Если МинимальноеКоличествоИспользованийТега <> Неопределено Тогда
		МассивПараметров.Добавить("usageCount=" + Формат(МинимальноеКоличествоИспользованийТега, "ЧН=0; ЧГ=;"));		
	КонецЕсли;
	Если НомерСтраницы <> Неопределено Тогда
		МассивПараметров.Добавить("page=" + Формат(НомерСтраницы,"ЧН=0; ЧГ=;"));		
	КонецЕсли;
	Если КоличествоКлючевыхСловНаСтранице <> Неопределено Тогда
		МассивПараметров.Добавить("size=" + Формат(КоличествоКлючевыхСловНаСтранице,"ЧН=0; ЧГ=;"));		
	КонецЕсли;
	
	Если МассивПараметров.Количество() Тогда
		ЗапросСервиса.Адрес = ЗапросСервиса.Адрес + "?" + СтрСоединить(МассивПараметров, "&");
	КонецЕсли;
	
	ЗапросСервиса.Метод = "GET";
	ЗапросСервиса.Аутентификация = Истина;
	
	//Заполнение заголовков http-запроса
	Заголовки = Новый Соответствие;
	Заголовки.Вставить("Accept", "*/*");
	Заголовки.Вставить("Content-Type", "application/json");
	Заголовки.Вставить("X-Bidzaar-Connector-User-Email", СокрЛП(ПараметрыЗапроса.UserEmail));
	Заголовки.Вставить("Authorization", "Bearer " + ПараметрыЗапроса.ТокенДоступа);

	ЗапросСервиса.Заголовки = Заголовки;

	Возврат ЗапросСервиса;

КонецФункции

