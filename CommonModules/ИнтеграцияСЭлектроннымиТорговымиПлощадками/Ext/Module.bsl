// Возвращает буквенный код валюты для использования в сервисе Бидзаар
//
// Параметры:
//  НаименованиеВалюты - Строка - буквенный код валюты
//  КодВалюты        - Строка - цифровой код валюты
//
// Возвращаемое значение:
//  Строка - буквенный код валюты для сервиса Бидзаар
//
Функция НаименованиеВалютыБидзаар(НаименованиеВалюты, КодВалюты)
	
	//Проверка валидности буквенного кода валюты в сервисе Бидзаар
	Если Не ПроверитьБуквенныйКодВалютыБидзаар(НаименованиеВалюты) Тогда
		//Получение буквенного кода валюты из классификатора по цифровому коду
		ДанныеВалютыПоКлассификатору = ДанныеВалютыПоКлассификатору(КодВалюты);
		Если ДанныеВалютыПоКлассификатору <> Неопределено Тогда
			Возврат ДанныеВалютыПоКлассификатору.КодВалютыБуквенный;
		КонецЕсли;
	КонецЕсли;
	
	Возврат НаименованиеВалюты;
	
КонецФункции

// Подготавливает значение адреса для выгрузки на маркетплейс Бидзаар.
//
// Параметры:
//   Адрес - Строка - исходное значение адреса
//   ОграничениеПоДлине - Число - максимальная длина возвращаемого адреса (0 - без ограничения)
//
// Возвращаемое значение:
//   - Строка - подготовленный адрес
//   - Неопределено - если передана пустая строка
Функция ОбработатьЗначениеАдресаДляВыгрузкиБидзаар(Знач Адрес, Знач ОграничениеПоДлине = 0)
	
	// Если передать пустую строку, то сервис выдает ошибку. В таком случае нужно передавать null в сервис
	Если ПустаяСтрока(Адрес) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Если ОграничениеПоДлине <> 0 Тогда
		Адрес = Сред(Адрес, 1, ОграничениеПоДлине);	
	КонецЕсли;
	
	Возврат Адрес;
	
КонецФункции

#КонецОбласти