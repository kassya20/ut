// Возвращает результат изменения данных входящего документа. 
// Изменение реквизитов входящих документов допустимо только для неформализованных документов,
// у которых нельзя получить данные из файла автоматически.
// Изменение реквизитов входящих формализованных документов недопустимо.
// 
// Параметры:
//  ИдентификаторДокумента - Строка
//  ДанныеДокумента - Структура:
//  * ВидДокумента - Неопределено - если изменение не требуется.
//                 - Структура:
//                   ** Наименование - Строка
//                   ** ТипДокумента - Строка
//  * НомерДокумента - Неопределено - если изменение не требуется.
//                   - Строка
//  * ДатаДокумента - Неопределено - если изменение не требуется.
//                  - см. ОбщегоНазначенияБЭД.ДатаВФорматеISO
//  * СуммаДокумента - Неопределено - если изменение не требуется.
//                   - Число
//
// Возвращаемое значение:
//  Структура:
//  * Успех - Булево
//  * Ошибка - Строка
//
Функция ИзменитьДанныеВходящегоДокумента(ИдентификаторДокумента, ДанныеДокумента) Экспорт
	
	Результат = Новый Структура;
	Результат.Вставить("Успех", Ложь);
	Результат.Вставить("Ошибка", "");
	
	ЭлектронныйДокумент = ДокументПоИдентификатору(ИдентификаторДокумента);

	Если Не ЗначениеЗаполнено(ЭлектронныйДокумент) Тогда
		ТекстОшибки = ТекстОшибкиНеУдалосьНайтиЭлектронныйДокументПоИдентификатору(ИдентификаторДокумента);
		Результат.Ошибка = ТекстОшибки;
		Возврат Результат;
	КонецЕсли;
	
	ДанныеДляИзменения = ЭлектронныеДокументыЭДОСлужебный.НовыеДанныеВходящегоДокументаДляИзменения();
	Если ДанныеДокумента.ВидДокумента <> Неопределено Тогда
		ДанныеДляИзменения.ВидДокумента = ВидДокументаИзФорматаСервиса(ДанныеДокумента.ВидДокумента);
	КонецЕсли;
	Если ДанныеДокумента.НомерДокумента <> Неопределено Тогда
		ДанныеДляИзменения.НомерДокумента = ДанныеДокумента.НомерДокумента;
	КонецЕсли;
	Если ДанныеДокумента.ДатаДокумента <> Неопределено Тогда
		ДанныеДляИзменения.ДатаДокумента = ОбщегоНазначенияБЭД.ДатаИзФорматаISO(ДанныеДокумента.ДатаДокумента);
	КонецЕсли;
	Если ДанныеДокумента.СуммаДокумента <> Неопределено Тогда
		ДанныеДляИзменения.СуммаДокумента = ДанныеДокумента.СуммаДокумента;
	КонецЕсли;
	
	РезультатИзменения = ЭлектронныеДокументыЭДОСлужебный.ИзменитьДанныеВходящегоДокумента(ЭлектронныйДокумент,
		ДанныеДляИзменения);
		
	Если РезультатИзменения.Успех Тогда
		Результат.Успех = Истина;
	Иначе
		ТекстОшибки = СтрШаблон(НСтр("ru = 'Не удалось изменить данные документа с идентификатором ""%1"": %2'"),
			ИдентификаторДокумента, РезультатИзменения.Ошибка);
		Результат.Ошибка = ТекстОшибки;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти // ДействияСДокументамиЭДО

#Область ДанныеДокументовЭДО

// Возвращает учетные данные основных титулов электронного документа.
// 
// Параметры:
//  ИдентификаторДокумента - Строка
// 
// Возвращаемое значение:
//  Структура:
//  * ДанныеОтправителя - Неопределено,Структура:
//    ** Данные - См. ДеревоУчетныхДанныхВСтруктуру
//    ** Формат - Строка - формат учетных данных.
//  * ДанныеПолучателя - Неопределено,Структура:
//    ** Данные - См. ДеревоУчетныхДанныхВСтруктуру
//    ** Формат - Строка - формат учетных данных.
Функция УчетныеДанныеДокумента(ИдентификаторДокумента) Экспорт
	
	Результат = Новый Структура;
	Результат.Вставить("ДанныеОтправителя", Неопределено);
	Результат.Вставить("ДанныеПолучателя", Неопределено);
	
	ЭлектронныйДокумент = ДокументПоИдентификатору(ИдентификаторДокумента);
	
	ДанныеДокумента = ЭлектронныеДокументыЭДО.ДанныеЭлектронногоДокумента(ЭлектронныйДокумент);
	
	ДанныеОтправителя = ДанныеДокумента.ДанныеОтправителя;
	Если ЗначениеЗаполнено(ДанныеОтправителя) Тогда
		УчетныеДанные = ДеревоУчетныхДанныхВСтруктуру(ДанныеОтправителя.Содержание);
		РезультатДанныеОтправителя = Новый Структура;
		РезультатДанныеОтправителя.Вставить("Данные", УчетныеДанные);
		РезультатДанныеОтправителя.Вставить("ФорматРазбора",
			СтрЗаменить(ДанныеОтправителя.ФорматРазбора, "ОбменСКонтрагентами.", ""));
		РезультатДанныеОтправителя.Вставить("ФорматТитула", ДанныеОтправителя.Формат);
		Результат.ДанныеОтправителя = РезультатДанныеОтправителя;
	КонецЕсли;
	
	ДанныеПолучателя = ДанныеДокумента.ДанныеПолучателя;
	Если ЗначениеЗаполнено(ДанныеДокумента.ДанныеПолучателя) Тогда
		УчетныеДанные = ДеревоУчетныхДанныхВСтруктуру(ДанныеПолучателя.Содержание);
		РезультатДанныеПолучателя = Новый Структура;
		РезультатДанныеПолучателя.Вставить("Данные", УчетныеДанные);
		РезультатДанныеПолучателя.Вставить("ФорматРазбора",
			СтрЗаменить(ДанныеПолучателя.ФорматРазбора, "ОбменСКонтрагентами.", ""));
		РезультатДанныеПолучателя.Вставить("ФорматТитула", ДанныеПолучателя.Формат);
		Результат.ДанныеПолучателя = РезультатДанныеПолучателя;
	КонецЕсли;
	
	Возврат Результат
	
КонецФункции

// Возвращает информацию о номенклатуре из файлов основных титулов электронных документов.
// 
// Параметры:
//  ИдентификаторыДокументов - Массив из Строка
// 
// Возвращаемое значение:
//  Массив из Структура:
//  * ИдентификаторДокумента - Строка
//  * СведенияОНоменклатуре - Массив из Структура:
//  ** ИД - Строка
//  ** Штрихкод - Строка
//  ** Наименование - Строка
//  ** НаименованиеХарактеристики - Строка
//  ** КодТовара - Строка
//  ** Артикул - Строка
//  ** БазоваяЕдиницаКод - Строка
//  ** БазоваяЕдиницаНаименование - Строка
//  ** БазоваяЕдиницаНаименованиеПолное - Строка
//  ** БазоваяЕдиницаМеждународноеСокращение - Строка
//  ** БазоваяЕдиницаНаименованиеКраткое - Строка
//  ** СтавкаНДС - Строка
//  ** Описание - Строка
//  ** ИсторияИдентификаторов - Массив из см. СопоставлениеНоменклатурыКонтрагентов.ИдентификаторТовараПоДаннымНоменклатуры
//  ** ТипНоменклатурыФНС - Строка
//  ** КодПоКТРУ - Строка
//  ** КодТНВЭД - Строка
//  ** СтранаПроисхожденияКод - Строка
//  ** ПрослеживаемыйТовар - Булево
//  ** МаркируемыйТовар - Булево
//
Функция СведенияНоменклатурыДокументовЭДО(ИдентификаторыДокументов) Экспорт
	
	СведенияНоменклатурыДокументов = Новый Массив; // См. СведенияНоменклатурыДокументовЭДО
	
	ПараметрыПолученияДанныхДокументов = ПараметрыПолученияДанныхДокументовЭДО(ИдентификаторыДокументов);
	
	Для Каждого ПараметрыПолученияДанныхДокумента Из ПараметрыПолученияДанныхДокументов Цикл
		
		СведенияНоменклатурыДокумента = НовыеСведенияНоменклатурыДокумента();
		СведенияНоменклатурыДокумента.ИдентификаторДокумента = ПараметрыПолученияДанныхДокумента.Ключ;
		СведенияНоменклатуры = СведенияНоменклатурыДокумента.СведенияНоменклатуры;
		
		ИнформацияОТовареИзФайла = ФорматыЭДО.ИнформацияОТовареИзФайла(ПараметрыПолученияДанныхДокумента.Значение);
		
		Для Каждого СтрокаТовара Из ИнформацияОТовареИзФайла Цикл
			
			СведенияНоменклатурнойПозиции = НовыеСведенияНоменклатурнойПозиции();
			ЗаполнитьЗначенияСвойств(СведенияНоменклатурнойПозиции, СтрокаТовара);
			СведенияНоменклатурнойПозиции.ИмяТипаНоменклатурыФНС = ОбщегоНазначения.ИмяЗначенияПеречисления(
				СтрокаТовара.ТипНоменклатурыФНС);
			СведенияНоменклатуры.Добавить(СведенияНоменклатурнойПозиции);
			
		КонецЦикла;
		
		СведенияНоменклатурыДокументов.Добавить(СведенияНоменклатурыДокумента);
		
	КонецЦикла;
	
	Возврат СведенияНоменклатурыДокументов;
	
КонецФункции

// Возвращает учетные данные из файлов основных титулов электронных документов.
// 
// Параметры:
//  ИдентификаторыДокументов - Массив из Строка
// 
// Возвращаемое значение:
//  Массив из Структура:
//  * ИдентификаторДокумента - Строка
//  * УчетныеДанные - Структура - данные прикладного решения:
//  ** Данные - См. ДеревоУчетныхДанныхВСтруктуру
//  ** Формат - Строка - формат учетных данных.
//
Функция УчетныеДанныеОтправителейДокументовЭДО(ИдентификаторыДокументов) Экспорт
	
	НаборДанныхОтражения = Новый Массив; // См. УчетныеДанныеОтправителейДокументовЭДО
	
	ПараметрыПолученияДанныхДокументов = ПараметрыПолученияДанныхДокументовЭДО(ИдентификаторыДокументов);
	
	Для Каждого ПараметрыПолученияДанныхДокумента Из ПараметрыПолученияДанныхДокументов Цикл
		
		ДанныеДокумента = ФорматыЭДО.ДанныеЭлектронногоДокумента(ПараметрыПолученияДанныхДокумента.Значение);
		ДеревоУчетныхДанных = ДанныеДокумента.НовыйЭД.ЗначениеРеквизита;
		
		ДанныеДляОтражения = НовыеУчетныеДанныеДляОтраженияДокумента();
		ДанныеДляОтражения.ИдентификаторДокумента = ПараметрыПолученияДанныхДокумента.Ключ;
		ДанныеДляОтражения.УчетныеДанные.Формат = ИмяМакетаДереваИзПути(ДанныеДокумента.НовыйЭД.ФорматРазбора);
		ДанныеДляОтражения.УчетныеДанные.Данные = ДеревоУчетныхДанныхВСтруктуру(ДеревоУчетныхДанных);
		НаборДанныхОтражения.Добавить(ДанныеДляОтражения);
		
	КонецЦикла;
	
	Возврат НаборДанныхОтражения;
	
КонецФункции

// Параметры:
//  ИдентификаторыДокументовЭДО - Массив из Строка
// 
// Возвращаемое значение:
//  См. ДанныеСинхронизацииДокументовЭДОПоИдентификаторам
Функция ДанныеСинхронизацииДокументовЭДО(ИдентификаторыДокументовЭДО) Экспорт
	
	Если Не ЗначениеЗаполнено(ИдентификаторыДокументовЭДО) Тогда
		Возврат Новый Массив;
	КонецЕсли;
	
	Если ЦентрЭДО.АвторизованСлужебныйПользователь() Тогда
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;
	
	ДанныеСинхронизации = ДанныеСинхронизацииДокументовЭДОПоИдентификаторам(ИдентификаторыДокументовЭДО);
	
	Возврат ДанныеСинхронизации;
	
КонецФункции

// Возвращает порцию сведений по документам ЭДО.
// 
// Параметры:
//  МеткиВремениПоИдентификаторамЭДО - Массив из Структура:
//  * МеткаВремени - Число
//  * ИдентификаторЭДО - Строка
// 
// Возвращаемое значение:
//  Структура:
//  * ЭтоПоследний - Булево
//  * НаборДанных - см. ДанныеСинхронизацииДокументовЭДО
Функция ПорцияДанныхСинхронизацииДокументовЭДОПоМеткамВремени(МеткиВремениПоИдентификаторамЭДО) Экспорт
	
	ПорцияДанных = Новый Структура;
	ПорцияДанных.Вставить("ЭтоПоследний", Истина);
	ПорцияДанных.Вставить("НаборДанных", Новый Массив);
	
	Если Не ЗначениеЗаполнено(МеткиВремениПоИдентификаторамЭДО) Тогда
		Возврат ПорцияДанных;
	КонецЕсли;
	
	Если ЦентрЭДО.АвторизованСлужебныйПользователь() Тогда
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;
	
	Порция = 1000;
	
	НаборДанных = ДанныеСинхронизацииДокументовЭДОПоМеткамВремени(МеткиВремениПоИдентификаторамЭДО, Порция);
	
	ПорцияДанных.ЭтоПоследний = НаборДанных.Количество() < Порция;
	ПорцияДанных.НаборДанных = НаборДанных;
	
	Возврат ПорцияДанных;
	
КонецФункции

// Параметры:
//  МеткиВремениПоИдентификаторамЭДО - Массив из Структура:
//  * МеткаВремени - Число
//  * ИдентификаторЭДО - Строка
// 
// Возвращаемое значение:
//  См. ПрограммныйИнтерфейсЦентраЭДОВерсия3.ПорцияМетокВремениПолныхДанныхДокументовЭДО
Функция ПорцияМетокВремениПолныхДанныхДокументовЭДО(МеткиВремениПоИдентификаторамЭДО) Экспорт
	
	ПорцияДанных = Новый Структура;;
	ПорцияДанных.Вставить("ЭтоПоследний", Истина);
	ПорцияДанных.Вставить("НаборДанных", Новый Массив);
	
	Если Не ЗначениеЗаполнено(МеткиВремениПоИдентификаторамЭДО) Тогда
		Возврат ПорцияДанных;
	КонецЕсли;
	
	Если ЦентрЭДО.АвторизованСлужебныйПользователь() Тогда
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;
	
	Порция = 1000;
	ТипДанных = Перечисления.ТипыСинхронизацииСЦентромЭДО.ДанныеДокументовЭДО;
	
	Выборка = МеткиВремениДанныхЭДО.ВыборкаИдентификаторовДанныхПоМеткамВремени(ТипДанных,
		МеткиВремениПоИдентификаторамЭДО, Порция);
	
	НаборДанных = ПорцияДанных.НаборДанных; // Массив из Структура
	Пока Выборка.Следующий() Цикл
		МеткаВремениДокумента = Новый Структура;
		МеткаВремениДокумента.Вставить("ИдентификаторОбъекта", Выборка.ИдентификаторОбъекта);
		МеткаВремениДокумента.Вставить("ИдентификаторЭДО", Выборка.ИдентификаторЭДО);
		МеткаВремениДокумента.Вставить("МеткаВремени", Выборка.МеткаВремени);
		НаборДанных.Добавить(МеткаВремениДокумента);
	КонецЦикла;
	
	ПорцияДанных.ЭтоПоследний = НаборДанных.Количество() < Порция;
	
	Возврат ПорцияДанных;
	
КонецФункции

// Возвращает сведения по документам ЭДО.
//
// Параметры:
//  ИдентификаторДокументаЭДО - Строка
//  МеткаВремени - Число
// 
// Возвращаемое значение:
//  См. ПрограммныйИнтерфейсЦентраЭДОВерсия3.ДанныеПолнойСинхронизацииДокументаЭДО
Функция ДанныеПолнойСинхронизацииДокументаЭДО(ИдентификаторДокументаЭДО, МеткаВремени = 0) Экспорт
	
	Если ЦентрЭДО.АвторизованСлужебныйПользователь() Тогда
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;
	
	ДанныеСинхронизации = НовыеДанныеПолнойСинхронизацииДокументаЭДО();
	
	ДанныеСинхронизации.МеткаВремени = МеткиВремениДанныхЭДО.МеткаВремениДанныхДокументаЭДО(ИдентификаторДокументаЭДО);
	
	КлючиДанныхПоТипам = МеткиВремениДанныхЭДО.КлючиДанныхДокументаПоТипам(
		ИдентификаторДокументаЭДО, МеткаВремени);
	
	Если ЗначениеЗаполнено(КлючиДанныхПоТипам.Сообщения) Тогда
		ДанныеСинхронизации.Сообщения = ДанныеСообщенийПолнойСинхронизацииДокумента(КлючиДанныхПоТипам.Сообщения,
			ИдентификаторДокументаЭДО);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(КлючиДанныхПоТипам.ФайлыСообщений) Тогда
		ДанныеСинхронизации.ФайлыСообщений = ДанныеФайловСообщенийПолнойСинхронизацииДокумента(
			КлючиДанныхПоТипам.ФайлыСообщений);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(КлючиДанныхПоТипам.ПодписиФайлов) Тогда
		ДанныеСинхронизации.ПодписиФайлов = ДанныеПодписейФайловПолнойСинхронизацииДокумента(
			КлючиДанныхПоТипам.ПодписиФайлов);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(КлючиДанныхПоТипам.ПроверкиПодписейПоМЧД) Тогда
		ДанныеСинхронизации.ПроверкиПодписейПоМЧД = ДанныеПроверокПодписейПолнойСинхронизацииДокумента(
			КлючиДанныхПоТипам.ПроверкиПодписейПоМЧД);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(КлючиДанныхПоТипам.События) Тогда
		ДанныеСинхронизации.События = СобытияПолнойСинхронизацииДокумента(КлючиДанныхПоТипам.События,
			ИдентификаторДокументаЭДО);
	КонецЕсли;
	
	Возврат ДанныеСинхронизации;
	
КонецФункции

// Возвращает метки времени изменения документов по идентификаторам.
//
// Параметры:
//  ИдентификаторыДокументовЭДО - Массив из Строка
// 
// Возвращаемое значение:
//  Массив из Структура:
//  * ИдентификаторДокументаЭДО - Строка
//  * МеткаВремени - Число
Функция МеткиВремениДокументовЭДО(ИдентификаторыДокументовЭДО) Экспорт
	
	Возврат МеткиВремениДокументовЭДОПоТипуСинхронизации(ИдентификаторыДокументовЭДО,
		Перечисления.ТипыСинхронизацииСЦентромЭДО.ДокументыЭДО);
	
КонецФункции

// Возвращает метки времени изменения полных данных документов по идентификаторам.
//
// Параметры:
//  ИдентификаторыДокументовЭДО - Массив из Строка
// 
// Возвращаемое значение:
//  Массив из Структура:
//  * ИдентификаторДокументаЭДО - Строка
//  * МеткаВремени - Неопределено,Число
Функция МеткиВремениПолныхДанныхДокументовЭДО(ИдентификаторыДокументовЭДО) Экспорт
	
	Возврат МеткиВремениДокументовЭДОПоТипуСинхронизации(ИдентификаторыДокументовЭДО,
		Перечисления.ТипыСинхронизацииСЦентромЭДО.ДанныеДокументовЭДО);
	
КонецФункции

// Возвращает метки времени последних изменений документов по идентификаторам ЭДО.
//
// Параметры:
//  ИдентификаторыЭДО - Массив из Строка
// 
// Возвращаемое значение:
//  Массив из Структура:
//  * ИдентификаторЭДО - Строка
//  * МеткаВремени - Неопределено,Число
Функция ПоследниеМеткиВремениДокументовЭДО(ИдентификаторыЭДО) Экспорт
	
	Возврат МеткиВремениДанныхЭДО.ПоследниеМеткиВремениОбъектов(ИдентификаторыЭДО,
		Перечисления.ТипыСинхронизацииСЦентромЭДО.ДокументыЭДО);
	
КонецФункции

// Возвращает метки времени последних изменений полных данных документов по идентификаторам ЭДО.
//
// Параметры:
//  ИдентификаторыЭДО - Массив из Строка
// 
// Возвращаемое значение:
//  Массив из Структура:
//  * ИдентификаторЭДО - Строка
//  * МеткаВремени - Неопределено,Число
Функция ПоследниеМеткиВремениПолныхДанныхДокументовЭДО(ИдентификаторыЭДО) Экспорт
	
	Возврат МеткиВремениДанныхЭДО.ПоследниеМеткиВремениОбъектов(ИдентификаторыЭДО,
		Перечисления.ТипыСинхронизацииСЦентромЭДО.ДанныеДокументовЭДО);
	
КонецФункции

// Параметры:
//  ИдентификаторДокументаЭДО - Строка
//  МеткаВремени - Число
// 
// Возвращаемое значение:
//  См. ПрограммныйИнтерфейсЦентраЭДОВерсия3.ДанныеПолнойСинхронизацииДокументаЭДО
Функция ДанныеПолнойСинхронизацииДокументаЭДОВерсия3(ИдентификаторДокументаЭДО, МеткаВремени = 0) Экспорт
		
	Если ЦентрЭДО.АвторизованСлужебныйПользователь() Тогда
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;
	
	ДанныеСинхронизации = НовыеДанныеПолнойСинхронизацииДокументаЭДОВерсия3();
	
	ДанныеСинхронизации.МеткаВремени = МеткиВремениДанныхЭДО.МеткаВремениДанныхДокументаЭДО(ИдентификаторДокументаЭДО);
	
	КлючиДанныхПоТипам = МеткиВремениДанныхЭДО.КлючиДанныхДокументаПоТипам(
		ИдентификаторДокументаЭДО, МеткаВремени);
	
	Если ЗначениеЗаполнено(КлючиДанныхПоТипам.Сообщения) Тогда
		ДанныеСинхронизации.Сообщения = ДанныеСообщенийПолнойСинхронизацииДокумента(КлючиДанныхПоТипам.Сообщения,
			ИдентификаторДокументаЭДО);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(КлючиДанныхПоТипам.ФайлыСообщений) Тогда
		ДанныеСинхронизации.ФайлыСообщений = ДанныеФайловСообщенийПолнойСинхронизацииДокумента(
			КлючиДанныхПоТипам.ФайлыСообщений);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(КлючиДанныхПоТипам.ПодписиФайлов) Тогда
		ДанныеСинхронизации.ПодписиФайлов = ДанныеПодписейФайловПолнойСинхронизацииДокумента(
			КлючиДанныхПоТипам.ПодписиФайлов);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(КлючиДанныхПоТипам.ПроверкиПодписейПоМЧД) Тогда
		ДанныеСинхронизации.ПроверкиПодписейПоМЧД = ДанныеПроверокПодписейПолнойСинхронизацииДокументаВерсия3(
			КлючиДанныхПоТипам.ПроверкиПодписейПоМЧД);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(КлючиДанныхПоТипам.События) Тогда
		ДанныеСинхронизации.События = СобытияПолнойСинхронизацииДокумента(КлючиДанныхПоТипам.События,
			ИдентификаторДокументаЭДО);
	КонецЕсли;
	
	Возврат ДанныеСинхронизации;
	
КонецФункции

#КонецОбласти // ДанныеДокументовЭДО

#Область ПроверкаПодписей

// Возвращает результат проверок подписей документов ЭДО.
// 
// Параметры:
//  ИдентификаторыДокументовЭДО - Массив из Строка
// 
// Возвращаемое значение:
//  Массив из Структура:
//  * ИдентификаторДокумента - Строка
//  * Ошибка - Неопределено,Строка
Функция ПроверитьПодписиДокументовЭДО(ИдентификаторыДокументовЭДО) Экспорт
	
	РезультатПоДокументам = Новый Массив; // См. ПроверитьПодписиДокументовЭДО
	
	ДокументыПоИдентификаторам = ДокументыПоИдентификаторам(ИдентификаторыДокументовЭДО);
	
	Для Каждого ДокументПоИдентификатору Из ДокументыПоИдентификаторам Цикл
		
		ИдентификаторДокумента = ДокументПоИдентификатору.Ключ;
		ЭлектронныйДокумент = ДокументПоИдентификатору.Значение;
		
		КонтекстДиагностики = ОбработкаНеисправностейБЭД.НовыйКонтекстДиагностики();
		РезультатПроверки = ЭлектронныеДокументыЭДО.ПроверитьПодписиДокумента(ЭлектронныйДокумент, КонтекстДиагностики);
		
		Ошибка = Неопределено;
		Если Не РезультатПроверки.Успех Тогда
			
			ТекстОшибок = ОбработкаНеисправностейБЭД.ТекстОшибокКонтекстаДиагностики(КонтекстДиагностики);
			Если ЗначениеЗаполнено(ТекстОшибок) Тогда
				Ошибка = ТекстОшибок;
			Иначе
				Ошибка = НСтр("ru = 'Неизвестная ошибка'");
			КонецЕсли;
			
		КонецЕсли;
		
		РезультатПроверкиВФорматеСервиса = Новый Структура("ИдентификаторДокумента, Ошибка",
			ИдентификаторДокумента, Ошибка);
		
		РезультатПоДокументам.Добавить(РезультатПроверкиВФорматеСервиса);
		
	КонецЦикла;
	
	Возврат РезультатПоДокументам;
	
КонецФункции

#КонецОбласти // ПроверкаПодписей

#Область ПереходВЦентрЭДО

// См. ПрограммныйИнтерфейсЦентраЭДОВерсия3.ЗагрузитьПолныеДанныеДокументаЭДО
Функция ЗагрузитьПолныеДанныеДокументаЭДО(ПолныеДанные) Экспорт
	
	Если ЦентрЭДО.АвторизованСлужебныйПользователь() Тогда
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;
	
	Результат = Новый Структура;
	Результат.Вставить("Ошибка", Неопределено);
	Результат.Вставить("Сопоставление", Неопределено);
	
	ЭтоВходящийЭДО = ПолныеДанные.Описание.ЭтоВходящийЭДО;
	ИдентификаторДокументооборота = ПолныеДанные.Описание.ИдентификаторДокументооборота;
	
	НачатьТранзакцию();
	Попытка
		КлючБлокировкиДокумента = ЭлектронныеДокументыЭДО.НовыйКлючДокументаДляБлокировки();
		КлючБлокировкиДокумента.ИдентификаторДокументооборота = ИдентификаторДокументооборота;
		ЭлектронныеДокументыЭДО.ЗаблокироватьДокументДляИзмененияПоКлючу(КлючБлокировкиДокумента, ЭтоВходящийЭДО);
		
		Результат.Сопоставление = ЗагрузитьСопоставитьДокументИзПолныхДанных(ПолныеДанные);
		
		ЗафиксироватьТранзакцию();
	Исключение
		ОтменитьТранзакцию();
		
		ШаблонСообщения = СтрШаблон(НСтр("ru = 'Не удалось загрузить данные электронного документа
			|с идентификатором документооборота %1 по причине:'"), ИдентификаторДокументооборота);
		
		ИнформацияОбОшибке = ИнформацияОбОшибке();
		Кратко = ОбработкаОшибок.КраткоеПредставлениеОшибки(ИнформацияОбОшибке);
		Подробно = ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке);
		
		Результат.Ошибка = ШаблонСообщения + Символы.ПС + Кратко;
		
		ОбщегоНазначенияБЭД.ЗаписатьВЖурналРегистрации(ШаблонСообщения + Символы.ПС + Подробно,
			ЦентрЭДО.ИмяПодсистемы(), УровеньЖурналаРегистрации.Ошибка);
	КонецПопытки;
	
	Возврат Результат;
	
КонецФункции

// См. ПрограммныйИнтерфейсЦентраЭДОВерсия3.ЗагрузитьПолныеДанныеПакетаДокументовЭДО
Функция ЗагрузитьПолныеДанныеПакетаДокументовЭДО(ПолныеДанныеПакета) Экспорт
	
	Результат = Новый Структура;
	Результат.Вставить("Ошибка", Неопределено);
	Результат.Вставить("Сопоставление", Неопределено);
	
	Если Не ЗначениеЗаполнено(ПолныеДанныеПакета) Тогда
		Результат.Ошибка = НСтр("ru = 'Отсутствуют полные данные пакета документов ЭДО для загрузки.'");
		Возврат Результат;
	КонецЕсли;
	
	Если ЦентрЭДО.АвторизованСлужебныйПользователь() Тогда
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;
	
	КлючиДокументовДляБлокировки = Новый Массив; // Массив из См. ЭлектронныеДокументыЭДО.НовыйКлючДокументаДляБлокировки
	Для Каждого ПолныеДанные Из ПолныеДанныеПакета Цикл
		ЭтоВходящийПакетДокументов = ПолныеДанные.Описание.ЭтоВходящийЭДО; // Булево
		ИдентификаторДокументооборота = ПолныеДанные.Описание.ИдентификаторДокументооборота; // Строка
		
		КлючДокументаДляБлокировки = ЭлектронныеДокументыЭДО.НовыйКлючДокументаДляБлокировки();
		КлючДокументаДляБлокировки.ИдентификаторДокументооборота = ИдентификаторДокументооборота;
		КлючиДокументовДляБлокировки.Добавить(КлючДокументаДляБлокировки);
	КонецЦикла;
	
	НачатьТранзакцию();
	Попытка
		ЭлектронныеДокументыЭДО.ЗаблокироватьДокументыДляИзмененияПоКлючам(КлючиДокументовДляБлокировки,
			ЭтоВходящийПакетДокументов);
		
		Сопоставление = Новый Массив; // Массив из см. ЗагрузитьСопоставитьДокументИзПолныхДанных
		ИдентификаторыДокументов = Новый Массив; // Массив из Строка
		
		Для Каждого ПолныеДанные Из ПолныеДанныеПакета Цикл
			
			СопоставлениеПоДокументу = ЗагрузитьСопоставитьДокументИзПолныхДанных(ПолныеДанные);
			Сопоставление.Добавить(СопоставлениеПоДокументу);
			
			ИдентификаторыДокументов.Добавить(СопоставлениеПоДокументу.Документ.Идентификатор);
			
		КонецЦикла;
		
		Результат.Сопоставление = Сопоставление;
		
		ИдентификаторПакета = Новый УникальныйИдентификатор(ПолныеДанныеПакета[0].Описание.ИдентификаторПакета);
		ДокументыПоИдентификаторам = ДокументыПоИдентификаторам(ИдентификаторыДокументов);
		Блокировка = Новый БлокировкаДанных;
		Для Каждого ДокументПоИдентификатору Из ДокументыПоИдентификаторам Цикл
			ЭлементБлокировки = Блокировка.Добавить("РегистрСведений.СоставПакетовДокументовЭДО");
			ЭлементБлокировки.УстановитьЗначение("ЭлектронныйДокумент", ДокументПоИдентификатору.Значение);
		КонецЦикла;
		ЭлементБлокировки = Блокировка.Добавить("РегистрСведений.ПакетыДокументовЭДО");
		ЭлементБлокировки.УстановитьЗначение("ИдентификаторПакета", ИдентификаторПакета);
		Блокировка.Заблокировать();
		
		ОбъединитьДокументыВПакет(ИдентификаторПакета,
			ОбщегоНазначения.ВыгрузитьКолонку(ДокументыПоИдентификаторам, "Значение"));
		
		ЗафиксироватьТранзакцию();
	Исключение
		ОтменитьТранзакцию();
		
		ШаблонСообщения = СтрШаблон(НСтр("ru = 'Не удалось загрузить пакет электронных документов
			|с идентификатором %1 по причине:'"), Строка(ИдентификаторПакета));
		
		ИнформацияОбОшибке = ИнформацияОбОшибке();
		Кратко = ОбработкаОшибок.КраткоеПредставлениеОшибки(ИнформацияОбОшибке);
		Подробно = ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке);
		
		Результат.Ошибка = ШаблонСообщения + Символы.ПС + Кратко;
		
		ОбщегоНазначенияБЭД.ЗаписатьВЖурналРегистрации(ШаблонСообщения + Символы.ПС + Подробно,
			ЦентрЭДО.ИмяПодсистемы(), УровеньЖурналаРегистрации.Ошибка);
	КонецПопытки;
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти

#КонецОбласти // СлужебныйПрограммныйИнтерфейс

#Область СлужебныеПроцедурыИФункции

#Область ОбработкаСобытий

Процедура ПроверитьУникальностьИдентификатораДокументаЭДОПередЗаписью(Источник, Отказ, РежимЗаписи, РежимПроведения) Экспорт
	
	Если Источник.ОбменДанными.Загрузка Тогда
		Возврат;
	КонецЕсли;
	
	Если Не Источник.ЭтоНовый() Или ПустаяСтрока(Источник.ИдентификаторДокумента) Тогда
		Возврат;
	КонецЕсли;
	
	КлючБлокировкиДокумента = ЭлектронныеДокументыЭДО.НовыйКлючДокументаДляБлокировки();
	КлючБлокировкиДокумента.ИдентификаторДокумента = Источник.ИдентификаторДокумента;
	ЭлектронныеДокументыЭДО.ЗаблокироватьДокументДляИзмененияПоКлючу(КлючБлокировкиДокумента);
	
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	ЭлектронныйДокументИсходящийЭДО.Ссылка КАК Ссылка
		|ИЗ
		|	Документ.ЭлектронныйДокументИсходящийЭДО КАК ЭлектронныйДокументИсходящийЭДО
		|ГДЕ
		|	ЭлектронныйДокументИсходящийЭДО.ИдентификаторДокумента = &ИдентификаторДокумента";
	
	Запрос.УстановитьПараметр("ИдентификаторДокумента", Источник.ИдентификаторДокумента);
	
	УстановитьПривилегированныйРежим(Истина);
	РезультатЗапроса = Запрос.Выполнить();
	УстановитьПривилегированныйРежим(Ложь);
	
	Если Не РезультатЗапроса.Пустой() Тогда
		ТекстОшибки = СтрШаблон(НСтр("ru = 'Электронный документ с идентификатором %1 уже существует'"),
			Источник.ИдентификаторДокумента);
		ВызватьИсключение(ТекстОшибки,
			КатегорияОшибки.ИсключениеВызванноеИзВстроенногоЯзыка,
			КодИсключенияДокументУжеСуществует());
	КонецЕсли;
	
КонецПроцедуры

// Возвращаемое значение:
//  Строка
Функция КодИсключенияДокументУжеСуществует()
	Возврат ЦентрЭДО.ИмяПодсистемы() + ".ДокументУжеСуществует";
КонецФункции

#КонецОбласти

#Область ОбщегоНазначения

// Параметры:
//  ИдентификаторыДокументов - Массив из Строка
// 
// Возвращаемое значение:
//  Массив из ДокументСсылка.ЭлектронныйДокументВходящийЭДО,ДокументСсылка.ЭлектронныйДокументИсходящийЭДО
Функция ДокументыЭДО(ИдентификаторыДокументов) Экспорт
	
	ДокументыЭДО = Новый Массив; // См. ДокументыЭДО
	
	Если Не ЗначениеЗаполнено(ИдентификаторыДокументов) Тогда
		Возврат ДокументыЭДО;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ЭлектронныйДокументВходящийЭДО.Ссылка КАК Ссылка
		|ИЗ
		|	Документ.ЭлектронныйДокументВходящийЭДО КАК ЭлектронныйДокументВходящийЭДО
		|ГДЕ
		|	ЭлектронныйДокументВходящийЭДО.ИдентификаторДокумента В(&ИдентификаторыДокументов)
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	ЭлектронныйДокументИсходящийЭДО.Ссылка
		|ИЗ
		|	Документ.ЭлектронныйДокументИсходящийЭДО КАК ЭлектронныйДокументИсходящийЭДО
		|ГДЕ
		|	ЭлектронныйДокументИсходящийЭДО.ИдентификаторДокумента В(&ИдентификаторыДокументов)";
	
	Запрос.УстановитьПараметр("ИдентификаторыДокументов", ИдентификаторыДокументов);
	
	УстановитьПривилегированныйРежим(Истина);
	Выборка = Запрос.Выполнить().Выбрать();
	УстановитьПривилегированныйРежим(Ложь);
	
	Пока Выборка.Следующий() Цикл
		ДокументыЭДО.Добавить(Выборка.Ссылка);
	КонецЦикла;
	
	Возврат ДокументыЭДО;
	
КонецФункции

// Параметры:
//  ИдентификаторДокумента - Строка
// 
// Возвращаемое значение:
//  Неопределено,ДокументСсылка.ЭлектронныйДокументИсходящийЭДО,ДокументСсылка.ЭлектронныйДокументВходящийЭДО
Функция ДокументПоИдентификатору(ИдентификаторДокумента) Экспорт
	
	ДокументЭДО = Неопределено;
	Если Не ЗначениеЗаполнено(ИдентификаторДокумента) Тогда
		Возврат ДокументЭДО;
	КонецЕсли;
	
	ДокументыПоИдентификаторам = ДокументыПоИдентификаторам(
		ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(ИдентификаторДокумента));
	
	Возврат ДокументыПоИдентификаторам[ИдентификаторДокумента];
	
КонецФункции

// Параметры:
//  ИдентификаторыДокументов - Массив из Строка
// 
// Возвращаемое значение:
//  Соответствие из КлючИЗначение:
//  * Ключ - Строка - идентификатор документа ЭДО.
//  * Значение - ДокументСсылка.ЭлектронныйДокументВходящийЭДО,ДокументСсылка.ЭлектронныйДокументИсходящийЭДО
Функция ДокументыПоИдентификаторам(ИдентификаторыДокументов)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	ЭлектронныйДокументВходящийЭДО.Ссылка КАК Ссылка,
		|	ЭлектронныйДокументВходящийЭДО.ИдентификаторДокумента КАК ИдентификаторДокумента
		|ИЗ
		|	Документ.ЭлектронныйДокументВходящийЭДО КАК ЭлектронныйДокументВходящийЭДО
		|ГДЕ
		|	ЭлектронныйДокументВходящийЭДО.ИдентификаторДокумента В (&ИдентификаторыДокументов)
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	ЭлектронныйДокументИсходящийЭДО.Ссылка КАК Ссылка,
		|	ЭлектронныйДокументИсходящийЭДО.ИдентификаторДокумента КАК ИдентификаторДокумента
		|ИЗ
		|	Документ.ЭлектронныйДокументИсходящийЭДО КАК ЭлектронныйДокументИсходящийЭДО
		|ГДЕ
		|	ЭлектронныйДокументИсходящийЭДО.ИдентификаторДокумента В (&ИдентификаторыДокументов)";
	
	Запрос.УстановитьПараметр("ИдентификаторыДокументов", ИдентификаторыДокументов);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ДокументыПоИдентификаторам = Новый Соответствие;
	
	Если РезультатЗапроса.Пустой() Тогда
		Возврат ДокументыПоИдентификаторам;
	КонецЕсли;
	
	Выборка = РезультатЗапроса.Выбрать();
	Пока Выборка.Следующий() Цикл
		ДокументыПоИдентификаторам.Вставить(Выборка.ИдентификаторДокумента, Выборка.Ссылка);
	КонецЦикла;
	
	Возврат ДокументыПоИдентификаторам;
	
КонецФункции

// Параметры:
//  ДокументыЭДО - Массив из ДокументСсылка.ЭлектронныйДокументВходящийЭДО,ДокументСсылка.ЭлектронныйДокументИсходящийЭДО
// 
// Возвращаемое значение:
//  Массив из См. НовоеСостояниеДокументаЭДОВФорматеСервиса
Функция СостоянияДокументовЭДОВФорматеСервиса(ДокументыЭДО)
	
	СостоянияДокументовЭДО = Новый Массив; // См. СостоянияДокументовЭДОВФорматеСервиса
	
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ
		|	СостоянияДокументовЭДО.ЭлектронныйДокумент.ИдентификаторДокумента КАК ИдентификаторДокумента,
		|	СостоянияДокументовЭДО.Состояние КАК Состояние,
		|	СостоянияДокументовЭДО.СостояниеДополнение КАК СостояниеДополнение,
		|	СостоянияДокументовЭДО.ДатаИзменения КАК ДатаИзменения,
		|	СостоянияДокументовЭДО.Комментарий КАК Комментарий
		|ИЗ
		|	РегистрСведений.СостоянияДокументовЭДО КАК СостоянияДокументовЭДО
		|ГДЕ
		|	СостоянияДокументовЭДО.ЭлектронныйДокумент В (&ЭлектронныеДокументы)";
	
	Запрос.УстановитьПараметр("ЭлектронныеДокументы", ДокументыЭДО);
	
	РезультатЗапроса = Запрос.Выполнить();
	Если РезультатЗапроса.Пустой() Тогда
		Возврат СостоянияДокументовЭДО;
	КонецЕсли;
	
	Выборка = РезультатЗапроса.Выбрать();
	Пока Выборка.Следующий() Цикл
		СостояниеДокументаЭДО = НовоеСостояниеДокументаЭДОВФорматеСервиса();
		СостояниеДокументаЭДО.ИдентификаторДокумента = Выборка.ИдентификаторДокумента;
		СостояниеДокументаЭДО.ИмяСостояния = ОбщегоНазначения.ИмяЗначенияПеречисления(Выборка.Состояние);
		СостояниеДокументаЭДО.СостояниеДополнение = Выборка.СостояниеДополнение;
		СостояниеДокументаЭДО.ДатаИзменения = ОбщегоНазначенияБЭД.ДатаВФорматеISO(Выборка.ДатаИзменения);
		СостояниеДокументаЭДО.Комментарий = Выборка.Комментарий;
		СостоянияДокументовЭДО.Добавить(СостояниеДокументаЭДО);
	КонецЦикла;
	
	Возврат СостоянияДокументовЭДО
	
КонецФункции

// Параметры:
//  РеквизитыКлючейНастроек - Массив из Структура:
//  * Идентификатор - Строка
//  * Отправитель - Структура:
//    ** ИНН - Строка
//    ** КПП - Строка
//  * Получатель - Структура:
//    ** ИНН - Строка
//    ** КПП - Строка
//  * ВидДокумента - Структура:
//    ** Наименование - Строка
//    ** ТипДокумента - Строка
// 
// Возвращаемое значение:
//  Соответствие из КлючИЗначение:
//  * Ключ - Строка - идентификатор ключа настройки.
//  * Значение - См. НастройкиЭДОКлиентСервер.НовыйКлючНастроекОтправки
Функция КлючиНастроекПоРеквизитам(РеквизитыКлючейНастроек)
	
	КлючиНастроек = Новый Соответствие;
	
	РеквизитыОрганизаций = Новый Массив; // Массив из см. ИнтеграцияЭДО.НовыеКлючевыеРеквизитыУчастникаЭДО
	РеквизитыКонтрагентов = Новый Массив; // Массив из см. ИнтеграцияЭДО.НовыеКлючевыеРеквизитыУчастникаЭДО
	ВидыДокументовВФорматеСервиса = Новый Массив; // См. ВидыДокументовИзФорматаСервиса.ВидыДокументовВФорматеСервиса
	
	Для Каждого РеквизитыКлючаНастройки Из РеквизитыКлючейНастроек Цикл
		ОбщегоНазначенияБЭД.ДобавитьЗаполненноеЗначение(РеквизитыОрганизаций, РеквизитыКлючаНастройки.Отправитель);
		ОбщегоНазначенияБЭД.ДобавитьЗаполненноеЗначение(РеквизитыКонтрагентов, РеквизитыКлючаНастройки.Получатель);
		ОбщегоНазначенияБЭД.ДобавитьЗаполненноеЗначение(ВидыДокументовВФорматеСервиса, РеквизитыКлючаНастройки.ВидДокумента);
	КонецЦикла;
	
	ОрганизацииПоРеквизитам = ИнтеграцияЭДО.ОрганизацииПоКлючевымРеквизитам(РеквизитыОрганизаций);
	КонтрагентыПоРеквизитам = ИнтеграцияЭДО.КонтрагентыПоКлючевымРеквизитам(РеквизитыКонтрагентов);
	ВидыДокументовИзФорматаСервиса = ВидыДокументовИзФорматаСервиса(ВидыДокументовВФорматеСервиса);
	
	Для Каждого РеквизитыКлючаНастройки Из РеквизитыКлючейНастроек Цикл
		КлючНастройки = НастройкиЭДОКлиентСервер.НовыйКлючНастроекОтправки();
		КлючНастройки.Отправитель = ИнтеграцияЭДО.ОрганизацияИзОтбораПоКлючевымРеквизитам(
			ОрганизацииПоРеквизитам, РеквизитыКлючаНастройки.Отправитель);
		КлючНастройки.Получатель = ИнтеграцияЭДО.КонтрагентИзОтбораПоКлючевымРеквизитам(
			КонтрагентыПоРеквизитам, РеквизитыКлючаНастройки.Получатель);
		КлючНастройки.ВидДокумента = ВидДокументаИзОтбораПоФорматуСервиса(ВидыДокументовИзФорматаСервиса,
			РеквизитыКлючаНастройки.ВидДокумента);
		КлючиНастроек.Вставить(РеквизитыКлючаНастройки.Идентификатор, КлючНастройки);
	КонецЦикла;
	
	Возврат КлючиНастроек;
	
КонецФункции

// Параметры:
//  ВидыДокументовВФорматеСервиса - Массив из Структура:
//  * Наименование - Строка
//  * ТипДокумента - Строка
// 
// Возвращаемое значение:
//  Соответствие из КлючИЗначение:
//  * Ключ - Строка
//  * Значение - СправочникСсылка.ВидыДокументовЭДО
Функция ВидыДокументовИзФорматаСервиса(ВидыДокументовВФорматеСервиса) Экспорт
	
	ИменаТиповДокументов = Новый Массив; // Массив из Строка
	Для Каждого ВидДокументаВФорматеСервиса Из ВидыДокументовВФорматеСервиса Цикл
		ИменаТиповДокументов.Добавить(ВидДокументаВФорматеСервиса.ТипДокумента);
	КонецЦикла;
	Возврат ЭлектронныеДокументыЭДО.ВидыДокументовПоИменамСтандартныхТипов(ИменаТиповДокументов);
	
КонецФункции

// Параметры:
//  ВидыДокументовИзФорматаСервиса - См. ВидыДокументовИзФорматаСервиса
//  ВидДокументаВФорматеСервиса - Структура:
//  * Наименование - Строка
//  * ТипДокумента - Строка
// 
// Возвращаемое значение:
//  Неопределено,СправочникСсылка.ВидыДокументовЭДО
Функция ВидДокументаИзОтбораПоФорматуСервиса(ВидыДокументовИзФорматаСервиса, ВидДокументаВФорматеСервиса)
	Возврат ВидыДокументовИзФорматаСервиса[ВидДокументаВФорматеСервиса.ТипДокумента];
КонецФункции

// Параметры:
//  ТипДокументаВФорматеСервиса - Строка
//  МетаданныеПеречисления - Неопределено,ОбъектМетаданныхПеречисление
// 
// Возвращаемое значение:
//  ПеречислениеСсылка.ТипыДокументовЭДО
Функция ТипДокументаИзФорматаСервиса(ТипДокументаВФорматеСервиса, МетаданныеПеречисления = Неопределено) Экспорт
	Если МетаданныеПеречисления = Неопределено Тогда
		МетаданныеПеречисления = Метаданные.Перечисления.ТипыДокументовЭДО;
	КонецЕсли;
	Возврат ОбщегоНазначенияБЭД.ЗначениеПеречисленияПоИмени(ТипДокументаВФорматеСервиса, МетаданныеПеречисления);
