// Параметры:
//  Сообщения - Массив из ДокументСсылка.СообщениеЭДО
//  ИдентификаторДокумента - Строка
// 
// Возвращаемое значение:
//  Массив из см. НовыеДанныеСообщенияПолнойСинхронизацииДокумента
Функция ДанныеСообщенийПолнойСинхронизацииДокумента(Сообщения, ИдентификаторДокумента)
	
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ
		|	СообщениеЭДО.Ссылка КАК Ссылка,
		|	СообщениеЭДО.Направление КАК Направление,
		|	СообщениеЭДО.ВидСообщения.ТипДокумента КАК ТипДокумента,
		|	СообщениеЭДО.ТипЭлементаРегламента КАК ТипЭлементаРегламента,
		|	СообщениеЭДО.Статус КАК Статус,
		|	СообщениеЭДО.ДатаИзмененияСтатуса КАК ДатаИзмененияСтатуса,
		|	СообщениеЭДО.ДополнительнаяИнформация КАК ДополнительнаяИнформация,
		|	СообщениеЭДО.ОсновнойФайл КАК ОсновнойФайл,
		|	ЕСТЬNULL(ТекстовыеСообщенияДокументовЭДО.ТекстСообщения, """") КАК ТекстСообщения,
		|	ЕСТЬNULL(ТекстовыеСообщенияДокументовЭДО.Прочитано, ЛОЖЬ) КАК Прочитано,
		|	ЕСТЬNULL(ТекстовыеСообщенияДокументовЭДО.СведенияОтправителя, """") КАК СведенияОтправителя
		|ИЗ
		|	Документ.СообщениеЭДО КАК СообщениеЭДО
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ТекстовыеСообщенияДокументовЭДО КАК ТекстовыеСообщенияДокументовЭДО
		|		ПО ТекстовыеСообщенияДокументовЭДО.Сообщение = СообщениеЭДО.Ссылка
		|		И ТекстовыеСообщенияДокументовЭДО.ЭлектронныйДокумент = СообщениеЭДО.ЭлектронныйДокумент
		|ГДЕ
		|	СообщениеЭДО.Ссылка В (&Сообщения)";
	
	Запрос.УстановитьПараметр("Сообщения", Сообщения);
	
	УстановитьПривилегированныйРежим(Истина);
	РезультатЗапроса = Запрос.Выполнить();
	УстановитьПривилегированныйРежим(Ложь);
	
	Выборка = РезультатЗапроса.Выбрать();
	
	ДанныеСообщений = Новый Массив; // Массив из см. НовыеДанныеСообщенияПолнойСинхронизацииДокумента
	
	Пока Выборка.Следующий() Цикл
		ДанныеСообщения = НовыеДанныеСообщенияПолнойСинхронизацииДокумента();
		ДанныеСообщения.Идентификатор = Строка(Выборка.Ссылка.УникальныйИдентификатор());
		ДанныеСообщения.ИдентификаторДокумента = ИдентификаторДокумента;
		Если ЗначениеЗаполнено(Выборка.ОсновнойФайл) Тогда
			ДанныеСообщения.ИдентификаторОсновногоФайла = Строка(Выборка.ОсновнойФайл.УникальныйИдентификатор());
		КонецЕсли;
		Если ЗначениеЗаполнено(Выборка.Направление) Тогда
			ДанныеСообщения.Направление = ОбщегоНазначения.ИмяЗначенияПеречисления(Выборка.Направление);
		КонецЕсли;
		Если ЗначениеЗаполнено(Выборка.ТипДокумента) Тогда
			ДанныеСообщения.Тип = ОбщегоНазначения.ИмяЗначенияПеречисления(Выборка.ТипДокумента);
		КонецЕсли;
		Если ЗначениеЗаполнено(Выборка.ТипЭлементаРегламента) Тогда
			ДанныеСообщения.ТипЭлементаРегламента = ОбщегоНазначения.ИмяЗначенияПеречисления(Выборка.ТипЭлементаРегламента);
		КонецЕсли;
		Если ЗначениеЗаполнено(Выборка.Статус) Тогда
			ДанныеСообщения.Статус = ОбщегоНазначения.ИмяЗначенияПеречисления(Выборка.Статус);
		КонецЕсли;
		ДанныеСообщения.ДатаИзмененияСтатуса = ОбщегоНазначенияБЭД.ДатаВФорматеISO(Выборка.ДатаИзмененияСтатуса);
		ДанныеСообщения.СопроводительнаяЗаписка = Выборка.ДополнительнаяИнформация;
		
		Если ЗначениеЗаполнено(Выборка.ТекстСообщения) Тогда
			ДанныеСообщения.ОписаниеТекстовогоСообщения = НовоеОписаниеТекстовогоСообщения();
			ЗаполнитьЗначенияСвойств(ДанныеСообщения.ОписаниеТекстовогоСообщения, Выборка);
		КонецЕсли;
		
		ДанныеСообщений.Добавить(ДанныеСообщения);
	КонецЦикла;
	
	Возврат ДанныеСообщений;
	
КонецФункции

// Возвращаемое значение:
//  Структура:
// * Идентификатор - Строка
// * ИдентификаторСообщения - Строка
// * Имя - Строка
// * Данные - Строка - Двоичные данные в формате base64.
Функция НовыеДанныеФайлаСообщенияПолнойСинхронизацииДокумента()
	
	Данные = Новый Структура;
	Данные.Вставить("Идентификатор", "");
	Данные.Вставить("ИдентификаторСообщения", "");
	Данные.Вставить("Имя", "");
	Данные.Вставить("Данные", "");
	Возврат Данные;
	
КонецФункции

