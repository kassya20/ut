	Событие = Новый Структура;
	Событие.Вставить("Тип", "");
	Событие.Вставить("Параметры", Неопределено);
	Возврат Событие;
	
КонецФункции

// События полной синхронизации документа.
// 
// Параметры:
//  ТипыСобытий - Массив из ПеречислениеСсылка.ТипыСобытийДокументаЦентраЭДО
//  ИдентификаторДокумента - Строка
// 
// Возвращаемое значение:
//  Массив из см. НовоеСобытиеПолнойСинхронизацииДокумента
Функция СобытияПолнойСинхронизацииДокумента(ТипыСобытий, ИдентификаторДокумента)
	
	События = Новый Массив; // см. СобытияПолнойСинхронизацииДокумента 
	
	Для Каждого ТипСобытия Из ТипыСобытий Цикл
		Событие = НовоеСобытиеПолнойСинхронизацииДокумента();
		Событие.Тип = ОбщегоНазначения.ИмяЗначенияПеречисления(ТипСобытия);
		Если ТипСобытия = Перечисления.ТипыСобытийДокументаЦентраЭДО.ПослеПолученияПоСчетуФактуреПДП
			Или ТипСобытия = Перечисления.ТипыСобытийДокументаЦентраЭДО.ПослеПолученияПоСчетуФактуреПДО
			Или ТипСобытия = Перечисления.ТипыСобытийДокументаЦентраЭДО.ПослеПолученияПоСчетуФактуреИОП
			Или ТипСобытия = Перечисления.ТипыСобытийДокументаЦентраЭДО.ПослеПолученияПоСчетуФактуреИОП_ПДО Тогда
			Событие.Параметры = ПараметрыСобытияПослеЗагрузкиПодтвержденияПоСчетуФактуре(ИдентификаторДокумента);
		КонецЕсли;
		События.Добавить(Событие);
	КонецЦикла;
	
	Возврат События;
	
КонецФункции

// Параметры:
//  ИдентификаторДокумента - Строка
// 
// Возвращаемое значение:
//  Структура:
//  * Подтверждения - Массив из см. НовоеОписаниеПодтвержденияПоСчетуФактуре
Функция ПараметрыСобытияПослеЗагрузкиПодтвержденияПоСчетуФактуре(ИдентификаторДокумента)
	
	Подтверждения = Новый Массив; // Массив из см. НовоеОписаниеПодтвержденияПоСчетуФактуре
	
	ЭлектронныйДокумент = ДокументПоИдентификатору(ИдентификаторДокумента);
	ТипыЭлементовРегламента = Новый Массив; // Массив из ПеречислениеСсылка.ТипыЭлементовРегламентаЭДО
	ТипыЭлементовРегламента.Добавить(Перечисления.ТипыЭлементовРегламентаЭДО.ПДП);
	ТипыЭлементовРегламента.Добавить(Перечисления.ТипыЭлементовРегламентаЭДО.ПДО);
	ТипыЭлементовРегламента.Добавить(Перечисления.ТипыЭлементовРегламентаЭДО.ИОП);
	ТипыЭлементовРегламента.Добавить(Перечисления.ТипыЭлементовРегламентаЭДО.ИОП_ПДП);
	
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ
		|	СообщениеЭДО.ТипЭлементаРегламента КАК ТипЭлементаРегламента,
		|	СообщениеЭДО.Дата КАК Дата
		|ИЗ
		|	Документ.СообщениеЭДО КАК СообщениеЭДО
		|ГДЕ
		|	СообщениеЭДО.ЭлектронныйДокумент = &ЭлектронныйДокумент
		|	И СообщениеЭДО.ТипЭлементаРегламента В (&ТипыЭлементовРегламента)";
	
	Запрос.УстановитьПараметр("ЭлектронныйДокумент", ЭлектронныйДокумент);
	Запрос.УстановитьПараметр("ТипыЭлементовРегламента", ТипыЭлементовРегламента);
	
	УстановитьПривилегированныйРежим(Истина);
	Выборка = Запрос.Выполнить().Выбрать();
	УстановитьПривилегированныйРежим(Ложь);
	
	Пока Выборка.Следующий() Цикл
		ДобавитьОписаниеПодтвержденияПоСчетуФактуре(Подтверждения, Выборка.ТипЭлементаРегламента, Выборка.Дата);
		Индекс = ТипыЭлементовРегламента.Найти(Выборка.ТипЭлементаРегламента);
		Если Индекс <> Неопределено Тогда
			ТипыЭлементовРегламента.Удалить(Индекс);
		КонецЕсли;
	КонецЦикла;
	
	Параметры = Новый Структура("Подтверждения", Подтверждения);
	Возврат Параметры;
	
КонецФункции

// Возвращаемое значение:
//  Структура:
// * Тип - Строка
// * Дата - См. ОбщегоНазначенияБЭД.ДатаВФорматеISO
Функция НовоеОписаниеПодтвержденияПоСчетуФактуре()
	Описание = Новый Структура;
	Описание.Вставить("Тип", "");
	Описание.Вставить("Дата", "");
	Возврат Описание;
КонецФункции

// Параметры:
//  ОписанияПодтверждений - Массив из см. НовоеОписаниеПодтвержденияПоСчетуФактуре
//  ТипЭлементаРегламента - ПеречислениеСсылка.ТипыЭлементовРегламентаЭДО
//  Дата - Дата
Процедура ДобавитьОписаниеПодтвержденияПоСчетуФактуре(ОписанияПодтверждений, ТипЭлементаРегламента, Дата)
	ОписаниеПодтверждения = НовоеОписаниеПодтвержденияПоСчетуФактуре();
	ОписаниеПодтверждения.Тип = ОбщегоНазначения.ИмяЗначенияПеречисления(ТипЭлементаРегламента);
	ОписаниеПодтверждения.Дата = ОбщегоНазначенияБЭД.ДатаВФорматеISO(Дата);
	ОписанияПодтверждений.Добавить(ОписаниеПодтверждения);
КонецПроцедуры

#КонецОбласти

#Область Переформирование

// Параметры:
//  Идентификатор - Строка
// 
// Возвращаемое значение:
//  Строка - Текст ошибки не удалось найти электронные документы по идентификаторам
Функция ТекстОшибкиНеУдалосьНайтиЭлектронныйДокументПоИдентификатору(Идентификатор)
	
	Возврат СтрШаблон(НСтр("ru = 'Не удалось найти электронный документ по идентификатору ""%1""'"),
		Идентификатор);
			
КонецФункции

#КонецОбласти // Переформирование

#Область ПереходВЦентрЭДО

// Параметры:
//  ПолныеДанные - см. ЗагрузитьПолныеДанныеДокументаЭДО.ПолныеДанные
// 
// Возвращаемое значение:
//  См. НовоеСопоставлениеДанныхДокументаЭДО
Функция ЗагрузитьСопоставитьДокументИзПолныхДанных(ПолныеДанные)
	
	ЭтоВходящийЭДО = ПолныеДанные.Описание.ЭтоВходящийЭДО;
	ИдентификаторДокументооборота = ПолныеДанные.Описание.ИдентификаторДокументооборота;
	ЭлектронныйДокумент = ЭлектронныеДокументыЭДО.НайтиПоИдентификаторуДокументооборота(
		ИдентификаторДокументооборота, ЭтоВходящийЭДО);
	
	Если ЗначениеЗаполнено(ЭлектронныйДокумент) Тогда
		
		СопоставлениеДанных = СопоставитьПолныеДанныеДокументаЭДО(ПолныеДанные, ЭлектронныйДокумент);
		
	Иначе
		
		СопоставлениеДанных = ЗагрузитьДокументИзПолныхДанных(ПолныеДанные);
		
	КонецЕсли;
	
	Возврат СопоставлениеДанных;
	
КонецФункции

// Возвращаемое значение:
//  Структура:
//  * Документ - См. НовоеСопоставлениеИдентификаторовОбъекта
//  * Сообщения - Массив из см. НовоеСопоставлениеИдентификаторовОбъекта
//  * ФайлыСообщений - Массив из см. НовоеСопоставлениеИдентификаторовОбъекта
//  * Доверенности - Массив из см. НовоеСопоставлениеИдентификаторовОбъекта
Функция НовоеСопоставлениеДанныхДокументаЭДО()
	
	Сопоставление = Новый Структура;
	Сопоставление.Вставить("Документ", НовоеСопоставлениеИдентификаторовОбъекта());
	Сопоставление.Вставить("Сообщения", Новый Массив);
	Сопоставление.Вставить("ФайлыСообщений", Новый Массив);
	Сопоставление.Вставить("Доверенности", Новый Массив);
	Возврат Сопоставление;
	
КонецФункции

// Возвращаемое значение:
//  Структура:
//  * Идентификатор - Строка
//  * ИдентификаторСервиса - Строка
Функция НовоеСопоставлениеИдентификаторовОбъекта()
	
	Сопоставление = Новый Структура;
	Сопоставление.Вставить("Идентификатор", "");
	Сопоставление.Вставить("ИдентификаторСервиса", "");
	Возврат Сопоставление;
	
КонецФункции

// Параметры:
//  ПолныеДанные - см. ЗагрузитьПолныеДанныеДокументаЭДО.ПолныеДанные
//  ЭлектронныйДокумент - ДокументСсылка.ЭлектронныйДокументВходящийЭДО,ДокументСсылка.ЭлектронныйДокументИсходящийЭДО
// 
// Возвращаемое значение:
//  См. НовоеСопоставлениеДанныхДокументаЭДО
Функция СопоставитьПолныеДанныеДокументаЭДО(ПолныеДанные, ЭлектронныйДокумент)
	
	Результат = НовоеСопоставлениеДанныхДокументаЭДО();
	
	Результат.Документ.Идентификатор = ПолныеДанные.Описание.Идентификатор;
	Результат.Документ.ИдентификаторСервиса = Строка(ЭлектронныйДокумент.УникальныйИдентификатор());
	
	СведенияСообщений = СведенияСообщенийДокументаДляСопоставления(ЭлектронныйДокумент);
	
	СопоставлениеФайлов = Результат.ФайлыСообщений;
	СопоставлениеСообщений = Результат.Сообщения;
	
	СопоставленныеСообщения = Новый Соответствие;
	
	Для Каждого ФайлСообщения Из ПолныеДанные.ФайлыСообщений Цикл
		СведенияСообщения = СведенияСообщений.Найти(ФайлСообщения.Имя, "ПолноеИмяФайла");
		Если СведенияСообщения = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		СопоставлениеФайла = НовоеСопоставлениеИдентификаторовОбъекта();
		СопоставлениеФайла.Идентификатор = ФайлСообщения.Идентификатор;
		СопоставлениеФайла.ИдентификаторСервиса = Строка(СведенияСообщения.ПрисоединенныйФайл.УникальныйИдентификатор());
		СопоставлениеФайлов.Добавить(СопоставлениеФайла);
		
		Если СопоставленныеСообщения[ФайлСообщения.ИдентификаторСообщения] <> Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		СопоставленныеСообщения.Вставить(ФайлСообщения.ИдентификаторСообщения, Истина);
		
		СопоставлениеСообщения = НовоеСопоставлениеИдентификаторовОбъекта();
		СопоставлениеСообщения.Идентификатор = ФайлСообщения.ИдентификаторСообщения;
		СопоставлениеСообщения.ИдентификаторСервиса = Строка(СведенияСообщения.Ссылка.УникальныйИдентификатор());
		СопоставлениеСообщений.Добавить(СопоставлениеСообщения);
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

// Параметры:
//  ЭлектронныйДокумент - ДокументСсылка.ЭлектронныйДокументВходящийЭДО,ДокументСсылка.ЭлектронныйДокументИсходящийЭДО
// 
// Возвращаемое значение:
//  ТаблицаЗначений:
//  * Ссылка - ДокументСсылка.СообщениеЭДО
//  * ТипЭлементаРегламента - ПеречислениеСсылка.ТипыЭлементовРегламентаЭДО
//  * ПрисоединенныйФайл - СправочникСсылка.СообщениеЭДОПрисоединенныеФайлы
//  * ПолноеИмяФайла - Строка
Функция СведенияСообщенийДокументаДляСопоставления(ЭлектронныйДокумент)
	
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ
		|	СообщениеЭДО.Ссылка КАК Ссылка,
		|	СообщениеЭДО.ТипЭлементаРегламента КАК ТипЭлементаРегламента,
		|	СообщениеЭДОПрисоединенныеФайлы.Ссылка КАК ПрисоединенныйФайл,
		|	СообщениеЭДОПрисоединенныеФайлы.ПолноеИмяФайла КАК ПолноеИмяФайла
		|ИЗ
		|	Документ.СообщениеЭДО КАК СообщениеЭДО
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.СообщениеЭДОПрисоединенныеФайлы КАК СообщениеЭДОПрисоединенныеФайлы
		|		ПО СообщениеЭДО.Ссылка = СообщениеЭДОПрисоединенныеФайлы.ВладелецФайла
		|ГДЕ
		|	СообщениеЭДО.ЭлектронныйДокумент = &ЭлектронныйДокумент";
	
	Запрос.УстановитьПараметр("ЭлектронныйДокумент", ЭлектронныйДокумент);
	
	Возврат Запрос.Выполнить().Выгрузить();
	
КонецФункции

// Параметры:
//  ПолныеДанные - см. ЗагрузитьПолныеДанныеДокументаЭДО.ПолныеДанные
// 
// Возвращаемое значение:
//  См. НовоеСопоставлениеДанныхДокументаЭДО
Функция ЗагрузитьДокументИзПолныхДанных(ПолныеДанные)
	
	Результат = НовоеСопоставлениеДанныхДокументаЭДО();
	
	ИдентификаторыОбъектов = НовыеИдентификаторыЗагруженныхОбъектов();
	
	Результат.Документ = ЗагрузитьОписаниеДокументаИзПолныхДанных(ПолныеДанные, ИдентификаторыОбъектов);
	
	Результат.Сообщения = ЗагрузитьСообщенияИзПолныхДанных(ПолныеДанные, ИдентификаторыОбъектов);
	
	Результат.ФайлыСообщений = ЗагрузитьФайлыСообщенийИзПолныхДанных(ПолныеДанные, ИдентификаторыОбъектов);
	
	Результат.Доверенности = ЗагрузитьДоверенностиИзПолныхДанных(ПолныеДанные, ИдентификаторыОбъектов);
	
	ЗагрузитьПодписиФайловИзПолныхДанных(ПолныеДанные, ИдентификаторыОбъектов);
	
	ЗагрузитьПроверкиПодписейПоМЧДИзПолныхДанных(ПолныеДанные, ИдентификаторыОбъектов);
	
	Возврат Результат;
	
КонецФункции

// Возвращаемое значение:
//  Соответствие из КлючИЗначение:
//  * Ключ - Строка
//  * Значение - ЛюбаяСсылка
Функция НовыеИдентификаторыЗагруженныхОбъектов()
	Возврат Новый Соответствие;
КонецФункции

// Параметры:
//  ПолныеДанные - См. ЗагрузитьДокументИзПолныхДанных.ПолныеДанные
//  ИдентификаторыОбъектов - См. НовыеИдентификаторыЗагруженныхОбъектов
// 
// Возвращаемое значение:
//  См. НовоеСопоставлениеИдентификаторовОбъекта
Функция ЗагрузитьОписаниеДокументаИзПолныхДанных(ПолныеДанные, ИдентификаторыОбъектов)
	
	ОписаниеДокумента = ПолныеДанные.Описание;
	
	Если ОписаниеДокумента.ЭтоВходящийЭДО Тогда
		ДокументОбъект = Документы.ЭлектронныйДокументВходящийЭДО.СоздатьДокумент(); // ДокументОбъект.ЭлектронныйДокументВходящийЭДО,ДокументОбъект.ЭлектронныйДокументИсходящийЭДО 
	Иначе
		ДокументОбъект = Документы.ЭлектронныйДокументИсходящийЭДО.СоздатьДокумент();
	КонецЕсли;
	
	ДокументОбъект.Дата = ОбщегоНазначенияБЭД.ДатаИзФорматаISO(ОписаниеДокумента.Дата);
	ДокументОбъект.ИдентификаторДокумента = ОписаниеДокумента.Идентификатор;
	ДокументОбъект.ФорматОсновногоТитула = ОписаниеДокумента.Формат;
	ДокументОбъект.НомерДокумента = ОписаниеДокумента.Номер;
	ДокументОбъект.ДатаДокумента = ОбщегоНазначенияБЭД.ДатаИзФорматаISO(ОписаниеДокумента.ДатаДокумента);
	ДокументОбъект.ДатаАннулирования = ОбщегоНазначенияБЭД.ДатаИзФорматаISO(ОписаниеДокумента.ДатаАннулирования);
	ДокументОбъект.ДатаПодписания = ОбщегоНазначенияБЭД.ДатаИзФорматаISO(ОписаниеДокумента.ДатаПодписания);
	ДокументОбъект.СуммаДокумента = ОписаниеДокумента.Сумма;
	ДокументОбъект.ТребуетсяИзвещение = ОписаниеДокумента.ТребуетсяИзвещение;
	ДокументОбъект.ТребуетсяПодтверждение = ОписаниеДокумента.ТребуетсяПодтверждение;
	ДокументОбъект.ИдентификаторОрганизации = ОписаниеДокумента.ИдентификаторОрганизации;
	ДокументОбъект.ИдентификаторКонтрагента = ОписаниеДокумента.ИдентификаторКонтрагента;
	ДокументОбъект.ИдентификаторДокументооборота = ОписаниеДокумента.ИдентификаторДокументооборота;
	
	ДокументОбъект.Организация = ИнтеграцияЭДО.ОрганизацияПоКлючевымРеквизитам(ОписаниеДокумента.Организация);
	ДокументОбъект.Контрагент = ИнтеграцияЭДО.КонтрагентПоКлючевымРеквизитам(ОписаниеДокумента.Контрагент);
	
	ДокументОбъект.ВидДокумента = ВидДокументаИзФорматаСервиса(ОписаниеДокумента.ВидДокумента);
	ДокументОбъект.ТипРегламента = ТипРегламентаИзФорматаСервиса(ОписаниеДокумента.ТипРегламента);
	ДокументОбъект.СпособОбмена = СпособОбменаИзФорматаСервиса(ОписаниеДокумента.СпособОбмена);
	
	Если ОписаниеДокумента.ЭтоВходящийЭДО Тогда
		ДокументОбъект.ДатаПолучения = ОбщегоНазначенияБЭД.ДатаИзФорматаISO(ОписаниеДокумента.ДатаОтправкиПолучения);
	Иначе
		ДокументОбъект.ДатаОтправки = ОбщегоНазначенияБЭД.ДатаИзФорматаISO(ОписаниеДокумента.ДатаОтправкиПолучения);
		ДокументОбъект.МаршрутПодписания = Справочники.МаршрутыПодписания.ОднойДоступнойПодписью;
	КонецЕсли;
	
	ДокументОбъект.Записать();
	
	ДатаИзмененияСостояния = ДокументОбъект.Дата;
	Если ЗначениеЗаполнено(ОписаниеДокумента.ДатаИзмененияСостояния) Тогда
		ДатаИзмененияСостояния = ОбщегоНазначенияБЭД.ДатаИзФорматаISO(ОписаниеДокумента.ДатаИзмененияСостояния);
	КонецЕсли;
	
	НаборЗаписей = РегистрыСведений.СостоянияДокументовЭДО.СоздатьНаборЗаписей();
	НаборЗаписей.Отбор.ЭлектронныйДокумент.Установить(ДокументОбъект.Ссылка);
	
	ЗаписьНабора = НаборЗаписей.Добавить();
	ЗаписьНабора.ЭлектронныйДокумент = ДокументОбъект.Ссылка;
	ЗаписьНабора.Состояние = СостояниеДокументаИзФорматаСервиса(ОписаниеДокумента.ИмяСостояния);
	ЗаписьНабора.СостояниеДополнение = ОписаниеДокумента.СостояниеДополнение;
	ЗаписьНабора.ДатаИзменения = ДатаИзмененияСостояния;
	ЗаписьНабора.Комментарий = ОписаниеДокумента.КомментарийСостояния;
	
	НаборЗаписей.Записать();
	
	ИдентификаторыОбъектов.Вставить(ОписаниеДокумента.Идентификатор, ДокументОбъект.Ссылка);
	
	Сопоставление = НовоеСопоставлениеИдентификаторовОбъекта();
	Сопоставление.Идентификатор = ОписаниеДокумента.Идентификатор;
	Сопоставление.ИдентификаторСервиса = Строка(ДокументОбъект.Ссылка.УникальныйИдентификатор());
	Возврат Сопоставление;
	
КонецФункции

// Параметры:
//  ПолныеДанные - См. ЗагрузитьДокументИзПолныхДанных.ПолныеДанные
//  ИдентификаторыОбъектов - См. НовыеИдентификаторыЗагруженныхОбъектов
// 
// Возвращаемое значение:
//  Массив из см. НовоеСопоставлениеИдентификаторовОбъекта
Функция ЗагрузитьСообщенияИзПолныхДанных(ПолныеДанные, ИдентификаторыОбъектов)
	
	НаборСопоставлений = Новый Массив; // Массив из см. НовоеСопоставлениеИдентификаторовОбъекта
	ДанныеСообщений = ПолныеДанные.Сообщения;
	
	Для Каждого ДанныеСообщения Из ДанныеСообщений Цикл
		СообщениеОбъект = Документы.СообщениеЭДО.СоздатьДокумент();
		СообщениеОбъект.Дата = ОбщегоНазначенияБЭД.ДатаИзФорматаISO(ДанныеСообщения.Дата);
		ЭлектронныйДокумент = ИдентификаторыОбъектов[ДанныеСообщения.ИдентификаторДокумента]; // ДокументСсылка.ЭлектронныйДокументВходящийЭДО,ДокументСсылка.ЭлектронныйДокументИсходящийЭДО
		СообщениеОбъект.ЭлектронныйДокумент = ЭлектронныйДокумент;
		ТипСообщения = ТипДокументаИзФорматаСервиса(ДанныеСообщения.Тип);
		СообщениеОбъект.ВидСообщения = ЭлектронныеДокументыЭДО.ВидДокументаПоТипу(ТипСообщения);
		СообщениеОбъект.Направление = НаправлениеИзФорматаСервиса(ДанныеСообщения.Направление);
		СообщениеОбъект.ТипЭлементаРегламента = ТипЭлементаРегламентаИзФорматаСервиса(
			ДанныеСообщения.ТипЭлементаРегламента);
		СообщениеОбъект.Статус = СтатусСообщенияИзФорматаСервиса(ДанныеСообщения.Статус);
		СообщениеОбъект.ДатаИзмененияСтатуса = ОбщегоНазначенияБЭД.ДатаИзФорматаISO(
			ДанныеСообщения.ДатаИзмененияСтатуса);
		СообщениеОбъект.Состояние = СостояниеСообщенияИзФорматаСервиса(ДанныеСообщения.Состояние);
		СообщениеОбъект.ОсновнойФайл = Справочники.СообщениеЭДОПрисоединенныеФайлы.ПолучитьСсылку();
		СообщениеОбъект.ДополнительнаяИнформация = ДанныеСообщения.СопроводительнаяЗаписка;
		СообщениеОбъект.Записать();
		
		СвойстваСообщения = Новый Структура("Ссылка, Состояние", СообщениеОбъект.Ссылка, СообщениеОбъект.Состояние);
		ЭлектронныеДокументыЭДО.СформироватьМаршрутПодписания(СвойстваСообщения);
		
		ИдентификаторыОбъектов.Вставить(ДанныеСообщения.Идентификатор, СообщениеОбъект.Ссылка);
		ИдентификаторыОбъектов.Вставить(ДанныеСообщения.ИдентификаторОсновногоФайла, СообщениеОбъект.ОсновнойФайл);
		
		Если ЗначениеЗаполнено(ДанныеСообщения.ОписаниеТекстовогоСообщения) Тогда
			РегистрыСведений.ТекстовыеСообщенияДокументовЭДО.ДобавитьСообщение(
				СообщениеОбъект.Ссылка, 
				ДанныеСообщения.ОписаниеТекстовогоСообщения.ТекстСообщения);
		КонецЕсли;
		
		Сопоставление = НовоеСопоставлениеИдентификаторовОбъекта();
		Сопоставление.Идентификатор = ДанныеСообщения.Идентификатор;
		Сопоставление.ИдентификаторСервиса = Строка(СообщениеОбъект.Ссылка.УникальныйИдентификатор());
		НаборСопоставлений.Добавить(Сопоставление);
	КонецЦикла;
	
	Возврат НаборСопоставлений;
	
КонецФункции

// Параметры:
//  ПолныеДанные - См. ЗагрузитьДокументИзПолныхДанных.ПолныеДанные
//  ИдентификаторыОбъектов - См. НовыеИдентификаторыЗагруженныхОбъектов
// 
// Возвращаемое значение:
//  Массив из см. НовоеСопоставлениеИдентификаторовОбъекта
Функция ЗагрузитьФайлыСообщенийИзПолныхДанных(ПолныеДанные, ИдентификаторыОбъектов)
	
	НаборСопоставлений = Новый Массив; // Массив из см. НовоеСопоставлениеИдентификаторовОбъекта
	ДанныеФайловСообщений = ПолныеДанные.ФайлыСообщений;
	
	Для Каждого ДанныеФайлаСообщения Из ДанныеФайловСообщений Цикл
		Сообщение = ИдентификаторыОбъектов[ДанныеФайлаСообщения.ИдентификаторСообщения]; // ДокументСсылка.СообщениеЭДО
		НоваяСсылкаНаФайл = ИдентификаторыОбъектов[ДанныеФайлаСообщения.Идентификатор]; // Неопределено,СправочникСсылка.СообщениеЭДОПрисоединенныеФайлы
		Файл = Новый Файл(ДанныеФайлаСообщения.Имя);
		ДвоичныеДанные = Base64Значение(ДанныеФайлаСообщения.Данные);
		АдресДвоичныхДанных = ПоместитьВоВременноеХранилище(ДвоичныеДанные);
		ПараметрыДобавленияФайла = РаботаСФайлами.ПараметрыДобавленияФайла();
		ПараметрыДобавленияФайла.ВладелецФайлов = Сообщение;
		ПараметрыДобавленияФайла.Служебный = Истина;
		ПараметрыДобавленияФайла.Автор = Пользователи.ТекущийПользователь();
		ПараметрыДобавленияФайла.ИмяБезРасширения = Файл.ИмяБезРасширения;
		ПараметрыДобавленияФайла.РасширениеБезТочки = СтрЗаменить(Файл.Расширение,".","");
		ПараметрыДобавленияФайла.Вставить("ПолноеИмяФайла", Файл.ПолноеИмя);
		СсылкаНаФайл = РаботаСФайлами.ДобавитьФайл(ПараметрыДобавленияФайла, АдресДвоичныхДанных,,,НоваяСсылкаНаФайл);
		
		ИдентификаторыОбъектов.Вставить(ДанныеФайлаСообщения.Идентификатор, СсылкаНаФайл);
		
		Сопоставление = НовоеСопоставлениеИдентификаторовОбъекта();
		Сопоставление.Идентификатор = ДанныеФайлаСообщения.Идентификатор;
		Сопоставление.ИдентификаторСервиса = Строка(СсылкаНаФайл.УникальныйИдентификатор());
		НаборСопоставлений.Добавить(Сопоставление);
	КонецЦикла;
	
	Возврат НаборСопоставлений;
	
КонецФункции

// Параметры:
//  ПолныеДанные - См. ЗагрузитьДокументИзПолныхДанных.ПолныеДанные
//  ИдентификаторыОбъектов - См. НовыеИдентификаторыЗагруженныхОбъектов
// 
// Возвращаемое значение:
//  Массив из см. НовоеСопоставлениеИдентификаторовОбъекта
Функция ЗагрузитьДоверенностиИзПолныхДанных(ПолныеДанные, ИдентификаторыОбъектов)
	
	НаборСопоставлений = Новый Массив; // Массив из см. НовоеСопоставлениеИдентификаторовОбъекта
	
	ДанныеДоверенностей = ПолныеДанные.Доверенности;
	Если Не ЗначениеЗаполнено(ДанныеДоверенностей) Тогда
		Возврат НаборСопоставлений;
	КонецЕсли;
	
	Для Каждого ДанныеДоверенности Из ДанныеДоверенностей Цикл
		
		Если ЗначениеЗаполнено(ДанныеДоверенности.ИдентификаторСервиса) Тогда
			Доверенность = МашиночитаемыеДоверенностиЦентрЭДО.ДоверенностьПоИдентификатору(
				ДанныеДоверенности.ИдентификаторСервиса);
			ИдентификаторыОбъектов.Вставить(ДанныеДоверенности.Идентификатор, Доверенность);
			Продолжить;
		КонецЕсли;
		
		ДвоичныеДанныеДоверенности = Base64Значение(ДанныеДоверенности.Данные);
		РезультатЗагрузки = МашиночитаемыеДоверенности.ЗагрузитьМЧДИзФайла(ДвоичныеДанныеДоверенности);
		Если Не ЗначениеЗаполнено(РезультатЗагрузки.МЧД) Тогда
			ВызватьИсключение РезультатЗагрузки.ТекстОшибки;
		КонецЕсли;
		
		ИдентификаторыОбъектов.Вставить(ДанныеДоверенности.Идентификатор, РезультатЗагрузки.МЧД);
		
		Сопоставление = НовоеСопоставлениеИдентификаторовОбъекта();
		Сопоставление.Идентификатор = ДанныеДоверенности.Идентификатор;
		Сопоставление.ИдентификаторСервиса = Строка(РезультатЗагрузки.МЧД.УникальныйИдентификатор());
		НаборСопоставлений.Добавить(Сопоставление);
		
	КонецЦикла;
	
	Возврат НаборСопоставлений;
	
КонецФункции

// Параметры:
//  ПолныеДанные - См. ЗагрузитьДокументИзПолныхДанных.ПолныеДанные
//  ИдентификаторыОбъектов - См. НовыеИдентификаторыЗагруженныхОбъектов
Процедура ЗагрузитьПодписиФайловИзПолныхДанных(ПолныеДанные, ИдентификаторыОбъектов)
	
	ДанныеПодписейФайлов = ПолныеДанные.ПодписиФайлов;
	Если Не ЗначениеЗаполнено(ДанныеПодписейФайлов) Тогда
		Возврат;
	КонецЕсли;
	
	Для Каждого ДанныеПодписиФайла Из ДанныеПодписейФайлов Цикл
		ПодписанныйОбъект = ИдентификаторыОбъектов[ДанныеПодписиФайла.ИдентификаторФайла]; // СправочникСсылка.СообщениеЭДОПрисоединенныеФайлы
		СвойстваПодписи = ЭлектроннаяПодписьКлиентСервер.НовыеСвойстваПодписи();
		СвойстваПодписи.ИдентификаторПодписи = Новый УникальныйИдентификатор(ДанныеПодписиФайла.Идентификатор);
		СвойстваПодписи.ПорядковыйНомер = ДанныеПодписиФайла.ПорядковыйНомер;
		СвойстваПодписи.Подпись = Base64Значение(ДанныеПодписиФайла.Подпись);
		Если ЗначениеЗаполнено(ДанныеПодписиФайла.Сертификат) Тогда
			СвойстваПодписи.Сертификат = Base64Значение(ДанныеПодписиФайла.Сертификат);
		КонецЕсли;
		СвойстваПодписи.ДатаПодписи = ОбщегоНазначенияБЭД.ДатаИзФорматаISO(ДанныеПодписиФайла.ДатаПодписи);
		СвойстваПодписи.ПодписьВерна = ДанныеПодписиФайла.ПодписьВерна;
		СвойстваПодписи.ДатаПроверкиПодписи = ОбщегоНазначенияБЭД.ДатаИзФорматаISO(
			ДанныеПодписиФайла.ДатаПроверкиПодписи);
		СвойстваПодписи.ПропуститьПриПродлении = ДанныеПодписиФайла.ПропуститьПриПродлении;
		Если ЗначениеЗаполнено(ДанныеПодписиФайла.ТипПодписи) Тогда
			СвойстваПодписи.ТипПодписи = ТипПодписиИзФорматаСервиса(ДанныеПодписиФайла.ТипПодписи);
		КонецЕсли;
		Если ЗначениеЗаполнено(ДанныеПодписиФайла.СрокДействияПоследнейМеткиВремени) Тогда
			СвойстваПодписи.СрокДействияПоследнейМеткиВремени = ОбщегоНазначенияБЭД.ДатаИзФорматаISO(
				ДанныеПодписиФайла.СрокДействияПоследнейМеткиВремени);
		КонецЕсли;
		Если СвойстваПодписи.Сертификат <> Неопределено Тогда
			СвойстваСертификата = ЭлектроннаяПодпись.СвойстваСертификата(СвойстваПодписи.Сертификат);
			СвойстваПодписи.Отпечаток = СвойстваСертификата.Отпечаток;
			СвойстваПодписи.КомуВыданСертификат = СвойстваСертификата.КомуВыдан;
		КонецЕсли;
		
		ПараметрыПолученияПодписей = ЭлектроннаяПодпись.НовыйПараметрыПолученияПодписейОбъекта();
		ПараметрыПолученияПодписей.ПорядковыйНомер = ДанныеПодписиФайла.ПорядковыйНомер;
		УстановленныеПодписи = ЭлектроннаяПодпись.ПодписиОбъекта(
			ПодписанныйОбъект, ПараметрыПолученияПодписей);
		
		Если ЗначениеЗаполнено(УстановленныеПодписи) Тогда
			ЭлектроннаяПодпись.ОбновитьПодпись(ПодписанныйОбъект, СвойстваПодписи, Истина);
		Иначе
			ЭлектроннаяПодпись.ДобавитьПодпись(ПодписанныйОбъект, СвойстваПодписи);
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

// Параметры:
//  ПолныеДанные - См. ЗагрузитьДокументИзПолныхДанных.ПолныеДанные
//  ИдентификаторыОбъектов - См. НовыеИдентификаторыЗагруженныхОбъектов
Процедура ЗагрузитьПроверкиПодписейПоМЧДИзПолныхДанных(ПолныеДанные, ИдентификаторыОбъектов)
	
	ДанныеПроверокПодписейПоМЧД = ПолныеДанные.ПроверкиПодписейПоМЧД;
	Если Не ЗначениеЗаполнено(ДанныеПроверокПодписейПоМЧД) Тогда
		Возврат;
	КонецЕсли;
	
	Для Каждого ДанныеПроверкиПодписиПоМЧД Из ДанныеПроверокПодписейПоМЧД Цикл
		ПодписанныйОбъект = ИдентификаторыОбъектов[ДанныеПроверкиПодписиПоМЧД.ИдентификаторФайла]; // СправочникСсылка.СообщениеЭДОПрисоединенныеФайлы
		Доверенность = ИдентификаторыОбъектов[ДанныеПроверкиПодписиПоМЧД.ИдентификаторДоверенности]; // ОпределяемыйТип.МашиночитаемаяДоверенность
		РезультатПроверки = МашиночитаемыеДоверенности.НовыйРезультатПроверкиПодписи();
		РезультатПроверки.ПроверкаВыполнена = ДанныеПроверкиПодписиПоМЧД.ПроверкаВыполнена;
		РезультатПроверки.ДатаПроверки = ОбщегоНазначенияБЭД.ДатаИзФорматаISO(
			ДанныеПроверкиПодписиПоМЧД.ДатаПроверки);
		РезультатПроверки.ПодписьВерна = ДанныеПроверкиПодписиПоМЧД.ПодписьВерна;
		РезультатПроверки.Доверенность = Доверенность;
		РезультатПроверки.ТребуетсяДоверенность = Истина;
		
		Если ЗначениеЗаполнено(ДанныеПроверкиПодписиПоМЧД.ПротоколПроверки) Тогда
			ДанныеПротоколаПроверки = Base64Значение(ДанныеПроверкиПодписиПоМЧД.ПротоколПроверки);
			ПротоколПроверкиСтрокой = ПолучитьСтрокуИзДвоичныхДанных(ДанныеПротоколаПроверки);
			ПротоколПроверки = МашиночитаемыеДоверенности.ПрочитатьПротоколПроверкиJSON(ПротоколПроверкиСтрокой);
			РезультатПроверки.ПротоколПроверки = ПротоколПроверки;
		КонецЕсли;
		
		МашиночитаемыеДоверенности.ЗаписатьРезультатПроверкиПодписи(ПодписанныйОбъект,
			ДанныеПроверкиПодписиПоМЧД.ХешПодписи, РезультатПроверки);
	КонецЦикла;
	
КонецПроцедуры

// Параметры:
//  ИдентификаторПакета - УникальныйИдентификатор
//  ЭлектронныеДокументы - Массив из ДокументСсылка.ЭлектронныйДокументВходящийЭДО,ДокументСсылка.ЭлектронныйДокументИсходящийЭДО
Процедура ОбъединитьДокументыВПакет(ИдентификаторПакета, ЭлектронныеДокументы)
	
	Если Не ЗначениеЗаполнено(ЭлектронныеДокументы) Тогда
		Возврат;
	КонецЕсли;
	
	СвойстваДокументовДляОписанияПакетов = ЭлектронныеДокументыЭДО.СвойстваДокументовДляОписанияПакетов(
		ЭлектронныеДокументы);

	РегистрыСведений.ПакетыДокументовЭДО.Удалить(ИдентификаторПакета);
	РегистрыСведений.ПакетыДокументовЭДО.ОбновитьОписание(ИдентификаторПакета, СвойстваДокументовДляОписанияПакетов);
	
	ТекущиеДокументыПакета = ПакетыДокументовЭДО.ДокументыПакета(ИдентификаторПакета);
	Для Каждого ТекущийДокументПакета Из ТекущиеДокументыПакета Цикл
		РегистрыСведений.СоставПакетовДокументовЭДО.Удалить(ТекущийДокументПакета);
	КонецЦикла;
	
	Для Каждого ЭлектронныйДокумент Из ЭлектронныеДокументы Цикл
		СвойстваДокумента = СвойстваДокументовДляОписанияПакетов.Найти(ЭлектронныйДокумент, "Ссылка");
		РегистрыСведений.СоставПакетовДокументовЭДО.Записать(ИдентификаторПакета, ЭлектронныйДокумент,
			СвойстваДокумента);
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти

#Область МеткиВремени

// Параметры:
//  ИдентификаторыДокументовЭДО - Массив из Строка
//  ТипСинхронизации - ПеречислениеСсылка.ТипыСинхронизацииСЦентромЭДО
// 
// Возвращаемое значение:
//  Массив из Структура:
//  * ИдентификаторДокументаЭДО - Строка
//  * МеткаВремени - Число
Функция МеткиВремениДокументовЭДОПоТипуСинхронизации(ИдентификаторыДокументовЭДО, ТипСинхронизации)
	
	МеткиВремениПоИдентификаторам = Новый Соответствие;
	Для Каждого ИдентификаторДокументаЭДО Из ИдентификаторыДокументовЭДО Цикл
		МеткиВремениПоИдентификаторам.Вставить(ИдентификаторДокументаЭДО, 0);
	КонецЦикла;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ЭлектронныйДокументВходящийЭДО.ИдентификаторДокумента КАК ИдентификаторДокумента,
		|	ЕСТЬNULL(МеткиВремениДанныхЭДО.МеткаВремени, 0) КАК МеткаВремени
		|ИЗ
		|	Документ.ЭлектронныйДокументВходящийЭДО КАК ЭлектронныйДокументВходящийЭДО
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.МеткиВремениДанныхЭДО КАК МеткиВремениДанныхЭДО
		|		ПО ЭлектронныйДокументВходящийЭДО.ИдентификаторОрганизации = МеткиВремениДанныхЭДО.ИдентификаторЭДО
		|		И МеткиВремениДанныхЭДО.ТипДанных = &ТипДанных
		|		И ЭлектронныйДокументВходящийЭДО.ИдентификаторДокумента = МеткиВремениДанныхЭДО.ИдентификаторОбъекта
		|ГДЕ
		|	ЭлектронныйДокументВходящийЭДО.ИдентификаторДокумента В (&ИдентификаторыДокументов)
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	ЭлектронныйДокументИсходящийЭДО.ИдентификаторДокумента КАК ИдентификаторДокумента,
		|	ЕСТЬNULL(МеткиВремениДанныхЭДО.МеткаВремени, 0) КАК МеткаВремени
		|ИЗ
		|	Документ.ЭлектронныйДокументИсходящийЭДО КАК ЭлектронныйДокументИсходящийЭДО
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.МеткиВремениДанныхЭДО КАК МеткиВремениДанныхЭДО
		|		ПО ЭлектронныйДокументИсходящийЭДО.ИдентификаторОрганизации = МеткиВремениДанныхЭДО.ИдентификаторЭДО
		|		И МеткиВремениДанныхЭДО.ТипДанных = &ТипДанных
		|		И ЭлектронныйДокументИсходящийЭДО.ИдентификаторДокумента = МеткиВремениДанныхЭДО.ИдентификаторОбъекта
		|ГДЕ
		|	ЭлектронныйДокументИсходящийЭДО.ИдентификаторДокумента В (&ИдентификаторыДокументов)";
	
	Запрос.УстановитьПараметр("ТипДанных", ТипСинхронизации);
	Запрос.УстановитьПараметр("ИдентификаторыДокументов", ИдентификаторыДокументовЭДО);
	
	УстановитьПривилегированныйРежим(Истина);
	Выборка = Запрос.Выполнить().Выбрать();
	УстановитьПривилегированныйРежим(Ложь);
	
	Пока Выборка.Следующий() Цикл
		МеткиВремениПоИдентификаторам.Вставить(Выборка.ИдентификаторДокумента, Выборка.МеткаВремени);
	КонецЦикла;
	
	МеткиВремениВФорматеСервиса = Новый Массив; // См. МеткиВремениДокументовЭДО
	Для Каждого МеткаВремениПоИдентификатору Из МеткиВремениПоИдентификаторам Цикл
		МеткаВремениВФорматеСервиса = Новый Структура("ИдентификаторДокументаЭДО, МеткаВремени",
			МеткаВремениПоИдентификатору.Ключ, МеткаВремениПоИдентификатору.Значение);
		МеткиВремениВФорматеСервиса.Добавить(МеткаВремениВФорматеСервиса);
	КонецЦикла;
	
	Возврат МеткиВремениВФорматеСервиса;
	
КонецФункции

#КонецОбласти

#КонецОбласти // СлужебныеПроцедурыИФункции