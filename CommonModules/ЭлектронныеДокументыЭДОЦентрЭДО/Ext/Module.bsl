КонецФункции

// Параметры:
//  ДокументыЭДО - Массив из ДокументСсылка.ЭлектронныйДокументВходящийЭДО,ДокументСсылка.ЭлектронныйДокументИсходящийЭДО
// 
// Возвращаемое значение:
//  Массив из Строка
Функция ИдентификаторыДокументовЭДО(ДокументыЭДО) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ
		|	ЭлектронныйДокументВходящийЭДО.ИдентификаторДокумента
		|ИЗ
		|	Документ.ЭлектронныйДокументВходящийЭДО КАК ЭлектронныйДокументВходящийЭДО
		|ГДЕ
		|	ЭлектронныйДокументВходящийЭДО.Ссылка В (&ДокументыЭДО)
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	ЭлектронныйДокументИсходящийЭДО.ИдентификаторДокумента
		|ИЗ
		|	Документ.ЭлектронныйДокументИсходящийЭДО КАК ЭлектронныйДокументИсходящийЭДО
		|ГДЕ
		|	ЭлектронныйДокументИсходящийЭДО.Ссылка В (&ДокументыЭДО)";
	
	Запрос.УстановитьПараметр("ДокументыЭДО",ДокументыЭДО);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Возврат РезультатЗапроса.Выгрузить().ВыгрузитьКолонку("ИдентификаторДокумента");
	
КонецФункции

// Возвращаемое значение:
//  Структура:
//  * ОтпечаткиСертификатов - Массив из Строка
//  * НаборДанных - Массив из См. НовыеДанныеДляПодписанияДокументаЦентраЭДО
//  * ИспользоватьБазовыйТипПодписи - Булево - определяет необходимость использования базового типа подписи (CAdES-BES)
//                                             независимо от пользовательской настройки.
Функция НовоеОписаниеНабораДанныхДляПодписанияВЦентреЭДО()
	Описание = Новый Структура;
	Описание.Вставить("ОтпечаткиСертификатов", Новый Массив);
	Описание.Вставить("НаборДанных", Новый Массив);
	Описание.Вставить("ИспользоватьБазовыйТипПодписи", Ложь);
	Возврат Описание;
КонецФункции

// Возвращаемое значение:
//  Структура:
//  * ИдентификаторДокумента - Строка
//  * Данные - Строка - ДвоичныеДанные в формате base64.
//  * ИдентификаторДанных - Строка
//  * ТребуетсяЗаполнитьПодписанта - Булево
//  * ДоверенностиПоСертификатам - Массив из Структура:
//  ** ОтпечатокСертификата - Строка
//  ** НомерДоверенности - Строка
//  * СертификатыТребующиеДоверенность - Массив из Строка
//
Функция НовыеДанныеДляПодписанияДокументаЦентраЭДО()
	ДанныеДляПодписания = Новый Структура;
	ДанныеДляПодписания.Вставить("ИдентификаторДокумента", "");
	ДанныеДляПодписания.Вставить("Данные", "");
	ДанныеДляПодписания.Вставить("ИдентификаторДанных", "");
	ДанныеДляПодписания.Вставить("ТребуетсяЗаполнитьПодписанта", Ложь);
	ДанныеДляПодписания.Вставить("ДоверенностиПоСертификатам", Новый Массив);
	ДанныеДляПодписания.Вставить("СертификатыТребующиеДоверенность", Новый Массив);
	Возврат ДанныеДляПодписания;
КонецФункции

// Параметры:
//  ДоверенностиПоСертификатам - Соответствие из КлючИЗначение:
//  * Ключ - СправочникСсылка.СертификатыКлючейЭлектроннойПодписиИШифрования
//  * Значение - Массив из СправочникСсылка.МашиночитаемыеДоверенностиОрганизаций,СправочникСсылка.МЧД003
//  ОтпечаткиПоСертификатам - см. ОтпечаткиПоСертификатамУчетныхЗаписейДокументовЭДО
//  НомераДоверенностей - см. МашиночитаемыеДоверенности.ПолучитьНомераДоверенностей
// 
// Возвращаемое значение:
//  Массив из Структура:
//  * ОтпечатокСертификата - Строка 
//  * НомерДоверенности - Строка
Функция ДоверенностиДанныхДляПодписанияВФорматеСервиса(ДоверенностиПоСертификатам, ОтпечаткиПоСертификатам,
	НомераДоверенностей)
	
	Результат = Новый Массив; // См. ДоверенностиДанныхДляПодписанияВФорматеСервиса
	
	Для Каждого ДоверенностиПоСертификату Из ДоверенностиПоСертификатам Цикл
		
		Сертификат = ДоверенностиПоСертификату.Ключ;
		Доверенности = ДоверенностиПоСертификату.Значение;
		
		ОтпечатокПоСертификату = ОтпечаткиПоСертификатам.Найти(Сертификат, "Сертификат");
		Если ОтпечатокПоСертификату = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		Для Каждого Доверенность Из Доверенности Цикл
		
			НомерДоверенности = НомераДоверенностей[Доверенность];
			Если НомерДоверенности = Неопределено Тогда
				Продолжить;
			КонецЕсли;
			
			ДоверенностьПоСертификатуВФорматеСервиса = Новый Структура("ОтпечатокСертификата, НомерДоверенности",
				ОтпечатокПоСертификату.Отпечаток, НомерДоверенности);
			
			Результат.Добавить(ДоверенностьПоСертификатуВФорматеСервиса);
			
		КонецЦикла;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

// Параметры:
//  ДокументыЭДО - Массив из ДокументСсылка.ЭлектронныйДокументВходящийЭДО,ДокументСсылка.ЭлектронныйДокументИсходящийЭДО
// 
// Возвращаемое значение:
//  ТаблицаЗначений:
//  * Сертификат - СправочникСсылка.СертификатыКлючейЭлектроннойПодписиИШифрования
//  * Отпечаток - Строка
Функция ОтпечаткиПоСертификатамУчетныхЗаписейДокументовЭДО(ДокументыЭДО)
	
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ЭлектронныйДокументВходящийЭДО.ИдентификаторОрганизации КАК ИдентификаторЭДО
		|ПОМЕСТИТЬ УчетныеЗаписиДокументовЭДО
		|ИЗ
		|	Документ.ЭлектронныйДокументВходящийЭДО КАК ЭлектронныйДокументВходящийЭДО
		|ГДЕ
		|	ЭлектронныйДокументВходящийЭДО.Ссылка В (&ДокументыЭДО)
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ЭлектронныйДокументИсходящийЭДО.ИдентификаторОрганизации КАК ИдентификаторЭДО
		|ИЗ
		|	Документ.ЭлектронныйДокументИсходящийЭДО КАК ЭлектронныйДокументИсходящийЭДО
		|ГДЕ
		|	ЭлектронныйДокументИсходящийЭДО.Ссылка В (&ДокументыЭДО)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	СертификатыУчетныхЗаписейЭДО.Сертификат КАК Сертификат,
		|	СертификатыУчетныхЗаписейЭДО.Сертификат.Отпечаток КАК Отпечаток
		|ИЗ
		|	РегистрСведений.СертификатыУчетныхЗаписейЭДО КАК СертификатыУчетныхЗаписейЭДО
		|ГДЕ
		|	СертификатыУчетныхЗаписейЭДО.ИдентификаторЭДО В
		|		(ВЫБРАТЬ
		|			ИдентификаторЭДО
		|		ИЗ
		|			УчетныеЗаписиДокументовЭДО)";
	
	Запрос.УстановитьПараметр("ДокументыЭДО", ДокументыЭДО);
	
	Возврат Запрос.Выполнить().Выгрузить();
	
КонецФункции

