// Возвращает результат формирования ответных титулов по электронным документам.
// 
// Параметры:
//  ДанныеОтветныхТитулов - Массив из Структура:
//  * ИдентификаторДокумента - Строка
//  * УчетныеДанные - Структура - данные прикладного решения:
//  ** Данные - Структура - учетные данные для конвертации.
//  ** Формат - Строка - формат учетных данных.
// 
// Возвращаемое значение:
//  Структура:
//  * Ошибки - Неопределено
//           - Массив из Строка
//  * СостоянияДокументовЭДО - Массив из Структура:
//  ** ИдентификаторДокумента - Строка
//  ** ИмяСостояния - Строка
//  ** СостояниеДополнение - Строка
//  ** ДатаИзменения - См. ОбщегоНазначенияБЭД.ДатаВФорматеISO
//  ** Комментарий - Строка
Функция СформироватьОтветныеТитулыДокументовЭДО(ДанныеОтветныхТитулов) Экспорт
	
	Результат = Новый Структура;
	Результат.Вставить("Ошибки", Неопределено);
	Результат.Вставить("СостоянияДокументовЭДО", Новый Массив);
	
	Если Не ЗначениеЗаполнено(ДанныеОтветныхТитулов) Тогда
		Возврат Результат;
	КонецЕсли;
	
	ИдентификаторыДокументов = Новый Массив; // Массив из Строка
	ДанныеПоИдентификаторамДокументов = Новый Соответствие;
	
	Для Каждого ДанныеОтветногоТитула Из ДанныеОтветныхТитулов Цикл
		ИдентификаторыДокументов.Добавить(ДанныеОтветногоТитула.ИдентификаторДокумента);
		Если Не ЗначениеЗаполнено(ДанныеОтветногоТитула.УчетныеДанные.Формат) Тогда
			Продолжить;
		КонецЕсли;
		УчетныеДанные = УчетныеДанныеОтветногоТитулаИзФорматаСервиса(ДанныеОтветногоТитула.УчетныеДанные);
		ДанныеПоИдентификаторамДокументов.Вставить(ДанныеОтветногоТитула.ИдентификаторДокумента, УчетныеДанные);
	КонецЦикла;
	
	РеквизитыДокументов = РеквизитыДокументовПоИдентификаторам(ИдентификаторыДокументов);
	
	КонтекстДиагностики = ОбработкаНеисправностейБЭД.НовыйКонтекстДиагностики();
	РезультатДействийПоЭДО = ЭлектронныеДокументыЭДО.НовыйРезультатДействийПоЭДО(КонтекстДиагностики);
	
	ОбъектыДействий = ЭлектронныеДокументыЭДОКлиентСервер.НовыеОбъектыДействийПоЭДО();
	ОбъектыДействий.ЭлектронныеДокументы = РеквизитыДокументов.ВыгрузитьКолонку("Ссылка");
	Выборка = ЭлектронныеДокументыЭДО.ВыборкаДокументовДляФормированияОтвета(ОбъектыДействий);
	
	Пока Выборка.Следующий() Цикл
		РеквизитыДокумента = РеквизитыДокументов.Найти(Выборка.ЭлектронныйДокумент, "Ссылка");
		УчетныеДанные = ДанныеПоИдентификаторамДокументов[РеквизитыДокумента.ИдентификаторДокумента];
		ЭлектронныеДокументыЭДО.СформироватьОтветПоДокументу(Выборка.ЭлектронныйДокумент, РезультатДействийПоЭДО, УчетныеДанные);
	КонецЦикла;
	
	ДокументыЭДО = ОбщегоНазначения.ВыгрузитьКолонку(РезультатДействийПоЭДО.Итог.ОбработанныеДокументы, "Ключ");
	
	Результат.СостоянияДокументовЭДО = СостоянияДокументовЭДОВФорматеСервиса(ДокументыЭДО);
	
	Возврат Результат;
	
КонецФункции

// Возвращает описания отправленных документов.
// 
// Параметры:
//  МаркерыАвторизации - Массив из см. УчетныеЗаписиЭДОЦентрЭДО.НовыйМаркерАвторизацииПоУчетнойЗаписиЭДО
// 
// Возвращаемое значение:
//  Структура:
//  * Ошибки - Неопределено
//           - Массив из Строка
//  * Отправлено - Число
//  
Функция ОтправитьКонтейнерыЭДО(МаркерыАвторизации) Экспорт
	
	Результат = Новый Структура;
	Результат.Вставить("Ошибки", Неопределено);
	Результат.Вставить("Отправлено", 0);
	
	ИдентификаторыУчетныхЗаписей = ОбщегоНазначения.ВыгрузитьКолонку(МаркерыАвторизации, "ИдентификаторУчетнойЗаписиЭДО");
	
	ПараметрыВыполнения = ЭлектронныеДокументыЭДОКлиентСервер.НовыеПараметрыВыполненияДействийПоЭДО();
	ПараметрыВыполнения.ОбъектыДействий.ИдентификаторыОрганизаций = ИдентификаторыУчетныхЗаписей;
	ЭлектронныеДокументыЭДО.ДобавитьДействие(ПараметрыВыполнения.НаборДействий, Перечисления.ДействияПоЭДО.Отправить);
	ПараметрыВыполнения.РасшифрованныеМаркеры = РасшифрованныеМаркерыИзМаркеровАвторизации(МаркерыАвторизации);
	
	РезультатДействийПоЭДО = ЭлектронныеДокументыЭДОСлужебный.ВыполнитьДействияЭДО(ПараметрыВыполнения);
	
	Отправлено = РезультатДействийПоЭДО.Итог.ОбработаноПоДействиям[Перечисления.ДействияПоЭДО.Отправить];
	Если ЗначениеЗаполнено(Отправлено) Тогда
		Результат.Отправлено = Отправлено;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

