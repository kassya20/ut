//  ФайлыСообщений - Массив из СправочникСсылка.СообщениеЭДОПрисоединенныеФайлы
// 
// Возвращаемое значение:
//  Массив из см. НовыеДанныеФайлаСообщенияПолнойСинхронизацииДокумента
Функция ДанныеФайловСообщенийПолнойСинхронизацииДокумента(ФайлыСообщений)
	
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ
		|	СообщениеЭДОПрисоединенныеФайлы.ВладелецФайла КАК ВладелецФайла,
		|	СообщениеЭДОПрисоединенныеФайлы.Ссылка КАК Ссылка,
		|	СообщениеЭДОПрисоединенныеФайлы.ПолноеИмяФайла КАК ПолноеИмяФайла
		|ИЗ
		|	Справочник.СообщениеЭДОПрисоединенныеФайлы КАК СообщениеЭДОПрисоединенныеФайлы
		|ГДЕ
		|	СообщениеЭДОПрисоединенныеФайлы.Ссылка В (&ФайлыСообщений)";
	
	Запрос.УстановитьПараметр("ФайлыСообщений", ФайлыСообщений);
	
	УстановитьПривилегированныйРежим(Истина);
	РезультатЗапроса = Запрос.Выполнить();
	УстановитьПривилегированныйРежим(Ложь);
	
	Выборка = РезультатЗапроса.Выбрать();
	
	ДвоичныеДанныеФайлов = РаботаСФайлами.ДвоичныеДанныеФайлов(ФайлыСообщений);
	
	ДанныеФайловСообщений = Новый Массив; // Массив из см. НовыеДанныеФайлаСообщенияПолнойСинхронизацииДокумента
	
	Пока Выборка.Следующий() Цикл
		ДвоичныеДанные = ДвоичныеДанныеФайлов[Выборка.Ссылка];
		
		ДанныеФайлаСообщения = НовыеДанныеФайлаСообщенияПолнойСинхронизацииДокумента();
		ДанныеФайлаСообщения.ИдентификаторСообщения = Строка(Выборка.ВладелецФайла.УникальныйИдентификатор());
		ДанныеФайлаСообщения.Идентификатор = Строка(Выборка.Ссылка.УникальныйИдентификатор());
		ДанныеФайлаСообщения.Имя = Выборка.ПолноеИмяФайла;
		ДанныеФайлаСообщения.Данные = Base64Строка(ДвоичныеДанные);
		ДанныеФайловСообщений.Добавить(ДанныеФайлаСообщения);
	КонецЦикла;
	
	Возврат ДанныеФайловСообщений;
	
КонецФункции

// Возвращаемое значение:
//  Структура:
//  * Идентификатор - Строка
//  * ИдентификаторФайла - Строка
//  * ПорядковыйНомер - Число
//  * Подпись - Строка - Двоичные данные в формате base64.
//  * ИмяФайлаПодписи - Строка
//  * Сертификат - Строка - Двоичные данные в формате base64.
//  * ДатаПодписи - Строка - см. ОбщегоНазначенияБЭД.ДатаВФорматеISO
//  * ПодписьВерна - Булево
//  * ДатаПроверкиПодписи - Строка - см. ОбщегоНазначенияБЭД.ДатаВФорматеISO
//  * ТипПодписи - Строка
//  * СрокДействияПоследнейМеткиВремени - см. ОбщегоНазначенияБЭД.ДатаВФорматеISO
//  * ПропуститьПриПродлении - Булево
Функция НовыеДанныеПодписиФайлаПолнойСинхронизацииДокумента()
	
	Данные = Новый Структура;
	Данные.Вставить("Идентификатор", "");
	Данные.Вставить("ИдентификаторФайла", "");
	Данные.Вставить("ПорядковыйНомер", 0);
	Данные.Вставить("Подпись", "");
	Данные.Вставить("ИмяФайлаПодписи", "");
	Данные.Вставить("Сертификат", "");
	Данные.Вставить("ДатаПодписи", "");
	Данные.Вставить("ПодписьВерна", Ложь);
	Данные.Вставить("ДатаПроверкиПодписи", "");
	Данные.Вставить("ТипПодписи", "");
	Данные.Вставить("СрокДействияПоследнейМеткиВремени", "");
	Данные.Вставить("ПропуститьПриПродлении", Ложь);
	Возврат Данные;
	
КонецФункции

// Параметры:
//  КлючиПодписейФайлов - ТаблицаЗначений:
//  * ПодписанныйОбъект - СправочникСсылка.СообщениеЭДОПрисоединенныеФайлы
//  * ПорядковыйНомер - Число
// 
// Возвращаемое значение:
//  Массив из см. НовыеДанныеПодписиФайлаПолнойСинхронизацииДокумента
Функция ДанныеПодписейФайловПолнойСинхронизацииДокумента(КлючиПодписейФайлов)
	
	ДанныеПодписей = Новый Массив; // Массив из см. НовыеДанныеПодписиФайлаПолнойСинхронизацииДокумента
	
	УстановитьПривилегированныйРежим(Истина);
	УстановленныеПодписиОбъектов = КриптографияБЭД.УстановленныеПодписиОбъектов(КлючиПодписейФайлов);
	УстановитьПривилегированныйРежим(Ложь);
	
	Для Каждого УстановленныеПодписиОбъекта Из УстановленныеПодписиОбъектов Цикл
		ПодписанныйОбъект = УстановленныеПодписиОбъекта.Ключ; // СправочникСсылка.СообщениеЭДОПрисоединенныеФайлы
		СвойстваПодписей = УстановленныеПодписиОбъекта.Значение; // Массив из см. КриптографияБЭДКлиентСервер.НовыеСвойстваПодписи
		Для Каждого СвойстваПодписи Из СвойстваПодписей Цикл
			ДанныеПодписиФайла = НовыеДанныеПодписиФайлаПолнойСинхронизацииДокумента();
			ДанныеПодписиФайла.Идентификатор = Строка(СвойстваПодписи.ИдентификаторПодписи);
			ДанныеПодписиФайла.ИдентификаторФайла = Строка(ПодписанныйОбъект.УникальныйИдентификатор());
			ДанныеПодписиФайла.ПорядковыйНомер = СвойстваПодписи.ПорядковыйНомер;
			ДанныеПодписиФайла.ИмяФайлаПодписи = СвойстваПодписи.ИмяФайлаПодписи;
			ДанныеПодписиФайла.Подпись = Base64Строка(СвойстваПодписи.Подпись);
			ДанныеПодписиФайла.Сертификат = Base64Строка(СвойстваПодписи.Сертификат);
			ДанныеПодписиФайла.ДатаПодписи = ОбщегоНазначенияБЭД.ДатаВФорматеISO(СвойстваПодписи.ДатаПодписи);
			ДанныеПодписиФайла.ПодписьВерна = СвойстваПодписи.ПодписьВерна;
			ДанныеПодписиФайла.ДатаПроверкиПодписи = ОбщегоНазначенияБЭД.ДатаВФорматеISO(
				СвойстваПодписи.ДатаПроверкиПодписи);
			ДанныеПодписиФайла.ПропуститьПриПродлении = СвойстваПодписи.ПропуститьПриПродлении;
			Если ЗначениеЗаполнено(СвойстваПодписи.ТипПодписи) Тогда
				ДанныеПодписиФайла.ТипПодписи = ОбщегоНазначения.ИмяЗначенияПеречисления(СвойстваПодписи.ТипПодписи);
			КонецЕсли;
			Если ЗначениеЗаполнено(СвойстваПодписи.СрокДействияПоследнейМеткиВремени) Тогда
				ДанныеПодписиФайла.СрокДействияПоследнейМеткиВремени = ОбщегоНазначенияБЭД.ДатаВФорматеISO(
					СвойстваПодписи.СрокДействияПоследнейМеткиВремени);
			КонецЕсли;
			
			ДанныеПодписей.Добавить(ДанныеПодписиФайла);
		КонецЦикла;
	КонецЦикла;
	
	Возврат ДанныеПодписей;
	
КонецФункции

// Возвращаемое значение:
//  Структура:
//  * ИдентификаторФайла - Строка
//  * ХешПодписи - Строка
//  * Доверенность - Неопределено
//  * ПроверкаВыполнена - Булево
//  * ДатаПроверки - Строка - см. ОбщегоНазначенияБЭД.ДатаВФорматеISO
//  * ПодписьВерна - Булево
//  * ПротоколПроверки - Неопределено
//                     - см. МашиночитаемыеДоверенностиКлиентСервер.НовыйПротоколПроверкиМЧД
Функция НовыеДанныеПроверкиПодписиПолнойСинхронизацииДокумента()
	
	Данные = Новый Структура;
	Данные.Вставить("ИдентификаторФайла", "");
	Данные.Вставить("ХешПодписи", "");
	Данные.Вставить("Доверенность", Неопределено);
	Данные.Вставить("ПроверкаВыполнена", Ложь);
	Данные.Вставить("ДатаПроверки", "");
	Данные.Вставить("ПодписьВерна", Ложь);
	Данные.Вставить("ПротоколПроверки", Неопределено);
	Возврат Данные;
	
КонецФункции

// Возвращаемое значение:
//  Структура:
//  * ИдентификаторФайла - Строка
//  * ХешПодписи - Строка
//  * ИдентификаторДоверенности - Строка
//  * ПроверкаВыполнена - Булево
//  * ДатаПроверки - Строка - см. ОбщегоНазначенияБЭД.ДатаВФорматеISO
//  * ПодписьВерна - Булево
//  * ПротоколПроверки - Неопределено
//                     - см. МашиночитаемыеДоверенностиКлиентСервер.НовыйПротоколПроверкиМЧД
Функция НовыеДанныеПроверкиПодписиПолнойСинхронизацииДокументаВерсия3()
	
	Данные = Новый Структура;
	Данные.Вставить("ИдентификаторФайла", "");
	Данные.Вставить("ХешПодписи", "");
	Данные.Вставить("ИдентификаторДоверенности", "");
	Данные.Вставить("ПроверкаВыполнена", Ложь);
	Данные.Вставить("ДатаПроверки", "");
	Данные.Вставить("ПодписьВерна", Ложь);
	Данные.Вставить("ПротоколПроверки", Неопределено);
	Возврат Данные;
	
КонецФункции

// Параметры:
//  КлючиПроверокПодписейПоМЧД - ТаблицаЗначений:
//  * ПодписанныйОбъект - СправочникСсылка.СообщениеЭДОПрисоединенныеФайлы
//  * ХешПодписи - Строка
//
// Возвращаемое значение:
//  ВыборкаИзРезультатаЗапроса:
//  * ПодписанныйОбъект - СправочникСсылка.СообщениеЭДОПрисоединенныеФайлы
//  * ХешПодписи - Строка
//  * Доверенность - ОпределяемыйТип.МашиночитаемаяДоверенность
//  * ПроверкаВыполнена - Булево
//  * ДатаПроверки - Дата
//  * ПодписьВерна - Булево
//  * ПротоколПроверки - ХранилищеЗначения
Функция ВыбратьЭлектронныеПодписиПоМЧД(КлючиПроверокПодписейПоМЧД)
	
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ
		|	КлючиПроверокПодписейПоМЧД.ПодписанныйОбъект КАК ПодписанныйОбъект,
		|	КлючиПроверокПодписейПоМЧД.ХешПодписи КАК ХешПодписи
		|ПОМЕСТИТЬ КлючиПроверокПодписейПоМЧД
		|ИЗ
		|	&КлючиПроверокПодписейПоМЧД КАК КлючиПроверокПодписейПоМЧД
		|
		|ИНДЕКСИРОВАТЬ ПО
		|	ПодписанныйОбъект
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ЭлектронныеПодписиПоМЧД.ПодписанныйОбъект КАК ПодписанныйОбъект,
		|	ЭлектронныеПодписиПоМЧД.ХешПодписи КАК ХешПодписи,
		|	ЭлектронныеПодписиПоМЧД.Доверенность КАК Доверенность,
		|	ЭлектронныеПодписиПоМЧД.ПроверкаВыполнена КАК ПроверкаВыполнена,
		|	ЭлектронныеПодписиПоМЧД.ДатаПроверки КАК ДатаПроверки,
		|	ЭлектронныеПодписиПоМЧД.ПодписьВерна КАК ПодписьВерна,
		|	ЭлектронныеПодписиПоМЧД.ПротоколПроверки КАК ПротоколПроверки
		|ИЗ
		|	РегистрСведений.ЭлектронныеПодписиПоМЧД КАК ЭлектронныеПодписиПоМЧД
		|ГДЕ
		|	(ЭлектронныеПодписиПоМЧД.ПодписанныйОбъект, ЭлектронныеПодписиПоМЧД.ХешПодписи) В
		|		(ВЫБРАТЬ ПодписанныйОбъект, ХешПодписи ИЗ КлючиПроверокПодписейПоМЧД)";
	
	Запрос.УстановитьПараметр("КлючиПроверокПодписейПоМЧД", КлючиПроверокПодписейПоМЧД);
	
	УстановитьПривилегированныйРежим(Истина);
	РезультатЗапроса = Запрос.Выполнить();
	УстановитьПривилегированныйРежим(Ложь);
	
	Возврат РезультатЗапроса.Выбрать();
	
КонецФункции

// Параметры:
//  КлючиПроверокПодписейПоМЧД - ТаблицаЗначений:
//  * ПодписанныйОбъект - СправочникСсылка.СообщениеЭДОПрисоединенныеФайлы
//  * ХешПодписи - Строка
// 
// Возвращаемое значение:
//  Массив из см. НовыеДанныеПроверкиПодписиПолнойСинхронизацииДокумента
Функция ДанныеПроверокПодписейПолнойСинхронизацииДокумента(КлючиПроверокПодписейПоМЧД)
	
	ДанныеПроверок = Новый Массив; // Массив из см. НовыеДанныеПроверкиПодписиПолнойСинхронизацииДокумента
	
	Выборка = ВыбратьЭлектронныеПодписиПоМЧД(КлючиПроверокПодписейПоМЧД);
	
	Пока Выборка.Следующий() Цикл
		ДанныеПроверкиПодписи = НовыеДанныеПроверкиПодписиПолнойСинхронизацииДокумента();
		ДанныеПроверкиПодписи.ИдентификаторФайла = Строка(Выборка.ПодписанныйОбъект.УникальныйИдентификатор());
		ДанныеПроверкиПодписи.ХешПодписи = Выборка.ХешПодписи;
		ДанныеПроверкиПодписи.ПроверкаВыполнена = Выборка.ПроверкаВыполнена;
		ДанныеПроверкиПодписи.ДатаПроверки = ОбщегоНазначенияБЭД.ДатаВФорматеISO(Выборка.ДатаПроверки);
		ДанныеПроверкиПодписи.ПодписьВерна = Выборка.ПодписьВерна;
		
		Если ЗначениеЗаполнено(Выборка.Доверенность) Тогда
			ДанныеПроверкиПодписи.Доверенность = МашиночитаемыеДоверенностиЦентрЭДО.ДанныеДоверенностиВФорматеСервиса(
				Выборка.Доверенность);
		КонецЕсли;
		
		ПротоколПроверки = Выборка.ПротоколПроверки.Получить(); // См. МашиночитаемыеДоверенностиКлиентСервер.НовыйПротоколПроверкиМЧД
		Если ЗначениеЗаполнено(ПротоколПроверки) Тогда
			ДанныеПроверкиПодписи.ПротоколПроверки = ПротоколПроверки;
		КонецЕсли;
		
		ДанныеПроверок.Добавить(ДанныеПроверкиПодписи);
	КонецЦикла;
	
	Возврат ДанныеПроверок;
	
КонецФункции

// Параметры:
//  КлючиПроверокПодписейПоМЧД - ТаблицаЗначений:
//  * ПодписанныйОбъект - СправочникСсылка.СообщениеЭДОПрисоединенныеФайлы
//  * ХешПодписи - Строка
// 
// Возвращаемое значение:
//  Массив из см. НовыеДанныеПроверкиПодписиПолнойСинхронизацииДокумента
Функция ДанныеПроверокПодписейПолнойСинхронизацииДокументаВерсия3(КлючиПроверокПодписейПоМЧД)
	
	ДанныеПроверок = Новый Массив; // Массив из см. НовыеДанныеПроверкиПодписиПолнойСинхронизацииДокумента
	
	Выборка = ВыбратьЭлектронныеПодписиПоМЧД(КлючиПроверокПодписейПоМЧД);
	
	Пока Выборка.Следующий() Цикл
		ДанныеПроверкиПодписи = НовыеДанныеПроверкиПодписиПолнойСинхронизацииДокументаВерсия3();
		ДанныеПроверкиПодписи.ИдентификаторФайла = Строка(Выборка.ПодписанныйОбъект.УникальныйИдентификатор());
		ДанныеПроверкиПодписи.ХешПодписи = Выборка.ХешПодписи;
		ДанныеПроверкиПодписи.ПроверкаВыполнена = Выборка.ПроверкаВыполнена;
		ДанныеПроверкиПодписи.ДатаПроверки = ОбщегоНазначенияБЭД.ДатаВФорматеISO(Выборка.ДатаПроверки);
		ДанныеПроверкиПодписи.ПодписьВерна = Выборка.ПодписьВерна;
		
		Если ЗначениеЗаполнено(Выборка.Доверенность) Тогда
			ДанныеПроверкиПодписи.ИдентификаторДоверенности =
				МашиночитаемыеДоверенностиЦентрЭДО.ИдентификаторДоверенности(Выборка.Доверенность);
		КонецЕсли;
		
		ПротоколПроверки = Выборка.ПротоколПроверки.Получить(); // См. МашиночитаемыеДоверенностиКлиентСервер.НовыйПротоколПроверкиМЧД
		Если ЗначениеЗаполнено(ПротоколПроверки) Тогда
			ДанныеПроверкиПодписи.ПротоколПроверки = ПротоколПроверки;
		КонецЕсли;
		
		ДанныеПроверок.Добавить(ДанныеПроверкиПодписи);
	КонецЦикла;
	
	Возврат ДанныеПроверок;
	
КонецФункции
// Возвращаемое значение:
//  Структура:
// * Тип - Строка - см. Перечисление.ТипыСобытийДокументаЦентраЭДО
// * Параметры - Неопределено,Структура
