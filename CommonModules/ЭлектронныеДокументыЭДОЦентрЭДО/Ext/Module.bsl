// 
// Возвращаемое значение:
//  Массив из Произвольный
Функция ВыгрузитьУникальныеЗначенияСвойстваКлючейНастроек(КлючиНастроек, ИмяСвойства)
	
	ЗначенияСвойства = Новый Массив; // Массив из Произвольный
	
	Для Каждого КлючНастройкиПоИдентификатору Из КлючиНастроек Цикл
		КлючНастройки = КлючНастройкиПоИдентификатору.Значение;
		Значение = КлючНастройки[ИмяСвойства]; // Произвольный
		Если ЗначенияСвойства.Найти(Значение) = Неопределено Тогда
			ЗначенияСвойства.Добавить(Значение);
		КонецЕсли;
	КонецЦикла;
	
	Возврат ЗначенияСвойства;
	
КонецФункции

// Параметры:
//  ИдентификаторыДокументов - Массив из Строка
// 
// Возвращаемое значение:
//  ТаблицаЗначений:
//  * Ссылка - ДокументСсылка.ЭлектронныйДокументВходящийЭДО,ДокументСсылка.ЭлектронныйДокументИсходящийЭДО
//  * ИдентификаторДокумента - Строка
Функция РеквизитыДокументовПоИдентификаторам(ИдентификаторыДокументов)
	
	Если Не ЗначениеЗаполнено(ИдентификаторыДокументов) Тогда
		Возврат Новый ТаблицаЗначений();
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ЭлектронныйДокументЭДО.Ссылка КАК Ссылка,
		|	ЭлектронныйДокументЭДО.ИдентификаторДокумента КАК ИдентификаторДокумента
		|ИЗ
		|	Документ.ЭлектронныйДокументВходящийЭДО КАК ЭлектронныйДокументЭДО
		|ГДЕ
		|	ЭлектронныйДокументЭДО.ИдентификаторДокумента В (&ИдентификаторыДокументов)
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	ЭлектронныйДокументЭДО.Ссылка,
		|	ЭлектронныйДокументЭДО.ИдентификаторДокумента
		|ИЗ
		|	Документ.ЭлектронныйДокументИсходящийЭДО КАК ЭлектронныйДокументЭДО
		|ГДЕ
		|	ЭлектронныйДокументЭДО.ИдентификаторДокумента В (&ИдентификаторыДокументов)";
	
	Запрос.УстановитьПараметр("ИдентификаторыДокументов", ИдентификаторыДокументов);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Возврат РезультатЗапроса.Выгрузить();
	
КонецФункции

// Параметры:
//  ИдентификаторыФайлов - Массив из Строка
// 
// Возвращаемое значение:
//  Соответствие из КлючИЗначение:
//  * Ключ - Строка
//  * Значение - СправочникСсылка.СообщениеЭДОПрисоединенныеФайлы
Функция ФайлыПоИдентификаторам(ИдентификаторыФайлов)
	ИдентификаторыПоТипам = Новый Соответствие;
	ИдентификаторыПоТипам.Вставить(Тип("СправочникСсылка.СообщениеЭДОПрисоединенныеФайлы"), ИдентификаторыФайлов);
	Возврат СсылкиПоИдентификаторам(ИдентификаторыПоТипам);
КонецФункции

// Параметры:
//  ИдентификаторыПоТипам - Соответствие из КлючИЗначение:
//  * Ключ - Тип
//  * Значение - Массив из Строка
// 
// Возвращаемое значение:
//  Соответствие из КлючИЗначение:
//  * Ключ - Строка
//  * Значение - ЛюбаяСсылка
//
Функция СсылкиПоИдентификаторам(ИдентификаторыПоТипам)
	
	ШаблонЗапроса = 
		"ВЫБРАТЬ
		|	Таблица.Ссылка
		|ИЗ
		|	&ИмяТаблицы КАК Таблица
		|ГДЕ
		|	Таблица.Ссылка В (&МассивСсылок)";
	
	ТекстыЗапросов = Новый Массив; // Массив из Строка
	
	Запрос = Новый Запрос;
	
	Счетчик = 0;
	Для Каждого ИдентификаторыПоТипу Из ИдентификаторыПоТипам Цикл
		Счетчик = Счетчик + 1;
		
		Тип = ИдентификаторыПоТипу.Ключ;
		Ссылка = Новый(Тип); // ЛюбаяСсылка
		ИмяТаблицы = ОбщегоНазначения.ИмяТаблицыПоСсылке(Ссылка);
		МенеджерОбъекта = ОбщегоНазначения.МенеджерОбъектаПоПолномуИмени(ИмяТаблицы);
		
		МассивСсылок = Новый Массив; // Массив из ЛюбаяСсылка
		Для Каждого Идентификатор Из ИдентификаторыПоТипу.Значение Цикл
			УникальныйИдентификаторСсылки = Новый УникальныйИдентификатор(Идентификатор);
			Ссылка = МенеджерОбъекта.ПолучитьСсылку(УникальныйИдентификаторСсылки);
			МассивСсылок.Добавить(Ссылка);
		КонецЦикла;
		
		ТекстЗапроса = СтрЗаменить(ШаблонЗапроса, "&ИмяТаблицы", ИмяТаблицы);
		ИмяПараметра = "МассивСсылок" + Счетчик;
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "МассивСсылок", ИмяПараметра);
		ТекстыЗапросов.Добавить(ТекстЗапроса);
		Запрос.УстановитьПараметр(ИмяПараметра, МассивСсылок);
	КонецЦикла;
	
	Запрос.Текст = СтрСоединить(ТекстыЗапросов, Символы.ПС + "ОБЪЕДИНИТЬ ВСЕ" + Символы.ПС);
	
	УстановитьПривилегированныйРежим(Истина);
	Выборка = Запрос.Выполнить().Выбрать();
	УстановитьПривилегированныйРежим(Ложь);
	
	Результат = Новый Соответствие;
	
	Пока Выборка.Следующий() Цикл
		Результат.Вставить(Строка(Выборка.Ссылка.УникальныйИдентификатор()), Выборка.Ссылка);
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

// Параметры:
//  Ссылка - ЛюбаяСсылка
// 
// Возвращаемое значение:
//  Строка
Функция ИдентификаторСсылки(Ссылка)
	Если ЗначениеЗаполнено(Ссылка) Тогда
		Возврат Строка(Ссылка.УникальныйИдентификатор());
	Иначе
		Возврат "";
	КонецЕсли;
КонецФункции

// Подписанные сообщения по файлам.
// 
// Параметры:
//  ПодписиФайлов - См. ДобавитьПодписиФайловДокументовЭДО.ПодписиФайлов
//  КонтекстДиагностики - См. ОбработкаНеисправностейБЭД.НовыйКонтекстДиагностики
// 
// Возвращаемое значение:
//  Массив из см. НовоеОписаниеПодписанногоСообщения
Функция ПодписанныеСообщенияПоФайлам(ПодписиФайлов, КонтекстДиагностики)
	
	ПодписанныеСообщения = Новый Массив; // Массив из см. НовоеОписаниеПодписанногоСообщения
	
	ИдентификаторыФайлов = ОбщегоНазначения.ВыгрузитьКолонку(ПодписиФайлов, "ИдентификаторДанных");
	
	ФайлыПоИдентификаторам = ФайлыПоИдентификаторам(ИдентификаторыФайлов);
	
	ФайлыДокументовЭДО = ОбщегоНазначения.ВыгрузитьКолонку(ФайлыПоИдентификаторам, "Значение"); // Массив из см. СправочникСсылка.СообщениеЭДОПрисоединенныеФайлы
	
	СообщенияПоФайлам = ОбщегоНазначения.ЗначениеРеквизитаОбъектов(ФайлыДокументовЭДО, "ВладелецФайла");
	
	ДвоичныеДанныеФайлов = РаботаСФайлами.ДвоичныеДанныеФайлов(ФайлыДокументовЭДО);
	
	Если Не ОбщегоНазначения.РазделениеВключено() Тогда
		ПрограммаКриптографии = Справочники.ПрограммыЭлектроннойПодписиИШифрования.НайтиПоРеквизиту("ТипПрограммы", 80);	
		МенеджерКриптографии = КриптографияБЭД.МенеджерКриптографии(,,ПрограммаКриптографии);
	Иначе
		МенеджерКриптографии = Неопределено;
	КонецЕсли;
	
	Для Каждого ПодписьФайла Из ПодписиФайлов Цикл
		
		Файл = ФайлыПоИдентификаторам[ПодписьФайла.ИдентификаторДанных];
		Если Файл = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		Сообщение = СообщенияПоФайлам[Файл];
		Если Сообщение = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		Данные  = ДвоичныеДанныеФайлов[Файл];
		Подпись = Base64Значение(ПодписьФайла.Подпись);
		
		РезультатПроверки = КриптографияБЭД.ПроверитьПодпись(МенеджерКриптографии, Данные, Подпись, КонтекстДиагностики);
		
		Если Не ЗначениеЗаполнено(РезультатПроверки.СвойстваПодписи.Сертификат) Тогда
			МенеджерКриптографии = ЭлектроннаяПодпись.МенеджерКриптографии("ПолучениеСертификатов", Ложь);
			Если МенеджерКриптографии <> Неопределено Тогда
				Сертификаты = МенеджерКриптографии.ПолучитьСертификатыИзПодписи(Подпись);
				КриптографияБЭД.ЗаполнитьСвойстваПоСертификатамИзПодписи(РезультатПроверки.СвойстваПодписи, Сертификаты);
			КонецЕсли;
		КонецЕсли;
		
		СвойстваПодписи = РезультатПроверки.СвойстваПодписи;
		СвойстваПодписи.Подпись = Подпись;
		СвойстваПодписи.ДатаПодписи = ЭлектроннаяПодпись.ДатаПодписания(Подпись);
		СвойстваПодписи.Комментарий = РезультатПроверки.ОписаниеОшибки;
		
		ВыбранныйСертификат = ЭлектроннаяПодпись.СсылкаНаСертификат(СвойстваПодписи.Сертификат);
		
		ПодписанноеСообщение = НовоеОписаниеПодписанногоСообщения();
		ПодписанноеСообщение.Ссылка = Сообщение;
		ПодписанноеСообщение.ПрисоединенныйФайл = Файл;
		ПодписанноеСообщение.СвойстваПодписи = СвойстваПодписи;
		ПодписанноеСообщение.ВыбранныйСертификат = ВыбранныйСертификат;
		ПодписанноеСообщение.Данные = Данные;
		
		Если ЗначениеЗаполнено(ПодписьФайла.НомерДоверенности) Тогда
			ПодписанноеСообщение.ВыбраннаяМЧД = МашиночитаемыеДоверенности.ПолучитьДоверенностьИзЖурналаПоНомеру(
				ПодписьФайла.НомерДоверенности);
		КонецЕсли;
		
		ПодписанныеСообщения.Добавить(ПодписанноеСообщение);
		
	КонецЦикла;
	
	Возврат ПодписанныеСообщения;
	
КонецФункции

// Возвращает пустое описание подписанного сообщения.
// 
// Возвращаемое значение:
//  Структура - Описание:
//  * Ссылка - ДокументСсылка.СообщениеЭДО
//  		 - СправочникСсылка.МашиночитаемыеДоверенностиОрганизаций
//  * ПрисоединенныйФайл - СправочникСсылка.СообщениеЭДОПрисоединенныеФайлы
// 						 - СправочникСсылка.МашиночитаемыеДоверенностиОрганизаций
//  * СвойстваПодписи - Неопределено
//                    - См. КриптографияБЭДКлиентСервер.НовыеСвойстваПодписи
//  * ВыбранныйСертификат - СправочникСсылка.СертификатыКлючейЭлектроннойПодписиИШифрования
//  * Данные - Неопределено
//           - ДвоичныеДанные
//  * ОбновитьДанные - Булево
//  * ВыбраннаяМЧД   - СправочникСсылка.МашиночитаемыеДоверенностиОрганизаций 
//                   - Неопределено
//  * ТребуетсяМЧД   - Булево
//
Функция НовоеОписаниеПодписанногоСообщения()
	ОписаниеДанных = Новый Структура;
	ОписаниеДанных.Вставить("Ссылка", Документы.СообщениеЭДО.ПустаяСсылка());
	ОписаниеДанных.Вставить("ПрисоединенныйФайл", Справочники.СообщениеЭДОПрисоединенныеФайлы.ПустаяСсылка());
	ОписаниеДанных.Вставить("СвойстваПодписи", Неопределено);
	ОписаниеДанных.Вставить("ВыбранныйСертификат", Справочники.СертификатыКлючейЭлектроннойПодписиИШифрования.ПустаяСсылка());
	ОписаниеДанных.Вставить("Данные", Неопределено);
	ОписаниеДанных.Вставить("ОбновитьДанные", Ложь);
	ОписаниеДанных.Вставить("ВыбраннаяМЧД", Неопределено);
	ОписаниеДанных.Вставить("ТребуетсяМЧД", Ложь);
	Возврат ОписаниеДанных;
КонецФункции

// Параметры:
//  МаркерыАвторизации - Массив из см. УчетныеЗаписиЭДОЦентрЭДО.НовыйМаркерАвторизацииПоУчетнойЗаписиЭДО
// 
// Возвращаемое значение:
//  См. КриптографияБЭДКлиентСервер.НовыйНаборРасшифрованныхДанных
Функция РасшифрованныеМаркерыИзМаркеровАвторизации(МаркерыАвторизации) Экспорт
	
	Результат = КриптографияБЭДКлиентСервер.НовыйНаборРасшифрованныхДанных();
	
	Если Не ЗначениеЗаполнено(МаркерыАвторизации) Тогда
		Возврат Результат;
	КонецЕсли;
	
	Для Каждого МаркерАвторизации Из МаркерыАвторизации Цикл
		
		Сертификат = ЭлектроннаяПодпись.СсылкаНаСертификат(МаркерАвторизации.ОтпечатокСертификата);
		ПараметрыМаркера = Новый Структура("Сертификат, Данные", Сертификат, Base64Значение(МаркерАвторизации.Данные));
		Результат.Вставить(МаркерАвторизации.ИдентификаторУчетнойЗаписиЭДО, ПараметрыМаркера);
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

// Параметры:
//  ОтпечаткиСертификатов - Массив из Строка
// 
// Возвращаемое значение:
//  См. КриптографияБЭДКлиентСервер.НовыеРезультатыПолученияОтпечатков
Функция РезультатыПолученияОтпечатков(ОтпечаткиСертификатов)
	
	РезультатПолученияОтпечатков = КриптографияБЭДКлиентСервер.НовыйРезультатПолученияОтпечатков();
	РезультатПолученияОтпечатков.Доступность = Истина;
	РезультатПолученияОтпечатков.Отпечатки = ОтпечаткиСертификатов;
	
	РезультатыПолученияОтпечатков = КриптографияБЭДКлиентСервер.НовыеРезультатыПолученияОтпечатков();
	РезультатыПолученияОтпечатков.Клиент = РезультатПолученияОтпечатков;
	РезультатыПолученияОтпечатков.Сервер = КриптографияБЭДКлиентСервер.НовыйРезультатПолученияОтпечатков();
	РезультатыПолученияОтпечатков.Облако = КриптографияБЭДКлиентСервер.НовыйРезультатПолученияОтпечатков();
	
	Возврат РезультатыПолученияОтпечатков;
	
КонецФункции

// Возвращаемое значение:
//  Структура:
//  * ИдентификаторДокумента - Строка
//  * ИмяСостояния - Строка
//  * СостояниеДополнение - Строка
//  * ДатаИзменения - См. ОбщегоНазначенияБЭД.ДатаВФорматеISO
//  * Комментарий - Строка
Функция НовоеСостояниеДокументаЭДОВФорматеСервиса()
	СостояниеДокументаЭДО = Новый Структура;
	СостояниеДокументаЭДО.Вставить("ИдентификаторДокумента", "");
	СостояниеДокументаЭДО.Вставить("ИмяСостояния", "");
	СостояниеДокументаЭДО.Вставить("СостояниеДополнение", "");
	СостояниеДокументаЭДО.Вставить("ДатаИзменения", "");
	СостояниеДокументаЭДО.Вставить("Комментарий", "");
