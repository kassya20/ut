// Параметры:
//  ПутьКМакету - Строка
// 
// Возвращаемое значение:
//  Строка
Функция ИмяМакетаДереваИзПути(ПутьКМакету)
	
	ИмяМакета = "";
	
	Если Не ЗначениеЗаполнено(ПутьКМакету) Тогда
		Возврат ИмяМакета;
	КонецЕсли;
	
	Позиция = СтрНайти(ПутьКМакету, ".", НаправлениеПоиска.СКонца);
	Если Позиция > 0 Тогда
		Позиция = Позиция + 1;
	КонецЕсли;
	
	ИмяМакета = Сред(ПутьКМакету, Позиция);
	
	Возврат ИмяМакета;
	
КонецФункции

#КонецОбласти // КонвертацияДанных

#Область КонвертацияДереваДанных

#Область ДеревоДанныхВСтруктуру

// Параметры:
//  ДеревоУчетныхДанных - ДеревоЗначений
// 
// Возвращаемое значение:
//  Структура
//@skip-check function-return-types
Функция ДеревоУчетныхДанныхВСтруктуру(ДеревоУчетныхДанных) Экспорт
	
	СтруктураУчетныхДанных = Новый Структура;
	
	Если Не ЗначениеЗаполнено(ДеревоУчетныхДанных.Строки) Тогда
		Возврат СтруктураУчетныхДанных;
	КонецЕсли;
	
	ДобавитьСвойстваПоВложеннымСтрокамДерева(СтруктураУчетныхДанных, ДеревоУчетныхДанных);
	
	Возврат СтруктураУчетныхДанных;
	
КонецФункции

// Параметры:
//  Свойства - Структура,Массив из Структура
//  СтрокаДереваРодитель - ДеревоЗначений,СтрокаДереваЗначений
Процедура ДобавитьСвойстваПоВложеннымСтрокамДерева(Свойства, СтрокаДереваРодитель)
	
	НаборСтрокРодителя = СтрокаДереваРодитель.Строки;
	
	Если НаборСтрокРодителя.Количество() Тогда
		
		Для Каждого СтрокаДерева Из НаборСтрокРодителя Цикл
			
			ДобавитьСвойстваПоСтрокеДерева(Свойства, СтрокаДерева);
			
		КонецЦикла;
		
	Иначе
		
		ДобавитьСвойствоВСтруктуруУчетныхДанных(Свойства, СтрокаДереваРодитель);
		
	КонецЕсли;
	
КонецПроцедуры

// Параметры:
//  Свойства - Структура
//  СтрокаДерева - СтрокаДереваЗначений:
//  * ПолныйПуть - Строка
//  * Признак - Строка
Процедура ДобавитьСвойстваПоСтрокеДерева(Свойства, СтрокаДерева)
	
	ЭтоНомерСтрокиТаблицы = СтрЗаканчиваетсяНа(СтрокаДерева.ПолныйПуть, "НомерСтроки");
	
	Если ЭтоНомерСтрокиТаблицы
		ИЛИ СтрокаДерева.Признак = "Группа"
		ИЛИ СтрокаДерева.Признак = "Выбор" Тогда
		
		ДобавитьГруппуСвойствПоВложеннымСтрокамДерева(Свойства, СтрокаДерева, ЭтоНомерСтрокиТаблицы);
		
	ИначеЕсли СтрокаДерева.Признак = "Таблица" Тогда
		
		ДобавитьНаборГруппПоВложеннымСтрокамДерева(Свойства, СтрокаДерева);
		
	Иначе
		
		ДобавитьСвойстваПоВложеннымСтрокамДерева(Свойства, СтрокаДерева);
		
	КонецЕсли;
	
КонецПроцедуры

// Параметры:
//  Свойства - Структура,Массив из Структура
//  СтрокаДерева - СтрокаДереваЗначений:
//  * ПолныйПуть - Строка
//  * Признак - Строка
//  ЭтоНомерСтрокиТаблицы - Булево
Процедура ДобавитьГруппуСвойствПоВложеннымСтрокамДерева(Свойства, СтрокаДерева, ЭтоНомерСтрокиТаблицы)
	
	ГруппаСвойств = Новый Структура;
	
	ДобавитьСвойстваПоВложеннымСтрокамДерева(ГруппаСвойств, СтрокаДерева);
	
	Если Не ЗначениеЗаполнено(ГруппаСвойств) Тогда
		Возврат;
	ИначеЕсли ЭтоНомерСтрокиТаблицы Тогда
		НаборСвойств = Свойства; // Массив
		НаборСвойств.Добавить(ГруппаСвойств);
	Иначе
		ГруппаСвойствВладелец = Свойства; // Структура
		ИмяСвойства = ИмяСвойстваПоПолномуПути(СтрокаДерева.ПолныйПуть);
		ГруппаСвойствВладелец.Вставить(ИмяСвойства, ГруппаСвойств);
	КонецЕсли;
	
КонецПроцедуры

// Параметры:
//  Свойства - Структура
//  СтрокаДерева - СтрокаДереваЗначений:
//  * ПолныйПуть - Строка
//  * Признак - Строка
Процедура ДобавитьНаборГруппПоВложеннымСтрокамДерева(Свойства, СтрокаДерева)
	
	НаборГрупп = Новый Массив;
	
	ДобавитьСвойстваПоВложеннымСтрокамДерева(НаборГрупп, СтрокаДерева);
	
	Если ЗначениеЗаполнено(НаборГрупп) Тогда
		ГруппаСвойств = Свойства; // Структура
		ИмяСвойства = ИмяСвойстваПоПолномуПути(СтрокаДерева.ПолныйПуть);
		ГруппаСвойств.Вставить(ИмяСвойства, НаборГрупп);
	КонецЕсли;
	
КонецПроцедуры

// Параметры:
//  Свойства - Структура
//  СтрокаДерева - ДеревоЗначений,СтрокаДереваЗначений:
//  * Типы - Строка
//  * Значение - Строка,Число,ПеречислениеСсылка
Процедура ДобавитьСвойствоВСтруктуруУчетныхДанных(Свойства, СтрокаДерева)
	
	Если Не ЗначениеЗаполнено(СтрокаДерева.Значение)
		И СтрокаДерева.Значение <> 0 Тогда
		Возврат;
	КонецЕсли;
	
	ТипыЗначения = СтрокаДерева.Типы;
	
	Если   ТипыЗначения = "Строка"
		ИЛИ ТипыЗначения = "Число"
		ИЛИ ТипыЗначения = "Булево"
		ИЛИ ТипыЗначения = "Дата" Тогда
		ЗначениеСвойства = СтрокаДерева.Значение;
	ИначеЕсли СтрНачинаетсяС(ТипыЗначения, "ПеречислениеСсылка") Тогда
		ЗначениеСвойства = ОбщегоНазначения.ИмяЗначенияПеречисления(СтрокаДерева.Значение);
	Иначе
		ТипЗначения = ТипЗнч(СтрокаДерева.Значение);
		Если   ТипЗначения = Тип("Строка")
			Или ТипЗначения = Тип("Число")
			Или ТипЗначения = Тип("Булево")
			Или ТипЗначения = Тип("Дата") Тогда
			ЗначениеСвойства = СтрокаДерева.Значение;
		Иначе
			Возврат;
		КонецЕсли; 
	КонецЕсли;
	
	Если ЗначениеСвойства <> Неопределено Тогда
		ГруппаСвойств = Свойства; // Структура
		ИмяСвойства = ИмяСвойстваПоПолномуПути(СтрокаДерева.ПолныйПуть);
		ГруппаСвойств.Вставить(ИмяСвойства, ЗначениеСвойства);
	КонецЕсли;
	
КонецПроцедуры

// Параметры:
//  ПолныйПуть - Строка
// 
// Возвращаемое значение:
//  Строка
Функция ИмяСвойстваПоПолномуПути(ПолныйПуть)
	Позиция = СтрНайти(ПолныйПуть, ".", НаправлениеПоиска.СКонца);
	Если Позиция > 0 Тогда
		Позиция = Позиция + 1;
	КонецЕсли;
	Возврат Сред(ПолныйПуть, Позиция);
КонецФункции

#КонецОбласти

#Область ДеревоДанныхИзСтруктуры

// Параметры:
//  СтруктураДанных - Структура
//  ФорматДерева - Строка
// 
// Возвращаемое значение:
//  См. ДеревоЭлектронногоДокументаБЭД.ДеревоЭлектронногоДокумента
Функция ДеревоУчетныхДанныхИзСтруктуры(СтруктураДанных, ФорматДерева)
	
	ПутьКМакету = "ОбменСКонтрагентами." + ФорматДерева;
	ДеревоДанных = ДеревоЭлектронногоДокументаБЭД.ДеревоЭлектронногоДокумента(ПутьКМакету);
	ЗагрузитьСтруктуруДанныхВСтрокуДерева(ДеревоДанных, СтруктураДанных);
	ДополнитьДеревоСлужебнымиДанными(ДеревоДанных, СтруктураДанных);
	
	Возврат ДеревоДанных;
	
КонецФункции

// Параметры:
//  ДеревоДанных - ДеревоЗначений
//  СтруктураДанных - Структура:
//  *_Операция - Строка
//  *Дата - Строка
//  *Номер - Строка
//  *Ид - Строка
Процедура ДополнитьДеревоСлужебнымиДанными(ДеревоДанных, СтруктураДанных)
	Операция = "";
	Если СтруктураДанных.Свойство("_Операция", Операция) Тогда
		ДеревоЭлектронногоДокументаБЭД.ДобавитьЗначениеВДерево(ДеревоДанных, "_Операция", Операция);
	КонецЕсли;
	Дата = "";
	Если СтруктураДанных.Свойство("Дата", Дата) И ЗначениеЗаполнено(Дата) Тогда
		ДеревоЭлектронногоДокументаБЭД.ДобавитьЗначениеВДерево(ДеревоДанных, "Дата", 
			ОбщегоНазначенияБЭД.ДатаИзФорматаISO(Дата));
	КонецЕсли;
	Номер = "";
	Если СтруктураДанных.Свойство("Номер", Номер) Тогда
		ДеревоЭлектронногоДокументаБЭД.ДобавитьЗначениеВДерево(ДеревоДанных, "Номер", Номер);
	КонецЕсли;
	Идентификатор = "";
	Если СтруктураДанных.Свойство("Ид", Идентификатор) Тогда
		ДеревоЭлектронногоДокументаБЭД.ДобавитьЗначениеВДерево(ДеревоДанных, "Ид", Идентификатор);
	КонецЕсли;
КонецПроцедуры

// Параметры:
//  СтрокаДерева - ДеревоЗначений,СтрокаДереваЗначений:
//  * Строки - КоллекцияСтрокДереваЗначений
//  * ПолныйПуть - Строка
//  * Признак - Строка
//  * Значение - Строка,Число,Булево,Структура,Массив из Структура
//  СтруктураДанных - Структура
Процедура ЗагрузитьСтруктуруДанныхВСтрокуДерева(СтрокаДерева, СтруктураДанных)
	
	ВложенныеСтроки = СтрокаДерева.Строки;
	Если Не ЗначениеЗаполнено(ВложенныеСтроки) Тогда
		Возврат;
	КонецЕсли;
	
	ТекущийПуть = "";
	Признак = "";
	Если ВложенныеСтроки[0].Родитель <> Неопределено Тогда
		ТекущийПуть = СтрокаДерева.ПолныйПуть + ".";
		Признак = СтрокаДерева.Признак;
	КонецЕсли;
	
	Если Признак = "Группа" Тогда
		СтрокаДерева.Значение = Истина;
	КонецЕсли;
	
	Для Каждого ЭлементСтруктуры Из СтруктураДанных Цикл
		
		ПолныйПуть = ТекущийПуть + ЭлементСтруктуры.Ключ;
		ТекущаяСтрока = ВложенныеСтроки.Найти(ПолныйПуть, "ПолныйПуть");
		Если ТекущаяСтрока = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		Если Признак = "Выбор" Тогда
			СтрокаДерева.Значение = ЭлементСтруктуры.Ключ;
		КонецЕсли;
		
		Данные = ЭлементСтруктуры.Значение; // Строка,Число,Булево,Структура,Массив из Структура
		ТипДанных = ТипЗнч(Данные);
		
		Если ТипДанных = Тип("Структура") Тогда
			
			ЗагрузитьСтруктуруДанныхВСтрокуДерева(ТекущаяСтрока, Данные);
			
		ИначеЕсли ТипДанных = Тип("Массив") Тогда
			
			ЗагрузитьНаборДанныхВСтрокуДерева(ТекущаяСтрока, Данные);
			
		Иначе
			
			ЗагрузитьДанныеВСтрокуДерева(ТекущаяСтрока, Данные);
			
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

// Параметры:
//  СтрокаДерева - См. ЗагрузитьДанныеВСтрокуДерева.СтрокаДерева
//  НаборДанных - Массив из Структура
Процедура ЗагрузитьНаборДанныхВСтрокуДерева(СтрокаДерева, НаборДанных)
	
	Если СтрокаДерева.Признак <> "Таблица" Тогда
		СтрокаДерева.Значение = НаборДанных;
		Возврат;
	КонецЕсли;
	
	ВложенныеСтроки = СтрокаДерева.Строки;
	ПерваяСтрока = ВложенныеСтроки[0];
	
	НомерСтроки = 0;
	Для Каждого СтруктураДанных Из НаборДанных Цикл
		НомерСтроки = НомерСтроки + 1;
		
		Если НомерСтроки = 1 Тогда
			ТекущаяСтрока = ПерваяСтрока;
		Иначе
			ТекущаяСтрока = ВложенныеСтроки.Добавить();
			ЗаполнитьЗначенияСвойств(ТекущаяСтрока, ПерваяСтрока);
			ДеревоЭлектронногоДокументаБЭДСлужебный.СкопироватьСтрокиДереваДляТаблицыРекурсивно(ТекущаяСтрока, ПерваяСтрока);
		КонецЕсли;
		
		ТекущаяСтрока.Значение = НомерСтроки;
		
		ЗагрузитьСтруктуруДанныхВСтрокуДерева(ТекущаяСтрока, СтруктураДанных);
		
	КонецЦикла;
	
	СтрокаДерева.Значение = НомерСтроки;
	
КонецПроцедуры

// Параметры:
//  СтрокаДерева - СтрокаДереваЗначений:
//  * Строки - КоллекцияСтрокДереваЗначений
//  * Типы - Строка
//  * Признак - Строка
//  * Значение - Строка,Число,Булево,Дата,Структура,Массив из Структура
//  * ПараметрыОбработкиОбязательны - Строка
//  Данные - Строка,Число,Булево
Процедура ЗагрузитьДанныеВСтрокуДерева(СтрокаДерева, Данные)
	
	Если ЗначениеЗаполнено(СтрокаДерева.Признак) Тогда
		Возврат;
	КонецЕсли;
	
	Если СтрокаДерева.Типы = "Дата" Тогда
		СтрокаДерева.Значение = ?(ЗначениеЗаполнено(Данные),
			ПрочитатьДатуJSON(Данные, ФорматДатыJSON.ISO), '00010101');
	Иначе
		СтрокаДерева.Значение = Данные;
	КонецЕсли;
	
	СтрокаДерева.ПараметрыОбработкиОбязательны = "Нет";
	
КонецПроцедуры

#КонецОбласти

#КонецОбласти // КонвертацияДереваДанных

#Область СформироватьДокументыЭДО

// Параметры:
//  Идентификатор - Строка
//  КонтекстДиагностики - См. ОбработкаНеисправностейБЭД.НовыйКонтекстДиагностики
//  ВидОперации - Строка
// 
// Возвращаемое значение:
//  Булево
Функция ЕстьОшибкаНекорректныйИдентификаторДокумента(Идентификатор, КонтекстДиагностики, ВидОперации)
	
	Если СтроковыеФункцииКлиентСервер.ЭтоУникальныйИдентификатор(Идентификатор) Тогда
		Возврат Ложь;
	КонецЕсли;
	
	ТекстОшибки = НСтр("ru = 'Некорректный идентификатор документа центра ЭДО.'");
	КраткоеПредставление = СтрШаблон(НСтр("ru = 'Не удалось сформировать электронный документ %1.'"),
		Идентификатор) + Символы.ПС + ТекстОшибки;
	
	Ошибка = ОбработкаНеисправностейБЭД.НоваяОшибка(ВидОперации,
		ОбработкаНеисправностейБЭДКлиентСервер.ВидОшибкиНеизвестнаяОшибка(),
		"", КраткоеПредставление);
	ПодсистемыБЭД = ОбщегоНазначенияБЭДКлиентСервер.ПодсистемыБЭД();
	ОбработкаНеисправностейБЭД.ДобавитьОшибку(КонтекстДиагностики, Ошибка, ПодсистемыБЭД.ОбменСКонтрагентами);
	
	Возврат Истина;
	
КонецФункции

// Параметры:
//  ДанныеДокументовЭДО - Массив из Структура:
//  * ИдентификаторОтправителя - Строка
//  * ИдентификаторПолучателя - Строка
//
// Возвращаемое значение:
//  ТаблицаЗначений:
//  * ИдентификаторОтправителя - Строка
//  * ИдентификаторПолучателя - Строка
//  * СпособОбмена - ПеречислениеСсылка.СпособыОбменаЭД
//  * СтатусПриглашения - ПеречислениеСсылка.СтатусыПриглашений
//
Функция НастройкиОбменаМеждуУчастникамиЭДО(ДанныеДокументовЭДО)
	
	ОписаниеТипаСтрока50 = ОбщегоНазначения.ОписаниеТипаСтрока(50);
	
	ИдентификаторыУчастниковЭДО = Новый ТаблицаЗначений;
	ИдентификаторыУчастниковЭДО.Колонки.Добавить("ИдентификаторОтправителя", ОписаниеТипаСтрока50);
	ИдентификаторыУчастниковЭДО.Колонки.Добавить("ИдентификаторПолучателя", ОписаниеТипаСтрока50);
	
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(ДанныеДокументовЭДО, ИдентификаторыУчастниковЭДО);
	
	ИдентификаторыУчастниковЭДО.Свернуть("ИдентификаторОтправителя, ИдентификаторПолучателя");
	
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ
		|	ИдентификаторыУчастниковЭДО.ИдентификаторОтправителя,
		|	ИдентификаторыУчастниковЭДО.ИдентификаторПолучателя
		|ПОМЕСТИТЬ ИдентификаторыУчастниковЭДО
		|ИЗ
		|	&ИдентификаторыУчастниковЭДО КАК ИдентификаторыУчастниковЭДО
		|;
		|ВЫБРАТЬ
		|	ИдентификаторыУчастниковЭДО.ИдентификаторОтправителя,
		|	ИдентификаторыУчастниковЭДО.ИдентификаторПолучателя,
		|	ЕСТЬNULL(УчетныеЗаписиЭДО.СпособОбменаЭД, ЗНАЧЕНИЕ(Перечисление.СпособыОбменаЭД.ПустаяСсылка)) КАК СпособОбмена,
		|	ЕСТЬNULL(ПриглашенияЭДО.Статус, ЗНАЧЕНИЕ(Перечисление.СтатусыПриглашений.ПустаяСсылка)) КАК СтатусПриглашения
		|ИЗ
		|	ИдентификаторыУчастниковЭДО КАК ИдентификаторыУчастниковЭДО
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.УчетныеЗаписиЭДО КАК УчетныеЗаписиЭДО
		|		ПО ИдентификаторыУчастниковЭДО.ИдентификаторОтправителя = УчетныеЗаписиЭДО.ИдентификаторЭДО
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ПриглашенияКОбменуЭлектроннымиДокументами КАК ПриглашенияЭДО
		|		ПО ИдентификаторыУчастниковЭДО.ИдентификаторОтправителя = ПриглашенияЭДО.ИдентификаторОрганизации
		|		И ИдентификаторыУчастниковЭДО.ИдентификаторПолучателя = ПриглашенияЭДО.ИдентификаторКонтрагента";
	
	Запрос.УстановитьПараметр("ИдентификаторыУчастниковЭДО", ИдентификаторыУчастниковЭДО);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	НастройкиОбмена = РезультатЗапроса.Выгрузить(); // ТаблицаЗначений
	
	Возврат НастройкиОбмена;
	
КонецФункции

// Параметры:
//  НастройкиОбмена - см. НастройкиОбменаМеждуУчастникамиЭДО
//  ДанныеДокументаЭДО - Структура:
//  * ИдентификаторОтправителя - Строка
//  * ИдентификаторПолучателя - Строка
// 
// Возвращаемое значение:
//  Неопределено,СтрокаТаблицыЗначений: см. НастройкиОбменаМеждуУчастникамиЭДО
Функция НастройкаОбменаПоДаннымДокументаЭДО(НастройкиОбмена, ДанныеДокументаЭДО)
	
	ОтборНастройкиОбмена = Новый Структура("ИдентификаторОтправителя, ИдентификаторПолучателя",
		ДанныеДокументаЭДО.ИдентификаторОтправителя, ДанныеДокументаЭДО.ИдентификаторПолучателя);
	
	НастройкиОбменаПоДокументуЭДО = НастройкиОбмена.НайтиСтроки(ОтборНастройкиОбмена);
	
	Если ЗначениеЗаполнено(НастройкиОбменаПоДокументуЭДО) Тогда
		Возврат НастройкиОбменаПоДокументуЭДО[0];
	КонецЕсли;
	
	Возврат Неопределено;
	
КонецФункции

// Параметры:
//  НастройкаОбмена - см. НастройкаОбменаПоДаннымДокументаЭДО
//  ДанныеДокументаЭДО - Структура:
//  * Идентификатор - Строка
//  * ИдентификаторОтправителя - Строка
//  * ИдентификаторПолучателя - Строка
//  КонтекстДиагностики - см. ОбработкаНеисправностейБЭД.НовыйКонтекстДиагностики
//  ВидОперации - Строка
// 
// Возвращаемое значение:
//  Булево
Функция ЕстьОшибкаНастройкиОбменаПоДаннымДокументаЭДО(НастройкаОбмена, ДанныеДокументаЭДО, КонтекстДиагностики, ВидОперации)
	
	БлокирующаяОшибка = Ложь;
	Если НастройкаОбмена = Неопределено Тогда
		ТекстОшибки = НСтр("ru = 'Не настроен обмен между участниками ЭДО.'");
		БлокирующаяОшибка = Истина;
	ИначеЕсли Не ЗначениеЗаполнено(НастройкаОбмена.СпособОбмена) Тогда
		ТекстОшибки = НСтр("ru = 'Не найдена учетная запись ЭДО организации.'");
		БлокирующаяОшибка = Истина;
	ИначеЕсли Не ЗначениеЗаполнено(НастройкаОбмена.СтатусПриглашения) Тогда
		ТекстОшибки = НСтр("ru = 'Не найдено приглашение к обмену электронными документами.'");
		БлокирующаяОшибка = Истина;
	ИначеЕсли НастройкаОбмена.СтатусПриглашения <> Перечисления.СтатусыПриглашений.Принято Тогда
		ТекстОшибки = НСтр("ru = 'Приглашение к обмену электронными документами не принято.'");
	Иначе
		Возврат Ложь;
	КонецЕсли;
	
	КраткоеПредставление = СтрШаблон(НСтр("ru = 'Не удалось сформировать электронный документ %1.'"),
		ДанныеДокументаЭДО.Идентификатор) + Символы.ПС + ТекстОшибки;
	ПодробноеПредставление = КраткоеПредставление + Символы.ПС
		+ СтрШаблон(НСтр("ru = 'Статус приглашения: %1.'"),
			?(НастройкаОбмена = Неопределено Или Не ЗначениеЗаполнено(НастройкаОбмена.СтатусПриглашения),
			НСтр("ru = '<отсутствует>'"), НастройкаОбмена.СтатусПриглашения));
	
	Ошибка = ОбработкаНеисправностейБЭД.НоваяОшибка(ВидОперации,
		ОбработкаНеисправностейБЭДКлиентСервер.ВидОшибкиНеизвестнаяОшибка(),
		ПодробноеПредставление, КраткоеПредставление);
	ПодсистемыБЭД = ОбщегоНазначенияБЭДКлиентСервер.ПодсистемыБЭД();
	ОбработкаНеисправностейБЭД.ДобавитьОшибку(КонтекстДиагностики, Ошибка, ПодсистемыБЭД.ОбменСКонтрагентами);
	
	Возврат БлокирующаяОшибка;
	
КонецФункции

// Параметры:
//  КлючНастройки - см. НастройкиЭДОКлиентСервер.НовыйКлючНастроекОтправки
//  ДанныеДокументаЭДО - Структура:
//  * Идентификатор - Строка
//  * Отправитель - Структура:
//  ** ИНН - Строка
//  ** КПП - Строка
//  * Получатель - Структура:
//  ** ИНН - Строка
//  ** КПП - Строка
//  * Договор - Структура:
//  ** Наименование - Строка
//  ** Номер - Строка
//  ** Дата - Дата
//  ** Сторона1 - Структура:
//  *** ИНН - Строка
//  *** КПП - Строка
//  ** Сторона2 - Структура:
//  *** ИНН - Строка
//  *** КПП - Строка
//  * ВидДокумента - Структура:
//  ** Наименование - Строка
//  ** ТипДокумента - Строка
//  КонтекстДиагностики - см. ОбработкаНеисправностейБЭД.НовыйКонтекстДиагностики
//  ВидОперации - Строка
// 
// Возвращаемое значение:
//  Булево
Функция ЕстьОшибкаКлючаНастройкиОтправкиПоДаннымДокументаЭДО(КлючНастройки, ДанныеДокументаЭДО, КонтекстДиагностики, ВидОперации)
	
	Если КлючНастройки = Неопределено Тогда
		ТекстОшибки = НСтр("ru = 'Ошибка заполнения значений по реквизитам.'");
	ИначеЕсли Не ЗначениеЗаполнено(КлючНастройки.Отправитель)
		И ЗначениеЗаполнено(ДанныеДокументаЭДО.Отправитель) Тогда
		ИНН = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ДанныеДокументаЭДО.Отправитель, "ИНН", "");
		КПП = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ДанныеДокументаЭДО.Отправитель, "КПП", "");
		ТекстОшибки = СтрШаблон(НСтр("ru = 'Не удалось найти отправителя по ИНН/КПП %1/%2'"), ИНН, КПП);
	ИначеЕсли Не ЗначениеЗаполнено(КлючНастройки.Получатель) 
		И ЗначениеЗаполнено(ДанныеДокументаЭДО.Получатель) Тогда
		ИНН = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ДанныеДокументаЭДО.Получатель, "ИНН", "");
		КПП = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ДанныеДокументаЭДО.Получатель, "КПП", "");
		ТекстОшибки = СтрШаблон(НСтр("ru = 'Не удалось найти отправителя по ИНН/КПП %1/%2'"), ИНН, КПП);
	ИначеЕсли Не ЗначениеЗаполнено(КлючНастройки.ВидДокумента)
		И ЗначениеЗаполнено(ДанныеДокументаЭДО.ВидДокумента) Тогда
		ТекстОшибки = СтрШаблон(НСтр("ru = 'Не найден вид документа ""%1"" по типу ""%2"".'"),
			ДанныеДокументаЭДО.ВидДокумента.Наименование, ДанныеДокументаЭДО.ВидДокумента.ТипДокумента);
	Иначе 
		Возврат Ложь;
	КонецЕсли;
	
	КраткоеПредставление = СтрШаблон(НСтр("ru = 'Не удалось сформировать электронный документ %1.'"),
		ДанныеДокументаЭДО.Идентификатор) + Символы.ПС + ТекстОшибки;
	
	Ошибка = ОбработкаНеисправностейБЭД.НоваяОшибка(ВидОперации,
		ОбработкаНеисправностейБЭДКлиентСервер.ВидОшибкиНеизвестнаяОшибка(),
		"", КраткоеПредставление);
	ПодсистемыБЭД = ОбщегоНазначенияБЭДКлиентСервер.ПодсистемыБЭД();
	ОбработкаНеисправностейБЭД.ДобавитьОшибку(КонтекстДиагностики, Ошибка, ПодсистемыБЭД.ОбменСКонтрагентами);
	
	Возврат Истина;
	
КонецФункции

// Параметры:
//  ДанныеДокументаЭДО - Структура:
//  * Идентификатор - Строка
//  * Формат - Строка
//  * ВидДокумента - Структура:
//    ** Наименование - Строка
//    ** ТипДокумента - Строка
//  * ТребуетсяОтветнаяПодпись - Булево
//  * ТребуетсяИзвещениеОПолучении - Булево
//  КонтекстДиагностики - см. ОбработкаНеисправностейБЭД.НовыйКонтекстДиагностики
//  ВидОперации - Строка
// 
// Возвращаемое значение:
//  Булево
Функция ЕстьОшибкаНастройкиРегламентаПоДаннымДокументаЭДО(ДанныеДокументаЭДО, КонтекстДиагностики, ВидОперации)
	
	ТипДокумента = ТипДокументаИзФорматаСервиса(ДанныеДокументаЭДО.ВидДокумента.ТипДокумента);
	
	ОписаниеВидаДокумента = Новый Структура;
	ОписаниеВидаДокумента.Вставить("ТипДокумента", ТипДокумента);
	ОписаниеВидаДокумента.Вставить("ПрикладнойТипДокумента", Неопределено);
	ОписаниеВидаДокумента.Вставить("ИдентификаторКомандыПечати", "");
	ОписаниеВидаДокумента.Вставить("ИдентификаторОбъектаУчета", "");
	
	НастройкиРегламента = ЭлектронныеДокументыЭДО.НастройкиРегламента(ОписаниеВидаДокумента, ДанныеДокументаЭДО.Формат);
	
	ТекстОшибки = "";
	
	Если НастройкиРегламента.ТребуетсяИзвещениеОПолучении <> ДанныеДокументаЭДО.ТребуетсяИзвещениеОПолучении
		И Не НастройкиРегламента.РедактироватьИзвещение Тогда
		ТекстОшибки = НСтр("ru = 'Изменение требования извещения о получении недоступно'");
	КонецЕсли;
	
	Если НастройкиРегламента.ТребуетсяОтветнаяПодпись <> ДанныеДокументаЭДО.ТребуетсяОтветнаяПодпись
		И Не НастройкиРегламента.РедактироватьОтветнуюПодпись Тогда
		ТекстОшибки = НСтр("ru = 'Изменение требования ответной подписи недоступно'");
	КонецЕсли;
	
	Если ПустаяСтрока(ТекстОшибки) Тогда
		Возврат Ложь;
	КонецЕсли;
	
	КраткоеПредставление = СтрШаблон(НСтр("ru = 'Не удалось сформировать электронный документ %1.'"),
		ДанныеДокументаЭДО.Идентификатор) + Символы.ПС + ТекстОшибки;
	
	Ошибка = ОбработкаНеисправностейБЭД.НоваяОшибка(ВидОперации,
		ОбработкаНеисправностейБЭДКлиентСервер.ВидОшибкиНеизвестнаяОшибка(),
		"", КраткоеПредставление);
	ПодсистемыБЭД = ОбщегоНазначенияБЭДКлиентСервер.ПодсистемыБЭД();
	ОбработкаНеисправностейБЭД.ДобавитьОшибку(КонтекстДиагностики, Ошибка, ПодсистемыБЭД.ОбменСКонтрагентами);
	
	Возврат Истина;
	
КонецФункции

// Параметры:
//  ФорматыЭлектронныхДокументов - см. ФорматыЭДО.ФорматыЭлектронныхДокументов
//  ДанныеДокументаЭДО - Структура:
//  * Идентификатор - Строка
//  * Формат - Строка
//  ВидДокумента - СправочникСсылка.ВидыДокументовЭДО
//  КонтекстДиагностики - см. ОбработкаНеисправностейБЭД.НовыйКонтекстДиагностики
//  ВидОперации - Строка
// 
// Возвращаемое значение:
//  Булево
Функция ЕстьОшибкаФорматаПоДаннымДокументаЭДО(ФорматыЭлектронныхДокументов, ДанныеДокументаЭДО, ВидДокумента, КонтекстДиагностики, ВидОперации)
	
	ОтборФормата = Новый Структура("ВидДокумента, ИдентификаторФормата", ВидДокумента, ДанныеДокументаЭДО.Формат);
	
	НайденныеФорматы = ФорматыЭлектронныхДокументов.НайтиСтроки(ОтборФормата);
	
	Если ЗначениеЗаполнено(НайденныеФорматы) Тогда
		Возврат Ложь;
	КонецЕсли;
	
	ТекстОшибки = СтрШаблон(НСтр("ru = 'Формат %1 не поддерживается для вида документа %2.'"),
		ДанныеДокументаЭДО.Формат, ВидДокумента);
	
	КраткоеПредставление = СтрШаблон(НСтр("ru = 'Не удалось сформировать электронный документ %1.'"),
		ДанныеДокументаЭДО.Идентификатор) + Символы.ПС + ТекстОшибки;
	
	Ошибка = ОбработкаНеисправностейБЭД.НоваяОшибка(ВидОперации,
		ОбработкаНеисправностейБЭДКлиентСервер.ВидОшибкиНеизвестнаяОшибка(),
		"", КраткоеПредставление);
	ПодсистемыБЭД = ОбщегоНазначенияБЭДКлиентСервер.ПодсистемыБЭД();
	ОбработкаНеисправностейБЭД.ДобавитьОшибку(КонтекстДиагностики, Ошибка, ПодсистемыБЭД.ОбменСКонтрагентами);
	
	Возврат Истина;
	
КонецФункции

// Возвращаемое значение:
//  Структура - данные для заполнения:
//   * ВерсияПрограммы - Строка - версия программы, с помощью которой сформирован файл. По умолчанию "1С:Предприятие 8".
//   * УникальныйИдентификатор - Строка- 36 символьный глобально уникальный идентификатор.
//   * Участники - Структура - участники ЭДО:
//    ** ИдентификаторОтправителя - Строка - идентификатор отправителя.
//    ** ИдентификаторПолучателя - Строка - идентификатор получателя.
//    ** Оператор - Структура - информация об операторе ЭДО отправителя:
//     *** Наименование - Строка - наименование оператора.
//     *** ИНН - Строка - ИНН оператора.
//     *** Идентификатор - Строка - идентификатор отправителя.
//
Функция НовыеДанныеДляФормированияОсновногоТитула()
	Данные = Новый Структура;
	Данные.Вставить("ВерсияПрограммы", "1С:Предприятие 8");
	Данные.Вставить("УникальныйИдентификатор", "");
	Данные.Вставить("Участники", Новый Структура);
	Данные.Участники.Вставить("ИдентификаторОтправителя", "");
	Данные.Участники.Вставить("ИдентификаторПолучателя", "");
	Данные.Участники.Вставить("Оператор", Новый Структура);
	Данные.Участники.Оператор.Вставить("Наименование", "");
	Данные.Участники.Оператор.Вставить("ИНН", "");
	Данные.Участники.Оператор.Вставить("Идентификатор", "");
	Возврат Данные;
КонецФункции

// Параметры:
//  Данные - ДеревоЗначений
//  ДополнительныеДанные - Структура
Процедура ДополнитьДеревоУчетныхДанных(Данные, ДополнительныеДанные)
	
	Для Каждого КлючЗначение Из ДополнительныеДанные Цикл
		Путь = КлючЗначение.Ключ;
		Значение = КлючЗначение.Значение;
		ДеревоЭлектронногоДокументаБЭД.ДобавитьЗначениеВДерево(Данные, Путь, Значение);
	КонецЦикла;
	
КонецПроцедуры

// Параметры:
//  УчетныеДанные - Структура:
//  * Данные - Структура
//  * Формат - Строка
//  НастройкиДокумента - См. ЭлектронныеДокументыЭДО.НовыеНастройкиОтправкиДокумента
// 
// Возвращаемое значение:
//  См. ФорматыЭДО.СформироватьДокумент
Функция СформироватьФайлыДокументаПоУчетнымДанным(УчетныеДанные, НастройкиДокумента)
	
	ДеревоУчетныхДанных = ДеревоУчетныхДанныхИзСтруктуры(УчетныеДанные.Данные, УчетныеДанные.Формат);
	
	ДанныеДляФормирования = НовыеДанныеДляФормированияОсновногоТитула();
	ДанныеДляФормирования.УникальныйИдентификатор = Строка(Новый УникальныйИдентификатор);
	ДанныеДляФормирования.Участники.ИдентификаторОтправителя = НастройкиДокумента.ИдентификаторОрганизации;
	ДанныеДляФормирования.Участники.ИдентификаторПолучателя = НастройкиДокумента.ИдентификаторКонтрагента;
	
	СведенияОбОператоре = СинхронизацияЭДО.СведенияОбОператоре(НастройкиДокумента.ИдентификаторОрганизации);
	ДанныеДляФормирования.Участники.Оператор.Наименование = СведенияОбОператоре.Наименование;
	ДанныеДляФормирования.Участники.Оператор.ИНН = СведенияОбОператоре.ИНН;
	ДанныеДляФормирования.Участники.Оператор.Идентификатор = СведенияОбОператоре.Идентификатор;
	
	ДополнитьДеревоУчетныхДанных(ДеревоУчетныхДанных, ДанныеДляФормирования);
	
	ФайлыДокументаЭДО = ФорматыЭДО.СформироватьДокумент(НастройкиДокумента.Формат, ДеревоУчетныхДанных);
	
	Возврат ФайлыДокументаЭДО;
	
КонецФункции

// Возвращаемое значение:
//  Структура:
//  * ИмяФайла - Строка
//  * Данные - Строка - двоичные данные в формате base64.
Функция НовыйФайлДокументаЭДОВФорматеСервиса()
	Файл = Новый Структура;
	Файл.Вставить("ИмяФайла", "");
	Файл.Вставить("Данные", "");
	Возврат Файл;
КонецФункции

// Параметры:
//  ЭлектронныеДокументы - Массив из ДокументСсылка.ЭлектронныйДокументИсходящийЭДО
// 
// Возвращаемое значение:
//  Массив из см. НовоеОписаниеДокументаЭДО
Функция ОписанияИсходящихДокументов(ЭлектронныеДокументы)
	
	Выборка = ВыбратьИсходящиеДокументыДляОписания(ЭлектронныеДокументы);
	ОписанияДокументовЭДО = Новый Массив; // Массив из см. НовоеОписаниеДокументаЭДО
	Пока Выборка.Следующий() Цикл
		ОписаниеДокументаЭДО = ОписаниеДокументаЭДОПоВыборкеДанных(Выборка);
		ОписанияДокументовЭДО.Добавить(ОписаниеДокументаЭДО);
	КонецЦикла;
	Возврат ОписанияДокументовЭДО;
	
КонецФункции

// Параметры:
//  ЭлектронныеДокументы - Массив из ДокументСсылка.ЭлектронныйДокументИсходящийЭДО
// 
// Возвращаемое значение:
//  ВыборкаИзРезультатаЗапроса:
//  * ЭтоВходящийЭДО - Булево
//  * ИдентификаторДокумента - Строка
//  * ФорматОсновногоТитула - Строка
//  * ВидДокумента - СправочникСсылка.ВидыДокументовЭДО
//  * ВидДокументаНаименование - Строка
//  * ВидДокументаТипДокумента - ПеречислениеСсылка.ТипыДокументовЭДО
//  * Организация - СправочникСсылка.Организации
//  * ОрганизацияИНН - Строка
//  * ОрганизацияКПП - Строка
//  * Контрагент - СправочникСсылка.Организации
//  * КонтрагентИНН - Строка
//  * КонтрагентКПП - Строка
//  * Договор - СправочникСсылка.ДоговорыКонтрагентов
//  * ДоговорНаименование - Строка
//  * ДоговорНомер - Строка
//  * ДоговорДата - Дата
//  * НомерДокумента - Строка
//  * ДатаДокумента - Дата
//  * ДатаАннулирования - Дата
//  * ДатаОтправкиПолучения - Дата
//  * ДатаПодписания - Дата
//  * СуммаДокумента - Число
//  * СпособОбмена - ПеречислениеСсылка.СпособыОбменаЭД
//  * ТипРегламента - ПеречислениеСсылка.ТипыРегламентовЭДО
//  * ТребуетсяИзвещение - Булево
//  * ТребуетсяПодтверждение - Булево
//  * ИдентификаторОрганизации - Строка
//  * ИдентификаторКонтрагента - Строка
//  * ИдентификаторДокументооборота - Строка
//  * Состояние - ПеречислениеСсылка.СостоянияДокументовЭДО
//  * СостояниеДополнение - Строка
//  * ДатаИзмененияСостояния - Дата
//  * КомментарийСостояния - Строка
//  * ИдентификаторПакета - УникальныйИдентификатор
//
Функция ВыбратьИсходящиеДокументыДляОписания(ЭлектронныеДокументы)
	
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ
		|	ЛОЖЬ КАК ЭтоВходящийЭДО,
		|	ЭлектронныйДокументИсходящийЭДО.ИдентификаторДокумента КАК ИдентификаторДокумента,
		|	ЭлектронныйДокументИсходящийЭДО.ФорматОсновногоТитула КАК ФорматОсновногоТитула,
		|	ЭлектронныйДокументИсходящийЭДО.ВидДокумента КАК ВидДокумента,
		|	ЭлектронныйДокументИсходящийЭДО.ВидДокумента.Наименование КАК ВидДокументаНаименование,
		|	ЭлектронныйДокументИсходящийЭДО.ВидДокумента.ТипДокумента КАК ВидДокументаТипДокумента,
		|	ЭлектронныйДокументИсходящийЭДО.Организация КАК Организация,
		|	ЭлектронныйДокументИсходящийЭДО.Организация.ИНН КАК ОрганизацияИНН,
		|	ЭлектронныйДокументИсходящийЭДО.Организация.КПП КАК ОрганизацияКПП,
		|	ЭлектронныйДокументИсходящийЭДО.Контрагент КАК Контрагент,
		|	ЭлектронныйДокументИсходящийЭДО.Контрагент.ИНН КАК КонтрагентИНН,
		|	ЭлектронныйДокументИсходящийЭДО.Контрагент.КПП КАК КонтрагентКПП,
		|	ЭлектронныйДокументИсходящийЭДО.НомерДокумента КАК НомерДокумента,
		|	ЭлектронныйДокументИсходящийЭДО.ДатаДокумента КАК ДатаДокумента,
		|	ЭлектронныйДокументИсходящийЭДО.ДатаАннулирования КАК ДатаАннулирования,
		|	ЭлектронныйДокументИсходящийЭДО.ДатаОтправки КАК ДатаОтправкиПолучения,
		|	ЭлектронныйДокументИсходящийЭДО.ДатаПодписания КАК ДатаПодписания,
		|	ЭлектронныйДокументИсходящийЭДО.СуммаДокумента КАК СуммаДокумента,
		|	ЭлектронныйДокументИсходящийЭДО.СпособОбмена КАК СпособОбмена,
		|	ЭлектронныйДокументИсходящийЭДО.ТипРегламента КАК ТипРегламента,
		|	ЭлектронныйДокументИсходящийЭДО.ТребуетсяИзвещение КАК ТребуетсяИзвещение,
		|	ЭлектронныйДокументИсходящийЭДО.ТребуетсяПодтверждение КАК ТребуетсяПодтверждение,
		|	ЭлектронныйДокументИсходящийЭДО.ИдентификаторОрганизации КАК ИдентификаторОрганизации,
		|	ЭлектронныйДокументИсходящийЭДО.ИдентификаторКонтрагента КАК ИдентификаторКонтрагента,
		|	ЭлектронныйДокументИсходящийЭДО.ИдентификаторДокументооборота КАК ИдентификаторДокументооборота,
		|	СостоянияДокументовЭДО.Состояние КАК Состояние,
		|	СостоянияДокументовЭДО.СостояниеДополнение КАК СостояниеДополнение,
		|	СостоянияДокументовЭДО.ДатаИзменения КАК ДатаИзмененияСостояния,
		|	СостоянияДокументовЭДО.Комментарий КАК КомментарийСостояния,
		|	ЕСТЬNULL(СоставПакетовДокументовЭДО.ИдентификаторПакета, """") КАК ИдентификаторПакета
		|ИЗ
		|	Документ.ЭлектронныйДокументИсходящийЭДО КАК ЭлектронныйДокументИсходящийЭДО
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.СостоянияДокументовЭДО КАК СостоянияДокументовЭДО
		|		ПО ЭлектронныйДокументИсходящийЭДО.Ссылка = СостоянияДокументовЭДО.ЭлектронныйДокумент
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СоставПакетовДокументовЭДО КАК СоставПакетовДокументовЭДО
		|		ПО ЭлектронныйДокументИсходящийЭДО.Ссылка = СоставПакетовДокументовЭДО.ЭлектронныйДокумент
		|ГДЕ
		|	ЭлектронныйДокументИсходящийЭДО.Ссылка В (&ЭлектронныеДокументы)";
	
	Запрос.УстановитьПараметр("ЭлектронныеДокументы", ЭлектронныеДокументы);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Возврат Выборка;
	
КонецФункции

#КонецОбласти

#Область СформироватьОтветныйТитул

// Параметры:
//  УчетныеДанныеВФорматеСервиса - Структура - данные прикладного решения:
//  * Данные - Структура - учетные данные для конвертации.
//  * Формат - Строка - формат учетных данных.
// 
// Возвращаемое значение:
//  См. ЭлектронныеДокументыЭДО.СформироватьОтветПоДокументу.ДанныеОбъектаУчета
Функция УчетныеДанныеОтветногоТитулаИзФорматаСервиса(УчетныеДанныеВФорматеСервиса)
	
	Возврат ДеревоУчетныхДанныхИзСтруктуры(
		УчетныеДанныеВФорматеСервиса.Данные, УчетныеДанныеВФорматеСервиса.Формат); // См. УчетныеДанныеОтветногоТитулаИзФорматаСервиса
	
КонецФункции

#КонецОбласти

#Область ЗаполнениеДанныхДляПодписанияПоВыбраннымСертификатам

// Параметры:
//  ИдентификаторыДокументовЭДО - Массив из Строка
//  ОтпечаткиСертификатов - Массив из Строка
//  ОбработатьТолькоИзвещения - Булево
// 
// Возвращаемое значение:
//  Структура:
//  * Ошибки - Неопределено
//           - Массив из см. ЦентрЭДО.НоваяОшибкаВФорматеСервиса
//  * ДанныеДляПодписания - Массив из См. НовоеОписаниеНабораДанныхДляПодписанияВЦентреЭДО
Функция ПодготовитьДанныеДляПодписания(ИдентификаторыДокументовЭДО, ОтпечаткиСертификатов, ОбработатьТолькоИзвещения = Ложь)
	
	Результат = Новый Структура;
	Результат.Вставить("Ошибки", Неопределено);
	Результат.Вставить("ДанныеДляПодписания", Новый Массив);
	
	РеквизитыДокументовЭДО = РеквизитыДокументовПоИдентификаторам(ИдентификаторыДокументовЭДО);
	ДокументыЭДО = РеквизитыДокументовЭДО.ВыгрузитьКолонку("Ссылка");
	
	ОтпечаткиПоСертификатам = ОтпечаткиПоСертификатамУчетныхЗаписейДокументовЭДО(ДокументыЭДО);
	ОтпечаткиДляДокументовЭДО = ОтпечаткиПоСертификатам.ВыгрузитьКолонку("Отпечаток");
	
	ОтпечаткиДляПодписания = ОбщегоНазначенияБЭД.ПересечениеМассивов(ОтпечаткиДляДокументовЭДО, ОтпечаткиСертификатов);
	
	РезультатыПолученияОтпечатков = РезультатыПолученияОтпечатков(ОтпечаткиДляПодписания);
	
	КонтекстДиагностики = ОбработкаНеисправностейБЭД.НовыйКонтекстДиагностики();
	
	ДанныеДляПодписанияПоТипам = ЭлектронныеДокументыЭДО.ДанныеДляПодписанияСообщенийПоДокументамЭДО(ДокументыЭДО,
		РезультатыПолученияОтпечатков, КонтекстДиагностики, ОбработатьТолькоИзвещения);
	
	Если Не ЗначениеЗаполнено(ДанныеДляПодписанияПоТипам.ДанныеДляИнтерактивногоПодписания) Тогда
		Ошибки = ЦентрЭДО.ВыгрузитьОшибкиВФорматеСервиса(КонтекстДиагностики);
		Если ЗначениеЗаполнено(Ошибки) Тогда
			Результат.Ошибки = Ошибки;
		КонецЕсли;
		Возврат Результат;
	КонецЕсли;
	
	ДанныеДляПодписания = Результат.ДанныеДляПодписания; // Массив из см. НовоеОписаниеНабораДанныхДляПодписанияВЦентреЭДО
	
	СообщенияДокументовЭДО = Новый Массив; // Массив из ДокументСсылка.СообщениеЭДО
	ДоверенностиПоСертификатам = Новый Соответствие;
	Для Каждого ОписаниеНабораДанных Из ДанныеДляПодписанияПоТипам.ДанныеДляИнтерактивногоПодписания Цикл
		Для Каждого ДанныеНабора Из ОписаниеНабораДанных.НаборДанных Цикл
			СообщенияДокументовЭДО.Добавить(ДанныеНабора.Представление.Значение);
			ОбщегоНазначенияКлиентСервер.ДополнитьСоответствие(ДоверенностиПоСертификатам, ДанныеНабора.Доверенности, Истина);
		КонецЦикла;
	КонецЦикла;
	
	ЗначенияРеквизитовПоСообщениям = ОбщегоНазначения.ЗначенияРеквизитовОбъектов(
		СообщенияДокументовЭДО, "ЭлектронныйДокумент");
	
	Доверенности = Новый Массив; // Массив из СправочникСсылка.МашиночитаемыеДоверенностиОрганизаций,СправочникСсылка.МЧД003
	Для Каждого ДоверенностиПоСертификату Из ДоверенностиПоСертификатам Цикл
		ОбщегоНазначенияКлиентСервер.ДополнитьМассив(Доверенности, ДоверенностиПоСертификату.Значение);
	КонецЦикла;
	НомераДоверенностей = МашиночитаемыеДоверенности.ПолучитьНомераДоверенностей(Доверенности);
	
	Для Каждого ОписаниеНабораДанных Из ДанныеДляПодписанияПоТипам.ДанныеДляИнтерактивногоПодписания Цикл
		
		ОписаниеНабораДанныхЦентраЭДО = НовоеОписаниеНабораДанныхДляПодписанияВЦентреЭДО();
		
		ОтпечаткиСертификатов = ОписаниеНабораДанныхЦентраЭДО.ОтпечаткиСертификатов;
		
		Для Каждого Сертификат Из ОписаниеНабораДанных.Сертификаты Цикл
			ОтпечатокПоСертификату = ОтпечаткиПоСертификатам.Найти(Сертификат, "Сертификат");
			Если ОтпечатокПоСертификату <> Неопределено Тогда
				ОтпечаткиСертификатов.Добавить(ОтпечатокПоСертификату.Отпечаток);
			КонецЕсли;
		КонецЦикла;
		
		СертификатыТребующиеДоверенность = Новый Массив; // Массив из Строка
		Для Каждого Элемент Из ОписаниеНабораДанных.СертификатыТребующиеДоверенность Цикл
			Сертификат = Элемент.Ключ;
			ОтпечатокПоСертификату = ОтпечаткиПоСертификатам.Найти(Сертификат, "Сертификат");
			Если ОтпечатокПоСертификату <> Неопределено Тогда
				СертификатыТребующиеДоверенность.Добавить(ОтпечатокПоСертификату.Отпечаток);
			КонецЕсли;
		КонецЦикла;
		
		НаборДанныхЦентраЭДО = ОписаниеНабораДанныхЦентраЭДО.НаборДанных;
		
		Для Каждого ДанныеНабора Из ОписаниеНабораДанных.НаборДанных Цикл
			
			РеквизитыСообщения = ЗначенияРеквизитовПоСообщениям[ДанныеНабора.Представление.Значение];
			РеквизитыДокумента = РеквизитыДокументовЭДО.Найти(РеквизитыСообщения.ЭлектронныйДокумент, "Ссылка");
			ИдентификаторДокумента = ?(РеквизитыДокумента <> Неопределено, РеквизитыДокумента.ИдентификаторДокумента, "");
			
			ДанныеНабораЦентраЭДО = НовыеДанныеДляПодписанияДокументаЦентраЭДО();
			ДанныеНабораЦентраЭДО.ИдентификаторДокумента = ИдентификаторДокумента;
			ДанныеНабораЦентраЭДО.ИдентификаторДанных = ИдентификаторСсылки(ДанныеНабора.ПрисоединенныйФайл);
			ДанныеНабораЦентраЭДО.ТребуетсяЗаполнитьПодписанта = ДанныеНабора.ТребуетсяЗаполнитьПодписанта;
			ДанныеНабораЦентраЭДО.СертификатыТребующиеДоверенность = СертификатыТребующиеДоверенность;
			
			Если Не ДанныеНабора.ТребуетсяЗаполнитьПодписанта Тогда
				ДанныеНабораЦентраЭДО.Данные = Base64Строка(ДанныеНабора.ИсходныеДвоичныеДанные);
			КонецЕсли;
			
			Если ЗначениеЗаполнено(ДанныеНабора.Доверенности) Тогда
				ДанныеНабораЦентраЭДО.ДоверенностиПоСертификатам = ДоверенностиДанныхДляПодписанияВФорматеСервиса(
					ДанныеНабора.Доверенности, ОтпечаткиПоСертификатам, НомераДоверенностей);
			КонецЕсли;
			
			НаборДанныхЦентраЭДО.Добавить(ДанныеНабораЦентраЭДО);
			
		КонецЦикла;
		
		ОписаниеНабораДанныхЦентраЭДО.ИспользоватьБазовыйТипПодписи =
			ОписаниеНабораДанных.ИспользоватьБазовыйТипПодписи;
		
		ДанныеДляПодписания.Добавить(ОписаниеНабораДанныхЦентраЭДО);
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

// Параметры:
//  ФайлыДокументовЭДО - Массив из СправочникСсылка.СообщениеЭДОПрисоединенныеФайлы
// 
// Возвращаемое значение:
//  ТаблицаЗначений:
//  * ФайлДокументаЭДО - СправочникСсылка.СообщениеЭДОПрисоединенныеФайлы
//  * ЭлектронныйДокумент - ДокументСсылка.ЭлектронныйДокументИсходящийЭДО
//  * Состояние - ПеречислениеСсылка.СостоянияДокументовЭДО
Функция СостоянияДокументовЭДОПоФайлам(ФайлыДокументовЭДО)
	
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	СообщениеЭДОПрисоединенныеФайлы.Ссылка КАК ФайлДокументаЭДО,
		|	СообщениеЭДО.ЭлектронныйДокумент,
		|	СостоянияДокументовЭДО.Состояние
		|ИЗ
		|	Справочник.СообщениеЭДОПрисоединенныеФайлы КАК СообщениеЭДОПрисоединенныеФайлы
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.СообщениеЭДО КАК СообщениеЭДО
		|		ПО СообщениеЭДОПрисоединенныеФайлы.ВладелецФайла = СообщениеЭДО.Ссылка
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.СостоянияДокументовЭДО КАК СостоянияДокументовЭДО
		|		ПО СообщениеЭДО.ЭлектронныйДокумент = СостоянияДокументовЭДО.ЭлектронныйДокумент
		|ГДЕ
		|	СообщениеЭДОПрисоединенныеФайлы.Ссылка В (&ФайлыДокументовЭДО)";
	
	Запрос.УстановитьПараметр("ФайлыДокументовЭДО", ФайлыДокументовЭДО);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Возврат РезультатЗапроса.Выгрузить();
	
КонецФункции

// Файлы документов ЭДОДля заполнения по сертификату.
// 
// Параметры:
//  ИдентификаторыДанных - Массив из Строка
//  ФайлыПоИдентификаторам - см. ФайлыПоИдентификаторам
//  СостоянияДокументовЭДОПоФайлам - см. СостоянияДокументовЭДОПоФайлам
//  Сертификат - СправочникСсылка.СертификатыКлючейЭлектроннойПодписиИШифрования
//  КонтекстДиагностики - см. ОбработкаНеисправностейБЭД.НовыйКонтекстДиагностики
// 
// Возвращаемое значение:
//  Массив из СправочникСсылка.СообщениеЭДОПрисоединенныеФайлы
Функция ФайлыДокументовЭДОДляЗаполненияПоСертификату(ИдентификаторыДанных, ФайлыПоИдентификаторам, СостоянияДокументовЭДОПоФайлам, Сертификат, КонтекстДиагностики)
	
	ФайлыДокументовЭДО = Новый Массив; // Массив из СправочникСсылка.СообщениеЭДОПрисоединенныеФайлы
	
	ВидОперации = НСтр("ru = 'Заполнение подписанта по сертификату'");
	
	Для Каждого ИдентификаторДанных Из ИдентификаторыДанных Цикл
		
		ФайлДокументаЭДО = ФайлыПоИдентификаторам[ИдентификаторДанных];
		Если Не ЗначениеЗаполнено(ФайлДокументаЭДО) Тогда
			КраткоеПредставление = СтрШаблон(НСтр("ru = 'Не найдены данные электронного документа по идентификатору %1'"),
				ИдентификаторДанных);
			ПодробноеПредставление = СтрШаблон(НСтр("ru = 'Не удалось заполнить подписанта по сертификату ""%1""'"),
				Сертификат) + Символы.ПС + КраткоеПредставление;
			Ошибка = ОбработкаНеисправностейБЭД.НоваяОшибка(ВидОперации,
				ОбработкаНеисправностейБЭДКлиентСервер.ВидОшибкиНеизвестнаяОшибка(),
				ПодробноеПредставление, КраткоеПредставление);
			ПодсистемыБЭД = ОбщегоНазначенияБЭДКлиентСервер.ПодсистемыБЭД();
			ОбработкаНеисправностейБЭД.ДобавитьОшибку(КонтекстДиагностики, Ошибка, ПодсистемыБЭД.ОбменСКонтрагентами);
			Продолжить;
		КонецЕсли;
		
		СостояниеДокументаЭДО = СостоянияДокументовЭДОПоФайлам.Найти(ФайлДокументаЭДО, "ФайлДокументаЭДО");
		Если СостояниеДокументаЭДО = Неопределено
			И СостояниеДокументаЭДО.Состояние <> Перечисления.СостоянияДокументовЭДО.ТребуетсяПодписаниеИзвещения
			И СостояниеДокументаЭДО.Состояние <> Перечисления.СостоянияДокументовЭДО.ТребуетсяПодписаниеИзвещенияПоОтклонению
			И СостояниеДокументаЭДО.Состояние <> Перечисления.СостоянияДокументовЭДО.ТребуетсяПодписаниеОтклонения
			И СостояниеДокументаЭДО.Состояние <> Перечисления.СостоянияДокументовЭДО.ТребуетсяПодписаниеАннулирования Тогда
			КраткоеПредставление = СтрШаблон(
				НСтр("ru = 'Изменение данных электронного документа по идентификатору %1 недоступно'"),
				ИдентификаторДанных);
			ПодробноеПредставление = СтрШаблон(НСтр("ru = 'Не удалось заполнить подписанта по сертификату ""%1""'"),
				Сертификат) + Символы.ПС + КраткоеПредставление;
			Ошибка = ОбработкаНеисправностейБЭД.НоваяОшибка(ВидОперации,
				ОбработкаНеисправностейБЭДКлиентСервер.ВидОшибкиНеизвестнаяОшибка(),
				ПодробноеПредставление, КраткоеПредставление);
			ПодсистемыБЭД = ОбщегоНазначенияБЭДКлиентСервер.ПодсистемыБЭД();
			ОбработкаНеисправностейБЭД.ДобавитьОшибку(КонтекстДиагностики, Ошибка, ПодсистемыБЭД.ОбменСКонтрагентами);
			Продолжить;
		КонецЕсли;
		
		ФайлыДокументовЭДО.Добавить(ФайлДокументаЭДО);
		
	КонецЦикла;
	
	Возврат ФайлыДокументовЭДО;
	
КонецФункции

// Параметры:
//  ФайлыДокументовЭДО - Массив из СправочникСсылка.СообщениеЭДОПрисоединенныеФайлы
//  Сертификат - СправочникСсылка.СертификатыКлючейЭлектроннойПодписиИШифрования
//  Доверенность - СправочникСсылка.МашиночитаемыеДоверенностиОрганизаций
//  КонтекстДиагностики - см. ОбработкаНеисправностейБЭД.НовыйКонтекстДиагностики
// 
// Возвращаемое значение:
//  См. ЭлектронныеДокументыЭДОСлужебный.ЗаполнитьПодписантовИДоверенностиПоСертификату
Функция ЗаполнитьПодписантовИДоверенностиПоСертификату(ФайлыДокументовЭДО, Сертификат, Доверенность, КонтекстДиагностики)
	
	ПараметрыЗаполнения = Новый Структура;
	ПараметрыЗаполнения.Вставить("ТребуетсяЗаполнитьПодписанта", Истина);
	ПараметрыЗаполнения.Вставить("ТребуетсяДоверенность", Ложь);
	ПараметрыЗаполнения.Вставить("НаборМЧД",  Новый Массив);
	ПараметрыЗаполнения.Вставить("Данные",  Неопределено);
	
	НаборМЧД = ПараметрыЗаполнения.НаборМЧД; // Массив из см. ЗаполнитьПодписантовИДоверенностиПоСертификату.Доверенность
	
	Если ЗначениеЗаполнено(Доверенность) Тогда
		ПараметрыЗаполнения.ТребуетсяДоверенность = Истина;
		НаборМЧД.Добавить(Доверенность);
	КонецЕсли;
	
	ДанныеДляЗаполнения = Новый Соответствие;
	
	Для Каждого ФайлДокументаЭДО Из ФайлыДокументовЭДО Цикл
		
		ДанныеДляЗаполнения.Вставить(ФайлДокументаЭДО, ПараметрыЗаполнения);
		
	КонецЦикла;
	
	РезультатыПоФайлам = ЭлектронныеДокументыЭДОСлужебный.ЗаполнитьПодписантовИДоверенностиПоСертификату(
		ДанныеДляЗаполнения, Сертификат, КонтекстДиагностики, Доверенность);
	
	Возврат РезультатыПоФайлам;
	
КонецФункции

#КонецОбласти

#Область ОтправитьДокументыЭДО

// Возвращает результат отправки электронных документов по ЭДО.
// 
// Параметры:
//  ИдентификаторыДокументовЭДО - Массив из Строка
//  МаркерыАвторизации - Массив из См. НовыйМаркерАвторизацииПоУчетнойЗаписиЭДО
//  ОбработатьТолькоИзвещения - Булево
// 
// Возвращаемое значение:
//  Структура:
//  * Ошибки - Неопределено
//           - Массив из Строка
//  * СостоянияДокументовЭДО - Массив из См. НовоеСостояниеДокументаЭДОВФорматеСервиса
//  * ЗашифрованныеМаркеры - Неопределено
//                         - Массив из См. НовыйМаркерАвторизацииПоУчетнойЗаписиЭДО
Функция ОправитьСообщенияПоДокументамЭДО(ИдентификаторыДокументовЭДО, МаркерыАвторизации = Неопределено,
	ОбработатьТолькоИзвещения = Ложь)
	
	Результат = Новый Структура;
	Результат.Вставить("Ошибки", Неопределено);
	Результат.Вставить("СостоянияДокументовЭДО", Новый Массив);
	Результат.Вставить("ЗашифрованныеМаркеры", Неопределено);
	
	ПараметрыВыполнения = ЭлектронныеДокументыЭДОКлиентСервер.НовыеПараметрыВыполненияДействийПоЭДО();
	ПараметрыВыполнения.ОбъектыДействий.ЭлектронныеДокументы = ДокументыЭДО(ИдентификаторыДокументовЭДО);
	ЭлектронныеДокументыЭДО.ДобавитьДействие(ПараметрыВыполнения.НаборДействий,
		Перечисления.ДействияПоЭДО.ПодготовитьКОтправке);
	ЭлектронныеДокументыЭДО.ДобавитьДействие(ПараметрыВыполнения.НаборДействий,
		Перечисления.ДействияПоЭДО.Отправить);
	ПараметрыВыполнения.РасшифрованныеМаркеры = РасшифрованныеМаркерыИзМаркеровАвторизации(МаркерыАвторизации);
	ПараметрыВыполнения.ОбработатьТолькоИзвещения = ОбработатьТолькоИзвещения;
	
	РезультатДействийПоЭДО = ВыполнитьДействиеЭДО(ПараметрыВыполнения);
	
	ДокументыЭДО = ОбщегоНазначения.ВыгрузитьКолонку(РезультатДействийПоЭДО.Итог.ОбработанныеДокументы, "Ключ");
	
	Результат.СостоянияДокументовЭДО = СостоянияДокументовЭДОВФорматеСервиса(ДокументыЭДО);
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти

#Область ПолучитьДокументыЭДО

// Параметры:
//  МеткиВремениПоИдентификаторамЭДО - см. ПорцияДанныхСинхронизацииДокументовЭДОПоМеткамВремени.МеткиВремениПоИдентификаторамЭДО
//  Порция - Число
// 
// Возвращаемое значение:
//  Массив из см. НовоеОписаниеДокументаЭДО
Функция ДанныеСинхронизацииДокументовЭДОПоМеткамВремени(МеткиВремениПоИдентификаторамЭДО, Порция)
	
	ОписаниеЗапроса = Новый Структура("Параметры, Тексты", Новый Структура, Новый Массив);
	
	МеткиВремениДанныхЭДО.ДобавитьТекстЗапросаИдентификаторовДанныхПоМеткамВремени(
		ОписаниеЗапроса, Перечисления.ТипыСинхронизацииСЦентромЭДО.ДокументыЭДО,
		МеткиВремениПоИдентификаторамЭДО, Порция);
	
	ДобавитьТекстЗапросаДанныхДокументовИзВременнойТаблицыМетокВремени(ОписаниеЗапроса);
	
	ДобавитьТекстЗапросаЗаписейБезДокументовИзВременнойТаблицыМетокВремени(ОписаниеЗапроса);
	
	Запрос = Новый Запрос;
	Запрос.Текст = СтрСоединить(ОписаниеЗапроса.Тексты, ОбщегоНазначения.РазделительПакетаЗапросов());
	Для Каждого Параметр Из ОписаниеЗапроса.Параметры Цикл
		Запрос.УстановитьПараметр(Параметр.Ключ, Параметр.Значение);
	КонецЦикла;
	
	РезультатыЗапроса = Запрос.ВыполнитьПакет();
	
	НаборДанных = Новый Массив;
	
	ДополнитьДаннымиСинхронизацииПоВыборкеДокументов(НаборДанных, РезультатыЗапроса[1].Выбрать());
	
	ДополнитьДаннымиСинхронизацииПоВыборкеБезДокументов(НаборДанных, РезультатыЗапроса[2].Выбрать());
	
	Возврат НаборДанных;
	
КонецФункции

// Параметры:
//  ОписаниеЗапроса - Структура:
//  * Параметры - Структура
//  * Тексты - Массив из Строка
Процедура ДобавитьТекстЗапросаДанныхДокументовИзВременнойТаблицыМетокВремени(ОписаниеЗапроса)
	
	ТекстЗапроса =
		"ВЫБРАТЬ
		|	МеткиВремени.ИдентификаторЭДО КАК ИдентификаторЭДО,
		|	МеткиВремени.МеткаВремени КАК МеткаВремени,
		|	ИСТИНА КАК ЭтоВходящийЭДО,
		|	ЭлектронныйДокументВходящийЭДО.ИдентификаторДокумента КАК ИдентификаторДокумента,
		|	ЭлектронныйДокументВходящийЭДО.ФорматОсновногоТитула КАК ФорматОсновногоТитула,
		|	ЭлектронныйДокументВходящийЭДО.ВидДокумента КАК ВидДокумента,
		|	ЭлектронныйДокументВходящийЭДО.ВидДокумента.Наименование КАК ВидДокументаНаименование,
		|	ЭлектронныйДокументВходящийЭДО.ВидДокумента.ТипДокумента КАК ВидДокументаТипДокумента,
		|	ЭлектронныйДокументВходящийЭДО.Организация КАК Организация,
		|	ЭлектронныйДокументВходящийЭДО.Организация.ИНН КАК ОрганизацияИНН,
		|	ЭлектронныйДокументВходящийЭДО.Организация.КПП КАК ОрганизацияКПП,
		|	ЭлектронныйДокументВходящийЭДО.Контрагент КАК Контрагент,
		|	ЭлектронныйДокументВходящийЭДО.Контрагент.ИНН КАК КонтрагентИНН,
		|	ЭлектронныйДокументВходящийЭДО.Контрагент.КПП КАК КонтрагентКПП,
		|	ЭлектронныйДокументВходящийЭДО.НомерДокумента КАК НомерДокумента,
		|	ЭлектронныйДокументВходящийЭДО.ДатаДокумента КАК ДатаДокумента,
		|	ЭлектронныйДокументВходящийЭДО.ДатаАннулирования КАК ДатаАннулирования,
		|	ЭлектронныйДокументВходящийЭДО.ДатаПодписания КАК ДатаПодписания,
		|	ЭлектронныйДокументВходящийЭДО.ДатаПолучения КАК ДатаОтправкиПолучения,
		|	ЭлектронныйДокументВходящийЭДО.СуммаДокумента КАК СуммаДокумента,
		|	ЭлектронныйДокументВходящийЭДО.СпособОбмена КАК СпособОбмена,
		|	ЭлектронныйДокументВходящийЭДО.ТипРегламента КАК ТипРегламента,
		|	ЭлектронныйДокументВходящийЭДО.ТребуетсяИзвещение КАК ТребуетсяИзвещение,
		|	ЭлектронныйДокументВходящийЭДО.ТребуетсяПодтверждение КАК ТребуетсяПодтверждение,
		|	ЭлектронныйДокументВходящийЭДО.ИдентификаторОрганизации КАК ИдентификаторОрганизации,
		|	ЭлектронныйДокументВходящийЭДО.ИдентификаторКонтрагента КАК ИдентификаторКонтрагента,
		|	ЭлектронныйДокументВходящийЭДО.ИдентификаторДокументооборота КАК ИдентификаторДокументооборота,
		|	ЕСТЬNULL(СостоянияДокументовЭДО.Состояние, ЗНАЧЕНИЕ(Перечисление.СостоянияДокументовЭДО.ПустаяСсылка)) КАК Состояние,
		|	ЕСТЬNULL(СостоянияДокументовЭДО.СостояниеДополнение, """") КАК СостояниеДополнение,
		|	ЕСТЬNULL(СостоянияДокументовЭДО.ДатаИзменения, ДАТАВРЕМЯ(1, 1, 1)) КАК ДатаИзмененияСостояния,
		|	ЕСТЬNULL(СостоянияДокументовЭДО.Комментарий, """") КАК КомментарийСостояния,
		|	ЕСТЬNULL(СоставПакетовДокументовЭДО.ИдентификаторПакета, """") КАК ИдентификаторПакета
		|ИЗ
		|	ИдентификаторыДанныхПоМеткамВремени КАК МеткиВремени
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЭлектронныйДокументВходящийЭДО КАК ЭлектронныйДокументВходящийЭДО
		|		ПО МеткиВремени.ИдентификаторОбъекта = ЭлектронныйДокументВходящийЭДО.ИдентификаторДокумента
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СостоянияДокументовЭДО КАК СостоянияДокументовЭДО
		|		ПО ЭлектронныйДокументВходящийЭДО.Ссылка = СостоянияДокументовЭДО.ЭлектронныйДокумент
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СоставПакетовДокументовЭДО КАК СоставПакетовДокументовЭДО
		|		ПО ЭлектронныйДокументВходящийЭДО.Ссылка = СоставПакетовДокументовЭДО.ЭлектронныйДокумент
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	МеткиВремени.ИдентификаторЭДО КАК ИдентификаторЭДО,
		|	МеткиВремени.МеткаВремени КАК МеткаВремени,
		|	ЛОЖЬ КАК ЭтоВходящийЭДО,
		|	ЭлектронныйДокументИсходящийЭДО.ИдентификаторДокумента КАК ИдентификаторДокумента,
		|	ЭлектронныйДокументИсходящийЭДО.ФорматОсновногоТитула КАК ФорматОсновногоТитула,
		|	ЭлектронныйДокументИсходящийЭДО.ВидДокумента КАК ВидДокумента,
		|	ЭлектронныйДокументИсходящийЭДО.ВидДокумента.Наименование КАК ВидДокументаНаименование,
		|	ЭлектронныйДокументИсходящийЭДО.ВидДокумента.ТипДокумента КАК ВидДокументаТипДокумента,
		|	ЭлектронныйДокументИсходящийЭДО.Организация КАК Организация,
		|	ЭлектронныйДокументИсходящийЭДО.Организация.ИНН КАК ОрганизацияИНН,
		|	ЭлектронныйДокументИсходящийЭДО.Организация.КПП КАК ОрганизацияКПП,
		|	ЭлектронныйДокументИсходящийЭДО.Контрагент КАК Контрагент,
		|	ЭлектронныйДокументИсходящийЭДО.Контрагент.ИНН КАК КонтрагентИНН,
		|	ЭлектронныйДокументИсходящийЭДО.Контрагент.КПП КАК КонтрагентКПП,
		|	ЭлектронныйДокументИсходящийЭДО.НомерДокумента КАК НомерДокумента,
		|	ЭлектронныйДокументИсходящийЭДО.ДатаДокумента КАК ДатаДокумента,
		|	ЭлектронныйДокументИсходящийЭДО.ДатаАннулирования КАК ДатаАннулирования,
		|	ЭлектронныйДокументИсходящийЭДО.ДатаПодписания КАК ДатаПодписания,
		|	ЭлектронныйДокументИсходящийЭДО.ДатаОтправки КАК ДатаОтправкиПолучения,
		|	ЭлектронныйДокументИсходящийЭДО.СуммаДокумента КАК СуммаДокумента,
		|	ЭлектронныйДокументИсходящийЭДО.СпособОбмена КАК СпособОбмена,
		|	ЭлектронныйДокументИсходящийЭДО.ТипРегламента КАК ТипРегламента,
		|	ЭлектронныйДокументИсходящийЭДО.ТребуетсяИзвещение КАК ТребуетсяИзвещение,
		|	ЭлектронныйДокументИсходящийЭДО.ТребуетсяПодтверждение КАК ТребуетсяПодтверждение,
		|	ЭлектронныйДокументИсходящийЭДО.ИдентификаторОрганизации КАК ИдентификаторОрганизации,
		|	ЭлектронныйДокументИсходящийЭДО.ИдентификаторКонтрагента КАК ИдентификаторКонтрагента,
		|	ЭлектронныйДокументИсходящийЭДО.ИдентификаторДокументооборота КАК ИдентификаторДокументооборота,
		|	ЕСТЬNULL(СостоянияДокументовЭДО.Состояние, ЗНАЧЕНИЕ(Перечисление.СостоянияДокументовЭДО.ПустаяСсылка)) КАК Состояние,
		|	ЕСТЬNULL(СостоянияДокументовЭДО.СостояниеДополнение, """") КАК СостояниеДополнение,
		|	ЕСТЬNULL(СостоянияДокументовЭДО.ДатаИзменения, ДАТАВРЕМЯ(1, 1, 1)) КАК ДатаИзмененияСостояния,
		|	ЕСТЬNULL(СостоянияДокументовЭДО.Комментарий, """") КАК КомментарийСостояния,
		|	ЕСТЬNULL(СоставПакетовДокументовЭДО.ИдентификаторПакета, """") КАК ИдентификаторПакета
		|ИЗ
		|	ИдентификаторыДанныхПоМеткамВремени КАК МеткиВремени
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЭлектронныйДокументИсходящийЭДО КАК ЭлектронныйДокументИсходящийЭДО
		|		ПО МеткиВремени.ИдентификаторОбъекта = ЭлектронныйДокументИсходящийЭДО.ИдентификаторДокумента
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СостоянияДокументовЭДО КАК СостоянияДокументовЭДО
		|		ПО ЭлектронныйДокументИсходящийЭДО.Ссылка = СостоянияДокументовЭДО.ЭлектронныйДокумент
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СоставПакетовДокументовЭДО КАК СоставПакетовДокументовЭДО
		|		ПО ЭлектронныйДокументИсходящийЭДО.Ссылка = СоставПакетовДокументовЭДО.ЭлектронныйДокумент";
	
	ОписаниеЗапроса.Тексты.Добавить(ТекстЗапроса);
	
КонецПроцедуры

// Параметры:
//  ОписаниеЗапроса - Структура:
//  * Параметры - Структура
//  * Тексты - Массив из Строка
Процедура ДобавитьТекстЗапросаЗаписейБезДокументовИзВременнойТаблицыМетокВремени(ОписаниеЗапроса)
	
	ТекстЗапроса =
		"ВЫБРАТЬ
		|	МеткиВремени.ИдентификаторЭДО КАК ИдентификаторЭДО,
		|	МеткиВремени.ИдентификаторОбъекта КАК ИдентификаторОбъекта,
		|	МеткиВремени.МеткаВремени КАК МеткаВремени
		|ИЗ
		|	ИдентификаторыДанныхПоМеткамВремени КАК МеткиВремени
		|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ЭлектронныйДокументВходящийЭДО КАК ЭлектронныйДокументВходящийЭДО
		|		ПО МеткиВремени.ИдентификаторОбъекта = ЭлектронныйДокументВходящийЭДО.ИдентификаторДокумента
		|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ЭлектронныйДокументИсходящийЭДО КАК ЭлектронныйДокументИсходящийЭДО
		|		ПО МеткиВремени.ИдентификаторОбъекта = ЭлектронныйДокументИсходящийЭДО.ИдентификаторДокумента
		|ГДЕ
		|	ЭлектронныйДокументВходящийЭДО.Ссылка ЕСТЬ NULL
		|	И ЭлектронныйДокументИсходящийЭДО.Ссылка ЕСТЬ NULL";
	
	ОписаниеЗапроса.Тексты.Добавить(ТекстЗапроса);
	
КонецПроцедуры

// Параметры:
//  НаборДанных - Массив из см. НовыеДанныеСинхронизацииДокументаЭДО
//  Выборка - см. ДанныеСинхронизацииПоВыборкеДокументов.Выборка
Процедура ДополнитьДаннымиСинхронизацииПоВыборкеДокументов(НаборДанных, Выборка)
	
	Пока Выборка.Следующий() Цикл
		ОписаниеДокументаЭДО = ДанныеСинхронизацииПоВыборкеДокументов(Выборка);
		НаборДанных.Добавить(ОписаниеДокументаЭДО);
	КонецЦикла;
	
КонецПроцедуры

// Параметры:
//  НаборДанных - Массив из см. НовыеДанныеСинхронизацииДокументаЭДО
//  Выборка - ВыборкаИзРезультатаЗапроса:
//  * ИдентификаторЭДО - Строка
//  * ИдентификаторОбъекта - Строка
//  * МеткаВремени - Число
Процедура ДополнитьДаннымиСинхронизацииПоВыборкеБезДокументов(НаборДанных, Выборка)
	
	Пока Выборка.Следующий() Цикл
		
		СостояниеСинхронизации = НовоеСостояниеСинхронизацииДокументаЭДО();
		СостояниеСинхронизации.ИдентификаторЭДО = Выборка.ИдентификаторЭДО;
		СостояниеСинхронизации.МеткаВремени = Выборка.МеткаВремени;
		СостояниеСинхронизации.Удаление = Истина;
		
		ДанныеСинхронизации = НовыеДанныеСинхронизацииДокументаЭДО();
		ДанныеСинхронизации.Идентификатор = Выборка.ИдентификаторОбъекта;
		ДанныеСинхронизации.Состояние = СостояниеСинхронизации;
		
		НаборДанных.Добавить(ДанныеСинхронизации);
		
	КонецЦикла;
	
КонецПроцедуры

// Возвращаемое значение:
//  Структура - Новые данные синхронизации документа ЭДО:
// * Идентификатор - Строка
// * Состояние - Неопределено
//             - см. НовоеСостояниеСинхронизацииДокументаЭДО
// * Описание - Неопределено,
//            - см. НовоеОписаниеДокументаЭДО
Функция НовыеДанныеСинхронизацииДокументаЭДО()
	Данные = Новый Структура;
	Данные.Вставить("Идентификатор", "");
	Данные.Вставить("Состояние", Неопределено);
	Данные.Вставить("Описание", Неопределено);
	Возврат Данные;
КонецФункции

// Возвращаемое значение:
//  Структура:
//  * ИдентификаторЭДО - Строка 
//  * МеткаВремени - Число
//  * Удаление - Булево
Функция НовоеСостояниеСинхронизацииДокументаЭДО()
	Состояние = Новый Структура;
	Состояние.Вставить("ИдентификаторЭДО", "");
	Состояние.Вставить("МеткаВремени", 0);
	Состояние.Вставить("Удаление", Ложь);
	Возврат Состояние;
КонецФункции

// Возвращаемое значение:
//  Структура:
//  * ЭтоВходящийЭДО                - Булево
//  * Идентификатор                 - Строка
//  * Формат                        - Строка
//  * ВидДокумента                  - Структура:
//  ** Наименование                 - Строка
//  ** ТипДокумента                 - Строка
//  * Организация                   - Структура:
//  ** ИНН                          - Строка
//  ** КПП                          - Строка
//  * Контрагент                    - Структура:
//  ** ИНН                          - Строка
//  ** КПП                          - Строка
//  * Договор                       - Неопределено,Структура:
//  ** Наименование                 - Строка
//  ** Номер                        - Строка
//  ** Дата                         - См. ОбщегоНазначенияБЭД.ДатаВФорматеISO
//  * Дата                          - См. ОбщегоНазначенияБЭД.ДатаВФорматеISO
//  * ДатаАннулирования             - См. ОбщегоНазначенияБЭД.ДатаВФорматеISO
//  * ДатаПодписания                - См. ОбщегоНазначенияБЭД.ДатаВФорматеISO
//  * ДатаОтправкиПолучения         - См. ОбщегоНазначенияБЭД.ДатаВФорматеISO
//  * Номер                         - Строка
//  * Сумма                         - Число
//  * СпособОбмена                  - Строка
//  * ТипРегламента                 - Строка
//  * ТребуетсяИзвещение            - Булево
//  * ТребуетсяПодтверждение        - Булево
//  * ИдентификаторОрганизации      - Строка
//  * ИдентификаторКонтрагента      - Строка
//  * ИдентификаторДокументооборота - Строка
//  * ИмяСостояния                  - Строка
//  * СостояниеДополнение           - Строка
//  * ДатаИзмененияСостояния        - Строка
//  * КомментарийСостояния          - Строка
//  * ИдентификаторПакета           - Строка
Функция НовоеОписаниеДокументаЭДО()
	Описание = Новый Структура;
	Описание.Вставить("ЭтоВходящийЭДО", Ложь);
	Описание.Вставить("Идентификатор", "");
	Описание.Вставить("Формат", "");
	Описание.Вставить("ВидДокумента", НовоеОписаниеВидаДокумента());
	Описание.Вставить("Организация", НовоеОписаниеОрганизации());
	Описание.Вставить("Контрагент", НовоеОписаниеОрганизации());
	Описание.Вставить("Договор", Неопределено);
	Описание.Вставить("Дата", "");
	Описание.Вставить("ДатаАннулирования", "");
	Описание.Вставить("ДатаПодписания", "");
	Описание.Вставить("ДатаОтправкиПолучения", "");
	Описание.Вставить("Номер", "");
	Описание.Вставить("Сумма", 0);
	Описание.Вставить("СпособОбмена", "");
	Описание.Вставить("ТипРегламента", "");
	Описание.Вставить("ТребуетсяИзвещение", Ложь);
	Описание.Вставить("ТребуетсяПодтверждение", Ложь);
	Описание.Вставить("ИдентификаторОрганизации", "");
	Описание.Вставить("ИдентификаторКонтрагента", "");
	Описание.Вставить("ИдентификаторДокументооборота", "");
	Описание.Вставить("ИмяСостояния", "");
	Описание.Вставить("СостояниеДополнение", "");
	Описание.Вставить("ДатаИзмененияСостояния", "");
	Описание.Вставить("КомментарийСостояния", "");
	Описание.Вставить("ИдентификаторПакета", "");
	Возврат Описание;
КонецФункции

// Параметры:
//  Выборка - ВыборкаИзРезультатаЗапроса:
//  * ИдентификаторЭДО - Строка
//  * ИдентификаторОбъекта - Строка
//  * МеткаВремени - Число
//  * ЭтоВходящийЭДО - Булево
//  * ИдентификаторДокумента - Строка
//  * ФорматОсновногоТитула - Строка
//  * ВидДокумента - СправочникСсылка.ВидыДокументовЭДО
//  * ВидДокументаНаименование - Строка
//  * ВидДокументаТипДокумента - ПеречислениеСсылка.ТипыДокументовЭДО
//  * Организация - СправочникСсылка.Организации
//  * ОрганизацияИНН - Строка
//  * ОрганизацияКПП - Строка
//  * Контрагент - СправочникСсылка.Организации
//  * КонтрагентИНН - Строка
//  * КонтрагентКПП - Строка
//  * Договор - СправочникСсылка.ДоговорыКонтрагентов
//  * ДоговорНаименование - Строка
//  * ДоговорНомер - Строка
//  * ДоговорДата - Дата
//  * НомерДокумента - Строка
//  * ДатаДокумента - Дата
//  * ДатаАннулирования - Дата
//  * ДатаПодписания - Дата
//  * ДатаОтправкиПолучения - Дата
//  * СуммаДокумента - Число
//  * СпособОбмена - ПеречислениеСсылка.СпособыОбменаЭД
//  * ТипРегламента - ПеречислениеСсылка.ТипыРегламентовЭДО
//  * ТребуетсяИзвещение - Булево
//  * ТребуетсяПодтверждение - Булево
//  * ИдентификаторОрганизации - Строка
//  * ИдентификаторКонтрагента - Строка
//  * ИдентификаторДокументооборота - Строка
//  * Состояние - ПеречислениеСсылка.СостоянияДокументовЭДО
//  * СостояниеДополнение - Строка
//  * ДатаИзмененияСостояния - Дата
//  * КомментарийСостояния - Строка
//  * ИдентификаторПакета - УникальныйИдентификатор
//  
// Возвращаемое значение:
//  См. НовыеДанныеСинхронизацииДокументаЭДО
Функция ДанныеСинхронизацииПоВыборкеДокументов(Выборка)
	
	СостояниеСинхронизации = НовоеСостояниеСинхронизацииДокументаЭДО();
	СостояниеСинхронизации.ИдентификаторЭДО = Выборка.ИдентификаторЭДО;
	СостояниеСинхронизации.МеткаВремени = Выборка.МеткаВремени;
	
	ДанныеСинхронизации = НовыеДанныеСинхронизацииДокументаЭДО();
	ДанныеСинхронизации.Идентификатор = Выборка.ИдентификаторДокумента;
	ДанныеСинхронизации.Состояние = СостояниеСинхронизации;
	ДанныеСинхронизации.Описание = ОписаниеДокументаЭДОПоВыборкеДанных(Выборка);
	
	Возврат ДанныеСинхронизации;
	
КонецФункции

// Параметры:
//  Выборка - ВыборкаИзРезультатаЗапроса:
//  * ЭтоВходящийЭДО - Булево
//  * ИдентификаторДокумента - Строка
//  * ФорматОсновногоТитула - Строка
//  * ВидДокумента - СправочникСсылка.ВидыДокументовЭДО
//  * ВидДокументаНаименование - Строка
//  * ВидДокументаТипДокумента - ПеречислениеСсылка.ТипыДокументовЭДО
//  * Организация - СправочникСсылка.Организации
//  * ОрганизацияИНН - Строка
//  * ОрганизацияКПП - Строка
//  * Контрагент - СправочникСсылка.Организации
//  * КонтрагентИНН - Строка
//  * КонтрагентКПП - Строка
//  * Договор - СправочникСсылка.ДоговорыКонтрагентов
//  * ДоговорНаименование - Строка
//  * ДоговорНомер - Строка
//  * ДоговорДата - Дата
//  * НомерДокумента - Строка
//  * ДатаДокумента - Дата
//  * ДатаАннулирования - Дата
//  * ДатаОтправкиПолучения - Дата
//  * ДатаПодписания - Дата
//  * СуммаДокумента - Число
//  * СпособОбмена - ПеречислениеСсылка.СпособыОбменаЭД
//  * ТипРегламента - ПеречислениеСсылка.ТипыРегламентовЭДО
//  * ТребуетсяИзвещение - Булево
//  * ТребуетсяПодтверждение - Булево
//  * ИдентификаторОрганизации - Строка
//  * ИдентификаторКонтрагента - Строка
//  * ИдентификаторДокументооборота - Строка
//  * Состояние - ПеречислениеСсылка.СостоянияДокументовЭДО
//  * СостояниеДополнение - Строка
//  * ДатаИзмененияСостояния - Дата
//  * КомментарийСостояния - Строка
//  * ИдентификаторПакета - УникальныйИдентификатор
// 
// Возвращаемое значение:
//  См. НовоеОписаниеДокументаЭДО
Функция ОписаниеДокументаЭДОПоВыборкеДанных(Выборка)
	
	ОписаниеДокументаЭДО = НовоеОписаниеДокументаЭДО();
	ОписаниеДокументаЭДО.ЭтоВходящийЭДО = Выборка.ЭтоВходящийЭДО;
	ОписаниеДокументаЭДО.Идентификатор = Выборка.ИдентификаторДокумента;
	ОписаниеДокументаЭДО.Формат = Выборка.ФорматОсновногоТитула;
	ОписаниеДокументаЭДО.ВидДокумента.Наименование = Выборка.ВидДокументаНаименование;
	ОписаниеДокументаЭДО.ВидДокумента.ТипДокумента = ОбщегоНазначенияБЭДПовтИсп.ИмяЗначенияПеречисления(
		Выборка.ВидДокументаТипДокумента);
	ОписаниеДокументаЭДО.Организация.ИНН = Выборка.ОрганизацияИНН;
	ОписаниеДокументаЭДО.Организация.КПП = Выборка.ОрганизацияКПП;
	ОписаниеДокументаЭДО.Контрагент.ИНН = Выборка.КонтрагентИНН;
	ОписаниеДокументаЭДО.Контрагент.КПП = Выборка.КонтрагентКПП;
	ОписаниеДокументаЭДО.Номер = Выборка.НомерДокумента;
	ОписаниеДокументаЭДО.Дата = ОбщегоНазначенияБЭД.ДатаВФорматеISO(Выборка.ДатаДокумента);
	ОписаниеДокументаЭДО.ДатаАннулирования = ОбщегоНазначенияБЭД.ДатаВФорматеISO(Выборка.ДатаАннулирования);
	ОписаниеДокументаЭДО.ДатаОтправкиПолучения = ОбщегоНазначенияБЭД.ДатаВФорматеISO(Выборка.ДатаОтправкиПолучения);
	ОписаниеДокументаЭДО.ДатаПодписания = ОбщегоНазначенияБЭД.ДатаВФорматеISO(Выборка.ДатаПодписания);
	ОписаниеДокументаЭДО.Сумма = Выборка.СуммаДокумента;
	ОписаниеДокументаЭДО.СпособОбмена = ОбщегоНазначенияБЭДПовтИсп.ИмяЗначенияПеречисления(Выборка.СпособОбмена);
	ОписаниеДокументаЭДО.ТипРегламента = ОбщегоНазначенияБЭДПовтИсп.ИмяЗначенияПеречисления(Выборка.ТипРегламента);
	ОписаниеДокументаЭДО.ТребуетсяИзвещение = Выборка.ТребуетсяИзвещение;
	ОписаниеДокументаЭДО.ТребуетсяПодтверждение = Выборка.ТребуетсяПодтверждение;
	ОписаниеДокументаЭДО.ИдентификаторОрганизации = Выборка.ИдентификаторОрганизации;
	ОписаниеДокументаЭДО.ИдентификаторКонтрагента = Выборка.ИдентификаторКонтрагента;
	ОписаниеДокументаЭДО.ИдентификаторДокументооборота = Выборка.ИдентификаторДокументооборота;
	ОписаниеДокументаЭДО.ИмяСостояния = ОбщегоНазначенияБЭДПовтИсп.ИмяЗначенияПеречисления(Выборка.Состояние);
	ОписаниеДокументаЭДО.СостояниеДополнение = Выборка.СостояниеДополнение;
	ОписаниеДокументаЭДО.ДатаИзмененияСостояния = ОбщегоНазначенияБЭД.ДатаВФорматеISO(Выборка.ДатаИзмененияСостояния);
	ОписаниеДокументаЭДО.КомментарийСостояния = Выборка.КомментарийСостояния;
	ОписаниеДокументаЭДО.ИдентификаторПакета = Строка(Выборка.ИдентификаторПакета);
	Возврат ОписаниеДокументаЭДО;
	
КонецФункции

// Параметры:
//  ИдентификаторыДокументовЭДО - Массив из Строка
// 
// Возвращаемое значение:
//  Массив из см. НовыеДанныеСинхронизацииДокументаЭДО
Функция ДанныеСинхронизацииДокументовЭДОПоИдентификаторам(ИдентификаторыДокументовЭДО)
	
	Запрос = Новый Запрос;
	Запрос.Текст = ТекстЗапросаДанныхДокументовПоИдентификаторам();
	Запрос.УстановитьПараметр("ИдентификаторыДокументов", ИдентификаторыДокументовЭДО);
	Выборка = Запрос.Выполнить().Выбрать();
	НаборДанных = Новый Массив; // Массив из см. НовыеДанныеСинхронизацииДокументаЭДО
	ДополнитьДаннымиСинхронизацииПоВыборкеДокументов(НаборДанных, Выборка);
	Возврат НаборДанных;
	
КонецФункции

// Возвращаемое значение:
//  Строка
Функция ТекстЗапросаДанныхДокументовПоИдентификаторам()
	
	Возврат
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	МеткиВремениДанныхЭДО.ИдентификаторЭДО КАК ИдентификаторЭДО,
		|	МеткиВремениДанныхЭДО.МеткаВремени КАК МеткаВремени,
		|	ИСТИНА КАК ЭтоВходящийЭДО,
		|	ЭлектронныйДокументВходящийЭДО.ИдентификаторДокумента КАК ИдентификаторДокумента,
		|	ЭлектронныйДокументВходящийЭДО.ФорматОсновногоТитула КАК ФорматОсновногоТитула,
		|	ЭлектронныйДокументВходящийЭДО.ВидДокумента КАК ВидДокумента,
		|	ЭлектронныйДокументВходящийЭДО.ВидДокумента.Наименование КАК ВидДокументаНаименование,
		|	ЭлектронныйДокументВходящийЭДО.ВидДокумента.ТипДокумента КАК ВидДокументаТипДокумента,
		|	ЭлектронныйДокументВходящийЭДО.Организация КАК Организация,
		|	ЭлектронныйДокументВходящийЭДО.Организация.ИНН КАК ОрганизацияИНН,
		|	ЭлектронныйДокументВходящийЭДО.Организация.КПП КАК ОрганизацияКПП,
		|	ЭлектронныйДокументВходящийЭДО.Контрагент КАК Контрагент,
		|	ЭлектронныйДокументВходящийЭДО.Контрагент.ИНН КАК КонтрагентИНН,
		|	ЭлектронныйДокументВходящийЭДО.Контрагент.КПП КАК КонтрагентКПП,
		|	ЭлектронныйДокументВходящийЭДО.НомерДокумента КАК НомерДокумента,
		|	ЭлектронныйДокументВходящийЭДО.ДатаДокумента КАК ДатаДокумента,
		|	ЭлектронныйДокументВходящийЭДО.ДатаАннулирования КАК ДатаАннулирования,
		|	ЭлектронныйДокументВходящийЭДО.ДатаПодписания КАК ДатаПодписания,
		|	ЭлектронныйДокументВходящийЭДО.ДатаПолучения КАК ДатаОтправкиПолучения,
		|	ЭлектронныйДокументВходящийЭДО.СуммаДокумента КАК СуммаДокумента,
		|	ЭлектронныйДокументВходящийЭДО.СпособОбмена КАК СпособОбмена,
		|	ЭлектронныйДокументВходящийЭДО.ТипРегламента КАК ТипРегламента,
		|	ЭлектронныйДокументВходящийЭДО.ТребуетсяИзвещение КАК ТребуетсяИзвещение,
		|	ЭлектронныйДокументВходящийЭДО.ТребуетсяПодтверждение КАК ТребуетсяПодтверждение,
		|	ЭлектронныйДокументВходящийЭДО.ИдентификаторОрганизации КАК ИдентификаторОрганизации,
		|	ЭлектронныйДокументВходящийЭДО.ИдентификаторКонтрагента КАК ИдентификаторКонтрагента,
		|	ЭлектронныйДокументВходящийЭДО.ИдентификаторДокументооборота КАК ИдентификаторДокументооборота,
		|	ЕСТЬNULL(СостоянияДокументовЭДО.Состояние, ЗНАЧЕНИЕ(Перечисление.СостоянияДокументовЭДО.ПустаяСсылка)) КАК Состояние,
		|	ЕСТЬNULL(СостоянияДокументовЭДО.СостояниеДополнение, """") КАК СостояниеДополнение,
		|	ЕСТЬNULL(СостоянияДокументовЭДО.ДатаИзменения, ДАТАВРЕМЯ(1, 1, 1)) КАК ДатаИзмененияСостояния,
		|	ЕСТЬNULL(СостоянияДокументовЭДО.Комментарий, """") КАК КомментарийСостояния,
		|	ЕСТЬNULL(СоставПакетовДокументовЭДО.ИдентификаторПакета, """") КАК ИдентификаторПакета
		|ИЗ
		|	Документ.ЭлектронныйДокументВходящийЭДО КАК ЭлектронныйДокументВходящийЭДО
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.МеткиВремениДанныхЭДО КАК МеткиВремениДанныхЭДО
		|		ПО ЭлектронныйДокументВходящийЭДО.ИдентификаторОрганизации = МеткиВремениДанныхЭДО.ИдентификаторЭДО
		|		И МеткиВремениДанныхЭДО.ТипДанных = ЗНАЧЕНИЕ(Перечисление.ТипыСинхронизацииСЦентромЭДО.ДокументыЭДО)
		|		И ЭлектронныйДокументВходящийЭДО.ИдентификаторДокумента = МеткиВремениДанныхЭДО.ИдентификаторОбъекта
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СостоянияДокументовЭДО КАК СостоянияДокументовЭДО
		|		ПО ЭлектронныйДокументВходящийЭДО.Ссылка = СостоянияДокументовЭДО.ЭлектронныйДокумент
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СоставПакетовДокументовЭДО КАК СоставПакетовДокументовЭДО
		|		ПО ЭлектронныйДокументВходящийЭДО.Ссылка = СоставПакетовДокументовЭДО.ЭлектронныйДокумент
		|ГДЕ
		|	ЭлектронныйДокументВходящийЭДО.ИдентификаторДокумента В (&ИдентификаторыДокументов)
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	МеткиВремениДанныхЭДО.ИдентификаторЭДО КАК ИдентификаторЭДО,
		|	МеткиВремениДанныхЭДО.МеткаВремени КАК МеткаВремени,
		|	ЛОЖЬ КАК ЭтоВходящийЭДО,
		|	ЭлектронныйДокументИсходящийЭДО.ИдентификаторДокумента КАК ИдентификаторДокумента,
		|	ЭлектронныйДокументИсходящийЭДО.ФорматОсновногоТитула КАК ФорматОсновногоТитула,
		|	ЭлектронныйДокументИсходящийЭДО.ВидДокумента КАК ВидДокумента,
		|	ЭлектронныйДокументИсходящийЭДО.ВидДокумента.Наименование КАК ВидДокументаНаименование,
		|	ЭлектронныйДокументИсходящийЭДО.ВидДокумента.ТипДокумента КАК ВидДокументаТипДокумента,
		|	ЭлектронныйДокументИсходящийЭДО.Организация КАК Организация,
		|	ЭлектронныйДокументИсходящийЭДО.Организация.ИНН КАК ОрганизацияИНН,
		|	ЭлектронныйДокументИсходящийЭДО.Организация.КПП КАК ОрганизацияКПП,
		|	ЭлектронныйДокументИсходящийЭДО.Контрагент КАК Контрагент,
		|	ЭлектронныйДокументИсходящийЭДО.Контрагент.ИНН КАК КонтрагентИНН,
		|	ЭлектронныйДокументИсходящийЭДО.Контрагент.КПП КАК КонтрагентКПП,
		|	ЭлектронныйДокументИсходящийЭДО.НомерДокумента КАК НомерДокумента,
		|	ЭлектронныйДокументИсходящийЭДО.ДатаДокумента КАК ДатаДокумента,
		|	ЭлектронныйДокументИсходящийЭДО.ДатаАннулирования КАК ДатаАннулирования,
		|	ЭлектронныйДокументИсходящийЭДО.ДатаПодписания КАК ДатаПодписания,
		|	ЭлектронныйДокументИсходящийЭДО.ДатаОтправки КАК ДатаОтправкиПолучения,
		|	ЭлектронныйДокументИсходящийЭДО.СуммаДокумента КАК СуммаДокумента,
		|	ЭлектронныйДокументИсходящийЭДО.СпособОбмена КАК СпособОбмена,
		|	ЭлектронныйДокументИсходящийЭДО.ТипРегламента КАК ТипРегламента,
		|	ЭлектронныйДокументИсходящийЭДО.ТребуетсяИзвещение КАК ТребуетсяИзвещение,
		|	ЭлектронныйДокументИсходящийЭДО.ТребуетсяПодтверждение КАК ТребуетсяПодтверждение,
		|	ЭлектронныйДокументИсходящийЭДО.ИдентификаторОрганизации КАК ИдентификаторОрганизации,
		|	ЭлектронныйДокументИсходящийЭДО.ИдентификаторКонтрагента КАК ИдентификаторКонтрагента,
		|	ЭлектронныйДокументИсходящийЭДО.ИдентификаторДокументооборота КАК ИдентификаторДокументооборота,
		|	ЕСТЬNULL(СостоянияДокументовЭДО.Состояние, ЗНАЧЕНИЕ(Перечисление.СостоянияДокументовЭДО.ПустаяСсылка)) КАК Состояние,
		|	ЕСТЬNULL(СостоянияДокументовЭДО.СостояниеДополнение, """") КАК СостояниеДополнение,
		|	ЕСТЬNULL(СостоянияДокументовЭДО.ДатаИзменения, ДАТАВРЕМЯ(1, 1, 1)) КАК ДатаИзмененияСостояния,
		|	ЕСТЬNULL(СостоянияДокументовЭДО.Комментарий, """") КАК КомментарийСостояния,
		|	ЕСТЬNULL(СоставПакетовДокументовЭДО.ИдентификаторПакета, """") КАК ИдентификаторПакета
		|ИЗ
		|	Документ.ЭлектронныйДокументИсходящийЭДО КАК ЭлектронныйДокументИсходящийЭДО
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.МеткиВремениДанныхЭДО КАК МеткиВремениДанныхЭДО
		|		ПО ЭлектронныйДокументИсходящийЭДО.ИдентификаторОрганизации = МеткиВремениДанныхЭДО.ИдентификаторЭДО
		|		И МеткиВремениДанныхЭДО.ТипДанных = ЗНАЧЕНИЕ(Перечисление.ТипыСинхронизацииСЦентромЭДО.ДокументыЭДО)
		|		И ЭлектронныйДокументИсходящийЭДО.ИдентификаторДокумента = МеткиВремениДанныхЭДО.ИдентификаторОбъекта
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СостоянияДокументовЭДО КАК СостоянияДокументовЭДО
		|		ПО ЭлектронныйДокументИсходящийЭДО.Ссылка = СостоянияДокументовЭДО.ЭлектронныйДокумент
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СоставПакетовДокументовЭДО КАК СоставПакетовДокументовЭДО
		|		ПО ЭлектронныйДокументИсходящийЭДО.Ссылка = СоставПакетовДокументовЭДО.ЭлектронныйДокумент
		|ГДЕ
		|	ЭлектронныйДокументИсходящийЭДО.ИдентификаторДокумента В (&ИдентификаторыДокументов)";
	
КонецФункции

#КонецОбласти

#Область ВыполнениеДействийПоШаблону

// Параметры:
//  ДействиеЭДО - ПеречислениеСсылка.ДействияПоЭДО
//  ИдентификаторыДокументовЭДО - Массив из Строка
//  Комментарий - Строка
// 
// Возвращаемое значение:
//  Структура:
//  * Ошибки - Неопределено
//           - Массив из Строка
//  * СостоянияДокументовЭДО - Массив из См. НовоеСостояниеДокументаЭДОВФорматеСервиса
Функция ВыполнитьДействиеЭДОПоШаблону(ДействиеЭДО, ИдентификаторыДокументовЭДО, Комментарий = "")
	
	РезультатШаблона = Новый Структура;
	РезультатШаблона.Вставить("Ошибки", Неопределено);
	РезультатШаблона.Вставить("СостоянияДокументовЭДО", Новый Массив);
	
	Если Не ЗначениеЗаполнено(ИдентификаторыДокументовЭДО) Тогда
		Возврат РезультатШаблона;
	КонецЕсли;
	
	ПараметрыВыполнения = ЭлектронныеДокументыЭДОКлиентСервер.НовыеПараметрыВыполненияДействийПоЭДО();
	ПараметрыВыполнения.ОбъектыДействий.ЭлектронныеДокументы = ДокументыЭДО(ИдентификаторыДокументовЭДО);
	ЭлектронныеДокументыЭДО.ДобавитьДействие(ПараметрыВыполнения.НаборДействий, ДействиеЭДО);
	Если ЗначениеЗаполнено(Комментарий) Тогда
		ДополнительныеПараметрыДействия = ЭлектронныеДокументыЭДОКлиентСервер.НовыеДополнительныеПараметрыДействия();
		ДополнительныеПараметрыДействия.Комментарий = Комментарий;
		ПараметрыВыполнения.ДополнительныеПараметрыДействий.Вставить(ДействиеЭДО, ДополнительныеПараметрыДействия);
	КонецЕсли;
	
	РезультатДействийЭДО = ВыполнитьДействиеЭДО(ПараметрыВыполнения);
	
	ДокументыЭДО = ОбщегоНазначения.ВыгрузитьКолонку(РезультатДействийЭДО.Итог.ОбработанныеДокументы, "Ключ");
	
	РезультатШаблона.СостоянияДокументовЭДО = СостоянияДокументовЭДОВФорматеСервиса(ДокументыЭДО);
	
	Возврат РезультатШаблона;
	
КонецФункции

// Параметры:
//  ПараметрыВыполнения - См. ЭлектронныеДокументыЭДО.ВыполнитьДействияПоИнтеграциямЭДО.ПараметрыВыполненияДействий
// 
// Возвращаемое значение:
//  См. ЭлектронныеДокументыЭДОСлужебный.НовыйРезультатДействийПоЭДО
Функция ВыполнитьДействиеЭДО(ПараметрыВыполнения)
	РезультатПоИнтеграциям = ЭлектронныеДокументыЭДО.ВыполнитьДействияПоИнтеграциямЭДО(ПараметрыВыполнения);
	РезультатДействийЭДО = РезультатПоИнтеграциям[ЭлектронныеДокументыЭДОКлиентСервер.ИдентификаторМенеджераДействийЭДО()]; // См. ЭлектронныеДокументыЭДОСлужебный.НовыйРезультатДействийПоЭДО
	Возврат РезультатДействийЭДО;
КонецФункции

#КонецОбласти

#Область ОтражениеВУчете

// Параметры:
//  ИдентификаторыДокументов - Массив из Строка
// 
// Возвращаемое значение:
//  Соответствие из КлючИЗначение:
//  * Ключ - Строка - идентификатор документа.
//  * Значение - см. ФорматыЭДО.НовыеПараметрыПолученияДанныхДокумента
Функция ПараметрыПолученияДанныхДокументовЭДО(ИдентификаторыДокументов)
	
	Результат = Новый Соответствие; // см. ПараметрыПолученияДанныхДокументовЭДО
	
	ПрисоединенныеФайлыДокументов = ПрисоединенныеФайлыОсновныхТитуловДокументов(ИдентификаторыДокументов);
	
	ПрисоединенныеФайлы = ПрисоединенныеФайлыДокументов.ВыгрузитьКолонку("Ссылка");
	
	ДвоичныеДанныеФайлов = РаботаСФайлами.ДвоичныеДанныеФайлов(ПрисоединенныеФайлы);
	
	Для Каждого ПрисоединенныйФайлДокумента Из ПрисоединенныеФайлыДокументов Цикл
		
		ПараметрыПолученияДанныхДокумента = Результат[ПрисоединенныйФайлДокумента.ИдентификаторДокумента];
		Если ПараметрыПолученияДанныхДокумента = Неопределено Тогда
			ПараметрыПолученияДанныхДокумента = ФорматыЭДО.НовыеПараметрыПолученияДанныхДокумента();
			Результат.Вставить(ПрисоединенныйФайлДокумента.ИдентификаторДокумента, ПараметрыПолученияДанныхДокумента);
		КонецЕсли;
		
		ДвоичныеДанныеФайла = ДвоичныеДанныеФайлов[ПрисоединенныйФайлДокумента.Ссылка];
		
		ОписаниеФайла = РаботаСФайламиБЭД.НовоеОписаниеФайла();
		ОписаниеФайла.ДвоичныеДанные = ДвоичныеДанныеФайла;
		ОписаниеФайла.ИмяФайла = ПрисоединенныйФайлДокумента.ПолноеИмяФайла;
		
		Если ПрисоединенныйФайлДокумента.ЭтоОсновнойФайл Тогда
			ПараметрыПолученияДанныхДокумента.ОсновнойФайл = ОписаниеФайла;
		Иначе
			ПараметрыПолученияДанныхДокумента.ДополнительныйФайл = ОписаниеФайла;
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

// Возвращаемое значение:
//  Структура:
//  * ИдентификаторДокумента - Строка
//  * СведенияНоменклатуры - Массив из см. НовыеСведенияНоменклатурнойПозиции
Функция НовыеСведенияНоменклатурыДокумента()
	Сведения = Новый Структура;
	Сведения.Вставить("ИдентификаторДокумента", "");
	Сведения.Вставить("СведенияНоменклатуры", Новый Массив);
	Возврат Сведения;
