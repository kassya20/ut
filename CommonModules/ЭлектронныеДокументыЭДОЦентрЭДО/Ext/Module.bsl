// @strict-types

#Область СлужебныйПрограммныйИнтерфейс

#Область ДействияСДокументамиЭДО

// Возвращает сведения по созданным документам ЭДО.
//
// Параметры:
//  ДанныеДокументовЭДО - Массив из Структура:
//  * Идентификатор - Строка
//  * Отправитель - Структура:
//    ** ИНН - Строка
//    ** КПП - Строка
//  * Получатель - Структура:
//    ** ИНН - Строка
//    ** КПП - Строка
//  * ВидДокумента - Структура:
//    ** Наименование - Строка
//    ** ТипДокумента - Строка
//  * ИдентификаторОтправителя - Строка
//  * ИдентификаторПолучателя - Строка
//  * ТребуетсяОтветнаяПодпись - Булево
//  * ТребуетсяИзвещениеОПолучении - Булево
//  * Формат - Строка - формат, в который конвертируются учетные данные.
//  * УчетныеДанные - Неопределено,Структура:
//    ** Данные - См. ДеревоУчетныхДанныхИзСтруктуры.СтруктураДанных
//    ** Формат - Строка - формат учетных данных.
// 
// Возвращаемое значение:
//  Структура:
//  * Ошибки - Неопределено
//           - Массив из Строка
//  * ОписанияДокументовЭДО - См. ОписанияИсходящихДокументов
Функция СформироватьДокументыЭДО(ДанныеДокументовЭДО) Экспорт
	
	Результат = Новый Структура;
	Результат.Вставить("Ошибки", Неопределено);
	Результат.Вставить("ОписанияДокументовЭДО", Новый Массив);
	
	КонтекстДиагностики = ОбработкаНеисправностейБЭД.НовыйКонтекстДиагностики();
	
	ВидОперации = НСтр("ru = 'Формирование документов ЭДО.'");
	
	НастройкиОбмена = НастройкиОбменаМеждуУчастникамиЭДО(ДанныеДокументовЭДО);
	
	КлючиНастроекПоРеквизитам = КлючиНастроекПоРеквизитам(ДанныеДокументовЭДО);
	
	ФорматыЭлектронныхДокументов = ФорматыЭДО.ФорматыЭлектронныхДокументов();
	
	НовыеДокументыЭДО = Новый Массив; // Массив из ДокументСсылка.ЭлектронныйДокументИсходящийЭДО
	
	Для Каждого ДанныеДокументаЭДО Из ДанныеДокументовЭДО Цикл
		
		ЕстьОшибкаИдентификатора = ЕстьОшибкаНекорректныйИдентификаторДокумента(
			ДанныеДокументаЭДО.Идентификатор, КонтекстДиагностики, ВидОперации);
		Если ЕстьОшибкаИдентификатора Тогда
			Продолжить;
		КонецЕсли;
		
		НастройкаОбмена = НастройкаОбменаПоДаннымДокументаЭДО(НастройкиОбмена, ДанныеДокументаЭДО);
		
		ЕстьОшибкаНастройкиОбмена = ЕстьОшибкаНастройкиОбменаПоДаннымДокументаЭДО(
			НастройкаОбмена, ДанныеДокументаЭДО, КонтекстДиагностики, ВидОперации);
		Если ЕстьОшибкаНастройкиОбмена Тогда
			Продолжить;
		КонецЕсли;
		
		КлючНастройки = КлючиНастроекПоРеквизитам[ДанныеДокументаЭДО.Идентификатор];
		ЕстьОшибкаКлючаНастройки = ЕстьОшибкаКлючаНастройкиОтправкиПоДаннымДокументаЭДО(
			КлючНастройки, ДанныеДокументаЭДО, КонтекстДиагностики, ВидОперации);
		Если ЕстьОшибкаКлючаНастройки Тогда
			Продолжить;
		КонецЕсли;
		
		ЕстьОшибкаНастройкиРегламента = ЕстьОшибкаНастройкиРегламентаПоДаннымДокументаЭДО(
			ДанныеДокументаЭДО, КонтекстДиагностики, ВидОперации);
		Если ЕстьОшибкаНастройкиРегламента Тогда
			Продолжить;
		КонецЕсли;
		
		ЕстьОшибкаФормата = ЕстьОшибкаФорматаПоДаннымДокументаЭДО(ФорматыЭлектронныхДокументов,
			ДанныеДокументаЭДО, КлючНастройки.ВидДокумента, КонтекстДиагностики, ВидОперации);
		Если ЕстьОшибкаФормата Тогда
			Продолжить;
		КонецЕсли;
		
		НастройкиДокумента = ЭлектронныеДокументыЭДО.НовыеНастройкиОтправкиДокумента();
		НастройкиДокумента.Организация = КлючНастройки.Отправитель;
		НастройкиДокумента.Контрагент = КлючНастройки.Получатель;
		НастройкиДокумента.ДоговорКонтрагента = КлючНастройки.Договор;
		НастройкиДокумента.ИдентификаторОрганизации = ДанныеДокументаЭДО.ИдентификаторОтправителя;
		НастройкиДокумента.ИдентификаторКонтрагента = ДанныеДокументаЭДО.ИдентификаторПолучателя;
		НастройкиДокумента.СпособОбмена = НастройкаОбмена.СпособОбмена;
		НастройкиДокумента.МаршрутПодписания = Справочники.МаршрутыПодписания.ОднойДоступнойПодписью;
		НастройкиДокумента.ТребуетсяИзвещение = ДанныеДокументаЭДО.ТребуетсяИзвещениеОПолучении;
		НастройкиДокумента.ТребуетсяПодтверждение = ДанныеДокументаЭДО.ТребуетсяОтветнаяПодпись;
		НастройкиДокумента.ИдентификаторДокумента = ДанныеДокументаЭДО.Идентификатор;
		НастройкиДокумента.Формат = ДанныеДокументаЭДО.Формат;
		
		ФайлыДокументаЭДО = СформироватьФайлыДокументаПоУчетнымДанным(
			ДанныеДокументаЭДО.УчетныеДанные, НастройкиДокумента);
		
		Если ЗначениеЗаполнено(ФайлыДокументаЭДО.Ошибки) Тогда
			Продолжить;
		КонецЕсли;
		
		Содержание = ЭлектронныеДокументыЭДО.СодержаниеСообщения(ФайлыДокументаЭДО.Документ);
		
		Если Не ЗначениеЗаполнено(Содержание) Тогда
			Продолжить;
		КонецЕсли;
	
		ОписаниеСообщения = ЭлектронныеДокументыЭДО.НовоеОписаниеСообщения();
		ОписаниеСообщения.ТипЭлементаРегламента = Перечисления.ТипыЭлементовРегламентаЭДО.ИнформацияОтправителя;
		ОписаниеСообщения.ВидСообщения = КлючНастройки.ВидДокумента;
		ОписаниеСообщения.Направление = Перечисления.НаправленияЭДО.Исходящий;
		ОписаниеСообщения.Данные.Содержание = Содержание;
		ОписаниеСообщения.Данные.Документ = ФайлыДокументаЭДО.Документ;
		ОписаниеСообщения.Данные.ДополнительныйДокумент = ФайлыДокументаЭДО.ДополнительныйДокумент;
		
		ОписаниеСообщений = ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(ОписаниеСообщения);
		
		Попытка
			ДокументОбъект = ЭлектронныеДокументыЭДО.СоздатьДокументПоОписаниюСообщений(
				НастройкиДокумента, ОписаниеСообщений, КонтекстДиагностики);
		Исключение
			ИнформацияОбОшибке = ИнформацияОбОшибке();
			ИмяСобытия = ЦентрЭДО.ПредставлениеПодсистемы();
			Уровень = УровеньЖурналаРегистрации.Ошибка;
			ОбъектМетаданных = ДокументОбъект.Метаданные();
			Данные = ДанныеДокументаЭДО.Идентификатор;
			Комментарий = НСтр("ru = 'Не удалось сформировать электронный документ по причине:'")
				+ Символы.ПС + ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке);
			ЗаписьЖурналаРегистрации(ИмяСобытия, Уровень, ОбъектМетаданных, Данные, Комментарий);
			
			Если ИнформацияОбОшибке.Код = КодИсключенияДокументУжеСуществует() Тогда
				ДокументЭДО = ДокументПоИдентификатору(ДанныеДокументаЭДО.Идентификатор);
				Если ЗначениеЗаполнено(ДокументЭДО) Тогда
					НовыеДокументыЭДО.Добавить(ДокументЭДО);
				КонецЕсли;
			КонецЕсли;
			
			Продолжить;
		КонецПопытки;
		
		Если ЗначениеЗаполнено(ДокументОбъект.Ссылка) Тогда
			НовыеДокументыЭДО.Добавить(ДокументОбъект.Ссылка);
		КонецЕсли;
		
	КонецЦикла;
	
	Результат.ОписанияДокументовЭДО = ОписанияИсходящихДокументов(НовыеДокументыЭДО);
	
	Возврат Результат;
	
КонецФункции

// Возвращает сформированные файлы документа ЭДО.
//
// Параметры:
//  ДанныеДокументовЭДО - Массив из Структура:
//  * Идентификатор     - Строка
//  * Отправитель       - Структура:
//  ** ИНН              - Строка
//  ** КПП              - Строка
//  * Получатель        - Структура:
//  ** ИНН              - Строка
//  ** КПП              - Строка
//  * ВидДокумента      - Структура:
//  ** Наименование     - Строка
//  ** ТипДокумента     - Строка
//  * ИдентификаторОтправителя - Строка
//  * ИдентификаторПолучателя - Строка
//  * Формат            - Строка - формат, в который конвертируются учетные данные.
//  * УчетныеДанные     - Структура:
//  ** Данные           - См. ДеревоУчетныхДанныхИзСтруктуры.СтруктураДанных
//  ** Формат           - Строка - формат учетных данных.
// 
// Возвращаемое значение:
//  Массив из Структура:
//  * Идентификатор - Строка
//  * Ошибки - Неопределено - при формировании без ошибок.
//           - Массив из Строка
//  * ОсновнойФайл - Неопределено - при наличии ошибок.
//                 - Структура:
//  ** ИмяФайла - Строка
//  ** Данные - Строка - двоичные данные в формате base64.
//  * ДополнительныйФайл - Неопределено - при наличии ошибок или отсутствии соответствующих учетных данных.
//                       - Структура:
//  ** ИмяФайла - Строка
//  ** Данные - Строка - двоичные данные в формате base64.
//
Функция СформироватьФайлыДокументовЭДО(ДанныеДокументовЭДО) Экспорт
	
	НаборРезультатов = Новый Массив; // См. СформироватьФайлыДокументовЭДО
	
	КонтекстДиагностики = ОбработкаНеисправностейБЭД.НовыйКонтекстДиагностики();
	
	ВидОперации = НСтр("ru = 'Формирование файлов документов ЭДО.'");
	
	НастройкиОбмена = НастройкиОбменаМеждуУчастникамиЭДО(ДанныеДокументовЭДО);
	
	КлючиНастроекПоРеквизитам = КлючиНастроекПоРеквизитам(ДанныеДокументовЭДО);
	
	ВидыДокументов = ВыгрузитьУникальныеЗначенияСвойстваКлючейНастроек(КлючиНастроекПоРеквизитам, "ВидДокумента");
	
	ОборФорматов = ФорматыЭДО.НовыйОтборФорматовЭлектронныхДокументов();
	ОборФорматов.ВидыДокументов = ВидыДокументов;
	ФорматыЭлектронныхДокументов = ФорматыЭДО.ФорматыЭлектронныхДокументов();

	Для Каждого ДанныеДокументаЭДО Из ДанныеДокументовЭДО Цикл
		
		РезультатФормирования = Новый Структура;
		РезультатФормирования.Вставить("Идентификатор", ДанныеДокументаЭДО.Идентификатор);
		РезультатФормирования.Вставить("Ошибки", Неопределено);
		РезультатФормирования.Вставить("ОсновнойФайл", Неопределено);
		РезультатФормирования.Вставить("ДополнительныйФайл", Неопределено);
		
		НаборРезультатов.Добавить(РезультатФормирования);
		
		ЕстьОшибкаИдентификатора = ЕстьОшибкаНекорректныйИдентификаторДокумента(
			ДанныеДокументаЭДО.Идентификатор, КонтекстДиагностики, ВидОперации);
		Если ЕстьОшибкаИдентификатора Тогда
			РезультатФормирования.Ошибки = 
				ОбработкаНеисправностейБЭДКлиентСервер.ПодробныеПредставленияОшибок(КонтекстДиагностики);
			Продолжить;
		КонецЕсли;
		
		НастройкаОбмена = НастройкаОбменаПоДаннымДокументаЭДО(НастройкиОбмена, ДанныеДокументаЭДО);
		
		ЕстьОшибкаНастройкиОбмена = ЕстьОшибкаНастройкиОбменаПоДаннымДокументаЭДО(
			НастройкаОбмена, ДанныеДокументаЭДО, КонтекстДиагностики, ВидОперации);
		Если ЕстьОшибкаНастройкиОбмена Тогда
			РезультатФормирования.Ошибки = 
				ОбработкаНеисправностейБЭДКлиентСервер.ПодробныеПредставленияОшибок(КонтекстДиагностики);
			Продолжить;
		КонецЕсли;
		
		КлючНастройки = КлючиНастроекПоРеквизитам[ДанныеДокументаЭДО.Идентификатор];
		ЕстьОшибкаКлючаНастройки = ЕстьОшибкаКлючаНастройкиОтправкиПоДаннымДокументаЭДО(
			КлючНастройки, ДанныеДокументаЭДО, КонтекстДиагностики, ВидОперации);
		Если ЕстьОшибкаКлючаНастройки Тогда
			РезультатФормирования.Ошибки = 
				ОбработкаНеисправностейБЭДКлиентСервер.ПодробныеПредставленияОшибок(КонтекстДиагностики);
			Продолжить;
		КонецЕсли;
		
		ЕстьОшибкаФормата = ЕстьОшибкаФорматаПоДаннымДокументаЭДО(ФорматыЭлектронныхДокументов,
			ДанныеДокументаЭДО, КлючНастройки.ВидДокумента, КонтекстДиагностики, ВидОперации);
		Если ЕстьОшибкаФормата Тогда
			РезультатФормирования.Ошибки = 
				ОбработкаНеисправностейБЭДКлиентСервер.ПодробныеПредставленияОшибок(КонтекстДиагностики);
			Продолжить;
		КонецЕсли;

		КлючНастройки = КлючиНастроекПоРеквизитам[ДанныеДокументаЭДО.Идентификатор];
		
		НастройкиДокумента = ЭлектронныеДокументыЭДО.НовыеНастройкиОтправкиДокумента();
		НастройкиДокумента.Организация = КлючНастройки.Отправитель;
		НастройкиДокумента.Контрагент = КлючНастройки.Получатель;
		НастройкиДокумента.ДоговорКонтрагента = КлючНастройки.Договор;
		НастройкиДокумента.ИдентификаторОрганизации = ДанныеДокументаЭДО.ИдентификаторОтправителя;
		НастройкиДокумента.ИдентификаторКонтрагента = ДанныеДокументаЭДО.ИдентификаторПолучателя;
		НастройкиДокумента.СпособОбмена = НастройкаОбмена.СпособОбмена;
		НастройкиДокумента.МаршрутПодписания = Справочники.МаршрутыПодписания.ОднойДоступнойПодписью;
		НастройкиДокумента.ИдентификаторДокумента = ДанныеДокументаЭДО.Идентификатор;
		Если ЗначениеЗаполнено(ДанныеДокументаЭДО.Формат) Тогда
			НастройкиДокумента.Формат = ДанныеДокументаЭДО.Формат;
		КонецЕсли;
		
		ФайлыДокументаЭДО = СформироватьФайлыДокументаПоУчетнымДанным(
			ДанныеДокументаЭДО.УчетныеДанные, НастройкиДокумента);
		
		Если ЗначениеЗаполнено(ФайлыДокументаЭДО.Ошибки) Тогда
			РезультатФормирования.Ошибки = ФайлыДокументаЭДО.Ошибки;
		КонецЕсли;
		
		Если ФайлыДокументаЭДО.Документ.ДвоичныеДанные <> Неопределено Тогда
			ОсновнойФайл = НовыйФайлДокументаЭДОВФорматеСервиса();
			ОсновнойФайл.ИмяФайла = ФайлыДокументаЭДО.Документ.ИмяФайла;
			ОсновнойФайл.Данные = Base64Строка(ФайлыДокументаЭДО.Документ.ДвоичныеДанные);
			РезультатФормирования.ОсновнойФайл = ОсновнойФайл;
		КонецЕсли;
		
		Если ФайлыДокументаЭДО.ДополнительныйДокумент.ДвоичныеДанные <> Неопределено Тогда
			ДополнительныйФайл = НовыйФайлДокументаЭДОВФорматеСервиса();
			ДополнительныйФайл.ИмяФайла = ФайлыДокументаЭДО.ДополнительныйДокумент.ИмяФайла;
			ДополнительныйФайл.Данные = Base64Строка(ФайлыДокументаЭДО.ДополнительныйДокумент.ДвоичныеДанные);
			РезультатФормирования.ДополнительныйФайл = ДополнительныйФайл;
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат НаборРезультатов;
	
КонецФункции

// Возвращает сведения по созданным документам ЭДО на основании файлов.
//
// Параметры:
//  ДанныеДокументовЭДО - Массив из Структура:
//  * Идентификатор     - Строка
//  * Отправитель       - Структура:
//  ** ИНН              - Строка
//  ** КПП              - Строка
//  * Получатель        - Структура:
//  ** ИНН              - Строка
//  ** КПП              - Строка
//  * ВидДокумента      - Структура:
//  ** Наименование     - Строка
//  ** ТипДокумента     - Строка
//  * ИдентификаторОтправителя - Строка
//  * ИдентификаторПолучателя - Строка
//  * ТребуетсяОтветнаяПодпись - Булево
//  * ТребуетсяИзвещениеОПолучении - Булево
//  * Номер                   - Строка
//  * Дата                    - См. ОбщегоНазначенияБЭД.ДатаВФорматеISO
//  * Сумма                   - Число
//  * СопроводительнаяЗаписка - Строка
//  * ФайлыТитулов      - Массив Из Структура:
//  ** Основной - Структура:
//  *** ИмяФайла - Строка
//  *** Данные - Строка - двоичные данные в формате base64.
//  ** Дополнительный - Структура:
//  *** ИмяФайла - Строка
//  *** Данные - Строка - двоичные данные в формате base64.
// 
// Возвращаемое значение:
//  Структура:
//  * Ошибки - Неопределено
//           - Массив из Строка
//  * ОписанияДокументовЭДО - См. ОписанияИсходящихДокументов
//
Функция СформироватьДокументыЭДОПоФайлам(ДанныеДокументовЭДО) Экспорт
	
	Результат = Новый Структура;
	Результат.Вставить("Ошибки", Неопределено);
	Результат.Вставить("ОписанияДокументовЭДО", Новый Массив);
	
	КлючиНастроекПоРеквизитам = КлючиНастроекПоРеквизитам(ДанныеДокументовЭДО);
	
	НовыеДокументыЭДО = Новый Массив; // Массив из ДокументСсылка.ЭлектронныйДокументИсходящийЭДО
	Ошибки = Новый Массив; // Массив из Строка
	
	Для Каждого ДанныеДокументаЭДО Из ДанныеДокументовЭДО Цикл
		
		КлючНастройки = КлючиНастроекПоРеквизитам[ДанныеДокументаЭДО.Идентификатор];
		Если Не ЗначениеЗаполнено(КлючНастройки) Тогда
			Продолжить;
		КонецЕсли;
		
		ПараметрыСоздания = ИнтерфейсДокументовЭДОКлиентСервер.НовыеПараметрыСозданияДокументаПоФайлу();
		ПараметрыСоздания.ИдентификаторДокумента = ДанныеДокументаЭДО.Идентификатор;
		ПараметрыСоздания.ВидДокумента = КлючНастройки.ВидДокумента;
		ПараметрыСоздания.Организация = КлючНастройки.Отправитель;
		ПараметрыСоздания.Контрагент = КлючНастройки.Получатель;
		ПараметрыСоздания.Договор = КлючНастройки.Договор;
		ПараметрыСоздания.НомерДокумента = ДанныеДокументаЭДО.Номер;
		ПараметрыСоздания.ДатаДокумента = ОбщегоНазначенияБЭД.ДатаИзФорматаISO(ДанныеДокументаЭДО.Дата);
		ПараметрыСоздания.СуммаДокумента = ДанныеДокументаЭДО.Сумма;
		ПараметрыСоздания.СопроводительнаяЗаписка = ДанныеДокументаЭДО.СопроводительнаяЗаписка;
		
		ПараметрыОбменаЭДО = ЭлектронныеДокументыЭДОКлиентСервер.НовыеПараметрыОбменаЭДОДляСозданияДокументаПоФайлу();
		Если ДанныеДокументаЭДО.Свойство("ИдентификаторОтправителя", ПараметрыОбменаЭДО.ИдентификаторОтправителя)
			И ДанныеДокументаЭДО.Свойство("ИдентификаторПолучателя", ПараметрыОбменаЭДО.ИдентификаторПолучателя)
			И ДанныеДокументаЭДО.Свойство("ТребуетсяИзвещениеОПолучении", ПараметрыОбменаЭДО.ТребуетсяИзвещениеОПолучении)
			И ДанныеДокументаЭДО.Свойство("ТребуетсяОтветнаяПодпись", ПараметрыОбменаЭДО.ТребуетсяОтветнаяПодпись) Тогда
			ПараметрыСоздания.ПараметрыОбмена = ПараметрыОбменаЭДО;
		КонецЕсли;
		
		ОписаниеФайла = РаботаСФайламиБЭД.НовоеОписаниеФайла();
		Для Каждого ФайлТитула Из ДанныеДокументаЭДО.ФайлыТитулов Цикл
			Если Не ЗначениеЗаполнено(ФайлТитула.Основной) Тогда
				Продолжить;
			КонецЕсли;
			
			ОписаниеФайла.ИмяФайла = ФайлТитула.Основной.ИмяФайла;
			ОписаниеФайла.ДвоичныеДанные = Base64Значение(ФайлТитула.Основной.Данные);
		КонецЦикла;
		
		РезультатСоздания = ЭлектронныеДокументыЭДО.СоздатьДокументПоФайлу(ПараметрыСоздания, ОписаниеФайла);
		Если РезультатСоздания.Успех Тогда
			НовыеДокументыЭДО.Добавить(РезультатСоздания.ЭлектронныйДокумент);
		ИначеЕсли ЗначениеЗаполнено(РезультатСоздания.Ошибки) Тогда
			Для Каждого Ошибка Из РезультатСоздания.Ошибки Цикл
				Если Не ЗначениеЗаполнено(Ошибка.ОшибкиСозданияПоФайлу) Тогда
					Продолжить;
				КонецЕсли;
				Для Каждого ОшибкаСозданияПоФайлу Из Ошибка.ОшибкиСозданияПоФайлу Цикл
					Ошибки.Добавить(ОшибкаСозданияПоФайлу.ТекстОшибки);
				КонецЦикла;
			КонецЦикла;
		КонецЕсли;
		
	КонецЦикла;
	
	Если ЗначениеЗаполнено(Ошибки) Тогда
		Результат.Ошибки = Ошибки;
	КонецЕсли;
	
	Результат.ОписанияДокументовЭДО = ОписанияИсходящихДокументов(НовыеДокументыЭДО);
	
	Возврат Результат;
	
КонецФункции

// Возвращает сведения по переформированным документам ЭДО на основании файлов.
//
// Параметры:
//  ДанныеДокументовЭДО - Массив из Структура:
//  * Идентификатор     - Строка
//  * Отправитель       - Структура:
//  ** ИНН              - Строка
//  ** КПП              - Строка
//  * Получатель        - Структура:
//  ** ИНН              - Строка
//  ** КПП              - Строка
//  * ВидДокумента      - Структура:
//  ** Наименование     - Строка
//  ** ТипДокумента     - Строка
//  * ИдентификаторОтправителя - Строка
//  * ИдентификаторПолучателя - Строка
//  * ТребуетсяОтветнаяПодпись - Булево
//  * ТребуетсяИзвещениеОПолучении - Булево
//  * Номер                   - Строка
//  * Дата                    - См. ОбщегоНазначенияБЭД.ДатаВФорматеISO
//  * Сумма                   - Число
//  * СопроводительнаяЗаписка - Строка
//  * ФайлыТитулов      - Массив Из Структура:
//  ** Основной - Структура:
//  *** ИмяФайла - Строка
//  *** Данные - Строка - двоичные данные в формате base64.
//  ** Дополнительный - Структура:
//  *** ИмяФайла - Строка
//  *** Данные - Строка - двоичные данные в формате base64.
// 
// Возвращаемое значение:
//  Структура:
//  * Ошибки - Массив из Строка
//  * ОписанияДокументовЭДО - См. ОписанияИсходящихДокументов
//
Функция ПереформироватьДокументыЭДОПоФайлам(ДанныеДокументовЭДО) Экспорт
	
	Ошибки = Новый Массив; // Массив из Строка
	Результат = Новый Структура;
	Результат.Вставить("Ошибки", Ошибки);
	Результат.Вставить("ОписанияДокументовЭДО", Новый Массив);
	
	ПереформированныеДокументы = Новый Массив; // Массив из ДокументСсылка.ЭлектронныйДокументИсходящийЭДО
	
	ИдентификаторыДокументов = Новый Массив; // Массив из Строка
	Для Каждого ДанныеДокументаЭДО Из ДанныеДокументовЭДО Цикл
		ИдентификаторыДокументов.Добавить(ДанныеДокументаЭДО.Идентификатор);
	КонецЦикла;
	ДокументыПоИдентификаторам = ДокументыПоИдентификаторам(ИдентификаторыДокументов);
	
	КлючиНастроекПоРеквизитам = КлючиНастроекПоРеквизитам(ДанныеДокументовЭДО);
	
	Для Каждого ДанныеДокументаЭДО Из ДанныеДокументовЭДО Цикл
		
		ЭлектронныйДокумент = ДокументыПоИдентификаторам[ДанныеДокументаЭДО.Идентификатор];
	
		Если Не ЗначениеЗаполнено(ЭлектронныйДокумент) Тогда
			ТекстОшибки = ТекстОшибкиНеУдалосьНайтиЭлектронныйДокументПоИдентификатору(
				ДанныеДокументаЭДО.Идентификатор);
			Результат.Ошибки.Добавить(ТекстОшибки);
			Продолжить;
		КонецЕсли;
		
		КлючНастройки = КлючиНастроекПоРеквизитам[ДанныеДокументаЭДО.Идентификатор];
		Если Не ЗначениеЗаполнено(КлючНастройки) Тогда
			Продолжить;
		КонецЕсли;
		
		НастройкиДокумента = НастройкиЭДО.НастройкиОтправки(КлючНастройки);
		Если Не ЗначениеЗаполнено(НастройкиДокумента) Тогда
			Продолжить;
		КонецЕсли;

		ПараметрыПереформирования = ЭлектронныеДокументыЭДО.НовыеПараметрыПереформированияДокументаПоФайлу();
		ПараметрыПереформирования.Организация = КлючНастройки.Отправитель;
		ПараметрыПереформирования.Контрагент = КлючНастройки.Получатель;
		ПараметрыПереформирования.Договор = КлючНастройки.Договор;
		ПараметрыПереформирования.ВидДокумента = КлючНастройки.ВидДокумента;
		ПараметрыПереформирования.НомерДокумента = ДанныеДокументаЭДО.Номер;
		ПараметрыПереформирования.ДатаДокумента = ОбщегоНазначенияБЭД.ДатаИзФорматаISO(ДанныеДокументаЭДО.Дата);
		ПараметрыПереформирования.СуммаДокумента = ДанныеДокументаЭДО.Сумма;
		ПараметрыПереформирования.СопроводительнаяЗаписка = ДанныеДокументаЭДО.СопроводительнаяЗаписка;
		
		ОписаниеФайла = Неопределено;
		Для Каждого ФайлТитула Из ДанныеДокументаЭДО.ФайлыТитулов Цикл
			Если Не ЗначениеЗаполнено(ФайлТитула.Основной) Тогда
				Продолжить;
			КонецЕсли;
			
			ОписаниеФайла = РаботаСФайламиБЭД.НовоеОписаниеФайла();
			ОписаниеФайла.ИмяФайла = ФайлТитула.Основной.ИмяФайла;
			ОписаниеФайла.ДвоичныеДанные = Base64Значение(ФайлТитула.Основной.Данные);
		КонецЦикла;
		
		РезультатПереформирования = ЭлектронныеДокументыЭДО.ПереформироватьДокументПоФайлу(ЭлектронныйДокумент,
			ПараметрыПереформирования, ОписаниеФайла);
			
		Если РезультатПереформирования.Успех Тогда
			ПереформированныеДокументы.Добавить(ЭлектронныйДокумент);
		КонецЕсли;
		
	КонецЦикла;
	
	Результат.ОписанияДокументовЭДО = ОписанияИсходящихДокументов(ПереформированныеДокументы);
	
	Возврат Результат;
	
КонецФункции

// Возвращает данные для подписания документов ЭДО.
// 
// Параметры:
//  ИдентификаторыДокументовЭДО - Массив из Строка
//  ОтпечаткиСертификатов - Массив из Строка
// 
// Возвращаемое значение:
//  См. ПодготовитьДанныеДляПодписания
Функция ПодготовитьДанныеДляПодписанияДокументовЭДО(ИдентификаторыДокументовЭДО, ОтпечаткиСертификатов) Экспорт
	
	Возврат ПодготовитьДанныеДляПодписания(ИдентификаторыДокументовЭДО, ОтпечаткиСертификатов);
	
КонецФункции

// Возвращает данные файлов электронных документов с заполненными подписантами и доверенностями.
//
// Параметры:
//  ДанныеДляЗаполненияПоСертификатам - Массив из Структура:
//  * ИдентификаторыДанных - Массив из Строка
//  * ОтпечатокСертификата - Строка
//  * НомерДоверенности - Строка
// 
// Возвращаемое значение:
//  Структура:
//  * Ошибки - Неопределено
//           - Массив из Строка
//  * НаборДанных - Массив из Структура:
//  ** ИдентификаторДанных - Строка - идентификатор данных электронного документа в сервисе.
//  ** Данные - Строка - двоичные данные в формате base64.
//
Функция ЗаполнитьДанныеДляПодписанияПоВыбраннымСертификатам(ДанныеДляЗаполненияПоСертификатам) Экспорт
	
	ИдентификаторыДанных = Новый Массив;
	ОтпечаткиСертификатов = Новый Массив; // Массив из Строка
	НомераДоверенностей = Новый Массив; // Массив из Строка
	
	Для Каждого ОписаниеНабораДанных Из ДанныеДляЗаполненияПоСертификатам Цикл
		ОбщегоНазначенияКлиентСервер.ДополнитьМассив(ИдентификаторыДанных, ОписаниеНабораДанных.ИдентификаторыДанных);
		ОтпечаткиСертификатов.Добавить(ОписаниеНабораДанных.ОтпечатокСертификата);
		НомераДоверенностей.Добавить(ОписаниеНабораДанных.НомерДоверенности);
	КонецЦикла;
	
	ФайлыПоИдентификаторам = ФайлыПоИдентификаторам(ИдентификаторыДанных);
	ФайлыДокументовЭДО = ОбщегоНазначения.ВыгрузитьКолонку(ФайлыПоИдентификаторам, "Значение"); // Массив из СправочникСсылка.СообщениеЭДОПрисоединенныеФайлы
	СостоянияДокументовЭДОПоФайлам = СостоянияДокументовЭДОПоФайлам(ФайлыДокументовЭДО);
	
	СертификатыПоОтпечаткам = КриптографияБЭД.СертификатыПоОтпечаткам(ОтпечаткиСертификатов);
	ДоверенностиПоНомерам = МашиночитаемыеДоверенности.ПолучитьДоверенностиИзЖурналаПоНомерам(НомераДоверенностей);
	
	РезультатыПоФайлам = Новый Соответствие; // См. ЗаполнитьПодписантовИДоверенностиПоСертификату
	
	КонтекстДиагностики = ОбработкаНеисправностейБЭД.НовыйКонтекстДиагностики();
	
	Для Каждого ОписаниеНабораДанных Из ДанныеДляЗаполненияПоСертификатам Цикл
		
		Сертификат = СертификатыПоОтпечаткам[ОписаниеНабораДанных.ОтпечатокСертификата];
		Доверенность = ДоверенностиПоНомерам[ОписаниеНабораДанных.НомерДоверенности];
		
		ФайлыДокументовЭДОПоСертификату = ФайлыДокументовЭДОДляЗаполненияПоСертификату(
			ОписаниеНабораДанных.ИдентификаторыДанных, ФайлыПоИдентификаторам, СостоянияДокументовЭДОПоФайлам,
			Сертификат, КонтекстДиагностики);
		
		Если Не ЗначениеЗаполнено(ФайлыДокументовЭДОПоСертификату) Тогда
			Продолжить;
		КонецЕсли;
		
		РезультатыПоФайламНабора = ЗаполнитьПодписантовИДоверенностиПоСертификату(
			ФайлыДокументовЭДОПоСертификату, Сертификат, Доверенность, КонтекстДиагностики);
		
		ОбщегоНазначенияКлиентСервер.ДополнитьСоответствие(РезультатыПоФайлам, РезультатыПоФайламНабора);
		
	КонецЦикла;
	
	НаборДанныхВФорматеСервиса = Новый Массив; // Массив из Структура
	
	Для Каждого РезультатПоФайлу Из РезультатыПоФайлам Цикл
		
		Если РезультатПоФайлу.Значение.Отказ Тогда
			Продолжить;
		КонецЕсли;
		
		ПрисоединенныйФайл = РезультатПоФайлу.Ключ;
		ДанныеДляПодписания = РезультатПоФайлу.Значение.ДанныеДляПодписания;
		
		АдресДанныхДляОбновления = ПоместитьВоВременноеХранилище(ДанныеДляПодписания);
		ИнформацияОФайле = Новый Структура;
		ИнформацияОФайле.Вставить("АдресФайлаВоВременномХранилище", АдресДанныхДляОбновления);
		ИнформацияОФайле.Вставить("АдресВременногоХранилищаТекста", "");
		РаботаСФайлами.ОбновитьФайл(ПрисоединенныйФайл, ИнформацияОФайле);
		
		ЗаполненныеДанные = Новый Структура;
		ЗаполненныеДанные.Вставить("ИдентификаторФайла", ИдентификаторСсылки(ПрисоединенныйФайл));
		ЗаполненныеДанные.Вставить("Данные", Base64Строка(ДанныеДляПодписания));
		НаборДанныхВФорматеСервиса.Добавить(ЗаполненныеДанные);
		
	КонецЦикла;
	
	Результат = Новый Структура;
	Результат.Вставить("Ошибки", Неопределено);
	Результат.Вставить("НаборДанных", НаборДанныхВФорматеСервиса);
	
	Возврат Результат;
	
КонецФункции

// Возвращает результат добавления подписей к файлам электронных документов.
// 
// Параметры:
//  ПодписиФайлов - Массив из Структура:
//  * ИдентификаторДанных - Строка - идентификатор файла электронного документа.
//  * Подпись - Строка - данные подписи в формате base64.
//  * НомерДоверенности - Строка
// 
// Возвращаемое значение:
//  Структура:
//  * Ошибки - Неопределено
//           - Массив из Строка
//  * СостоянияДокументовЭДО - Массив из См. НовоеСостояниеДокументаЭДОВФорматеСервиса
//  
Функция ДобавитьПодписиФайловДокументовЭДО(ПодписиФайлов) Экспорт
	
	Результат = Новый Структура;
	Результат.Вставить("Ошибки", Неопределено);
