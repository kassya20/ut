#Область ПрограммныйИнтерфейс

// Добавляет элемент условного оформления. Устанавливает значение параметра и отбор оформления
// Параметры:
//  Объект - ФормаКлиентскогоПриложения, ДинамическийСписок - В который необходимо добавить условное оформление
//  ИменаЭлементовОформления - Строка, Массив из Строка - Имена оформляемых элементов формы. 
//			Например, "Товары", "Номенклатура, Характеристика", Имена = Новый Массив; Имена.Добавить("Номенклатура"); Имена.Добавить("Характеристика");.
//  ИмяПараметраОформления - Строка, ПараметрКомпоновкиДанных - Указывает что будет изменено в оформлении поля. Например, "ЦветФона" / "Текст" / 
//  ЗначениеПараметраОформления - Произвольный - Значение оформления.
//  		Например, Новый Цвет(222, 255, 222).
//  ПутьКЛевомуЗначениюОтбора - Строка, Неопределено - Путь к полю по которому выполняется отбор условного оформления. 
//			Например, "Товары.Номенклатура" / "Контрагент". Если не передавать, то отбор не будет установлен.
//			
//  ПравоеЗначениеОтбора - Произвольный - С которым сравнивать правое значение отбора.
//  ВидСравненияОтбора - ВидСравненияКомпоновкиДанных - По умолчанию "ВидСравненияКомпоновкиДанных.Равно".
// 
// Возвращаемое значение:
//  ЭлементУсловногоОформленияКомпоновкиДанных
//
Функция НовыйЭлементОформления(Объект, ИменаЭлементовОформления,
	ИмяПараметраОформления, ЗначениеПараметраОформления,
	ПутьКЛевомуЗначениюОтбора, ПравоеЗначениеОтбора = Неопределено, ВидСравненияОтбора = Неопределено) Экспорт
	
	ЭлементУсловногоОформления = НовыйПростойЭлементОформления(Объект, ИменаЭлементовОформления);
	ЭлементУсловногоОформления.Оформление.УстановитьЗначениеПараметра(ИмяПараметраОформления, ЗначениеПараметраОформления);
	КомпоновкаДанныхКлиентСервер.ДобавитьОтбор(ЭлементУсловногоОформления.Отбор,
		ПутьКЛевомуЗначениюОтбора,
		ПравоеЗначениеОтбора,
		ВидСравненияОтбора);
		
	Возврат ЭлементУсловногоОформления;
КонецФункции

// Добавляет элемент условного оформления. Устанавливает значение параметра оформления
// Параметры:
//  Объект - ФормаКлиентскогоПриложения, ДинамическийСписок - В который необходимо добавить условное оформление
//  ИменаЭлементовОформления - Строка, Массив из Строка - Имена оформляемых элементов формы. 
//			Например, "Товары", "Номенклатура, Характеристика", Имена = Новый Массив; Имена.Добавить("Номенклатура"); Имена.Добавить("Характеристика");.
//  ИмяПараметраОформления - Строка, ПараметрКомпоновкиДанных - Указывает что будет изменено в оформлении поля. Например, "ЦветФона" / "Текст" / 
//  ЗначениеПараметраОформления - Произвольный - Значение оформления.
//  		Например, Новый Цвет(222, 255, 222).
// 
// Возвращаемое значение:
//  ЭлементУсловногоОформленияКомпоновкиДанных
//
Функция НовыйПростойЭлементОформленияСПараметромОформления(Объект, ИменаЭлементовОформления,
	ИмяПараметраОформления, ЗначениеПараметраОформления) Экспорт
	
	ЭлементУсловногоОформления = НовыйПростойЭлементОформления(Объект, ИменаЭлементовОформления);
	ЭлементУсловногоОформления.Оформление.УстановитьЗначениеПараметра(ИмяПараметраОформления, ЗначениеПараметраОформления);
	
	Возврат ЭлементУсловногоОформления;
КонецФункции

// Добавляет элемент условного оформления для элемента формы. Устанавливает отбор для оформления
// Параметры:
//  Объект - ФормаКлиентскогоПриложения, ДинамическийСписок - В который необходимо добавить условное оформление
//  ИменаЭлементовОформления - Строка, Массив из Строка - Имена оформляемых элементов формы. 
//			Например, "Товары", "Номенклатура, Характеристика", Имена = Новый Массив; Имена.Добавить("Номенклатура"); Имена.Добавить("Характеристика");.
//  ПутьКЛевомуЗначениюОтбора - Строка, Неопределено - Путь к полю по которому выполняется отбор условного оформления. 
//			Например, "Товары.Номенклатура" / "Контрагент". Если не передавать, то отбор не будет установлен.
//			
//  ПравоеЗначениеОтбора - Произвольный - С которым сравнивать правое значение отбора.
//  ВидСравненияОтбора - ВидСравненияКомпоновкиДанных - По умолчанию "ВидСравненияКомпоновкиДанных.Равно".
// 
// Возвращаемое значение:
//  ЭлементУсловногоОформленияКомпоновкиДанных
//
Функция НовыйПростойЭлементОформленияСОтбором(Объект, ИменаЭлементовОформления,
	ПутьКЛевомуЗначениюОтбора, ПравоеЗначениеОтбора = Неопределено, ВидСравненияОтбора = Неопределено) Экспорт
	
	ЭлементУсловногоОформления = НовыйПростойЭлементОформления(Объект, ИменаЭлементовОформления);
	КомпоновкаДанныхКлиентСервер.ДобавитьОтбор(ЭлементУсловногоОформления.Отбор,
		ПутьКЛевомуЗначениюОтбора,
		ПравоеЗначениеОтбора,
		ВидСравненияОтбора);
	
	Возврат ЭлементУсловногоОформления;
	
КонецФункции

// Добавляет элемент условного оформления для элемента формы
// Параметры:
//  Объект - ФормаКлиентскогоПриложения, ДинамическийСписок - В который необходимо добавить условное оформление
//  ИменаЭлементовОформления - Строка, Массив из Строка - Имена оформляемых элементов формы. 
//			Например, "Товары", "Номенклатура, Характеристика", Имена = Новый Массив; Имена.Добавить("Номенклатура"); Имена.Добавить("Характеристика");.
// 
// Возвращаемое значение:
//  ЭлементУсловногоОформленияКомпоновкиДанных
//
Функция НовыйПростойЭлементОформления(Объект, Знач ИменаЭлементовОформления) Экспорт
	
	Если ТипЗнч(ИменаЭлементовОформления) = Тип("Строка") Тогда
		ИменаЭлементовОформления = ОбщегоНазначенияУТКлиентСервер.СтрокаИменВМассив(ИменаЭлементовОформления);
	КонецЕсли;
	
	ЭлементУсловногоОформления = Объект.УсловноеОформление.Элементы.Добавить();
	Для Каждого ИмяЭлементаОформления Из ИменаЭлементовОформления Цикл
		КомпоновкаДанныхКлиентСервер.ДобавитьОформляемоеПоле(ЭлементУсловногоОформления.Поля, ИмяЭлементаОформления);
	КонецЦикла;
	
	Возврат ЭлементУсловногоОформления;
	
КонецФункции

// Добавляет элемент условного оформления для недоступного поля формы. Устанавливает свойства "ТолькоПросмотр", "ЦветТекста", "Текст"
// Параметры:
//  Объект - ФормаКлиентскогоПриложения, ДинамическийСписок - В который необходимо добавить условное оформление
//  ИменаЭлементовОформления - Строка, Массив из Строка - Имена оформляемых элементов формы. 
//			Например, "Товары", "Номенклатура, Характеристика", Имена = Новый Массив; Имена.Добавить("Номенклатура"); Имена.Добавить("Характеристика");.
//	ЦветТекста - Цвет, Неопределено - Будет установлен для элемента
//	Текст - Строка, Неопределено - Будет установлена для элемента
//  ПутьКЛевомуЗначениюОтбора - Строка, Неопределено - Путь к полю по которому выполняется отбор условного оформления. 
//			Например, "Товары.Номенклатура" / "Контрагент". Если не передавать, то отбор не будет установлен.
//			
//  ПравоеЗначениеОтбора - Произвольный - С которым сравнивать правое значение отбора.
//  ВидСравненияОтбора - ВидСравненияКомпоновкиДанных - По умолчанию "ВидСравненияКомпоновкиДанных.Равно".
// 
// Возвращаемое значение:
//  ЭлементУсловногоОформленияКомпоновкиДанных
//
Функция НовыйЭлементОформленияНедоступногоПоля(Объект, ИменаЭлементовОформления,
	ЦветТекста, Текст,
	ПутьКЛевомуЗначениюОтбора, ПравоеЗначениеОтбора = Неопределено, ВидСравненияОтбора = Неопределено) Экспорт
	
	ЭлементУсловногоОформления = НовыйПростойЭлементОформленияСОтбором(Объект,
		ИменаЭлементовОформления,
		ПутьКЛевомуЗначениюОтбора,
		ПравоеЗначениеОтбора,
		ВидСравненияОтбора);
		
	УстановитьОформлениеНедоступногоПоля(ЭлементУсловногоОформления, ЦветТекста, Текст);
	
	Возврат ЭлементУсловногоОформления;
	
КонецФункции

// Устанавливает параметры "ЦветТекста", "Текст" и "ТолькоПросмотр" для элемента условного оформления
// 
// Параметры:
//  ЭлементУсловногоОформления - ЭлементУсловногоОформленияКомпоновкиДанных - в который необходимо добавить оформление.
//  ЦветТекста - Цвет, Неопределено - устанавливаемый для элемента оформления.
//  Текст - Строка, Неопределено - устанавливаемый для элемента оформления.
Процедура УстановитьОформлениеНедоступногоПоля(ЭлементУсловногоОформления, ЦветТекста = Неопределено, Текст = Неопределено) Экспорт
	
	Оформление = ЭлементУсловногоОформления.Оформление;
	
	Если ЦветТекста <> Неопределено Тогда
		Оформление.УстановитьЗначениеПараметра("ЦветТекста", ЦветТекста);
	КонецЕсли;
	
	Если Текст <> Неопределено Тогда
		Оформление.УстановитьЗначениеПараметра("Текст", Текст);
	КонецЕсли;
	
	Оформление.УстановитьЗначениеПараметра("ТолькоПросмотр", Истина);
	
КонецПроцедуры
#КонецОбласти

