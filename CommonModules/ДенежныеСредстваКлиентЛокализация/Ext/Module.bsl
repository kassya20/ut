КонецПроцедуры

#Область СистемаБыстрыхПлатежей

// Обрабатывает оповещение при наступлении события от СБП: изменяет надпись гиперссылки СБП.
// 
// Параметры:
//  Форма - ФормаКлиентскогоПриложения - общая форма этапов оплаты.
//  Документ - ДокументСсылка - документ, по которому обрабатывается оповещение.
//  ИмяСобытия - Строка - Имя события.
//  Входящий - Булево - признак направления платежной ссылки СБП.
//
Процедура ОбработкаОповещенияСБП(Форма, Документ, ИмяСобытия, Входящий = Ложь) Экспорт

	//++ Локализация
	Если ИмяСобытия = "ИзмененСтатусСБП" Тогда
		Форма.НадписьОплатаСБП = ДенежныеСредстваВызовСервераЛокализация.ТекстНадписиОплатыСБП(Документ, Входящий);
	КонецЕсли;
	//-- Локализация
	
	Возврат;

КонецПроцедуры

// Обрабатывает нажатие на навигационную гиперссылку оплаты через СБП.
// 
// Параметры:
//  Форма - ФормаКлиентскогоПриложения - форма этапов оплаты или форма документа "Счет на оплату".
//  Документ - ДокументСсылка - документ операции.
//  НавигационнаяСсылка - Строка - навигационная ссылка.
//
Процедура ОбработкаНавигационнойСсылкиСБП(Форма, Документ, НавигационнаяСсылка) Экспорт

	//++ Локализация
	
	Если НавигационнаяСсылка = "ОтправкаИсходящейСсылки" Тогда
		
		ПараметрыВыполненияКоманды = ПодключаемыеКомандыКлиент.ПараметрыВыполненияКоманды();
		ПараметрыВыполненияКоманды.Вставить("Форма", Форма);
		ПараметрыВыполненияКоманды.Вставить("Источник", Форма.Объект);
		ПараметрыВыполненияКоманды.Вставить("ЭтоФормаОбъекта", Истина);
		
		СистемаБыстрыхПлатежейКлиент.Подключаемый_ОткрытьФормуПлатежнойСсылкиСБП(Документ, ПараметрыВыполненияКоманды);
		Форма.НадписьОплатаСБП = ДенежныеСредстваВызовСервераЛокализация.ТекстНадписиОплатыСБП(Документ);
		
	ИначеЕсли НавигационнаяСсылка = "ПодробностиИсходящейСсылки" Тогда
		
		Ключ = СистемаБыстрыхПлатежейУТВызовСервера.КлючЗаписиИдентификатораСБП(Документ);
		
		Если ТипЗнч(Ключ) = Тип("РегистрСведенийКлючЗаписи.ИдентификаторыОперацийСБПb2b") Тогда
			ИмяФормыЗаписи = "РегистрСведений.ИдентификаторыОперацийСБПb2b.ФормаЗаписи";
		Иначе
			ИмяФормыЗаписи = "РегистрСведений.ИдентификаторыОперацийСБПc2b.ФормаЗаписи";
		КонецЕсли;
		
		ОткрытьФормуПлатежнойСсылкиСБП(Форма, ИмяФормыЗаписи, Ключ);
		
	ИначеЕсли НавигационнаяСсылка = "ДобавлениеВходящейСсылки" Тогда
		
		СистемаБыстрыхПлатежейУТКлиент.НачатьВводВходящейПлатежнойСсылки(Форма, Документ);
		
	ИначеЕсли НавигационнаяСсылка = "ПодробностиВходящейСсылки" Тогда
		
		Ключ = СистемаБыстрыхПлатежейУТВызовСервера.КлючЗаписиВходящейСсылкиСБП(Документ);
		ОткрытьФормуПлатежнойСсылкиСБП(Форма, "РегистрСведений.ВходящиеПлатежныеСсылкиСБП.ФормаЗаписи", Ключ)
		
	ИначеЕсли НавигационнаяСсылка = "СписокВходящихСсылок" Тогда
		
		Отбор = Новый Структура;
		Отбор.Вставить("ДокументОперации", Документ);
		
		ПараметрыОткрытия = Новый Структура;
		ПараметрыОткрытия.Вставить("ТолькоПросмотр", Истина);
		ПараметрыОткрытия.Вставить("Отбор", Отбор);
		ОткрытьФорму(
			"РегистрСведений.ВходящиеПлатежныеСсылкиСБП.ФормаСписка",
			ПараметрыОткрытия,
			Форма, , , , ,
			РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
			
	КонецЕсли;
	//-- Локализация
	
	Возврат;

КонецПроцедуры

// Получает настройки подключения СБП перед обработкой штрихкода платежной ссылки.
// 
// Параметры:
//  Форма - ФормаКлиентскогоПриложения - Форма документа.
//  Штрихкод - Строка - Штрихкод.
//  ОбработкаОтказа - Неопределено, ОписаниеОповещения - оповещение при отказе.
Процедура ПередОбработкойШтрихкодаПлатежнойСсылки(Форма, Штрихкод, ОбработкаОтказа) Экспорт

	//++ Локализация
	
	ПараметрыОповещения = Новый Структура;
	ПараметрыОповещения.Вставить("ОповещениеЗавершения", ОбработкаОтказа);
	ПараметрыОповещения.Вставить("Штрихкод", Штрихкод);
	ПослеПолученияНастройки = Новый ОписаниеОповещения("ОбработатьШтрихкодПлатежнойСсылки", Форма, ПараметрыОповещения);
	
	ПараметрыПолученияНастройки = СистемаБыстрыхПлатежейУТКлиент.НовыйПараметрыПолученияНастроекПодключения();
	Отбор = ПараметрыПолученияНастройки.ОтборНастроек;
	Отбор.ВидКонтрагента = ПредопределенноеЗначение("Перечисление.ЮрФизЛицо.ЮрЛицо");
	ПараметрыПолученияНастройки.ОповещениеПослеПолученияНастройки = ПослеПолученияНастройки;
	
	ПараметрыИсточника = Новый Структура;
	ПараметрыИсточника.Вставить("Форма", Форма);
	
	СистемаБыстрыхПлатежейУТКлиент.ПолучитьНастройкиПодключения(ПараметрыПолученияНастройки, ПараметрыИсточника, ОбработкаОтказа);

	//-- Локализация
	
	Возврат;

КонецПроцедуры

// Обновляет статус оплаты СБП по документу через запрос сведений об оплате в сервис.
// 
// Параметры:
//  Форма - ФормаКлиентскогоПриложения - Форма документа.
//  ДокументСсылка - ДокументСсылка - Документ, по которому выполняется обновление статуса.
//
Процедура ОбновитьСтатусОплатыСБППоДокументу(Форма, ДокументСсылка) Экспорт

	//++ Локализация
	ПараметрыЗагрузки = НовыеПараметрыЗагрузкиИзСервиса();
	ПараметрыЗагрузки.ЭтоЗагрузкаИзСБП = Истина;
	
	ДополнительныеПараметры = Новый Структура;
	ДополнительныеПараметры.Вставить("ДокументСсылка", ДокументСсылка);
	ОповещениеПослеПроверки = Новый ОписаниеОповещения(
		"НачатьОбновлениеСтатусаОплатыПоДокументу",
		СистемаБыстрыхПлатежейУТКлиент,
		ДополнительныеПараметры);
	
	ПроверитьФоновоеЗаданиеЗагрузкиОплатИзСервиса(
		Форма, ПараметрыЗагрузки, ОповещениеПослеПроверки);
	//-- Локализация
	
	Возврат;

КонецПроцедуры

