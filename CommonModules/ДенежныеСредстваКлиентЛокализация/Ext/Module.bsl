// Подключает обработчики ожидания для проверки наличия выполненной оплаты через сервисы онлайн-заказов и СБП.
// 
// Параметры:
//  Форма - ФормаКлиентскогоПриложения - Форма документа, в котором запускаются обработчики.
//  ДокументСсылка - ДокументСсылка - ссылка на документ, в котором выполняется проверка.
//  Контрагент - СправочникСсылка.Контрагенты - плательщик в документе.
//
Процедура ПодключитьПроверкуОплатыЧерезСервисы(Форма, ДокументСсылка, Контрагент) Экспорт

	//++ Локализация
	Если ДокументСсылка.Пустая() Тогда
		Возврат;
	КонецЕсли;
	
	ПодключаемыеОбработчики = 
		ДенежныеСредстваВызовСервераЛокализация.ПроцедурыПроверкиОплатыЧерезСервис(ДокументСсылка, Контрагент);
	
	Если ПодключаемыеОбработчики = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Для Каждого ИмяПроцедуры Из ПодключаемыеОбработчики Цикл
		Форма.ПодключитьОбработчикОжидания(ИмяПроцедуры, 0.1, Истина);
	КонецЦикла;
	//-- Локализация
	
	Возврат;

КонецПроцедуры

// Отключает проверки наличия оплаты через сервисы: онлайн-заказ, СБП.
// 
// Параметры:
//  Форма - ФормаКлиентскогоПриложения - Форма документа, в котором выполнялась проверка.
//
Процедура ОтключитьПроверкуОплатыЧерезСервисы(Форма) Экспорт

	Форма.ОтключитьОбработчикОжидания("Подключаемый_ПроверкаОплатыОнлайнЗаказа");
	Форма.ОтключитьОбработчикОжидания("Подключаемый_ПроверкаОплатыСБП");

КонецПроцедуры

