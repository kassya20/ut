// Возвращаемое значение:
//  Число
Функция ИнтервалЗавершенияРегламентногоЗадания()
	Возврат 3600;
КонецФункции

// Возвращаемое значение:
//  Булево
Функция ПревышенИнтервалЗавершенияПолнойСинхронизацииОбъектов(ДатаНачала)
	
	Результат = Ложь;
	
	ИнтервалАктивности = ТекущаяДатаСеанса() - ДатаНачала;
	Если ИнтервалЗавершенияРегламентногоЗадания() > ИнтервалАктивности Тогда
		Возврат Результат;
	КонецЕсли; 
	
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ
		|	МАКСИМУМ(СостоянияСинхронизацииСЦентромЭДО.МеткаВремени)
		|ИЗ
		|	РегистрСведений.СостоянияСинхронизацииСЦентромЭДО КАК СостоянияСинхронизацииСЦентромЭДО
		|ГДЕ
		|	СостоянияСинхронизацииСЦентромЭДО.ТипСинхронизации = &ТипСинхронизации";
	
	Запрос.УстановитьПараметр("ТипСинхронизации", Перечисления.ТипыСинхронизацииСЦентромЭДО.ДанныеДокументовЭДО);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();
	
	Если Не Выборка.Следующий()
		Или Выборка.МеткаВремени = 0 Тогда
		Возврат Ложь;
	КонецЕсли;
	
	ИнтервалИзмененияСостояния = Цел(ТекущаяУниверсальнаяДатаВМиллисекундах() - Выборка.МеткаВремени) / 1000;
	Если ИнтервалИзмененияСостояния > ИнтервалЗавершенияРегламентногоЗадания() Тогда
		Результат = Истина;
	КонецЕсли; 
	
	Возврат Результат;
	
КонецФункции

