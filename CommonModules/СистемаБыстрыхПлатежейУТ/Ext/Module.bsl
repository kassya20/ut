Функция ПараметрыПоступленияОплатыB2B(ДокументОперации, НастройкаПодключения, ПараметрыОперации)

	ПараметрыОплаты = Новый Структура;
	ПараметрыОплаты.Вставить("ДокументОплаты", Неопределено);
	ПараметрыОплаты.Вставить("ИдентификаторОперацииСБП", "");
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ДоговорыЭквайринга.Организация КАК Организация,
		|	ДоговорыЭквайринга.БанковскийСчет КАК БанковскийСчет,
		|	&ОснованиеПлатежа КАК ОснованиеПлатежа,
		|	&ДатаВходящегоДокумента КАК ДатаВходящегоДокумента,
		|	&СуммаДокумента КАК СуммаДокумента,
		|	&ИдентификаторПлатежа КАК ИдентификаторПлатежа
		|ПОМЕСТИТЬ ПараметрыОплаты
		|ИЗ
		|	РегистрСведений.НастройкиИнтеграцииСПлатежнымиСистемамиУТ КАК НастройкиИнтеграцииСПлатежнымиСистемамиУТ
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ДоговорыЭквайринга КАК ДоговорыЭквайринга
		|		ПО НастройкиИнтеграцииСПлатежнымиСистемамиУТ.Договор = ДоговорыЭквайринга.Ссылка
		|			И (НастройкиИнтеграцииСПлатежнымиСистемамиУТ.Интеграция = &Интеграция)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ПоступлениеБезналичныхДенежныхСредств.Ссылка КАК Ссылка,
		|	ПараметрыОплаты.ОснованиеПлатежа КАК ОснованиеПлатежа,
		|	ПоступлениеБезналичныхДенежныхСредств.ИдентификаторОперацииСБП КАК ИдентификаторОперацииСБП
		|ПОМЕСТИТЬ ДокументыПоступления
		|ИЗ
		|	Документ.ПоступлениеБезналичныхДенежныхСредств КАК ПоступлениеБезналичныхДенежныхСредств
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ПараметрыОплаты КАК ПараметрыОплаты
		|		ПО (ПараметрыОплаты.Организация = ПоступлениеБезналичныхДенежныхСредств.Организация)
		|			И (ПараметрыОплаты.БанковскийСчет = ПоступлениеБезналичныхДенежныхСредств.БанковскийСчет)
		|			И (ПараметрыОплаты.ДатаВходящегоДокумента = ПоступлениеБезналичныхДенежныхСредств.ДатаВходящегоДокумента)
		|			И (ПараметрыОплаты.СуммаДокумента = ПоступлениеБезналичныхДенежныхСредств.СуммаДокумента)
		|			И (ПараметрыОплаты.ИдентификаторПлатежа = ПоступлениеБезналичныхДенежныхСредств.ИдентификаторПлатежа)
		|			И (НЕ ПоступлениеБезналичныхДенежныхСредств.ПометкаУдаления)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ДокументыПоступления.Ссылка КАК Ссылка,
		|	ДокументыПоступления.ИдентификаторОперацииСБП КАК ИдентификаторОперацииСБП
		|ИЗ
		|	ДокументыПоступления КАК ДокументыПоступления
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ПоступлениеБезналичныхДенежныхСредств.РасшифровкаПлатежа КАК РасшифровкаПлатежа
		|		ПО ДокументыПоступления.Ссылка = РасшифровкаПлатежа.Ссылка
		|			И ДокументыПоступления.ОснованиеПлатежа = РасшифровкаПлатежа.ОснованиеПлатежа
		|			И (ДокументыПоступления.ИдентификаторОперацииСБП = &ИдентификаторОперацииСБП)
		|
		|ОБЪЕДИНИТЬ
		|
		|ВЫБРАТЬ
		|	ДокументыПоступления.Ссылка,
		|	ДокументыПоступления.ИдентификаторОперацииСБП
		|ИЗ
		|	ДокументыПоступления КАК ДокументыПоступления
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ПоступлениеБезналичныхДенежныхСредств.РасшифровкаПлатежа КАК РасшифровкаПлатежа
		|		ПО ДокументыПоступления.Ссылка = РасшифровкаПлатежа.Ссылка
		|			И ДокументыПоступления.ОснованиеПлатежа = РасшифровкаПлатежа.ОснованиеПлатежа
		|			И (ДокументыПоступления.ИдентификаторОперацииСБП = """")";
	
	Запрос.УстановитьПараметр("ДатаВходящегоДокумента", НачалоДня(ПараметрыОперации.ДатаОперации));
	Запрос.УстановитьПараметр("ИдентификаторОперацииСБП", ПараметрыОперации.ИдентификаторОплаты);
	Запрос.УстановитьПараметр("ОснованиеПлатежа", ДокументОперации);
	Запрос.УстановитьПараметр("СуммаДокумента", ПараметрыОперации.СуммаОперации);
	Запрос.УстановитьПараметр("ИдентификаторПлатежа", ПараметрыОперации.ИдентификаторПлатежа);
	Запрос.УстановитьПараметр("Интеграция", НастройкаПодключения);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Если РезультатЗапроса.Пустой() Тогда
		Возврат ПараметрыОплаты;
	КонецЕсли;
		
	Выборка = РезультатЗапроса.Выбрать();
	Отбор = Новый Структура;
	Отбор.Вставить("ИдентификаторОперацииСБП", ПараметрыОперации.ИдентификаторОплаты);
	
	Если Выборка.НайтиСледующий(Отбор) Тогда
		ПараметрыОплаты.ДокументОплаты = Выборка.Ссылка;
		ПараметрыОплаты.ИдентификаторОперацииСБП = Выборка.ИдентификаторОперацииСБП;
	КонецЕсли;
	
	Если ПараметрыОплаты.ДокументОплаты = Неопределено Тогда
		
		Выборка.Сбросить();
		
		Отбор = Новый Структура;
		Отбор.Вставить("ИдентификаторОперацииСБП", "");
		
		Если Выборка.НайтиСледующий(Отбор) Тогда
			ПараметрыОплаты.ДокументОплаты = Выборка.Ссылка;
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат ПараметрыОплаты;

КонецФункции

Функция ЗаписатьДокументПОступленияОплатыB2B(ДокументОбъект)

	Обработан = Ложь;
	НетОшибок = ДокументОбъект.ПроверитьЗаполнение();
	
	Если НетОшибок Тогда
		РежимЗаписи = РежимЗаписиДокумента.Проведение;
	Иначе
		РежимЗаписи = РежимЗаписиДокумента.Запись;
	КонецЕсли;
	
	КопияРасшифровкиПлатежа = ДокументОбъект.РасшифровкаПлатежа.Выгрузить();
	
	Попытка
		
		ДокументОбъект.Записать(РежимЗаписи);
		Обработан = Истина;
		
	Исключение
		
		ОписаниеОшибки = ИнформацияОбОшибке();
		ВывестиОшибкуЗаписи(ДокументОбъект, ОписаниеОшибки);
		
	КонецПопытки;
	
	Если РежимЗаписи = РежимЗаписиДокумента.Проведение
		И Не ДокументОбъект.Проведен Тогда
		
		Если КопияРасшифровкиПлатежа <> Неопределено Тогда
			ДокументОбъект.РасшифровкаПлатежа.Загрузить(КопияРасшифровкиПлатежа);
		КонецЕсли;
		
		Попытка
			
			ДокументОбъект.Записать(РежимЗаписиДокумента.Запись);
			Обработан = Истина;
			
		Исключение
			
			ОписаниеОшибки = ИнформацияОбОшибке();
			ВывестиОшибкуЗаписи(ДокументОбъект, ОписаниеОшибки);
			
		КонецПопытки;
		
	КонецЕсли;
	
	Возврат Обработан;

КонецФункции

