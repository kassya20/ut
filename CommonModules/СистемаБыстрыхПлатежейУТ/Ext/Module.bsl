Функция ШаблонЭлектронногоПисьмаСБП(ИмяОбъекта, ТекстШаблона, Наименование, Тема)
	
	ТекстШаблона = СтрЗаменить(ТекстШаблона, Символы.ПС, "");
	
	Шаблон = Новый Структура;
	Шаблон.Вставить("ТипШаблона", "Письмо");
	Шаблон.Вставить("ПолноеИмяТипаНазначения", ИмяОбъекта);
	Шаблон.Вставить("Наименование", Наименование);
	Шаблон.Вставить("Тема", Тема);
	Шаблон.Вставить("Текст", ТекстШаблона);
	
	Возврат Шаблон;
	
КонецФункции

Функция ШаблонПисьмаСМССБП(ИмяОбъекта, ТекстШаблона, Наименование, Тема)
	
	Шаблон = Новый Структура;
	Шаблон.Вставить("ТипШаблона", "SMS");
	Шаблон.Вставить("ПолноеИмяТипаНазначения", ИмяОбъекта);
	Шаблон.Вставить("Наименование", Наименование);
	Шаблон.Вставить("Тема", Тема);
	Шаблон.Вставить("Текст", ТекстШаблона);
	
	Возврат Шаблон;
	
КонецФункции

Процедура НастроитьЭлементыФормы(НастройкиФормы, ДополнительныеПараметры)

	// Договор
	ЭлементФормыДоговор = НастройкиФормы.ЭлементыНастроекОплаты.Договор;
	
	ПараметрыВыбора       = Новый Массив;
	
	НовыйПараметр = Новый ПараметрВыбора("Отбор.СпособПроведенияПлатежа", Перечисления.СпособыПроведенияПлатежей.СистемаБыстрыхПлатежей);
	ПараметрыВыбора.Добавить(НовыйПараметр);
	
	Если ЗначениеЗаполнено(ДополнительныеПараметры) Тогда
		
		Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(ДополнительныеПараметры, "Организация") Тогда
			
			НовыйПараметр = Новый ПараметрВыбора("Отбор.Организация", ДополнительныеПараметры.Организация);
			ПараметрыВыбора.Добавить(НовыйПараметр);
		
		КонецЕсли;
		
		Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(ДополнительныеПараметры, "БанковскийСчет")
			И ЗначениеЗаполнено(ДополнительныеПараметры.БанковскийСчет) Тогда
			
			НовыйПараметр = Новый ПараметрВыбора("Отбор.БанковскийСчет", ДополнительныеПараметры.БанковскийСчет);
			ПараметрыВыбора.Добавить(НовыйПараметр);
		
		КонецЕсли;
		
	КонецЕсли;
	
	ЭлементФормыДоговор.ПараметрыВыбора       = Новый ФиксированныйМассив(ПараметрыВыбора);
	
	// Магазин
	ЭлементФормыМагазин = НастройкиФормы.ЭлементыНастроекОплаты.Магазин;
	ЭлементФормыМагазин.ВыборГруппИЭлементов = ГруппыИЭлементы.ГруппыИЭлементы;
	
	// Подсказка в поле Магазин
	ЭлементФормыМагазин.ПодсказкаВвода = НСтр("ru = '<Все магазины, если реквизит не заполнен>'");

КонецПроцедуры

Процедура ПроверитьПорядокРасчетов(Ошибки, ПроверяемыеДанные)

	Если ПроверяемыеДанные.ЭтоЗаказ
		И ПроверяемыеДанные.ПорядокРасчетов = Перечисления.ПорядокРасчетов.ПоНакладным Тогда
		Ошибки.Добавить(НСтр("ru = 'В документах с порядком расчетов по накладным оплата через СБП доступна только в накладной.'"));
	КонецЕсли;

КонецПроцедуры

