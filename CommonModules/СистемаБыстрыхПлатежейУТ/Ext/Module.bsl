//++ Локализация

#Область ПрограммныйИнтерфейс

#Область НастройкиПодключения

// См. СистемаБыстрыхПлатежейПереопределяемый.ПриОпределенииНастроекПодключения.
//
Процедура ПриОпределенииНастроекПодключения(Настройки) Экспорт

	ОбъектМетаданных = Метаданные.РегистрыСведений.НастройкиИнтеграцииСПлатежнымиСистемамиУТ;
	
	ИсключаемыеПоля  = Новый Массив;
	ИсключаемыеПоля.Добавить("ВариантНастройки");
	
	// c2b
	Настройки.c2b.Вставить("ОбъектМетаданных", ОбъектМетаданных);
	Настройки.c2b.Вставить("ИспользоватьЧастичныеОплаты", Ложь);
	Настройки.c2b.Вставить("ИсключаемыеПоля",  ИсключаемыеПоля);
	
	// b2b
	Настройки.b2b.Вставить("ОбъектМетаданных", ОбъектМетаданных);
	Настройки.c2b.Вставить("ИспользоватьЧастичныеОплаты", Ложь);
	Настройки.b2b.Вставить("ИсключаемыеПоля",  ИсключаемыеПоля);

КонецПроцедуры

// См. СистемаБыстрыхПлатежейПереопределяемый.ПриЗаписиНастроекПодключения.
//
Процедура ПриЗаписиНастроекПодключения(ПараметрыОплаты, Отказ, СообщениеОбОшибке) Экспорт

	УстановитьПривилегированныйРежим(Истина);
	
	НачатьТранзакцию();
	
	Попытка
		
		Если ПараметрыОплаты.c2b <> Неопределено Тогда
			НастройкиОплаты = ПараметрыОплаты.c2b;
			ВариантНастройки = Перечисления.ВариантыНастройкиСБП.c2b;
		Иначе
			НастройкиОплаты = ПараметрыОплаты.b2b;
			ВариантНастройки = Перечисления.ВариантыНастройкиСБП.b2b;
		КонецЕсли;
		
		Договор    = НастройкиОплаты.Получить("Договор");
		Магазин    = НастройкиОплаты.Получить("Магазин");
		Интеграция = НастройкиОплаты.Получить("Интеграция");
		
		Если Не ЗначениеЗаполнено(Договор) Тогда
			ВызватьИсключение НСтр("ru = 'Не заполнен договор подключения к платежной системе'");
		КонецЕсли;
		
		Блокировка = Новый БлокировкаДанных;
		
		ЭлементБлокировки = Блокировка.Добавить("РегистрСведений.НастройкиИнтеграцииСПлатежнымиСистемамиУТ");
		ЭлементБлокировки.УстановитьЗначение("Договор", Договор);
		
		ЭлементБлокировки.Режим = РежимБлокировкиДанных.Исключительный;
		Блокировка.Заблокировать();
		
		Если ЗначениеЗаполнено(Интеграция) Тогда
			Запрос = Новый Запрос;
			Запрос.Текст = 
			"ВЫБРАТЬ
			|	НастройкиИнтеграцииСПлатежнымиСистемамиУТ.Договор КАК Договор,
			|	НастройкиИнтеграцииСПлатежнымиСистемамиУТ.Магазин КАК Магазин,
			|	НастройкиИнтеграцииСПлатежнымиСистемамиУТ.ВариантНастройки КАК ВариантНастройки
			|ИЗ
			|	РегистрСведений.НастройкиИнтеграцииСПлатежнымиСистемамиУТ КАК НастройкиИнтеграцииСПлатежнымиСистемамиУТ
			|ГДЕ
			|	НастройкиИнтеграцииСПлатежнымиСистемамиУТ.Интеграция = &Интеграция";
			Запрос.УстановитьПараметр("Интеграция", Интеграция);
			
			ВыборкаДетальныеЗаписи = Запрос.Выполнить().Выбрать();
			
			Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
				Набор = РегистрыСведений.НастройкиИнтеграцииСПлатежнымиСистемамиУТ.СоздатьНаборЗаписей();
				Набор.Отбор.Договор.Установить(ВыборкаДетальныеЗаписи.Договор);
				Набор.Отбор.Магазин.Установить(ВыборкаДетальныеЗаписи.Магазин);
				Набор.Отбор.ВариантНастройки.Установить(ВыборкаДетальныеЗаписи.ВариантНастройки);
				Набор.Записать();
			КонецЦикла;
		КонецЕсли;
		
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	ИСТИНА КАК Поле1
		|ИЗ
		|	РегистрСведений.НастройкиИнтеграцииСПлатежнымиСистемамиУТ КАК НастройкиИнтеграцииСПлатежнымиСистемамиУТ
		|ГДЕ
		|	НастройкиИнтеграцииСПлатежнымиСистемамиУТ.Договор = &Договор
		|	И НастройкиИнтеграцииСПлатежнымиСистемамиУТ.Магазин В(&Магазины)
		|	И НастройкиИнтеграцииСПлатежнымиСистемамиУТ.Интеграция <> &Интеграция
		|	И НастройкиИнтеграцииСПлатежнымиСистемамиУТ.Интеграция.Используется
		|	И НастройкиИнтеграцииСПлатежнымиСистемамиУТ.ВариантНастройки = &ВариантНастройки";
		Запрос.УстановитьПараметр("Договор",    Договор);
		Запрос.УстановитьПараметр("Магазины",   РозничныеПродажи.СкладВИерархии(Магазин));
		Запрос.УстановитьПараметр("Интеграция", Интеграция);
		Запрос.УстановитьПараметр("ВариантНастройки", ВариантНастройки);
		
		РезультатЗапроса = Запрос.Выполнить();
		Если Не РезультатЗапроса.Пустой() Тогда
			Если ЗначениеЗаполнено(Магазин) Тогда
				СообщениеОбОшибке = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
					НСтр("ru = 'Для договора подключения ""%1"" и магазина ""%2"" существует настройка подключения.'"),
					Договор, Магазин);
			Иначе
				СообщениеОбОшибке = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
					НСтр("ru = 'Для договора подключения ""%1"" без указания магазина существует настройка подключения.'"),
					Договор);
			КонецЕсли;
			
			ВызватьИсключение СообщениеОбОшибке;
		КонецЕсли;
		
		Запись = РегистрыСведений.НастройкиИнтеграцииСПлатежнымиСистемамиУТ.СоздатьМенеджерЗаписи();
		Запись.Интеграция       = Интеграция;
		Запись.Договор          = Договор;
		Запись.Магазин          = Магазин;
		Запись.ВариантНастройки = ВариантНастройки;
		Запись.Записать();
		
		ЗафиксироватьТранзакцию();
		
	Исключение
		
		ОтменитьТранзакцию();
		
		ЗаписьЖурналаРегистрации(
			НСтр("ru = 'СистемаБыстрыхПлатежейПереопределяемый.ПриЗаписиНастроекПодключения'"
				, ОбщегоНазначения.КодОсновногоЯзыка()),
			УровеньЖурналаРегистрации.Ошибка,,,
			ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
			
		Отказ = Истина;
		СообщениеОбОшибке = ОбработкаОшибок.КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
		
	КонецПопытки;
	
	ОбновитьПовторноИспользуемыеЗначения();

КонецПроцедуры

// См. СистемаБыстрыхПлатежейПереопределяемый.ПриНастройкеЭлементовФормыПодключения.
//
Процедура ПриНастройкеЭлементовФормыПодключения(НастройкиФормы, ДополнительныеПараметры) Экспорт

	Если НастройкиФормы.c2b <> Неопределено Тогда
		НастроитьЭлементыФормы(НастройкиФормы.c2b, ДополнительныеПараметры);
	КонецЕсли;
	
	Если НастройкиФормы.b2b <> Неопределено Тогда
		НастроитьЭлементыФормы(НастройкиФормы.b2b, ДополнительныеПараметры);
	КонецЕсли;

КонецПроцедуры

// См. СистемаБыстрыхПлатежейПереопределяемый.ПриЗаполненииФормыНастройкиПодключения.
//
Процедура ПриЗаполненииФормыНастройкиПодключения(Настройки, ДополнительныеПараметры) Экспорт

	Если ДополнительныеПараметры <> Неопределено Тогда
		
		ДанныеЗаполнения = Новый Структура;
		
		Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(ДополнительныеПараметры, "Договор") Тогда
			
			Автонаименование = СтрШаблон(НСтр("ru = '%1'"), ДополнительныеПараметры.Договор);
			ЗаполнитьЗначенияСвойств(Настройки.ОбщиеНастройки,  Новый Структура("Наименование", Автонаименование));
			ДанныеЗаполнения.Вставить("Договор", ДополнительныеПараметры.Договор);
			
		КонецЕсли;
		
		Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(ДополнительныеПараметры, "Магазин") Тогда
			ДанныеЗаполнения.Вставить("Магазин", ДополнительныеПараметры.Магазин);
		КонецЕсли;
		
		Если Настройки.НастройкиОплаты.c2b <> Неопределено Тогда
			ЗаполнитьЗначенияСвойств(Настройки.НастройкиОплаты.c2b,  ДанныеЗаполнения);
		ИначеЕсли Настройки.НастройкиОплаты.b2b <> Неопределено Тогда
			ЗаполнитьЗначенияСвойств(Настройки.НастройкиОплаты.b2b,  ДанныеЗаполнения);
		КонецЕсли;
		
	КонецЕсли;

КонецПроцедуры

#КонецОбласти

#Область ШаблоныСообщений

// См. СистемаБыстрыхПлатежейПереопределяемый.ПриПроверкеИспользованияШаблоновСообщений.
//
Процедура ПриПроверкеИспользованияШаблоновСообщений(Используется) Экспорт

	Используется = Истина;

КонецПроцедуры

// См. СистемаБыстрыхПлатежейПереопределяемый.ПриОпределенииПредопределенныхШаблоновСообщений.
//
Процедура ПриОпределенииПредопределенныхШаблоновСообщений(НастройкиШаблонов) Экспорт 
	
	ШаблонНаименованиеПисьма = НСтр("ru = 'Реквизиты для оплаты через СБП (%1) (почта)'");
	ШаблонНаименованиеСМС = НСтр("ru = 'Реквизиты для оплаты через СБП (%1) (смс)'");
	ЗаполнитьШаблон(НастройкиШаблонов.c2b, ШаблонНаименованиеПисьма, ШаблонНаименованиеСМС);
	
	ШаблонНаименованиеПисьма = НСтр("ru = 'Реквизиты для оплаты через СБП B2B (%1) (почта)'");
	ШаблонНаименованиеСМС = НСтр("ru = 'Реквизиты для оплаты через СБП B2B (%1) (смс)'");
	ЗаполнитьШаблон(НастройкиШаблонов.b2b, ШаблонНаименованиеПисьма, ШаблонНаименованиеСМС);
	
КонецПроцедуры

#КонецОбласти

#Область ФормаПодготовкиПлатежнойСсылки

// См. СистемаБыстрыхПлатежейПереопределяемый.ПриОпределенииОбъектовСКомандамиСБП.
//
Процедура ПриОпределенииОбъектовСКомандамиСБП(ИменаДокументовОперации) Экспорт
	
	Если СтандартныеПодсистемыСервер.ЭтоБазоваяВерсияКонфигурации() Тогда
		Возврат;
	КонецЕсли;
	
	ИменаДокументовОперации.Добавить("Документ.ЗаказКлиента");
	ИменаДокументовОперации.Добавить("Документ.СчетНаОплатуКлиенту");
	ИменаДокументовОперации.Добавить("Документ.АктВыполненныхРабот");
	ИменаДокументовОперации.Добавить("Документ.РеализацияТоваровУслуг");
	ИменаДокументовОперации.Добавить("Документ.РеализацияУслугПрочихАктивов");
	ИменаДокументовОперации.Добавить("Документ.ВыкупВозвратнойТарыКлиентом");
	ИменаДокументовОперации.Добавить("Документ.ВыкупТоваровХранителем");


	ИменаДокументовОперации.Добавить("Документ.ЗаявкаНаВозвратТоваровОтКлиента");
	ИменаДокументовОперации.Добавить("Документ.КорректировкаРеализации");


	ИменаДокументовОперации.Добавить("Документ.ОтчетКомитентуОЗакупках");
	ИменаДокументовОперации.Добавить("Документ.ОтчетКомиссионера");
	
КонецПроцедуры

// См. СистемаБыстрыхПлатежейПереопределяемый.ПриОпределенииДоступностиПодключенияПоДокументуОперации.
//
Процедура ПриОпределенииДоступностиПодключенияПоДокументуОперации(ДокументОперации, Результат) Экспорт

	Результат.ИнтеграцияДоступна = Ложь;
	
	Если Не ОбщегоНазначения.СсылкаСуществует(ДокументОперации) Тогда
		
		Результат.СообщениеОбОшибке = НСтр("ru = 'Для оплаты через СБП необходимо провести документ.'");
		Возврат;
		
	КонецЕсли;
	
	РеквизитыДокумента = Новый Соответствие;
	РеквизитыДокумента.Вставить("ЗаказКакСчет", "ЗаказКакСчет");
	РеквизитыДокумента.Вставить("ЭтоЗаказ", "ЭтоЗаказ");
	РеквизитыДокумента.Вставить("ЭтоПродажаЗакупка", "ЭтоПродажаЗакупка");
	РеквизитыДокумента.Вставить("ИзменяетПланОплаты", "ИзменяетПланОплаты");
	РеквизитыДокумента.Вставить("БанковскийСчетОрганизации", "БанковскийСчетОрганизации");
	РеквизитыДокумента.Вставить("БанковскийСчетКонтрагента", "БанковскийСчетКонтрагента");
	РеквизитыДокумента.Вставить("Контрагент.ЮрФизЛицо", "ВидКонтрагента");
	РеквизитыДокумента.Вставить("ИдентификаторПлатежа", "ИдентификаторПлатежа");
	РеквизитыДокумента.Вставить("ПорядокРасчетов", "ПорядокРасчетов");
	РеквизитыДокумента.Вставить("ФормаОплаты", "ФормаОплаты");
	
	СтруктураПараметров = ДенежныеСредстваСервер.ДанныеДокумента(
		ДокументОперации, Перечисления.ТипыРасчетовСПартнерами.РасчетыСКлиентом, РеквизитыДокумента, Истина);
	
	Результат.ИнтеграцияДоступна = Истина;
	
	СуммыДокумента = ДенежныеСредстваСервер.СуммыДокумента(ДокументОперации, СтруктураПараметров.ДокументОперации);
	
	Если СуммыДокумента.Итог("СуммаСНДС") <= 0
		Или (Не СтруктураПараметров.ИзменяетПланОплаты И Не СтруктураПараметров.ЗаказКакСчет)
		Или (СуммыДокумента.Итог("СуммаСНДС") <= 0 И (СтруктураПараметров.ЭтоПродажаЗакупка Или СтруктураПараметров.ЭтоЗаказ)) Тогда
	
		Результат.ИнтеграцияДоступна = Ложь;
		Результат.СообщениеОбОшибке = НСтр("ru = 'Оплата не требуется.'");
		Возврат;
		
	КонецЕсли;
	
	Если Не (СтруктураПараметров.ФормаОплаты = Перечисления.ФормыОплаты.ПустаяСсылка()
		Или СтруктураПараметров.ФормаОплаты = Перечисления.ФормыОплаты.СистемаБыстрыхПлатежей) Тогда
		
		Результат.ИнтеграцияДоступна = Ложь;
		Результат.СообщениеОбОшибке = НСтр("ru = 'Для выбранной формы оплаты не доступны переводы через СБП.'");
		Возврат;
		
	КонецЕсли;
	
	Если СтруктураПараметров.ВидКонтрагента = Перечисления.ЮрФизЛицо.ФизЛицо Тогда
		ПлатежнаяСсылка = РегистрыСведений.ИдентификаторыОперацийСБПc2b.ДанныеПлатежнойСсылки(ДокументОперации);
	ИначеЕсли СтруктураПараметров.ВидКонтрагента <> Перечисления.ЮрФизЛицо.ПустаяСсылка() Тогда
		ПлатежнаяСсылка = РегистрыСведений.ИдентификаторыОперацийСБПb2b.ДанныеПлатежнойСсылки(ДокументОперации);
	КонецЕсли;
	
	ОплатаПоДокументу = 
		СтруктураПараметров.ПорядокРасчетов = Перечисления.ПорядокРасчетов.ПоЗаказам
		Или СтруктураПараметров.ПорядокРасчетов = Перечисления.ПорядокРасчетов.ПоЗаказамНакладным
		Или (СтруктураПараметров.ПорядокРасчетов = Перечисления.ПорядокРасчетов.ПоНакладным
			И СтруктураПараметров.ЭтоПродажаЗакупка) 
		Или (СтруктураПараметров.ПорядокРасчетов = Перечисления.ПорядокРасчетов.ПоДоговорамНакладным
			И СтруктураПараметров.ЭтоПродажаЗакупка);
	
	Если ПлатежнаяСсылка = Неопределено
		И ОплатаПоДокументу
		И СтруктураПараметров.ПроцентОплат >= 100
		И СтруктураПараметров.СуммаЗадолженности <= 0 Тогда
	
		Результат.ИнтеграцияДоступна = Ложь;
		ШаблонСообщенияОбОшибке = НСтр("ru = 'Остаток задолженности по документу ""%1"" равен 0. Документ полностью оплачен.'");
		Результат.СообщениеОбОшибке = СтрШаблон(ШаблонСообщенияОбОшибке, СтруктураПараметров.ДокументОперации);
		Возврат;
		
	КонецЕсли;
	
	СписокОшибок = Новый Массив;
	
	Если СтруктураПараметров.ВидКонтрагента <> Перечисления.ЮрФизЛицо.ФизЛицо
		И Не ЗначениеЗаполнено(СтруктураПараметров.БанковскийСчетОрганизации) Тогда
		СписокОшибок.Добавить(НСтр("ru = 'Необходимо заполнить банковский счет организации.'"));
	КонецЕсли;
	
	ПроверитьПорядокРасчетов(СписокОшибок, СтруктураПараметров);
	
	Если Не ЗначениеЗаполнено(СтруктураПараметров.ИдентификаторПлатежа)
		И СтруктураПараметров.ВидКонтрагента <> Перечисления.ЮрФизЛицо.ФизЛицо Тогда
		СписокОшибок.Добавить(НСтр("ru = 'Необходимо заполнить УИП.'"));
	КонецЕсли;
	
	Если СписокОшибок.Количество() <> 0 Тогда
		
		Результат.ИнтеграцияДоступна = Ложь;
		Результат.СообщениеОбОшибке = СтрСоединить(СписокОшибок, Символы.ПС);
		Возврат;
		
	КонецЕсли;
	
	Если Результат.ИнтеграцияДоступна
		И Не СтруктураПараметров.Проведен Тогда
	
		Результат.ИнтеграцияДоступна = Ложь;
		Результат.СообщениеОбОшибке = НСтр("ru = 'Для оплаты через СБП необходимо провести документ.'");
		
	КонецЕсли;

КонецПроцедуры

// См. СистемаБыстрыхПлатежейПереопределяемый.ПриОпределенииПараметровПодключенияДокументаОперации.
//
Процедура ПриОпределенииПараметровПодключенияДокументаОперации(ДокументОперации, НастройкиПодключения, ДополнительныеНастройки, ПараметрыВопроса) Экспорт
	
	ТребуетсяПроверкаДокументаОснования = Ложь;

	РеквизитыДокумента = Новый Соответствие;
	РеквизитыДокумента.Вставить("Организация", "Организация");
	РеквизитыДокумента.Вставить("БанковскийСчетОрганизации", "БанковскийСчетОрганизации");
	РеквизитыДокумента.Вставить("ТСП", "Склад");
	РеквизитыДокумента.Вставить("Контрагент.ЮрФизЛицо", "ВидКонтрагента");
	СтруктураПараметров = ДенежныеСредстваСервер.ДанныеДокумента(
		ДокументОперации, Перечисления.ТипыРасчетовСПартнерами.РасчетыСКлиентом, РеквизитыДокумента);
	СуммыДокумента = ДенежныеСредстваСервер.СуммыДокумента(ДокументОперации, СтруктураПараметров.ДокументОперации);
	
	Если СтруктураПараметров.ВидКонтрагента = Перечисления.ЮрФизЛицо.ФизЛицо Тогда
	
		Если ТипЗнч(ДокументОперации) = Тип("ДокументСсылка.СчетНаОплатуКлиенту")
			И РегистрыСведений.ИдентификаторыОперацийСБПc2b.ПараметрыОпределенияСтатусаОперации(ДокументОперации) = Неопределено Тогда 
			ТребуетсяПроверкаДокументаОснования = Истина;
		КонецЕсли;
		
		НастройкиПодключения.c2b = НастройкиПодключенияC2B(
			СтруктураПараметров.Организация, СтруктураПараметров.Склад);
		
		Если ТребуетсяПроверкаДокументаОснования
			И ЗначениеЗаполнено(СтруктураПараметров.ДокументОперации) Тогда
			
			Если Не РегистрыСведений.ИдентификаторыОперацийСБПc2b.ПараметрыОпределенияСтатусаОперации(СтруктураПараметров.ДокументОперации) = Неопределено Тогда 
				
				ПараметрыВопроса.ТекстВопроса = НСтр("ru = 'Для документа основания уже сформирована ссылка на оплату СБП. Продолжить?'");
			КонецЕсли;
			
		КонецЕсли;
		
		ДополнительныеНастройки.ВариантНастройки = "c2b";
		
	Иначе
		
		Если ТипЗнч(ДокументОперации) = Тип("ДокументСсылка.СчетНаОплатуКлиенту")
			И РегистрыСведений.ИдентификаторыОперацийСБПb2b.ПараметрыОпределенияСтатусаОперации(ДокументОперации) = Неопределено Тогда 
			ТребуетсяПроверкаДокументаОснования = Истина;
		КонецЕсли;
		
		НастройкиПодключения.b2b = НастройкиПодключенияB2B(
			СтруктураПараметров.Организация, СтруктураПараметров.БанковскийСчетОрганизации, СтруктураПараметров.Склад);
		
		Если ТребуетсяПроверкаДокументаОснования
			И ЗначениеЗаполнено(СтруктураПараметров.ДокументОперации) Тогда
			
			Если Не РегистрыСведений.ИдентификаторыОперацийСБПb2b.ПараметрыОпределенияСтатусаОперации(СтруктураПараметров.ДокументОперации) = Неопределено Тогда 
				ПараметрыВопроса.ТекстВопроса = НСтр("ru = 'Для документа основания уже сформирована ссылка на оплату СБП. Продолжить?'");
			КонецЕсли;
			
		КонецЕсли;
		
		ДополнительныеНастройки.ВариантНастройки = "b2b";

	КонецЕсли;
	
	ДополнительныеНастройки.МаксимальнаяСуммаОплаты = СуммыДокумента.Итог("СуммаСНДС");
	
	Если НастройкиПодключения.b2b.Количество() = 0 
		И НастройкиПодключения.c2b.Количество() = 0 Тогда
		
		ДополнительныеНастройки.ДополнительныеПараметры = Новый Структура;
		ДополнительныеНастройки.ДополнительныеПараметры.Вставить("Организация", СтруктураПараметров.Организация);
		ДополнительныеНастройки.ДополнительныеПараметры.Вставить("БанковскийСчет", СтруктураПараметров.БанковскийСчетОрганизации);
		ДополнительныеНастройки.ДополнительныеПараметры.Вставить("Магазин", СтруктураПараметров.Склад);
		
	КонецЕсли;

КонецПроцедуры

#КонецОбласти

#Область ОтправкаСообщений

// См. СистемаБыстрыхПлатежейПереопределяемый.ПриФормированииСпискаПолучателейСообщенияСБП.
//
Процедура ПриФормированииСпискаПолучателейСообщенияСБП(ДокументОперации, ВариантОтправки, Получатели) Экспорт
	
	СписокИменДокументов = Новый Массив;
	ПриОпределенииОбъектовСКомандамиСБП(СписокИменДокументов);
	
	ОбъектДокумент = ДокументОперации.Метаданные();
	Если СписокИменДокументов.Найти(ОбъектДокумент.ПолноеИмя()) = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Реквизиты = Новый Соответствие;
	Реквизиты.Вставить("Контрагент", "Контрагент");
	РеквизитыДокумента = ДенежныеСредстваСервер.ДанныеДокумента(ДокументОперации, Перечисления.ТипыРасчетовСПартнерами.РасчетыСКлиентом, Реквизиты);
	
	Если Не ЗначениеЗаполнено(РеквизитыДокумента.Контрагент) Тогда
		Возврат;
	КонецЕсли;
	
	ВидыКонтактнойИнформацииДляОтбора = Новый Массив;
	ПараметрыОтбора = УправлениеКонтактнойИнформацией.ОтборКонтактнойИнформации();
	
	Если ВариантОтправки = "ЭлектроннаяПочта" Тогда
		ВидыКонтактнойИнформацииДляОтбора.Добавить(Справочники.ВидыКонтактнойИнформации.EmailКонтрагента);
	ИначеЕсли ВариантОтправки = "Телефон" Тогда
		ВидыКонтактнойИнформацииДляОтбора.Добавить(Справочники.ВидыКонтактнойИнформации.ТелефонКонтрагента);
	КонецЕсли;
	
	ПараметрыОтбора.ВидыКонтактнойИнформации = ВидыКонтактнойИнформацииДляОтбора;
	ПараметрыОтбора.Дата = ТекущаяДатаСеанса();
	
	КонтактнаяИнформацияКонтрагента = УправлениеКонтактнойИнформацией.КонтактнаяИнформация(РеквизитыДокумента.Контрагент, ПараметрыОтбора);
	
	Для Каждого ЗаписьКонтактнойИнформации Из КонтактнаяИнформацияКонтрагента Цикл
		Если ЗначениеЗаполнено(ЗаписьКонтактнойИнформации.Представление) Тогда
			Получатели.Добавить(ЗаписьКонтактнойИнформации.Представление);
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти

// Возвращает признак, что создание и отправка исходящей платежной ссылки СБП доступно по документу.
// 
// Параметры:
//  Документ - ДокументСсылка - проверяемый документ.
// 
// Возвращаемое значение:
//  Булево
Функция ПереводыСБППоДокументуДоступны(Документ) Экспорт

	Результат = Ложь;
	
	ВидКонтрагента = ДенежныеСредстваСервер.ВидКонтрагентаДокументаОперации(
		Документ, Перечисления.ТипыРасчетовСПартнерами.РасчетыСКлиентом);
	
	Если ВидКонтрагента = Перечисления.ЮрФизЛицо.ФизЛицо Тогда
		Результат = ПереводыСБПc2b.ПереводыСБПДоступны();
	ИначеЕсли ВидКонтрагента <> Перечисления.ЮрФизЛицо.ПустаяСсылка() Тогда
		Результат = ПереводыСБПb2b.ПереводыСБПДоступны();
	Иначе
		Результат = ПереводыСБПc2b.ПереводыСБПДоступны()
			И ПереводыСБПb2b.ПереводыСБПДоступны();
	КонецЕсли;
	
	Возврат Результат;

КонецФункции

// Возвращает признак, что ввод входящей платежной ссылки СБП доступно по документу.
// 
// Параметры:
//  Документ - ДокументСсылка - проверяемый документ.
// 
// Возвращаемое значение:
//  Булево
Функция ДоступноДобавлениеВходящейСсылкиПоДокументу(Документ) Экспорт
	
	Результат = Ложь;
	
	ВидКонтрагента = ДенежныеСредстваСервер.ВидКонтрагентаДокументаОперации(
		Документ, Перечисления.ТипыРасчетовСПартнерами.РасчетыСПоставщиком);
	ЭтоПлатежныйДокумент = ТипЗнч(Документ) = Тип("ДокументСсылка.ЗаявкаНаРасходованиеДенежныхСредств");
	
	Если ВидКонтрагента = Перечисления.ЮрФизЛицо.ФизЛицо Тогда
		Результат = Ложь;
	Иначе
		
		ДопустимыеТипы = ТипыДокументовВходящейПлатежнойСсылки();
		Результат = ЕстьПравоВводаВходящейСсылки()
			И ДопустимыеТипы.Найти(ТипЗнч(Документ)) <> Неопределено
			И (Не Документ.Пустая() Или ЭтоПлатежныйДокумент);
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Возвращает признак права ввода входящей ссылки.
// 
// Возвращаемое значение:
//  Булево - Есть право ввода входящей ссылки
Функция ЕстьПравоВводаВходящейСсылки() Экспорт
	
	Возврат ПравоДоступа("Изменение", Метаданные.РегистрыСведений.ВходящиеПлатежныеСсылкиСБП);
	
КонецФункции

// Возвращает доступные настройки подключения по отбору.
// 
// Параметры:
//  Отбор - Структура - данные документа:
//  * Организация - Неопределено, СправочникСсылка.Организации - организация, по которой выполняется поиск настройки подключения.
//  * БанковскийСчетОрганизации - Неопределено, СправочникСсылка.БанковскиеСчетаОрганизаций - банковский счет организации, по которому выполняется поиск настройки подключения.
//  * Склад - Неопределено, СправочникСсылка.Склады - склад, по которому выполняется поиск настройки подключения.
//  * ВидКонтрагента - Неопределено, ПеречислениеСсылка.ЮрФизЛицо - вид контрагента, по которому выполняется поиск настройки подключения.
// 
// Возвращаемое значение:
//  Структура - Настройки подключения документа:
// * НастройкиПодключения - Неопределено, Массив из СправочникСсылка.НастройкиПодключенияКСистемеБыстрыхПлатежей - список настроек.
// * ДоступноПодключение - Булево - признак доступности прав на добавление настройки подключения.
// * ДополнительныеНастройки - Структура - дополнительные настройки:
// ** БИК - Неопределено, Строка - БИК банка.
// ** ОтборУчастников - Неопределено - отбор участников СБП.
// ** ДополнительныеПараметры - Неопределено - дополнительные параметры для создания подключения, если настройки не найдены.
// ** ВариантНастройки - Неопределено, Строка - вариант настройки.
Функция ДоступныеНастройкиПодключения(Отбор) Экспорт

	Если ПравоДоступа("Чтение", Метаданные.Справочники.НастройкиПодключенияКСистемеБыстрыхПлатежей) Тогда
		
		Настройки = НастройкиПодключения(
			Отбор.Организация,
			Отбор.БанковскийСчетОрганизации,
			Отбор.Склад,
			Отбор.ВидКонтрагента);
		
		Если ЗначениеЗаполнено(Настройки.НастройкиПодключения)
			И Настройки.НастройкиПодключения.Количество() = 0 Тогда
			
			Настройки.ДополнительныеНастройки.ДополнительныеПараметры = Новый Структура;
			Настройки.ДополнительныеНастройки.ДополнительныеПараметры.Вставить("Организация", Отбор.Организация);
			Настройки.ДополнительныеНастройки.ДополнительныеПараметры.Вставить("БанковскийСчет", Отбор.БанковскийСчетОрганизации);
			Настройки.ДополнительныеНастройки.ДополнительныеПараметры.Вставить("Магазин", Отбор.Склад);
			
		КонецЕсли;
		
	Иначе
		Настройки = ИнициализироватьПараметрыНастроекПодключения();
	КонецЕсли;
	
	Возврат Настройки;

КонецФункции

// Возвращает параметры команды сканирования штрихкода СБП для заполнения.
// 
// Возвращаемое значение:
//  Структура - Новый параметры команды сканирования штрихкода СБП:
// * Родитель - Неопределено, ГруппаФормы - группа, куда будет добавлена команда.
Функция НовыйПараметрыКомандыСканированияШтрихкодаСБП() Экспорт

	ПараметрыКоманды = Новый Структура;
	ПараметрыКоманды.Вставить("Родитель", Неопределено);
	
	Возврат ПараметрыКоманды;

КонецФункции

// Добавляет команду сканирования штрихкода СБП.
// 
// Параметры:
//  Форма - ФормаКлиентскогоПриложения - Форма списка.
//  ПараметрыКоманды - см. НовыйПараметрыКомандыСканированияШтрихкодаСБП.
Процедура ДобавитьКомандуСканированияШтрихкодаСБП(Форма, ПараметрыКоманды) Экспорт

	Если ОбщегоНазначения.ЭтоМобильныйКлиент() Тогда
		
		Если ПараметрыКоманды.Родитель = Неопределено Тогда
			ПараметрыКоманды.Родитель = Форма.КоманднаяПанель;
		КонецЕсли;
		
		Отбор = Новый Структура;
		Отбор.Вставить("Организация", Неопределено);
		Отбор.Вставить("БанковскийСчетОрганизации", Неопределено);
		Отбор.Вставить("Склад", Неопределено);
		Отбор.Вставить("ВидКонтрагента", Перечисления.ЮрФизЛицо.ЮрЛицо);
		ДоступныеНастройки = ДоступныеНастройкиПодключения(Отбор);
		
		Если ДоступныеНастройки.НастройкиПодключения <> Неопределено Тогда
			
			НоваяКоманда = Форма.Команды.Добавить("СканироватьQRКодСБП");
			НоваяКоманда.Действие = "Подключаемый_СканироватьQRКодСБПЛокализация";
			НоваяКоманда.Заголовок = НСтр("ru = 'Сканировать QR-код'");
			НоваяКоманда.Подсказка = НСтр("ru = 'Сканировать QR-код СБП'");
			НоваяКоманда.Картинка = БиблиотекаКартинок.ЛоготипСБПКнопка;
			НоваяКоманда.Отображение = ОтображениеКнопки.Картинка;
			
			КнопкаФормы = Форма.Элементы.Добавить("СканироватьQRКодСБП", Тип("КнопкаФормы"), ПараметрыКоманды.Родитель);
			КнопкаФормы.ИмяКоманды = "СканироватьQRКодСБП";
			КнопкаФормы.Вид = ВидКнопкиФормы.КнопкаКоманднойПанели;
			КнопкаФормы.ПоложениеВКоманднойПанели = ПоложениеКнопкиВКоманднойПанели.ВКоманднойПанели;
			КнопкаФормы.УникальностьКоманды = Истина;
			
		КонецЕсли;
		
	Иначе
		Возврат;
	КонецЕсли;

КонецПроцедуры

// Возвращает фоновое задание на получение данных по платежной ссылке.
// 
// Параметры:
//  ПараметрыПроцедуры - Структура - Параметры процедуры
// 
// Возвращаемое значение:
//  Структура - Задание на получение данных по платежной ссылке:
// * Статус - Строка - статус фонового задания.
// * ИдентификаторЗадания - Неопределено, УникальныйИдентификатор - идентификатор задания.
// * АдресРезультата - Строка - адрес временного хранилища, в которое будет помещен результат работы процедуры.
// * АдресДополнительногоРезультата - Строка - адрес дополнительного временного хранилища.
// * ИнформацияОбОшибке - Неопределено, ИнформацияОбОшибке - информация об ошибке.
// * КраткоеПредставлениеОшибки - Строка - краткое описание ошибки.
// * ПодробноеПредставлениеОшибки - Строка - подробное описание ошибки
// * Сообщения - ФиксированныйМассив из Строка - список сообщений, сформированный во время выполнения задания.
//
Функция ЗаданиеНаПолучениеДанныхПоПлатежнойСсылке(ПараметрыПроцедуры) Экспорт

	ПараметрыЗадания = ДлительныеОперации.ПараметрыВыполненияВФоне(Новый УникальныйИдентификатор);
	ПараметрыЗадания.НаименованиеФоновогоЗадания = НСтр("ru='Получение данных функциональной ссылки Системы быстрых платежей'");
	ФоновоеЗадание = ДлительныеОперации.ВыполнитьВФоне("СистемаБыстрыхПлатежейУТ.ДанныеЗаполненияПоПлатежнойСсылкеСБПb2b", ПараметрыПроцедуры, ПараметрыЗадания);
	
	Возврат ФоновоеЗадание;

КонецФункции

// Возвращает фоновое задание на загрузку статусов операций.
// 
// Возвращаемое значение:
//  Структура - Задание на загрузку статусов операций:
// * Статус - Строка - статус фонового задания.
// * ИдентификаторЗадания - Неопределено, УникальныйИдентификатор - идентификатор задания.
// * АдресРезультата - Строка - адрес временного хранилища, в которое будет помещен результат работы процедуры.
// * АдресДополнительногоРезультата - Строка - адрес дополнительного временного хранилища.
// * ИнформацияОбОшибке - Неопределено, ИнформацияОбОшибке - информация об ошибке.
// * КраткоеПредставлениеОшибки - Строка - краткое описание ошибки.
// * ПодробноеПредставлениеОшибки - Строка - подробное описание ошибки
// * Сообщения - ФиксированныйМассив из Строка - список сообщений, сформированный во время выполнения задания.
Функция ЗаданиеНаЗагрузкуСтатусовОпераций() Экспорт

	ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияВФоне(Новый УникальныйИдентификатор);
	ПараметрыВыполнения.НаименованиеФоновогоЗадания = НСтр("ru='Загрузка статусов операций СБП'");
	ПараметрыПроцедуры = Новый Структура;
	ФоновоеЗадание = ДлительныеОперации.ВыполнитьВФоне("СистемаБыстрыхПлатежейУТ.ЗагрузкаСтатусовОпераций", ПараметрыПроцедуры, ПараметрыВыполнения);
	
	Возврат ФоновоеЗадание;

КонецФункции

// Добавляет команду "Обновить статус оплаты СБП" на форму документа.
// 
// Параметры:
//  Форма - ФормаКлиентскогоПриложения - Форма документа.
//  ПараметрыКоманды - см. ДенежныеСредстваСерверЛокализация.НовыйПараметрыКомандыОбновленияСтатусаОплатыСБП.
//
Процедура ДобавитьКомандуОбновленияСтатусаОплатыСБП(Форма, ПараметрыКоманды) Экспорт

	Объект = Форма.Объект; // ДанныеФормыСтруктура
	Ссылка = Объект.Ссылка;
	
	Если Ссылка.Пустая() Тогда
		Возврат;
	КонецЕсли;
	
	Если Не ДенежныеСредстваСерверЛокализация.ВключенаГенерацияПлатежнойСсылкиСБППоДокументу(Ссылка) Тогда
		Возврат;
	КонецЕсли;
	
	СтруктураПараметров = ДенежныеСредстваСервер.ПараметрыПоТипуРасчетов(Ссылка, Перечисления.ТипыРасчетовСПартнерами.РасчетыСКлиентом);
	
	Если СтруктураПараметров = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Контрагент = ОбщегоНазначенияУТКлиентСервер.ДанныеПоПути(Форма, СтруктураПараметров.Контрагент);
	ФормаОплаты = ОбщегоНазначенияУТКлиентСервер.ДанныеПоПути(Форма, СтруктураПараметров.ФормаОплаты);
	
	ВидКонтрагента = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Контрагент, "ЮрФизЛицо");
	
	Если Не (ФормаОплаты = Перечисления.ФормыОплаты.СистемаБыстрыхПлатежей
		Или ФормаОплаты = Перечисления.ФормыОплаты.ПустаяСсылка()) Тогда
		Возврат;
	КонецЕсли;
	
	Если ВидКонтрагента = Перечисления.ЮрФизЛицо.ФизЛицо
		И ПереводыСБПc2b.ПереводыСБПДоступны()
		И ПравоДоступа("Добавление", Метаданные.Документы.ОперацияПоПлатежнойКарте) Тогда
		ИмяИсточника = Метаданные.РегистрыСведений.ИдентификаторыОперацийСБПc2b.ПолноеИмя();
	ИначеЕсли ВидКонтрагента <> Перечисления.ЮрФизЛицо.ФизЛицо
		И ВидКонтрагента <> Перечисления.ЮрФизЛицо.ПустаяСсылка()
		И ПереводыСБПb2b.ПереводыСБПДоступны()
		И ПравоДоступа("Добавление", Метаданные.Документы.ПоступлениеБезналичныхДенежныхСредств) Тогда
		ИмяИсточника = Метаданные.РегистрыСведений.ИдентификаторыОперацийСБПb2b.ПолноеИмя();
	Иначе
		Возврат;
	КонецЕсли;
	
	ДокументыОперации = ДокументыОперации(Ссылка);
	
	СхемаЗапроса = Новый СхемаЗапроса;
	ЗапросВыбора = СхемаЗапроса.ПакетЗапросов[0];
	ОператорВыбора = ЗапросВыбора.Операторы[0];
	ОператорВыбора.Источники.Добавить(ИмяИсточника, "ИдентификаторыОперацийСБП");
	ОператорВыбора.Отбор.Добавить("ИдентификаторыОперацийСБП.ДокументОперации В(&ДокументыОпераций)");
	ОператорВыбора.Отбор.Добавить("ИдентификаторыОперацийСБП.СтатусОперации <> &СтатусОперации");
	ОператорВыбора.Отбор.Добавить("ИдентификаторыОперацийСБП.ПлатежнаяСсылка <> """"");
	ОператорВыбора.ВыбираемыеПоля.Добавить("ДокументОперации");
	
	ТекстЗапроса = СхемаЗапроса.ПолучитьТекстЗапроса();
	
	Запрос = Новый Запрос;
	Запрос.Текст = ТекстЗапроса;
	Запрос.УстановитьПараметр("ДокументыОпераций", ДокументыОперации);
	Запрос.УстановитьПараметр("СтатусОперации", НастройкиПлатежныхСистемСлужебный.ИдентификаторСтатусаВыполнена());
	
	ОперацииДокументов = Запрос.Выполнить().Выгрузить();
	
	Если ОперацииДокументов.Количество() <> 0 Тогда
		
		Если ПараметрыКоманды.Родитель = Неопределено Тогда
			
			ГруппаРасчеты = Форма.Элементы.Найти("ГруппаЭтапыОплатыРасчеты");
			Если ГруппаРасчеты <> Неопределено Тогда
				ПараметрыКоманды.Родитель = ГруппаРасчеты;
			Иначе
				Возврат;
			КонецЕсли;
			
		КонецЕсли;
		
		Если ПараметрыКоманды.МестоРасположения = Неопределено Тогда
			
			СтруктураПараметров = ДенежныеСредстваСервер.ПараметрыПоТипуРасчетов(Ссылка, Перечисления.ТипыРасчетовСПартнерами.РасчетыСКлиентом);
			ЭлементРасчет = СтруктураПараметров.ЭлементыФормы.НадписьРасчеты;
			Если ЗначениеЗаполнено(ЭлементРасчет) Тогда
				ПараметрыКоманды.МестоРасположения = Форма.Элементы[ЭлементРасчет];
			КонецЕсли;
			
		КонецЕсли;
		
		Если Форма.Команды.Найти("ОбновитьСтатусОплатыСБП") = Неопределено Тогда
			
			КомандаОбновления = Форма.Команды.Добавить("ОбновитьСтатусОплатыСБП");
			КомандаОбновления.Действие = "Подключаемый_ОбновитьСтатусОплатыСБП";
			КомандаОбновления.Заголовок = НСтр("ru = 'Обновить статус оплаты СБП'");
			КомандаОбновления.Подсказка = НСтр("ru = 'Загружает статус операции СБП по документу'");
			КомандаОбновления.Отображение = ОтображениеКнопки.Текст;
			
		Иначе
			КомандаОбновления = Форма.Команды.Найти("ОбновитьСтатусОплатыСБП");
		КонецЕсли;
		
		Если Форма.Элементы.Найти("ОбновитьСтатусОплатыСБП") = Неопределено Тогда
		
			КнопкаФормы = Форма.Элементы.Добавить("ОбновитьСтатусОплатыСБП", Тип("КнопкаФормы"), ПараметрыКоманды.Родитель);
			КнопкаФормы.ИмяКоманды = "ОбновитьСтатусОплатыСБП";
			КнопкаФормы.Вид = ВидКнопкиФормы.Гиперссылка;
			КнопкаФормы.УникальностьКоманды = Истина;
			
			Форма.Элементы.Переместить(КнопкаФормы, КнопкаФормы.Родитель, ПараметрыКоманды.МестоРасположения);
			
		КонецЕсли;
		
	Иначе
		
		КомандаОбновления = Форма.Команды.Найти("ОбновитьСтатусОплатыСБП");
		
		Если КомандаОбновления <> Неопределено Тогда
			Форма.Команды.Удалить(КомандаОбновления);
		КонецЕсли;
		
	КонецЕсли;

КонецПроцедуры

// Возвращает фоновое задание на обновление статуса оплаты по документу.
// 
// Параметры:
//  ПараметрыПроцедуры - Структура - Параметры процедуры:
//  *ДокументСсылка - ДокументСсылка - ссылка на документ.
// 
// Возвращаемое значение:
//  Структура - Задание на обновление статуса оплаты по документу:
// * Статус - Строка - статус фонового задания.
// * ИдентификаторЗадания - Неопределено, УникальныйИдентификатор - идентификатор задания.
// * АдресРезультата - Строка - адрес временного хранилища, в которое будет помещен результат работы процедуры.
// * АдресДополнительногоРезультата - Строка - адрес дополнительного временного хранилища.
// * ИнформацияОбОшибке - Неопределено, ИнформацияОбОшибке - информация об ошибке.
// * КраткоеПредставлениеОшибки - Строка - краткое описание ошибки.
// * ПодробноеПредставлениеОшибки - Строка - подробное описание ошибки
// * Сообщения - ФиксированныйМассив из Строка - список сообщений, сформированный во время выполнения задания.
Функция ЗаданиеНаОбновлениеСтатусаОплатыПоДокументу(ПараметрыПроцедуры) Экспорт

	ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияВФоне(Новый УникальныйИдентификатор);
	ПараметрыВыполнения.НаименованиеФоновогоЗадания = НСтр("ru='Загрузка статуса оплаты СБП по документу'");
	ФоновоеЗадание = ДлительныеОперации.ВыполнитьВФоне("СистемаБыстрыхПлатежейУТ.АктуализироватьСтатусОплаты", ПараметрыПроцедуры, ПараметрыВыполнения);
	
	Возврат ФоновоеЗадание;

КонецФункции

// Возвращает список настроек подключения СБП b2b.
// 
// Параметры:
//  Организация - СправочникСсылка.Организации, Неопределено - Организация
//  БанковскийСчетОрганизации - СправочникСсылка.БанковскиеСчетаОрганизаций, Неопределено - Банковский счет организации
//  Склад - СправочникСсылка.Склады, Неопределено - Склад
// 
// Возвращаемое значение:
//  Массив из СправочникСсылка.НастройкиПодключенияКСистемеБыстрыхПлатежей
//
Функция НастройкиПодключенияB2B(Организация, БанковскийСчетОрганизации, Склад) Экспорт

	НастройкиПодключения = Новый Массив;
	СписокСкладов = Новый Массив;
	
	УстановитьПривилегированныйРежим(Истина);
	
	Если Склад <> Неопределено
		И Склад <> Справочники.Склады.ПустаяСсылка() Тогда
		
		СписокСкладов.Добавить(Склад);
		ГруппаСклада = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Склад, "Родитель");
		
		Пока ЗначениеЗаполнено(ГруппаСклада) Цикл
			
			СписокСкладов.Добавить(ГруппаСклада);
			ГруппаСклада = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ГруппаСклада, "Родитель");
			
		КонецЦикла;
		
	КонецЕсли;
	
	Если СписокСкладов.Найти(Справочники.Склады.ПустаяСсылка()) = Неопределено Тогда
		СписокСкладов.Добавить(Справочники.Склады.ПустаяСсылка());
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	НастройкиИнтеграции.Интеграция КАК Интеграция,
		|	НастройкиИнтеграции.Договор КАК Договор
		|ПОМЕСТИТЬ НастройкиИнтеграцииB2B
		|ИЗ
		|	РегистрСведений.НастройкиИнтеграцииСПлатежнымиСистемамиУТ КАК НастройкиИнтеграции
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.НастройкиПодключенияКСистемеБыстрыхПлатежей КАК НастройкиПодключенияКСистемеБыстрыхПлатежей
		|		ПО НастройкиИнтеграции.Интеграция = НастройкиПодключенияКСистемеБыстрыхПлатежей.Ссылка
		|			И (НастройкиИнтеграции.ВариантНастройки = ЗНАЧЕНИЕ(Перечисление.ВариантыНастройкиСБП.b2b))
		|			И (НастройкиПодключенияКСистемеБыстрыхПлатежей.Используется)
		|			И &УсловиеМагазина
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	НастройкиИнтеграцииB2B.Интеграция КАК Интеграция
		|ИЗ
		|	НастройкиИнтеграцииB2B КАК НастройкиИнтеграцииB2B
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ДоговорыЭквайринга КАК ДоговорыЭквайринга
		|		ПО НастройкиИнтеграцииB2B.Договор = ДоговорыЭквайринга.Ссылка
		|ГДЕ
		|	НЕ ДоговорыЭквайринга.ПометкаУдаления
		|	И (ДоговорыЭквайринга.Организация = &Организация
		|			ИЛИ &Организация = НЕОПРЕДЕЛЕНО)
		|	И (ДоговорыЭквайринга.БанковскийСчет = &БанковскийСчет
		|			ИЛИ &БанковскийСчет = НЕОПРЕДЕЛЕНО)";
	
	Запрос.УстановитьПараметр("Организация", ?(ЗначениеЗаполнено(Организация), Организация, Неопределено));
	Запрос.УстановитьПараметр("БанковскийСчет", ?(ЗначениеЗаполнено(БанковскийСчетОрганизации), БанковскийСчетОрганизации, Неопределено));
	
	Если Склад = Неопределено Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеМагазина", "ИСТИНА");
	Иначе
		
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеМагазина", "НастройкиИнтеграции.Магазин В (&Магазины)");
		Запрос.УстановитьПараметр("Магазины", СписокСкладов);
		
	КонецЕсли;
	
	ВыборкаДетальныеЗаписи = Запрос.Выполнить().Выбрать();
	
	УстановитьПривилегированныйРежим(Ложь);
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		НастройкиПодключения.Добавить(ВыборкаДетальныеЗаписи.Интеграция);
	КонецЦикла;
	
	Возврат НастройкиПодключения;

КонецФункции

// Возвращает список настроек подключения СБП c2b.
// 
// Параметры:
//  Организация - СправочникСсылка.Организации, Неопределено - Организация
//  Склад - СправочникСсылка.Склады, Неопределено - Склад
// 
// Возвращаемое значение:
//  Массив из СправочникСсылка.НастройкиПодключенияКСистемеБыстрыхПлатежей
//
Функция НастройкиПодключенияC2B(Организация, Склад) Экспорт

	НастройкиПодключения = Новый Массив;
	
	ТаблицаПодключенийСБППоОрганизации = Справочники.НастройкиРМК.СписокДоговоровИПодключенийСБП(
		Организация,,
		Склад);
	Для Каждого Строка Из ТаблицаПодключенийСБППоОрганизации Цикл
		Если НастройкиПодключения.Найти(Строка.НастройкаПодключения) = Неопределено Тогда
			НастройкиПодключения.Добавить(Строка.НастройкаПодключения);
		КонецЕсли;
	КонецЦикла;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	НастройкиИнтеграцииСПлатежнымиСистемамиУТ.Интеграция КАК НастройкаПодключения
	|ИЗ РегистрСведений.НастройкиИнтеграцииСПлатежнымиСистемамиУТ КАК НастройкиИнтеграцииСПлатежнымиСистемамиУТ
	|ГДЕ
	|	НастройкиИнтеграцииСПлатежнымиСистемамиУТ.Договор.Организация = &Организация
	|	И НастройкиИнтеграцииСПлатежнымиСистемамиУТ.Договор.ПометкаУдаления = ЛОЖЬ
	|	И НастройкиИнтеграцииСПлатежнымиСистемамиУТ.Магазин = &СкладПустой
	|	И НастройкиИнтеграцииСПлатежнымиСистемамиУТ.Интеграция.Используется = ИСТИНА
	|	И НастройкиИнтеграцииСПлатежнымиСистемамиУТ.ВариантНастройки = ЗНАЧЕНИЕ(Перечисление.ВариантыНастройкиСБП.c2b)";
	Запрос.УстановитьПараметр("Организация", Организация);
	Запрос.УстановитьПараметр("СкладПустой", Справочники.Склады.ПустаяСсылка());
	
	УстановитьПривилегированныйРежим(Истина);
	Выборка = Запрос.Выполнить().Выбрать();
	УстановитьПривилегированныйРежим(Ложь);
	
	Пока Выборка.Следующий() Цикл
		Если НастройкиПодключения.Найти(Выборка.НастройкаПодключения) = Неопределено Тогда
			НастройкиПодключения.Добавить(Выборка.НастройкаПодключения);
		КонецЕсли;
	КонецЦикла;
	
	Возврат НастройкиПодключения;

КонецФункции

// см. ПереводыСБПb2bПереопределяемый.ПриФормированииЗаказаНаОплатуСБП
Процедура ПриФормированииЗаказаНаОплатуСБПb2b(
		ДокументОплаты, ЗаказНаОплату, НастройкаПодключения, ДополнительныеПараметры, СтатическаяСсылка) Экспорт

	ИменаРеквизитов = Новый Соответствие;
	ИменаРеквизитов.Вставить("Номер", "Номер");
	ИменаРеквизитов.Вставить("Дата", "Дата");
	ИменаРеквизитов.Вставить("БанковскийСчетОрганизации.НомерСчета", "НомерСчета");
	ИменаРеквизитов.Вставить("ДокументОснование", "ДокументОснование");
	ИменаРеквизитов.Вставить("ИдентификаторПлатежа", "ИдентификаторПлатежа");
	ИменаРеквизитов.Вставить("ДатаПлатежа", "ДатаПлатежа");
	ИменаРеквизитов.Вставить("ПутьКДаннымТЧЭтапыОплаты", "ЭтапыОплаты");
	ИменаРеквизитов.Вставить("НазначениеПлатежа", "НазначениеПлатежа");
	ИменаРеквизитов.Вставить("ВалютаДокумента.Код", "КодВалюты");
	ИменаРеквизитов.Вставить("ВалютаДокумента.Наименование", "Валюта");
	ИменаРеквизитов.Вставить("ПорядокРасчетов", "ПорядокРасчетов");
	ИменаРеквизитов.Вставить("Договор", "Договор");
	ИменаРеквизитов.Вставить("ЭтоЗаказ", "ЭтоЗаказ");
	РеквизитыДокумента = ДенежныеСредстваСервер.ДанныеДокумента(
		ДокументОплаты, Перечисления.ТипыРасчетовСПартнерами.РасчетыСКлиентом, ИменаРеквизитов);
	
	ЗаказНаОплату.ОтложенноеПолучениеСтатуса = Истина;
	ЗаказНаОплату.РасчетныйСчет = РеквизитыДокумента.НомерСчета;
	
	Если ТипЗнч(ДокументОплаты) = Тип("ДокументСсылка.КорректировкаРеализации")
		И РеквизитыДокумента.ДокументОснование <> Неопределено Тогда
		ЗаказНаОплату.ИдентификаторПлатежа = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(РеквизитыДокумента.ДокументОснование, "ИдентификаторПлатежа");
	Иначе
		ЗаказНаОплату.ИдентификаторПлатежа = РеквизитыДокумента.ИдентификаторПлатежа;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(РеквизитыДокумента.ДатаПлатежа) Тогда
		ЗаказНаОплату.ДатаОплаты = РеквизитыДокумента.ДатаПлатежа;
	ИначеЕсли РеквизитыДокумента.ЭтапыОплаты <> Неопределено Тогда
		
		ПлановыеДатыОплаты = ПолучитьИзВременногоХранилища(РеквизитыДокумента.ЭтапыОплаты);
		ПлановыеДатыОплаты.Сортировать("ДатаПлатежа Убыв");
		ЗаказНаОплату.ДатаОплаты = ПлановыеДатыОплаты[0].ДатаПлатежа;
		
	КонецЕсли;
	
	ЗаказНаОплату.СрокЖизниQRКода = 129600;

	Если ЗначениеЗаполнено(ЗаказНаОплату.ДатаОплаты) Тогда
		
		СрокОплаты = Цел((КонецДня(ЗаказНаОплату.ДатаОплаты) - КонецЧаса(ТекущаяДатаСеанса())) / 60);
		
		Если СрокОплаты <= 129600
			И СрокОплаты >= 300 Тогда
			ЗаказНаОплату.СрокЖизниQRКода = СрокОплаты;
		ИначеЕсли СрокОплаты < 300 Тогда
			ЗаказНаОплату.СрокЖизниQRКода = 300;
		КонецЕсли;
		
	КонецЕсли;
	
	ТаблицаСумм = ДенежныеСредстваСервер.СуммыДокумента(ДокументОплаты, РеквизитыДокумента.ДокументОперации);
	
	ЗаказНаОплату.СуммаНДС = ТаблицаСумм.Итог("СуммаНДС");
	ЗаказНаОплату.СуммаОплаты = ТаблицаСумм.Итог("СуммаСНДС");
	ЗаказНаОплату.ОблагаетсяНДС = (ЗаказНаОплату.СуммаНДС <> 0);
	
	Отбор = Новый Структура;
	Отбор.Вставить("Идентификатор", ДокументОплаты.Метаданные().Имя);
	НайденныеСтроки = ЗаказНаОплату.ШаблоныНазначений.НайтиСтроки(Отбор);
	
	Если НайденныеСтроки.Количество() <> 0 Тогда
		ШаблонНазначения = НайденныеСтроки[0];
	Иначе
		ШаблонНазначения = Неопределено;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(РеквизитыДокумента.НазначениеПлатежа) Тогда
		ЗаказНаОплату.НазначениеПлатежа = РеквизитыДокумента.НазначениеПлатежа;
	ИначеЕсли ШаблонНазначения <> Неопределено Тогда
		ЗаказНаОплату.НазначениеПлатежа = СтрЗаменить(
			ШаблонНазначения.НазначениеПлатежа,
			"[Номер]",
			ПрефиксацияОбъектовКлиентСервер.НомерНаПечать(РеквизитыДокумента.Номер));
		ЗаказНаОплату.НазначениеПлатежа = СтрЗаменить(
			ЗаказНаОплату.НазначениеПлатежа,
			"[Дата]",
			Формат(РеквизитыДокумента.Дата, "ДЛФ=D"));
	ИначеЕсли ДокументОплаты <> РеквизитыДокумента.ДокументОперации Тогда
		
		ИменаРеквизитов = Новый Соответствие;
		ИменаРеквизитов.Вставить("Номер", "Номер");
		ИменаРеквизитов.Вставить("Дата", "Дата");
		ИменаРеквизитов.Вставить("ВалютаДокумента.Код", "КодВалюты");
		ИменаРеквизитов.Вставить("ВалютаДокумента.Наименование", "Валюта");
		ИменаРеквизитов.Вставить("ПорядокРасчетов", "ПорядокРасчетов");
		ИменаРеквизитов.Вставить("Договор", "Договор");
		ИменаРеквизитов.Вставить("ЭтоЗаказ", "ЭтоЗаказ");
		РеквизитыДокументаОснования = ДенежныеСредстваСервер.ДанныеДокумента(
			РеквизитыДокумента.ДокументОперации, Перечисления.ТипыРасчетовСПартнерами.РасчетыСКлиентом, ИменаРеквизитов);
		ЗаказНаОплату.НазначениеПлатежа = ДенежныеСредстваСервер.НазначениеПлатежаДокументаОперации(
			РеквизитыДокумента.ДокументОперации, РеквизитыДокументаОснования, ТаблицаСумм);
		
	Иначе
		ЗаказНаОплату.НазначениеПлатежа = 
			ДенежныеСредстваСервер.НазначениеПлатежаДокументаОперации(ДокументОплаты, РеквизитыДокумента, ТаблицаСумм);
	КонецЕсли;

КонецПроцедуры

// см. ПереводыСБПc2bПереопределяемый.ПриФормированииЗаказаНаОплатуСБП
//
Процедура ПриФормированииЗаказаНаОплатуСБПс2b(ДокументОплаты, ЗаказНаОплату, НастройкаПодключения, ДополнительныеПараметры) Экспорт
	
	Если ДополнительныеПараметры <> Неопределено Тогда
		
		ЗаказНаОплату.ДатаОплаты  = ДополнительныеПараметры.ДатаОплаты;
		ЗаказНаОплату.СуммаОплаты = ДополнительныеПараметры.СуммаОплаты;
		
	Иначе
		РеквизитыЗапроса   = Новый Структура("СуммаОплаты, ДатаОплаты, Договор", "СуммаДокумента", "Дата", "Договор");
		РеквизитыДокумента = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ДокументОплаты, РеквизитыЗапроса);
		МенеджерОбъекта = ОбщегоНазначения.МенеджерОбъектаПоСсылке(ДокументОплаты);
		
		Если ТипЗнч(ДокументОплаты) = Тип("ДокументСсылка.СчетНаОплатуКлиенту") Тогда
		ИначеЕсли ТипЗнч(ДокументОплаты) = Тип("ДокументСсылка.ЗаказКлиента") Тогда
			
			СостояниеВзаиморасчетов = Новый Структура;
			СостояниеВзаиморасчетов.Вставить("СуммаДолга", 0);
			СостояниеВзаиморасчетов.Вставить("СуммаОплаты", 0);
			СостояниеВзаиморасчетов.Вставить("ПроцентОплаты", 0);
			
			МенеджерОбъекта.РассчитатьСостояние(ДокументОплаты, РеквизитыДокумента.Договор, СостояниеВзаиморасчетов);
			
			Если СостояниеВзаиморасчетов.ПроцентОплаты > 0 Тогда 
				РеквизитыДокумента.СуммаОплаты  = РеквизитыДокумента.СуммаОплаты - СостояниеВзаиморасчетов.СуммаОплаты;
			КонецЕсли; 
			
		Иначе
			ПараметрыМеханизма = МенеджерОбъекта.ПараметрыВзаиморасчеты(ДокументОплаты);
			Если ТипЗнч(ПараметрыМеханизма) = Тип("Массив") Тогда
				МассивПараметров = ПараметрыМеханизма;
			Иначе
				МассивПараметров = ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(ПараметрыМеханизма);
			КонецЕсли;
			
			Для Каждого СтруктураПараметров Из МассивПараметров Цикл 
				СостояниеВзаиморасчетов = ВзаиморасчетыСервер.СостояниеВзаиморасчетов(ДокументОплаты, СтруктураПараметров)
			КонецЦикла;
			
			Если СостояниеВзаиморасчетов.ПроцентОплат > 0 Тогда
				РеквизитыДокумента.СуммаОплаты = 0;
				Если СостояниеВзаиморасчетов.СуммаЗадолженности > 0 Тогда
					РеквизитыДокумента.СуммаОплаты = СостояниеВзаиморасчетов.СуммаЗадолженности;
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
		
		ЗаполнитьЗначенияСвойств(ЗаказНаОплату, РеквизитыДокумента);
		
		ЗаполнитьЗначенияСвойств(ЗаказНаОплату, Новый Структура("ОтложенноеПолучениеСтатуса", Истина));
		ЗаполнитьЗначенияСвойств(ЗаказНаОплату, Новый Структура("СрокЖизниQRКода",			24*60*14)); // 14 дней
	КонецЕсли;
	
КонецПроцедуры

// см. ПереводыСБПb2bПереопределяемый.ПриЗагрузкеСтатусаОперации
Процедура ПриЗагрузкеСтатусаОперацииb2b(ДокументОперации, НастройкаПодключения, РезультатОбработки, Обработан) Экспорт

	Если ТипЗнч(РезультатОбработки.СтатусОперации) = Тип("Структура") Тогда
		СтатусОперации = РезультатОбработки.СтатусОперации.СтатусОперации;
	Иначе
		СтатусОперации = РезультатОбработки.СтатусОперации;
	КонецЕсли;
	
	Если СтатусОперации = НастройкиПлатежныхСистемКлиентСервер.СтатусОперацииВыполнена() Тогда
		
		ПараметрыОперации = РезультатОбработки.ПараметрыОперации;
		ПараметрыОплаты = ПараметрыПоступленияОплатыB2B(ДокументОперации, НастройкаПодключения, ПараметрыОперации);
		
		Если ПараметрыОплаты.ДокументОплаты = Неопределено Тогда
		
			ДокументОбъект = Документы.ПоступлениеБезналичныхДенежныхСредств.СоздатьДокумент();
			ДокументОбъект.Заполнить(ДокументОперации);
			ДокументОбъект.Дата = ПараметрыОперации.ДатаОперации;
			ДокументОбъект.ДатаВходящегоДокумента = ПараметрыОперации.ДатаОперации;
			ДокументОбъект.СуммаДокумента = ПараметрыОперации.СуммаОперации;
			ДокументОбъект.ИдентификаторПлатежа = ПараметрыОперации.ИдентификаторПлатежа;
			ДокументОбъект.ИдентификаторОперацииСБП = ПараметрыОперации.ИдентификаторОплаты;
			ДокументОбъект.ДополнительныеСвойства.Вставить("ОбменСБанками", Истина);
			
			Если ДокументОбъект.СуммаДокумента <> ДокументОбъект.РасшифровкаПлатежа.Итог("Сумма") Тогда
				
				ФинансыКлиентСервер.ПересчитатьСуммыВСтрокеРасшифровкиПлатежа(
					ДокументОбъект, ДокументОбъект.СуммаДокумента, Ложь);
				ПараметрыПересчетаНДС = Новый Структура("ЦенаВключаетНДС", Истина);
				СтруктураДействий = Новый Структура("ПересчитатьСуммуНДС", ПараметрыПересчетаНДС);
				ПакетнаяОбработкаТабличнойЧастиСервер.ОбработатьТЧ(ДокументОбъект.РасшифровкаПлатежа, СтруктураДействий, Неопределено);
			
				Для каждого СтрокаТЧ Из ДокументОбъект.РасшифровкаПлатежа Цикл
					ДенежныеСредстваКлиентСервер.РассчитатьСуммуВзаиморасчетовВСтрокеРасшифровки(
						СтрокаТЧ, ДокументОбъект.Валюта, ЗначениеНастроекПовтИсп.ВалютаРегламентированногоУчетаОрганизации(ДокументОбъект.Организация));
				КонецЦикла;
				
			КонецЕсли;
			
			Обработан = ЗаписатьДокументПОступленияОплатыB2B(ДокументОбъект);
			
		Иначе
			
			Если ПараметрыОплаты.ИдентификаторОперацииСБП <> ПараметрыОперации.ИдентификаторОплаты Тогда
				
				ДокументОбъект = ПараметрыОплаты.ДокументОплаты.ПолучитьОбъект();
				ДокументОбъект.ИдентификаторОперацииСБП = ПараметрыОперации.ИдентификаторОплаты;
				Обработан = ЗаписатьДокументПОступленияОплатыB2B(ДокументОбъект);
				
			Иначе
				Обработан = Истина;
				Возврат;
			КонецЕсли;
			
		КонецЕсли;
		
	Иначе
		Обработан = Истина;
	КонецЕсли;

КонецПроцедуры

// Возращает признак наличия активной платежной ссылки на оплату через СБП.
// 
// Параметры: 
//  ДокументСсылка - ДокументСсылка - Документ, для которого выполняется проверка.
//  Контрагент - СправочникСсылка.Контрагенты - плательщик по документу.
// 
// Возвращаемое значение:
//  Булево - признак наличия активной ссылки.
Функция ЕстьАктивнаяПлатежнаяСсылкаСБП(ДокументСсылка, Контрагент) Экспорт

	ВидКонтрагента = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Контрагент, "ЮрФизЛицо");
	
	Если ВидКонтрагента = Перечисления.ЮрФизЛицо.ФизЛицо Тогда
		ИмяИсточника = Метаданные.РегистрыСведений.ИдентификаторыОперацийСБПc2b.ПолноеИмя();
	ИначеЕсли ВидКонтрагента <> Перечисления.ЮрФизЛицо.ФизЛицо
		И ВидКонтрагента <> Перечисления.ЮрФизЛицо.ПустаяСсылка() Тогда
		ИмяИсточника = Метаданные.РегистрыСведений.ИдентификаторыОперацийСБПb2b.ПолноеИмя();
	Иначе
		Возврат Ложь;
	КонецЕсли;
	
	ДокументыОперации = ДокументыОперации(ДокументСсылка);
	
	СхемаЗапроса = Новый СхемаЗапроса;
	ЗапросВыбора = СхемаЗапроса.ПакетЗапросов[0];
	ОператорВыбора = ЗапросВыбора.Операторы[0];
	ОператорВыбора.Источники.Добавить(ИмяИсточника, "ИдентификаторыОперацийСБП");
	ОператорВыбора.Отбор.Добавить("ИдентификаторыОперацийСБП.ДокументОперации В (&ДокументыОпераций)");
	ОператорВыбора.ВыбираемыеПоля.Добавить("СтатусОперации");
	
	ТекстЗапроса = СхемаЗапроса.ПолучитьТекстЗапроса();
	Запрос = Новый Запрос;
	Запрос.Текст = ТекстЗапроса;
	Запрос.УстановитьПараметр("ДокументыОпераций", ДокументыОперации);
	
	УстановитьПривилегированныйРежим(Истина);
	РезультатЗапроса = Запрос.Выполнить();
	
	Если РезультатЗапроса.Пустой() Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Выборка = РезультатЗапроса.Выбрать();
	ЕстьСсылка = Ложь;
	
	Пока Выборка.Следующий() Цикл
		
		Если Выборка.СтатусОперации = НастройкиПлатежныхСистемСлужебный.ИдентификаторСтатусаВПроцессе() Тогда
			ЕстьСсылка = Истина;
			Прервать;
		Иначе
			ЕстьСсылка = Ложь;
		КонецЕсли;
		
	КонецЦикла;
	
	УстановитьПривилегированныйРежим(Ложь);
	
	Возврат ЕстьСсылка;

КонецФункции

#КонецОбласти

#Область СлужебныйПрограммныйИнтерфейс

// Возвращает заголовок надписи оплаты СБП.
// 
// Параметры:
//  Документ - ДокументСсылка - документ, в котором выводится надпись.
//  Входящая - Булево - признак направления платежной ссылки.
// 
// Возвращаемое значение:
//  ФорматированнаяСтрока - Текст надписи оплаты СБП
Функция ТекстНадписиОплатыСБП(Документ, Входящая = Ложь) Экспорт

	ПлатежнаяСсылка = Неопределено;
	
	Если Входящая Тогда
		
		Если ЗначениеЗаполнено(Документ) Тогда
			
			Отбор = Новый Структура;
			Отбор.Вставить("ДокументОперации", Документ);
			
			УстановитьПривилегированныйРежим(Истина);
			Выборка = РегистрыСведений.ВходящиеПлатежныеСсылкиСБП.Выбрать(Отбор);
			
			Пока Выборка.Следующий() Цикл
				
				Если ПлатежнаяСсылка = Неопределено Тогда
					ПлатежнаяСсылка = Новый Массив;
				КонецЕсли;
				
				ПлатежнаяСсылка.Добавить(Выборка);
				
			КонецЦикла;
			
			УстановитьПривилегированныйРежим(Ложь);
			
		КонецЕсли;
		
		Если ПлатежнаяСсылка = Неопределено
			Или (ПлатежнаяСсылка <> Неопределено
			И ПлатежнаяСсылка.Количество() = 0) Тогда
			
			ТекстСсылки = НСтр("ru = 'Ввести платежную ссылку'");
			ТекстЗаголовка = "<a href = ДобавлениеВходящейСсылки>" + ТекстСсылки + "</a>";
			
		ИначеЕсли ПлатежнаяСсылка.Количество() = 1 Тогда
			
			ТекстСсылки = 
				СтрШаблон(НСтр("ru = 'посмотреть платежную ссылку на сумму %1 руб.'"), ПлатежнаяСсылка[0].СуммаОперации);
			ТекстЗаголовка = "<a href = ДобавлениеВходящейСсылки>" + НСтр("ru = 'Добавить'") + "</a>"
							+ " или "
							+ "<a href = ПодробностиВходящейСсылки>" + ТекстСсылки + "</a>";
			
		Иначе
			
			ТекстСсылки = 
				СтрШаблон(НСтр("ru = 'открыть список платежных ссылок (%1)'"), ПлатежнаяСсылка.Количество());
			ТекстЗаголовка = "<a href = ДобавлениеВходящейСсылки>" + НСтр("ru = 'Добавить'") + "</a>"
							+ " или "
							+ "<a href = СписокВходящихСсылок>" + ТекстСсылки + "</a>";
			
		КонецЕсли;
		
	Иначе
		
		Если ЗначениеЗаполнено(Документ) Тогда
			
			УстановитьПривилегированныйРежим(Истина);
			
			ВидКонтрагента = ДенежныеСредстваСервер.ВидКонтрагентаДокументаОперации(
				Документ, Перечисления.ТипыРасчетовСПартнерами.РасчетыСКлиентом);
		
			Если ВидКонтрагента = Перечисления.ЮрФизЛицо.ФизЛицо Тогда
				ПлатежнаяСсылка = РегистрыСведений.ИдентификаторыОперацийСБПc2b.ДанныеПлатежнойСсылки(Документ);
			ИначеЕсли ВидКонтрагента <> Перечисления.ЮрФизЛицо.ПустаяСсылка() Тогда
				ПлатежнаяСсылка = РегистрыСведений.ИдентификаторыОперацийСБПb2b.ДанныеПлатежнойСсылки(Документ);
			КонецЕсли;
			
			УстановитьПривилегированныйРежим(Ложь);
			
		КонецЕсли;
		
		Если ПлатежнаяСсылка = Неопределено
			Или ПустаяСтрока(ПлатежнаяСсылка.ПлатежнаяСсылка) Тогда
			
			ТекстСсылки = НСтр("ru = 'Получить платежную ссылку СБП'");
			ТекстЗаголовка = "<a href = ОтправкаИсходящейСсылки>" + ТекстСсылки + "</a>";
			
		Иначе
			
			ТекстСсылки = 
				СтрШаблон(НСтр("ru = 'Отправить платежную ссылку на сумму %1 руб.'"), ПлатежнаяСсылка.СуммаОперации);
			ТекстЗаголовка = "<a href = ОтправкаИсходящейСсылки>" + ТекстСсылки + "</a>"
							+ " или "
							+ "<a href = ПодробностиИсходящейСсылки>" + НСтр("ru = 'посмотреть сведения'") + "</a>";
			
		КонецЕсли;
		
	КонецЕсли;
	
	ТекстЗаголовка = СтроковыеФункции.ФорматированнаяСтрока(ТекстЗаголовка);
	
	Возврат ТекстЗаголовка;

КонецФункции

// Возвращает ключ записи регистра сведений, хранящий идентификатор СБП по документу.
// 
// Параметры:
//  Документ - ДокументСсылка - документ, по которому выполняется поиск идентификатора в регистре.
// 
// Возвращаемое значение:
//  РегистрСведенийКлючЗаписи.ИдентификаторыОперацийСБПc2b, РегистрСведенийКлючЗаписи.ИдентификаторыОперацийСБПb2b - Ключ записи идентификатора СБППо документу
Функция КлючЗаписиИдентификатораСБППоДокументу(Документ) Экспорт

	ВидКонтрагента = ДенежныеСредстваСервер.ВидКонтрагентаДокументаОперации(
		Документ, Перечисления.ТипыРасчетовСПартнерами.РасчетыСКлиентом);
	
	Отбор = Новый Структура;
	Отбор.Вставить("ДокументОперации", Документ);
	
	Если ВидКонтрагента = Перечисления.ЮрФизЛицо.ФизЛицо Тогда
		Возврат РегистрыСведений.ИдентификаторыОперацийСБПc2b.СоздатьКлючЗаписи(Отбор);
	Иначе
		Возврат РегистрыСведений.ИдентификаторыОперацийСБПb2b.СоздатьКлючЗаписи(Отбор);
	КонецЕсли;

КонецФункции

// Возвращает ключ записи регистра сведений, хранящий входящие ссылки СБП.
// 
// Параметры:
//  Документ - ДокументСсылка - документ, по которому выполняется поиск платежной ссылки.
// 
// Возвращаемое значение:
//  РегистрСведенийКлючЗаписи.ВходящиеПлатежныеСсылкиСБП - Ключ записи входящей ссылки СБП.
//
Функция КлючЗаписиВходящейСсылкиСБП(Документ) Экспорт

	Отбор = Новый Структура;
	Отбор.Вставить("ДокументОперации", Документ);
	
	Выборка = РегистрыСведений.ВходящиеПлатежныеСсылкиСБП.Выбрать(Отбор);
	
	Пока Выборка.Следующий() Цикл
		
		Отбор.Вставить("ПлатежнаяСсылка", Выборка.ПлатежнаяСсылка);
		Прервать;
		
	КонецЦикла;
	
	Возврат РегистрыСведений.ВходящиеПлатежныеСсылкиСБП.СоздатьКлючЗаписи(Отбор);

КонецФункции

#Область ВходящиеСсылки

// Возвращает признак наличия или отсутствия ошибки при проверке документа.
// 
// Параметры:
//  Данные - Структура - данные документа, в котором выполняется проверка.
//  Ошибка - Булево - признак наличия ошибки.
//
Процедура ПроверитьДанныеДокументаДляВводаПлатежнойСсылки(Данные, Ошибка) Экспорт

	Если Данные.ВидКонтрагента = Перечисления.ЮрФизЛицо.ФизЛицо Тогда
		
		ТекстСообщения = НСтр("ru = 'Доступен ввод платежных ссылок только от юрлиц и ИП.'");
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения, , , , Ошибка);
		Возврат;
		
	КонецЕсли;
	
	СписокОшибок = Новый Массив;
	
	ПроверитьПорядокРасчетов(СписокОшибок, Данные);
	
	Если СписокОшибок.Количество() > 0 Тогда
		
		ТекстСообщения = СтрСоединить(СписокОшибок, Символы.ПС);
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения, , , , Ошибка);
		
	КонецЕсли;

КонецПроцедуры

// Возвращает настройки подключения к СБП с параметрами, если настройки не найдено.
// 
// Параметры:
//  Организация - СправочникСсылка.Организации - организация настройки.
//  БанковскийСчетОрганизации - Неопределено, СправочникСсылка.БанковскиеСчетаОрганизаций - банковский счет настройки.
//  Склад - СправочникСсылка.Склады - склад.
//  ВидКонтрагента - ПеречислениеСсылка.ЮрФизЛицо - вид контрагента.
// 
// Возвращаемое значение:
//  Структура - параметры настройки:
//  *НастройкиПодключения - Неопределено, Массив из СправочникСсылка.НастройкиПодключенияКСистемеБыстрыхПлатежей - список настроек подключений к СБП.
//  *ДоступноПодключение - Булево - признак доступности создания настройки подключения к СБП.
//  *ДополнительныеНастройки - Структура - дополнительные настройки для создания новой настройки подключения:
//  **БИК - Неопределено - БИК банка.
//  **ОтборУчастников - Неопределено - параметры отбора участников СБП.
//  **ДополнительныеПараметры - Неопределено - дополнительные параметры определения настройки СБП.
//  **ВариантНастройки - Неопределено, Строка - вариант настройки подключения.
Функция НастройкиПодключения(Организация, БанковскийСчетОрганизации, Склад, ВидКонтрагента) Экспорт

	Результат = ИнициализироватьПараметрыНастроекПодключения();
	
	Если ВидКонтрагента = Перечисления.ЮрФизЛицо.ФизЛицо Тогда
		Результат.ДополнительныеНастройки.ВариантНастройки = "c2b";
		Результат.НастройкиПодключения = НастройкиПодключенияC2B(Организация, Склад);
	ИначеЕсли ЗначениеЗаполнено(ВидКонтрагента) Тогда
		Результат.ДополнительныеНастройки.ВариантНастройки = "b2b";
		Результат.НастройкиПодключения = НастройкиПодключенияB2B(Организация, БанковскийСчетОрганизации, Склад);
	КонецЕсли;
	
	Возврат Результат;

КонецФункции

// Возвращает параметры настройки подключения СБП.
// 
// Параметры:
//  Настройка - СправочникСсылка.НастройкиПодключенияКСистемеБыстрыхПлатежей - Настройка подключения.
// 
// Возвращаемое значение:
//  Структура - Данные настройки подключения:
// * ВариантНастройки - Неопределено, ПеречислениеСсылка.ВариантыНастройкиСБП - вариант настройки.
// * Организация - Неопределено, СправочникСсылка.Организации - организация настройки.
// * БанковскийСчет - Неопределено, СправочникСсылка.БанковскиеСчетаОрганизаций - банковский счет настройки.
// * Договор - Неопределено, СправочникСсылка.ДоговорыЭквайринга - договор подключения.
// * Магазин - Неопределено, СправочникСсылка.Склады - склад настройки.
//
Функция ДанныеНастройкиПодключения(Настройка) Экспорт

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	НастройкиИнтеграцииСПлатежнымиСистемамиУТ.ВариантНастройки КАК ВариантНастройки,
		|	ДоговорыЭквайринга.Организация КАК Организация,
		|	ДоговорыЭквайринга.БанковскийСчет КАК БанковскийСчет,
		|	НастройкиИнтеграцииСПлатежнымиСистемамиУТ.Договор КАК Договор,
		|	НастройкиИнтеграцииСПлатежнымиСистемамиУТ.Магазин КАК Магазин
		|ИЗ
		|	РегистрСведений.НастройкиИнтеграцииСПлатежнымиСистемамиУТ КАК НастройкиИнтеграцииСПлатежнымиСистемамиУТ
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ДоговорыЭквайринга КАК ДоговорыЭквайринга
		|		ПО НастройкиИнтеграцииСПлатежнымиСистемамиУТ.Договор = ДоговорыЭквайринга.Ссылка
		|			И (НастройкиИнтеграцииСПлатежнымиСистемамиУТ.Интеграция = &Интеграция)";
	
	Запрос.УстановитьПараметр("Интеграция", Настройка);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Результат = Новый Структура;
	Результат.Вставить("ВариантНастройки", Неопределено);
	Результат.Вставить("Организация", Неопределено);
	Результат.Вставить("БанковскийСчет", Неопределено);
	Результат.Вставить("Договор", Неопределено);
	Результат.Вставить("Магазин", Неопределено);
	
	Пока Выборка.Следующий() Цикл
		
		Результат.ВариантНастройки = Выборка.ВариантНастройки;
		Результат.Организация = Выборка.Организация;
		Результат.БанковскийСчет = Выборка.БанковскийСчет;
		Результат.Договор = Выборка.Договор;
		Результат.Магазин = Выборка.Магазин;
		
	КонецЦикла;
	
	Возврат Результат;

КонецФункции

#КонецОбласти

// Выполняет загрузку статусов операций в регистр ИдентификаторыОперацийСБПb2b и создает документы поступления оплаты.
//
// Параметры:
//  ПараметрыПроцедуры - Структура - параметры процедуры.
//  АдресХранилища - Строка - адрес результата.
//
Процедура ЗагрузкаСтатусовОпераций(ПараметрыПроцедуры, АдресХранилища) Экспорт

	ЗамерПроизводительности = ОценкаПроизводительности.НачатьЗамерДлительнойОперации(
		"СистемаБыстрыхПлатежей.ЗагрузитьСтатусыОпераций");
	
	ОбработанныеОперации = СистемаБыстрыхПлатежей.СтатусыОпераций();
	
	Результат = Новый Соответствие;
	
	Для Итерация = 1 По 2 Цикл
		
		Если Итерация = 1 Тогда
			СведенияОбОперациях = РегистрыСведений.ИдентификаторыОперацийСБПc2b.ДанныеОпераций(ОбработанныеОперации);
		Иначе
			СведенияОбОперациях = РегистрыСведений.ИдентификаторыОперацийСБПb2b.ДанныеОпераций(ОбработанныеОперации);
		КонецЕсли;
		
		Для Каждого Операция Из СведенияОбОперациях Цикл
			
			Если Операция.Значение <> Неопределено
				И Операция.Значение.СтатусОперации = НастройкиПлатежныхСистемСлужебный.ИдентификаторСтатусаВыполнена() Тогда
				Результат.Вставить(Операция, 1);
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЦикла;
	
	ПоместитьВоВременноеХранилище(Результат, АдресХранилища);
	
	ОценкаПроизводительности.ЗакончитьЗамерДлительнойОперации(
		ЗамерПроизводительности, ОбработанныеОперации.Количество());

КонецПроцедуры

// Обновляет статусы оплат по документу платежной ссылки и создает документы оплаты.
// 
// Параметры:
//  ПараметрыПроцедуры - Структура:
//   *ДокументСсылка - ДокументСсылка - документ платежной ссылки, в котором выполняется обновление статуса СБП.
//  АдресХранилища - Строка - адрес результата.
Процедура АктуализироватьСтатусОплаты(ПараметрыПроцедуры, АдресХранилища) Экспорт

	ЗамерПроизводительности = ОценкаПроизводительности.НачатьЗамерДлительнойОперации(
		"СистемаБыстрыхПлатежей.ЗагрузитьСтатусыОплатыПоДокументу");
	
	ДокументыОперации = ДокументыОперации(ПараметрыПроцедуры.ДокументСсылка);
	
	ВидКонтрагента = ДенежныеСредстваСервер.ВидКонтрагентаДокументаОперации(
		ПараметрыПроцедуры.ДокументСсылка, Перечисления.ТипыРасчетовСПартнерами.РасчетыСКлиентом);
	
	СхемаЗапроса = Новый СхемаЗапроса;
	ЗапросВыбора = СхемаЗапроса.ПакетЗапросов[0];
	ОператорВыбора = ЗапросВыбора.Операторы[0];
	
	Если ВидКонтрагента = Перечисления.ЮрФизЛицо.ФизЛицо Тогда
		ОператорВыбора.Источники.Добавить(Метаданные.РегистрыСведений.ИдентификаторыОперацийСБПc2b.ПолноеИмя(), "ИдентификаторыОперацийСБП");
	Иначе
		ОператорВыбора.Источники.Добавить(Метаданные.РегистрыСведений.ИдентификаторыОперацийСБПb2b.ПолноеИмя(), "ИдентификаторыОперацийСБП");
	КонецЕсли;
	
	ОператорВыбора.Отбор.Добавить("ИдентификаторыОперацийСБП.ДокументОперации В(&ДокументыОпераций)");
	
	ОператорВыбора.ВыбираемыеПоля.Добавить("ИдентификаторОперации");
	ОператорВыбора.ВыбираемыеПоля.Добавить("ДатаОперации");
	ОператорВыбора.ВыбираемыеПоля.Добавить("СуммаОперации");
	ОператорВыбора.ВыбираемыеПоля.Добавить("ДокументОперации");
	ОператорВыбора.ВыбираемыеПоля.Добавить("НастройкаПодключения");
	ОператорВыбора.ВыбираемыеПоля.Добавить("НастройкаПодключения.ВариантНастройки");
	ОператорВыбора.ВыбираемыеПоля.Добавить("ПлатежнаяСсылка");
	ОператорВыбора.ВыбираемыеПоля.Добавить("СтатусОперации");
	
	ТекстЗапроса = СхемаЗапроса.ПолучитьТекстЗапроса();
	
	Запрос = Новый Запрос;
	Запрос.Текст = ТекстЗапроса;
	Запрос.УстановитьПараметр("ДокументыОпераций", ДокументыОперации);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Результат = Новый Массив;
	
	ОценкаПроизводительности.ЗафиксироватьЗамерДлительнойОперации(ЗамерПроизводительности, 0, "ПоискДокументов");
	
	Для Каждого ДокументОперации Из ДокументыОперации Цикл
		
		ПараметрыОтбора = Новый Структура;
		ПараметрыОтбора.Вставить("ДокументОперации", ДокументОперации);
		
		Если Выборка.НайтиСледующий(ПараметрыОтбора) Тогда
			
			Если Выборка.СтатусОперации = НастройкиПлатежныхСистемСлужебный.ИдентификаторСтатусаВыполнена() Тогда
				Продолжить;
			КонецЕсли;
			
			ПараметрыОперации = Новый Структура;
			ПараметрыОперации.Вставить("ДатаОперации", Выборка.ДатаОперации);
			ПараметрыОперации.Вставить("СуммаОперации", Выборка.СуммаОперации);
			ПараметрыОперации.Вставить("ИдентификаторОперации", Выборка.ИдентификаторОперации);
			ПараметрыОперации.Вставить("ПлатежнаяСсылка", Выборка.ПлатежнаяСсылка);

			РезультатОперации = СистемаБыстрыхПлатежейСлужебный.АктуализироватьСтатусОплаты(
				ДокументОперации, Выборка.НастройкаПодключения, ПараметрыОперации, Неопределено);
			
			РезультатОперации.Вставить("Документ", ДокументОперации);
			РезультатОперации.Вставить("ВариантНастройки", Выборка.НастройкаПодключенияВариантНастройки);
			Результат.Добавить(РезультатОперации);
			
		КонецЕсли;
		
	КонецЦикла;
	
	ПоместитьВоВременноеХранилище(Результат, АдресХранилища);
	
	ОценкаПроизводительности.ЗакончитьЗамерДлительнойОперации(ЗамерПроизводительности, Результат.Количество());

КонецПроцедуры

// Формирует данные заполнения по платежной ссылке СБПb2b.
// 
// Параметры:
//  ПараметрыПроцедуры - Структура - Параметры процедуры:
//  *НастройкаПодключения - СправочникСсылка.НастройкиПодключенияКСистемеБыстрыхПлатежей - Настройка подключения.
//  *ПлатежнаяСсылка - Строка - Платежная ссылка.
//  АдресХранилищаРезультата - Строка - адрес результата.
Процедура ДанныеЗаполненияПоПлатежнойСсылкеСБПb2b(ПараметрыПроцедуры, АдресХранилищаРезультата) Экспорт

	РезультатПроверки = СистемаБыстрыхПлатежейКлиентСервер.СтруктураURLФункциональнойСсылки(
		ПараметрыПроцедуры.ПлатежнаяСсылка, Истина);
		
	ДанныеЗаполнения = Новый Структура;
	ДанныеЗаполнения.Вставить("КодОшибки", 1);
	ДанныеЗаполнения.Вставить("СообщениеОбОшибке", НСтр("ru = 'Неверный формат платежной ссылки.'"));
	
	Если Не РезультатПроверки.URLВалиден Тогда
		ПоместитьВоВременноеХранилище(ДанныеЗаполнения, АдресХранилищаРезультата);
		Возврат;
	КонецЕсли;
	
	Результат = ДанныеПолучателяПоПлатежнойСсылкеСБПb2b(ПараметрыПроцедуры.ПлатежнаяСсылка, ПараметрыПроцедуры.НастройкаПодключения);
	
	ДанныеЗаполнения.Вставить("КодОшибки", Результат.КодОшибки);
	ДанныеЗаполнения.Вставить("СообщениеОбОшибке", Результат.СообщениеОбОшибке);
	
	Если ЗначениеЗаполнено(Результат.КодОшибки) Тогда
		ПоместитьВоВременноеХранилище(ДанныеЗаполнения, АдресХранилищаРезультата);
		Возврат;
	КонецЕсли;
	
	ДанныеСсылки = Результат.ДанныеСсылки;
	
	ДанныеЗаполнения.Вставить("ПлатежнаяСсылка", ПараметрыПроцедуры.ПлатежнаяСсылка);
	ОбщегоНазначенияКлиентСервер.ДополнитьСтруктуру(ДанныеЗаполнения, ДанныеСсылки, Истина);
	ДанныеЗаполнения.Вставить("ИдентификаторОперации", РезультатПроверки.СтруктураURI.ПутьНаСервере);
	
	ДанныеНастройки = ДанныеНастройкиПодключения(ПараметрыПроцедуры.НастройкаПодключения);
	ДанныеЗаполнения.Вставить("НастройкаПодключения", ПараметрыПроцедуры.НастройкаПодключения);
	ДанныеЗаполнения.Вставить("Организация", ДанныеНастройки.Организация);
	ДанныеЗаполнения.Вставить("БанковскийСчет", ДанныеНастройки.БанковскийСчет);
	ДанныеЗаполнения.Вставить("ИдентификаторПлатежа", ДанныеСсылки.ИдентификаторОплаты);
	
	ДанныеЗаполнения.Вставить("ФормаОплатыЗаявки", Перечисления.ФормыОплаты.СистемаБыстрыхПлатежей);
	ДанныеЗаполнения.Вставить("ФормаОплатыНаличная", Ложь);
	ДанныеЗаполнения.Вставить("ФормаОплатыПлатежнаяКарта", Ложь);
	ДанныеЗаполнения.Вставить("ФормаОплатыБезналичная", Истина);
	
	ПоместитьВоВременноеХранилище(ДанныеЗаполнения, АдресХранилищаРезультата);

КонецПроцедуры

// Возвращает список документов, связанных с документом.
// 
// Параметры:
//  ДокументОснование - ДокументСсылка - Документ основание
// 
// Возвращаемое значение:
//  Массив из ОпределяемыйТип.ДокументОперацииСБП, ДокументСсылка.СчетНаОплатуКлиенту - Документы операции
Функция ДокументыОперации(ДокументОснование) Экспорт

	ДокументыОперации = Новый Массив;
	ДокументыОперации.Добавить(ДокументОснование);
	
	ДанныеДокумента = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ДокументОснование, "ПорядокРасчетов, Договор");
	
	Основание = Новый Массив;
	
	Если ДанныеДокумента.ПорядокРасчетов = Перечисления.ПорядокРасчетов.ПоДоговорамКонтрагентов
		Или ДанныеДокумента.ПорядокРасчетов = Перечисления.ПорядокРасчетов.ПоДоговорамНакладным Тогда
		Основание.Добавить(ДанныеДокумента.Договор);
	КонецЕсли;
	
	Если ДанныеДокумента.ПорядокРасчетов <> Перечисления.ПорядокРасчетов.ПоДоговорамКонтрагентов Тогда
		Основание.Добавить(ДокументОснование);
	КонецЕсли;
	
	Если ПравоДоступа("Чтение", Метаданные.Документы.СчетНаОплатуКлиенту) Тогда
		
		Запрос = Новый Запрос;
		Запрос.Текст = 
			"ВЫБРАТЬ РАЗРЕШЕННЫЕ
			|	СчетНаОплатуКлиенту.Ссылка КАК Ссылка
			|ИЗ
			|	Документ.СчетНаОплатуКлиенту КАК СчетНаОплатуКлиенту
			|ГДЕ
			|	СчетНаОплатуКлиенту.ДокументОснование В (&ДокументОснование)
			|	И СчетНаОплатуКлиенту.Проведен";
		
		Запрос.УстановитьПараметр("ДокументОснование", Основание);
		
		Выборка = Запрос.Выполнить().Выбрать();
		
		Пока Выборка.Следующий() Цикл
			ДокументыОперации.Добавить(Выборка.Ссылка);
		КонецЦикла;
		
	КонецЕсли;
	
	Возврат ДокументыОперации;

КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Процедура ЗаполнитьШаблон(НастройкиШаблонов, ШаблонНаименованиеПисьма, ШаблонНаименованиеСМС)

	СписокИменДокументов = Новый Массив;
	ПриОпределенииОбъектовСКомандамиСБП(СписокИменДокументов);
	
	НастройкиШаблоновСообщений = ШаблоныСообщенийСлужебныйПовтИсп.ПриОпределенииНастроек();
	
	ТекстДействие = НСтр("ru = 'Для оплаты отсканируйте QR-код в Вашем мобильном банковском приложении или перейдите по ссылке для  выбора приложения банка.'");
	ШаблонТема = НСтр("ru = 'Реквизиты для оплаты: %1'");
	ШаблонТекстаПисьма = ТекстШаблонаПисьмаСБП();
	ШаблонТекстаСМС = ТекстШаблонаСМССБП();
	
	Для Каждого ТекущееИмя Из СписокИменДокументов Цикл
		
		ПредметШаблона = НастройкиШаблоновСообщений.ПредметыШаблонов.Найти(ТекущееИмя, "Имя");
		
		Если ПредметШаблона = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		НайденШаблонПисьма = Ложь;
		НайденШаблонСМС = Ложь;
		
		Для Каждого НастройкаШаблона Из НастройкиШаблонов Цикл
			
			Если НастройкаШаблона.ПолноеИмяТипаНазначения = ТекущееИмя Тогда
				
				Если НастройкаШаблона.ТипШаблона = "Письмо" Тогда
					НайденШаблонПисьма = Истина;
				ИначеЕсли НастройкаШаблона.ТипШаблона = "SMS" Тогда
					НайденШаблонСМС = Истина;
				КонецЕсли;
				
				Если НайденШаблонПисьма
					И НайденШаблонСМС Тогда
					Прервать;
				КонецЕсли;
				
			КонецЕсли;
			
		КонецЦикла;
		
		Если НайденШаблонПисьма
			И НайденШаблонСМС Тогда
			Продолжить;
		КонецЕсли;
		
		ОбъектДокумент = Метаданные.НайтиПоПолномуИмени(ТекущееИмя);
		НаименованиеПисьма = СтрШаблон(ШаблонНаименованиеПисьма, ОбъектДокумент.Синоним);
		НаименованиеСМС = СтрШаблон(ШаблонНаименованиеСМС, ОбъектДокумент.Синоним);
		СтандартныеРеквизитыДокумента = ОбъектДокумент.СтандартныеРеквизиты; // ОписанияСтандартныхРеквизитов
		
		Номер = СтрШаблон("[%1.%2]", ОбъектДокумент.Имя, СтандартныеРеквизитыДокумента.Номер.Имя);
		Дата = СтрШаблон("[%1.%2{ДЛФ=''dd.MM.yyyy''}]", ОбъектДокумент.Имя, СтандартныеРеквизитыДокумента.Дата.Имя);
		
		СведенияДокумента = СтрШаблон(НСтр("ru = '%1 от %2'"), Номер, Дата);
		
		РеквизитыДокумента = ОбъектДокумент.Реквизиты;
		
		Если РеквизитыДокумента.Найти("СуммаДокумента") <> Неопределено Тогда
			
			СуммаДокумента = СтрШаблон("[%1.%2]", ОбъектДокумент.Имя, РеквизитыДокумента.СуммаДокумента.Имя);
			СведенияДокумента = СтрШаблон(НСтр("ru = '%1 на сумму %2 руб.'"), СведенияДокумента, СуммаДокумента)
			
		Иначе
			СуммаДокумента = "СуммаСсылкиСБП";
		КонецЕсли;
		
		Тема = СтрШаблон(ШаблонТема, СведенияДокумента);
		ТипСправочникаПартнеры = Новый ОписаниеТипов("СправочникСсылка.Партнеры");
		
		Если РеквизитыДокумента.Найти("Партнер") <> Неопределено
			И РеквизитыДокумента.Партнер.Тип = ТипСправочникаПартнеры Тогда
			Покупатель = СтрШаблон("[%1.%2]", ОбъектДокумент.Имя, НСтр("ru = 'ПартнерНаименование'"));
		Иначе
			Покупатель = "";
		КонецЕсли;
		
		ПредставлениеСсылкиСБПQRКод = СтрШаблон("[%1.%2]", ОбъектДокумент.Имя, НСтр("ru = 'ПредставлениеСсылкиСБПQRКод'"));
		ПредставлениеСсылкиСБП = СтрШаблон("[%1.%2]", ОбъектДокумент.Имя, НСтр("ru = 'ПредставлениеСсылкиСБП'"));
		
		ТекстШаблонаПисьма = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
			ШаблонТекстаПисьма,
			НСтр("ru = 'Благодарим за заказ и просим оплатить.'"),
			Покупатель,
			Номер,
			Дата,
			СтрШаблон(НСтр("ru = '%1 руб.'"), СуммаДокумента),
			ТекстДействие,
			ПредставлениеСсылкиСБПQRКод,
			ПредставлениеСсылкиСБП);
		
		ТекстШаблонаСМС = СтрШаблон(
			ШаблонТекстаСМС,
			НСтр("ru = 'Благодарим за заказ и просим оплатить.'"),
			СтрШаблон(НСтр("ru = '%1 руб.'"), СуммаДокумента),
			ПредставлениеСсылкиСБП);
		
		ШаблонПисьма = ШаблонЭлектронногоПисьмаСБП(ТекущееИмя, ТекстШаблонаПисьма, НаименованиеПисьма, Тема);
		ШаблонСМС = ШаблонПисьмаСМССБП(ТекущееИмя, ТекстШаблонаСМС, НаименованиеСМС, Тема);
		
		НастройкиШаблонов.Добавить(ШаблонПисьма);
		НастройкиШаблонов.Добавить(ШаблонСМС);
		
	КонецЦикла;

КонецПроцедуры

