// Проверяет заполнение платежной ссылки в заявке на оплату.
//
// Параметры:
//  ДокументОбъект - ДокументОбъект.ЗаявкаНаРасходованиеДенежныхСредств - заявка на оплату.
//  Ошибка - Булево - признак наличия ошибки.
//
Процедура ПроверитьЗаполнениеПлатежнойСсылкиСБП(ДокументОбъект, Ошибка) Экспорт
	
	Если Не ЗначениеЗаполнено(ДокументОбъект.ПлатежнаяСсылкаСБП) Тогда
		Возврат;
	КонецЕсли;
	
	ОбъектыРасчетов = ДокументОбъект.РасшифровкаПлатежа.ВыгрузитьКолонку("ОбъектРасчетов");
	ОбъектыРасчетов = ОбщегоНазначенияКлиентСервер.СвернутьМассив(ОбъектыРасчетов);
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ОбъектыРасчетов.Ссылка КАК ОбъектРасчетов,
		|	ЕСТЬNULL(ВходящиеПлатежныеСсылкиСБП.ПлатежнаяСсылка, """") КАК ПлатежнаяСсылка,
		|	ЕСТЬNULL(ВходящиеПлатежныеСсылкиСБП.ТипСсылки, """") КАК ТипСсылки,
		|	ЕСТЬNULL(ВходящиеПлатежныеСсылкиСБП.ПроверкаПройдена, ИСТИНА) КАК ПроверкаПройдена
		|ПОМЕСТИТЬ ПлатежныеСсылкиОбъектовРасчетов
		|ИЗ
		|	Справочник.ОбъектыРасчетов КАК ОбъектыРасчетов
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ВходящиеПлатежныеСсылкиСБП КАК ВходящиеПлатежныеСсылкиСБП
		|		ПО ОбъектыРасчетов.Объект = ВходящиеПлатежныеСсылкиСБП.ДокументОперации
		|ГДЕ
		|	ОбъектыРасчетов.Ссылка В(&ОбъектыРасчетов)
		|
		|СГРУППИРОВАТЬ ПО
		|	ОбъектыРасчетов.Ссылка,
		|	ЕСТЬNULL(ВходящиеПлатежныеСсылкиСБП.ПлатежнаяСсылка, """"),
		|	ЕСТЬNULL(ВходящиеПлатежныеСсылкиСБП.ТипСсылки, """"),
		|	ЕСТЬNULL(ВходящиеПлатежныеСсылкиСБП.ПроверкаПройдена, ИСТИНА)
		|
		|ИМЕЮЩИЕ
		|	МАКСИМУМ(ВЫБОР
		|			КОГДА ЕСТЬNULL(ВходящиеПлатежныеСсылкиСБП.ПлатежнаяСсылка, """") = """"
		|				ТОГДА ИСТИНА
		|			КОГДА ЕСТЬNULL(ВходящиеПлатежныеСсылкиСБП.ПлатежнаяСсылка, """") = &ПлатежнаяСсылка
		|				ТОГДА ИСТИНА
		|			ИНАЧЕ ЛОЖЬ
		|		КОНЕЦ) = ЛОЖЬ
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ПлатежныеСсылкиОбъектовРасчетов.ОбъектРасчетов КАК ОбъектРасчетов,
		|	МАКСИМУМ(ВЫБОР
		|			КОГДА ПлатежныеСсылкиОбъектовРасчетов.ПлатежнаяСсылка = """"
		|					ИЛИ ПлатежныеСсылкиОбъектовРасчетов.ПлатежнаяСсылка = &ПлатежнаяСсылка
		|						И ПлатежныеСсылкиОбъектовРасчетов.ПроверкаПройдена
		|				ТОГДА ИСТИНА
		|			ИНАЧЕ ЛОЖЬ
		|		КОНЕЦ) КАК ПлатежнаяСсылкаСовпадает
		|ИЗ
		|	ПлатежныеСсылкиОбъектовРасчетов КАК ПлатежныеСсылкиОбъектовРасчетов
		|
		|СГРУППИРОВАТЬ ПО
		|	ПлатежныеСсылкиОбъектовРасчетов.ОбъектРасчетов
		|
		|ИМЕЮЩИЕ
		|	МАКСИМУМ(ВЫБОР
		|			КОГДА ПлатежныеСсылкиОбъектовРасчетов.ПлатежнаяСсылка = """"
		|					ИЛИ ПлатежныеСсылкиОбъектовРасчетов.ПлатежнаяСсылка = &ПлатежнаяСсылка
		|						И ПлатежныеСсылкиОбъектовРасчетов.ПроверкаПройдена
		|				ТОГДА ИСТИНА
		|			ИНАЧЕ ЛОЖЬ
		|		КОНЕЦ) = ЛОЖЬ
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ПлатежныеСсылкиОбъектовРасчетов.ТипСсылки КАК ТипСсылки
		|ИЗ
		|	ПлатежныеСсылкиОбъектовРасчетов КАК ПлатежныеСсылкиОбъектовРасчетов
		|ГДЕ
		|	ПлатежныеСсылкиОбъектовРасчетов.ПлатежнаяСсылка = &ПлатежнаяСсылка";
	
	Запрос.УстановитьПараметр("ОбъектыРасчетов", ОбъектыРасчетов);
	Запрос.УстановитьПараметр("ПлатежнаяСсылка", ДокументОбъект.ПлатежнаяСсылкаСБП);
	
	УстановитьПривилегированныйРежим(Истина);
	РезультатыЗапросов = Запрос.ВыполнитьПакет();
	Выборка = РезультатыЗапросов[РезультатыЗапросов.ВГраница() - 1].Выбрать();
	ВыборкаТипСсылки = РезультатыЗапросов[РезультатыЗапросов.ВГраница()].Выбрать();
	УстановитьПривилегированныйРежим(Ложь);
	
	Пока Выборка.Следующий() Цикл
		
		ТекстСообщения = СтрШаблон(НСтр("ru = 'К объекту %1 привязана другая платежная ссылка'"), Выборка.ОбъектРасчетов);
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения, , , , Ошибка);
		Прервать;
		
	КонецЦикла;
	
	Если ВыборкаТипСсылки.Следующий() Тогда
		ТипСсылки = ВыборкаТипСсылки.ТипСсылки;
	Иначе
		ТипСсылки = "";
	КонецЕсли;
	
	Если ТипСсылки = "02" Тогда
		ПроверитьИспользованиеПлатежнойСсылкиВЗаявках(ДокументОбъект.Ссылка, ДокументОбъект.ПлатежнаяСсылкаСБП, Ошибка);
	КонецЕсли;

КонецПроцедуры

// Проверяет использование платежной ссылки в заявках.
// 
// Параметры:
//  ДокументСсылка - ДокументСсылка.ЗаявкаНаРасходованиеДенежныхСредств - заявка на оплату.
//  ПлатежнаяСсылка - Строка - Платежная ссылка.
//  Ошибка - Булево - Ошибка.
Процедура ПроверитьИспользованиеПлатежнойСсылкиВЗаявках(ДокументСсылка, ПлатежнаяСсылка, Ошибка) Экспорт

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ЗаявкаНаРасходованиеДенежныхСредств.Ссылка КАК Ссылка
		|ИЗ
		|	Документ.ЗаявкаНаРасходованиеДенежныхСредств КАК ЗаявкаНаРасходованиеДенежныхСредств
		|ГДЕ
		|	НЕ ЗаявкаНаРасходованиеДенежныхСредств.ПометкаУдаления
		|	И ЗаявкаНаРасходованиеДенежныхСредств.ПлатежнаяСсылкаСБП = &ПлатежнаяСсылка
		|	И ЗаявкаНаРасходованиеДенежныхСредств.Ссылка <> &Ссылка";
	
	Запрос.УстановитьПараметр("ПлатежнаяСсылка", ПлатежнаяСсылка);
	Запрос.УстановитьПараметр("Ссылка", ДокументСсылка);
	
	УстановитьПривилегированныйРежим(Истина);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Если Не РезультатЗапроса.Пустой() Тогда
		
		Выборка = РезультатЗапроса.Выбрать();
		
		Пока Выборка.Следующий() Цикл
			
			ТекстСообщения = СтрШаблон(НСтр("ru = 'Платежная ссылка уже привязана к документу %1'"), Выборка.Ссылка);
			ОбщегоНазначения.СообщитьПользователю(ТекстСообщения, , , , Ошибка);
			Прервать;
		
		КонецЦикла;
		
	КонецЕсли;
	
	УстановитьПривилегированныйРежим(Ложь);

КонецПроцедуры

