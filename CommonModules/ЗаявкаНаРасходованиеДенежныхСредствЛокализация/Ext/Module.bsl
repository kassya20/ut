// Дополняет доступные формы оплаты в список.
// 
// Параметры:
//  Форма - ФормаКлиентскогоПриложения - форма документа.
//
Процедура ДополнитьДоступныеФормыОплаты(Форма) Экспорт

	//++ Локализация
	Элементы = Форма.Элементы;
	Объект = Форма.Объект;
	ФормыОплаты = Элементы.ФормаОплаты.СписокВыбора; // СписокЗначений
	
	Если Не ЭтоОперацияОплатыБезСБП(Объект.ХозяйственнаяОперация, Объект.ПлатежСКонвертацией, Форма.КонтрагентЮрФизЛицо) Тогда
		ФормыОплаты.Добавить("СБП", НСтр("ru = 'СБП'"));
	КонецЕсли;
	//-- Локализация
	
	Возврат;

КонецПроцедуры

#Область СистемаБыстрыхПлатежей

// Заполнить платежную ссылку и идентификатор оплаты СБП по документу основанию.
//
// Параметры:
//  ДанныеЗаполнения - Структура - данные заполнения документа.
//  СписокДокументов - Массив из ДокументСсылка, ДокументСсылка - документы-основания.
//  СуммаКОплате - Число - сумма к оплате по платежной ссылке.
//
Процедура ЗаполнитьПлатежнуюСсылкуПоОснованию(ДанныеЗаполнения, СписокДокументов, СуммаКОплате) Экспорт

	//++ Локализация
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ВходящиеПлатежныеСсылкиСБП.ДокументОперации КАК Документ,
		|	ВходящиеПлатежныеСсылкиСБП.ПлатежнаяСсылка КАК ПлатежнаяСсылка,
		|	ВходящиеПлатежныеСсылкиСБП.СуммаОперации КАК СуммаОперации,
		|	ВходящиеПлатежныеСсылкиСБП.ДатаСоздания КАК ДатаСоздания,
		|	ВходящиеПлатежныеСсылкиСБП.НастройкаПодключения КАК НастройкаПодключения,
		|	ВходящиеПлатежныеСсылкиСБП.ИдентификаторПлатежа КАК ИдентификаторПлатежа
		|ПОМЕСТИТЬ ПлатежныеСсылкиПоДокументам
		|ИЗ
		|	РегистрСведений.ВходящиеПлатежныеСсылкиСБП КАК ВходящиеПлатежныеСсылкиСБП
		|ГДЕ
		|	ВходящиеПлатежныеСсылкиСБП.ДокументОперации В(&ДокументыОперации)
		|	И ВходящиеПлатежныеСсылкиСБП.ПроверкаПройдена
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ПлатежныеСсылкиПоДокументам.Документ КАК Документ,
		|	ПлатежныеСсылкиПоДокументам.ПлатежнаяСсылка КАК ПлатежнаяСсылка,
		|	ЗаявкаНаРасходованиеДенежныхСредств.Ссылка КАК Ссылка,
		|	ПлатежныеСсылкиПоДокументам.СуммаОперации КАК СуммаОперации,
		|	ПлатежныеСсылкиПоДокументам.НастройкаПодключения КАК НастройкаПодключения,
		|	ПлатежныеСсылкиПоДокументам.ИдентификаторПлатежа КАК ИдентификаторПлатежа
		|ИЗ
		|	ПлатежныеСсылкиПоДокументам КАК ПлатежныеСсылкиПоДокументам
		|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ЗаявкаНаРасходованиеДенежныхСредств КАК ЗаявкаНаРасходованиеДенежныхСредств
		|		ПО ПлатежныеСсылкиПоДокументам.ПлатежнаяСсылка = ЗаявкаНаРасходованиеДенежныхСредств.ПлатежнаяСсылкаСБП
		|			И (ЗаявкаНаРасходованиеДенежныхСредств.ПометкаУдаления = ЛОЖЬ)
		|ГДЕ
		|	ЗаявкаНаРасходованиеДенежныхСредств.Ссылка ЕСТЬ NULL";
	
	Если ТипЗнч(СписокДокументов) <> Тип("Массив") Тогда
		СписокДокументов = ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(СписокДокументов);
	КонецЕсли;
	
	Запрос.УстановитьПараметр("ДокументыОперации", СписокДокументов);
	
	УстановитьПривилегированныйРежим(Истина);
	Выборка = Запрос.Выполнить().Выбрать();
	УстановитьПривилегированныйРежим(Ложь);
	
	Пока Выборка.Следующий() Цикл
		
		СтруктураURI = ОбщегоНазначенияКлиентСервер.СтруктураURI(Выборка.ПлатежнаяСсылка);
		ДанныеЗаполнения.Вставить("ПлатежнаяСсылкаСБП", Выборка.ПлатежнаяСсылка);
		ДанныеЗаполнения.Вставить("ИдентификаторОперацииСБП", СтруктураURI.ПутьНаСервере);
		СуммаКОплате = Выборка.СуммаОперации;
		Прервать;
		
	КонецЦикла;
	
	//-- Локализация

КонецПроцедуры

// Возвращает признак оплаты без возможности применения СБП.
// 
// Параметры:
//  ХозяйственнаяОперация - ПеречислениеСсылка.ХозяйственныеОперации - хозяйственная операция документа оплаты.
//  ПлатежСКонвертацией - Булево - признак платежа с конвертацией.
//  ВидКонтрагента - ПеречислениеСсылка.ЮрФизЛицо - вид контрагента.
// 
// Возвращаемое значение:
//  Булево
Функция ЭтоОперацияОплатыБезСБП(ХозяйственнаяОперация, ПлатежСКонвертацией, ВидКонтрагента) Экспорт

	Возврат ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.ВыдачаДенежныхСредствПодотчетнику
		Или ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.ВыдачаЗаймаСотруднику
		Или ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.ВозвратДенежныхСредствВДругуюОрганизацию
		Или ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.ОплатаПоКредитам
		Или ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.КонвертацияВалюты
		Или ПлатежСКонвертацией
		Или ВидКонтрагента = Перечисления.ЮрФизЛицо.ФизЛицо;

КонецФункции

