Функция ПараметрыПроверкиКорреспонденцииМеждуБанковскимиСчетами(Объект)
	
	МассивБанковскихСчетов = ОбщегоНазначенияКлиентСервер.МассивЗначений(
		Объект.БанковскийСчет, Объект.БанковскийСчетПолучатель, Объект.БанковскийСчетКонтрагента);
	ДанныеБанковскихСчетов = ОбщегоНазначения.ЗначениеРеквизитаОбъектов(МассивБанковскихСчетов, "СчетЦифровогоРубля");
	
	СчетаРаспределения = Новый Массив;
	Для Каждого СтрокаСчета Из Объект.РаспределениеПоСчетам Цикл
		Если ТипЗнч(СтрокаСчета.БанковскийСчетКасса) = Тип("СправочникСсылка.БанковскиеСчетаОрганизаций") Тогда
			СчетаРаспределения.Добавить(СтрокаСчета.БанковскийСчетКасса);
		КонецЕсли;
	КонецЦикла;
	
	ДанныеБанковскихСчетовОрганизации =
		ОбщегоНазначения.ЗначениеРеквизитаОбъектов(СчетаРаспределения, "СчетЦифровогоРубля");
		
	КорСчетОрганизацииЦифровогоРубля = ?(ЗначениеЗаполнено(Объект.БанковскийСчетПолучатель),
		                                 ДанныеБанковскихСчетов.Получить(Объект.БанковскийСчетПолучатель), Ложь);
	КорСчетКонтрагентаЦифровогоРубля = ?(ЗначениеЗаполнено(Объект.БанковскийСчетКонтрагента),
		                                 ДанныеБанковскихСчетов.Получить(Объект.БанковскийСчетКонтрагента), Ложь);
		
	ПараметрыПроверки = Новый Структура;
	ПараметрыПроверки.Вставить("СчетЦифровогоРубляОрганизации",    Ложь);
	ПараметрыПроверки.Вставить("РасчетныйСчетОрганизации",         Ложь);
	ПараметрыПроверки.Вставить("КорСчетОрганизацииЦифровогоРубля", КорСчетОрганизацииЦифровогоРубля);
	ПараметрыПроверки.Вставить("КорСчетКонтрагентаЦифровогоРубля", КорСчетКонтрагентаЦифровогоРубля);
