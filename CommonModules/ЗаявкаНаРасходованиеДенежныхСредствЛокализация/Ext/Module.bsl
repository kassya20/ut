// Возвращает данные о получателе денежных средств в зависимости от типа хозяйственной операции.
//
// Параметры:
//   Объект - ДокументСсылка.ЗаявкаНаРасходованиеДенежныхСредств, ДанныеФормыСтруктура - документ заявки
//
// Возвращаемое значение:
//   Структура:
//     * Получатель - СправочникСсылка.ФизическиеЛица, СправочникСсылка.Контрагенты, СправочникСсылка.Организации, Неопределено - получатель денежных средств
//     * СчетПолучателя - СправочникСсылка.БанковскиеСчетаОрганизаций, СправочникСсылка.БанковскиеСчетаКонтрагентов, Неопределено - банковский счет получателя
//     * ПравоСубъект - ПеречислениеСсылка.ЮрФизЛицо - признак юридического или физического лица
//
Функция ДанныеПолучателяХозяйственнойОперации(Объект) Экспорт

	Результат = Новый Структура;
	Результат.Вставить("Получатель", Неопределено);
	Результат.Вставить("СчетПолучателя", Неопределено);
	Результат.Вставить("ПравоСубъект", Перечисления.ЮрФизЛицо.ПустаяСсылка());
	
	// Получатель - физлицо
	Если (Объект.ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.ВыдачаДенежныхСредствПодотчетнику
		Или Объект.ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.ВыдачаЗаймаСотруднику)
		И Не Объект.ПеречислениеСотрудникуЧерезБанк
		И Не Объект.СписокФизЛиц Тогда
		
		Результат.Получатель = Объект.ПодотчетноеЛицо;
		Результат.ПравоСубъект = Перечисления.ЮрФизЛицо.ФизЛицо;
		Результат.СчетПолучателя = Объект.БанковскийСчетКонтрагента;
	
	// Получатель - неопределено (нет поля получателя на форме)
	ИначеЕсли (Объект.СписокФизЛиц
		Или Объект.ХозяйственнаяОперацияПоЗарплате = Перечисления.ХозяйственныеОперации.ВыплатаЗарплатыНаЛицевыеСчета)
		И Не Объект.ПеречислениеСотрудникуЧерезБанк Тогда
		
		Результат.Получатель = Неопределено;
		Результат.ПравоСубъект = Перечисления.ЮрФизЛицо.ПустаяСсылка();
		Результат.СчетПолучателя = Неопределено;
	
	// Получатель - организация
	ИначеЕсли Объект.ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.ОплатаДенежныхСредствВДругуюОрганизацию
		Или Объект.ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.ВозвратДенежныхСредствВДругуюОрганизацию
		Или Объект.ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.ВнутренняяПередачаДенежныхСредств Тогда
		
		Результат.Получатель = Объект.ОрганизацияПолучатель; // СправочникСсылка.Организации
		Результат.ПравоСубъект = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Результат.Получатель, "ЮрФизЛицо");
		Результат.СчетПолучателя = Объект.БанковскийСчетПолучатель;
		
	ИначеЕсли Объект.ХозяйственнаяОперацияПоЗарплате = Перечисления.ХозяйственныеОперации.ВыплатаЗарплатыЧерезКассу Тогда
		
		ЗначенияРеквизитов = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Объект.Касса, "Владелец, Владелец.ЮрФизЛицо");
		Результат.Получатель = ЗначенияРеквизитов.Владелец;
		Результат.ПравоСубъект = ЗначенияРеквизитов.ВладелецЮрФизЛицо;
		Результат.СчетПолучателя = Неопределено;
		
	// Получатель - контрагент
	Иначе
		
		Результат.Получатель = Объект.Контрагент; //СправочникСсылка.Контрагенты
		Результат.ПравоСубъект = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Результат.Получатель, "ЮрФизЛицо");
		Результат.СчетПолучателя = Объект.БанковскийСчетКонтрагента;
		
	КонецЕсли;
	
	Возврат Результат;

