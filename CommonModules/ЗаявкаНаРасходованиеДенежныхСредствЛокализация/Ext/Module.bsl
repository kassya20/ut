// Заполняет идентификатор платежа по платежной ссылке СБП в заявке на оплату.
// 
// Параметры:
//  ДокументОбъект - ДокументОбъект.ЗаявкаНаРасходованиеДенежныхСредств - заявка на оплату.
//  ПлатежнаяСсылка - Строка - Платежная ссылка СБП.
//
Процедура ЗаполнитьИдентификаторПлатежаПоПлатежнойСсылкеСБП(ДокументОбъект, ПлатежнаяСсылка) Экспорт

	//++ Локализация
	
	Отбор = Новый Структура;
	Отбор.Вставить("Организация", ДокументОбъект.Организация);
	Отбор.Вставить("БанковскийСчетОрганизации", ДокументОбъект.БанковскийСчет);
	Отбор.Вставить("Склад", Неопределено);
	Отбор.Вставить("ВидКонтрагента", Перечисления.ЮрФизЛицо.ЮрЛицо);
	
	ПараметрыНастроек = СистемаБыстрыхПлатежейУТ.ДоступныеНастройкиПодключения(Отбор);
	
	Если ПараметрыНастроек.НастройкиПодключения <> Неопределено
		И ПараметрыНастроек.НастройкиПодключения.Количество() >= 1 Тогда
		НастройкаПодключения = ПараметрыНастроек.НастройкиПодключения[0];
	Иначе
		Возврат;
	КонецЕсли;
	
	ПараметрыПроцедуры = Новый Структура;
	ПараметрыПроцедуры.Вставить("НастройкаПодключения", НастройкаПодключения);
	ПараметрыПроцедуры.Вставить("ПлатежнаяСсылка", ПлатежнаяСсылка);
	
	ПараметрыЗадания = ДлительныеОперации.ПараметрыВыполненияВФоне(Новый УникальныйИдентификатор);
	ПараметрыЗадания.НаименованиеФоновогоЗадания = НСтр("ru='Получение данных функциональной ссылки Системы быстрых платежей'");
	ПараметрыЗадания.ОжидатьЗавершение = Неопределено;
	
	ФоновоеЗадание = ДлительныеОперации.ВыполнитьВФоне("СистемаБыстрыхПлатежейУТ.ДанныеЗаполненияПоПлатежнойСсылкеСБПb2b", ПараметрыПроцедуры, ПараметрыЗадания);
	ДанныеЗаполнения = ПолучитьИзВременногоХранилища(ФоновоеЗадание.АдресРезультата);
	
	Если ЗначениеЗаполнено(ДанныеЗаполнения.КодОшибки) Тогда
		
		ТекстСообщения = СтрШаблон(
			НСтр("ru = 'Ошибка получения данных платежной ссылки СБП: %1'"),
			ДанныеЗаполнения.СообщениеОбОшибке);
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);
		Возврат;
		
	КонецЕсли;
	
	ДокументОбъект.ПлатежнаяСсылкаСБП = ПлатежнаяСсылка;
	ДокументОбъект.ИдентификаторОперацииСБП = ДанныеЗаполнения.ИдентификаторОперации;
	ДокументОбъект.ИдентификаторПлатежа = ДанныеЗаполнения.ИдентификаторПлатежа;
	ДокументОбъект.ФормаОплатыЗаявки = ДанныеЗаполнения.ФормаОплатыЗаявки;
	ДокументОбъект.ФормаОплатыНаличная = ДанныеЗаполнения.ФормаОплатыНаличная;
	ДокументОбъект.ФормаОплатыПлатежнаяКарта = ДанныеЗаполнения.ФормаОплатыПлатежнаяКарта;
	ДокументОбъект.ФормаОплатыБезналичная = ДанныеЗаполнения.ФормаОплатыБезналичная;
	
	//-- Локализация
	
	Возврат;

КонецПроцедуры
 
#КонецОбласти

