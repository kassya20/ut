// Открывает форму подключения организации к Бидзаар.
//
// Параметры:
//  Организация					 - ОпределяемыйТип.Организация - подключаемая организация.
//  Владелец					 - ФормаКлиентскогоПриложения - владелец формы.
//  ОписаниеОповещенияОЗакрытии	 - ОписаниеОповещения - описание оповещения о закрытии формы.
//
Процедура ОткрытьФормуПодключенияОрганизацииБидзаар(Организация, Владелец = Неопределено, ОписаниеОповещенияОЗакрытии = Неопределено)  Экспорт
	
	ПараметрыФормы = Новый Структура;
	
	ПараметрыФормы.Вставить("Организация", Организация);
	ПараметрыФормы.Вставить("РазделУчета", "Покупатели");
	
	Если ИнтеграцияСЭлектроннымиТорговымиПлощадкамиВызовСервера.ДоступноПравоНастройкиАвторизацииБидзаар() Тогда
		ОткрытьФорму("Обработка.УправлениеВыгрузкамиВБидзаар.Форма.НастройкаПодключения", 
			ПараметрыФормы, 
			Владелец, , , , 
			ОписаниеОповещенияОЗакрытии);
	КонецЕсли;
	
КонецПроцедуры

// Проверяет изменение ключевого реквизита и возвращает флаг модификации
//
// Параметры:
//   КлючевыеРеквизиты - см. ИнтеграцияСЭлектроннымиТорговымиПлощадками.ИменаРеквизитовЗКППубликуемыхВБидзаар
//   ИмяРеквизита - Строка - имя проверяемого реквизита
//
// Возвращаемое значение:
//   Число - 0 если реквизит не изменен, иначе значение пометки + 1
Функция ПроверитьИзменениеКлючевогоРеквизита(КлючевыеРеквизиты, ИмяРеквизита) Экспорт

	НайденноеЗначение = КлючевыеРеквизиты.НайтиПоЗначению(ИмяРеквизита);
	
	Если НайденноеЗначение = Неопределено Тогда
		Возврат 0;
	Иначе
		Возврат НайденноеЗначение.Пометка + 1;
	КонецЕсли;
	
КонецФункции

// Подбор ключевых слов для запроса коммерческих предложений.
// Подготавливаются данные для выполнения длительной операции и осуществляется вызов функции подбора.
// 
// Параметры:
//  Документ - ДокументСсылка.ЗапросКоммерческихПредложенийПоставщиков - публикуемый документ
Процедура ПодборКлючевыхСловДляЗапросаКоммерческихПредложенийБидзаар(Знач Документ) Экспорт

	Результат = ИнтеграцияСЭлектроннымиТорговымиПлощадкамиВызовСервера.ПодборКлючевыхСловДляЗапросаКоммерческихПредложенийБидзаарВФоне(Документ);

	ПараметрыЗавершения = Новый Структура;
	ПараметрыЗавершения.Вставить("ЗапросКоммерческихПредложений", Документ);
	ПараметрыЗавершения.Вставить("АдресРезультата", "");
			
	Если Результат <> Неопределено Тогда 

		ПараметрыЗавершения.АдресРезультата = Результат.АдресРезультата;
		ПриЗавершенииОтправкиЗапроса = Новый ОписаниеОповещения("ПодборКлючевыхСловДляЗапросаКоммерческихПредложенийБидзаарЗавершение", 
			ЭтотОбъект, ПараметрыЗавершения);
		
		ПараметрыОжидания = ДлительныеОперацииКлиент.ПараметрыОжидания(Неопределено);
		ПараметрыОжидания.ВыводитьПрогрессВыполнения = Ложь;
		ПараметрыОжидания.ВыводитьОкноОжидания = Ложь;
		ПараметрыОжидания.ОповещениеПользователя.Показать = Ложь;
		ПараметрыОжидания.ВыводитьСообщения = Истина;
		
		ДлительныеОперацииКлиент.ОжидатьЗавершение(Результат, ПриЗавершенииОтправкиЗапроса, ПараметрыОжидания);
		
	Иначе
		ПриЗавершенииОтправкиЗапроса = Новый ОписаниеОповещения("ПодборКлючевыхСловДляЗапросаКоммерческихПредложенийБидзаарЗавершение", 
			ЭтотОбъект, ПараметрыЗавершения);
			
		Результат = Новый Структура("Статус, Сообщения", "Ошибка", Новый Массив);
		ВыполнитьОбработкуОповещения(ПриЗавершенииОтправкиЗапроса, Результат);
	КонецЕсли;
		
КонецПроцедуры

// Получение ключевых слов из сервиса Бидзаар.
// Подготавливаются данные для выполнения длительной операции и осуществляется вызов функции получения.
// 
// Параметры:
//  УчетнаяЗапись - СправочникСсылка.УчетныеЗаписиЭлектронныхТорговыхПлощадок
//  МенеджерEmail - Строка
//  Источник - Произвольный - источник оповещения о завершении выполнения задания
//  СтрокаПоиска - Строка - строка поиска для отбора ключевых слов по наименованию. Необязательный
Процедура КлючевыеСловаБидзаар(Знач УчетнаяЗапись, Знач МенеджерEmail, Знач Источник, Знач СтрокаПоиска = "") Экспорт

	Результат = ИнтеграцияСЭлектроннымиТорговымиПлощадкамиВызовСервера.КлючевыеСловаБидзаарВФоне(УчетнаяЗапись, МенеджерEmail, СтрокаПоиска);
	
	ПараметрыЗавершения = Новый Структура;
	ПараметрыЗавершения.Вставить("Источник", Источник);
	ПараметрыЗавершения.Вставить("АдресРезультата", "");
			
	Если Результат <> Неопределено Тогда 

		ПараметрыЗавершения.АдресРезультата = Результат.АдресРезультата;
		ПриЗавершенииОтправкиЗапроса = Новый ОписаниеОповещения("КлючевыеСловаБидзаарЗавершение", 
			ЭтотОбъект, ПараметрыЗавершения);
		
		ПараметрыОжидания = ДлительныеОперацииКлиент.ПараметрыОжидания(Неопределено);
		ПараметрыОжидания.ВыводитьПрогрессВыполнения = Ложь;
		ПараметрыОжидания.ВыводитьОкноОжидания = Ложь;
		ПараметрыОжидания.ОповещениеПользователя.Показать = Ложь;
		ПараметрыОжидания.ВыводитьСообщения = Истина;
		
		ДлительныеОперацииКлиент.ОжидатьЗавершение(Результат, ПриЗавершенииОтправкиЗапроса, ПараметрыОжидания);
		
	Иначе
		ПриЗавершенииОтправкиЗапроса = Новый ОписаниеОповещения("КлючевыеСловаБидзаарЗавершение", 
			ЭтотОбъект, ПараметрыЗавершения);
			
		Результат = Новый Структура("Статус, Сообщения", "Ошибка", Новый Массив);
		ВыполнитьОбработкуОповещения(ПриЗавершенииОтправкиЗапроса, Результат);
	КонецЕсли;
		
КонецПроцедуры

// Открывает отчет "Результат опроса" по данным анкетирования поставщиков в сервисе Бидзаар.
//
// Параметры:
//	ПараметрыПечати - Структура - сведения о печатной форме:
//	 * ОбъектыПечати - Массив из ДокументСсылка.ЗапросКоммерческихПредложенийПоставщиков - массив выбранных ссылок.
//	 * Форма - ФормаКлиентскогоПриложения - форма, из которой вызвана команда печати.
//	 * ДополнительныеПараметры - Структура - дополнительные параметры печати.
//     Прочие ключи структуры соответствуют колонкам таблицы КомандыПечати,
//     подробнее см. в функции УправлениеПечатью.СоздатьКоллекциюКомандПечати.
//	Возвращаемое значение:
//		Неопределено 
Функция ОткрытьРезультатОпросаБидзаар(ПараметрыПечати) Экспорт
	
	Если ПараметрыПечати.ОбъектыПечати.Количество() = 0 Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Субъект = ПараметрыПечати.ОбъектыПечати[0];
	
	ДанныеОткрытияРезультатаОпроса =
		ИнтеграцияСЭлектроннымиТорговымиПлощадкамиВызовСервера.ПолучитьДанныеОткрытияРезультатОпросаБизаар(Субъект);
	
	ЭтоБидзаар = ДанныеОткрытияРезультатаОпроса.ЭтоБидзаар;
	
	Если Не ЭтоБидзаар Тогда
		ТекстПредупреждения =
			НСтр("ru = 'Результат опроса поставщиков доступен только для документов, размещенных в сервисе ""Бидзаар""'");
		ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстПредупреждения);
		Возврат Неопределено;
	КонецЕсли;
	
	ОписаниеВариантаОтчета = ДанныеОткрытияРезультатаОпроса.ОписаниеВариантаОтчета;
	ПроведениеОпроса = ДанныеОткрытияРезультатаОпроса.ПроведениеОпроса;
	
	ДополнительныеПараметры = Новый Структура;
	ДополнительныеПараметры.Вставить("СформироватьПриОткрытии", Истина);
	ПараметрыОтбор = Новый Структура("Опрос", ПроведениеОпроса);
	ДополнительныеПараметры.Вставить("Отбор", ПараметрыОтбор);
	
	Если ОписаниеВариантаОтчета.ВариантОтчета <> Неопределено Тогда
		ВариантыОтчетовКлиент.ОткрытьФормуОтчета(Неопределено, ОписаниеВариантаОтчета.ВариантОтчета, ДополнительныеПараметры);
	Иначе
		ОбщегоНазначенияКлиент.СообщитьПользователю(ОписаниеВариантаОтчета.ТекстОшибки);
	КонецЕсли;
	
	Возврат Неопределено;
	
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Процедура ПроверитьСвязьСЭТПБидзаарЗавершение(Результат, ПараметрыЗавершения) Экспорт

	Если ТипЗнч(Результат) = Тип("Структура") Тогда
		Статус = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(Результат, "Статус", "");
		Если Статус = "Выполнено" Тогда
			РезультатВыполнения = ПолучитьИзВременногоХранилища(Результат.АдресРезультата);
			ПараметрыЗавершения.Вставить("Результат", РезультатВыполнения);
			Оповестить("Бидзаар_ПроверкаСвязиСЭТП", ПараметрыЗавершения, ПараметрыЗавершения.Источник);
		КонецЕсли;
	КонецЕсли;

КонецПроцедуры

// Обрабатывает результат асинхронной публикации запроса коммерческих предложений и оповещает документ о результате.
//
// Параметры:
//   Результат - Структура - результат выполнения асинхронной операции, содержащий статус и сообщения
//   ПараметрыЗавершения - Структура - параметры, переданные при запуске асинхронной операции
Процедура ПубликацияЗапросаКоммерческихПредложенийЗавершение(Результат, ПараметрыЗавершения) Экспорт

	//Данные для оповещения публикуемого документа о результате публикации
	СостояниеДокумента = Новый Структура;
	СостояниеДокумента.Вставить("СостояниеСинхронизации", ПредопределенноеЗначение("Перечисление.СостоянияСинхронизацииЗапросовКоммерческихПредложений.ПустаяСсылка"));
	СостояниеДокумента.Вставить("Детализация", Новый Соответствие);
	
	//Данные о результате подбора ключевых слов
	РезультатПодбораКлючевыхСлов = ИнтеграцияСЭлектроннымиТорговымиПлощадкамиКлиентСервер.РезультатПодбораКлючевыхСлов();
	
	ПараметрыОповещения = Новый Структура("КодСостояния, Идентификатор, СостояниеДокумента, ТекстОшибки, РезультатПодбораКлючевыхСлов",
		0, "", СостояниеДокумента, "", РезультатПодбораКлючевыхСлов);

	Если Результат.Статус = "Выполнено" Тогда

		РезультатПубликации = ПолучитьИзВременногоХранилища(ПараметрыЗавершения.АдресРезультата);
		ЗаполнитьЗначенияСвойств(ПараметрыОповещения, РезультатПубликации);

		Оповестить("Бидзаар_ОтправкаЗапросаКоммерческихПредложений", ПараметрыОповещения,
			ПараметрыЗавершения.ЗапросКоммерческихПредложений);
		Если Не ПустаяСтрока(РезультатПубликации.Идентификатор) Тогда
			ПолучитьСостоянияБидзаар(ПараметрыЗавершения.ЗапросКоммерческихПредложений);
		КонецЕсли;

	ИначеЕсли Результат.Статус = "Ошибка" Тогда

		СообщенияОбОшибках = Новый массив;
		Для Каждого Сообщение Из Результат.Сообщения Цикл
			Если ТипЗнч(Сообщение) = Тип("Строка") Тогда
				СообщенияОбОшибках.Добавить(Сообщение);
			ИначеЕсли ТипЗнч(Сообщение) = Тип("СообщениеПользователю") Тогда
				СообщенияОбОшибках.Добавить(Сообщение.Текст);
			КонецЕсли;
		КонецЦикла;

		ПараметрыОповещения.ТекстОшибки = СтрСоединить(СообщенияОбОшибках, Символы.ПС);
		СостояниеДокумента.СостояниеСинхронизации = ПредопределенноеЗначение("Перечисление.СостоянияСинхронизацииЗапросовКоммерческихПредложений.Ошибка");

		Оповестить("Бидзаар_ОтправкаЗапросаКоммерческихПредложений", ПараметрыОповещения,
			ПараметрыЗавершения.ЗапросКоммерческихПредложений);

	КонецЕсли;

КонецПроцедуры

Процедура ПолучитьСостоянияБидзаарЗавершение(Результат, ПараметрыЗавершения) Экспорт

	ПараметрыОповещения = Новый Структура("Состояние, ТекстОшибки, КоличествоПобедителей", "", "", 0);

	Если Результат.Статус = "Выполнено" Тогда
		
		Если Не ПараметрыЗавершения.ОповещаемыеДокументы.Количество() Тогда
			Оповестить("ПолучитьСостоянияБидзаар", ПараметрыОповещения);
			Возврат;
		КонецЕсли;
		
		РезультатВыполнения = ПолучитьИзВременногоХранилища(ПараметрыЗавершения.АдресРезультата);
		
		Для Каждого ОповещаемыйДокумент Из ПараметрыЗавершения.ОповещаемыеДокументы Цикл
			СостояниеДокумента = РезультатВыполнения.СостоянияДокументов.Получить(ОповещаемыйДокумент);

			Если СостояниеДокумента <> Неопределено Тогда
				ПараметрыОповещения.Состояние = СостояниеДокумента;
				ПараметрыОповещения.ТекстОшибки = "";
			Иначе
				ПараметрыОповещения.Состояние = "";
				ПараметрыОповещения.ТекстОшибки = "";
			КонецЕсли;
			
			КоличествоПобедителей = РезультатВыполнения.КоличестваПобедителей.Получить(ОповещаемыйДокумент);
			Если СостояниеДокумента <> Неопределено Тогда
				ПараметрыОповещения.КоличествоПобедителей = КоличествоПобедителей;
			Иначе
				ПараметрыОповещения.КоличествоПобедителей = 0;
			КонецЕсли;
			
			Оповестить("ПолучитьСостояниеБидзаар", ПараметрыОповещения, ОповещаемыйДокумент);
			
		КонецЦикла;
			
	ИначеЕсли Результат.Статус = "Ошибка" Тогда
		
		Если Не ПараметрыЗавершения.ОповещаемыеДокументы.Количество() Тогда
			Оповестить("ПолучитьСостояниеБидзаар", ПараметрыОповещения);
			Возврат;
		КонецЕсли;

		Для Каждого ОповещаемыйДокумент Из ПараметрыЗавершения.ОповещаемыеДокументы Цикл

			ПараметрыОповещения.Состояние = "Ошибка";
			ПараметрыОповещения.ТекстОшибки = "";
			ПараметрыОповещения.КоличествоПобедителей = 0;

			Оповестить("ПолучитьСостояниеБидзаар", ПараметрыОповещения, ОповещаемыйДокумент);

		КонецЦикла;
		
	КонецЕсли;
	
КонецПроцедуры

Процедура ПолучениеДанныхКоммерческихПредложенийЗавершение(Результат, ПараметрыЗавершения) Экспорт
	
	ПараметрыОповещения = Новый Структура("ДанныеКоммерческихПредложений, ТекстОшибки", "", "");

	Если Результат.Статус = "Выполнено" Тогда
		
		РезультатВыполнения = ПолучитьИзВременногоХранилища(ПараметрыЗавершения.АдресРезультата);
		
		ЗаполнитьЗначенияСвойств(ПараметрыОповещения, РезультатВыполнения);
			
		Оповестить("ПолучениеДанныхКоммерческихПредложенийПоЗапросуБидзаар", ПараметрыОповещения, ПараметрыЗавершения.ОповещаемыйДокумент);
		
	ИначеЕсли Результат.Статус = "Ошибка" Тогда
		
		ПараметрыОповещения.ТекстОшибки = Результат.КраткоеПредставлениеошибки;
		Оповестить("ПолучениеДанныхКоммерческихПредложенийПоЗапросуБидзаар", ПараметрыОповещения, ПараметрыЗавершения.ОповещаемыйДокумент);
			
	КонецЕсли;
	
КонецПроцедуры

Процедура ПолучениеДанныхУчастниковПоЗапросуБидзаарЗавершение(Результат, ПараметрыЗавершения) Экспорт
	
	ПараметрыОповещения = Новый Структура("ДанныеУчастников, ТекстОшибки", "", "");
	
	Если Результат.Статус = "Выполнено" Тогда
		
		РезультатВыполнения = ПолучитьИзВременногоХранилища(ПараметрыЗавершения.АдресРезультата);
		
		ЗаполнитьЗначенияСвойств(ПараметрыОповещения, РезультатВыполнения);
		
		Оповестить("ПолучениеДанныхУчастниковБидзаар", ПараметрыОповещения, ПараметрыЗавершения.ОповещаемыйДокумент);
			
	ИначеЕсли Результат.Статус = "Ошибка" Тогда
		
		ПараметрыОповещения.ТекстОшибки = Результат.КраткоеПредставлениеошибки;
	
		Оповестить("ПолучениеДанныхУчастниковБидзаар", ПараметрыОповещения, ПараметрыЗавершения.ОповещаемыйДокумент);
			
	КонецЕсли;
	
КонецПроцедуры

// Обрабатывает результат подбора ключевых слов для запроса коммерческих предложений площадки Бидзаар и отправляет уведомление.
//
// Параметры:
//   Результат - Структура - содержит статус выполнения ("Выполнено" или "Ошибка"), данные из временного хранилища и краткое представление ошибки
//   ПараметрыЗавершения - Структура - параметры завершения, содержащие адрес результата во временном хранилище и ссылку на запрос коммерческих предложений
Процедура ПодборКлючевыхСловДляЗапросаКоммерческихПредложенийБидзаарЗавершение(Результат, ПараметрыЗавершения) Экспорт

	ПараметрыОповещения = ИнтеграцияСЭлектроннымиТорговымиПлощадкамиКлиентСервер.РезультатПодбораКлючевыхСлов();
	ПараметрыОповещения.ПодборВыполнялся = Истина;
	
	Если Результат.Статус = "Выполнено" Тогда
		
		РезультатВыполнения = ПолучитьИзВременногоХранилища(ПараметрыЗавершения.АдресРезультата);
		
		ЗаполнитьЗначенияСвойств(ПараметрыОповещения, РезультатВыполнения);
		
		Оповестить("Бидзаар_ПодборКлючевыхСлов", ПараметрыОповещения, ПараметрыЗавершения.ЗапросКоммерческихПредложений);
			
	ИначеЕсли Результат.Статус = "Ошибка" Тогда
		
		ПараметрыОповещения.ТекстОшибки = Результат.КраткоеПредставлениеошибки;
	
		Оповестить("Бидзаар_ПодборКлючевыхСлов", ПараметрыОповещения, ПараметрыЗавершения.ЗапросКоммерческихПредложений);
			
	КонецЕсли;

КонецПроцедуры

// Обрабатывает результат асинхронного получения ключевых слов для Bidzaar и отправляет оповещение.
//
// Параметры:
//   Результат - Структура - результат выполнения операции со свойствами Статус, КраткоеПредставлениеошибки
//   ПараметрыЗавершения - Структура - параметры завершения, содержащие АдресРезультата и Источник
Процедура КлючевыеСловаБидзаарЗавершение(Результат, ПараметрыЗавершения) Экспорт

	ПараметрыОповещения = Новый Структура("КлючевыеСлова, ТекстОшибки",
		 ИнтеграцияСЭлектроннымиТорговымиПлощадкамиКлиентСервер.СписокКлючевыхСлов(), "");
	
	Если Результат.Статус = "Выполнено" Тогда
		
		РезультатВыполнения = ПолучитьИзВременногоХранилища(ПараметрыЗавершения.АдресРезультата);
		
		ЗаполнитьЗначенияСвойств(ПараметрыОповещения, РезультатВыполнения);
		
		Оповестить("Бидзаар_ПолучениеКлючевыхСлов", ПараметрыОповещения, ПараметрыЗавершения.Источник);
			
	ИначеЕсли Результат.Статус = "Ошибка" Тогда
		
		ПараметрыОповещения.ТекстОшибки = Результат.КраткоеПредставлениеошибки;
	
		Оповестить("Бидзаар_ПолучениеКлючевыхСлов", ПараметрыОповещения, ПараметрыЗавершения.Источник);
			
	КонецЕсли;

КонецПроцедуры

#КонецОбласти