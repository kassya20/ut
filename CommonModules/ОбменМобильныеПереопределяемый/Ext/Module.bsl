	ДанныеСсылка = Документы.РасходныйОрдерНаТовары.ПолучитьСсылку(Новый УникальныйИдентификатор(ОбъектXDTO.Ссылка));
	Данные = ДанныеСсылка.ПолучитьОбъект();
	
	Если Данные = Неопределено Тогда
		Данные = Документы.РасходныйОрдерНаТовары.СоздатьДокумент();
		Данные.УстановитьСсылкуНового(ДанныеСсылка);
	Иначе
		Данные = ДанныеСсылка.ПолучитьОбъект();
	КонецЕсли;
			
	ЗаполнитьЗначенияСвойств(Данные, ОбъектXDTO); 
	
	Данные.Дата = Дата(ОбъектXDTO.Дата);
	Данные.ДатаОтгрузки = Дата(ОбъектXDTO.ДатаОтгрузки);
	Данные.ПометкаУдаления = Булево(ОбъектXDTO.ПометкаУдаления);
	Данные.Проведен = Булево(ОбъектXDTO.Проведен);
	Данные.ЗонаОтгрузки = Справочники.СкладскиеЯчейки.ПолучитьСсылку(Новый УникальныйИдентификатор(ОбъектXDTO.ЗонаОтгрузки));
	Данные.Ответственный = Справочники.Пользователи.ПолучитьСсылку(Новый УникальныйИдентификатор(ОбъектXDTO.Ответственный));
	Данные.Контролер = Справочники.Пользователи.ПолучитьСсылку(Новый УникальныйИдентификатор(ОбъектXDTO.Контролер));
	Данные.Отгрузил = Справочники.Пользователи.ПолучитьСсылку(Новый УникальныйИдентификатор(ОбъектXDTO.Отгрузил));
	Данные.Помещение = Справочники.СкладскиеПомещения.ПолучитьСсылку(Новый УникальныйИдентификатор(ОбъектXDTO.Помещение));
	Данные.Склад = Справочники.Склады.ПолучитьСсылку(Новый УникальныйИдентификатор(ОбъектXDTO.Склад));
	
	ТипПолучатель = ОбъектXDTO.ТипПолучатель;
	Тип = МобильноеРабочееМестоКладовщика.МенеджерОбъектаПоПолномуИмени(ТипПолучатель);
	Данные.Получатель = Тип.ПолучитьСсылку(Новый УникальныйИдентификатор(ОбъектXDTO.Получатель));
	
	Если ТипЗнч(ОбъектXDTO.Статус) = Тип("Строка") Тогда
		Данные.Статус = Перечисления.СтатусыРасходныхОрдеров[ОбъектXDTO.Статус];
	КонецЕсли;
	
	Данные.ТоварыПоРаспоряжениям.Очистить(); 
	
	Если ОбъектXDTO.Свойства().Получить("ТоварыПоРаспоряжениям") <> Неопределено Тогда   
		
		Если ТипЗнч(ОбъектXDTO.ТоварыПоРаспоряжениям.ЭлементТоварыПоРаспоряжениям) <> Тип("СписокXDTO") Тогда
			СписокXDTOСтрокаТовары	= Новый Массив;
			СписокXDTOСтрокаТовары.Добавить(ОбъектXDTO.ТоварыПоРаспоряжениям.ЭлементТоварыПоРаспоряжениям);
		Иначе
			СписокXDTOСтрокаТовары = ОбъектXDTO.ТоварыПоРаспоряжениям.ЭлементТоварыПоРаспоряжениям;
		КонецЕсли;
			
		Для Каждого СтрокаТовары Из СписокXDTOСтрокаТовары Цикл
			НоваяСтрока = Данные.ТоварыПоРаспоряжениям.Добавить();
			НоваяСтрока.Номенклатура = Справочники.Номенклатура.ПолучитьСсылку(Новый УникальныйИдентификатор(СтрокаТовары.Номенклатура));
			НоваяСтрока.Характеристика = Справочники.ХарактеристикиНоменклатуры.ПолучитьСсылку(Новый УникальныйИдентификатор(СтрокаТовары.Характеристика));
			НоваяСтрока.Назначение = Справочники.Назначения.ПолучитьСсылку(Новый УникальныйИдентификатор(СтрокаТовары.Назначение));
			НоваяСтрока.Серия = Справочники.СерииНоменклатуры.ПолучитьСсылку(Новый УникальныйИдентификатор(СтрокаТовары.Серия));
			НоваяСтрока.СтатусУказанияСерий = Число(СтрокаТовары.СтатусУказанияСерий);
			Если СтрокаТовары.Свойства().Получить("Распоряжение") <> Неопределено Тогда
				ТипРаспоряжение = СтрокаТовары.ТипРаспоряжение;
				Тип = МобильноеРабочееМестоКладовщика.МенеджерОбъектаПоПолномуИмени(ТипРаспоряжение);
				НоваяСтрока.Распоряжение = Тип.ПолучитьСсылку(Новый УникальныйИдентификатор(СтрокаТовары.Распоряжение));
			КонецЕсли;
			НоваяСтрока.Количество = Число(СтрокаТовары.Количество);
		КонецЦикла;
	КонецЕсли;
	
	Данные.ОтгружаемыеТовары.Очистить(); 
	
	Если ОбъектXDTO.Свойства().Получить("ОтгружаемыеТовары") <> Неопределено Тогда   
		
		Если ТипЗнч(ОбъектXDTO.ОтгружаемыеТовары.ЭлементОтгружаемыеТовары) <> Тип("СписокXDTO") Тогда
			СписокXDTOСтрокаТовары	= Новый Массив;
			СписокXDTOСтрокаТовары.Добавить(ОбъектXDTO.ОтгружаемыеТовары.ЭлементОтгружаемыеТовары);
		Иначе
			СписокXDTOСтрокаТовары = ОбъектXDTO.ОтгружаемыеТовары.ЭлементОтгружаемыеТовары;
		КонецЕсли;
			
		Для Каждого СтрокаТовары Из СписокXDTOСтрокаТовары Цикл
			НоваяСтрока = Данные.ОтгружаемыеТовары.Добавить();
			НоваяСтрока.Номенклатура = Справочники.Номенклатура.ПолучитьСсылку(Новый УникальныйИдентификатор(СтрокаТовары.Номенклатура));
			НоваяСтрока.Характеристика = Справочники.ХарактеристикиНоменклатуры.ПолучитьСсылку(Новый УникальныйИдентификатор(СтрокаТовары.Характеристика));
			НоваяСтрока.Назначение = Справочники.Назначения.ПолучитьСсылку(Новый УникальныйИдентификатор(СтрокаТовары.Назначение));
			НоваяСтрока.Серия = Справочники.СерииНоменклатуры.ПолучитьСсылку(Новый УникальныйИдентификатор(СтрокаТовары.Серия));
			НоваяСтрока.СтатусУказанияСерий = Число(СтрокаТовары.СтатусУказанияСерий);
			НоваяСтрока.ЭтоУпаковочныйЛист = Булево(СтрокаТовары.ЭтоУпаковочныйЛист);
			НоваяСтрока.ЭтоСлужебнаяСтрокаПустогоУпаковочногоЛиста = Число(СтрокаТовары.ЭтоСлужебнаяСтрокаПустогоУпаковочногоЛиста);
			Если СтрокаТовары.Свойства().Получить("УпаковочныйЛистРодитель") <> Неопределено Тогда
				НоваяСтрока.УпаковочныйЛистРодитель = Документы.УпаковочныйЛист.ПолучитьСсылку(Новый УникальныйИдентификатор(СтрокаТовары.УпаковочныйЛистРодитель));
			КонецЕсли;
			Если СтрокаТовары.Свойства().Получить("УпаковочныйЛист") <> Неопределено Тогда
				НоваяСтрока.УпаковочныйЛист = Документы.УпаковочныйЛист.ПолучитьСсылку(Новый УникальныйИдентификатор(СтрокаТовары.УпаковочныйЛист));
			КонецЕсли;
			НоваяСтрока.Упаковка = Справочники.УпаковкиЕдиницыИзмерения.ПолучитьСсылку(Новый УникальныйИдентификатор(СтрокаТовары.Упаковка));
			НоваяСтрока.Количество = Число(СтрокаТовары.Количество);
			НоваяСтрока.КоличествоУпаковок = Число(СтрокаТовары.КоличествоУпаковок);
			Если ТипЗнч(СтрокаТовары.Действие) = Тип("Строка") Тогда
				НоваяСтрока.Действие = Перечисления.ДействияСоСтрокамиОрдеровНаОтгрузку[СтрокаТовары.Действие];
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
	Возврат Данные;
	
