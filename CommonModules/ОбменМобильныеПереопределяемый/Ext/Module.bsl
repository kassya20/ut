Процедура КонстантыВXML(ЗаписьXML, Данные)
	
	ИмяОбъекта = СтрРазделить(Данные.Метаданные().ПолноеИмя(), ".");
	ЗаписьXML.ЗаписатьНачалоЭлемента("ConstantValueManager." + ИмяОбъекта[1]);
	
	Тип = Строка(ТипЗнч(Данные.Значение));
	Если Тип = "Число" Или Тип = "Строка" Или Тип = "Дата" Или Тип = "Булево" Тогда	
		ЗаписьXML.ЗаписатьНачалоЭлемента("ЗначениеКонстанты");
		ЗаписьXML.ЗаписатьТекст(Строка(Данные.Значение));
		ЗаписьXML.ЗаписатьКонецЭлемента();
		
		ЗаписьXML.ЗаписатьНачалоЭлемента("ТипЗначения");
		ЗаписьXML.ЗаписатьТекст(Тип);
		ЗаписьXML.ЗаписатьКонецЭлемента();
	Иначе
		Тип = Данные.Значение.Метаданные().ПолноеИмя();
		
		Если СтрРазделить(Тип, ".")[0] = "Перечисление" Тогда
			ЗаписьXML.ЗаписатьНачалоЭлемента("ЗначениеКонстанты");
			ЗаписьXML.ЗаписатьТекст(XMLСтрока(Данные.Значение));
			ЗаписьXML.ЗаписатьКонецЭлемента();
		Иначе
			ЗаписьXML.ЗаписатьНачалоЭлемента("ЗначениеКонстанты");
			ЗаписьXML.ЗаписатьТекст(Строка(Данные.Значение.УникальныйИдентификатор()));
			ЗаписьXML.ЗаписатьКонецЭлемента();
		КонецЕсли;
		
		ЗаписьXML.ЗаписатьНачалоЭлемента("ТипЗначения");
		ЗаписьXML.ЗаписатьТекст(Тип);
		ЗаписьXML.ЗаписатьКонецЭлемента();
	КонецЕсли;
	
	ЗаписьXML.ЗаписатьКонецЭлемента();
	
КонецПроцедуры

