Функция ВидыНоменклатурыИзXML(ЧтениеXML)
	
	ОбъектXDTO = ФабрикаXDTO.ПрочитатьXML(ЧтениеXML);
	ЭтоГруппа = Булево(ОбъектXDTO.ЭтоГруппа);
	
	ДанныеСсылка = Справочники.ВидыНоменклатуры.ПолучитьСсылку(Новый УникальныйИдентификатор(ОбъектXDTO.Ссылка));
	Данные = ДанныеСсылка.ПолучитьОбъект();
	
	Если Данные = Неопределено И ЭтоГруппа Тогда
		Данные = Справочники.ВидыНоменклатуры.СоздатьГруппу();
		Данные.УстановитьСсылкуНового(ДанныеСсылка);
	ИначеЕсли Данные = Неопределено И НЕ ЭтоГруппа Тогда
		Данные = Справочники.ВидыНоменклатуры.СоздатьЭлемент();
		Данные.УстановитьСсылкуНового(ДанныеСсылка);
	Иначе
		Данные = ДанныеСсылка.ПолучитьОбъект();
	КонецЕсли;
	
	ЗаполнитьЗначенияСвойств(Данные, ОбъектXDTO);
	
	Данные.Родитель = Справочники.ВидыНоменклатуры.ПолучитьСсылку(Новый УникальныйИдентификатор(ОбъектXDTO.Родитель));
	
	Если ЭтоГруппа Тогда
		Возврат Данные;
	КонецЕсли;
	
	Данные.ИспользоватьНомерСерии = Булево(ОбъектXDTO.ИспользоватьНомерСерии);
	Данные.ИспользоватьСрокГодностиСерии = Булево(ОбъектXDTO.ИспользоватьСрокГодностиСерии);
	Данные.ИспользоватьRFIDМеткиСерии = Булево(ОбъектXDTO.ИспользоватьRFIDМеткиСерии);
	Данные.ИспользоватьДатуПроизводстваСерии = Булево(ОбъектXDTO.ИспользоватьДатуПроизводстваСерии);
	Данные.ИспользоватьНомерКИЗГИСМСерии = Булево(ОбъектXDTO.ИспользоватьНомерКИЗГИСМСерии);
	Данные.ИспользоватьПроизводителяЕГАИССерии = Булево(ОбъектXDTO.ИспользоватьПроизводителяЕГАИССерии);
	Данные.ИспользоватьСправку2ЕГАИССерии = Булево(ОбъектXDTO.ИспользоватьСправку2ЕГАИССерии);
	Данные.ИспользоватьПроизводителяВЕТИССерии = Булево(ОбъектXDTO.ИспользоватьПроизводителяВЕТИССерии);
	Данные.ИспользоватьЗаписьСкладскогоЖурналаВЕТИССерии = Булево(ОбъектXDTO.ИспользоватьЗаписьСкладскогоЖурналаВЕТИССерии);
	Данные.ИспользоватьИдентификаторПартииВЕТИССерии = Булево(ОбъектXDTO.ИспользоватьИдентификаторПартииВЕТИССерии);
	Данные.ИспользоватьМРЦМОТПСерии = Булево(ОбъектXDTO.ИспользоватьМРЦМОТПСерии);
	Данные.ИспользоватьСерии = Булево(ОбъектXDTO.ИспользоватьСерии);
	
	Если ТипЗнч(ОбъектXDTO.ОсобенностьУчета) = Тип("Строка") Тогда
		Данные.ОсобенностьУчета = Перечисления.ОсобенностиУчетаНоменклатуры[ОбъектXDTO.ОсобенностьУчета];
	КонецЕсли;
	Если ТипЗнч(ОбъектXDTO.НастройкаИспользованияСерий) = Тип("Строка") Тогда
		Данные.НастройкаИспользованияСерий = Перечисления.НастройкиИспользованияСерийНоменклатуры[ОбъектXDTO.НастройкаИспользованияСерий];
	КонецЕсли;
	Данные.АвтоматическиГенерироватьСерии = Булево(ОбъектXDTO.АвтоматическиГенерироватьСерии);
	Данные.ВладелецСерий = Справочники.ВидыНоменклатуры.ПолучитьСсылку(Новый УникальныйИдентификатор(ОбъектXDTO.ВладелецСерий));
	Данные.ШаблонЭтикеткиСерии = Справочники.ШаблоныЭтикетокИЦенников.ПолучитьСсылку(Новый УникальныйИдентификатор(ОбъектXDTO.ШаблонЭтикеткиСерии));
	Данные.НастройкиСерийБерутсяИзДругогоВидаНоменклатуры = Булево(ОбъектXDTO.НастройкиСерийБерутсяИзДругогоВидаНоменклатуры);
	Если ТипЗнч(ОбъектXDTO.ШаблонРабочегоНаименованияСерии) = Тип("ОбъектXDTO") Тогда
		Данные.ШаблонРабочегоНаименованияСерии = "";
	Иначе
		Данные.ШаблонРабочегоНаименованияСерии = Строка(ОбъектXDTO.ШаблонРабочегоНаименованияСерии);
	КонецЕсли;
	Если ТипЗнч(ОбъектXDTO.ЕдиницаИзмеренияСрокаГодности) = Тип("Строка") Тогда
		Данные.ЕдиницаИзмеренияСрокаГодности = Перечисления.ЕдиницыИзмеренияВремени[ОбъектXDTO.ЕдиницаИзмеренияСрокаГодности];
	КонецЕсли;
	Если ТипЗнч(ОбъектXDTO.ТочностьУказанияСрокаГодностиСерии) = Тип("Строка") Тогда
		Данные.ТочностьУказанияСрокаГодностиСерии = Перечисления.ТочностиУказанияСрокаГодности[ОбъектXDTO.ТочностьУказанияСрокаГодностиСерии];
	КонецЕсли;
	Данные.ИспользоватьКоличествоСерии = Булево(ОбъектXDTO.ИспользоватьКоличествоСерии);
	Данные.ПолитикаУчетаСерий = Справочники.ПолитикиУчетаСерий.ПолучитьСсылку(Новый УникальныйИдентификатор(ОбъектXDTO.ПолитикаУчетаСерий));
	Если ТипЗнч(ОбъектXDTO.НастройкиКлючаЦенПоСерии) = Тип("Строка") Тогда
		Данные.НастройкиКлючаЦенПоСерии = Перечисления.ВариантОтбораДляКлючаЦен[ОбъектXDTO.НастройкиКлючаЦенПоСерии];
	КонецЕсли;
	
	Данные.ПолитикиУчетаСерий.Очистить(); 
	
	Если ОбъектXDTO.Свойства().Получить("ПолитикиУчетаСерий") <> Неопределено Тогда   
		
		Если ТипЗнч(ОбъектXDTO.ПолитикиУчетаСерий.ЭлементПолитикиУчетаСерий) <> Тип("СписокXDTO") Тогда
			СписокXDTOСтрокаПолитикиУчета	= Новый Массив;
			СписокXDTOСтрокаПолитикиУчета.Добавить(ОбъектXDTO.ПолитикиУчетаСерий.ЭлементПолитикиУчетаСерий);
		Иначе
			СписокXDTOСтрокаПолитикиУчета = ОбъектXDTO.ПолитикиУчетаСерий.ЭлементПолитикиУчетаСерий;
		КонецЕсли;
			
		Для Каждого СтрокаПолитикиУчета Из СписокXDTOСтрокаПолитикиУчета Цикл
			НоваяСтрока = Данные.ПолитикиУчетаСерий.Добавить();
			НоваяСтрока.Склад = Справочники.Склады.ПолучитьСсылку(Новый УникальныйИдентификатор(СтрокаПолитикиУчета.Склад));
			НоваяСтрока.ПолитикаУчетаСерий = Справочники.ПолитикиУчетаСерий.ПолучитьСсылку(Новый УникальныйИдентификатор(СтрокаПолитикиУчета.ПолитикаУчетаСерий)); 
		КонецЦикла;
	КонецЕсли;
	
	Данные.РеквизитыДляКонтроляСерий.Очистить(); 
	
	Если ОбъектXDTO.Свойства().Получить("РеквизитыДляКонтроляСерий") <> Неопределено Тогда   
		
		Если ТипЗнч(ОбъектXDTO.РеквизитыДляКонтроляСерий.ЭлементРеквизитыДляКонтроляСерий) <> Тип("СписокXDTO") Тогда
			СписокXDTOСтрокаРеквизиты	= Новый Массив;
			СписокXDTOСтрокаРеквизиты.Добавить(ОбъектXDTO.РеквизитыДляКонтроляСерий.ЭлементРеквизитыДляКонтроляСерий);
		Иначе
			СписокXDTOСтрокаРеквизиты = ОбъектXDTO.РеквизитыДляКонтроляСерий.ЭлементРеквизитыДляКонтроляСерий;
		КонецЕсли;
			
		Для Каждого СтрокаРеквизиты Из СписокXDTOСтрокаРеквизиты Цикл
			НоваяСтрока = Данные.РеквизитыДляКонтроляСерий.Добавить();
			НоваяСтрока.ЭтоДопРеквизит = Булево(СтрокаРеквизиты.ЭтоДопРеквизит);
