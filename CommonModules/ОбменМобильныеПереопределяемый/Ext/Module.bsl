#Область РегистрыСведений

Функция ШтрихкодыНоменклатурыИзXML(ЧтениеXML)
	
	ОбъектXDTO = ФабрикаXDTO.ПрочитатьXML(ЧтениеXML);
	
	Штрихкод = ОбъектXDTO.Штрихкод;
	Номенклатура  = Справочники.Номенклатура.ПолучитьСсылку(Новый УникальныйИдентификатор(ОбъектXDTO.Номенклатура));
	Характеристика = Справочники.ХарактеристикиНоменклатуры.ПолучитьСсылку(Новый УникальныйИдентификатор(ОбъектXDTO.Характеристика));
	Серия = Справочники.СерииНоменклатуры.ПолучитьСсылку(Новый УникальныйИдентификатор(ОбъектXDTO.Серия));
	Упаковка = Справочники.УпаковкиЕдиницыИзмерения.ПолучитьСсылку(Новый УникальныйИдентификатор(ОбъектXDTO.Упаковка));
			
	НаборЗаписей = РегистрыСведений.ШтрихкодыНоменклатуры.СоздатьНаборЗаписей();

	НаборЗаписей.Отбор.Штрихкод.Установить(Штрихкод);
	НаборЗаписей.Отбор.Номенклатура.Установить(Номенклатура);
	НаборЗаписей.Отбор.Характеристика.Установить(Характеристика);
	НаборЗаписей.Отбор.Серия.Установить(Серия);
	НаборЗаписей.Отбор.Упаковка.Установить(Упаковка);

	НоваяЗапись = НаборЗаписей.Добавить();
	
	НоваяЗапись.Штрихкод       = Штрихкод;
	НоваяЗапись.Номенклатура   = Номенклатура;
	НоваяЗапись.Характеристика = Характеристика;
	НоваяЗапись.Серия          = Серия;
	НоваяЗапись.Упаковка       = Упаковка;
	
	Попытка
		НаборЗаписей.Записать();
	Исключение
	КонецПопытки;
	
	Возврат Неопределено;
	
КонецФункции

Функция СнимкиОтчетовИзXML(ЧтениеXML)
	
	ОбъектXDTO = ФабрикаXDTO.ПрочитатьXML(ЧтениеXML);
	
	Пользователь = Справочники.Пользователи.ПолучитьСсылку(Новый УникальныйИдентификатор(ОбъектXDTO.Пользователь));
	Если ОбъектXDTO.ОтчетТипЗначения = "ИдентификаторыОбъектовМетаданных" Тогда
		Отчет = Справочники.ИдентификаторыОбъектовМетаданных.ПолучитьСсылку(Новый УникальныйИдентификатор(ОбъектXDTO.Отчет));
	Иначе
		Отчет = Справочники.ИдентификаторыОбъектовРасширений.ПолучитьСсылку(Новый УникальныйИдентификатор(ОбъектXDTO.Отчет));
	КонецЕсли;
	Если ОбъектXDTO.ВариантТипЗначения = "ВариантыОтчетов" Тогда
		Вариант = Справочники.ВариантыОтчетов.ПолучитьСсылку(Новый УникальныйИдентификатор(ОбъектXDTO.ВариантОтчета));
	Иначе
		Вариант = Справочники.ДашбордыМЦП.ПолучитьСсылку(Новый УникальныйИдентификатор(ОбъектXDTO.ВариантОтчета));
	КонецЕсли;
	
	МенеджерЗаписи = РегистрыСведений.СнимкиОтчетов.СоздатьМенеджерЗаписи();
	
	МенеджерЗаписи.Пользователь = Пользователь;
	МенеджерЗаписи.Отчет = Отчет;
	МенеджерЗаписи.Вариант = Вариант;
	МенеджерЗаписи.ХешПользовательскойНастройки = ОбъектXDTO.ХешПользовательскойНастройки;
	
	МенеджерЗаписи.РезультатОтчета = ОбъектXDTO.РезультатОтчета.ValueStorage;
	МенеджерЗаписи.ДатаАктуальности = Дата(ОбъектXDTO.ДатаАктуальности);
	МенеджерЗаписи.ДатаПоследнегоПросмотра = Дата(ОбъектXDTO.ДатаПоследнегоПросмотра);
	
	МенеджерЗаписи.ОшибкаОбновленияОтчета = Булево(ОбъектXDTO.ОшибкаОбновленияОтчета);
	
	Попытка
		МенеджерЗаписи.Записать();
	Исключение
	КонецПопытки;
	
	Возврат Неопределено;
	
КонецФункции

Функция БлокировкиСкладскихЯчеекИзXML(ЧтениеXML)
	
	ОбъектXDTO = ФабрикаXDTO.ПрочитатьXML(ЧтениеXML);
	
	НаборЗаписей = РегистрыСведений.БлокировкиСкладскихЯчеек.СоздатьНаборЗаписей();   
	Если ОбъектXDTO.РегистраторТипЗначения = "УстановкаБлокировокЯчеек" Тогда
		Регистратор = Документы.УстановкаБлокировокЯчеек.ПолучитьСсылку(Новый УникальныйИдентификатор(ОбъектXDTO.Регистратор));
	Иначе
		Регистратор = Документы.ПересчетТоваров.ПолучитьСсылку(Новый УникальныйИдентификатор(ОбъектXDTO.Регистратор));
	КонецЕсли;   
	
	НаборЗаписей.Отбор.Регистратор.Установить(Регистратор);
	
	Если ОбъектXDTO.Свойства().Получить("Блокировки") <> Неопределено Тогда   
		
		Если ТипЗнч(ОбъектXDTO.Блокировки.ЭлементБлокировки) <> Тип("СписокXDTO") Тогда
			СписокXDTOСтрокаБлокировки	= Новый Массив;
			СписокXDTOСтрокаБлокировки.Добавить(ОбъектXDTO.Блокировки.ЭлементБлокировки);
		Иначе
			СписокXDTOСтрокаБлокировки = ОбъектXDTO.Блокировки.ЭлементБлокировки;
		КонецЕсли;
			
		Для Каждого СтрокаБлокировки Из СписокXDTOСтрокаБлокировки Цикл
			НоваяЗапись = НаборЗаписей.Добавить();
	
			НоваяЗапись.Регистратор	  = Регистратор;
			НоваяЗапись.Активность	  = Булево(СтрокаБлокировки.Активность);
			НоваяЗапись.Ячейка 		  = Справочники.СкладскиеЯчейки.ПолучитьСсылку(Новый УникальныйИдентификатор(СтрокаБлокировки.Ячейка));
			Если ТипЗнч(СтрокаБлокировки.ТипБлокировки) = Тип("Строка") Тогда
				НоваяЗапись.ТипБлокировки = Перечисления.ТипыБлокировокСкладскихЯчеек[СтрокаБлокировки.ТипБлокировки];
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
	Попытка
		НаборЗаписей.Записать();
	Исключение
	КонецПопытки;
	
	Возврат Неопределено;
	
КонецФункции

Функция НастройкиАдресныхСкладовИзXML(ЧтениеXML)
	
	ОбъектXDTO = ФабрикаXDTO.ПрочитатьXML(ЧтениеXML);
	
	НаборЗаписей = РегистрыСведений.НастройкиАдресныхСкладов.СоздатьНаборЗаписей();   
	Склад = Справочники.Склады.ПолучитьСсылку(Новый УникальныйИдентификатор(ОбъектXDTO.Склад));
	Помещение = Справочники.СкладскиеПомещения.ПолучитьСсылку(Новый УникальныйИдентификатор(ОбъектXDTO.Помещение));
	НаборЗаписей.Отбор.Склад.Установить(Склад);
	НаборЗаписей.Отбор.Помещение.Установить(Помещение);
	
	Если ОбъектXDTO.Свойства().Получить("НастройкиСкладов") <> Неопределено Тогда   
		
		Если ТипЗнч(ОбъектXDTO.НастройкиСкладов.ЭлементНастройкиСкладов) <> Тип("СписокXDTO") Тогда
			СписокXDTOСтрокаНастройкиСкладов	= Новый Массив;
			СписокXDTOСтрокаНастройкиСкладов.Добавить(ОбъектXDTO.НастройкиСкладов.ЭлементНастройкиСкладов);
		Иначе
			СписокXDTOСтрокаНастройкиСкладов = ОбъектXDTO.НастройкиСкладов.ЭлементНастройкиСкладов;
		КонецЕсли;
			
		Для Каждого СтрокаНастройкиСкладов Из СписокXDTOСтрокаНастройкиСкладов Цикл
			НоваяЗапись = НаборЗаписей.Добавить();
	
			НоваяЗапись.Склад = Склад;
			НоваяЗапись.Помещение = Помещение;
			НоваяЗапись.ИспользоватьАдресноеХранение = Булево(СтрокаНастройкиСкладов.ИспользоватьАдресноеХранение);
			НоваяЗапись.ДатаНачалаАдресногоХраненияОстатков = Дата(СтрокаНастройкиСкладов.ДатаНачалаАдресногоХраненияОстатков);
		КонецЦикла;
	КонецЕсли;
	
	Попытка
		НаборЗаписей.Записать();
	Исключение
	КонецПопытки;
	
	Возврат Неопределено;
	
КонецФункции

Функция РазмещениеНоменклатурыПоСкладскимЯчейкамИзXML(ЧтениеXML)
	
	ОбъектXDTO = ФабрикаXDTO.ПрочитатьXML(ЧтениеXML);
	
	НаборЗаписей = РегистрыСведений.РазмещениеНоменклатурыПоСкладскимЯчейкам.СоздатьНаборЗаписей();   
	Номенклатура = Справочники.Номенклатура.ПолучитьСсылку(Новый УникальныйИдентификатор(ОбъектXDTO.Номенклатура));
	Ячейка = Справочники.СкладскиеЯчейки.ПолучитьСсылку(Новый УникальныйИдентификатор(ОбъектXDTO.Ячейка));
	Склад = Справочники.Склады.ПолучитьСсылку(Новый УникальныйИдентификатор(ОбъектXDTO.Склад));
	Помещение = Справочники.СкладскиеПомещения.ПолучитьСсылку(Новый УникальныйИдентификатор(ОбъектXDTO.Помещение));
	
	НаборЗаписей.Отбор.Номенклатура.Установить(Номенклатура);
	НаборЗаписей.Отбор.Ячейка.Установить(Ячейка);
	НаборЗаписей.Отбор.Склад.Установить(Склад);
	НаборЗаписей.Отбор.Помещение.Установить(Помещение);
	
	Если ОбъектXDTO.Свойства().Получить("Размещение") <> Неопределено Тогда   
		
		Если ТипЗнч(ОбъектXDTO.Размещение.ЭлементРазмещение) <> Тип("СписокXDTO") Тогда
			СписокXDTOСтрокаРазмещение = Новый Массив;
			СписокXDTOСтрокаРазмещение.Добавить(ОбъектXDTO.Размещение.ЭлементРазмещение);
		Иначе
			СписокXDTOСтрокаРазмещение = ОбъектXDTO.Размещение.ЭлементРазмещение;
		КонецЕсли;
			
		Для Каждого СтрокаРазмещение Из СписокXDTOСтрокаРазмещение Цикл
			НоваяЗапись = НаборЗаписей.Добавить();
			
			НоваяЗапись.Номенклатура = Номенклатура;
			НоваяЗапись.Ячейка = Ячейка;
			НоваяЗапись.Склад = Склад;
			НоваяЗапись.Помещение = Помещение;
			НоваяЗапись.ОсновнаяЯчейка = Булево(СтрокаРазмещение.ОсновнаяЯчейка);
		КонецЦикла;
	КонецЕсли;
	
	Попытка
		НаборЗаписей.Записать();
	Исключение
	КонецПопытки;
	
	Возврат Неопределено;
	
КонецФункции

