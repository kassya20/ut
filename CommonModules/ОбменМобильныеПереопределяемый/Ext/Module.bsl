Функция ХарактеристикиНоменклатурыИзXML(ЧтениеXML)
	
	ОбъектXDTO = ФабрикаXDTO.ПрочитатьXML(ЧтениеXML);
	
	ДанныеСсылка = Справочники.ХарактеристикиНоменклатуры.ПолучитьСсылку(Новый УникальныйИдентификатор(ОбъектXDTO.Ссылка));
	Данные = ДанныеСсылка.ПолучитьОбъект();
	
	Если Данные = Неопределено Тогда
		Данные = Справочники.ХарактеристикиНоменклатуры.СоздатьЭлемент();
		Данные.УстановитьСсылкуНового(ДанныеСсылка);
	Иначе
		Данные = ДанныеСсылка.ПолучитьОбъект();
	КонецЕсли;
	
	ЗаполнитьЗначенияСвойств(Данные, ОбъектXDTO);
	
	Если ОбъектXDTO.Свойства().Получить("Принципал") <> Неопределено Тогда
		ТипПринципал = ОбъектXDTO.ТипПринципал;
		Тип = МобильноеРабочееМестоКладовщика.МенеджерОбъектаПоПолномуИмени(ТипПринципал);
		Данные.Принципал = Тип.ПолучитьСсылку(Новый УникальныйИдентификатор(ОбъектXDTO.Принципал));
	КонецЕсли;
	
	Если ОбъектXDTO.Свойства().Получить("Контрагент") <> Неопределено Тогда
		ТипКонтрагент = ОбъектXDTO.ТипКонтрагент;
		Тип = МобильноеРабочееМестоКладовщика.МенеджерОбъектаПоПолномуИмени(ТипКонтрагент);
		Данные.Контрагент = Тип.ПолучитьСсылку(Новый УникальныйИдентификатор(ОбъектXDTO.Контрагент));
	КонецЕсли;
	
	ТипВладелец = ОбъектXDTO.ТипВладелец;
	Тип = МобильноеРабочееМестоКладовщика.МенеджерОбъектаПоПолномуИмени(ТипВладелец);
	Данные.Владелец = Тип.ПолучитьСсылку(Новый УникальныйИдентификатор(ОбъектXDTO.Владелец));
	
	Если ТипЗнч(ОбъектXDTO.НаименованиеПолное) = Тип("ОбъектXDTO") Тогда
		Данные.НаименованиеПолное = "";
	Иначе
		Данные.НаименованиеПолное = Строка(ОбъектXDTO.НаименованиеПолное);
	КонецЕсли;
	
	Данные.ПометкаУдаления = Булево(ОбъектXDTO.ПометкаУдаления);
	
	Возврат Данные;
	
КонецФункции

Функция ВариантыКомплектацииНоменклатурыИзXML(ЧтениеXML)
	
	ОбъектXDTO = ФабрикаXDTO.ПрочитатьXML(ЧтениеXML);
	
