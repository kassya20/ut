Функция КонстантыИзXML(ЧтениеXML)
	
	ИмяОбъекта = СтрРазделить(ЧтениеXML.Имя, ".");
	
	ОбъектXDTO = ФабрикаXDTO.ПрочитатьXML(ЧтениеXML);
	
	Тип = МобильноеРабочееМестоКладовщика.МенеджерОбъектаПоПолномуИмени("Константа." + ИмяОбъекта[1]);
	ТипЗначения = ОбъектXDTO.ТипЗначения;
	Если ТипЗначения = "Число" Тогда
		Тип.Установить(Число(ОбъектXDTO.ЗначениеКонстанты));
	ИначеЕсли ТипЗначения = "Дата" Тогда
		Тип.Установить(Дата(ОбъектXDTO.ЗначениеКонстанты));
	ИначеЕсли ТипЗначения = "Булево" Тогда
		Тип.Установить(Булево(ОбъектXDTO.ЗначениеКонстанты));
	ИначеЕсли ТипЗначения = "Строка" Тогда
		Если ТипЗнч(ОбъектXDTO.ЗначениеКонстанты) = Тип("ОбъектXDTO") Тогда
			Тип.Установить("");
		Иначе
			Тип.Установить(Строка(ОбъектXDTO.ЗначениеКонстанты));
		КонецЕсли;
	ИначеЕсли СтрРазделить(ТипЗначения, ".")[0] = "Перечисление" Тогда
		Если ТипЗнч(ОбъектXDTO.ЗначениеКонстанты) = Тип("Строка") Тогда
			ТипЗначения = МобильноеРабочееМестоКладовщика.МенеджерОбъектаПоПолномуИмени(ТипЗначения);
			Тип.Установить(ТипЗначения[ОбъектXDTO.ЗначениеКонстанты]);
		КонецЕсли;
	Иначе
		ТипЗначения = МобильноеРабочееМестоКладовщика.МенеджерОбъектаПоПолномуИмени(ТипЗначения);
		Тип.Установить(ТипЗначения.ПолучитьСсылку(Новый УникальныйИдентификатор(ОбъектXDTO.ЗначениеКонстанты)));
	КонецЕсли;
	
	Возврат НеОпределено;
	
КонецФункции

#Область Справочники

Функция ПрочиеСправочникиИзXML(ЧтениеXML)
	
	ИмяОбъекта = СтрРазделить(ЧтениеXML.Имя, ".");
	ОбъектXDTO = ФабрикаXDTO.ПрочитатьXML(ЧтениеXML); // ОбъектXDTO
	
	Тип = МобильноеРабочееМестоКладовщика.МенеджерОбъектаПоПолномуИмени("Справочник." + ИмяОбъекта[1]);
	ДанныеСсылка = Тип.ПолучитьСсылку(Новый УникальныйИдентификатор(ОбъектXDTO.Ссылка));
	Данные = ДанныеСсылка.ПолучитьОбъект();
	
	Если Данные = Неопределено Тогда
		Данные = Тип.СоздатьЭлемент();
		Данные.УстановитьСсылкуНового(ДанныеСсылка);
	Иначе
		Данные = ДанныеСсылка.ПолучитьОбъект();
	КонецЕсли;
	
	ЗаполнитьЗначенияСвойств(Данные, ОбъектXDTO);
	
	Если ОбъектXDTO.Свойства().Получить("Организация") <> Неопределено Тогда
		Данные.Организация = Справочники.Организации.ПолучитьСсылку(Новый УникальныйИдентификатор(ОбъектXDTO.Организация));
	КонецЕсли;
	
	Возврат Данные;
	
КонецФункции

Функция УпаковкиЕдиницыИзмеренияИзXML(ЧтениеXML)
	
	ОбъектXDTO = ФабрикаXDTO.ПрочитатьXML(ЧтениеXML);
	
	ДанныеСсылка = Справочники.УпаковкиЕдиницыИзмерения.ПолучитьСсылку(Новый УникальныйИдентификатор(ОбъектXDTO.Ссылка));
	Данные = ДанныеСсылка.ПолучитьОбъект();
	
	Если Данные = Неопределено Тогда
		Данные = Справочники.УпаковкиЕдиницыИзмерения.СоздатьЭлемент();
		Данные.УстановитьСсылкуНового(ДанныеСсылка);
	Иначе
		Данные = ДанныеСсылка.ПолучитьОбъект();
	КонецЕсли;
	
	ЗаполнитьЗначенияСвойств(Данные, ОбъектXDTO);
	
