Функция СерииНоменклатурыИзXML(ЧтениеXML)
	
	ОбъектXDTO = ФабрикаXDTO.ПрочитатьXML(ЧтениеXML);
	
	ДанныеСсылка = Справочники.СерииНоменклатуры.ПолучитьСсылку(Новый УникальныйИдентификатор(ОбъектXDTO.Ссылка));
	Данные = ДанныеСсылка.ПолучитьОбъект();
	
	Если Данные = Неопределено Тогда
		Данные = Справочники.СерииНоменклатуры.СоздатьЭлемент();
		Данные.УстановитьСсылкуНового(ДанныеСсылка);
	Иначе
		Данные = ДанныеСсылка.ПолучитьОбъект();
	КонецЕсли;
	
	ЗаполнитьЗначенияСвойств(Данные, ОбъектXDTO);
	
	Данные.ВидНоменклатуры = Справочники.ВидыНоменклатуры.ПолучитьСсылку(Новый УникальныйИдентификатор(ОбъектXDTO.ВидНоменклатуры));
	Данные.ПометкаУдаления = Булево(ОбъектXDTO.ПометкаУдаления);
	
	Данные.ГоденДо = Дата(ОбъектXDTO.ГоденДо);
	Данные.ДатаПроизводства = Дата(ОбъектXDTO.ДатаПроизводства);
	Если ТипЗнч(ОбъектXDTO.Номер) = Тип("ОбъектXDTO") Тогда
		Данные.Номер = "";
	Иначе
		Данные.Номер = Строка(ОбъектXDTO.Номер);
	КонецЕсли;
	
	Если ТипЗнч(ОбъектXDTO.RFIDTID) = Тип("ОбъектXDTO") Тогда
		Данные.RFIDTID = "";
	Иначе
		Данные.RFIDTID = Строка(ОбъектXDTO.RFIDTID);
	КонецЕсли;
	Если ТипЗнч(ОбъектXDTO.RFIDUser) = Тип("ОбъектXDTO") Тогда
		Данные.RFIDUser = "";
	Иначе
		Данные.RFIDUser = Строка(ОбъектXDTO.RFIDUser);
	КонецЕсли;
	Если ТипЗнч(ОбъектXDTO.RFIDEPC) = Тип("ОбъектXDTO") Тогда
		Данные.RFIDEPC = "";
	Иначе
		Данные.RFIDEPC = Строка(ОбъектXDTO.RFIDEPC);
	КонецЕсли;
	Если ТипЗнч(ОбъектXDTO.EPCGTIN) = Тип("ОбъектXDTO") Тогда
		Данные.EPCGTIN = "";
	Иначе
		Данные.EPCGTIN = Строка(ОбъектXDTO.EPCGTIN);
	КонецЕсли;
	
	Данные.RFIDМеткаНеЧитаемая = Булево(ОбъектXDTO.RFIDМеткаНеЧитаемая);
	
	Если ТипЗнч(ОбъектXDTO.НомерКиЗГИСМ) = Тип("ОбъектXDTO") Тогда
		Данные.НомерКиЗГИСМ = "";
	Иначе
		Данные.НомерКиЗГИСМ = Строка(ОбъектXDTO.НомерКиЗГИСМ);
	КонецЕсли;
	
	Если ТипЗнч(ОбъектXDTO.ИдентификаторПартииВЕТИС) = Тип("ОбъектXDTO") Тогда
		Данные.ИдентификаторПартииВЕТИС = "";
	Иначе
		Данные.ИдентификаторПартииВЕТИС = Строка(ОбъектXDTO.ИдентификаторПартииВЕТИС);
	КонецЕсли;
	Данные.МаксимальнаяРозничнаяЦенаМОТП = Число(ОбъектXDTO.МаксимальнаяРозничнаяЦенаМОТП);
	
	Возврат Данные;
	
КонецФункции

