Функция ЗаказПоставщикуИзXML(ЧтениеXML)
	
	ОбъектXDTO = ФабрикаXDTO.ПрочитатьXML(ЧтениеXML);
	
	ДанныеСсылка = Документы.ЗаказПоставщику.ПолучитьСсылку(Новый УникальныйИдентификатор(ОбъектXDTO.Ссылка));
	Данные = ДанныеСсылка.ПолучитьОбъект();
	
	Если Данные = Неопределено Тогда
		Данные = Документы.ЗаказПоставщику.СоздатьДокумент();
		Данные.УстановитьСсылкуНового(ДанныеСсылка);
	Иначе
		Данные = ДанныеСсылка.ПолучитьОбъект();
	КонецЕсли;
			
	ЗаполнитьЗначенияСвойств(Данные, ОбъектXDTO); 
	
	Данные.Дата = Дата(ОбъектXDTO.Дата);
	Данные.ПометкаУдаления = Булево(ОбъектXDTO.ПометкаУдаления);
	Данные.Проведен = Булево(ОбъектXDTO.Проведен);
	Данные.Организация = Справочники.Организации.ПолучитьСсылку(Новый УникальныйИдентификатор(ОбъектXDTO.Организация));
	Данные.Менеджер = Справочники.Пользователи.ПолучитьСсылку(Новый УникальныйИдентификатор(ОбъектXDTO.Менеджер));
		
	Возврат Данные;
	
КонецФункции

Функция КорректировкаПоОрдеруИзXML(ЧтениеXML)
	
	ОбъектXDTO = ФабрикаXDTO.ПрочитатьXML(ЧтениеXML);
	
	ДанныеСсылка = Документы.КорректировкаПоОрдеруНаТовары.ПолучитьСсылку(Новый УникальныйИдентификатор(ОбъектXDTO.Ссылка));
	Данные = ДанныеСсылка.ПолучитьОбъект();
	
	Если Данные = Неопределено Тогда
		Данные = Документы.КорректировкаПоОрдеруНаТовары.СоздатьДокумент();
		Данные.УстановитьСсылкуНового(ДанныеСсылка);
	Иначе
		Данные = ДанныеСсылка.ПолучитьОбъект();
	КонецЕсли;
			
	ЗаполнитьЗначенияСвойств(Данные, ОбъектXDTO); 
	
	Данные.Дата = Дата(ОбъектXDTO.Дата);
	Данные.ПометкаУдаления = Булево(ОбъектXDTO.ПометкаУдаления);
	Данные.Проведен = Булево(ОбъектXDTO.Проведен);
	
	Данные.ЗонаОтгрузки = Справочники.СкладскиеЯчейки.ПолучитьСсылку(Новый УникальныйИдентификатор(ОбъектXDTO.ЗонаОтгрузки));
	Данные.Ответственный = Справочники.Пользователи.ПолучитьСсылку(Новый УникальныйИдентификатор(ОбъектXDTO.Ответственный));
	Данные.Помещение = Справочники.СкладскиеПомещения.ПолучитьСсылку(Новый УникальныйИдентификатор(ОбъектXDTO.Помещение));
	Данные.Склад = Справочники.Склады.ПолучитьСсылку(Новый УникальныйИдентификатор(ОбъектXDTO.Склад));
	
	ТипОрдер = ОбъектXDTO.ТипОрдер;
	Тип = МобильноеРабочееМестоКладовщика.МенеджерОбъектаПоПолномуИмени(ТипОрдер);
	Данные.Ордер = Тип.ПолучитьСсылку(Новый УникальныйИдентификатор(ОбъектXDTO.Ордер));
	
	Если ОбъектXDTO.Свойства().Получить("ОрдерПолучатель") <> Неопределено Тогда
		ТипОрдерПолучатель = ОбъектXDTO.ТипОрдерПолучатель;
		Тип = МобильноеРабочееМестоКладовщика.МенеджерОбъектаПоПолномуИмени(ТипОрдерПолучатель);
		Данные.ОрдерПолучатель = Тип.ПолучитьСсылку(Новый УникальныйИдентификатор(ОбъектXDTO.ОрдерПолучатель));
	КонецЕсли;
	
	Данные.Товары.Очистить(); 
	
	Если ОбъектXDTO.Свойства().Получить("Товары") <> Неопределено Тогда   
		
		Если ТипЗнч(ОбъектXDTO.Товары.ЭлементТовары) <> Тип("СписокXDTO") Тогда
			СписокXDTOСтрокаТовары	= Новый Массив;
			СписокXDTOСтрокаТовары.Добавить(ОбъектXDTO.Товары.ЭлементТовары);
		Иначе
			СписокXDTOСтрокаТовары = ОбъектXDTO.Товары.ЭлементТовары;
		КонецЕсли;
			
		Для Каждого СтрокаТовары Из СписокXDTOСтрокаТовары Цикл
			НоваяСтрока = Данные.Товары.Добавить();
			НоваяСтрока.Количество = Число(СтрокаТовары.Количество);
			НоваяСтрока.Номенклатура = Справочники.Номенклатура.ПолучитьСсылку(Новый УникальныйИдентификатор(СтрокаТовары.Номенклатура));
			НоваяСтрока.Характеристика = Справочники.ХарактеристикиНоменклатуры.ПолучитьСсылку(Новый УникальныйИдентификатор(СтрокаТовары.Характеристика));
			НоваяСтрока.Серия = Справочники.СерииНоменклатуры.ПолучитьСсылку(Новый УникальныйИдентификатор(СтрокаТовары.Серия));
			НоваяСтрока.Назначение = Справочники.Назначения.ПолучитьСсылку(Новый УникальныйИдентификатор(СтрокаТовары.Назначение));
			НоваяСтрока.Упаковка = Справочники.УпаковкиЕдиницыИзмерения.ПолучитьСсылку(Новый УникальныйИдентификатор(СтрокаТовары.Упаковка));
			НоваяСтрока.КоличествоУпаковок = Число(СтрокаТовары.КоличествоУпаковок);
			НоваяСтрока.СтатусУказанияСерий = Число(СтрокаТовары.СтатусУказанияСерий);
			
			Если ТипЗнч(СтрокаТовары.ВидОперации) = Тип("Строка") Тогда
				НоваяСтрока.ВидОперации = Перечисления.ВидыОперацийКорректировокОстатковТоваров[СтрокаТовары.ВидОперации];
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
	Возврат Данные;
	
КонецФункции

Функция ПрочиеДокументыИзXML(ЧтениеXML)
	
	ИмяОбъекта = СтрРазделить(ЧтениеXML.Имя, ".");
	ОбъектXDTO = ФабрикаXDTO.ПрочитатьXML(ЧтениеXML); // ОбъектXDTO
	
	Тип = МобильноеРабочееМестоКладовщика.МенеджерОбъектаПоПолномуИмени("Документ." + ИмяОбъекта[1]);
	ДанныеСсылка = Тип.ПолучитьСсылку(Новый УникальныйИдентификатор(ОбъектXDTO.Ссылка));
	Данные = ДанныеСсылка.ПолучитьОбъект();
	
	Если Данные = Неопределено Тогда
		Данные = Тип.СоздатьДокумент();
		Данные.УстановитьСсылкуНового(ДанныеСсылка);
	Иначе
		Данные = ДанныеСсылка.ПолучитьОбъект();
	КонецЕсли;
			
	ЗаполнитьЗначенияСвойств(Данные, ОбъектXDTO);
	
	Возврат Данные;
	
КонецФункции

