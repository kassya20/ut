Функция ТекстСкорректироватьСтоимостьПрошлыхПериодов(ПараметрыРасчета)
	
	ТекстыВтВыбытияДляОтклонений = Новый Массив;
	ТекстыВтВыбытияДляОтклонений.Добавить(ТекстОписаниеДанныхДляВтВыбытияДляОтклонений()); // вт ВтВыбытияДляОтклонений
	ТекстыВтВыбытияДляОтклонений.Добавить(ТекстДвиженияСебестоимостиТоваровПоПериодам());
	ТекстыВтВыбытияДляОтклонений.Добавить(ТекстСписаниеОтклоненийНаСебестоимостьПродаж());
	ТекстыВтВыбытияДляОтклонений.Добавить(ТекстРаспределениеРасходовНаСебестоимостьТоваров());
	ТекстыВтВыбытияДляОтклонений.Добавить(ТекстРаспределениеРасходовНаПартииПроизводства());
	ТекстыВтВыбытияДляОтклонений.Добавить(ТекстРаспределениеРасходовНаФинансовыйРезультатИПрочее());
	ТекстыВтВыбытияДляОтклонений.Добавить(ТекстСписаниеОтклоненийКРаспределению());
	ТекстыВтВыбытияДляОтклонений.Добавить(ТекстСписаниеОтклоненийПрочихРасходовКРаспределению());
	ТекстыВтВыбытияДляОтклонений.Добавить(ТекстКорректировкаОтклоненийНеСоответствующихПрочимРасходам());
	ТекстВтВыбытияДляОтклонений = СтрСоединить(ТекстыВтВыбытияДляОтклонений, ОбщегоНазначения.ТекстОбъединитьВсе());
	ТекстВтВыбытияДляОтклонений = ТекстВтВыбытияДляОтклонений + "
	|ИНДЕКСИРОВАТЬ ПО
	|	НомерУзлаИсточник
	|";
	
	ТекстыЗапросов = Новый Массив;
	ТекстыЗапросов.Добавить(ТекстТаблицаРешенийДетально()); // ТаблицаРешенийДетально
	ТекстыЗапросов.Добавить(ТекстТаблицаРешенийПрочиеРасходыДетально()); // вт ТаблицаРешенийПрочиеРасходыДетально
	ТекстыЗапросов.Добавить(ТекстВтНеактуальныеДвиженияПрочиеРасходыПредварительная()); // ВтНеактуальныеДвиженияПрочиеРасходыПредварительная
	ТекстыЗапросов.Добавить(ТекстВтНеактуальныеДвиженияПрочиеРасходы()); // ВтНеактуальныеДвиженияПрочиеРасходы
	ТекстыЗапросов.Добавить(ТекстВтВыбытияДляОтклонений); // ВтВыбытияДляОтклонений
	ТекстыЗапросов.Добавить(ТекстВтДвиженияСебестоимостиТоваров()); // ВтДвиженияСебестоимостиТоваров
	ТекстыЗапросов.Добавить(ТекстВтДвиженияВыручка()); // ВтДвиженияВыручка
	ТекстыЗапросов.Добавить(ТекстВтДвиженияПрочиеРасходы()); // ВтДвиженияПрочиеРасходы
	ТекстыЗапросов.Добавить(ТекстВтДвиженияПрочиеАктивыПассивы()); // ВтДвиженияПрочиеАктивыПассивы
	
	
	ТекстЗапроса = СтрСоединить(ТекстыЗапросов, ОбщегоНазначения.РазделительПакетаЗапросов());	
	Если ПараметрыРасчета <> Неопределено Тогда
		ТекстЗапроса = УстановитьРазрядностьЧиселВТекстеЗапроса(ПараметрыРасчета, ТекстЗапроса);
	КонецЕсли;
	
	Возврат ТекстЗапроса;
	
КонецФункции	

// ... формирования временные таблиц

Функция ТекстТаблицаРешенийДетально() // вт ТаблицаРешенийДетально
	Возврат "	
		|ВЫБРАТЬ
		|	ВЫРАЗИТЬ(Узлы.НомерУзла КАК ЧИСЛО(31,0)) КАК НомерУзла,
		|	Регистраторы.Ссылка КАК Регистратор,
		|	Узлы.ПериодОтклонения,
		|	Узлы.ПериодРаспределения,
		|
		|	Узлы.АналитикаУчетаНоменклатуры КАК АналитикаУчетаНоменклатуры,
		|	Узлы.РазделУчета КАК РазделУчета,
		|	Узлы.ВидЗапасов КАК ВидЗапасов,
		|	Узлы.Организация КАК Организация,
		|	Узлы.Партия КАК Партия,
		|	Узлы.АналитикаУчетаПартий КАК АналитикаУчетаПартий,
		|	Узлы.АналитикаФинансовогоУчета КАК АналитикаФинансовогоУчета,
		|	Узлы.ВидДеятельностиНДС КАК ВидДеятельностиНДС,
		|
		|	ЕСТЬNULL(ТаблицаРешений.ОтклоненияВСтоимостиСНДС, 0) КАК ОтклоненияВСтоимостиСНДС,
		|	ЕСТЬNULL(ТаблицаРешений.ОтклоненияВСтоимостиБезНДС, 0) КАК ОтклоненияВСтоимостиБезНДС,
		|	ЕСТЬNULL(ТаблицаРешений.ОтклоненияВСтоимостиРегл, 0) КАК ОтклоненияВСтоимостиРегл,
		|	ЕСТЬNULL(ТаблицаРешений.ОтклоненияВСтоимостиУпр, 0) КАК ОтклоненияВСтоимостиУпр,
		|	0 КАК НДСРегл,
		|	0 КАК НДСУпр,
		|	ЕСТЬNULL(ТаблицаРешений.ДопРасходыСНДС, 0) КАК ДопРасходыСНДС,
		|	ЕСТЬNULL(ТаблицаРешений.ДопРасходыБезНДС, 0) КАК ДопРасходыБезНДС,
		|	ЕСТЬNULL(ТаблицаРешений.ДопРасходыРегл, 0) КАК ДопРасходыРегл,
		|	ЕСТЬNULL(ТаблицаРешений.ДопРасходыУпр, 0) КАК ДопРасходыУпр,
		|	ЕСТЬNULL(ТаблицаРешений.ПостояннаяРазница, 0) КАК ПостояннаяРазница,
		|	ЕСТЬNULL(ТаблицаРешений.ВременнаяРазница, 0) КАК ВременнаяРазница,
		|	ЕСТЬNULL(ТаблицаРешений.НДД, 0) КАК НДД,
		|	(НЕ ТаблицаРешений.НомерУзла ЕСТЬ NULL) КАК ЕстьСтоимость
		|
		|ПОМЕСТИТЬ ТаблицаРешенийДетально
		|ИЗ
		|	ВТУзлыОтклонений КАК Узлы
		|	ЛЕВОЕ СОЕДИНЕНИЕ ВтТаблицаРешений_ПрошлыйПериод КАК ТаблицаРешений
		|		ПО ТаблицаРешений.НомерУзла = Узлы.НомерУзла
		|	ЛЕВОЕ СОЕДИНЕНИЕ ВТРегистраторыРасчетаСебестоимости КАК Регистраторы
		|		ПО Узлы.Организация = Регистраторы.Организация
		|ГДЕ
		|	Узлы.СтатьяРасходов = ЗНАЧЕНИЕ(ПланВидовХарактеристик.СтатьиРасходов.ПустаяСсылка)
		|	И Узлы.Номенклатура <> НЕОПРЕДЕЛЕНО
		|
		|ИНДЕКСИРОВАТЬ ПО
		|	НомерУзла
		|";
КонецФункции

