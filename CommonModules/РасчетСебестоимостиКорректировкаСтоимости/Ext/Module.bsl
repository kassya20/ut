		|ГДЕ
		|	Узлы.СтатьяРасходов <> ЗНАЧЕНИЕ(ПланВидовХарактеристик.СтатьиРасходов.ПустаяСсылка)
		|	И Узлы.СтатьяРасходов <> НЕОПРЕДЕЛЕНО
		|	И Узлы.Номенклатура = НЕОПРЕДЕЛЕНО
		|
		|ИНДЕКСИРОВАТЬ ПО
		|	Организация,
		|	Подразделение,
		|	СтатьяРасходов
		|";
КонецФункции

// Тексты запросов формирования таблицы ВтВыбытияДляОтклонений.

Функция ТекстОписаниеДанныхДляВтВыбытияДляОтклонений() // ВтВыбытияДляОтклонений Количество полей 8 + 7 + 6 + 7 + 6 + 17
	
	ТекстЗапроса = "
		|ВЫБРАТЬ ПЕРВЫЕ 0
		|	""0"" КАК ЗапросИсточник,
		|	ЛОЖЬ КАК ЭтоОстатки,
		|	ЛОЖЬ КАК ЭтоТекущийПериод,
		|	ЛОЖЬ КАК ЕстьКорЧасть,
		|	0 КАК НомерУзлаИсточник,
		|	0 КАК НомерУзлаПриемник,
		|	Т.Регистратор,
		|	Т.Период,
		// Измерения отклонений
		|	Т.Организация КАК Организация,
		|	Т.АналитикаУчетаНоменклатуры.Номенклатура КАК Номенклатура,
		|	Т.АналитикаУчетаНоменклатуры.Характеристика КАК Характеристика,
		|	Т.ВидЗапасов,
		|	Т.АналитикаУчетаНоменклатуры.Назначение.НаправлениеДеятельности КАК НаправлениеДеятельности,
		|	Т.Подразделение,
		|	Т.АналитикаУчетаНоменклатуры.МестоХранения КАК МестоХранения,
		// Измерения себестоимости
		|	Т.АналитикаУчетаНоменклатуры КАК АналитикаУчетаНоменклатуры,
		|	Т.РазделУчета КАК РазделУчета,
		|	Т.Партия КАК Партия,
		|	Т.АналитикаУчетаПартий КАК АналитикаУчетаПартий,
		|	Т.АналитикаФинансовогоУчета КАК АналитикаФинансовогоУчета,
		|	Т.ВидДеятельностиНДС КАК ВидДеятельностиНДС,
		// Кор реквизиты отклонений
		|	Т.КорОрганизация,
		|	Т.КорАналитикаУчетаНоменклатуры.Номенклатура КАК КорНоменклатура,
		|	Т.КорАналитикаУчетаНоменклатуры.Характеристика КАК КорХарактеристика,
		|	Т.КорВидЗапасов,
		|	Т.КорАналитикаУчетаНоменклатуры.Назначение.НаправлениеДеятельности КАК КорНаправлениеДеятельности,
		|	Т.Подразделение КАК КорПодразделение,
		|	Т.КорАналитикаУчетаНоменклатуры.МестоХранения КАК КорМестоХранения,
		// Кор реквизиты себестоимости
		|	Т.КорАналитикаУчетаНоменклатуры,
		|	Т.КорРазделУчета,
		|	Т.КорПартия,
		|	Т.КорАналитикаУчетаПартий,
		|	Т.КорАналитикаФинансовогоУчета,
		|	Т.КорВидДеятельностиНДС,
		// Прочие поля
		|	Т.АналитикаУчетаПоПартнерам КАК АналитикаУчетаПоПартнерам,
		|	НЕОПРЕДЕЛЕНО КАК СтатьяКалькуляции,
		|	НЕОПРЕДЕЛЕНО КАК ПравилоОтнесенияНаВыпуск,
		|	Т.СтатьяРасходовСписания КАК СтатьяРасходовСписания,
		|	Т.АналитикаРасходов КАК АналитикаРасходов,
		|	Т.СтатьяРасходовСписания КАК КорСтатьяРасходов,
		|	Т.АналитикаРасходов КАК КорАналитикаРасходов,
		|	Т.СтатьяАктивовПассивов КАК СтатьяАктивовПассивов,
		|	Т.АналитикаАктивовПассивов КАК АналитикаАктивовПассивов,
		|	Т.НастройкаСчетовУчета КАК НастройкаСчетовУчета,
		|	Т.ХозяйственнаяОперация КАК ХозяйственнаяОперация,
		|	Т.НастройкаХозяйственнойОперации КАК НастройкаХозяйственнойОперации,
		|	Т.ИдентификаторФинЗаписи КАК ИдентификаторФинЗаписи,
		|	ДАТАВРЕМЯ(1,1,1) КАК ПериодРаспределения,
		|	ДАТАВРЕМЯ(1,1,1) КАК ПериодОтклоненияИсточник,
		|	ДАТАВРЕМЯ(1,1,1) КАК ПериодОтклоненияПриемник,
		|	ЛОЖЬ КАК Сторно,
		|	ЛОЖЬ КАК СписыватьОтклоненияНаСебестоимостьПродаж,
		// Ресурсы
		|	Т.Количество КАК Количество,
		|	0 КАК ОтклоненияВСтоимостиСНДС,
		|	0 КАК ОтклоненияВСтоимостиБезНДС,
		|	0 КАК ОтклоненияВСтоимостиРегл,
		|	0 КАК ОтклоненияВСтоимостиУпр,
		|	0 КАК НДСРегл,
		|	0 КАК НДСУпр,
		|	0 КАК ДопРасходыСНДС,
		|	0 КАК ДопРасходыБезНДС,
		|	0 КАК ДопРасходыРегл,
		|	0 КАК ДопРасходыУпр,
		|	0 КАК ПостояннаяРазница,
		|	0 КАК ВременнаяРазница,
		|	0 КАК НДД
		|
		|ПОМЕСТИТЬ ВтВыбытияДляОтклонений
		|ИЗ
		|	РегистрНакопления.СебестоимостьТоваров КАК Т
		|";

	ТекстЗапроса = РасчетСебестоимостиПрикладныеАлгоритмы.ПодготовитьЗапросОписанияДанных(ТекстЗапроса);
	
	Возврат ТекстЗапроса;
	
КонецФункции

Функция ТекстДвиженияСебестоимостиТоваровПоПериодам() // использует ВтДвиженияСебестоимостиТоваровПоПериодам
	Возврат "	
		|ВЫБРАТЬ
		|	""ТекстДвиженияСебестоимостиТоваровПоПериодам"" КАК ЗапросИсточник,
		|	ЛОЖЬ КАК ЭтоОстатки,
		|	Т.ЭтоТекущийПериод,
		|	Т.ЕстьКорЧасть,
		|	Т.НомерУзлаИсточник КАК НомерУзлаИсточник,
		|	Т.НомерУзлаПриемник КАК НомерУзлаПриемник,
		|	УзлыИсточники.Регистратор,
		|	Т.Период,
		// Измерения отклонений
		|	Т.Организация КАК Организация,
		|	Т.Номенклатура КАК Номенклатура,
		|	Т.Характеристика КАК Характеристика,
		|	Т.ВидЗапасов,
		|	Т.НаправлениеДеятельности КАК НаправлениеДеятельности,
		|	Т.Подразделение,
		|	Т.МестоХранения КАК МестоХранения,
		// Измерения себестоимости
		|	Т.АналитикаУчетаНоменклатуры КАК АналитикаУчетаНоменклатуры,
		|	Т.РазделУчета КАК РазделУчета,
		|	Т.Партия КАК Партия,
		|	Т.АналитикаУчетаПартий КАК АналитикаУчетаПартий,
		|	Т.АналитикаФинансовогоУчета КАК АналитикаФинансовогоУчета,
		|	Т.ВидДеятельностиНДС КАК ВидДеятельностиНДС,
		// Кор реквизиты отклонений
		|	Т.КорОрганизация,
		|	Т.КорНоменклатура КАК КорНоменклатура,
		|	Т.КорХарактеристика КорХарактеристика,
		|	Т.КорВидЗапасов,
		|	Т.КорНаправлениеДеятельности КАК КорНаправлениеДеятельности,
		|	Т.КорПодразделение КАК КорПодразделение,
		|	Т.КорМестоХранения КорМестоХранения,
		// Кор реквизиты
		|	Т.КорАналитикаУчетаНоменклатуры,
		|	Т.КорРазделУчета,
		|	Т.КорПартия,
		|	Т.КорАналитикаУчетаПартий,
		|	Т.КорАналитикаФинансовогоУчета,
		|	Т.КорВидДеятельностиНДС,
		// Прочие поля
		|	Т.АналитикаУчетаПоПартнерам КАК АналитикаУчетаПоПартнерам,
		|	НЕОПРЕДЕЛЕНО КАК СтатьяКалькуляции,
		|	НЕОПРЕДЕЛЕНО КАК ПравилоОтнесенияНаВыпуск,
		|	Т.СтатьяРасходовСписания КАК СтатьяРасходовСписания,
		|	Т.АналитикаРасходов КАК АналитикаРасходов,
		|	Т.СтатьяРасходовСписания КАК КорСтатьяРасходов,
		|	Т.АналитикаРасходов КАК КорАналитикаРасходов,
		|	Т.СтатьяАктивовПассивов КАК СтатьяАктивовПассивов,
		|	Т.АналитикаАктивовПассивов КАК АналитикаАктивовПассивов,
		|	Т.НастройкаСчетовУчета КАК НастройкаСчетовУчета,
		|	Т.ХозяйственнаяОперация КАК ХозяйственнаяОперация,
		// Поле НастройкаХозяйственнойОперации должно заполняться аналогично запросам:
		// ТекстСторноДвиженияПоИсправлениямПрошлогоПериодаСреднескользящая() и ТекстВтНеактуальныеДвиженияПредварительная().
		|	(ВЫБОР
		|		КОГДА НЕ Т.Организация В (&ОрганизацииСреднескользящая)
		|			ТОГДА Т.НастройкаХозяйственнойОперации
		// Для организаций на среднескользящей используются отдельные настройки хоз. операций для отражения
		// движений по регистру "Отклонения в стоимости товаров".
		|		КОГДА Т.ХозяйственнаяОперация = ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.ПередачаНаПрочиеЦели)
		|		 ИЛИ Т.СтатьяАктивовПассивов <> НЕОПРЕДЕЛЕНО
		|		 И Т.СтатьяАктивовПассивов <> ЗНАЧЕНИЕ(ПланВидовХарактеристик.СтатьиАктивовПассивов.ПустаяСсылка)
		|		 И Т.ХозяйственнаяОперация <> ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.РеализацияТоваровВДругуюОрганизацию)
		|			ТОГДА ЗНАЧЕНИЕ(Справочник.НастройкиХозяйственныхОпераций.ПередачаНаПрочиеЦелиОтклонения)
		|		КОГДА Т.ХозяйственнаяОперация = ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.ПередачаПродукцииИзПроизводства)
		|		 И Т.СписыватьОтклоненияНаСебестоимостьПродаж
		|			ТОГДА ЗНАЧЕНИЕ(Справочник.НастройкиХозяйственныхОпераций.ПередачаПродукцииИзПроизводстваОтклонения)
		|		КОГДА Т.ХозяйственнаяОперация = ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.ВыпускПродукции)
		|			ТОГДА ЗНАЧЕНИЕ(Справочник.НастройкиХозяйственныхОпераций.ВыпускПродукцииОтклонения)
		|		КОГДА Т.ХозяйственнаяОперация = ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.ОтчетДавальцуМеждуОрганизациями)
		|			ТОГДА ЗНАЧЕНИЕ(Справочник.НастройкиХозяйственныхОпераций.ОтчетДавальцуМеждуОрганизациямиОтклонения)
		|		КОГДА НЕ Т.ЕстьКорЧасть
		|		 И Т.СтатьяРасходовСписания <> НЕОПРЕДЕЛЕНО
		|		 И Т.СтатьяРасходовСписания <> ЗНАЧЕНИЕ(ПланВидовХарактеристик.СтатьиРасходов.ПустаяСсылка)
		|		 И Т.ХозяйственнаяОперация <> ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.РеализацияТоваровВДругуюОрганизацию)
		|			ТОГДА ЗНАЧЕНИЕ(Справочник.НастройкиХозяйственныхОпераций.СписаниеНаРасходыОтклонения)
		|		ИНАЧЕ Т.НастройкаХозяйственнойОперации КОНЕЦ) КАК НастройкаХозяйственнойОперации,
		|	Т.ИдентификаторФинЗаписи КАК ИдентификаторФинЗаписи,
		|	Т.ПериодРаспределения КАК ПериодРаспределения,
		|	Т.ПериодРаспределенияИсточник КАК ПериодРаспределенияИсточник,
		|	Т.ПериодРаспределенияПриемник КАК ПериодРаспределенияПриемник,
		|	ЛОЖЬ КАК Сторно,
		|	ЛОЖЬ КАК СписыватьОтклоненияНаСебестоимостьПродаж,
		// Ресурсы
		|	Т.Количество КАК Количество,
		|	ВЫРАЗИТЬ(Т.Количество * УзлыИсточники.ОтклоненияВСтоимостиСНДС КАК ЧИСЛО(31,2)) КАК ОтклоненияВСтоимостиСНДС,
		|	ВЫРАЗИТЬ(Т.Количество * УзлыИсточники.ОтклоненияВСтоимостиБезНДС КАК ЧИСЛО(31,2)) КАК ОтклоненияВСтоимостиБезНДС,
		|	ВЫРАЗИТЬ(Т.Количество *
		|		ВЫБОР КОГДА Т.СписыватьОтклоненияНаСебестоимостьПродаж ТОГДА 0
		|		ИНАЧЕ УзлыИсточники.ОтклоненияВСтоимостиРегл КОНЕЦ КАК ЧИСЛО(31,2)) КАК ОтклоненияВСтоимостиРегл,
		|	ВЫРАЗИТЬ(Т.Количество *
		|		ВЫБОР КОГДА Т.СписыватьОтклоненияНаСебестоимостьПродаж ТОГДА 0
		|		ИНАЧЕ УзлыИсточники.ОтклоненияВСтоимостиУпр КОНЕЦ КАК ЧИСЛО(31,2)) КАК ОтклоненияВСтоимостиУпр,
		|	ВЫРАЗИТЬ(Т.Количество *
		|		ВЫБОР КОГДА Т.СписыватьОтклоненияНаСебестоимостьПродаж ТОГДА 0
		|		ИНАЧЕ УзлыИсточники.НДСРегл КОНЕЦ КАК ЧИСЛО(31,2)) КАК НДСРегл,
		|	ВЫРАЗИТЬ(Т.Количество *
		|		ВЫБОР КОГДА Т.СписыватьОтклоненияНаСебестоимостьПродаж ТОГДА 0
		|		ИНАЧЕ УзлыИсточники.НДСУпр КОНЕЦ КАК ЧИСЛО(31,2)) КАК НДСУпр,
		|	ВЫРАЗИТЬ(Т.Количество * УзлыИсточники.ДопРасходыСНДС КАК ЧИСЛО(31,2)) КАК ДопРасходыСНДС,
		|	ВЫРАЗИТЬ(Т.Количество * УзлыИсточники.ДопРасходыБезНДС КАК ЧИСЛО(31,2)) КАК ДопРасходыБезНДС,
		|	ВЫРАЗИТЬ(Т.Количество *
		|		ВЫБОР КОГДА Т.СписыватьОтклоненияНаСебестоимостьПродаж ТОГДА 0
		|		ИНАЧЕ УзлыИсточники.ДопРасходыРегл КОНЕЦ КАК ЧИСЛО(31,2)) КАК ДопРасходыРегл,
		|	ВЫРАЗИТЬ(Т.Количество *
		|		ВЫБОР КОГДА Т.СписыватьОтклоненияНаСебестоимостьПродаж ТОГДА 0
		|		ИНАЧЕ УзлыИсточники.ДопРасходыУпр КОНЕЦ КАК ЧИСЛО(31,2)) КАК ДопРасходыУпр,
		|	ВЫРАЗИТЬ(Т.Количество *
		|		ВЫБОР КОГДА Т.СписыватьОтклоненияНаСебестоимостьПродаж ТОГДА 0
		|		ИНАЧЕ УзлыИсточники.ПостояннаяРазница КОНЕЦ КАК ЧИСЛО(31,2)) КАК ПостояннаяРазница,
		|	ВЫРАЗИТЬ(Т.Количество *
		// Сумма регл. учета и постоянная разница списаны на себестоимость продаж, поэтому временную разницу уменьшим 
		// на сумму регл. учета и увеличиваем на сумму постоянной разницы
		|		(ВЫБОР КОГДА Т.СписыватьОтклоненияНаСебестоимостьПродаж
		|			ТОГДА -(УзлыИсточники.ОтклоненияВСтоимостиРегл
		|				+ УзлыИсточники.ДопРасходыРегл
		|				+ УзлыИсточники.НДСРегл
		|				- УзлыИсточники.ПостояннаяРазница
		|				- УзлыИсточники.ВременнаяРазница)
		|		ИНАЧЕ УзлыИсточники.ВременнаяРазница КОНЕЦ) КАК ЧИСЛО(31,2)) КАК ВременнаяРазница,
		|	ВЫРАЗИТЬ(Т.Количество * УзлыИсточники.НДД КАК ЧИСЛО(31,2)) КАК НДД
		|ИЗ
		|	ВтДвиженияСебестоимостиТоваровПоПериодам КАК Т
		|
		|	ВНУТРЕННЕЕ СОЕДИНЕНИЕ ТаблицаРешенийДетально КАК УзлыИсточники
		|		ПО УзлыИсточники.НомерУзла = Т.НомерУзлаИсточник
		|ГДЕ
		|	УзлыИсточники.ЕстьСтоимость
		|	И Т.НомерУзлаИсточник <> ЕСТЬNULL(Т.НомерУзлаПриемник, -1)
		|";
КонецФункции
		
Функция ТекстСписаниеОтклоненийНаСебестоимостьПродаж() // использует ВтДвиженияСебестоимостиТоваровПоПериодам
	// Списание отклонений на себестоимость продаж.
	Возврат "
		|ВЫБРАТЬ
		|	""ТекстСписаниеОтклоненийНаСебестоимостьПродаж"" КАК ЗапросИсточник,
		|	ЛОЖЬ КАК ЭтоОстатки,
		|	Т.ЭтоТекущийПериод,
		|	ЛОЖЬ КАК ЕстьКорЧасть,
		|	Т.НомерУзлаИсточник КАК НомерУзлаИсточник,
		|	-1 КАК НомерУзлаПриемник,
		|	УзлыИсточники.Регистратор,
		|	Т.Период,
		// Измерения отклонений
		|	Т.Организация КАК Организация,
		|	Т.Номенклатура КАК Номенклатура,
		|	Т.Характеристика КАК Характеристика,
		|	Т.ВидЗапасов,
		|	Т.НаправлениеДеятельности КАК НаправлениеДеятельности,
		|	Т.Подразделение,
		|	Т.МестоХранения КАК МестоХранения,
		// Измерения себестоимости
		|	Т.АналитикаУчетаНоменклатуры,
		|	Т.РазделУчета,
		|	Т.Партия,
		|	Т.АналитикаУчетаПартий,
		|	Т.АналитикаФинансовогоУчета,
		|	Т.ВидДеятельностиНДС,
		// Кор реквизиты отклонений
		|	Т.КорОрганизация,
		|	Т.КорНоменклатура КАК КорНоменклатура,
		|	Т.КорХарактеристика КАК КорХарактеристика,
		|	Т.КорВидЗапасов,
		|	Т.КорНаправлениеДеятельности КАК КорНаправлениеДеятельности,
		|	Т.Подразделение КАК КорПодразделение,
		|	Т.КорМестоХранения КАК КорМестоХранения,
		// Кор реквизиты
		|	Т.КорАналитикаУчетаНоменклатуры,
		|	Т.КорРазделУчета,
		|	Т.КорПартия,
		|	Т.КорАналитикаУчетаПартий,
		|	Т.КорАналитикаФинансовогоУчета,
		|	Т.КорВидДеятельностиНДС,
		// Прочие поля
		|	Т.АналитикаУчетаПоПартнерам КАК АналитикаУчетаПоПартнерам,
		|	НЕОПРЕДЕЛЕНО КАК СтатьяКалькуляции,
		|	НЕОПРЕДЕЛЕНО КАК ПравилоОтнесенияНаВыпуск,
		|	ЗНАЧЕНИЕ(ПланВидовХарактеристик.СтатьиРасходов.ПустаяСсылка) КАК СтатьяРасходовСписания,
		|	НЕОПРЕДЕЛЕНО КАК АналитикаРасходов,
		|	ЗНАЧЕНИЕ(ПланВидовХарактеристик.СтатьиРасходов.ПустаяСсылка) КАК КорСтатьяРасходов,
		|	НЕОПРЕДЕЛЕНО КАК КорАналитикаРасходов,
		|	ЗНАЧЕНИЕ(ПланВидовХарактеристик.СтатьиАктивовПассивов.ПустаяСсылка) КАК СтатьяАктивовПассивов,
		|	НЕОПРЕДЕЛЕНО КАК АналитикаАктивовПассивов,
		|	Т.НастройкаСчетовУчета КАК НастройкаСчетовУчета,
		|	ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.СписаниеОтклоненийНаСебестоимостьПродаж) КАК ХозяйственнаяОперация,
		|	(ВЫБОР
		|		КОГДА Т.Организация В (&ОрганизацииСреднескользящая)
		|			ТОГДА ЗНАЧЕНИЕ(Справочник.НастройкиХозяйственныхОпераций.СписаниеОтклоненийНаСебестоимостьПродажОтклонения)
		|		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.НастройкиХозяйственныхОпераций.СписаниеОтклоненийНаСебестоимостьПродаж) КОНЕЦ) КАК НастройкаХозяйственнойОперации,
		|	Т.ИдентификаторФинЗаписи КАК ИдентификаторФинЗаписи,
		|	Т.ПериодРаспределения КАК ПериодРаспределения,
		|	УзлыИсточники.ПериодОтклонения КАК ПериодОтклоненияИсточник,
		|	ДАТАВРЕМЯ(1,1,1) КАК ПериодОтклоненияПриемник,
		|	ЛОЖЬ КАК Сторно,
		|	Т.СписыватьОтклоненияНаСебестоимостьПродаж,
		// Ресурсы
		|	Т.Количество КАК Количество,
		|	0 КАК ОтклоненияВСтоимостиСНДС,
		|	0 КАК ОтклоненияВСтоимостиБезНДС,
		|	ВЫРАЗИТЬ(Т.Количество * УзлыИсточники.ОтклоненияВСтоимостиРегл КАК ЧИСЛО(31,2)) КАК ОтклоненияВСтоимостиРегл,
		|	ВЫРАЗИТЬ(Т.Количество * УзлыИсточники.ОтклоненияВСтоимостиУпр КАК ЧИСЛО(31,2)) КАК ОтклоненияВСтоимостиУпр,
		|	ВЫРАЗИТЬ(Т.Количество * УзлыИсточники.НДСРегл КАК ЧИСЛО(31,2)) КАК НДСРегл,
		|	ВЫРАЗИТЬ(Т.Количество * УзлыИсточники.НДСУпр КАК ЧИСЛО(31,2)) КАК НДСУпр,
		|	0 КАК ДопРасходыСНДС,
		|	0 КАК ДопРасходыБезНДС,
		|	ВЫРАЗИТЬ(Т.Количество * УзлыИсточники.ДопРасходыРегл КАК ЧИСЛО(31,2)) КАК ДопРасходыРегл,
		|	ВЫРАЗИТЬ(Т.Количество * УзлыИсточники.ДопРасходыУпр КАК ЧИСЛО(31,2)) КАК ДопРасходыУпр,
		|	ВЫРАЗИТЬ(Т.Количество * УзлыИсточники.ПостояннаяРазница КАК ЧИСЛО(31,2)) КАК ПостояннаяРазница,
		// При выпуске продукции со списанием отклонений на себестоимость продаж стоимость по налоговому учету будет нулевая,
		// поэтому сумма временной разницы по отклонениям в стоимости должна быть отражена на полную сумму регл учета
		// за минусовм постоянной разницы.
		|	ВЫРАЗИТЬ(Т.Количество *
		|		(УзлыИсточники.ОтклоненияВСтоимостиРегл
		|		+ УзлыИсточники.ДопРасходыРегл
		|		+ УзлыИсточники.НДСРегл
		|		- УзлыИсточники.ПостояннаяРазница) КАК ЧИСЛО(31,2)) КАК ВременнаяРазница,
		|	0 КАК НДД
		|ИЗ
		|	ВтДвиженияСебестоимостиТоваровПоПериодам КАК Т
		|
		|	ВНУТРЕННЕЕ СОЕДИНЕНИЕ ТаблицаРешенийДетально КАК УзлыИсточники
		|		ПО УзлыИсточники.НомерУзла = Т.НомерУзлаИсточник
		|ГДЕ
		|	Т.СписыватьОтклоненияНаСебестоимостьПродаж
		|	И УзлыИсточники.ЕстьСтоимость
		|";
КонецФункции
		
Функция ТекстРаспределениеРасходовНаСебестоимостьТоваров() // использует ВтДвиженияПрочиеРасходыПоПериодам, ТаблицаРешенийПрочиеРасходыДетально
	// Распределение расходов на себестоимость товаров.
	Возврат "
		|ВЫБРАТЬ
		|	""ТекстРаспределениеРасходовНаСебестоимостьТоваров"" КАК ЗапросИсточник,
		|	ЛОЖЬ КАК ЭтоОстатки,
		|	ЛОЖЬ КАК ЭтоТекущийПериод,
		|	ИСТИНА КАК ЕстьКорЧасть,
		|	УзлыИсточники.НомерУзла КАК НомерУзлаИсточник,
		|	ЕСТЬNULL(УзлыПриемники.НомерУзла, -1) КАК НомерУзлаПриемник,
		|	(ВЫБОР
		|		КОГДА Т.Регистратор <> НЕОПРЕДЕЛЕНО ТОГДА Т.Регистратор
		|		ИНАЧЕ УзлыИсточники.Регистратор КОНЕЦ) КАК Регистратор,
		|	Т.Период,
		// Измерения отклонений
		|	Т.Организация КАК Организация,
		|	НЕОПРЕДЕЛЕНО КАК Номенклатура,
		|	ЗНАЧЕНИЕ(Справочник.ХарактеристикиНоменклатуры.ПустаяСсылка) КАК Характеристика,
		|	ЗНАЧЕНИЕ(Справочник.ВидыЗапасов.ПустаяСсылка) КАК ВидЗапасов,
		|	Т.НаправлениеДеятельности КАК НаправлениеДеятельности,
		|	Т.Подразделение,
		|	НЕОПРЕДЕЛЕНО КАК МестоХранения,
		// Измерения себестоимости
		|	ЗНАЧЕНИЕ(Справочник.КлючиАналитикиУчетаНоменклатуры.ПустаяСсылка) КАК АналитикаУчетаНоменклатуры,
		|	ЗНАЧЕНИЕ(Перечисление.РазделыУчетаСебестоимостиТоваров.ПустаяСсылка) КАК РазделУчета,
		|	Т.Партия КАК Партия,
		|	ЗНАЧЕНИЕ(Справочник.КлючиАналитикиУчетаПартий.ПустаяСсылка) КАК АналитикаУчетаПартий,
		|	НЕОПРЕДЕЛЕНО КАК АналитикаФинансовогоУчета,
		|	ЗНАЧЕНИЕ(Перечисление.ТипыНалогообложенияНДС.ПустаяСсылка) КАК ВидДеятельностиНДС,
		// Кор реквизиты отклонений
		|	Т.Организация КАК КорОрганизация,
		|	Т.КорНоменклатура КАК КорНоменклатура,
		|	Т.КорХарактеристика КАК КорХарактеристика,
		|	Т.КорВидЗапасов,
		|	Т.КорНаправлениеДеятельности КАК КорНаправлениеДеятельности,
		|	Т.КорПодразделение КАК КорПодразделение,
		|	Т.КорМестоХранения КАК КорМестоХранения,
		// Кор реквизиты
		|	Т.КорАналитикаУчетаНоменклатуры,
		|	Т.КорРазделУчета,
		|	Т.КорПартия,
		|	Т.КорАналитикаУчетаПартий,
		|	Т.КорАналитикаФинансовогоУчета,
		|	Т.КорВидДеятельностиНДС,
		// Прочие поля
		|	ЗНАЧЕНИЕ(Справочник.КлючиАналитикиУчетаПоПартнерам.ПустаяСсылка) КАК АналитикаУчетаПоПартнерам,
		|	Т.СтатьяКалькуляции КАК СтатьяКалькуляции,
		|	Т.ПравилоОтнесенияНаВыпуск КАК ПравилоОтнесенияНаВыпуск,
		|	Т.СтатьяРасходов КАК СтатьяРасходовСписания,
		|	Т.АналитикаРасходов КАК АналитикаРасходов,
		|	Т.КорСтатьяРасходов КАК КорСтатьяРасходов,
		|	Т.КорАналитикаРасходов КАК КорАналитикаРасходов,
		|	ЗНАЧЕНИЕ(ПланВидовХарактеристик.СтатьиАктивовПассивов.ПустаяСсылка) КАК СтатьяАктивовПассивов,
		|	НЕОПРЕДЕЛЕНО КАК АналитикаАктивовПассивов,
		|	НЕОПРЕДЕЛЕНО КАК НастройкаСчетовУчета,
		|	Т.ХозяйственнаяОперация КАК ХозяйственнаяОперация,
		|	Т.НастройкаХозяйственнойОперации КАК НастройкаХозяйственнойОперации,
		|	ЕСТЬNULL(ТаблицаИдентификаторов.Идентификатор, Т.ИдентификаторФинЗаписи) КАК ИдентификаторФинЗаписи,
		|	Т.ПериодРаспределения КАК ПериодРаспределения,
		|	УзлыИсточники.ПериодОтклонения КАК ПериодОтклоненияИсточник,
		|	ДАТАВРЕМЯ(1,1,1) КАК ПериодОтклоненияПриемник,
		|	ЛОЖЬ КАК Сторно,
		|	ЛОЖЬ КАК СписыватьОтклоненияНаСебестоимостьПродаж,
		// Ресурсы
		|	0 КАК Количество,
		|	ВЫРАЗИТЬ(Т.СуммаСНДС * УзлыИсточники.ОтклоненияВСтоимостиСНДС КАК ЧИСЛО(31,2)) КАК ОтклоненияВСтоимостиСНДС,
		|	ВЫРАЗИТЬ(Т.СуммаБезНДС * УзлыИсточники.ОтклоненияВСтоимостиБезНДС КАК ЧИСЛО(31,2)) КАК ОтклоненияВСтоимостиБезНДС,
		|	ВЫРАЗИТЬ(Т.СуммаРегл * УзлыИсточники.ОтклоненияВСтоимостиРегл КАК ЧИСЛО(31,2)) КАК ОтклоненияВСтоимостиРегл,
		|	ВЫРАЗИТЬ(Т.СуммаУпр * УзлыИсточники.ОтклоненияВСтоимостиУпр КАК ЧИСЛО(31,2)) КАК ОтклоненияВСтоимостиУпр,
		|	0 КАК НДСРегл,
		|	0 КАК НДСУпр,
		|	ВЫРАЗИТЬ(Т.СуммаСНДС * УзлыИсточники.ДопРасходыСНДС КАК ЧИСЛО(31,2)) КАК ДопРасходыСНДС,
		|	ВЫРАЗИТЬ(Т.СуммаБезНДС * УзлыИсточники.ДопРасходыБезНДС КАК ЧИСЛО(31,2)) КАК ДопРасходыБезНДС,
		|	ВЫРАЗИТЬ(Т.СуммаРегл * УзлыИсточники.ДопРасходыРегл КАК ЧИСЛО(31,2)) КАК ДопРасходыРегл,
		|	ВЫРАЗИТЬ(Т.СуммаУпр * УзлыИсточники.ДопРасходыУпр КАК ЧИСЛО(31,2)) КАК ДопРасходыУпр,
		|	ВЫРАЗИТЬ(Т.СуммаРегл * УзлыИсточники.ПостояннаяРазница КАК ЧИСЛО(31,2)) КАК ПостояннаяРазница,
		|	ВЫРАЗИТЬ(ВЫБОР
		|		КОГДА Т.СуммаНУ = 0 И Т.СуммаРегл <> 0
		|			ТОГДА Т.СуммаРегл * УзлыИсточники.ОтклоненияВСтоимостиРегл
		|			+ Т.СуммаРегл * УзлыИсточники.ДопРасходыРегл
		|			- Т.СуммаРегл * УзлыИсточники.ПостояннаяРазница
		|		КОГДА Т.СуммаНУ <> 0 И Т.СуммаРегл = 0
		|			ТОГДА -(Т.СуммаРегл * УзлыИсточники.ОтклоненияВСтоимостиРегл
		|			+ Т.СуммаНУ * УзлыИсточники.СтоимостьНУ
		|			- Т.СуммаРегл * УзлыИсточники.ПостояннаяРазница)
		// Если в узле стоимость НУ нулевая, то временная разница рассчитывается от суммы регл.
		|		КОГДА УзлыИсточники.СтоимостьНУ = 0 И УзлыИсточники.ПостояннаяРазница = 0
		|			ТОГДА Т.СуммаРегл * УзлыИсточники.ОтклоненияВСтоимостиРегл
		|			+ Т.СуммаРегл * УзлыИсточники.ДопРасходыРегл
		|		ИНАЧЕ Т.СуммаРегл * УзлыИсточники.ОтклоненияВСтоимостиРегл
		|			+ Т.СуммаРегл * УзлыИсточники.ДопРасходыРегл
		|			- Т.СуммаНУ * УзлыИсточники.СтоимостьНУ
		|			- Т.СуммаРегл * УзлыИсточники.ПостояннаяРазница
		|		КОНЕЦ КАК ЧИСЛО(31,2)) КАК ВременнаяРазница,
		|	ВЫРАЗИТЬ(Т.СуммаНУ * УзлыИсточники.НДД КАК ЧИСЛО(31,2)) КАК НДД
		|ИЗ
		|	ВтДвиженияПрочиеРасходыПоПериодам КАК Т
		|
		|	ВНУТРЕННЕЕ СОЕДИНЕНИЕ ТаблицаРешенийПрочиеРасходыДетально КАК УзлыИсточники
		|		ПО УзлыИсточники.Организация = Т.Организация
		|		И УзлыИсточники.Подразделение = Т.Подразделение
		|		И УзлыИсточники.НаправлениеДеятельности = Т.НаправлениеДеятельности
		|		И УзлыИсточники.СтатьяРасходов = Т.СтатьяРасходов
		|		И УзлыИсточники.АналитикаРасходов = Т.АналитикаРасходов	
		|		И УзлыИсточники.Партия = Т.Партия
		|		И УзлыИсточники.ПериодРаспределения = Т.ПериодРаспределения
		|		И УзлыИсточники.ПериодОтклонения <= Т.ПериодРаспределения
		|
		// При распределении расходов узла - приемника может не быть, если расходы распределяются на остатки товаров
		// по которым нет движений.
		|	ЛЕВОЕ СОЕДИНЕНИЕ ТаблицаРешенийДетально КАК УзлыПриемники
		|		ПО УзлыПриемники.АналитикаУчетаНоменклатуры = Т.КорАналитикаУчетаНоменклатуры
		|		И УзлыПриемники.РазделУчета = Т.КорРазделУчета
		|		И УзлыПриемники.ВидЗапасов = Т.КорВидЗапасов
		|		И УзлыПриемники.Партия = Т.КорПартия
		|		И УзлыПриемники.АналитикаУчетаПартий = Т.КорАналитикаУчетаПартий
		|		И УзлыПриемники.АналитикаФинансовогоУчета = Т.КорАналитикаФинансовогоУчета
		|		И УзлыПриемники.ВидДеятельностиНДС = Т.КорВидДеятельностиНДС
		|		И УзлыПриемники.ПериодРаспределения = Т.ПериодРаспределения
		|		И УзлыПриемники.ПериодОтклонения <= Т.ПериодРаспределения
		|		И (ВЫБОР КОГДА Т.КорОрганизация <> ЗНАЧЕНИЕ(Справочник.Организации.ПустаяСсылка)
		|			ТОГДА Т.КорОрганизация ИНАЧЕ Т.Организация КОНЕЦ) = УзлыПриемники.Организация
		|
		|	ЛЕВОЕ СОЕДИНЕНИЕ ТаблицаИдентификаторов КАК ТаблицаИдентификаторов
		|		ПО ТаблицаИдентификаторов.НомерУзлаИсточник = УзлыИсточники.НомерУзла
		|		И ТаблицаИдентификаторов.НомерУзлаПриемник = УзлыПриемники.НомерУзла
		|		И Т.ИдентификаторФинЗаписи = """"
		|ГДЕ
		|	УзлыИсточники.ЕстьСтоимость
		|	И Т.КорНоменклатура <> ЗНАЧЕНИЕ(Справочник.Номенклатура.ПустаяСсылка)
		|";
КонецФункции
		
Функция ТекстРаспределениеРасходовНаПартииПроизводства() // использует ВтДвиженияПрочиеРасходыПоПериодам, ТаблицаРешенийПрочиеРасходыДетально
	// Распределение расходов на партии производства.
	Возврат "
		|ВЫБРАТЬ
		|	""ТекстРаспределениеРасходовНаПартииПроизводства"" КАК ЗапросИсточник,
		|	ЛОЖЬ КАК ЭтоОстатки,
		|	ЛОЖЬ КАК ЭтоТекущийПериод,
		|	ИСТИНА КАК ЕстьКорЧасть,
		|	УзлыИсточники.НомерУзла КАК НомерУзлаИсточник,
		|	ЕСТЬNULL(УзлыПриемники.НомерУзла, -1) КАК НомерУзлаПриемник,
		|	УзлыИсточники.Регистратор,
		|	Т.Период,
		// Измерения отклонений
		|	Т.Организация КАК Организация,
		|	НЕОПРЕДЕЛЕНО КАК Номенклатура,
		|	ЗНАЧЕНИЕ(Справочник.ХарактеристикиНоменклатуры.ПустаяСсылка) КАК Характеристика,
		|	ЗНАЧЕНИЕ(Справочник.ВидыЗапасов.ПустаяСсылка) КАК ВидЗапасов,
		|	Т.НаправлениеДеятельности КАК НаправлениеДеятельности,
		|	Т.Подразделение,
		|	НЕОПРЕДЕЛЕНО КАК МестоХранения,
		// Измерения себестоимости
		|	ЗНАЧЕНИЕ(Справочник.КлючиАналитикиУчетаНоменклатуры.ПустаяСсылка) КАК АналитикаУчетаНоменклатуры,
		|	ЗНАЧЕНИЕ(Перечисление.РазделыУчетаСебестоимостиТоваров.ПустаяСсылка) КАК РазделУчета,
		|	НЕОПРЕДЕЛЕНО КАК Партия,
		|	ЗНАЧЕНИЕ(Справочник.КлючиАналитикиУчетаПартий.ПустаяСсылка) КАК АналитикаУчетаПартий,
		|	НЕОПРЕДЕЛЕНО КАК АналитикаФинансовогоУчета,
		|	ЗНАЧЕНИЕ(Перечисление.ТипыНалогообложенияНДС.ПустаяСсылка) КАК ВидДеятельностиНДС,
		// Кор реквизиты отклонений
		|	Т.Организация КАК КорОрганизация,
		|	НЕОПРЕДЕЛЕНО КАК КорНоменклатура,
		|	ЗНАЧЕНИЕ(Справочник.ХарактеристикиНоменклатуры.ПустаяСсылка) КАК КорХарактеристика,
		|	ЗНАЧЕНИЕ(Справочник.ВидыЗапасов.ПустаяСсылка) КАК КорВидЗапасов,
		|	Т.КорНаправлениеДеятельности КАК КорНаправлениеДеятельности,
		|	Т.КорПодразделение КАК КорПодразделение,
		|	НЕОПРЕДЕЛЕНО КАК КорМестоХранения,
		// Кор реквизиты
		|	ЗНАЧЕНИЕ(Справочник.КлючиАналитикиУчетаНоменклатуры.ПустаяСсылка) КАК КорАналитикаУчетаНоменклатуры,
		|	ЗНАЧЕНИЕ(Перечисление.РазделыУчетаСебестоимостиТоваров.ПустаяСсылка) КАК КорРазделУчета,
		|	Т.КорПартия,
		|	ЗНАЧЕНИЕ(Справочник.КлючиАналитикиУчетаПартий.ПустаяСсылка) КАК КорАналитикаУчетаПартий,
		|	НЕОПРЕДЕЛЕНО КАК КорАналитикаФинансовогоУчета,
		|	ЗНАЧЕНИЕ(Перечисление.ТипыНалогообложенияНДС.ПустаяСсылка) КАК КорВидДеятельностиНДС,
		// Прочие поля
		|	ЗНАЧЕНИЕ(Справочник.КлючиАналитикиУчетаПоПартнерам.ПустаяСсылка) КАК АналитикаУчетаПоПартнерам,
		|	Т.СтатьяКалькуляции КАК СтатьяКалькуляции,
		|	Т.ПравилоОтнесенияНаВыпуск КАК ПравилоОтнесенияНаВыпуск,
		|	Т.СтатьяРасходов КАК СтатьяРасходовСписания,
		|	Т.АналитикаРасходов КАК АналитикаРасходов,
		|	Т.КорСтатьяРасходов КАК КорСтатьяРасходов,
		|	Т.КорАналитикаРасходов КАК КорАналитикаРасходов,
		|	ЗНАЧЕНИЕ(ПланВидовХарактеристик.СтатьиАктивовПассивов.ПустаяСсылка) КАК СтатьяАктивовПассивов,
		|	НЕОПРЕДЕЛЕНО КАК АналитикаАктивовПассивов,
		|	НЕОПРЕДЕЛЕНО КАК НастройкаСчетовУчета,
		|	Т.ХозяйственнаяОперация КАК ХозяйственнаяОперация,
		|	Т.НастройкаХозяйственнойОперации КАК НастройкаХозяйственнойОперации,
		|	Т.ИдентификаторФинЗаписи КАК ИдентификаторФинЗаписи,
		|	Т.ПериодРаспределения КАК ПериодРаспределения,
		|	УзлыИсточники.ПериодОтклонения КАК ПериодОтклоненияИсточник,
		|	ДАТАВРЕМЯ(1,1,1) КАК ПериодОтклоненияПриемник,
		|	ЛОЖЬ КАК Сторно,
		|	ЛОЖЬ КАК СписыватьОтклоненияНаСебестоимостьПродаж,
		// Ресурсы
		|	0 КАК Количество,
		|	ВЫРАЗИТЬ(Т.СуммаСНДС * УзлыИсточники.ОтклоненияВСтоимостиСНДС КАК ЧИСЛО(31,2)) КАК ОтклоненияВСтоимостиСНДС,
		|	ВЫРАЗИТЬ(Т.СуммаБезНДС * УзлыИсточники.ОтклоненияВСтоимостиБезНДС КАК ЧИСЛО(31,2)) КАК ОтклоненияВСтоимостиБезНДС,
		|	ВЫРАЗИТЬ(Т.СуммаРегл * УзлыИсточники.ОтклоненияВСтоимостиРегл КАК ЧИСЛО(31,2)) КАК ОтклоненияВСтоимостиРегл,
		|	ВЫРАЗИТЬ(Т.СуммаУпр * УзлыИсточники.ОтклоненияВСтоимостиУпр КАК ЧИСЛО(31,2)) КАК ОтклоненияВСтоимостиУпр,
		|	0 КАК НДСРегл,
		|	0 КАК НДСУпр,
		|	ВЫРАЗИТЬ(Т.СуммаСНДС * УзлыИсточники.ДопРасходыСНДС КАК ЧИСЛО(31,2)) КАК ДопРасходыСНДС,
		|	ВЫРАЗИТЬ(Т.СуммаБезНДС * УзлыИсточники.ДопРасходыБезНДС КАК ЧИСЛО(31,2)) КАК ДопРасходыБезНДС,
		|	ВЫРАЗИТЬ(Т.СуммаРегл * УзлыИсточники.ДопРасходыРегл КАК ЧИСЛО(31,2)) КАК ДопРасходыРегл,
		|	ВЫРАЗИТЬ(Т.СуммаУпр * УзлыИсточники.ДопРасходыУпр КАК ЧИСЛО(31,2)) КАК ДопРасходыУпр,
		|	ВЫРАЗИТЬ(Т.СуммаРегл * УзлыИсточники.ПостояннаяРазница КАК ЧИСЛО(31,2)) КАК ПостояннаяРазница,
		|	ВЫРАЗИТЬ(ВЫБОР
		|		КОГДА Т.СуммаНУ = 0 И Т.СуммаРегл <> 0
		|			ТОГДА Т.СуммаРегл * УзлыИсточники.ОтклоненияВСтоимостиРегл
		|			+ Т.СуммаРегл * УзлыИсточники.ДопРасходыРегл
		|			- Т.СуммаРегл * УзлыИсточники.ПостояннаяРазница
		|		КОГДА Т.СуммаНУ <> 0 И Т.СуммаРегл = 0
		|			ТОГДА -(Т.СуммаРегл * УзлыИсточники.ОтклоненияВСтоимостиРегл
		|			+ Т.СуммаНУ * УзлыИсточники.СтоимостьНУ
		|			- Т.СуммаРегл * УзлыИсточники.ПостояннаяРазница)
		// Если в узле стоимость НУ нулевая, то временная разница рассчитывается от суммы регл.
		|		КОГДА УзлыИсточники.СтоимостьНУ = 0 И УзлыИсточники.ПостояннаяРазница = 0
		|			ТОГДА Т.СуммаРегл * УзлыИсточники.ОтклоненияВСтоимостиРегл
		|			+ Т.СуммаРегл * УзлыИсточники.ДопРасходыРегл
		|		ИНАЧЕ Т.СуммаРегл * УзлыИсточники.ОтклоненияВСтоимостиРегл
		|			+ Т.СуммаРегл * УзлыИсточники.ДопРасходыРегл
		|			- Т.СуммаНУ * УзлыИсточники.СтоимостьНУ
		|			- Т.СуммаРегл * УзлыИсточники.ПостояннаяРазница
		|		КОНЕЦ КАК ЧИСЛО(31,2)) КАК ВременнаяРазница,
		|	ВЫРАЗИТЬ(Т.СуммаНУ * УзлыИсточники.НДД КАК ЧИСЛО(31,2)) КАК НДД
		|ИЗ
		|	ВтДвиженияПрочиеРасходыПоПериодам КАК Т
		|
		|	ВНУТРЕННЕЕ СОЕДИНЕНИЕ ТаблицаРешенийПрочиеРасходыДетально КАК УзлыИсточники
		|		ПО УзлыИсточники.Организация = Т.Организация
		|		И УзлыИсточники.Подразделение = Т.Подразделение
		|		И УзлыИсточники.НаправлениеДеятельности = Т.НаправлениеДеятельности
		|		И УзлыИсточники.СтатьяРасходов = Т.СтатьяРасходов
		|		И УзлыИсточники.АналитикаРасходов = Т.АналитикаРасходов	
		|		И УзлыИсточники.Партия = Т.Партия
		|		И УзлыИсточники.ПериодРаспределения = Т.ПериодРаспределения
		|		И УзлыИсточники.ПериодОтклонения <= Т.ПериодРаспределения
		|
		|	ВНУТРЕННЕЕ СОЕДИНЕНИЕ ТаблицаРешенийПрочиеРасходыДетально КАК УзлыПриемники
		|		ПО УзлыПриемники.Организация = Т.КорОрганизация
		|		И УзлыПриемники.Подразделение = Т.КорПодразделение
		|		И УзлыПриемники.НаправлениеДеятельности = Т.КорНаправлениеДеятельности
		|		И УзлыПриемники.СтатьяРасходов = Т.СтатьяРасходов
		|		И УзлыПриемники.АналитикаРасходов = Т.АналитикаРасходов
		|		И УзлыПриемники.Партия = Т.КорПартия
		|		И УзлыПриемники.ПериодРаспределения = Т.ПериодРаспределения
		|		И УзлыПриемники.ПериодОтклонения <= Т.ПериодРаспределения
		|ГДЕ
		|	УзлыИсточники.ЕстьСтоимость
		|	И Т.КорНоменклатура = НЕОПРЕДЕЛЕНО
		|	И Т.КорПартия <> НЕОПРЕДЕЛЕНО
		|";
КонецФункции
		
Функция ТекстРаспределениеРасходовНаФинансовыйРезультатИПрочее()
	// Распределение расходов на финансовый результат и другие направления выбытия.
	Возврат "
		|ВЫБРАТЬ
		|	""ТекстРаспределениеРасходовНаФинансовыйРезультатИПрочее"" КАК ЗапросИсточник,
		|	ЛОЖЬ КАК ЭтоОстатки,
		|	ЛОЖЬ КАК ЭтоТекущийПериод,
		|	Т.ЕстьКорЧасть,
		|	УзлыИсточники.НомерУзла КАК НомерУзлаИсточник,
		|	ЕСТЬNULL(УзлыПриемники.НомерУзла, -1) КАК НомерУзлаПриемник,
		|	(ВЫБОР
		|		КОГДА Т.Регистратор <> НЕОПРЕДЕЛЕНО ТОГДА Т.Регистратор
		|		ИНАЧЕ УзлыИсточники.Регистратор КОНЕЦ) КАК Регистратор,
		|	Т.Период,
		// Измерения отклонений
		|	Т.Организация КАК Организация,
		|	НЕОПРЕДЕЛЕНО КАК Номенклатура,
		|	ЗНАЧЕНИЕ(Справочник.ХарактеристикиНоменклатуры.ПустаяСсылка) КАК Характеристика,
		|	ЗНАЧЕНИЕ(Справочник.ВидыЗапасов.ПустаяСсылка) КАК ВидЗапасов,
		|	Т.НаправлениеДеятельности КАК НаправлениеДеятельности,
		|	Т.Подразделение,
		|	НЕОПРЕДЕЛЕНО КАК МестоХранения,
		// Измерения себестоимости
		|	ЗНАЧЕНИЕ(Справочник.КлючиАналитикиУчетаНоменклатуры.ПустаяСсылка) КАК АналитикаУчетаНоменклатуры,
		|	ЗНАЧЕНИЕ(Перечисление.РазделыУчетаСебестоимостиТоваров.ПустаяСсылка) КАК РазделУчета,
		|	(ВЫБОР
		|		КОГДА Т.ХозяйственнаяОперация = ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.РаспределениеРасходовНаСебестоимостьПродаж)
		|			ТОГДА Т.КорПартия
		|		ИНАЧЕ НЕОПРЕДЕЛЕНО КОНЕЦ) КАК Партия,
		|	(ВЫБОР
		|		КОГДА Т.ХозяйственнаяОперация = ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.РаспределениеРасходовНаСебестоимостьПродаж)
		|			ТОГДА Т.КорАналитикаУчетаПартий
		|		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.КлючиАналитикиУчетаПартий.ПустаяСсылка) КОНЕЦ) КАК АналитикаУчетаПартий,
		|	НЕОПРЕДЕЛЕНО КАК АналитикаФинансовогоУчета,
		|	ЗНАЧЕНИЕ(Перечисление.ТипыНалогообложенияНДС.ПустаяСсылка) КАК ВидДеятельностиНДС,
		// Кор реквизиты отклонений
		|	Т.Организация КАК КорОрганизация,
		|	НЕОПРЕДЕЛЕНО КАК КорНоменклатура,
		|	ЗНАЧЕНИЕ(Справочник.ХарактеристикиНоменклатуры.ПустаяСсылка) КАК КорХарактеристика,
		|	ЗНАЧЕНИЕ(Справочник.ВидыЗапасов.ПустаяСсылка) КАК КорВидЗапасов,
		|	Т.КорНаправлениеДеятельности КАК КорНаправлениеДеятельности,
		|	Т.КорПодразделение КАК КорПодразделение,
		|	НЕОПРЕДЕЛЕНО КАК КорМестоХранения,
		// Кор реквизиты
		|	ЗНАЧЕНИЕ(Справочник.КлючиАналитикиУчетаНоменклатуры.ПустаяСсылка) КАК КорАналитикаУчетаНоменклатуры,
		|	ЗНАЧЕНИЕ(Перечисление.РазделыУчетаСебестоимостиТоваров.ПустаяСсылка) КАК КорРазделУчета,
		|	НЕОПРЕДЕЛЕНО КАК КорПартия,
		|	ЗНАЧЕНИЕ(Справочник.КлючиАналитикиУчетаПартий.ПустаяСсылка) КАК КорАналитикаУчетаПартий,
		|	НЕОПРЕДЕЛЕНО КАК КорАналитикаФинансовогоУчета,
		|	ЗНАЧЕНИЕ(Перечисление.ТипыНалогообложенияНДС.ПустаяСсылка) КАК КорВидДеятельностиНДС,
		// Прочие поля
		|	Т.АналитикаУчетаПоПартнерам КАК АналитикаУчетаПоПартнерам,
		|	НЕОПРЕДЕЛЕНО КАК СтатьяКалькуляции,
		|	НЕОПРЕДЕЛЕНО КАК ПравилоОтнесенияНаВыпуск,
		|	Т.СтатьяРасходов КАК СтатьяРасходовСписания,
		|	Т.АналитикаРасходов КАК АналитикаРасходов,
		|	Т.КорСтатьяРасходов КАК КорСтатьяРасходов,
		|	Т.КорАналитикаРасходов КАК КорАналитикаРасходов,
		|	ЗНАЧЕНИЕ(ПланВидовХарактеристик.СтатьиАктивовПассивов.ПустаяСсылка) КАК СтатьяАктивовПассивов,
		|	НЕОПРЕДЕЛЕНО КАК АналитикаАктивовПассивов,
		|	НЕОПРЕДЕЛЕНО КАК НастройкаСчетовУчета,
		|	Т.ХозяйственнаяОперация КАК ХозяйственнаяОперация,
		|	Т.НастройкаХозяйственнойОперации КАК НастройкаХозяйственнойОперации,
		|	ЕСТЬNULL(ТаблицаИдентификаторов.Идентификатор, Т.ИдентификаторФинЗаписи) КАК ИдентификаторФинЗаписи,
		|	Т.ПериодРаспределения КАК ПериодРаспределения,
		|	УзлыИсточники.ПериодОтклонения КАК ПериодОтклоненияИсточник,
		|	ДАТАВРЕМЯ(1,1,1) КАК ПериодОтклоненияПриемник,
		|	ЛОЖЬ КАК Сторно,
		|	ЛОЖЬ КАК СписыватьОтклоненияНаСебестоимостьПродаж,
		// Ресурсы
		|	0 КАК Количество,
		|	ВЫРАЗИТЬ(Т.СуммаСНДС * УзлыИсточники.ОтклоненияВСтоимостиСНДС КАК ЧИСЛО(31,2)) КАК ОтклоненияВСтоимостиСНДС,
		|	ВЫРАЗИТЬ(Т.СуммаБезНДС * УзлыИсточники.ОтклоненияВСтоимостиБезНДС КАК ЧИСЛО(31,2)) КАК ОтклоненияВСтоимостиБезНДС,
		|	ВЫРАЗИТЬ(Т.СуммаРегл * УзлыИсточники.ОтклоненияВСтоимостиРегл КАК ЧИСЛО(31,2)) КАК ОтклоненияВСтоимостиРегл,
		|	ВЫРАЗИТЬ(Т.СуммаУпр * УзлыИсточники.ОтклоненияВСтоимостиУпр КАК ЧИСЛО(31,2)) КАК ОтклоненияВСтоимостиУпр,
		|	0 КАК НДСРегл,
		|	0 КАК НДСУпр,
		|	ВЫРАЗИТЬ(Т.СуммаСНДС * УзлыИсточники.ДопРасходыСНДС КАК ЧИСЛО(31,2)) КАК ДопРасходыСНДС,
		|	ВЫРАЗИТЬ(Т.СуммаБезНДС * УзлыИсточники.ДопРасходыБезНДС КАК ЧИСЛО(31,2)) КАК ДопРасходыБезНДС,
		|	ВЫРАЗИТЬ(Т.СуммаРегл * УзлыИсточники.ДопРасходыРегл КАК ЧИСЛО(31,2)) КАК ДопРасходыРегл,
		|	ВЫРАЗИТЬ(Т.СуммаУпр * УзлыИсточники.ДопРасходыУпр КАК ЧИСЛО(31,2)) КАК ДопРасходыУпр,
		|	ВЫРАЗИТЬ(Т.СуммаРегл * УзлыИсточники.ПостояннаяРазница КАК ЧИСЛО(31,2)) КАК ПостояннаяРазница,
		|	ВЫРАЗИТЬ(ВЫБОР
		|		КОГДА Т.СуммаНУ = 0 И Т.СуммаРегл <> 0
		|			ТОГДА Т.СуммаРегл * УзлыИсточники.ОтклоненияВСтоимостиРегл
		|			+ Т.СуммаРегл * УзлыИсточники.ДопРасходыРегл
		|			- Т.СуммаРегл * УзлыИсточники.ПостояннаяРазница
		|		КОГДА Т.СуммаНУ <> 0 И Т.СуммаРегл = 0
		|			ТОГДА -(Т.СуммаРегл * УзлыИсточники.ОтклоненияВСтоимостиРегл
		|			+ Т.СуммаНУ * УзлыИсточники.СтоимостьНУ
		|			- Т.СуммаРегл * УзлыИсточники.ПостояннаяРазница)
		// Если в узле стоимость НУ нулевая, то временная разница рассчитывается от суммы регл.
		|		КОГДА УзлыИсточники.СтоимостьНУ = 0 И УзлыИсточники.ПостояннаяРазница = 0
		|			ТОГДА Т.СуммаРегл * УзлыИсточники.ОтклоненияВСтоимостиРегл
		|			+ Т.СуммаРегл * УзлыИсточники.ДопРасходыРегл
		|		ИНАЧЕ Т.СуммаРегл * УзлыИсточники.ОтклоненияВСтоимостиРегл
		|			+ Т.СуммаРегл * УзлыИсточники.ДопРасходыРегл
		|			- Т.СуммаНУ * УзлыИсточники.СтоимостьНУ
		|			- Т.СуммаРегл * УзлыИсточники.ПостояннаяРазница
		|		КОНЕЦ КАК ЧИСЛО(31,2)) КАК ВременнаяРазница,
		|	ВЫРАЗИТЬ(Т.СуммаНУ * УзлыИсточники.НДД КАК ЧИСЛО(31,2)) КАК НДД
		|ИЗ
		|	ВтДвиженияПрочиеРасходыПоПериодам КАК Т
		|
		|	ВНУТРЕННЕЕ СОЕДИНЕНИЕ ТаблицаРешенийПрочиеРасходыДетально КАК УзлыИсточники
		|		ПО УзлыИсточники.Организация = Т.Организация
		|		И УзлыИсточники.Подразделение = Т.Подразделение
		|		И УзлыИсточники.НаправлениеДеятельности = Т.НаправлениеДеятельности
		|		И УзлыИсточники.СтатьяРасходов = Т.СтатьяРасходов
		|		И УзлыИсточники.АналитикаРасходов = Т.АналитикаРасходов	
		|		И УзлыИсточники.Партия = НЕОПРЕДЕЛЕНО
		|		И УзлыИсточники.ПериодРаспределения = Т.ПериодРаспределения
		|		И УзлыИсточники.ПериодОтклонения <= Т.ПериодРаспределения
		|
		|	ЛЕВОЕ СОЕДИНЕНИЕ ТаблицаРешенийПрочиеРасходыДетально КАК УзлыПриемники
		|		ПО УзлыПриемники.Организация = Т.КорОрганизация
		|		И УзлыПриемники.Подразделение = Т.КорПодразделение
		|		И УзлыПриемники.НаправлениеДеятельности = Т.КорНаправлениеДеятельности
		|		И УзлыПриемники.СтатьяРасходов = Т.КорСтатьяРасходов
		|		И УзлыПриемники.АналитикаРасходов = Т.КорАналитикаРасходов
		|		И УзлыПриемники.Партия = НЕОПРЕДЕЛЕНО
		|		И УзлыПриемники.ПериодРаспределения = Т.ПериодРаспределения
		|		И УзлыПриемники.ПериодОтклонения <= Т.ПериодРаспределения
		|
		|	ЛЕВОЕ СОЕДИНЕНИЕ ТаблицаИдентификаторов КАК ТаблицаИдентификаторов
		|		ПО ТаблицаИдентификаторов.НомерУзлаИсточник = УзлыИсточники.НомерУзла
		|		И ТаблицаИдентификаторов.НомерУзлаПриемник = УзлыПриемники.НомерУзла
		|ГДЕ
		|	УзлыИсточники.ЕстьСтоимость
		|	И Т.КорНоменклатура = ЗНАЧЕНИЕ(Справочник.Номенклатура.ПустаяСсылка)
		|	И Т.КорПартия = НЕОПРЕДЕЛЕНО
		|";
КонецФункции

Функция ТекстВтНеактуальныеДвиженияПрочиеРасходыПредварительная() // ВтНеактуальныеДвиженияПрочиеРасходыПредварительная
	Возврат "
		|ВЫБРАТЬ
		|	ИСТИНА КАК ЕстьДвижения,
		|	Т.ЕстьКорЧасть,
		|	НЕОПРЕДЕЛЕНО КАК Регистратор,
		|	Т.Период,
		// Измерения отклонений
		|	Т.Организация КАК Организация,
		|	Т.НаправлениеДеятельности КАК НаправлениеДеятельности,
		|	Т.Подразделение,
		|	Т.СтатьяРасходов КАК СтатьяРасходов,
		|	Т.АналитикаРасходов КАК АналитикаРасходов,
		// Кор реквизиты
		|	Т.Организация КАК КорОрганизация,
		|	Т.КорНаправлениеДеятельности КАК КорНаправлениеДеятельности,
		|	Т.КорПодразделение КАК КорПодразделение,
		|	Т.КорСтатьяРасходов КАК КорСтатьяРасходов,
		|	Т.КорАналитикаРасходов КАК КорАналитикаРасходов,
		// Прочие поля
		|	Т.ХозяйственнаяОперация КАК ХозяйственнаяОперация,
		|	Т.НастройкаХозяйственнойОперации КАК НастройкаХозяйственнойОперации,
		|	Т.ИдентификаторФинЗаписи КАК ИдентификаторФинЗаписи,
		// Ресурсы
		|	0 КАК ДопРасходыСНДС,
		|	0 КАК ДопРасходыБезНДС,
		|	0 КАК ДопРасходыРегл,
		|	0 КАК ДопРасходыУпр,
		|	0 КАК ПостояннаяРазница,
		|	0 КАК ВременнаяРазница,
		|	0 КАК НДД
		|
		|ПОМЕСТИТЬ ВтНеактуальныеДвиженияПрочиеРасходыПредварительная
		|ИЗ
		|	ВтДвиженияПрочиеРасходыПоПериодам КАК Т
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	ЛОЖЬ КАК ЕстьДвижения,
		|	ВЫБОР
		|		КОГДА КорДвижения.Регистратор ЕСТЬ NULL
		|			ТОГДА ЛОЖЬ 
		|		ИНАЧЕ ИСТИНА КОНЕЦ КАК ЕстьКорЧасть,
		|	Регистраторы.Ссылка КАК Регистратор,
		|	Т.Период,
		// Измерения отклонений
		|	Т.Организация КАК Организация,
		|	Т.НаправлениеДеятельности КАК НаправлениеДеятельности,
		|	Т.Подразделение,
		|	Т.СтатьяРасходов КАК СтатьяРасходов,
		|	Т.АналитикаРасходов КАК АналитикаРасходов,
		// Кор реквизиты
		|	Т.Организация КАК КорОрганизация,
		|	Т.КорНаправлениеДеятельности КАК КорНаправлениеДеятельности,
		|	Т.КорПодразделение КАК КорПодразделение,
		|	Т.КорСтатьяРасходов КАК КорСтатьяРасходов,
		|	Т.КорАналитикаРасходов КАК КорАналитикаРасходов,
		// Прочие поля
		|	Т.ХозяйственнаяОперация КАК ХозяйственнаяОперация,
		|	Т.НастройкаХозяйственнойОперации КАК НастройкаХозяйственнойОперации,
		|	Т.ИдентификаторФинЗаписи КАК ИдентификаторФинЗаписи,
		// Ресурсы
		|	-Т.Сумма КАК ДопРасходыСНДС,
		|	-Т.СуммаБезНДС КАК ДопРасходыБезНДС,
		|	-Т.СуммаРегл КАК ДопРасходыРегл,
		|	-Т.СуммаУпр КАК ДопРасходыУпр,
		|	-Т.ПостояннаяРазница КАК ПостояннаяРазница,
		|	-Т.ВременнаяРазница КАК ВременнаяРазница,
		|	-Т.СуммаНДД КАК НДД
		|ИЗ
		|	РегистрНакопления.ПрочиеРасходы КАК Т
		|	ЛЕВОЕ СОЕДИНЕНИЕ ВТРегистраторыРасчетаСебестоимости КАК Регистраторы
		|		ПО Т.Организация = Регистраторы.Организация
		|	ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ПрочиеРасходы КАК КорДвижения
		|		ПО КорДвижения.Регистратор = Т.Регистратор
		|		И КорДвижения.Период = Т.Период
		|		И КорДвижения.НастройкаХозяйственнойОперации = Т.НастройкаХозяйственнойОперации
		|		И КорДвижения.ИдентификаторФинЗаписи = Т.ИдентификаторФинЗаписи
		|		И КорДвижения.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход)
		|		И КорДвижения.Сумма = Т.Сумма
		|		И КорДвижения.СуммаБезНДС = Т.СуммаБезНДС
		|		И КорДвижения.СуммаРегл = Т.СуммаРегл
		|		И КорДвижения.СуммаУпр = Т.СуммаУпр
		|		И КорДвижения.ПостояннаяРазница = Т.ПостояннаяРазница
		|		И КорДвижения.ВременнаяРазница = Т.ВременнаяРазница
		|ГДЕ
		|	Т.Период МЕЖДУ &НачалоПериода И &КонецПериода
		|	И Т.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход)
		|	И Т.Активность
		|	И Т.Регистратор ССЫЛКА Документ.РегистраторРасчетаСебестоимости
		|	И НЕ Т.ХозяйственнаяОперация В (
		|		ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.СписаниеОтклоненийКРаспределению))
		|	И Т.Организация В (
		|		ВЫБРАТЬ
		|			Отбор.Организация
		|		ИЗ
		|			ВтДвиженияПрочиеРасходыПоПериодам КАК Отбор)
		|";
КонецФункции

Функция ТекстВтНеактуальныеДвиженияПрочиеРасходы() // ВтНеактуальныеДвиженияПрочиеРасходы
	Возврат "
		|ВЫБРАТЬ
		|	МАКСИМУМ(Т.ЕстьДвижения) КАК ЕстьДвижения,
		|	МАКСИМУМ(Т.ЕстьКорЧасть) КАК ЕстьКорЧасть,
		|	МАКСИМУМ(Т.Регистратор) КАК Регистратор,
		|	Т.Период,
		// Измерения
		|	Т.Организация КАК Организация,
		|	Т.НаправлениеДеятельности КАК НаправлениеДеятельности,
		|	Т.Подразделение,
		|	Т.СтатьяРасходов КАК СтатьяРасходов,
		|	Т.АналитикаРасходов КАК АналитикаРасходов,
		// Кор реквизиты
		|	Т.Организация КАК КорОрганизация,
		|	Т.КорНаправлениеДеятельности КАК КорНаправлениеДеятельности,
		|	Т.КорПодразделение КАК КорПодразделение,
		|	Т.КорСтатьяРасходов КАК КорСтатьяРасходов,
		|	Т.КорАналитикаРасходов КАК КорАналитикаРасходов,
		// Прочие поля
		|	Т.ХозяйственнаяОперация КАК ХозяйственнаяОперация,
		|	Т.НастройкаХозяйственнойОперации КАК НастройкаХозяйственнойОперации,
		|	Т.ИдентификаторФинЗаписи КАК ИдентификаторФинЗаписи,
		// Ресурсы
		|	СУММА(Т.ДопРасходыСНДС) КАК ДопРасходыСНДС,
		|	СУММА(Т.ДопРасходыБезНДС) КАК ДопРасходыБезНДС,
		|	СУММА(Т.ДопРасходыРегл) КАК ДопРасходыРегл,
		|	СУММА(Т.ДопРасходыУпр) КАК ДопРасходыУпр,
		|	СУММА(Т.ПостояннаяРазница) КАК ПостояннаяРазница,
		|	СУММА(Т.ВременнаяРазница) КАК ВременнаяРазница,
		|	СУММА(Т.НДД) КАК НДД
		|
		|ПОМЕСТИТЬ ВтНеактуальныеДвиженияПрочиеРасходы
		|ИЗ
		|	ВтНеактуальныеДвиженияПрочиеРасходыПредварительная КАК Т
		|СГРУППИРОВАТЬ ПО
		|	Т.Период,
		// Измерения
		|	Т.Организация,
		|	Т.НаправлениеДеятельности,
		|	Т.Подразделение,
		|	Т.СтатьяРасходов,
		|	Т.АналитикаРасходов,
		// Кор реквизиты
		|	Т.КорНаправлениеДеятельности,
		|	Т.КорПодразделение,
		|	Т.КорСтатьяРасходов,
		|	Т.КорАналитикаРасходов,
		// Прочие поля
		|	Т.ХозяйственнаяОперация,
		|	Т.НастройкаХозяйственнойОперации,
		|	Т.ИдентификаторФинЗаписи
		|ИМЕЮЩИЕ
		|	МАКСИМУМ(Т.ЕстьДвижения) = ЛОЖЬ
		|	И (СУММА(Т.ДопРасходыСНДС) <> 0
		|		ИЛИ СУММА(Т.ДопРасходыБезНДС) <> 0
		|		ИЛИ СУММА(Т.ДопРасходыРегл) <> 0
		|		ИЛИ СУММА(Т.ДопРасходыУпр) <> 0
		|		ИЛИ СУММА(Т.ПостояннаяРазница) <> 0
		|		ИЛИ СУММА(Т.ВременнаяРазница) <> 0
		|		ИЛИ СУММА(Т.НДД) <> 0)
		|";
КонецФункции

Функция ТекстСписаниеОтклоненийКРаспределению()
	Возврат "
		|ВЫБРАТЬ
		|	""ТекстСписаниеОтклоненийКРаспределению"" КАК ЗапросИсточник,
		|	ЛОЖЬ КАК ЭтоОстатки,
		|	ИСТИНА КАК ЭтоТекущийПериод,
		|	ИСТИНА КАК ЕстьКорЧасть,
		|	УзлыИсточники.НомерУзла КАК НомерУзлаИсточник,
		|	УзлыИсточники.НомерУзла КАК НомерУзлаПриемник,
		|	УзлыИсточники.Регистратор,
		|	&НачалоПериода КАК Период,
		// Измерения отклонений
		|	Т.Организация КАК Организация,
		|	Т.Номенклатура КАК Номенклатура,
		|	Т.АналитикаУчетаНоменклатуры.Характеристика КАК Характеристика,
		|	Т.ВидЗапасов КАК ВидЗапасов,
		|	ЕСТЬNULL(Т.АналитикаУчетаНоменклатуры.Назначение.НаправлениеДеятельности, НЕОПРЕДЕЛЕНО) КАК НаправлениеДеятельности,
		|	ЗНАЧЕНИЕ(Справочник.СтруктураПредприятия.ПустаяСсылка) КАК Подразделение,
		|	Т.АналитикаУчетаНоменклатуры.МестоХранения КАК МестоХранения,
		// Измерения себестоимости
		|	Т.АналитикаУчетаНоменклатуры КАК АналитикаУчетаНоменклатуры,
		|	Т.РазделУчета КАК РазделУчета,
		|	Т.Партия КАК Партия,
		|	Т.АналитикаУчетаПартий КАК АналитикаУчетаПартий,
		|	Т.АналитикаФинансовогоУчета КАК АналитикаФинансовогоУчета,
		|	Т.ВидДеятельностиНДС КАК ВидДеятельностиНДС,
		// Кор реквизиты отклонений
		|	Т.Организация КАК КорОрганизация,
		|	Т.Номенклатура КАК КорНоменклатура,
		|	ЕСТЬNULL(Т.АналитикаУчетаНоменклатуры.Характеристика, НЕОПРЕДЕЛЕНО) КАК КорХарактеристика,
		|	Т.ВидЗапасов КАК КорВидЗапасов,
		|	ЗНАЧЕНИЕ(Справочник.НаправленияДеятельности.ПустаяСсылка) КАК КорНаправлениеДеятельности,
		|	ЗНАЧЕНИЕ(Справочник.СтруктураПредприятия.ПустаяСсылка) КАК КорПодразделение,
		|	ЕСТЬNULL(Т.АналитикаУчетаНоменклатуры.МестоХранения, НЕОПРЕДЕЛЕНО) КАК КорМестоХранения,
		// Кор реквизиты
		|	Т.АналитикаУчетаНоменклатуры КАК КорАналитикаУчетаНоменклатуры,
		|	Т.РазделУчета КАК КорРазделУчета,
		|	Т.Партия КАК КорПартия,
		|	Т.АналитикаУчетаПартий КАК КорАналитикаУчетаПартий,
		|	Т.АналитикаФинансовогоУчета КАК КорАналитикаФинансовогоУчета,
		|	Т.ВидДеятельностиНДС КАК КорВидДеятельностиНДС,
		// Прочие поля
		|	ЗНАЧЕНИЕ(Справочник.КлючиАналитикиУчетаПоПартнерам.ПустаяСсылка) КАК АналитикаУчетаПоПартнерам,
		|	НЕОПРЕДЕЛЕНО КАК СтатьяКалькуляции,
		|	НЕОПРЕДЕЛЕНО КАК ПравилоОтнесенияНаВыпуск,
		|	ЗНАЧЕНИЕ(ПланВидовХарактеристик.СтатьиРасходов.ПустаяСсылка) КАК СтатьяРасходовСписания,
		|	НЕОПРЕДЕЛЕНО КАК АналитикаРасходов,
		|	ЗНАЧЕНИЕ(ПланВидовХарактеристик.СтатьиРасходов.ПустаяСсылка) КАК КорСтатьяРасходов,
		|	НЕОПРЕДЕЛЕНО КАК КорАналитикаРасходов,
		|	ЗНАЧЕНИЕ(ПланВидовХарактеристик.СтатьиАктивовПассивов.ПустаяСсылка) КАК СтатьяАктивовПассивов,
		|	НЕОПРЕДЕЛЕНО КАК АналитикаАктивовПассивов,
		|	НЕОПРЕДЕЛЕНО КАК НастройкаСчетовУчета,
		|	ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.СписаниеОтклоненийКРаспределению) КАК ХозяйственнаяОперация,
		|	ЗНАЧЕНИЕ(Справочник.НастройкиХозяйственныхОпераций.ПустаяСсылка) КАК НастройкаХозяйственнойОперации,
		|	&ИдентификаторНеиспользуемойФинЗаписи КАК ИдентификаторФинЗаписи,
		|	ДАТАВРЕМЯ(1,1,1) КАК ПериодРаспределения,
		|	УзлыИсточники.ПериодОтклонения КАК ПериодОтклоненияИсточник,
		|	УзлыИсточники.ПериодОтклонения КАК ПериодОтклоненияПриемник,
		|	ЛОЖЬ КАК Сторно,
		|	ЛОЖЬ КАК СписыватьОтклоненияНаСебестоимостьПродаж,
		// Ресурсы
		|	0 КАК Количество,
		|	0 КАК ОтклоненияВСтоимостиСНДС,
		|	0 КАК ОтклоненияВСтоимостиБезНДС,
		|	0 КАК ОтклоненияВСтоимостиРегл,
		|	0 КАК ОтклоненияВСтоимостиУпр,
		|	0 КАК НДСРегл,
		|	0 КАК НДСУпр,
		|	Т.ДопРасходыСНДС КАК ДопРасходыСНДС,
		|	Т.ДопРасходыБезНДС КАК ДопРасходыБезНДС,
		|	Т.ДопРасходыРегл КАК ДопРасходыРегл,
		|	Т.ДопРасходыУпр КАК ДопРасходыУпр,
		|	Т.ПостояннаяРазница КАК ПостояннаяРазница,
		|	Т.ВременнаяРазница КАК ВременнаяРазница,
		|	Т.НДД КАК НДД
		|ИЗ
		|	ВтОтклоненияКРаспределению КАК Т
		|
		|	ВНУТРЕННЕЕ СОЕДИНЕНИЕ ТаблицаРешенийДетально КАК УзлыИсточники
		|		ПО УзлыИсточники.АналитикаУчетаНоменклатуры = Т.АналитикаУчетаНоменклатуры
		|		И УзлыИсточники.РазделУчета = Т.РазделУчета
		|		И УзлыИсточники.ВидЗапасов = Т.ВидЗапасов
		|		И УзлыИсточники.Организация = Т.Организация
		|		И УзлыИсточники.Партия = Т.Партия	
		|		И УзлыИсточники.АналитикаУчетаПартий = Т.АналитикаУчетаПартий
		|		И УзлыИсточники.АналитикаФинансовогоУчета = Т.АналитикаФинансовогоУчета
		|		И УзлыИсточники.ВидДеятельностиНДС = Т.ВидДеятельностиНДС
		|		И УзлыИсточники.ПериодРаспределения = Т.ПериодОтклонения
		|		И УзлыИсточники.ПериодОтклонения = Т.ПериодОтклонения
		|";
КонецФункции
	
Функция ТекстСписаниеОтклоненийПрочихРасходовКРаспределению()
	Возврат "
		|ВЫБРАТЬ
		|	""ТекстСписаниеОтклоненийПрочихРасходовКРаспределению"" КАК ЗапросИсточник,
		|	ЛОЖЬ КАК ЭтоОстатки,
		|	ИСТИНА КАК ЭтоТекущийПериод,
		|	ЛОЖЬ КАК ЕстьКорЧасть,
		|	УзлыИсточники.НомерУзла КАК НомерУзлаИсточник,
		|	УзлыИсточники.НомерУзла КАК НомерУзлаПриемник,
		|	УзлыИсточники.Регистратор,
		|	&НачалоПериода КАК Период,
		// Измерения отклонений
		|	Т.Организация КАК Организация,
		|	НЕОПРЕДЕЛЕНО КАК Номенклатура,
		|	ЗНАЧЕНИЕ(Справочник.ХарактеристикиНоменклатуры.ПустаяСсылка) КАК Характеристика,
		|	ЗНАЧЕНИЕ(Справочник.ВидыЗапасов.ПустаяСсылка) КАК ВидЗапасов,
		|	Т.НаправлениеДеятельности КАК НаправлениеДеятельности,
		|	Т.Подразделение,
		|	НЕОПРЕДЕЛЕНО КАК МестоХранения,
		// Измерения себестоимости
		|	ЗНАЧЕНИЕ(Справочник.КлючиАналитикиУчетаНоменклатуры.ПустаяСсылка) КАК АналитикаУчетаНоменклатуры,
		|	ЗНАЧЕНИЕ(Перечисление.РазделыУчетаСебестоимостиТоваров.ПустаяСсылка) КАК РазделУчета,
		|	НЕОПРЕДЕЛЕНО КАК Партия,
		|	ЗНАЧЕНИЕ(Справочник.КлючиАналитикиУчетаПартий.ПустаяСсылка) КАК АналитикаУчетаПартий,
		|	НЕОПРЕДЕЛЕНО КАК АналитикаФинансовогоУчета,
		|	ЗНАЧЕНИЕ(Перечисление.ТипыНалогообложенияНДС.ПустаяСсылка) КАК ВидДеятельностиНДС,
		// Кор реквизиты отклонений
		|	Т.Организация КАК КорОрганизация,
		|	НЕОПРЕДЕЛЕНО КАК КорНоменклатура,
		|	ЗНАЧЕНИЕ(Справочник.ХарактеристикиНоменклатуры.ПустаяСсылка) КАК КорХарактеристика,
		|	ЗНАЧЕНИЕ(Справочник.ВидыЗапасов.ПустаяСсылка) КАК КорВидЗапасов,
		|	Т.НаправлениеДеятельности КАК КорНаправлениеДеятельности,
		|	Т.Подразделение КАК КорПодразделение,
		|	НЕОПРЕДЕЛЕНО КАК КорМестоХранения,
		// Кор реквизиты
		|	ЗНАЧЕНИЕ(Справочник.КлючиАналитикиУчетаНоменклатуры.ПустаяСсылка) КАК КорАналитикаУчетаНоменклатуры,
		|	ЗНАЧЕНИЕ(Перечисление.РазделыУчетаСебестоимостиТоваров.ПустаяСсылка) КАК КорРазделУчета,
		|	НЕОПРЕДЕЛЕНО КАК КорПартия,
		|	ЗНАЧЕНИЕ(Справочник.КлючиАналитикиУчетаПартий.ПустаяСсылка) КАК КорАналитикаУчетаПартий,
		|	НЕОПРЕДЕЛЕНО КАК КорАналитикаФинансовогоУчета,
		|	ЗНАЧЕНИЕ(Перечисление.ТипыНалогообложенияНДС.ПустаяСсылка) КАК КорВидДеятельностиНДС,
		// Прочие поля
		|	ЗНАЧЕНИЕ(Справочник.КлючиАналитикиУчетаПоПартнерам.ПустаяСсылка) КАК АналитикаУчетаПоПартнерам,
		|	НЕОПРЕДЕЛЕНО КАК СтатьяКалькуляции,
		|	НЕОПРЕДЕЛЕНО КАК ПравилоОтнесенияНаВыпуск,
		|	Т.СтатьяРасходов КАК СтатьяРасходовСписания,
		|	Т.АналитикаРасходов КАК АналитикаРасходов,
		|	Т.СтатьяРасходов КАК КорСтатьяРасходов,
		|	Т.АналитикаРасходов КАК КорАналитикаРасходов,
		|	ЗНАЧЕНИЕ(ПланВидовХарактеристик.СтатьиАктивовПассивов.ПустаяСсылка) КАК СтатьяАктивовПассивов,
		|	НЕОПРЕДЕЛЕНО КАК АналитикаАктивовПассивов,
		|	НЕОПРЕДЕЛЕНО КАК НастройкаСчетовУчета,
		|	ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.СписаниеОтклоненийКРаспределению) КАК ХозяйственнаяОперация,
		|	ЗНАЧЕНИЕ(Справочник.НастройкиХозяйственныхОпераций.ПустаяСсылка) КАК НастройкаХозяйственнойОперации,
		|	&ИдентификаторНеиспользуемойФинЗаписи КАК ИдентификаторФинЗаписи,
		|	ДАТАВРЕМЯ(1,1,1) КАК ПериодРаспределения,
		|	УзлыИсточники.ПериодОтклонения КАК ПериодОтклоненияИсточник,
		|	УзлыИсточники.ПериодОтклонения КАК ПериодОтклоненияПриемник,
		|	ЛОЖЬ КАК Сторно,
		|	ЛОЖЬ КАК СписыватьОтклоненияНаСебестоимостьПродаж,
		// Ресурсы
		|	0 КАК Количество,
		|	0 КАК ОтклоненияВСтоимостиСНДС,
		|	0 КАК ОтклоненияВСтоимостиБезНДС,
		|	0 КАК ОтклоненияВСтоимостиРегл,
		|	0 КАК ОтклоненияВСтоимостиУпр,
		|	0 КАК НДСРегл,
		|	0 КАК НДСУпр,
		|	Т.Сумма КАК ДопРасходыСНДС,
		|	Т.СуммаБезНДС КАК ДопРасходыБезНДС,
		|	Т.СуммаРегл КАК ДопРасходыРегл,
		|	Т.СуммаУпр КАК ДопРасходыУпр,
		|	Т.ПостояннаяРазница КАК ПостояннаяРазница,
		|	Т.ВременнаяРазница КАК ВременнаяРазница,
		|	Т.НДД КАК НДД
		|ИЗ
		|	ВтОтклоненияПрочиеРасходыКРаспределению КАК Т
		|
		|	ВНУТРЕННЕЕ СОЕДИНЕНИЕ ТаблицаРешенийПрочиеРасходыДетально КАК УзлыИсточники
		|		ПО УзлыИсточники.Организация = Т.Организация
		|		И УзлыИсточники.Подразделение = Т.Подразделение
		|		И УзлыИсточники.НаправлениеДеятельности = Т.НаправлениеДеятельности
		|		И УзлыИсточники.СтатьяРасходов = Т.СтатьяРасходов
		|		И УзлыИсточники.АналитикаРасходов = Т.АналитикаРасходов
		|		И УзлыИсточники.Партия = НЕОПРЕДЕЛЕНО
		|		И УзлыИсточники.ПериодРаспределения = Т.ПериодОтклонения
		|		И УзлыИсточники.ПериодОтклонения = Т.ПериодОтклонения
		|";
КонецФункции

Функция ТекстКорректировкаОтклоненийНеСоответствующихПрочимРасходам()
	Возврат "
		|ВЫБРАТЬ
		|	""ТекстКорректировкаОтклоненийНеСоответствующихПрочимРасходам"" КАК ЗапросИсточник,
		|	ЛОЖЬ КАК ЭтоОстатки,
		|	ИСТИНА КАК ЭтоТекущийПериод,
		|	ЛОЖЬ КАК ЕстьКорЧасть,
		|	-1 КАК НомерУзлаИсточник,
		|	(ВЫБОР КОГДА Т.ЕстьКорЧасть ТОГДА 0 ИНАЧЕ -1 КОНЕЦ) КАК НомерУзлаПриемник,
		|	Т.Регистратор,
		|	&НачалоПериода КАК Период,
		// Измерения отклонений
		|	Т.Организация КАК Организация,
		|	НЕОПРЕДЕЛЕНО КАК Номенклатура,
		|	ЗНАЧЕНИЕ(Справочник.ХарактеристикиНоменклатуры.ПустаяСсылка) КАК Характеристика,
		|	ЗНАЧЕНИЕ(Справочник.ВидыЗапасов.ПустаяСсылка) КАК ВидЗапасов,
		|	Т.НаправлениеДеятельности КАК НаправлениеДеятельности,
		|	Т.Подразделение,
		|	НЕОПРЕДЕЛЕНО КАК МестоХранения,
		// Измерения себестоимости
		|	ЗНАЧЕНИЕ(Справочник.КлючиАналитикиУчетаНоменклатуры.ПустаяСсылка) КАК АналитикаУчетаНоменклатуры,
		|	ЗНАЧЕНИЕ(Перечисление.РазделыУчетаСебестоимостиТоваров.ПустаяСсылка) КАК РазделУчета,
		|	НЕОПРЕДЕЛЕНО КАК Партия,
		|	ЗНАЧЕНИЕ(Справочник.КлючиАналитикиУчетаПартий.ПустаяСсылка) КАК АналитикаУчетаПартий,
		|	НЕОПРЕДЕЛЕНО КАК АналитикаФинансовогоУчета,
		|	ЗНАЧЕНИЕ(Перечисление.ТипыНалогообложенияНДС.ПустаяСсылка) КАК ВидДеятельностиНДС,
		// Кор реквизиты отклонений
		|	Т.Организация КАК КорОрганизация,
		|	НЕОПРЕДЕЛЕНО КАК КорНоменклатура,
		|	ЗНАЧЕНИЕ(Справочник.ХарактеристикиНоменклатуры.ПустаяСсылка) КАК КорХарактеристика,
		|	ЗНАЧЕНИЕ(Справочник.ВидыЗапасов.ПустаяСсылка) КАК КорВидЗапасов,
		|	Т.КорНаправлениеДеятельности КАК КорНаправлениеДеятельности,
		|	Т.КорПодразделение КАК КорПодразделение,
		|	НЕОПРЕДЕЛЕНО КАК КорМестоХранения,
		// Кор реквизиты
		|	ЗНАЧЕНИЕ(Справочник.КлючиАналитикиУчетаНоменклатуры.ПустаяСсылка) КАК КорАналитикаУчетаНоменклатуры,
		|	ЗНАЧЕНИЕ(Перечисление.РазделыУчетаСебестоимостиТоваров.ПустаяСсылка) КАК КорРазделУчета,
		|	НЕОПРЕДЕЛЕНО КАК КорПартия,
		|	ЗНАЧЕНИЕ(Справочник.КлючиАналитикиУчетаПартий.ПустаяСсылка) КАК КорАналитикаУчетаПартий,
		|	НЕОПРЕДЕЛЕНО КАК КорАналитикаФинансовогоУчета,
		|	ЗНАЧЕНИЕ(Перечисление.ТипыНалогообложенияНДС.ПустаяСсылка) КАК КорВидДеятельностиНДС,
		// Прочие поля
		|	ЗНАЧЕНИЕ(Справочник.КлючиАналитикиУчетаПоПартнерам.ПустаяСсылка) КАК АналитикаУчетаПоПартнерам,
		|	НЕОПРЕДЕЛЕНО КАК СтатьяКалькуляции,
		|	НЕОПРЕДЕЛЕНО КАК ПравилоОтнесенияНаВыпуск,
		|	Т.СтатьяРасходов КАК СтатьяРасходовСписания,
		|	Т.АналитикаРасходов КАК АналитикаРасходов,
		|	Т.КорСтатьяРасходов КАК КорСтатьяРасходов,
		|	Т.КорАналитикаРасходов КАК КорАналитикаРасходов,
		|	ЗНАЧЕНИЕ(ПланВидовХарактеристик.СтатьиАктивовПассивов.ПустаяСсылка) КАК СтатьяАктивовПассивов,
		|	НЕОПРЕДЕЛЕНО КАК АналитикаАктивовПассивов,
		|	НЕОПРЕДЕЛЕНО КАК НастройкаСчетовУчета,
		|	Т.ХозяйственнаяОперация,
		|	Т.НастройкаХозяйственнойОперации,
		|	Т.ИдентификаторФинЗаписи,
		|	ДАТАВРЕМЯ(1,1,1) КАК ПериодРаспределения,
		|	ДАТАВРЕМЯ(1,1,1) КАК ПериодОтклоненияИсточник,
		|	ДАТАВРЕМЯ(1,1,1) КАК ПериодОтклоненияПриемник,
		|	ЛОЖЬ КАК Сторно,
		|	ЛОЖЬ КАК СписыватьОтклоненияНаСебестоимостьПродаж,
		// Ресурсы
		|	0 КАК Количество,
		|	0 КАК ОтклоненияВСтоимостиСНДС,
		|	0 КАК ОтклоненияВСтоимостиБезНДС,
		|	0 КАК ОтклоненияВСтоимостиРегл,
		|	0 КАК ОтклоненияВСтоимостиУпр,
		|	0 КАК НДСРегл,
		|	0 КАК НДСУпр,
		|	Т.ДопРасходыСНДС КАК ДопРасходыСНДС,
		|	Т.ДопРасходыБезНДС КАК ДопРасходыБезНДС,
		|	Т.ДопРасходыРегл КАК ДопРасходыРегл,
		|	Т.ДопРасходыУпр КАК ДопРасходыУпр,
		|	Т.ПостояннаяРазница КАК ПостояннаяРазница,
		|	Т.ВременнаяРазница КАК ВременнаяРазница,
		|	Т.НДД КАК НДД
		|ИЗ
		|	ВтНеактуальныеДвиженияПрочиеРасходы КАК Т
		|";
КонецФункции

