	ВариантыРаспределенияДляСписанияОшибокОкругления = Новый Массив();
	ВариантыРаспределенияДляСписанияОшибокОкругления.Добавить(Перечисления.ВариантыРаспределенияРасходов.НаСебестоимостьТоваров);
