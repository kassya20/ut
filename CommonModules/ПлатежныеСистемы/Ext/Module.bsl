///////////////////////////////////////////////////////////////////////////////////////////////////////
// Подсистема "ИнтернетПоддержкаПользователей.ПлатежныеСистемы.БазоваяФункциональностьПлатежныхСистем".
// ОбщийМодуль.ПлатежныеСистемы.
// 
// Серверные процедуры взаимодействия с платежными системами:
//  - проверка доступности использования функциональности подсистемы;
//  - создание запроса на возврат оплаты по оплаченным заказам;
//  - установка отложенного получения статуса;
//  - проверка статуса операций;
//  - получение данных операции;
//  - удаление операции.
//
///////////////////////////////////////////////////////////////////////////////////////////////////////

#Область ПрограммныйИнтерфейс

#Область ПроверкаДоступности

// Определяет доступность использования функциональности подключения к платежным системам на основании прав доступа
// пользователя.
//
// Возвращаемое значение:
//  Булево - если Истина, настройка подключения к платежным системам доступна.
//
Функция НастройкаПодключенияДоступна() Экспорт
	
	Возврат ПравоДоступа("Изменение", Метаданные.Справочники.НастройкиПодключенияКПлатежнымСистемам)
		И ПравоДоступа("Добавление", Метаданные.Справочники.НастройкиПодключенияКПлатежнымСистемам);
	
КонецФункции

// Определяет доступность использования функциональности выполнения операций на основании прав доступа пользователя.
//
// Возвращаемое значение:
//  Булево - если Истина, выполнение операций с платежными системами доступно.
//
Функция ОперацииДоступны() Экспорт
	
	Возврат ПравоДоступа("Изменение", Метаданные.РегистрыСведений.ИдентификаторыПлатежныхСистем)
		И ПравоДоступа("Чтение", Метаданные.Справочники.НастройкиПодключенияКПлатежнымСистемам);
	
КонецФункции

#КонецОбласти

#Область ПрикладныеОперации

// Создает запрос на частичный/полный возврат по ранее созданному заказу на оплату.
//
// Параметры:
//  ДокументВозврата - ОпределяемыйТип.ДокументОперацииПлатежнойСистемы - документ, который отражает возврат в
//    информационной базе.
//  ДокументОплаты - ОпределяемыйТип.ДокументОперацииПлатежнойСистемы - документ, который отражает оплату в
//    информационной базе.
//  НастройкаПодключения - СправочникСсылка.НастройкиПодключенияКПлатежнымСистемам - настройка подключения к сервису.
//  ДополнительныеПараметры - Структура, Неопределено - дополнительные настройки формирования запроса на возврат оплаты.
//
// Возвращаемое значение:
//  Структура - результат создания запроса на возврат оплаты в платежной системе:
//    * КодОшибки - Строка - строковый код возникшей ошибки.
//        Возможные значения:
//          "" - возврат оплаты успешно создан.
//          "НеверныйФорматЗапроса" - передан некорректный запрос или настройка подключения.
//          "НеверныйЛогинИлиПароль" - неверный логин или пароль или параметры подключения к платежной системе.
//          "ОтсутствуетДоступКСервису" - недостаточно прав для выполнения запроса.
//          "ПревышеноКоличествоПопыток" - превышено количество попыток обращения к сервису с некорректным логином и
//            паролем.
//          "СервисВременноНеДоступен" - сервер временно не имеет возможности обрабатывать запросы.
//          "ОшибкаСервиса" - внутренняя ошибка сервиса.
//          "ОшибкаПодключения" - ошибка работы сети Интернет.
//          "НеизвестнаяОшибка" - при получении информации возникла неизвестная (не обрабатываемая) ошибка.
//          "ИнтеграцияНеИспользуется" - настройка подключения неактивна.
//          "ОперацияВыполнена" - ошибка создания нового заказа на возврат оплаты.
//    * СообщениеОбОшибке - Строка, ФорматированнаяСтрока - сообщение об ошибке для пользователя.
//    * ИнформацияОбОшибке - Строка, ФорматированнаяСтрока - сообщение об ошибке для администратора.
//    * СтатусОперации - Строка - текущее состояние операции оплаты.
//        Возможные значения:
//          см. НастройкиПлатежныхСистемКлиентСервер.СтатусОперацииВыполняется - подтверждение операции не получено.
//          см. НастройкиПлатежныхСистемКлиентСервер.СтатусОперацииВыполнена - платежная система подтвердила операцию.
//          см. НастройкиПлатежныхСистемКлиентСервер.СтатусОперацииОтменена - операция не может быть выполнена.
//          см. НастройкиПлатежныхСистемКлиентСервер.СтатусОперацииОшибка - не удалось получить статус операции из-за
//            ошибки.
//    * ПараметрыОперации - Структура - дополнительные данные по оплате:
//        ** ИдентификаторОперации - Строка - идентификатор операции в платежной системе.
//        ** ИдентификаторОплаты - Строка - идентификатор оплаты в платежной системе.
//        ** ТипОперации - Строка - тип операции в платежной системе.
//             Возможные значения:
//               см. ПлатежныеСистемыКлиентСервер.ТипОперацииОплата - идентификатор операции оплаты.
//               см. ПлатежныеСистемыКлиентСервер.ТипОперацииВозврат - идентификатор операции возврата.
//        ** ДатаОперации - Дата - фактическая дата оплаты в UTC.
//        ** СуммаОперации - Число - фактическая сумма операции.
//
Функция ВозвратОплаты(
		ДокументВозврата,
		ДокументОплаты,
		НастройкаПодключения,
		ДополнительныеПараметры = Неопределено) Экспорт
	
	// Проверка входных параметров
	ИмяФункции = "ПлатежныеСистемы.ВозвратОплаты";
	
	ОбщегоНазначенияКлиентСервер.ПроверитьПараметр(
		ИмяФункции,
		"ДокументВозврата",
		ДокументВозврата,
		Метаданные.ОпределяемыеТипы.ДокументОперацииПлатежнойСистемы.Тип);
	ОбщегоНазначенияКлиентСервер.ПроверитьПараметр(
		ИмяФункции,
		"ДокументОплаты",
		ДокументОплаты,
		Метаданные.ОпределяемыеТипы.ДокументОперацииПлатежнойСистемы.Тип);
	ОбщегоНазначенияКлиентСервер.ПроверитьПараметр(
		ИмяФункции,
		"НастройкаПодключения",
		НастройкаПодключения,
		Тип("СправочникСсылка.НастройкиПодключенияКПлатежнымСистемам"));
	Если ДополнительныеПараметры <> Неопределено Тогда
		ОбщегоНазначенияКлиентСервер.ПроверитьПараметр(
			ИмяФункции,
			"ДополнительныеПараметры",
			ДополнительныеПараметры,
			Новый ОписаниеТипов("Структура"));
	КонецЕсли;
	
	Возврат ПлатежныеСистемыСлужебный.ВозвратОплаты(
		ДокументВозврата,
		ДокументОплаты,
		НастройкаПодключения,
		ДополнительныеПараметры);
	
КонецФункции

// Выполняет получение статуса операции в платежной системе.
// Если терминальный статус операции был загружен ранее, то метод вернет информацию из базы данных, в противном случае
// будет выполнен запрос к сервису платежной системы.
//
// Параметры:
//  ДокументОперации - ОпределяемыйТип.ДокументОперацииПлатежнойСистемы - документ, который отражает операцию в
//    информационной базе.
//  ВремяОжидания - Число - время ожидания терминального статуса в секундах.
//    Если параметр заполнен, то получение статуса будет выполняться в цикле с небольшими задержками между запросами.
//    Значение по умолчанию: 0 (один запрос).
//
// Возвращаемое значение:
//  Структура - результат получения статуса операции:
//    * КодОшибки - Строка - строковый код возникшей ошибки.
//        Возможные значения:
//          "" - операция получения статуса операции выполнено успешно.
//          "НеверныйФорматЗапроса" - передан некорректный запрос или настройка подключения.
//          "НеверныйЛогинИлиПароль" - неверный логин или пароль или параметры подключения к платежной системе.
//          "ОтсутствуетДоступКСервису" - недостаточно прав для выполнения запроса.
//          "ОбъектНеНайден" - искомый объект в сервисе не найден.
//          "ПревышеноКоличествоПопыток" - превышено количество попыток обращения к сервису с некорректным логином и
//            паролем.
//          "СервисВременноНеДоступен" - сервер временно не имеет возможности обрабатывать запросы.
//          "ОшибкаСервиса" - внутренняя ошибка сервиса.
//          "ОшибкаПодключения" - ошибка работы сети Интернет.
//          "НеизвестнаяОшибка" - при получении информации возникла неизвестная (не обрабатываемая) ошибка.
//          "ИнтеграцияНеИспользуется" - настройка подключения неактивна.
//    * СообщениеОбОшибке - Строка, ФорматированнаяСтрока - сообщение об ошибке для пользователя.
//    * ИнформацияОбОшибке - Строка, ФорматированнаяСтрока - сообщение об ошибке для администратора.
//    * СтатусОперации - Строка - текущее состояние операции оплаты.
//        Возможные значения:
//          см. НастройкиПлатежныхСистемКлиентСервер.СтатусОперацииВыполняется - подтверждение операции не получено.
//          см. НастройкиПлатежныхСистемКлиентСервер.СтатусОперацииВыполнена - платежная система подтвердила операцию.
//          см. НастройкиПлатежныхСистемКлиентСервер.СтатусОперацииОтменена - операция не может быть выполнена.
//          см. НастройкиПлатежныхСистемКлиентСервер.СтатусОперацииОшибка - не удалось получить статус операции из-за
//            ошибки.
//    * ПараметрыОперации - Структура - дополнительные данные по операции:
//        ** ИдентификаторОперации - Строка - идентификатор операции в платежной системе.
//        ** ИдентификаторОплаты - Строка - идентификатор оплаты в платежной системе.
//        ** ТипОперации - Строка - тип операции в платежной системе.
//             Возможные значения:
//               см. ПлатежныеСистемыКлиентСервер.ТипОперацииОплата - идентификатор операции оплаты.
//               см. ПлатежныеСистемыКлиентСервер.ТипОперацииВозврат - идентификатор операции возврата.
//        ** ДатаОперации - Дата - фактическая дата оплаты в UTC.
//        ** СуммаОперации - Число - фактическая сумма операции.
//
Функция СтатусОперации(ДокументОперации, ВремяОжидания = 0) Экспорт
	
	// Проверка входных параметров
	ИмяФункции = "ПлатежныеСистемы.СтатусОперации";
	
	ОбщегоНазначенияКлиентСервер.ПроверитьПараметр(
		ИмяФункции,
		"ДокументОперации",
		ДокументОперации,
		Метаданные.ОпределяемыеТипы.ДокументОперацииПлатежнойСистемы.Тип);
	ОбщегоНазначенияКлиентСервер.ПроверитьПараметр(
		ИмяФункции,
		"ВремяОжидания",
		ВремяОжидания,
		Тип("Число"));
	
	Возврат ПлатежныеСистемыСлужебный.СтатусОперации(ДокументОперации, ВремяОжидания);
	
КонецФункции

#КонецОбласти

#Область ДополнительныеОперации

// Возвращает данные операции по документу.
//
// Параметры:
//  ДокументОперации - ОпределяемыйТип.ДокументОперацииПлатежнойСистемы - документ, который отражает операцию в
//    информационной базе.
//
// Возвращаемое значение:
//  Неопределено - данные операции по документу не найдены.
//  Структура:
//    * ИдентификаторОперации - Строка - идентификатор операции в платежной системе.
//    * ИдентификаторОплаты - Строка - идентификатор оплаты в платежной системе.
//    * ТипОперации - Строка - тип выполненной операции в платежной системе.
//        Возможные значения:
//          см. ПлатежныеСистемыКлиентСервер.ТипОперацииОплата - операция оплаты.
//          см. ПлатежныеСистемыКлиентСервер.ТипОперацииВозврат - операция возврата оплаты.
//    * СтатусОперации - Строка - текущее состояние операции оплаты.
//        Возможные значения:
//          см. НастройкиПлатежныхСистемКлиентСервер.СтатусОперацииВыполняется - операция в процессе выполнения.
//          см. НастройкиПлатежныхСистемКлиентСервер.СтатусОперацииВыполнена - платежная система выполнила операцию.
//          см. НастройкиПлатежныхСистемКлиентСервер.СтатусОперацииОтменена - операция отменена в платежной системе.
//          см. НастройкиПлатежныхСистемКлиентСервер.СтатусОперацииОшибка - выполнение операции завершилось ошибкой в
//            платежной системе.
//    * ДатаОперации - Дата - фактическая дата операции в UTC.
//    * СуммаОперации - Число - фактическая суммы операции по документу.
//    * НастройкаПодключения - СправочникСсылка.НастройкиПодключенияКПлатежнымСистемам - настройка подключения к
//        сервису.
//    * СпособОплаты - Строка - способ оплаты. Доступные значения определяются методами
//        общего модуля ПлатежныеСистемыКлиентСервер.
//
Функция ДанныеОперации(ДокументОперации) Экспорт
	
	// Проверка входных параметров
	ОбщегоНазначенияКлиентСервер.ПроверитьПараметр(
		"ПлатежныеСистемы.",
		"ДокументОперации",
		ДокументОперации,
		Метаданные.ОпределяемыеТипы.ДокументОперацииПлатежнойСистемы.Тип);
	
	ДанныеРегистра = РегистрыСведений.ИдентификаторыПлатежныхСистем.ДанныеОперации(ДокументОперации);
	Если ДанныеРегистра = Неопределено Тогда
		Результат = Неопределено;
	Иначе
		
		Результат = Новый Структура();
		Результат.Вставить("ИдентификаторОперации", ДанныеРегистра.ИдентификаторОперации);
		Результат.Вставить("ИдентификаторОплаты"  , ДанныеРегистра.ИдентификаторОплаты);
		Результат.Вставить("СтатусОперации"       , ДанныеРегистра.СтатусОперации);
		Результат.Вставить("ДатаОперации"         , ДанныеРегистра.ДатаОперации);
		Результат.Вставить("СуммаОперации"        , ДанныеРегистра.СуммаОперации);
		Результат.Вставить("НастройкаПодключения" , ДанныеРегистра.НастройкаПодключения);
		Результат.Вставить("СпособОплаты"         , ДанныеРегистра.СпособОплаты);
		
		Если ДанныеРегистра.Оплата Тогда
			Результат.Вставить("ТипОперации" , ПлатежныеСистемыКлиентСервер.ТипОперацииОплата());
		Иначе
			Результат.Вставить("ТипОперации" , ПлатежныеСистемыКлиентСервер.ТипОперацииВозврат());
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Удаляет данные операции из информационной базы.
// Процедуру необходимо использовать только в том случае, если при вызове методов оплаты в качестве документа оплаты
// была передана ссылка нового и после выполнения оплаты объект не был записан. Во всех остальных случаях вызов метода
// не рекомендуется.
//
// Параметры:
//  ДокументОперации - ОпределяемыйТип.ДокументОперацииПлатежнойСистемы - документ, который отражает операцию в
//    информационной базе.
//
Процедура УдалитьОперацию(ДокументОперации) Экспорт
	
	// Проверка входных параметров
	ОбщегоНазначенияКлиентСервер.ПроверитьПараметр(
		"ПлатежныеСистемы.УдалитьОперацию",
		"ДокументОперации",
		ДокументОперации,
		Метаданные.ОпределяемыеТипы.ДокументОперацииПлатежнойСистемы.Тип);
	
	ПлатежныеСистемыСлужебный.ПроверитьПраваНаВыполнениеОперации();
	
	РегистрыСведений.ИдентификаторыПлатежныхСистем.УдалитьОперацию(ДокументОперации);
	
КонецПроцедуры

#КонецОбласти

#КонецОбласти