#Область ШаблоныКодовМаркировки

// Возвращает доступные шаблоны по виду продукции.
// 
// Параметры:
//  см. ШаблоныКодовПоВидуПродукции
// Возвращаемое значение:
//  СправочникСсылка.ШаблоныКодовМаркировкиСУЗ - Шаблон кода маркировки.
Функция ШаблонКодаМаркировкиПоВидуПродукции(ВидПродукцииТоварнаяГруппа, РежимВключенияУпаковокИНаборов = 0) Экспорт
	
	Результат = Неопределено;
	
	СписокШаблонов = ШаблоныКодовПоВидуПродукции(ВидПродукцииТоварнаяГруппа, РежимВключенияУпаковокИНаборов);
	
	Для Каждого ЭлементСписка Из СписокШаблонов Цикл
		Если ЭлементСписка.Пометка Тогда
			Результат = ЭлементСписка.Значение;
			Прервать;
		ИначеЕсли Результат = Неопределено Тогда
			Результат = ЭлементСписка.Значение;
		КонецЕсли;
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

// Возвращает все шаблоны групповых упаковок
//
// Возвращаемое значение:
//   Массив Из СправочникСсылка.ШаблоныКодовМаркировкиСУЗ - шаблоны групповых упаковок
//
Функция ШаблоныГрупповыхУпаковок() Экспорт
	
	Результат = Новый Массив;
	
	ШаблоныКодовМаркировки = ИнтеграцияИСМПКлиентСерверПовтИсп.ШаблоныКодовМаркировки();
	Для Каждого КлючИЗначение Из ШаблоныКодовМаркировки Цикл
		ШаблоныПоТипуКодов = КлючИЗначение.Значение[ПредопределенноеЗначение("Перечисление.ТипыКодовМаркировкиИСМП.ГрупповаяУпаковка")];
		Если ШаблоныПоТипуКодов <> Неопределено Тогда
			Для Каждого Шаблон Из ШаблоныПоТипуКодов Цикл
				Результат.Добавить(Шаблон.Ключ);
			КонецЦикла;
		КонецЕсли;
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

