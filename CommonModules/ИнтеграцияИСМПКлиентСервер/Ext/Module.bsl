// Возвращает доступные шаблоны по виду продукции.
// 
// Параметры:
// 	ВидПродукцииТоварнаяГруппа     - СправочникСсылка.ВидыПродукцииИС,
//                                   Массив из СправочникСсылка.ВидыПродукцииИС - Виды продукции,
// 	                                 СправочникСсылка.ТоварныеГруппыГИСМТ - Товарная группа.
// 	РежимВключенияУпаковокИНаборов - Число - Режим включения шаблонов для групповых упаковок и наборов:
// 	 0 - включать только потребительские упаковки
// 	 1 - включать групповые упаковки и потребительские упаковки
// 	 2 - включать наборы и потребительские упаковки
// 	 3 - включать групповые упаковки, наборы и потребительские упаковки
// 	 4 - включать только групповые упаковки
// 	 5 - включать только наборы.
// Возвращаемое значение:
// 	СписокЗначений из СправочникСсылка.ШаблоныКодовМаркировкиСУЗ - Список значений.
Функция ШаблоныКодовПоВидуПродукции(ВидПродукцииТоварнаяГруппа, РежимВключенияУпаковокИНаборов = 1) Экспорт
	
	Результат = Новый СписокЗначений;
	
	Если Не ЗначениеЗаполнено(ВидПродукцииТоварнаяГруппа) Тогда
		Возврат Результат;
	КонецЕсли;
	
	Если ТипЗнч(ВидПродукцииТоварнаяГруппа) = Тип("СправочникСсылка.ТоварныеГруппыГИСМТ") Тогда
		ТоварнаяГруппа = ВидПродукцииТоварнаяГруппа;
	Иначе
		ТоварнаяГруппа = КонструкторИСМПОбщегоНазначенияКлиентСервер.ТоварнаяГруппаПоВидуПродукции(ВидПродукцииТоварнаяГруппа);
		Если ТоварнаяГруппа = Неопределено Тогда
			Возврат Результат;
		КонецЕсли;
	КонецЕсли;
	
	ВключатьИндивидуальныеУпаковки =
			РежимВключенияУпаковокИНаборов = 0
		Или РежимВключенияУпаковокИНаборов = 1
		Или РежимВключенияУпаковокИНаборов = 2
		Или РежимВключенияУпаковокИНаборов = 3;
		
	ВключатьГрупповыеУпаковки =
			РежимВключенияУпаковокИНаборов = 1
		Или РежимВключенияУпаковокИНаборов = 3
		Или РежимВключенияУпаковокИНаборов = 4;
	
	ВключатьНаборы =
			РежимВключенияУпаковокИНаборов = 2
		Или РежимВключенияУпаковокИНаборов = 3
		Или РежимВключенияУпаковокИНаборов = 5;
	
	ШаблоныКодовМаркировки = ИнтеграцияИСМПКлиентСерверПовтИсп.ШаблоныКодовМаркировки();
	ШаблоныПоТоварнойГруппе = ШаблоныКодовМаркировки[ТоварнаяГруппа];
	Если ШаблоныПоТоварнойГруппе <> Неопределено Тогда
		Если ВключатьИндивидуальныеУпаковки Тогда
			ШаблоныПоТипуКодов = ШаблоныПоТоварнойГруппе[ПредопределенноеЗначение("Перечисление.ТипыКодовМаркировкиИСМП.ЕдиницаТовара")];
			Если ШаблоныПоТипуКодов <> Неопределено Тогда
				Для Каждого Шаблон Из ШаблоныПоТипуКодов Цикл
					Результат.Добавить(Шаблон.Ключ,, Шаблон.Значение);
				КонецЦикла;
			КонецЕсли;
			ШаблоныПоТипуКодов = ШаблоныПоТоварнойГруппе[ПредопределенноеЗначение("Перечисление.ТипыКодовМаркировкиИСМП.Комплект")];
			Если ШаблоныПоТипуКодов <> Неопределено Тогда
				Для Каждого Шаблон Из ШаблоныПоТипуКодов Цикл
					Результат.Добавить(Шаблон.Ключ,, Шаблон.Значение);
				КонецЦикла;
			КонецЕсли;
		КонецЕсли;
		Если ВключатьГрупповыеУпаковки Тогда
			ШаблоныПоТипуКодов = ШаблоныПоТоварнойГруппе[ПредопределенноеЗначение("Перечисление.ТипыКодовМаркировкиИСМП.ГрупповаяУпаковка")];
			Если ШаблоныПоТипуКодов <> Неопределено Тогда
				Для Каждого Шаблон Из ШаблоныПоТипуКодов Цикл
					Результат.Добавить(Шаблон.Ключ);
				КонецЦикла;
			КонецЕсли;
		КонецЕсли;
		Если ВключатьНаборы Тогда
			ШаблоныПоТипуКодов = ШаблоныПоТоварнойГруппе[ПредопределенноеЗначение("Перечисление.ТипыКодовМаркировкиИСМП.Набор")];
			Если ШаблоныПоТипуКодов <> Неопределено Тогда
				Для Каждого Шаблон Из ШаблоныПоТипуКодов Цикл
					Результат.Добавить(Шаблон.Ключ);
				КонецЦикла;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Шаблоны кодов по номенклатуре.
// 
// Параметры:
//  Номенклатура - ОпределяемыйТип.Номенклатура - Номенклатура
//  РежимВключенияУпаковокИНаборов - Число - Режим включения упаковок и наборов
// 
// Возвращаемое значение:
//  См. ШаблоныКодовПоВидуПродукции
Функция ШаблоныКодовПоНоменклатуре(Номенклатура, РежимВключенияУпаковокИНаборов = 1) Экспорт
	
	ВидПродукции = ИнтеграцияИСМПВызовСервера.ОписаниеНоменклатуры(Номенклатура)[Номенклатура].КлючВидовПродукции;
	
	Возврат ШаблоныКодовПоВидуПродукции(ВидПродукции, РежимВключенияУпаковокИНаборов);
	
КонецФункции

#КонецОбласти

// Представление GTINОстатки по виду продукции.
// 
// Параметры:
//  Представление - Строка - Представление
//  ТоварнаяГруппа  - СправочникСсылка.ТоварныеГруппыГИСМТ - Товарная группа
// 
// Возвращаемое значение:
//  Строка - Представление GTINОстатки по виду продукции
Функция ПредставлениеGTINОстаткиПоВидуПродукции(Представление, ТоварнаяГруппа) Экспорт
	
	Если ЗначениеЗаполнено(Представление) Тогда
		Возврат Представление;
	КонецЕсли;
	
	МассивПредставления = Новый Массив();
	МассивПредставления.Добавить(НСтр("ru = 'Остатки'"));
	Если ЗначениеЗаполнено(ТоварнаяГруппа) Тогда
		МассивПредставления.Добавить(Строка(ТоварнаяГруппа));
	КонецЕсли;
	
	ПредставлениеНовое = СтрСоединить(МассивПредставления, ". ");
	
	Возврат ПредставлениеНовое;
	
КонецФункции

Функция ПредставлениеПустойНоменклатурыПродукцииПоддерживающейИндивидуализациюКИЗ(ВходныеДанные, Префикс = Неопределено) Экспорт

	Поля = Новый Массив();
	Поля.Добавить("СпособВводаВОборот");
	Поля.Добавить("ВидКИЗ");
	Поля.Добавить("РазмерКИЗ");

	ИсходныеДанные = Новый Структура(СтрСоединить(Поля, ","));
	ЗаполнитьЗначенияСвойств(ИсходныеДанные, ВходныеДанные);

	ИтоговоеЗначение = Новый Массив();
	Если ЗначениеЗаполнено(Префикс) Тогда
		ИтоговоеЗначение.Добавить(Префикс);
	Иначе
		ИтоговоеЗначение.Добавить(НСтр("ru = 'КИЗ без индивидуализации'"));
	КонецЕсли;

	Для Каждого ИмяПоля Из Поля Цикл
		Если ЗначениеЗаполнено(ИсходныеДанные[ИмяПоля]) Тогда
			ИтоговоеЗначение.Добавить(ИсходныеДанные[ИмяПоля]);
		КонецЕсли;
	КонецЦикла;

	Возврат СтрСоединить(ИтоговоеЗначение, ", ");

КонецФункции

