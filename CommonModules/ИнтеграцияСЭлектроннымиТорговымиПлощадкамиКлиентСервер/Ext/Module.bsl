// Функция - Преобразует коллекцию ключевых слов в строку
//
// Параметры:
//  КоллекцияКлючевыхСлов - СписокЗначений из Строка - список ключевых слов для преобразования
//  				   - Массив из Строка - массив ключевых слов для преобразования
//
// Возвращаемое значение:
//  Строка - строка ключевых слов, разделенных символом разделителя
//
Функция СтрокаКлючевыхСлов(КоллекцияКлючевыхСлов) Экспорт
	МассивКлючевыхСлов = Новый Массив;
	Если ТипЗнч(КоллекцияКлючевыхСлов) = Тип("СписокЗначений") Тогда
		МассивКлючевыхСлов = КоллекцияКлючевыхСлов.ВыгрузитьЗначения();
	ИначеЕсли ТипЗнч(КоллекцияКлючевыхСлов) = Тип("Массив") Тогда
		МассивКлючевыхСлов = КоллекцияКлючевыхСлов;
	КонецЕсли;
	Возврат СтрСоединить(МассивКлючевыхСлов, РазделительКлючевыхСлов());
КонецФункции

// Функция - Преобразует строку ключевых слов в список значений
//
// Параметры:
//  СтрокаКлючевыхСлов - Строка - строка с ключевыми словами, разделенными символом разделителя
//
// Возвращаемое значение:
//  СписокЗначений из Строка - список ключевых слов с типом значения Строка (длина до 50 символов)
//
Функция СписокКлючевыхСлов(СтрокаКлючевыхСлов = "") Экспорт
	Результат = Новый СписокЗначений();
	Результат.ТипЗначения = Новый ОписаниеТипов("Строка",, Новый КвалификаторыСтроки(50));
	Если Не ПустаяСтрока(СтрокаКлючевыхСлов) Тогда
		МассивКлючевыхСлов = СтрРазделить(СтрокаКлючевыхСлов,РазделительКлючевыхСлов(),Ложь);
		Результат.ЗагрузитьЗначения(МассивКлючевыхСлов);
	КонецЕсли;
	Возврат Результат;
КонецФункции

// Функция - Преобразует строку ключевых слов в массив
//
// Параметры:
//  СтрокаКлючевыхСлов - Строка - строка с ключевыми словами, разделенными символом разделителя
//
// Возвращаемое значение:
//  Массив из Строка - массив ключевых слов с типом значения Строка
//
Функция МассивКлючевыхСлов(СтрокаКлючевыхСлов) Экспорт
	Возврат СтрРазделить(СтрокаКлючевыхСлов,РазделительКлючевыхСлов(),Ложь);
КонецФункции

// Функция - Возвращает структуру с данными результата подбора ключевых слов
//
// Возвращаемое значение:
//	Структура - Результат подбора ключевых слов. Содержит свойства:
//		* ПодборВыполнялся - булево - указывает, что подбор выполнялся
//		* КлючевыеСлова - СписокЗначений из Строка - список подобранных ключевых слов
//		* ТекстОшибки - Строка - текст ошибки, которая возникла при подборе ключевых слов
//
Функция РезультатПодбораКлючевыхСлов() Экспорт
	
	Результат = Новый Структура;
	
	Результат.Вставить("ПодборВыполнялся",Ложь);
	Результат.Вставить("КлючевыеСлова",СписокКлючевыхСлов());
	Результат.Вставить("ТекстОшибки","");
	
	Возврат Результат;

КонецФункции

