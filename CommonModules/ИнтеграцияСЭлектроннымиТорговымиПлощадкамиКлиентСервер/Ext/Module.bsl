// Возвращает имена серверов торговой площадки Бидзаар
// 
// Параметры:
//  Рабочие - Булево - Рабочие
//  Тестовые - Булево - Тестовые
// 
// Возвращаемое значение:
//  СписокЗначений из Строка - Имена серверов бидзаар
Функция ИменаСерверовБидзаар(Рабочие = Истина, Тестовые = Истина) Экспорт
	
	Результат = Новый СписокЗначений;
	
	Если Рабочие Тогда
		Результат.Добавить("bidzaar.com", НСтр("ru = 'Рабочий'"), Истина);	// Отметка рабочего сервера
	КонецЕсли;
	Если Тестовые Тогда
		Результат.Добавить("phoenix.bidzaar.com", НСтр("ru = 'Тестовый (phoenix)'"), Ложь);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

