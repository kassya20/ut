Функция ТаблицаВидовПродукцииПеречислений() Экспорт
	
	ОписаниеТипаВидыПродукцииИС = Новый ОписаниеТипов("СправочникСсылка.ВидыПродукцииИС");
	ИменаПолейКлюча             = КонструкторИСОбщегоНазначенияКлиентСервер.ИменаПолейКлючаВидовПродукции();
	ТаблицаПоВидамПродукции     = Новый ТаблицаЗначений();
	СтрокаИменПолей             = СтрСоединить(ИменаПолейКлюча, ",");
	ТаблицаПоВидамПродукции.Колонки.Добавить("Ссылка", Новый ОписаниеТипов("ПеречислениеСсылка.ВидыПродукцииИС"));
	Для Каждого ИмяПоля Из ИменаПолейКлюча Цикл
		ТаблицаПоВидамПродукции.Колонки.Добавить(ИмяПоля, ОписаниеТипаВидыПродукцииИС);
	КонецЦикла;
	
	ТаблицаПоВидамПродукции.Индексы.Добавить(СтрокаИменПолей);
	
	Для Каждого ЗначениеПеречисления Из Перечисления.ВидыПродукцииИС Цикл
		
		ВидыПродукции = КонструкторИСОбщегоНазначенияКлиентСервер.ВидыПродукцииПоЗначениюПеречисления(
			ЗначениеПеречисления);
		
		Если Не ЗначениеЗаполнено(ВидыПродукции) Тогда
			Продолжить;
		КонецЕсли;
		
		ПоляКлюча = Новый Структура();
		
		Для Каждого ИмяПоля Из ИменаПолейКлюча Цикл
			ПоляКлюча.Вставить(ИмяПоля, Новый Массив);
		КонецЦикла;
		
		Для Каждого ВидПродукции Из ВидыПродукции Цикл
			
			Если КонструкторИСОбщегоНазначенияКлиентСервер.ЭтоПродукцияВЕТИС(ВидПродукции) Тогда
				ПоляКлюча.ВидПродукцииВЕТИС.Добавить(ВидПродукции);
			ИначеЕсли КонструкторИСОбщегоНазначенияКлиентСервер.ЭтоПродукцияИСМП(ВидПродукции, Истина) Тогда
				ПоляКлюча.ВидПродукцииГИСМТ.Добавить(ВидПродукции);
			ИначеЕсли КонструкторИСОбщегоНазначенияКлиентСервер.ЭтоПродукцияЕГАИС(ВидПродукции) Тогда
				ПоляКлюча.ВидПродукцииЕГАИС.Добавить(ВидПродукции);
			ИначеЕсли КонструкторИСОбщегоНазначенияКлиентСервер.ЭтоПродукцияЗЕРНО(ВидПродукции) Тогда
				ПоляКлюча.ВидПродукцииЗЕРНО.Добавить(ВидПродукции);
			ИначеЕсли КонструкторИСОбщегоНазначенияКлиентСервер.ЭтоПродукцияСАТУРН(ВидПродукции) Тогда
				ПоляКлюча.ВидПродукцииСАТУРН.Добавить(ВидПродукции);
			ИначеЕсли ЗначениеПеречисления <> Перечисления.ВидыПродукцииИС.АлкогольнаяПродукцияДо9Процентов Тогда
				ВызватьИсключение СтрШаблон(
					НСтр("ru='Не определена подсистема для вида продукции %1. Обновите классификатор видов продукции.'"),
					ВидПродукции);
			КонецЕсли;
			
		КонецЦикла;
		
		Для Каждого КлючИЗначение Из ПоляКлюча Цикл
			Если КлючИЗначение.Значение.Количество() = 0 Тогда
				КлючИЗначение.Значение.Добавить(Справочники.ВидыПродукцииИС.ПустаяСсылка());
			КонецЕсли;
		КонецЦикла;
		
		Для Каждого ВидПродукцииВЕТИС Из ПоляКлюча.ВидПродукцииВЕТИС Цикл
			Для Каждого ВидПродукцииГИСМТ Из ПоляКлюча.ВидПродукцииГИСМТ Цикл
				Для Каждого ВидПродукцииЕГАИС Из ПоляКлюча.ВидПродукцииЕГАИС Цикл
					Для Каждого ВидПродукцииЗЕРНО Из ПоляКлюча.ВидПродукцииЗЕРНО Цикл
						Для Каждого ВидПродукцииСАТУРН Из ПоляКлюча.ВидПродукцииСАТУРН Цикл
							НоваяСтрока = ТаблицаПоВидамПродукции.Добавить();
							НоваяСтрока.Ссылка             = ЗначениеПеречисления;
							НоваяСтрока.ВидПродукцииСАТУРН = ВидПродукцииСАТУРН;
							НоваяСтрока.ВидПродукцииЗЕРНО  = ВидПродукцииЗЕРНО;
							НоваяСтрока.ВидПродукцииЕГАИС  = ВидПродукцииЕГАИС;
							НоваяСтрока.ВидПродукцииГИСМТ  = ВидПродукцииГИСМТ;
							НоваяСтрока.ВидПродукцииВЕТИС  = ВидПродукцииВЕТИС;
						КонецЦикла;
					КонецЦикла;
				КонецЦикла;
			КонецЦикла;
		КонецЦикла;
		
	КонецЦикла;
	
	Возврат ТаблицаПоВидамПродукции;
	
КонецФункции

Функция ПредставленияВскрытыхПотребительскихУпаковок(ИмяПодсистемы) Экспорт
	
	ВозвращаемоеЗначение = Новый Структура();
	ВозвращаемоеЗначение.Вставить("ЗаголовокСписка", НСтр("ru='Вскрытые потребительские упаковки ИС МП'"));
	ВозвращаемоеЗначение.Вставить("ЗаголовокЗаписи", НСтр("ru='Вскрытие потребительской упаковки ИС МП'"));
	
	ВидыПродукции = ОбщегоНазначенияИСВызовСервера.ВидыПродукцииИспользующиеВскрытыеПотребительскихУпаковок(
		ИмяПодсистемы = "ИСМП", ИмяПодсистемы = "ЕГАИС");
	
	Если ИмяПодсистемы = "ИСМП" Тогда
		
		Если ВидыПродукции.Количество() = 1
			И КонструкторИСМПОбщегоНазначенияКлиентСервер.ПоддерживаетсяПодключениеКОборудованиюРозлива(ВидыПродукции[0]) Тогда
			
			ВозвращаемоеЗначение.ЗаголовокСписка = НСтр("ru='Кеги на оборудовании розлива ИС МП'");
			ВозвращаемоеЗначение.ЗаголовокЗаписи = НСтр("ru='Подключение кега к оборудованию розлива'");
			
		КонецЕсли;
		
	ИначеЕсли ИмяПодсистемы = "ЕГАИС" Тогда
		
		ВозвращаемоеЗначение.ЗаголовокСписка = НСтр("ru='Вскрытые бутылки ЕГАИС'");
		ВозвращаемоеЗначение.ЗаголовокЗаписи = НСтр("ru='Вскрытие бутылки ЕГАИС'");
		
	КонецЕсли;
	
	Возврат Новый ФиксированнаяСтруктура(ВозвращаемоеЗначение);
	
КонецФункции

