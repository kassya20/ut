#Область ОтгрузкиСлужебный

// Конструктор таблицы со списком отгрузок.
// 
// Возвращаемое значение:
//  ТаблицаЗначений:
//   * ИдентификаторОтгрузки - Строка
//   * ИдентификаторыЗаказов - Массив из Строка
//   * НачалоПлановогоИнтервала - Дата
//   * КонецПлановогоИнтервала - Дата
//   * СпособОтгрузки - Строка
//   * СкладОтправленияИдентификатор - Строка
//   * СкладОтправленияНаименование - Строка
//   * СкладОтправленияАдрес - Строка
//   * СкладПолученияИдентификатор - Строка
//   * СкладПолученияНаименование - Строка
//   * СкладПолученияАдрес - Строка
//   * СлужбаДоставкиИдентификатор - Строка
//   * СлужбаДоставкиНаименование - Строка
//   * КоличествоЗаказовПлан - Число
//   * КоличествоЗаказовПодтверждено - Число
//   * КоличествоЗаказовФакт - Число
//   * КоличествоПалетПлан - Число
//   * КоличествоПалетФакт - Число
//   * ПодписанАктПриемаПередачи - Булево
//   * СтатусОтгрузки - Строка
//   * ДатаУстановкиСтатусаОтгрузки - Дата
//   * ДоступныеДействия - Массив из Строка
//
Функция НоваяТаблицаОтгрузок()
	
	Результат = Новый ТаблицаЗначений;
	
	ОписаниеСтроки = ОбщегоНазначения.ОписаниеТипаСтрока(0);
	ОписаниеСтроки50 = ОбщегоНазначения.ОписаниеТипаСтрока(50);
	ОписаниеСтроки250 = ОбщегоНазначения.ОписаниеТипаСтрока(250);
	
	ОписаниеДаты = ОбщегоНазначения.ОписаниеТипаДата(ЧастиДаты.ДатаВремя);
	ОписаниеКоличества = ОбщегоНазначенияУТ.ОписаниеТипаКоличественногоПоля(ДопустимыйЗнак.Неотрицательный);
	
	Результат.Колонки.Добавить("ИдентификаторОтгрузки", ОписаниеСтроки50);
	Результат.Колонки.Добавить("ИдентификаторыЗаказов", Новый ОписаниеТипов("Массив"));
	
	Результат.Колонки.Добавить("НачалоПлановогоИнтервала", ОписаниеДаты);
	Результат.Колонки.Добавить("КонецПлановогоИнтервала", ОписаниеДаты);
	Результат.Колонки.Добавить("СпособОтгрузки", ОписаниеСтроки50);
	
	Результат.Колонки.Добавить("СкладОтправленияИдентификатор", ОписаниеСтроки50);
	Результат.Колонки.Добавить("СкладОтправленияНаименование", ОписаниеСтроки250);
	Результат.Колонки.Добавить("СкладОтправленияАдрес", ОписаниеСтроки);
	
	Результат.Колонки.Добавить("СкладПолученияИдентификатор", ОписаниеСтроки50);
	Результат.Колонки.Добавить("СкладПолученияНаименование", ОписаниеСтроки250);
	Результат.Колонки.Добавить("СкладПолученияАдрес", ОписаниеСтроки);
	
	Результат.Колонки.Добавить("СлужбаДоставкиИдентификатор", ОписаниеСтроки50);
	Результат.Колонки.Добавить("СлужбаДоставкиНаименование", ОписаниеСтроки250);
	
	Результат.Колонки.Добавить("КоличествоЗаказовПлан", ОписаниеКоличества);
	Результат.Колонки.Добавить("КоличествоЗаказовПодтверждено", ОписаниеКоличества);
	Результат.Колонки.Добавить("КоличествоЗаказовФакт", ОписаниеКоличества);
	Результат.Колонки.Добавить("КоличествоПалетПлан", ОписаниеКоличества);
	Результат.Колонки.Добавить("КоличествоПалетФакт", ОписаниеКоличества);
	
	Результат.Колонки.Добавить("ПодписанАктПриемаПередачи", Новый ОписаниеТипов("Булево"));
	Результат.Колонки.Добавить("СтатусОтгрузки", ОписаниеСтроки50);
	Результат.Колонки.Добавить("ДатаУстановкиСтатусаОтгрузки", ОписаниеДаты);
	
	Результат.Колонки.Добавить("ДоступныеДействия", Новый ОписаниеТипов("Массив"));
	
	Возврат Результат;
	
КонецФункции

Процедура ЗаполнитьИнформациюОбОтгрузкеПоОтветуСервиса(ИнформацияОбОтгрузке, ОтветСервиса,
			ВозможныеСпособыОтгрузкиЗаказов, ВозможныеСтатусыОтгрузки, ДоступныеДействияНадОтгрузкой)
		
	ИнформацияОбОтгрузке.ИдентификаторОтгрузки = ЧислоВСтроку(ОтветСервиса["id"]);
	
	ЗаказыВОтгрузке = ОтветСервиса["orderIds"];
	Если ТипЗнч(ЗаказыВОтгрузке) = Тип("Массив") Тогда
		Для Каждого ИдентификаторЗаказа Из ЗаказыВОтгрузке Цикл
			ИнформацияОбОтгрузке.ИдентификаторыЗаказов.Добавить(ЧислоВСтроку(ИдентификаторЗаказа));
		КонецЦикла;
	КонецЕсли;
	
	ИнформацияОбОтгрузке.НачалоПлановогоИнтервала = ОтветСервиса["planIntervalFrom"];
	ИнформацияОбОтгрузке.КонецПлановогоИнтервала = ОтветСервиса["planIntervalTo"];   
	ИнформацияОбОтгрузке.СпособОтгрузки = ВозможныеСпособыОтгрузкиЗаказов[ОтветСервиса["shipmentType"]];
	
	СкладОтправления = ОтветСервиса["warehouse"];
	Если ЗначениеЗаполнено(СкладОтправления) Тогда
		ИнформацияОбОтгрузке.СкладОтправленияИдентификатор = ЧислоВСтроку(СкладОтправления["id"]);
		ИнформацияОбОтгрузке.СкладОтправленияНаименование = СкладОтправления["name"];
		ИнформацияОбОтгрузке.СкладОтправленияАдрес = СкладОтправления["address"];
	КонецЕсли;
	
	СкладПолучения = ОтветСервиса["warehouseTo"];
	Если ЗначениеЗаполнено(СкладПолучения) Тогда
		ИнформацияОбОтгрузке.СкладПолученияИдентификатор = ЧислоВСтроку(СкладПолучения["id"]);
		ИнформацияОбОтгрузке.СкладПолученияНаименование = СкладПолучения["name"];
		ИнформацияОбОтгрузке.СкладПолученияАдрес = СкладПолучения["address"];
	КонецЕсли;
	
	СлужбаДоставки = ОтветСервиса["deliveryService"];
	Если ЗначениеЗаполнено(СлужбаДоставки) Тогда
		ИнформацияОбОтгрузке.СлужбаДоставкиИдентификатор = ЧислоВСтроку(СлужбаДоставки["id"]);
		ИнформацияОбОтгрузке.СлужбаДоставкиНаименование = СлужбаДоставки["name"];
	КонецЕсли;
	
	ОписаниеПалет = ОтветСервиса["palletsCount"];
	Если ЗначениеЗаполнено(ОписаниеПалет) Тогда
		ИнформацияОбОтгрузке.КоличествоПалетПлан = ОписаниеПалет["planned"];
		ИнформацияОбОтгрузке.КоличествоПалетФакт = ОписаниеПалет["fact"];
	КонецЕсли;
	
	ИнформацияОбОтгрузке.КоличествоЗаказовПлан = ОтветСервиса["draftCount"];
	ИнформацияОбОтгрузке.КоличествоЗаказовПодтверждено = ОтветСервиса["plannedCount"];
	ИнформацияОбОтгрузке.КоличествоЗаказовФакт = ОтветСервиса["factCount"];
	
	ДанныеПодписи = ОтветСервиса["signature"];
	Если ЗначениеЗаполнено(ДанныеПодписи) Тогда
		ИнформацияОбОтгрузке.ПодписанАктПриемаПередачи = ДанныеПодписи["signed"];
	КонецЕсли;
	
	ДанныеСтатуса = ОтветСервиса["currentStatus"];
	Если ЗначениеЗаполнено(ДанныеСтатуса) Тогда
		ДатаУстановкиСтатусаОтгрузки = ДанныеСтатуса["updateTime"];
		СтатусИзСервиса = ДанныеСтатуса["status"];
	Иначе
		ДатаУстановкиСтатусаОтгрузки = ОтветСервиса["statusUpdateTime"];
		СтатусИзСервиса = ОтветСервиса["status"];
	КонецЕсли;
	
	ИнформацияОбОтгрузке.ДатаУстановкиСтатусаОтгрузки = ДатаУстановкиСтатусаОтгрузки;
	ИнформацияОбОтгрузке.СтатусОтгрузки = ВозможныеСтатусыОтгрузки[СтатусИзСервиса];
	
	ДоступныеДействия = ОтветСервиса["availableActions"];
	Если ТипЗнч(ДоступныеДействия) = Тип("Массив") Тогда
		Для Каждого Действие Из ДоступныеДействия Цикл
			ИнформацияОбОтгрузке.ДоступныеДействия.Добавить(ДоступныеДействияНадОтгрузкой[Действие]);
		КонецЦикла;
	КонецЕсли;
	
КонецПроцедуры

Процедура ЗаполнитьРезультатПоДаннымОтгрузки(ИнформацияОбОтгрузке, ДанныеОтгрузки) 
	
	ИнформацияОбОтгрузке.ИдентификаторОтгрузки = ДанныеОтгрузки.ИдентификаторОтгрузки; 
	ИнформацияОбОтгрузке.НомерОтгрузки = ДанныеОтгрузки.ИдентификаторОтгрузки;
	ИнформацияОбОтгрузке.ДатаВыполнения = Дата(Год(ДанныеОтгрузки.КонецПлановогоИнтервала),Месяц(ДанныеОтгрузки.КонецПлановогоИнтервала),День(ДанныеОтгрузки.КонецПлановогоИнтервала));                                   
	ИнформацияОбОтгрузке.ДатаОбновления = Дата(Год(ДанныеОтгрузки.ДатаУстановкиСтатусаОтгрузки),Месяц(ДанныеОтгрузки.ДатаУстановкиСтатусаОтгрузки),День(ДанныеОтгрузки.ДатаУстановкиСтатусаОтгрузки));                            
	
	СтатусОтгрузки  = ДанныеОтгрузки.СтатусОтгрузки;  
	ИнформацияОбОтгрузке.Статус  = СтатусОтгрузки;                                         
	ИнформацияОбОтгрузке.ДоступныеДействия = ДанныеОтгрузки.ДоступныеДействия;                             
	
	Если СтатусОтгрузки = "Сформирована" Тогда 
			
				ИнформацияОбОтгрузке.МожноРедактировать = Истина; 
				ИнформацияОбОтгрузке.ОтгрузкаСформирована = Истина; 
				
	ИначеЕсли СтатусОтгрузки = "Принята" 
				Или СтатусОтгрузки = "ПринятаСРасхождениями" 
				Или СтатусОтгрузки = "ГотоваКОтправке"
				Или СтатусОтгрузки = "ПодписанАктПриемаПередачи" Тогда
				
				ИнформацияОбОтгрузке.МожноРедактировать = Ложь; 
				ИнформацияОбОтгрузке.ОтгрузкаСформирована = Истина;  	
	КонецЕсли;
	
	Если СтатусОтгрузки = "Завершена" Или СтатусОтгрузки = "Ошибка" Тогда         
		ИнформацияОбОтгрузке.ОтгрузкаАктуальна = Ложь;
	Иначе
		ИнформацияОбОтгрузке.ОтгрузкаАктуальна = Истина;	
	КонецЕсли;  
	
	ДанныеЗаказовОтгрузки = ПолучитьДанныеЗаказовОтгрузки(ИнформацияОбОтгрузке.УчетнаяЗапись,ДанныеОтгрузки.ИдентификаторыЗаказов);
	ИнформацияОбОтгрузке.ЗаказыНеЗагруженные = ДанныеЗаказовОтгрузки.ЗаказыНеЗагруженные; 
	ИнформацияОбОтгрузке.ЗаказыЗагруженные = ДанныеЗаказовОтгрузки.ЗаказыЗагруженные; 
	ИнформацияОбОтгрузке.ЗаказыНеЗагруженныеОтмененные = ДанныеЗаказовОтгрузки.ЗаказыНеЗагруженныеОтмененные;
	ИнформацияОбОтгрузке.ВсеНеЗагруженныеЗаказыОтменены = ДанныеЗаказовОтгрузки.ВсеНеЗагруженныеЗаказыОтменены;
	ИнформацияОбОтгрузке.СоответствиеЗаказовИОтправлений = ДанныеЗаказовОтгрузки.СоответствиеЗаказовИОтправлений;
	ИнформацияОбОтгрузке.СрокОтгрузки = Дата(Год(ДанныеОтгрузки.КонецПлановогоИнтервала),Месяц(ДанныеОтгрузки.КонецПлановогоИнтервала),День(ДанныеОтгрузки.КонецПлановогоИнтервала));                             
    ИнформацияОбОтгрузке.КоличествоЗаказовПлан = ДанныеОтгрузки.КоличествоЗаказовПлан;
	ИнформацияОбОтгрузке.КоличествоЗаказовПодтверждено = ДанныеОтгрузки.КоличествоЗаказовПодтверждено;
	ИнформацияОбОтгрузке.КоличествоЗаказовФакт = ДанныеОтгрузки.КоличествоЗаказовФакт;
	ИнформацияОбОтгрузке.ИдентификаторыЗаказов = ДанныеОтгрузки.ИдентификаторыЗаказов;
	ИнформацияОбОтгрузке.СпособОтгрузки = ДанныеОтгрузки.СпособОтгрузки;                  
	ИнформацияОбОтгрузке.АдресПунктаПриема = ДанныеОтгрузки.СкладПолученияАдрес;               
	ИнформацияОбОтгрузке.ВремяПриемаНачало = ДанныеОтгрузки.НачалоПлановогоИнтервала;
	ИнформацияОбОтгрузке.ВремяПриемаОкончание = ДанныеОтгрузки.КонецПлановогоИнтервала;
	ИнформацияОбОтгрузке.ВремяОтгрузкиРекомендуемое = ДанныеОтгрузки.КонецПлановогоИнтервала; 
	ИнформацияОбОтгрузке.ПодписанАктПриемаПередачи = ДанныеОтгрузки.ПодписанАктПриемаПередачи;            

КонецПроцедуры

Процедура ДополнитьТаблицуЗаказовИнформациейОбОтгрузках(УчетнаяЗапись, ТаблицаЗаказов, ПараметрыПолученияЗаказов)
	
	Если ТаблицаЗаказов.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	Если ТаблицаЗаказов.Количество() > КоличествоСтрокДляИндексации() Тогда
		ТаблицаЗаказов.Индексы.Добавить("ИдентификаторЗаказа");
	КонецЕсли;
	
	ДатыОтгрузки = МинимальнаяИМаксимальнаяДатыОтгрузкиИзТаблицыЗаказов(ТаблицаЗаказов);
	
	ИдентификаторыЗаказов = ТаблицаЗаказов.ВыгрузитьКолонку("ИдентификаторЗаказа");
	ИдентификаторыЗаказов = ОбщегоНазначенияКлиентСервер.СвернутьМассив(ИдентификаторыЗаказов);
	
	ВозможныеСтатусыОтгрузки = ВозможныеСтатусыОтгрузки();
	
	ПараметрыПолучения = НовыеПараметрыПолученияСпискаОтгрузок(
		ДатыОтгрузки.МинимальнаяДата,
		ДатыОтгрузки.МаксимальнаяДата);
	
	ПараметрыПолучения.Фильтр.СтатусыОтгрузок.Добавить(ВозможныеСтатусыОтгрузки.Сформирована);
	ПараметрыПолучения.Фильтр.СтатусыОтгрузок.Добавить(ВозможныеСтатусыОтгрузки.ГотоваКОтправке);
	ПараметрыПолучения.Фильтр.СтатусыОтгрузок.Добавить(ВозможныеСтатусыОтгрузки.ПринятаСРасхождениями);
	ПараметрыПолучения.Фильтр.ИдентификаторыЗаказов = ИдентификаторыЗаказов;
	
	РезультатПолучения = СписокОтгрузок(УчетнаяЗапись, ПараметрыПолучения);
	
	КоличествоСтрок = РезультатПолучения.ТаблицаОтгрузок.Количество();
	Если КоличествоСтрок = 0 Тогда
		Возврат;
	ИначеЕсли КоличествоСтрок > КоличествоСтрокДляИндексации() Тогда
		РезультатПолучения.ТаблицаОтгрузок.Индексы.Добавить("СтатусОтгрузки");
	КонецЕсли;
	
	ДополнитьТаблицуЗаказовИнформациейОбОтгрузкахВСтатусеСформирована(
		ТаблицаЗаказов,
		РезультатПолучения.ТаблицаОтгрузок);
	
	ДополнитьТаблицуЗаказовИнформациейОбОтгрузкахВСтатусеГотоваКОтправке(
		ТаблицаЗаказов,
		РезультатПолучения.ТаблицаОтгрузок);
	
	ДополнитьТаблицуЗаказовИнформациейОбОтгрузкахВСтатусеПринятаСРасхождениями(
		УчетнаяЗапись,
		ТаблицаЗаказов,
		РезультатПолучения.ТаблицаОтгрузок);
	
КонецПроцедуры

Функция МинимальнаяИМаксимальнаяДатыОтгрузкиИзТаблицыЗаказов(ТаблицаЗаказов)
	
	Результат = Новый Структура;
	
	ПустаяДата = Дата(1, 1, 1);
	
	Результат.Вставить("МинимальнаяДата", ПустаяДата);
	Результат.Вставить("МаксимальнаяДата", ПустаяДата);
	
	Для Каждого ДанныеЗаказа Из ТаблицаЗаказов Цикл
		ДатаОтгрузки = ДанныеЗаказа.ДатаОтгрузки;
		Если Результат.МинимальнаяДата = ПустаяДата Тогда
			Результат.МинимальнаяДата = ДатаОтгрузки;
		Иначе
			Результат.МинимальнаяДата = Мин(Результат.МинимальнаяДата, ДатаОтгрузки);
		КонецЕсли;
		Если Результат.МаксимальнаяДата = ПустаяДата Тогда
			Результат.МаксимальнаяДата = ДатаОтгрузки;
		Иначе
			Результат.МаксимальнаяДата = Макс(Результат.МаксимальнаяДата, ДатаОтгрузки);
		КонецЕсли;
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Процедура ДополнитьТаблицуЗаказовИнформациейОбОтгрузкахВСтатусеСформирована(ТаблицаЗаказов, ТаблицаОтгрузок)
	
	ОтборПоСтатусу = Новый Структура;
	ОтборПоСтатусу.Вставить("СтатусОтгрузки", "Сформирована");
	НайденныеСтрокиПоСтатусу = ТаблицаОтгрузок.НайтиСтроки(ОтборПоСтатусу);
	
	Для Каждого ИнформацияОбОтгрузке Из НайденныеСтрокиПоСтатусу Цикл
		Для Каждого ИдентификаторЗаказа Из ИнформацияОбОтгрузке.ИдентификаторыЗаказов Цикл
			
			Отбор = Новый Структура;
			Отбор.Вставить("ИдентификаторЗаказа", ИдентификаторЗаказа);
			НайденныеСтроки = ТаблицаЗаказов.НайтиСтроки(Отбор);
			
			Для Каждого СтрокаЗаказ Из НайденныеСтроки Цикл
				СтрокаЗаказ.Действие = Перечисления.ДействияПриОбменеСТорговымиПлощадками.ПодтвердитьОтгрузку;
			КонецЦикла;
			
		КонецЦикла;
	КонецЦикла;
	
КонецПроцедуры

Процедура ДополнитьТаблицуЗаказовИнформациейОбОтгрузкахВСтатусеГотоваКОтправке(ТаблицаЗаказов, ТаблицаОтгрузок)
	
	ОтборПоСтатусу = Новый Структура;
	ОтборПоСтатусу.Вставить("СтатусОтгрузки", "ГотоваКОтправке");
	НайденныеСтрокиПоСтатусу = ТаблицаОтгрузок.НайтиСтроки(ОтборПоСтатусу);
	
	Для Каждого ИнформацияОбОтгрузке Из НайденныеСтрокиПоСтатусу Цикл
		Для Каждого ИдентификаторЗаказа Из ИнформацияОбОтгрузке.ИдентификаторыЗаказов Цикл
			
			Отбор = Новый Структура;
			Отбор.Вставить("ИдентификаторЗаказа", ИдентификаторЗаказа);
			НайденныеСтроки = ТаблицаЗаказов.НайтиСтроки(Отбор);
			
			Для Каждого СтрокаЗаказ Из НайденныеСтроки Цикл
				ТипСтатуса = ТипЗнч(СтрокаЗаказ.СтатусОтправления);
				
				Если ТипСтатуса = Тип("Строка")
						И СтрокаЗаказ.СтатусОтправления = "PROCESSING"
						И СтрокаЗаказ.ПодстатусОтправления = "READY_TO_SHIP" Тогда
					
					// Несуществующий на площадке подстатус для отражения процесса передачи в доставку
					СтрокаЗаказ.ПодстатусОтправления = "POSTING_IN_CARRIAGE";
					
				ИначеЕсли ТипСтатуса = Тип("ПеречислениеСсылка.СтатусыЗаказовТорговыхПлощадок")
						И СтрокаЗаказ.СтатусОтправления = Перечисления.СтатусыЗаказовТорговыхПлощадок.ГотовКОтгрузке Тогда
					
					СтрокаЗаказ.СтатусОтправления = Перечисления.СтатусыЗаказовТорговыхПлощадок.ПередаетсяВДоставку;
				КонецЕсли;
			КонецЦикла;
		КонецЦикла;
	КонецЦикла;
	
	ОтборПоСтатусу = Новый Структура;
	ОтборПоСтатусу.Вставить("СтатусОтгрузки", "ПодписанАктПриемаПередачи");
	НайденныеСтрокиПоСтатусу = ТаблицаОтгрузок.НайтиСтроки(ОтборПоСтатусу);  
	
	Для Каждого ИнформацияОбОтгрузке Из НайденныеСтрокиПоСтатусу Цикл
		Для Каждого ИдентификаторЗаказа Из ИнформацияОбОтгрузке.ИдентификаторыЗаказов Цикл
			
			Отбор = Новый Структура;
			Отбор.Вставить("ИдентификаторЗаказа", ИдентификаторЗаказа);
			НайденныеСтроки = ТаблицаЗаказов.НайтиСтроки(Отбор);
			
			Для Каждого СтрокаЗаказ Из НайденныеСтроки Цикл
				ТипСтатуса = ТипЗнч(СтрокаЗаказ.СтатусОтправления);
				
				Если ТипСтатуса = Тип("ПеречислениеСсылка.СтатусыЗаказовТорговыхПлощадок")
						И СтрокаЗаказ.СтатусОтправления = Перечисления.СтатусыЗаказовТорговыхПлощадок.ГотовКОтгрузке Тогда
					
					СтрокаЗаказ.СтатусОтправления = Перечисления.СтатусыЗаказовТорговыхПлощадок.ПередаетсяВДоставку;
				КонецЕсли;
			КонецЦикла;
		КонецЦикла;
	КонецЦикла; 
	
КонецПроцедуры

Процедура ДополнитьТаблицуЗаказовИнформациейОбОтгрузкахВСтатусеПринятаСРасхождениями(УчетнаяЗапись, ТаблицаЗаказов,
			ТаблицаОтгрузок)
	
	ОтборПоСтатусу = Новый Структура;
	ОтборПоСтатусу.Вставить("СтатусОтгрузки", "ПринятаСРасхождениями");
	НайденныеСтрокиПоСтатусу = ТаблицаОтгрузок.НайтиСтроки(ОтборПоСтатусу);
	
	ОписаниеОшибки = ОписаниеОшибкиПроблемаПриОтгрузке();
	
	Для Каждого ИнформацияОбОтгрузке Из НайденныеСтрокиПоСтатусу Цикл
		
		РезультатПолучения = АктРасхождений(УчетнаяЗапись, ИнформацияОбОтгрузке.ИдентификаторОтгрузки);
		Если Не ЭтоАдресВременногоХранилища(РезультатПолучения.АдресФайла) Тогда
			Продолжить;
		КонецЕсли;
		
		ИдентификаторыЗаказов = ИдентификаторыЗаказовИзАктаРасхождений(РезультатПолучения.АдресФайла);
		Для Каждого ИдентификаторЗаказа Из ИдентификаторыЗаказов Цикл
			
			Отбор = Новый Структура;
			Отбор.Вставить("ИдентификаторЗаказа", ИдентификаторЗаказа);
			НайденныеСтроки = ТаблицаЗаказов.НайтиСтроки(Отбор);
			
			Для Каждого СтрокаЗаказ Из НайденныеСтроки Цикл
				СтрокаЗаказ.ОписаниеОшибки = ОписаниеОшибки;
			КонецЦикла;
			
		КонецЦикла;
	КонецЦикла;
	
КонецПроцедуры

Функция ИдентификаторыЗаказовИзАктаРасхождений(АдресФайла)
	
	Результат = Новый Массив; // Массив из Строка
	
	ДвоичныеДанные = ПолучитьИзВременногоХранилища(АдресФайла); // ДвоичныеДанные
	УдалитьИзВременногоХранилища(АдресФайла);
	
	ПараметрыШапки = ИнтеграцияСМаркетплейсамиСервер.ПараметрыШапки();
	ИнформацияПоКолонкам = ИнтеграцияСМаркетплейсамиСервер.ИнициализироватьТаблицуИнформацииПоКолонкам();
	
	ПараметрыЗагрузкиИзФайла = ИнтеграцияСМаркетплейсамиСервер.ПараметрыЗагрузкиИзФайлаВТабличнуюЧасть();
	ПараметрыЗагрузкиИзФайла.ИмяОбъектаМетаданных = "Обработка.УправлениеПродажамиНаЯндексМаркет";
	ПараметрыЗагрузкиИзФайла.ИмяТабличнойЧасти    = "АктРасхождений";
	ПараметрыЗагрузкиИзФайла.ИмяМакетаСШаблоном   = "ПФ_MXL_АктРасхождений";
	
	ИнтеграцияСМаркетплейсамиСервер.ОпределитьИнформациюПоКолонкамИПараметрамШапки(
		ПараметрыЗагрузкиИзФайла,
		ИнформацияПоКолонкам,
		ПараметрыШапки);
	
	ПараметрыЗагрузки = ИнтеграцияСМаркетплейсамиСервер.ПараметрыЗагрузкиТабличногоДокумента(
		Новый УникальныйИдентификатор());
	
	ПараметрыЗагрузки.ДанныеФайла = ДвоичныеДанные;
	ПараметрыЗагрузки.РасширениеФайла = "xlsx";
	ПараметрыЗагрузки.ИнформацияПоКолонкам = ИнформацияПоКолонкам;
	
	РезультатЗагрузки = ИнтеграцияСМаркетплейсамиСервер.ЗагрузитьФайлВТаблицу(ПараметрыЗагрузки);
	
	ТаблицаРасхождений = ТаблицаРасхожденийИзАктаРасхождений(РезультатЗагрузки.АдресТаблицыЗагруженныхДанных);
	
	Для Каждого Строка Из ТаблицаРасхождений Цикл
		Если Строка.НомерПоПорядку = 0 Тогда
			Продолжить;
		КонецЕсли;
		Результат.Добавить(Строка.НомерЗаказа);
	КонецЦикла;
	
	Результат = ОбщегоНазначенияКлиентСервер.СвернутьМассив(Результат);
	Возврат Результат;
	
КонецФункции

// Параметры:
//  АдресТаблицыЗагруженныхДанных - Строка
// 
// Возвращаемое значение:
//  См. Обработка.УправлениеПродажамиНаЯндексМаркет.АктРасхождений
//
Функция ТаблицаРасхожденийИзАктаРасхождений(АдресТаблицыЗагруженныхДанных)
	
	Результат = ПолучитьИзВременногоХранилища(АдресТаблицыЗагруженныхДанных);
	УдалитьИзВременногоХранилища(АдресТаблицыЗагруженныхДанных);
	
	Возврат Результат;
	
КонецФункции

