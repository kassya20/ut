	ИначеЕсли Доступ = "offers_and_cards_management" Тогда
		Описание = НСтр("ru = '- управление товарами и карточками'");   
		ЕдиничноеОписание  = НСтр("ru = 'Текущий ключ предоставляет права на управление товарами и карточками.'");
		
	ИначеЕсли Доступ = "offers_and_cards_management_read_only" Тогда
		Описание = НСтр("ru = '- просмотр товаров и карточек'");   
		ЕдиничноеОписание  = НСтр("ru = 'Текущий ключ предоставляет права на просмотр товаров и карточек.'");
		
	ИначеЕсли Доступ = "promotion" Тогда
		Описание = НСтр("ru = '- продвижение товаров'"); 
		ЕдиничноеОписание  = НСтр("ru = 'Текущий ключ предоставляет права на продвижение товаров.'");
		
	ИначеЕсли Доступ = "promotion_read_only" Тогда
		Описание = НСтр("ru = '- просмотр информации о продвижении товаров'");  
		ЕдиничноеОписание  = НСтр("ru = 'Текущий ключ предоставляет права на просмотр информации о продвижении товаров.'");
		
	ИначеЕсли Доступ = "finance_and_accounting" Тогда
