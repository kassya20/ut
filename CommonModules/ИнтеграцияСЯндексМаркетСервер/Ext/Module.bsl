// Определяет открываемую форму и параметры открытия этой формы по штрихкоду.
// 
// Параметры:
//  УникальныйИдентификаторУчетнойЗаписи - УникальныйИдентификатор - уникальный идентификатор учетной записи
//                                         подключения к сервису.
//  СхемаРаботы - ПеречислениеСсылка.СхемыРаботыТорговыхПлощадок - схема работы, по которой необходимо получить данные.
//  Штрихкод - Строка - штрихкод, по которому необходимо сформировать параметры открытия.
// 
// Возвращаемое значение:
//  - Неопределено
//  - См. ИнтеграцияСМаркетплейсамиСервер.НовыйРезультатОбработкиШтрихкода
//
Функция РезультатОбработкиШтрихкода(УникальныйИдентификаторУчетнойЗаписи, СхемаРаботы, Штрихкод) Экспорт
	
	Результат = ИнтеграцияСМаркетплейсамиСервер.НовыйРезультатОбработкиШтрихкода();
	
	Идентификатор = ШтрихкодированиеПечатныхФорм.ИдентификаторИзШтрихкодаТабличногоДокумента(Штрихкод, Ложь);
	Если Идентификатор <> Неопределено Тогда
		Возврат Неопределено; // Это уникальный идентификатор документа из печатной формы
	КонецЕсли;
	
	УчетнаяЗапись = Справочники.УчетныеЗаписиМаркетплейсов.ПолучитьСсылку(УникальныйИдентификаторУчетнойЗаписи);
	
	ДанныеЗаказаПоШтрихкоду = РегистрыСведений.ЗаказыТорговыхПлощадок.ДанныеЗаказаПоСтрокеПоиска(Штрихкод);
	
	Если ДанныеЗаказаПоШтрихкоду = Неопределено Тогда
		СтрокаПоиска = Штрихкод;
	
	ИначеЕсли ДанныеЗаказаПоШтрихкоду.ИмяПоляПоиска = "ИдентификаторОтгрузки" Тогда
		СтрокаПоиска = Штрихкод;
	Иначе
		СтрокаПоиска = ДанныеЗаказаПоШтрихкоду.НомерЗаказа;
	КонецЕсли;
	
	ТаблицаЗаказов = НоваяТаблицаЗаказов(Ложь);
	ТаблицаЗаказов.Колонки.Добавить("СписокТоваровВОтправлении", Новый ОписаниеТипов("ТаблицаЗначений"));
	
	Если ДанныеЗаказаПоШтрихкоду <> Неопределено
			И ДанныеЗаказаПоШтрихкоду.ИмяПоляПоиска = "ИдентификаторОтгрузки" Тогда
		
		ПараметрыОткрытия = ИнтеграцияСМаркетплейсамиКлиентСервер.НовыеПараметрыОткрытияПодготовкиОтгрузки();
		ПараметрыОткрытия.УчетнаяЗапись = УчетнаяЗапись;
		ПараметрыОткрытия.ИдентификаторОтгрузки = СтрокаПоиска;
		ПараметрыОткрытия.ИдентификаторСклада = ДанныеЗаказаПоШтрихкоду.ИдентификаторСклада;
		
		Результат.ИмяФормы = "РегистрСведений.ЗаказыТорговыхПлощадок.Форма.ПодготовкаОтгрузки";
		Результат.ПараметрыОткрытия = ПараметрыОткрытия;
		
	ИначеЕсли СхемаРаботы = Перечисления.СхемыРаботыТорговыхПлощадок.FBO
			Или СхемаРаботы = Перечисления.СхемыРаботыТорговыхПлощадок.FBS Тогда
		
		ПараметрыПолучения = НовыеПараметрыЗагрузкиЗаказов();
		ПараметрыПолучения.Фильтр.ИдентификаторыЗаказов.Добавить(СтрокаПоиска);
		
		Если ДанныеЗаказаПоШтрихкоду <> Неопределено Тогда
			ПараметрыПолучения.Фильтр.ДатаНачала = НачалоДня(ДанныеЗаказаПоШтрихкоду.ДатаСозданияЗаказа);
			ПараметрыПолучения.Фильтр.ДатаОкончания = КонецДня(ДанныеЗаказаПоШтрихкоду.ДатаСозданияЗаказа);
		КонецЕсли;
	
		ПолучитьДанныеЗаказов(УчетнаяЗапись, ТаблицаЗаказов, ПараметрыПолучения);
		
		Если ТаблицаЗаказов.Количество() = 0 Тогда
			Возврат Неопределено;
		КонецЕсли;
		
		ДанныеЗаказа = ТаблицаЗаказов[0];
		
		ПараметрыОткрытия = РегистрыСведений.ЗаказыТорговыхПлощадок.НовыеПараметрыОткрытияФормыПросмотраЗаказа();
		ЗаполнитьЗначенияСвойств(ПараметрыОткрытия, ДанныеЗаказа);
		
		ПараметрыОткрытия.УчетнаяЗапись = УчетнаяЗапись;
		ПараметрыОткрытия.ЭтоFBO = (СхемаРаботы = Перечисления.СхемыРаботыТорговыхПлощадок.FBO);
		ПараметрыОткрытия.АдресСодержимогоЗаказа = ПоместитьВоВременноеХранилище(
			ДанныеЗаказа.СписокТоваровВОтправлении);
		
		Если ДанныеЗаказаПоШтрихкоду <> Неопределено Тогда
			ПараметрыОткрытия.ДокументЗаказа = ДанныеЗаказаПоШтрихкоду.Заказ;
			ПараметрыОткрытия.ДокументОтгрузки = ДанныеЗаказаПоШтрихкоду.ДокументОтгрузки;
		КонецЕсли;
		
		Результат.ИмяФормы = "РегистрСведений.ЗаказыТорговыхПлощадок.Форма.СоставЗаказа";
		Результат.ПараметрыОткрытия = ПараметрыОткрытия;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

