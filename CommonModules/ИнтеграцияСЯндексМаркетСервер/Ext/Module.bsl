// Получает подробный список отправлений по заказам FBS.
//
// Параметры:
//   УчетнаяЗапись - СправочникСсылка.УчетныеЗаписиМаркетплейсов - учетная запись подключения к сервису.
//   ТаблицаЗаказов - см. РегистрСведений.ЗаказыТорговыхПлощадок.Форма.ПросмотрИЗагрузкаЗаказов.ТаблицаЗаказов
//                  - см. НоваяТаблицаЗаказов
//   Параметры - см. НовыеПараметрыПолученияЗаказов
//   Отказ - Булево - выходной параметр, определяет наличие ошибки при выполнении запросов к сервису.
//
Процедура ПолучитьДанныеЗаказов(Знач УчетнаяЗапись, ТаблицаЗаказов, Знач Параметры, Отказ = Ложь)
	
	НачалоПериода = Параметры.Фильтр.ДатаНачала;
	КонецПериода = Параметры.Фильтр.ДатаОкончания;
	
	ДанныеАвторизации = ИнтеграцияСМаркетплейсамиПовтИсп.ПолучитьДанныеАвторизации(УчетнаяЗапись);
	Параметры.Фильтр.ИдентификаторыКампаний.Добавить(ДанныеАвторизации.ИдентификаторМагазина);
	
	СекундВСутках = 24 * 60 * 60;
	МаксимальнаяРазницаВДнях = 30;
	
	МаксимальныйПериод = МаксимальнаяРазницаВДнях * СекундВСутках;
	
	Пока НачалоПериода < КонецПериода Цикл
		ОкончаниеПериода = НачалоПериода + МаксимальныйПериод - СекундВСутках;
		
		Если Параметры.Фильтр.ВидФильтраПоДате = ВидФильтраПоДатеОбновленияСтатуса() Тогда
			ОкончаниеПериода = Мин(ОкончаниеПериода, КонецДня(КонецПериода));
			Итератор = 1;
		Иначе
			ОкончаниеПериода = Мин(ОкончаниеПериода, КонецПериода);
			Итератор = СекундВСутках;
		КонецЕсли;
		
		Параметры.Фильтр.ДатаНачала = НачалоПериода;
		Параметры.Фильтр.ДатаОкончания = ОкончаниеПериода;
		
		ПорцииЗаказов = РазбитьМассивИдентификаторовНаПорции(Параметры.Фильтр.ИдентификаторыЗаказов);
		Если ПорцииЗаказов.Количество() = 0 Тогда
			ПорцииЗаказов = ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(Новый Массив);
		КонецЕсли;
		
		Для Каждого ПорцияЗаказов Из ПорцииЗаказов Цикл
			Параметры.Фильтр.ИдентификаторыЗаказов = ПорцияЗаказов;
			//@skip-check query-in-loop - Обработка порции данных
			ПолучитьПорциюДанныхЗаказов(УчетнаяЗапись, ТаблицаЗаказов, Параметры, Отказ);
		КонецЦикла;
		
		НачалоПериода = ОкончаниеПериода + Итератор;
	КонецЦикла;
	
	ДанныеСклада = СкладУчетнойЗаписиДляВыгрузкиОстатков(УчетнаяЗапись);
	ИдентификаторСклада = ДанныеСклада.ИдентификаторСклада;
	ТаблицаЗаказов.ЗаполнитьЗначения(ИдентификаторСклада, "ИдентификаторСклада");
	
	Если Параметры.ПолучитьСтатусыОтгрузок Тогда
		ДополнитьТаблицуЗаказовИнформациейОбОтгрузках(УчетнаяЗапись, ТаблицаЗаказов, Параметры);
	КонецЕсли;
	
КонецПроцедуры

Функция РазбитьМассивИдентификаторовНаПорции(МассивИдентификаторов, РазмерПорции = 50)
	
	Результат = Новый Массив; // Массив из Массив
	ТекущаяПорция = Новый Массив; // Массив из Строка
	
	Для Индекс = 0 По МассивИдентификаторов.ВГраница() Цикл
		
		Идентификатор = МассивИдентификаторов[Индекс];
		Идентификатор = ФорматированныйИдентификаторЗаказа(Идентификатор);
		ТекущаяПорция.Добавить(Идентификатор);
		
		Если ТекущаяПорция.Количество() = РазмерПорции Тогда
			Результат.Добавить(ТекущаяПорция);
			ТекущаяПорция = Новый Массив;
		КонецЕсли;
	КонецЦикла;
	
	Если ТекущаяПорция.Количество() > 0 Тогда
		Результат.Добавить(ТекущаяПорция);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Процедура ПолучитьПорциюДанныхЗаказов(УчетнаяЗапись, ТаблицаЗаказов, Параметры, Отказ)
	
	ЕстьСледующаяСтраница = Истина;
	ИдентификаторСтраницы = "";
	
	Пока ЕстьСледующаяСтраница Цикл
		Параметры.ИдентификаторСтраницы = ИдентификаторСтраницы;
		ОтветСервиса = ПолучитьЗаказыИзСервиса(УчетнаяЗапись, Параметры);
		
		Если ОтветСервиса.Ошибка <> Неопределено Тогда
			ЕстьСледующаяСтраница = Ложь;
			Отказ = Истина;
			
		ИначеЕсли ОтветСервиса.Результат.Количество() = 0 Тогда
			ЕстьСледующаяСтраница = Ложь;
			
		Иначе
			Для Каждого Заказ Из ОтветСервиса.Результат Цикл
				
				ДанныеДоставки = Заказ["delivery"];
				Если Не ЗначениеЗаполнено(ДанныеДоставки) Тогда
					Продолжить;
				КонецЕсли;
				
				Отгрузка = ДанныеДоставки["shipment"];
				Если Не ЗначениеЗаполнено(Отгрузка) Тогда
					Продолжить;
				КонецЕсли;
				
				ОтправленияПоЗаказу = ДанныеДоставки["boxesLayout"];
				Если Не ЗначениеЗаполнено(ОтправленияПоЗаказу) Или ТипЗнч(ОтправленияПоЗаказу) <> Тип("Массив") Тогда
					Отправление = НовоеОтправлениеИзСервиса(Заказ["orderId"]);
				Иначе
					Отправление = ОтправленияПоЗаказу[0];
				КонецЕсли;
				
				Если Не Параметры.РазвернутьДоТоваров Тогда
					ДанныеЗаказа = ДанныеЗаказаИзСервиса(Заказ, Отгрузка, Отправление, Неопределено);
					ЗаполнитьЗначенияСвойств(ТаблицаЗаказов.Добавить(), ДанныеЗаказа);
				Иначе
					Для Каждого Товар Из Заказ["items"] Цикл
						ДанныеЗаказа = ДанныеЗаказаИзСервиса(Заказ, Отгрузка, Отправление, Товар);
						ДанныеСтроки = ДанныеСтрокиЗаказаИзСервиса(Заказ, Товар);
						ОбщегоНазначенияКлиентСервер.ДополнитьСтруктуру(ДанныеЗаказа, ДанныеСтроки);
						ЗаполнитьЗначенияСвойств(ТаблицаЗаказов.Добавить(), ДанныеЗаказа);
					КонецЦикла;
				КонецЕсли;
			КонецЦикла;
			
			ЕстьСледующаяСтраница = ОтветСервиса.ЕстьСледующаяСтраница;
			ИдентификаторСтраницы = ОтветСервиса.ИдентификаторСтраницы;
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

Функция НовоеОтправлениеИзСервиса(ИдентификаторЗаказа)
	
	НомерОтправления = НомерОтправленияПоИдентификаторуЗаказа(
		ФорматированныйИдентификаторЗаказа(ИдентификаторЗаказа));
	
	Результат = Новый Структура;
	
	Результат.Вставить("boxId", 0);
	Результат.Вставить("barcode", НомерОтправления);
	
	Возврат Результат;
	
КонецФункции

Функция ДанныеЗаказаИзСервиса(Заказ, Отгрузка, Отправление, Товар)
	
	Результат = НовыеДанныеЗаказаИзСервиса();
	Результат.ИдентификаторЗаказа = ЧислоВСтроку(Заказ["orderId"]);
	Результат.НомерЗаказа = Результат.ИдентификаторЗаказа;
	Результат.ИдентификаторОтправления = ЧислоВСтроку(Отправление["boxId"]);
	Результат.НомерОтправления = Отправление["barcode"];
	Результат.ИдентификаторОтгрузки = ЧислоВСтроку(Отгрузка["id"]);
	
	Результат.СтатусПокупателя = (Заказ["buyerType"] = "BUSINESS");
	Результат.СпособОплаты = ПреобразоватьСпособОплаты(Заказ["paymentType"], Заказ["paymentMethod"]);
	
	Результат.ДатаОтправления = Заказ["creationDate"];
	Результат.ДатаНачалаОбработкиОтправления = Заказ["updateDate"];
	Результат.ДатаОтгрузки = Отгрузка["shipmentDate"];
	Результат.КомментарийКЗаказу = Заказ["notes"];
	
	ДанныеДоставки = Заказ["delivery"];
	Результат.ТипДоставки = ДанныеДоставки["serviceName"];
	
	ДатыДоставки = ДанныеДоставки["dates"];
	Если ЗначениеЗаполнено(ДатыДоставки) Тогда
		Результат.ДатаДоставки = ДатыДоставки["toDate"];
	КонецЕсли;
	
	ДоставкаКурьером = ИнформацияОДоставкеИзСервиса(ДанныеДоставки["courier"]);
	ЗаполнитьДанныеАдресаДоставки(Результат, ДоставкаКурьером["region"]);
	
	ДоставкаВПунктВыдачи = ИнформацияОДоставкеИзСервиса(ДанныеДоставки["pickup"]);
	ЗаполнитьДанныеАдресаДоставки(Результат, ДоставкаВПунктВыдачи["region"]);
	
	Если Товар <> Неопределено Тогда
		Результат.СпособДоставки = ДанныеДоставки["type"];
	Иначе
		Результат.СпособДоставки = ПреобразоватьСпособДоставки(ДанныеДоставки["type"]);
	КонецЕсли;
	
	Если Заказ["status"] = "CANCELLED" Тогда
		Результат.ИдентификаторПричиныОтмены = Заказ["substatus"];
		ПричиныОтмены = ПолучитьПричиныОтмены(Результат.ИдентификаторПричиныОтмены);
		
		Если ПричиныОтмены.Детализация.Количество() > 0 Тогда
			ПричинаОтмены = ПричиныОтмены.Детализация[0];
			Если ПричинаОтмены.Доступность Тогда
				Результат.ПричинаОтмены = ПричинаОтмены.Наименование;
				Результат.ИнициаторОтмены = ПричинаОтмены.Инициатор;
			КонецЕсли;
		КонецЕсли;
		Результат.ПричинаОтменыОтправления = Результат.ПричинаОтмены;
	КонецЕсли;
	
	Если Товар <> Неопределено Тогда
		Результат.СтатусОтправления = Заказ["status"];
		Результат.ПодстатусОтправления = Заказ["substatus"];
		
		ТребованияПоМаркировке = Товар["requiredInstanceTypes"];
		Если ЗначениеЗаполнено(ТребованияПоМаркировке) Тогда // Свойства может не быть, если нет требований к маркировке
			ЗаполнитьТребованиеПоМаркировке(Результат, ТребованияПоМаркировке, "CIS", "ТребуетсяМаркировка");
			ЗаполнитьТребованиеПоМаркировке(Результат, ТребованияПоМаркировке, "CIS_OPTIONAL", "ТребуетсяМаркировка");
			ЗаполнитьТребованиеПоМаркировке(Результат, ТребованияПоМаркировке, "UIN", "ТребуетсяУИНЮвелирногоИзделия");
			ЗаполнитьТребованиеПоМаркировке(Результат, ТребованияПоМаркировке, "RNPT", "ТребуетсяРНПТ");
			ЗаполнитьТребованиеПоМаркировке(Результат, ТребованияПоМаркировке, "GTD", "ТребуетсяГТД");
		КонецЕсли;
	Иначе
		Результат.СтатусОтправления = Перечисления.СтатусыЗаказовТорговыхПлощадок.ПолучитьПоПредставлению(
			Заказ["status"],
			Заказ["substatus"],
			Перечисления.ВидыМаркетплейсов.МаркетплейсЯндексМаркет);
		
		СписокТоваровВОтправлении = НовыйСписокТоваровВОтправлении();
		Для Каждого Товар Из Заказ["items"] Цикл
			ДанныеСтроки = ДанныеСтрокиЗаказаИзСервиса(Заказ, Товар);
			ЗаполнитьЗначенияСвойств(СписокТоваровВОтправлении.Добавить(), ДанныеСтроки);
		КонецЦикла;
		
		Результат.СписокТоваровВОтправлении = СписокТоваровВОтправлении;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Возвращаемое значение:
//  Структура:
//   * ИдентификаторЗаказа - Строка
//   * НомерЗаказа - Строка
//   * ИдентификаторОтправления - Строка
//   * НомерОтправления - Строка
//   * ИдентификаторОтгрузки - Строка
//   * ДатаОтправления - Дата
//   * ДатаНачалаОбработкиОтправления - Дата
//   * СтатусОтправления - Строка
