// Получает заказы из сервиса.
// Описание метода см. https://yandex.ru/dev/market/partner-api/doc/ru/reference/orders/getBusinessOrders.
//
// Параметры:
//  УчетнаяЗапись - СправочникСсылка.УчетныеЗаписиМаркетплейсов - учетная запись подключения к сервису.
//  Параметры - см. НовыеПараметрыПолученияЗаказов
//
// Возвращаемое значение:
//  Структура:
//   * Ошибка - Неопределено - при выполнении запроса к внешнему ресурсу ошибок не возникло.
//            - см. ИнтеграцияСМаркетплейсамиСервер.НоваяОшибка
//   * ЕстьСледующаяСтраница - Булево - признак наличия данных в следующей порции.
//   * ИдентификаторСтраницы - Строка - идентификатор последней страницы (page_token).
//   * Результат - Массив из Структура:
//      ** orderId - Число - идентификатор заказа.
//      ** externalOrderId - Строка - внешний идентификатор заказа.
//      ** campaignId - Число - идентификатор кампании (магазина).
//      ** programType - Строка - схема доставки: FBY, FBS, DBS, EXPRESS, LAAS.
//      ** status - Строка - статус заказа.
//      ** substatus - Строка - этап обработки заказа.
//      ** creationDate - Дата - дата и время оформления заказа.
//      ** updateDate - Дата - дата и время последнего обновления заказа.
//      ** paymentType - Строка - тип оплаты заказа.
//      ** paymentMethod - Строка - способ оплаты заказа.
//      ** fake - Булево - тип заказа: настоящий заказ покупателя или тестовый заказ Маркета.
//      ** items - Массив из Структура - список товаров в заказе:
//          *** id - Число - идентификатор товара в заказе. Позволяет идентифицировать товар в рамках данного заказа.
//          *** offerId - Строка - идентификатор товарного предложения для определенного товара.
//          *** offerName - Строка - название товара.
//          *** count - Число - количество единиц товара.
//          *** prices - см. НоваяИнформацияОВыплатахИВознагражденияхИзСервиса
//          *** instances - Массив из Структура - информация о маркировке единиц товара:
//               **** cis - Строка - код идентификации единицы товара в системе "Честный ЗНАК" без криптохвоста или
//                        "ASL BELGISI" (для продавцов Market Yandex Go).
//               **** cisFull - Строка - код идентификации единицы товара в системе "Честный ЗНАК" с криптохвостом.
//               **** uin - Строка - УИН ювелирного изделия.
//               **** rnpt - Строка - регистрационный номер партии товара.
//               **** gtd - Строка - грузовая таможенная декларация.
//               **** countryCode - Строка - страна производства в формате ISO 3166-1 alpha-2.
//          *** requiredInstanceTypes - Массив из Строка - список необходимых маркировок товара.
//          *** tags - Массив из Строка - признаки товара.
//      ** prices - см. НоваяИнформацияОВыплатахИВознагражденияхИзСервиса
//      ** delivery - Структура - информация о доставке заказа:
//          *** type - Строка - способ доставки заказа.
//          *** serviceName - Строка - название службы доставки.
//          *** deliveryServiceId - Число - идентификатор службы доставки.
//          *** warehouseId - Строка - идентификатор склада в системе магазина, на который сформирован заказ.
//          *** deliveryPartnerType - Строка - тип сотрудничества со службой доставки в рамках конкретного заказа.
//          *** dispatchType - Строка - способ отгрузки.
//          *** dates - Структура - диапазон дат доставки:
//               **** fromDate - Дата - ближайшая дата доставки.
//               **** toDate - Дата - самая поздняя дата доставки.
//               **** fromTime - Дата - начало интервала времени доставки.
//               **** toTime - Дата - конец интервала времени доставки.
//               **** realDeliveryDate - Дата - когда товар доставлен до пункта выдачи заказа или до покупателя.
//          *** shipment - Структура - информация об отгрузке:
//               **** id - Число - идентификатор отгрузки.
//               **** shipmentDate - Дата - дата отгрузки.
//               **** shipmentTime - Дата - время отгрузки.
//          *** courier - Структура - информация о курьерской доставке:
//               **** address - см. НовоеОписаниеАдресаИзСервиса
//               **** region - см. НовоеОписаниеРегионаИзСервиса
//          *** pickup - Структура - информация о доставке в пункт выдачи:
//               **** address - см. НовоеОписаниеАдресаИзСервиса
//               **** region - см. НовоеОписаниеРегионаИзСервиса
//               **** logisticPointId - Число - идентификатор пункта выдачи.
//               **** outletCode - Строка - идентификатор пункта самовывоза, присвоенный магазином.
//               **** outletStorageLimitDate - Дата - дата, до которой заказ будет храниться в пункте выдачи.
//          *** transfer - Структура - информация о курьере и код подтверждения:
//               **** courier - Структура - информация о курьере:
//                     ***** fullName - Строка - полное имя курьера.
//                     ***** phone - Строка - номер телефона курьера.
//                     ***** phoneExtension - Строка - добавочный номер телефона.
//                     ***** vehicleDescription - Строка - описание машины. Например, модель и цвет.
//                     ***** vehicleNumber - Строка - номер транспортного средства.
//               **** eac - Структура - информация о коде подтверждения:
//                     ***** eacType - Строка - тип кода подтверждения ЭАПП.
//                     ***** eacCode - Строка - код подтверждения ЭАПП.
//          *** boxesLayout - Массив из Структура - раскладка товаров по коробкам:
//               **** barcode - Строка - идентификатор грузового места в системе магазина.
//               **** boxId - Число - идентификатор коробки.
//               **** items - Массив из Структура - список товаров в коробке:
//                     ***** id - Число - идентификатор товара в заказе.
//                     ***** fullCount - Число - количество единиц товара в коробке.
//                     ***** instances - Массив из Структура - переданные коды маркировки:
//                            ****** cis - Строка - код идентификации единицы товара в системе "Честный ЗНАК" без
//                                       криптохвоста или "ASL BELGISI" (для продавцов Market Yandex Go).
//                            ****** uin - Строка - УИН ювелирного изделия.
//                            ****** rnpt - Строка - регистрационный номер партии товара.
//                            ****** gtd - Строка - грузовая таможенная декларация.
//                            ****** countryCode - Строка - страна производства в формате ISO 3166-1 alpha-2.
//                     ***** partialCount - Структура:
//                            ****** current - Число - номер части, начиная с 1.
//                            ****** total - Число - на сколько всего частей разделен товар.
//          *** tracks - Массив из Структура - информация для отслеживания посылки:
//               **** deliveryServiceId - Число - идентификатор службы доставки.
//               **** trackCode - Строка - трек-номер посылки.
//          *** estimated - Булево - приблизительная ли дата доставки.
//      ** services - Структура - услуги, добавленные в заказ:
//          *** liftType - Строка - тип подъема заказа на этаж.
//      ** buyerType - Строка - тип покупателя: физическое лицо или организация (PERSON, BUSINESS).
//      ** notes - Строка - комментарий к заказу.
//      ** cancelRequested - Булево - запрошена ли отмена.
//
Функция ПолучитьЗаказыИзСервиса(УчетнаяЗапись, Параметры)
	
	ТекстЗапроса = "/v1/businesses/{businessId}/orders";
	
	ПараметрыЗапроса = Новый Структура;
	
	ПараметрыЗапроса.Вставить("limit", Параметры.МаксимальноеКоличествоВЗапросе);
	ПараметрыЗапроса.Вставить("page_token", Параметры.ИдентификаторСтраницы);
	
	ТелоЗапроса = Новый Структура;
	
	ИдентификаторыЗаказов = Новый Массив; // Массив из Число
	Для Каждого ИдентификаторЗаказа Из Параметры.Фильтр.ИдентификаторыЗаказов Цикл
		ИдентификаторыЗаказов.Добавить(СтрокаВЧисло(ИдентификаторЗаказа));
	КонецЦикла;
	
	Если ИдентификаторыЗаказов.Количество() > 0 Тогда
		ТелоЗапроса.Вставить("orderIds", ИдентификаторыЗаказов);
	КонецЕсли;
	
	Если Параметры.Фильтр.ВнешниеИдентификаторыЗаказов.Количество() > 0 Тогда
		ТелоЗапроса.Вставить("externalOrderIds", Параметры.Фильтр.ВнешниеИдентификаторыЗаказов);
	КонецЕсли;
	
	Если Параметры.Фильтр.СхемыРаботы.Количество() > 0 Тогда
		ТелоЗапроса.Вставить("programTypes", Параметры.Фильтр.СхемыРаботы);
	КонецЕсли;
	
	Если Параметры.Фильтр.ИдентификаторыКампаний.Количество() > 0 Тогда
		ТелоЗапроса.Вставить("campaignIds", Параметры.Фильтр.ИдентификаторыКампаний);
	КонецЕсли;
	
	ДобавитьФильтрПоСтатусуВТелоЗапроса(ТелоЗапроса, Параметры.Фильтр.СтатусЗаказа);
	
	ФильтрПоДате = ФильтрПоДатеИзПараметровЗапроса(Параметры);
	ТелоЗапроса.Вставить("dates", ФильтрПоДате);
	
	ТелоЗапроса.Вставить("fake", ВключенТестовыйРежимЗаказов(УчетнаяЗапись));
	ТелоЗапроса.Вставить("waitingForCancellationApprove", Параметры.Фильтр.ЗаказыСЗапросамиНаОтмену);
	
	СлужебныеПараметры = НовыеСлужебныеПараметрыHTTPЗапроса();
	СлужебныеПараметры.ПрочитатьВСоответствие = Истина;
	
	СлужебныеПараметры.ПоляТипаДата.Добавить("creationDate");
	СлужебныеПараметры.ПоляТипаДата.Добавить("updateDate");
	СлужебныеПараметры.ПоляТипаДата.Добавить("fromDate");
	СлужебныеПараметры.ПоляТипаДата.Добавить("toDate");
	СлужебныеПараметры.ПоляТипаДата.Добавить("fromTime");
	СлужебныеПараметры.ПоляТипаДата.Добавить("toTime");
	СлужебныеПараметры.ПоляТипаДата.Добавить("shipmentDate");
	СлужебныеПараметры.ПоляТипаДата.Добавить("shipmentTime");
	СлужебныеПараметры.ПоляТипаДата.Добавить("outletStorageLimitDate");
	
	ОтветСервиса = ВыполнитьЗапросВСервис(
		УчетнаяЗапись,
		ТекстЗапроса,
		ПараметрыЗапроса,
		ТелоЗапроса,
		"POST",
		СлужебныеПараметры);
	
	РезультатЗапроса = Новый Структура;
	
	РезультатЗапроса.Вставить("Результат", Новый Массив);
	РезультатЗапроса.Вставить("ЕстьСледующаяСтраница", Ложь);
	РезультатЗапроса.Вставить("ИдентификаторСтраницы", "");
	РезультатЗапроса.Вставить("Ошибка", Неопределено);
	
	Если ОтветСервиса.Ошибка = Неопределено Тогда
		//@skip-check statement-type-change
		РезультатЗапроса.Результат = ОтветСервиса.Результат["orders"];
		
		ДанныеСтраницы = ДанныеСледующейСтраницы(ОтветСервиса.Результат);
		РезультатЗапроса.ЕстьСледующаяСтраница = ДанныеСтраницы.ЕстьСледующаяСтраница;
		РезультатЗапроса.ИдентификаторСтраницы = ДанныеСтраницы.ИдентификаторСтраницы;
	Иначе
		РезультатЗапроса.Ошибка = ОтветСервиса.Ошибка;
	КонецЕсли;
	
	Возврат РезультатЗапроса;
	
КонецФункции

Процедура ДобавитьФильтрПоСтатусуВТелоЗапроса(ТелоЗапроса, СтатусЗаказа)
	
	Если Не ЗначениеЗаполнено(СтатусЗаказа) Тогда
		Возврат;
	КонецЕсли;
	
	Статус = "";
	Подстатус = "";
	
	Если СтатусЗаказа = Перечисления.СтатусыЗаказовТорговыхПлощадок.ОжидаетСборки Тогда
		Статус = "PROCESSING";
		Подстатус = "STARTED";
		
	ИначеЕсли СтатусЗаказа = Перечисления.СтатусыЗаказовТорговыхПлощадок.ГотовКОтгрузке Тогда
		Статус = "PROCESSING";
		Подстатус = "READY_TO_SHIP";

	ИначеЕсли СтатусЗаказа = Перечисления.СтатусыЗаказовТорговыхПлощадок.ОжидаетОплату Тогда
		Статус = "UNPAID";
		Подстатус = "";

	ИначеЕсли СтатусЗаказа = Перечисления.СтатусыЗаказовТорговыхПлощадок.Отменен Тогда
		Статус = "CANCELLED";
		Подстатус = "";

	ИначеЕсли СтатусЗаказа = Перечисления.СтатусыЗаказовТорговыхПлощадок.Доставляется Тогда
		Статус = "DELIVERY";
		Подстатус = "";

	ИначеЕсли СтатусЗаказа = Перечисления.СтатусыЗаказовТорговыхПлощадок.ВПунктеВыдачи Тогда
		Статус = "PICKUP";
		Подстатус = "";

	ИначеЕсли СтатусЗаказа = Перечисления.СтатусыЗаказовТорговыхПлощадок.Доставлен Тогда
		Статус = "DELIVERED";
		Подстатус = "";

	ИначеЕсли СтатусЗаказа = Перечисления.СтатусыЗаказовТорговыхПлощадок.Возвращен Тогда
		Статус = "RETURNED";
		Подстатус = "";
	КонецЕсли;
	
	Если Не ПустаяСтрока(Статус) Тогда
		ТелоЗапроса.Вставить("statuses", ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(Статус));
	КонецЕсли;
	Если Не ПустаяСтрока(Подстатус) Тогда
		ТелоЗапроса.Вставить("substatuses", ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(Подстатус));
	КонецЕсли;
	
КонецПроцедуры

Функция ФильтрПоДатеИзПараметровЗапроса(Параметры)
	
	Результат = Новый Структура;
	
	ДатаНачала = Параметры.Фильтр.ДатаНачала;
	ДатаОкончания = Параметры.Фильтр.ДатаОкончания;
	
	Если Параметры.Фильтр.ВидФильтраПоДате = ВидФильтраПоДатеСоздания() Тогда 
		ДатаОкончания = ДатаОкончания + 86400; // Не включается в интервал фильтрации
		Результат.Вставить("creationDateFrom", Формат(ДатаНачала, "ДФ=dd-MM-yyyy"));
		Результат.Вставить("creationDateTo", Формат(ДатаОкончания, "ДФ=dd-MM-yyyy"));
		
	ИначеЕсли Параметры.Фильтр.ВидФильтраПоДате = ВидФильтраПоДатеОтгрузки() Тогда 
		ДатаОкончания = ДатаОкончания + 86400; // Не включается в интервал фильтрации
		Результат.Вставить("shipmentDateFrom", Формат(ДатаНачала, "ДФ=dd-MM-yyyy"));
		Результат.Вставить("shipmentDateTo", Формат(ДатаОкончания, "ДФ=dd-MM-yyyy"));
		
	ИначеЕсли Параметры.Фильтр.ВидФильтраПоДате = ВидФильтраПоДатеОбновленияСтатуса() Тогда
		Результат.Вставить("updateDateFrom", ДатаUTC(ДатаНачала));
		Результат.Вставить("updateDateTo", ДатаUTC(ДатаОкончания));
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Получает номера отправлений по идентификаторам заказов.
//
// Параметры:
//   УчетнаяЗапись - СправочникСсылка.УчетныеЗаписиМаркетплейсов - данные текущего магазина.
//   ИдентификаторыЗаказов - Массив Из Строка - массив идентификаторов заказов по данным торговой площадки.
//   ДатаОтгрузки - Дата - фильтр по дате создания заказов. Поиск выполняется в пределах месяца до указанной даты.
//
// Возвращаемое значение: 
//  Структура:
//   * Ошибка - см. ИнтеграцияСМаркетплейсамиСервер.НоваяОшибка
//   * НомераОтправлений - Массив Из Строка
//
Функция ПолучитьОтправленияПоИдентификаторамЗаказов(УчетнаяЗапись, ИдентификаторыЗаказов, ДатаОтгрузки)
	
	Результат = Новый Структура;
	Результат.Вставить("Ошибка", ИнтеграцияСМаркетплейсамиСервер.НоваяОшибка());
	Результат.Вставить("НомераОтправлений", Новый Массив);
	
	ТаблицаЗаказов = НоваяТаблицаЗаказов(Ложь);
	Отказ = Ложь;
	ПараметрыПолучения = НовыеПараметрыЗагрузкиЗаказов();
	ПараметрыПолучения.РазвернутьДоТоваров = Ложь;
	
	ПараметрыПолучения.Фильтр.ДатаНачала = НачалоДня(ДобавитьМесяц(ДатаОтгрузки, -1));
	ПараметрыПолучения.Фильтр.ДатаОкончания = КонецДня(ДатаОтгрузки);
	
	Если ЗначениеЗаполнено(ИдентификаторыЗаказов) Тогда
		ПараметрыПолучения.Фильтр.ИдентификаторыЗаказов = ИдентификаторыЗаказов;
		ПолучитьДанныеЗаказов(УчетнаяЗапись, ТаблицаЗаказов, ПараметрыПолучения, Отказ);
		Если Отказ Тогда
			Результат.Ошибка.ОписаниеОшибки = НСтр("ru = 'Получение номеров отправлений по списку идентификаторов заказов завершилось неудачно.'"); 
		КонецЕсли;
	Иначе    
		Отказ = Истина;
		Результат.Ошибка.ОписаниеОшибки = НСтр("ru = 'При получении информации о номерах отправлений передан пустой фильтр идентификаторов заказов.'");	
	КонецЕсли;         
	
	Если Не Отказ Тогда
		НомераОтправлений = ТаблицаЗаказов.ВыгрузитьКолонку("НомерОтправления");
		Результат.НомераОтправлений = ОбщегоНазначенияКлиентСервер.СвернутьМассив(НомераОтправлений);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Выполняет передачу номера заказа клиента в качестве внешнего идентификатора заказа.
// 
// Параметры:
//  УчетнаяЗапись - СправочникСсылка.УчетныеЗаписиМаркетплейсов
//  НомерЗаказа - Строка - номер заказа клиента.
//  ИдентификаторЗаказа - Строка - идентификатор заказа торговой площадки.
//
Процедура ПередатьНомерЗаказаКакВнешнийИдентификаторВСервис(УчетнаяЗапись, НомерЗаказа, ИдентификаторЗаказа)
	
	ТекстЗапроса = СтрШаблон("/v2/campaigns/{campaignId}/orders/%1/external-id", ИдентификаторЗаказа);
	
	ТелоЗапроса = Новый Структура;
	ТелоЗапроса.Вставить("externalOrderId", НомерЗаказа);
	
	ОтветСервиса = ВыполнитьЗапросВСервис(
		УчетнаяЗапись,
		ТекстЗапроса,
		Новый Структура,
		ТелоЗапроса,
		"POST");
	
КонецПроцедуры

