// Возвращаемое значение:
//  Структура:
//   * АдресФайла - Строка - адрес во временном хранилище, по которому помещен файл.
//   * Ошибка - см. ИнтеграцияСМаркетплейсамиСервер.НоваяОшибка
//            - Неопределено - при выполнении запроса к внешнему ресурсу ошибок не возникло.
//
Функция НовыйРезультатПолученияПроизвольногоФайла()
	
	Результат = Новый Структура;
	Результат.Вставить("АдресФайла", "");
	Результат.Вставить("Ошибка", ИнтеграцияСМаркетплейсамиСервер.НоваяОшибка());
	
	Возврат Результат;
	
КонецФункции

// Получает двоичные данные из сервиса.
//
// Параметры: 
//   УчетнаяЗапись - СправочникСсылка.УчетныеЗаписиМаркетплейсов
//   ТекстЗапроса - Строка - текст запроса (метод API).
//   ПараметрыЗапроса - Неопределено
//                    - Структура - произвольная структура с параметрами выполняемого запроса.
//   ТелоЗапроса - Неопределено
//               - Структура - данные тела запроса.
//
// Возвращаемое значение:
//  Структура:
//   * Ошибка - Неопределено - при выполнении запроса к внешнему ресурсу ошибок не возникло.
//            - см. ИнтеграцияСМаркетплейсамиСервер.НоваяОшибка
//   * Результат - Неопределено - при выполнении запроса к внешнему ресурсу возникла ошибка.
//               - ДвоичныеДанные - полученный файл из сервиса.
//
Функция ПроизвольныйФайлИзСервиса(УчетнаяЗапись, ТекстЗапроса, Знач ПараметрыЗапроса = Неопределено,
			Знач ТелоЗапроса = Неопределено)
	
	Если ПараметрыЗапроса = Неопределено Тогда
		ПараметрыЗапроса = Новый Структура;
	КонецЕсли;
	
	Если ТелоЗапроса = Неопределено Тогда
		ТелоЗапроса = Новый Структура;
	КонецЕсли;
	
	СлужебныеПараметры = НовыеСлужебныеПараметрыHTTPЗапроса();
	СлужебныеПараметры.ПолучениеДвоичныхДанных = Истина;
	
	ОтветСервиса = ВыполнитьЗапросВСервис(
		УчетнаяЗапись,
		ТекстЗапроса,
		ПараметрыЗапроса,
		ТелоЗапроса,
		"GET",
		СлужебныеПараметры);
	
	РезультатЗапроса = Новый Структура;
	
	РезультатЗапроса.Вставить("Результат", Неопределено);
	РезультатЗапроса.Вставить("Ошибка", Неопределено);
	
	Если ОтветСервиса.Ошибка = Неопределено Тогда
		РезультатЗапроса.Результат = ОтветСервиса.Результат;
	Иначе
		РезультатЗапроса.Ошибка = ОтветСервиса.Ошибка;
	КонецЕсли;
	
	Возврат РезультатЗапроса;
	
КонецФункции

Процедура ОбработатьПолучениеПроизвольногоФайла(Результат, ОтветСервиса, Адрес, УчетнаяЗапись, ТекстОшибки)
	
	Если ТипЗнч(ОтветСервиса.Результат) = Тип("ДвоичныеДанные") Тогда
		Результат.АдресФайла = ПоместитьВоВременноеХранилище(ОтветСервиса.Результат, Адрес);
		
	ИначеЕсли ОтветСервиса.Ошибка <> Неопределено Тогда
		Результат.Ошибка.ОписаниеОшибки = ТекстОшибки;
		ЗаписьЖурналаРегистрации(
			СобытиеЖурналаРегистрации(),
			УровеньЖурналаРегистрации.Ошибка, ,
			УчетнаяЗапись,
			ТекстОшибки);
	Иначе
		Результат.Ошибка = ОтветСервиса.Ошибка;
	КонецЕсли;
	
КонецПроцедуры

// Конструктор служебных параметров HTTP-запроса.
// 
// Возвращаемое значение:
//  Структура:
//   * ПрочитатьВСоответствие - Булево - если установлено Истина, результат выполнения запроса будет представлен
//         как Соответствие. Если установлено Ложь, результат представляется как Структура.
//         Значение по умолчанию: Ложь.
//   * ПолучениеДвоичныхДанных - Булево - признак необходимости получения двоичных данных из тела ответа.
//   * ПоляТипаДата - Массив из Строка - массив, элементы которого содержат имена свойств JSON,
//         для которых нужно вызывать восстановление даты из строки.
//
Функция НовыеСлужебныеПараметрыHTTPЗапроса()
	
	Результат = Новый Структура;
	
	Результат.Вставить("ПрочитатьВСоответствие", Ложь);
	Результат.Вставить("ПолучениеДвоичныхДанных", Ложь);
	Результат.Вставить("ПоляТипаДата", Новый Массив);
	Результат.Вставить("ДанныеАвторизации", Новый Структура);
	
	Возврат Результат;
	
КонецФункции

// Выполняет запрос в сервис. Автоматически добавляет к выполняемому тексту запроса идентификатор кабинета или магазина.
// Для установки идентификатора кабинета в тексте запроса должна присутствовать подстрока "{businessId}".
// Для установки идентификатора магазина - "{campaignId}".
//
// Параметры:
//   УчетнаяЗапись - СправочникСсылка.УчетныеЗаписиМаркетплейсов - учетная запись подключения к сервису.
//   ТекстЗапроса - Строка - текст запроса (метод API).
//   ПараметрыЗапроса - Структура - произвольная структура с параметрами выполняемого запроса.
//   ТелоЗапроса - Структура - данные тела запроса.
//   HTTPМетод  - Строка - имя HTTP-метода для запроса, например, "GET" или "POST".
//   СлужебныеПараметры - Неопределено
//                      - см. НовыеСлужебныеПараметрыHTTPЗапроса
//
// Возвращаемое значение:
//   Структура - ответ сервиса:
//     * Результат - Неопределено - при выполнении запроса возникла ошибка.
//                 - ДвоичныеДанные - в служебных параметрах указано, что нужно вернуть двоичные данные.
//                 - Структура - в служебных параметрах указано, что нужно вернуть структуру.
//                 - Соответствие Из КлючИЗначение - в служебных параметрах указано, что нужно вернуть соответствие.
//     * Ошибка - см. ИнтеграцияСМаркетплейсамиСервер.НоваяОшибка
//              - Неопределено - при выполнении запроса ошибок не возникло.
//
Функция ВыполнитьЗапросВСервис(УчетнаяЗапись, ТекстЗапроса, ПараметрыЗапроса, ТелоЗапроса, HTTPМетод,
			Знач СлужебныеПараметры = Неопределено)
	
	Результат = Неопределено; // Неопределено, ДвоичныеДанные, Структура, Соответствие Из КлючИЗначение
	Ошибка = Неопределено; // Неопределено, Структура
	
	Если СлужебныеПараметры = Неопределено Тогда
		СлужебныеПараметры = НовыеСлужебныеПараметрыHTTPЗапроса();
	КонецЕсли;
	
	Попытка
		Если УчетнаяЗапись <> Неопределено Тогда
			ДанныеАвторизации = ИнтеграцияСМаркетплейсамиПовтИсп.ПолучитьДанныеАвторизации(УчетнаяЗапись); 
		Иначе
			ДанныеАвторизации = СлужебныеПараметры.ДанныеАвторизации;
		КонецЕсли;

		ДанныеПриложения = ДанныеПриложения();
		АдресСервера = СерверAPI();
		
		АдресРесурса = СтрЗаменить(ТекстЗапроса, "{businessId}", ДанныеАвторизации.ИдентификаторКабинета);
		АдресРесурса = СтрЗаменить(АдресРесурса, "{campaignId}", ДанныеАвторизации.ИдентификаторМагазина);
		
		ПараметрыURL = ЗаполнитьПараметрыURL(ПараметрыЗапроса);
		Если ПараметрыURL.Количество() > 0 Тогда
			АдресРесурса = СтрШаблон("%1?%2", АдресРесурса, СтрСоединить(ПараметрыURL, "&"));
		КонецЕсли;
		
		ИнтернетПрокси = Неопределено;
		Если ОбщегоНазначения.ПодсистемаСуществует("СтандартныеПодсистемы.ПолучениеФайловИзИнтернета") Тогда
			МодульПолучениеФайловИзИнтернета = ОбщегоНазначения.ОбщийМодуль("ПолучениеФайловИзИнтернета");
			ИнтернетПрокси = МодульПолучениеФайловИзИнтернета.ПолучитьПрокси("https");
		КонецЕсли;
		СоединениеOpenSSL = ОбщегоНазначенияКлиентСервер.НовоеЗащищенноеСоединение();
		
		HTTPСоединение = Новый HTTPСоединение(АдресСервера,,,, ИнтернетПрокси, 60, СоединениеOpenSSL);
		
		Заголовки = Новый Соответствие;
		Заголовки.Вставить("Content-Type", "application/json");
		
		Если Не ПустаяСтрока(ДанныеАвторизации["apikey_token"]) Тогда
			Заголовки.Вставить("Api-Key", ДанныеАвторизации["apikey_token"]);
			
		ИначеЕсли Не ПустаяСтрока(ДанныеАвторизации["access_token"]) Тогда
			Заголовки.Вставить(
				"Authorization",
				СтрШаблон("OAuth oauth_token=%1, oauth_client_id=%2",
					ДанныеАвторизации["access_token"],
					ДанныеПриложения.IDПриложения));
		КонецЕсли;
		
		ДобавитьПодписьИнтеграцииВЗаголовки(Заголовки);
		
		HTTPЗапрос = Новый HTTPЗапрос(АдресРесурса, Заголовки);
		Если ЗначениеЗаполнено(ТелоЗапроса) Тогда
			HTTPЗапрос.УстановитьТелоИзСтроки(ВJSON(ТелоЗапроса), "UTF-8");
		КонецЕсли;
		
		HTTPОтвет = HTTPСоединение.ВызватьHTTPМетод(HTTPМетод, HTTPЗапрос);
		
		Если HTTPОтвет.КодСостояния = 200 Тогда
			Если СлужебныеПараметры.ПолучениеДвоичныхДанных Тогда
				Результат = HTTPОтвет.ПолучитьТелоКакДвоичныеДанные();
			Иначе
				Если СлужебныеПараметры.ПрочитатьВСоответствие Тогда
					Результат = Новый Соответствие;
				Иначе
					Результат = Новый Структура;
				КонецЕсли;
				
				ЗаполнитьРезультатЗапросаПоОтветуСервиса(
					HTTPОтвет,
					Результат,
					СлужебныеПараметры.ПоляТипаДата,
					СлужебныеПараметры.ПрочитатьВСоответствие);
			КонецЕсли;
		Иначе
			ОжидаемыйСоставОтвета = Новый Структура;
			ОжидаемыйСоставОтвета.Вставить("errors", Новый Массив);
			
			ЗаполнитьРезультатЗапросаПоОтветуСервиса(
				HTTPОтвет,
				ОжидаемыйСоставОтвета,
				СлужебныеПараметры.ПоляТипаДата,
				СлужебныеПараметры.ПрочитатьВСоответствие);
			
			Ошибка = ОписаниеОшибкиИзСервиса(ОжидаемыйСоставОтвета["errors"], АдресСервера, АдресРесурса);
			
			ЗаписьЖурналаРегистрации(
				СобытиеЖурналаРегистрации(),
				УровеньЖурналаРегистрации.Ошибка, ,
				УчетнаяЗапись,
				Ошибка.ОписаниеОшибки);
		КонецЕсли;
	Исключение
		ТекстОшибки = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
			НСтр("ru = 'Отсутствует соединение с сервером %1 по причине: %2'",
				ОбщегоНазначения.КодОсновногоЯзыка()),
			АдресСервера,
			ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
		
		Ошибка = ИнтеграцияСМаркетплейсамиСервер.НоваяОшибка();
		Ошибка.КодОшибки = ИнтеграцияСМаркетплейсамиСервер.КодыОшибок().ОшибкаПрочие;
		Ошибка.ОписаниеОшибки = ТекстОшибки;
		
		ЗаписьЖурналаРегистрации(
			СобытиеЖурналаРегистрации(),
			УровеньЖурналаРегистрации.Ошибка,,
			УчетнаяЗапись,
			ТекстОшибки);
	КонецПопытки;
	
	ОтветСервиса = Новый Структура;
	
	ОтветСервиса.Вставить("Результат", Результат);
	ОтветСервиса.Вставить("Ошибка", Ошибка);
	
	Возврат ОтветСервиса;
	
КонецФункции

// Преобразует данные в строку JSON.
//
// Параметры:
//   Значение - Произвольный - объект записи JSON. Представляет собой значение произвольного типа.  
//                Ограничения см. в описании функции глобального контекста ЗаписатьJSON.
//
// Возвращаемое значение:
//   Строка - строка JSON.
//
Функция ВJSON(Значение)

	ЗаписьJSON = Новый ЗаписьJSON;
	ЗаписьJSON.УстановитьСтроку();
	ЗаписьJSON.ПроверятьСтруктуру = Истина;
	ЗаписатьJSON(ЗаписьJSON, Значение);
	
	Возврат ЗаписьJSON.Закрыть();

КонецФункции

// Формирует представление даты в формате Coordinated Universal Time.
//
// Параметры:
//   Дата        - Дата - дата/время, представление которой необходимо получить.
//   Миллисекунд - Число - миллисекунд во времени.
//   ЧасовойПояс - Строка, Неопределено - идентификатор часового пояса.
//
// Возвращаемое значение:
//   Строка - представление даты в формате Coordinated Universal Time (UTC).
//
Функция ДатаUTC(Знач Дата, Миллисекунд = 0, ЧасовойПояс = Неопределено)
	
	Миллисекунд = Мин(Миллисекунд, 999);
	Миллисекунд = Макс(Миллисекунд, 0);
	
	Если ЧасовойПояс = Неопределено Тогда
		ЧасовойПояс = ЧасовойПоясСеанса();
	КонецЕсли;
	
	Дата = УниверсальноеВремя(Дата, ЧасовойПояс);
	
	Результат = Формат(Дата, "ДФ=yyyy-MM-ddTЧЧ:мм:сс") + "." + Формат(Миллисекунд, "ЧН=; ЧГ=0") + "Z";
	
	Возврат Результат;
	
КонецФункции

// Параметры:
//  Ошибки - Неопределено
//         - Массив Из Структура:
//            * code - Строка
//            * message - Строка
//  АдресСервера - Строка
//  АдресРесурса - Строка
//
// Возвращаемое значение:
//  См. ИнтеграцияСМаркетплейсамиСервер.НоваяОшибка
//
Функция ОписаниеОшибкиИзСервиса(Ошибки, АдресСервера, АдресРесурса)
	
	Результат = ИнтеграцияСМаркетплейсамиСервер.НоваяОшибка();
	
	ТекстыОшибок = ТекстОшибки(Ошибки);
	
	Результат.КодОшибки = ИнтеграцияСМаркетплейсамиСервер.КодыОшибок().ОшибкаПрочие;
	Результат.ОписаниеОшибки = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
		НСтр("ru = 'Не удалось выполнить запрос %1 по причине:
		|%2.'"),
		АдресСервера + АдресРесурса,
		ТекстыОшибок);
	
	Возврат Результат;
	
КонецФункции

// Параметры:
//  HTTPОтвет - HTTPОтвет
//  Результат - Структура
//            - Соответствие Из КлючИЗначение
//  ПоляТипаДата - Массив из Строка
//  ПрочитатьВСоответствие - Булево
//
Процедура ЗаполнитьРезультатЗапросаПоОтветуСервиса(HTTPОтвет, Результат, ПоляТипаДата, ПрочитатьВСоответствие)
	
	ОтветСтрокой = HTTPОтвет.ПолучитьТелоКакСтроку();
	ДанныеОтвета = ИзJSON(ОтветСтрокой, ПоляТипаДата, ПрочитатьВСоответствие); // Структура, Соответствие Из КлючИЗначение
	
	Если ПрочитатьВСоответствие Тогда
		ОбщегоНазначенияКлиентСервер.ДополнитьСоответствие(Результат, ДанныеОтвета, Истина);
	Иначе
		ОбщегоНазначенияКлиентСервер.ДополнитьСтруктуру(Результат, ДанныеОтвета, Истина);
	КонецЕсли;
	
КонецПроцедуры

Функция ДанныеСледующейСтраницы(ОтветСервиса)
	
	Результат = Новый Структура;
	Результат.Вставить("ЕстьСледующаяСтраница", Ложь);
	Результат.Вставить("ИдентификаторСтраницы", "");
	
	ТипОтветаСервиса = ТипЗнч(ОтветСервиса);
	
	ЭтоСтруктура = (ТипОтветаСервиса = Тип("Структура"));
	ЭтоСоответствие = (ТипОтветаСервиса = Тип("Соответствие"));
	
	Если Не ЭтоСтруктура И Не ЭтоСоответствие Тогда
		Возврат Результат;
	КонецЕсли;
	
	ОписаниеСтраниц = Новый Структура;
	ОписаниеСтраниц.Вставить("paging", Неопределено);
	
	Если ЭтоСтруктура Тогда
		ЗаполнитьЗначенияСвойств(ОписаниеСтраниц, ОтветСервиса);
	
	ИначеЕсли ЭтоСоответствие Тогда
		ОписаниеСтраницИзСервиса = ОтветСервиса["paging"]; // Неопределено, Соответствие из КлючИЗначение
		Если ОписаниеСтраницИзСервиса <> Неопределено Тогда
			ОписаниеСтраниц["paging"] = ОписаниеСтраницИзСервиса;
		КонецЕсли;
	КонецЕсли;
	
	ДанныеСтраницы = ОписаниеСтраниц["paging"];
	Если ДанныеСтраницы = Неопределено Тогда
		Возврат Результат;
	КонецЕсли;
	
	ОписаниеСтраницы = Новый Структура;
	ОписаниеСтраницы.Вставить("nextPageToken", Неопределено);
	
	Если ЭтоСтруктура Тогда
		ЗаполнитьЗначенияСвойств(ОписаниеСтраницы, ДанныеСтраницы);
	
	ИначеЕсли ЭтоСоответствие Тогда
		ОписаниеСтраницыИзСервиса = ДанныеСтраницы["nextPageToken"]; // Неопределено, Соответствие из КлючИЗначение
		Если ОписаниеСтраницыИзСервиса <> Неопределено Тогда
			ОписаниеСтраницы["nextPageToken"] = ОписаниеСтраницыИзСервиса;
		КонецЕсли;
	КонецЕсли;
	
	ИдентификаторСтраницы = ОписаниеСтраницы["nextPageToken"]; // Неопределено, Строка
	Если ИдентификаторСтраницы = Неопределено Тогда
		Возврат Результат;
	КонецЕсли;
	
	Результат.ИдентификаторСтраницы = ИдентификаторСтраницы;
	Результат.ЕстьСледующаяСтраница = Не ПустаяСтрока(Результат.ИдентификаторСтраницы);
	
	Возврат Результат;
	
КонецФункции

Процедура ЗаполнитьЗначенияСвойствПриемникаРекурсивно(Приемник, Источник)
	
	Для Каждого КлючЗначение Из Приемник Цикл
		ИмяСвойства = КлючЗначение.Ключ;
		ЗначениеСвойства = КлючЗначение.Значение;
		
		ДанныеИсточника = Источник[ИмяСвойства]; // Структура, Соответствие из КлючИЗначение
		Если Не ЗначениеЗаполнено(ДанныеИсточника) Тогда
			Продолжить;
		КонецЕсли;
		
		Если ТипЗнч(ЗначениеСвойства) = Тип("Структура") Тогда
			ЗаполнитьЗначенияСвойствПриемникаРекурсивно(ЗначениеСвойства, ДанныеИсточника);
		Иначе
			Приемник[ИмяСвойства] = ДанныеИсточника;
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

Функция КоличествоСтрокДляИндексации()
	Возврат 1000;
КонецФункции

#Область КонструкторыПараметровЗапросов

// Конструктор списка параметров для импорта товарного каталога.
// 
// Возвращаемое значение:
//   Структура - список параметров:
//     * КоличествоНаСтранице    - Число - количество товаров на одной странице (limit);
//     * ИдентификаторСтраницы   - Строка - идентификатор страницы c результатами (page_token);
//     * Архивный                - Булево - фильтр по нахождению в архиве (archived);
//     * СтатусыКарточек         - Неопределено, Массив Из Строка - фильтр по статусам карточек (cardStatuses);
//     * ИдентификаторыКатегорий - Неопределено, Массив Из Число - фильтр по категориям на Маркете (categoryIds);
//     * ИдентификаторыТоваров   - Неопределено, Массив Из Строка - идентификаторы товаров, информация о которых нужна (offerIds);
//     * Теги                    - Неопределено, Массив Из Строка - фильтр по тегам (tags);
//     * Бренды                  - Неопределено, Массив Из Строка - фильтр по брендам (vendorNames).
//
Функция НовыеПараметрыЗапросаИмпортаТоварногоКаталога()
	
	Результат = Новый Структура;
	Результат.Вставить("КоличествоНаСтранице",    100);
	Результат.Вставить("ИдентификаторСтраницы",   "");
	Результат.Вставить("Архивный",                Ложь);
	Результат.Вставить("СтатусыКарточек",         Неопределено);
	Результат.Вставить("ИдентификаторыКатегорий", Неопределено);
	Результат.Вставить("ИдентификаторыТоваров",   Неопределено);
	Результат.Вставить("Теги",                    Неопределено);
	Результат.Вставить("Бренды",                  Неопределено);
	
	Возврат Результат;
	
КонецФункции

