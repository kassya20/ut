		Результат,
		"Завершена",
		"FINISHED",
		НСтр("ru = 'Завершена'"));
	ИнтеграцияСМаркетплейсамиСервер.ДобавитьЗначениеТорговойПлощадкиВКоллекцию(
		Результат,
		"Ошибка",
		"ERROR",
		НСтр("ru = 'Отменена из-за ошибки'"));
	
	Возврат Результат;
	
КонецФункции

// Конструктор параметров получения списка отгрузок.
// 
// Параметры:
//  НачалоПериода - Неопределено, Дата - начало периода.
//  ОкончаниеПериода - Неопределено, Дата - окончание периода.
// 
// Возвращаемое значение:
//  Структура:
//   * Фильтр - Структура:
//      ** НачалоПериода - Дата - начальная дата для фильтрации по дате отгрузки (включительно).
//      ** ОкончаниеПериода - Дата - конечная дата для фильтрации по дате отгрузки (включительно).
//      ** ВключатьОтмененныеЗаказы - Булево - возвращать ли отмененные заказы.
//      ** ИдентификаторыЗаказов - Массив из Строка - список идентификаторов заказов из отгрузок.
//      ** СтатусыОтгрузок - Массив из см. ИнтеграцияСМаркетплейсамиСервер.НовоеЗначениеТорговойПлощадки
//                           См. ВозможныеСтатусыОтгрузки().
//   * МаксимальноеКоличествоВЗапросе - Число - количество значений на одной странице. Максимальное значение - 30.
//   * ИдентификаторСтраницы - Строка - идентификатор последней полученной страницы.
//
Функция НовыеПараметрыПолученияСпискаОтгрузок(НачалоПериода = Неопределено, ОкончаниеПериода = Неопределено) Экспорт
	
	Фильтр = Новый Структура;
	Фильтр.Вставить("НачалоПериода", Дата(1, 1, 1));
	Фильтр.Вставить("ОкончаниеПериода", Дата(1, 1, 1));
	
	Если НачалоПериода <> Неопределено Тогда
		Фильтр.НачалоПериода = НачалоПериода;
	КонецЕсли;
	Если ОкончаниеПериода <> Неопределено Тогда
		Фильтр.ОкончаниеПериода = ОкончаниеПериода;
	КонецЕсли;
	
	Фильтр.Вставить("ВключатьОтмененныеЗаказы", Истина);
	Фильтр.Вставить("ИдентификаторыЗаказов", Новый Массив);
	Фильтр.Вставить("СтатусыОтгрузок", Новый Массив);
	
	Результат = Новый Структура;
	Результат.Вставить("Фильтр", Фильтр);
	Результат.Вставить("МаксимальноеКоличествоВЗапросе", 30);
	Результат.Вставить("ИдентификаторСтраницы", "");
	
	Возврат Результат;
	
КонецФункции

// Получает информацию о нескольких отгрузках.
// 
// Параметры:
//  УчетнаяЗапись - СправочникСсылка.УчетныеЗаписиМаркетплейсов
//  Параметры - см. НовыеПараметрыПолученияСпискаОтгрузок
//
// Возвращаемое значение:
//  Структура:
//   * Ошибка - см. ИнтеграцияСМаркетплейсамиСервер.НоваяОшибка
//   * ТаблицаОтгрузок - см. НоваяТаблицаОтгрузок
//
Функция СписокОтгрузок(УчетнаяЗапись, Параметры) Экспорт
	
	Результат = Новый Структура;
	Результат.Вставить("Ошибка", ИнтеграцияСМаркетплейсамиСервер.НоваяОшибка());
	Результат.Вставить("ТаблицаОтгрузок", НоваяТаблицаОтгрузок());
	
	ЕстьСледующаяСтраница = Истина;
	ИдентификаторСтраницы = "";
	
	Пока ЕстьСледующаяСтраница Цикл
		Параметры.ИдентификаторСтраницы = ИдентификаторСтраницы;
		ОтветСервиса = СписокОтгрузокИзСервиса(УчетнаяЗапись, Параметры);
		
		Если ОтветСервиса.Ошибка <> Неопределено Тогда
			ЕстьСледующаяСтраница = Ложь;
			ОшибкаЗапроса = ОтветСервиса.Ошибка; // см. ИнтеграцияСМаркетплейсамиСервер.НоваяОшибка
			ИнтеграцияСМаркетплейсамиСервер.ДополнитьОшибку(Результат.Ошибка, ОшибкаЗапроса);
			
		ИначеЕсли ОтветСервиса.Результат.Количество() = 0 Тогда
			ЕстьСледующаяСтраница = Ложь;
			
		Иначе
			ВозможныеСпособыОтгрузкиЗаказов =
				ИнтеграцияСМаркетплейсамиСервер.ДанныеДляПоискаСопоставленныхЗначенийТорговойПлощадки(
					ВозможныеСпособыОтгрузкиЗаказов());
			ВозможныеСтатусыОтгрузки =
				ИнтеграцияСМаркетплейсамиСервер.ДанныеДляПоискаСопоставленныхЗначенийТорговойПлощадки(
					ВозможныеСтатусыОтгрузки());
			ДоступныеДействияНадОтгрузкой =
				ИнтеграцияСМаркетплейсамиСервер.ДанныеДляПоискаСопоставленныхЗначенийТорговойПлощадки(
					ДоступныеДействияНадОтгрузкой());
			
			Для Каждого ЭлементОтветаСервиса Из ОтветСервиса.Результат Цикл
				ЕстьЗаказыВОтгрузке = Ложь;
				ЗаказыВОтгрузке = ЭлементОтветаСервиса["orderIds"];
				Если ТипЗнч(ЗаказыВОтгрузке) = Тип("Массив") И ЗаказыВОтгрузке.Количество()>0 Тогда    
					ЕстьЗаказыВОтгрузке = Истина;
				КонецЕсли;
				Если ЕстьЗаказыВОтгрузке Тогда
					Строка = Результат.ТаблицаОтгрузок.Добавить();
					ЗаполнитьИнформациюОбОтгрузкеПоОтветуСервиса(
					Строка,
					ЭлементОтветаСервиса,
					ВозможныеСпособыОтгрузкиЗаказов,
					ВозможныеСтатусыОтгрузки,
					ДоступныеДействияНадОтгрузкой);     
				КонецЕсли;
			КонецЦикла;
			
			ЕстьСледующаяСтраница = ОтветСервиса.ЕстьСледующаяСтраница;
			ИдентификаторСтраницы = ОтветСервиса.ИдентификаторСтраницы;
		КонецЕсли;
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

// Возвращает информацию об отгрузке на торговой площадке.
// 
// Параметры:
//   УчетнаяЗапись               - СправочникСсылка.УчетныеЗаписиМаркетплейсов - учетная запись подключения к сервису.
//   ИдентификаторОтгрузки       - Строка - идентификатор отгрузки. 
//   ДатаОтгрузки                - Дата - срок отгрузки.
//   ЗаполнитьДанныеПоПеревозке  - Булево - признак заполнения общих данных по перевозке в отгрузке.
//
// Возвращаемое значение:
//   см. РегистрыСведений.ЗаказыТорговыхПлощадок.НовыйСписокАтрибутовИнформацииОбОтгрузке.
//
Функция ИнформацияОбОтгрузке(УчетнаяЗапись, ИдентификаторОтгрузки = "", ДатаОтгрузки = Неопределено) Экспорт  
	
	Ошибка = ИнтеграцияСМаркетплейсамиСервер.НоваяОшибка(); 
	
	ИнформацияОбОтгрузке =
		РегистрыСведений.ЗаказыТорговыхПлощадок.НовыйСписокАтрибутовИнформацииОбОтгрузке(УчетнаяЗапись); 
	ИнформацияОбОтгрузке.УчетнаяЗапись = УчетнаяЗапись;
	ИнформацияОбОтгрузке.ВидМаркетплейса = Перечисления.ВидыМаркетплейсов.МаркетплейсЯндексМаркет;
	
	ДанныеСклада = СкладУчетнойЗаписиДляВыгрузкиОстатков(УчетнаяЗапись);
	ИнформацияОбОтгрузке.ИдентификаторСклада = ДанныеСклада.ИдентификаторСклада;
	
	Если ЗначениеЗаполнено(ИдентификаторОтгрузки) Тогда    
		
		РезультатИзСервиса = ИнформацияОбОтгрузкеПоИдентификатору(УчетнаяЗапись, ИдентификаторОтгрузки, Истина);
		
		Если НЕ ЗначениеЗаполнено(РезультатИзСервиса.Ошибка.ОписаниеОшибки) Тогда
			ДанныеОтгрузки = РезультатИзСервиса.ИнформацияОбОтгрузке; 
			ЗаполнитьРезультатПоДаннымОтгрузки(ИнформацияОбОтгрузке, ДанныеОтгрузки);
		Иначе
			ЗаполнитьЗначенияСвойств(Ошибка, РезультатИзСервиса.Ошибка); 
			ИнформацияОбОтгрузке.Ошибка = Ошибка;
		КонецЕсли;

	ИначеЕсли ЗначениеЗаполнено(ДатаОтгрузки) Тогда
		
		ПараметрыЗапроса = НовыеПараметрыПолученияСпискаОтгрузок(НачалоДня(ДатаОтгрузки), КонецДня(ДатаОтгрузки));
		РезультатИзСервиса = СписокОтгрузок(УчетнаяЗапись, ПараметрыЗапроса);
		
		Если Не ЗначениеЗаполнено(РезультатИзСервиса.Ошибка.ОписаниеОшибки) Тогда
			ТаблицаОтгрузок = РезультатИзСервиса.ТаблицаОтгрузок;
			
			Если ТаблицаОтгрузок.Количество() > 0 Тогда
				СтрокаТаблицы = ТаблицаОтгрузок.Получить(0);
				ЗаполнитьРезультатПоДаннымОтгрузки(ИнформацияОбОтгрузке, СтрокаТаблицы);
			КонецЕсли;
		Иначе
			ЗаполнитьЗначенияСвойств(Ошибка, РезультатИзСервиса.Ошибка);  
			ИнформацияОбОтгрузке.Ошибка = Ошибка;
		КонецЕсли;
	КонецЕсли;  
	
	Если Не ЗначениеЗаполнено(Ошибка.ОписаниеОшибки) И ИнформацияОбОтгрузке.ИдентификаторыЗаказов.Количество() > 0 Тогда
		ИдентификаторыЗаказов = ИнформацияОбОтгрузке.ИдентификаторыЗаказов; 
		РезультатИзСервиса = ПолучитьОтправленияПоИдентификаторамЗаказов(
			УчетнаяЗапись,
			ИдентификаторыЗаказов,
			ИнформацияОбОтгрузке.СрокОтгрузки);
		 
		Если НЕ ЗначениеЗаполнено(РезультатИзСервиса.Ошибка.ОписаниеОшибки) Тогда
			ОтправленияВОтгрузке = РезультатИзСервиса.НомераОтправлений;
			ВсеОтправленияЗаказов = ИнтеграцияСЯндексМаркетВызовСервера.ВсеОтправленияЗаказов(ОтправленияВОтгрузке);
			
			ОбщегоНазначенияКлиентСервер.ДополнитьМассив(ОтправленияВОтгрузке, ВсеОтправленияЗаказов, Истина);
			
			ИнформацияОбОтгрузке.ОтправленияВОтгрузке = ОтправленияВОтгрузке;
		Иначе
			ЗаполнитьЗначенияСвойств(Ошибка, РезультатИзСервиса.Ошибка);  
			ИнформацияОбОтгрузке.Ошибка = Ошибка;
		КонецЕсли;
	КонецЕсли;  
	
	Возврат ИнформацияОбОтгрузке;										
	
КонецФункции

// Получает информацию о конкретной отгрузке.
// 
// Параметры:
//  УчетнаяЗапись - СправочникСсылка.УчетныеЗаписиМаркетплейсов
//  ИдентификаторОтгрузки - Строка
//  ВключатьОтмененныеЗаказы - Булево
// 
// Возвращаемое значение:
//  Структура:
//   * Ошибка - см. ИнтеграцияСМаркетплейсамиСервер.НоваяОшибка
//   * ИнформацияОбОтгрузке - Структура - свойства структуры аналогичны колонкам таблицы из см. НоваяТаблицаОтгрузок.
//
//@skip-check function-return-types
Функция ИнформацияОбОтгрузкеПоИдентификатору(УчетнаяЗапись, ИдентификаторОтгрузки, ВключатьОтмененныеЗаказы = Ложь) Экспорт
	
	Результат = Новый Структура;
	Результат.Вставить("Ошибка", ИнтеграцияСМаркетплейсамиСервер.НоваяОшибка());
	Результат.Вставить("ИнформацияОбОтгрузке", Новый Структура);
	
	ОтветСервиса = ИнформацияОбОтгрузкеИзСервиса(
		УчетнаяЗапись,
		ИдентификаторОтгрузки,
		ВключатьОтмененныеЗаказы);
	
	Если ОтветСервиса.Ошибка = Неопределено Тогда
		
		ТаблицаОтгрузок = НоваяТаблицаОтгрузок();
		Строка = ТаблицаОтгрузок.Добавить();
		
		ВозможныеСпособыОтгрузкиЗаказов =
			ИнтеграцияСМаркетплейсамиСервер.ДанныеДляПоискаСопоставленныхЗначенийТорговойПлощадки(
				ВозможныеСпособыОтгрузкиЗаказов());
		ВозможныеСтатусыОтгрузки =
			ИнтеграцияСМаркетплейсамиСервер.ДанныеДляПоискаСопоставленныхЗначенийТорговойПлощадки(
				ВозможныеСтатусыОтгрузки());
		ДоступныеДействияНадОтгрузкой = 
			ИнтеграцияСМаркетплейсамиСервер.ДанныеДляПоискаСопоставленныхЗначенийТорговойПлощадки(
				ДоступныеДействияНадОтгрузкой());
		
		ЗаполнитьИнформациюОбОтгрузкеПоОтветуСервиса(
			Строка,
			ОтветСервиса.Результат["result"],
			ВозможныеСпособыОтгрузкиЗаказов,
			ВозможныеСтатусыОтгрузки,
			ДоступныеДействияНадОтгрузкой);
		
		Результат.ИнформацияОбОтгрузке = ОбщегоНазначения.СтрокаТаблицыЗначенийВСтруктуру(Строка);
		
	Иначе
		Результат.Ошибка = ОтветСервиса.Ошибка;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Переносит переданные заказы в следующую отгрузку.
// 
// Параметры:
//  УчетнаяЗапись - СправочникСсылка.УчетныеЗаписиМаркетплейсов
//  ИдентификаторОтгрузки - Строка
//  ИдентификаторыЗаказов - Массив из Строка
// 
// Возвращаемое значение:
//  - Неопределено - при выполнении запроса к внешнему ресурсу ошибок не возникло.
//  - см. ИнтеграцияСМаркетплейсамиСервер.НоваяОшибка
//
Функция ПеренестиЗаказыВСледующуюОтгрузку(УчетнаяЗапись, ИдентификаторОтгрузки, ИдентификаторыЗаказов) Экспорт
	
	Если ИдентификаторыЗаказов.Количество() = 0 Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Результат = ПеренестиЗаказыВСледующуюОтгрузкуВСервисе(УчетнаяЗапись, ИдентификаторОтгрузки, ИдентификаторыЗаказов);
	Возврат Результат;
	
КонецФункции

// Передает Маркету количество упаковок в отгрузке для доверительной приемки (см. https://yandex.ru/dev/market/partner-api/doc/ru/reference/shipments/setShipmentPalletsCount).
// Реализуется работа с методом PUT https://api.partner.market.yandex.ru/v2/campaigns/{campaignId}/first-mile/shipments/{shipmentId}/pallets.
//
// Параметры: 
//   УчетнаяЗапись       - СправочникСсылка.УчетныеЗаписиМаркетплейсов - учетная запись подключения к сервису.
//   ИдентификаторОтгрузки - Строка - идентификатор отгрузки.
//	 КоличествоУпаковок - Число - количество упаковок в отгрузке.
//
// Возвращаемое значение:
//  - Неопределено - при выполнении запроса к внешнему ресурсу ошибок не возникло.
//  - см. ИнтеграцияСМаркетплейсамиСервер.НоваяОшибка
//
Функция ПередатьКоличествоУпаковок(УчетнаяЗапись, ИдентификаторОтгрузки, КоличествоУпаковок, Отказ = Ложь) Экспорт
	
	Ошибка = ИнтеграцияСМаркетплейсамиСервер.НоваяОшибка();
	
	Если Не ЗначениеЗаполнено(УчетнаяЗапись) Тогда
		ТекстОшибки = НСтр("ru = 'Ошибка при передаче количества упаковок в отгрузке Яндекс Маркет: не указана учетная запись торговой площадки.'",
		ОбщегоНазначения.КодОсновногоЯзыка());
		
		ЗаписьЖурналаРегистрации(СобытиеЖурналаРегистрации(), 
		УровеньЖурналаРегистрации.Ошибка,,, 
		ТекстОшибки);      
		Ошибка.ОписаниеОшибки = ТекстОшибки; 
		
		Возврат Ошибка;		
	КонецЕсли;
	
	Если Не Справочники.УчетныеЗаписиМаркетплейсов.ОбновленияДанныхТорговойПлощадкиРазрешено(УчетнаяЗапись) Тогда
		ТекстОшибки = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
		НСтр("ru = 'Ошибка при передаче количества упаковок в отгрузке Яндекс Маркет: для учетной записи <%1> запрещено обновление данных торговой площадки'",
		ОбщегоНазначения.КодОсновногоЯзыка()),
		УчетнаяЗапись);
		
		ЗаписьЖурналаРегистрации(СобытиеЖурналаРегистрации(), 
		УровеньЖурналаРегистрации.Ошибка,,, 
		ТекстОшибки); 
    	Ошибка.ОписаниеОшибки = ТекстОшибки; 
		
		Возврат Ошибка;
	КонецЕсли;   
		
	ТекстЗапроса = СтрШаблон("/v2/campaigns/{campaignId}/first-mile/shipments/%1/pallets", ИдентификаторОтгрузки);
	
	ТелоЗапроса = Новый Структура;
	ТелоЗапроса.Вставить("placesCount", КоличествоУпаковок);
	
	ОтветСервиса = ВыполнитьЗапросВСервис(
		УчетнаяЗапись,
		ТекстЗапроса,
		Новый Структура,
		ТелоЗапроса,
		"PUT");
	
	Возврат ОтветСервиса.Ошибка;
		
КонецФункции

// Получает ярлыки грузомест (палет), используемых в процессе доверительной приемки.
// Описание метода см. https://yandex.ru/dev/market/partner-api/doc/ru/reference/shipments/downloadShipmentPalletLabels.
//
// Параметры: 
//  УчетнаяЗапись - СправочникСсылка.УчетныеЗаписиМаркетплейсов - учетная запись подключения к сервису.
//  ИдентификаторОтгрузки - Строка - идентификатор отгрузки.
//  Формат - Строка - формат страниц PDF-файла с ярлыками (возможные значения: A4, A8).
//  Адрес - Неопределено, Строка, УникальныйИдентификатор - адрес временного хранилища, по которому будет помещен файл.
//
// Возвращаемое значение:
//  См. НовыйРезультатПолученияПроизвольногоФайла
//
Функция ПолучитьЭтикеткиГрузомест(УчетнаяЗапись, ИдентификаторОтгрузки, Формат = "A8", Адрес = Неопределено) Экспорт
	
	Результат = НовыйРезультатПолученияПроизвольногоФайла();
	
	ТекстЗапроса = СтрШаблон("/v2/campaigns/{campaignId}/first-mile/shipments/%1/pallet/labels", ИдентификаторОтгрузки);
	
	ПараметрыЗапроса = Новый Структура;
	ПараметрыЗапроса.Вставить("format", Формат);
	
	ОтветСервиса = ПроизвольныйФайлИзСервиса(УчетнаяЗапись, ТекстЗапроса, ПараметрыЗапроса);
	
	ТекстОшибки = НСтр(
		"ru = 'При получении ярлыков для доверительной приемки из сервиса возникла непредвиденная ошибка.'");
	ОбработатьПолучениеПроизвольногоФайла(Результат, ОтветСервиса, Адрес, УчетнаяЗапись, ТекстОшибки);
	
	Возврат Результат;
	
КонецФункции

// Подтверждает отгрузку товаров в сортировочный центр или пункт приема заказов (см. https://yandex.ru/dev/market/partner-api/doc/ru/reference/shipments/confirmShipment).
// Реализуется работа с методом POST https://api.partner.market.yandex.ru/v2/campaigns/{campaignId}/first-mile/shipments/{shipmentId}/confirm.    
//
// Параметры: 
//   УчетнаяЗапись - СправочникСсылка.УчетныеЗаписиМаркетплейсов - учетная запись подключения к сервису.
//   ИдентификаторОтгрузки - Строка - идентификатор отгрузки.
//    
// Возвращаемое значение:
//  - Неопределено - при выполнении запроса к внешнему ресурсу ошибок не возникло.
//  - см. ИнтеграцияСМаркетплейсамиСервер.НоваяОшибка   
//
Функция ПодтвердитьОтгрузку(УчетнаяЗапись, ИдентификаторОтгрузки) Экспорт    
	
	Ошибка = ИнтеграцияСМаркетплейсамиСервер.НоваяОшибка();
	
	Если Не ЗначениеЗаполнено(УчетнаяЗапись) Тогда
		ТекстОшибки = НСтр("ru = 'Ошибка при подтверждении отгрузки Яндекс Маркет: не указана учетная запись торговой площадки.'",
		ОбщегоНазначения.КодОсновногоЯзыка());
		
		ЗаписьЖурналаРегистрации(СобытиеЖурналаРегистрации(), 
		УровеньЖурналаРегистрации.Ошибка,,, 
		ТекстОшибки);   
		Ошибка.ОписаниеОшибки = ТекстОшибки; 
		
		Возврат Ошибка;
	КонецЕсли;    
	
	Если Не ЗначениеЗаполнено(ИдентификаторОтгрузки) Тогда
        ТекстОшибки = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
		НСтр("ru = 'Ошибка при подтверждении отгрузки Яндекс Маркет для учетной записи <%1>: не заполнен идентификатор отгрузки'",
		ОбщегоНазначения.КодОсновногоЯзыка()),
		УчетнаяЗапись);
	
		ЗаписьЖурналаРегистрации(СобытиеЖурналаРегистрации(), 
		УровеньЖурналаРегистрации.Ошибка,,, 
		ТекстОшибки);  
		Ошибка.ОписаниеОшибки = ТекстОшибки; 
		
		Возврат Ошибка;
	КонецЕсли;
	
	ТекстЗапроса = СтрШаблон("/v2/campaigns/{campaignId}/first-mile/shipments/%1/confirm", ИдентификаторОтгрузки);
	
	ТелоЗапроса = Новый Структура;   
	ДанныеУчетнойЗаписи = ДанныеУчетнойЗаписиЯндексМаркет(УчетнаяЗапись, Ложь);
	Если  ДанныеУчетнойЗаписи.ЛогинДляПодписи <> "" Тогда  
		ТелоЗапроса.Вставить("signatory", ДанныеУчетнойЗаписи.ЛогинДляПодписи); 
	КонецЕсли;
	
	ОтветСервиса = ВыполнитьЗапросВСервис(
		УчетнаяЗапись,
		ТекстЗапроса,
		Новый Структура,
		ТелоЗапроса,
		"POST");
	
	Если  ОтветСервиса.Ошибка<>Неопределено И ЗначениеЗаполнено(ОтветСервиса.Ошибка.ОписаниеОшибки) Тогда  
		Если СтрНайти(ОтветСервиса.Ошибка.ОписаниеОшибки,"Reasons: orders are in wrong status")>0 Тогда   
			ОтветСервиса.Ошибка.ОписаниеОшибки = СтрЗаменить(ОтветСервиса.Ошибка.ОписаниеОшибки, НСтр("ru = 'по причине:'"), НСтр("ru = 'по причине: отгрузку невозможно подтвердить, некоторые заказы отгрузки в некорректном статусе.'"));
		КонецЕсли;
	КонецЕсли;	
	
	Возврат ОтветСервиса.Ошибка;
	
КонецФункции

