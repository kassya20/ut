// Получает информацию об одной отгрузке по ее идентификатору из сервиса.
// Описание метода см. https://yandex.ru/dev/market/partner-api/doc/ru/reference/shipments/searchShipments.
// 
// Параметры:
//  УчетнаяЗапись - СправочникСсылка.УчетныеЗаписиМаркетплейсов
//  Параметры - см. НовыеПараметрыПолученияСпискаОтгрузок
// 
// Возвращаемое значение:
//  Структура:
//   * Ошибка - Неопределено - при выполнении запроса к внешнему ресурсу ошибок не возникло.
//            - см. ИнтеграцияСМаркетплейсамиСервер.НоваяОшибка
//   * ЕстьСледующаяСтраница - Булево - признак наличия данных в следующей порции.
//   * ИдентификаторСтраницы - Строка - идентификатор последней страницы (page_token).
//   * Результат - Массив из Структура:
//      ** id - Число - идентификатор отгрузки.
//      ** planIntervalFrom - Дата - начало планового интервала отгрузки.
//      ** planIntervalTo - Дата - конец планового интервала отгрузки.
//      ** shipmentType - Строка - способ отгрузки заказов, см. ВозможныеСпособыОтгрузкиЗаказов.
//      ** warehouse - Структура - данные о складе отправления:
//          *** id - Число - идентификатор склада отправления.
//          *** name - Строка - наименование склада отправления.
//          *** address - Строка - адрес склада отправления.
//      ** warehouseTo - Структура - данные о складе назначения:
//          *** id - Число - идентификатор склада назначения.
//          *** name - Строка - наименование склада назначения.
//          *** address - Строка - адрес склада назначения.
//      ** deliveryService - Структура - служба доставки:
//          *** id - Число - идентификатор службы доставки.
//          *** name - Строка - название службы доставки.
//      ** palletsCount - Структура - данные о палетах в отгрузке:
//          *** planned - Число - количество палет, которое заявил продавец.
//          *** fact - Число - количество палет, которое приняли в сортировочном центре.
//      ** orderIds - Массив из Число - идентификаторы заказов в отгрузке.
//      ** draftCount - Число - количество заказов, которое Маркет запланировал к отгрузке.
//      ** plannedCount - Число - количество заказов, которое Маркет подтвердил к отгрузке.
//      ** factCount - Число - количество заказов, принятых в сортировочном центре или пункте приема.
//      ** signature - Структура - информация о подписи акта приема-передачи:
//          *** signed - Булево - подписан ли акт приема-передачи.
//      ** status - Строка - статус отгрузки, см. ВозможныеСтатусыОтгрузки.
//      ** statusDescription - Строка - описание статуса отгрузки.
//      ** statusUpdateTime - Дата - время последнего изменения статуса отгрузки.
//
Функция СписокОтгрузокИзСервиса(УчетнаяЗапись, Параметры)
	
	ТекстЗапроса = "/v2/campaigns/{campaignId}/first-mile/shipments";
	
	ПараметрыЗапроса = Новый Структура;
	ПараметрыЗапроса.Вставить("limit", Параметры.МаксимальноеКоличествоВЗапросе);
	ПараметрыЗапроса.Вставить("page_token", Параметры.ИдентификаторСтраницы);
	
	ТелоЗапроса = Новый Структура;
	ТелоЗапроса.Вставить("dateFrom", Формат(Параметры.Фильтр.НачалоПериода, "ДФ=dd-MM-yyyy"));
	ТелоЗапроса.Вставить("dateTo", Формат(Параметры.Фильтр.ОкончаниеПериода, "ДФ=dd-MM-yyyy"));
	ТелоЗапроса.Вставить("cancelledOrders", Параметры.Фильтр.ВключатьОтмененныеЗаказы);
	
	ИдентификаторыЗаказов = Новый Массив; // Массив из Число
	Для Каждого ИдентификаторЗаказа Из Параметры.Фильтр.ИдентификаторыЗаказов Цикл
		ИдентификаторыЗаказов.Добавить(Число(ИдентификаторЗаказа));
	КонецЦикла;
	
	Если ИдентификаторыЗаказов.Количество() > 0 Тогда
		ТелоЗапроса.Вставить("orderIds", ИдентификаторыЗаказов);
	КонецЕсли;
	
	СтатусыОтгрузок = Новый Массив; // Массив из Строка
	Для Каждого СтатусОтгрузки Из Параметры.Фильтр.СтатусыОтгрузок Цикл
		СтатусыОтгрузок.Добавить(СтатусОтгрузки.Значение);
	КонецЦикла;
	
	Если СтатусыОтгрузок.Количество() > 0 Тогда
		ТелоЗапроса.Вставить("statuses", СтатусыОтгрузок);
	КонецЕсли;
	
	СлужебныеПараметры = НовыеСлужебныеПараметрыHTTPЗапроса();
	СлужебныеПараметры.ПрочитатьВСоответствие = Истина;
	
	СлужебныеПараметры.ПоляТипаДата.Добавить("planIntervalFrom");
	СлужебныеПараметры.ПоляТипаДата.Добавить("planIntervalTo");
	СлужебныеПараметры.ПоляТипаДата.Добавить("statusUpdateTime");
	
	ОтветСервиса = ВыполнитьЗапросВСервис(
		УчетнаяЗапись,
		ТекстЗапроса,
		ПараметрыЗапроса,
		ТелоЗапроса,
		"PUT",
		СлужебныеПараметры);
	
	РезультатЗапроса = Новый Структура;
	
	РезультатЗапроса.Вставить("Результат", Новый Массив);
	РезультатЗапроса.Вставить("ЕстьСледующаяСтраница", Ложь);
	РезультатЗапроса.Вставить("ИдентификаторСтраницы", "");
	РезультатЗапроса.Вставить("Ошибка", Неопределено);
	
	Если ОтветСервиса.Ошибка = Неопределено Тогда
		//@skip-check statement-type-change 
		РезультатЗапроса.Результат = ОтветСервиса.Результат["result"]["shipments"]; 
		
		ДанныеСтраницы = ДанныеСледующейСтраницы(ОтветСервиса.Результат);
		РезультатЗапроса.ЕстьСледующаяСтраница = ДанныеСтраницы.ЕстьСледующаяСтраница;
		РезультатЗапроса.ИдентификаторСтраницы = ДанныеСтраницы.ИдентификаторСтраницы;
	Иначе
		РезультатЗапроса.Ошибка = ОтветСервиса.Ошибка;
	КонецЕсли;
	
	Возврат РезультатЗапроса;
	
КонецФункции

// Получает информацию об одной отгрузке по ее идентификатору из сервиса.
// Описание метода см. https://yandex.ru/dev/market/partner-api/doc/ru/reference/shipments/getShipment.
// 
// Параметры:
//  УчетнаяЗапись - СправочникСсылка.УчетныеЗаписиМаркетплейсов
//  ИдентификаторОтгрузки - Строка
//  ВключатьОтмененныеЗаказы - Булево
// 
// Возвращаемое значение:
//  Структура:
//   * Ошибка - Неопределено - при выполнении запроса к внешнему ресурсу ошибок не возникло.
//            - см. ИнтеграцияСМаркетплейсамиСервер.НоваяОшибка
//   * Результат - Неопределено - при выполнении запроса к внешнему ресурсу возникла ошибка.
//               - Структура:
//      ** id - Число - идентификатор отгрузки.
//      ** planIntervalFrom - Дата - начало планового интервала отгрузки.
//      ** planIntervalTo - Дата - конец планового интервала отгрузки.
//      ** shipmentType - Строка - способ отгрузки заказов, см. ВозможныеСпособыОтгрузкиЗаказов.
//      ** warehouse - Структура - данные о складе отправления:
//          *** id - Число - идентификатор склада отправления.
//          *** name - Строка - наименование склада отправления.
//          *** address - Строка - адрес склада отправления.
//      ** warehouseTo - Структура - данные о складе назначения:
//          *** id - Число - идентификатор склада назначения.
//          *** name - Строка - наименование склада назначения.
//          *** address - Строка - адрес склада назначения.
//      ** deliveryService - Структура - служба доставки:
//          *** id - Число - идентификатор службы доставки.
//          *** name - Строка - название службы доставки.
//      ** palletsCount - Структура - данные о палетах в отгрузке:
//          *** planned - Число - количество палет, которое заявил продавец.
//          *** fact - Число - количество палет, которое приняли в сортировочном центре.
//      ** orderIds - Массив из Число - идентификаторы заказов в отгрузке.
//      ** draftCount - Число - количество заказов, которое Маркет запланировал к отгрузке.
//      ** plannedCount - Число - количество заказов, которое Маркет подтвердил к отгрузке.
//      ** factCount - Число - количество заказов, принятых в сортировочном центре или пункте приема.
//      ** signature - Структура - информация о подписи акта приема-передачи:
//          *** signed - Булево - подписан ли акт приема-передачи.
//      ** currentStatus - Структура - статус отгрузки:
//          *** status - Строка - статус отгрузки, см. ВозможныеСтатусыОтгрузки.
//          *** description - Строка - описание статуса отгрузки.
//          *** updateTime - Дата - время последнего изменения статуса отгрузки.
//      ** availableActions - Массив из Строка - доступные действия над отгрузкой, см. ДоступныеДействияНадОтгрузкой.
//
Функция ИнформацияОбОтгрузкеИзСервиса(УчетнаяЗапись, ИдентификаторОтгрузки, ВключатьОтмененныеЗаказы)
	
	ТекстЗапроса = СтрШаблон("/v2/campaigns/{campaignId}/first-mile/shipments/%1", ИдентификаторОтгрузки);
	
	ПараметрыЗапроса = Новый Структура;
	ПараметрыЗапроса.Вставить("cancelledOrders", ВключатьОтмененныеЗаказы);
	
	СлужебныеПараметры = НовыеСлужебныеПараметрыHTTPЗапроса();
	СлужебныеПараметры.ПрочитатьВСоответствие = Истина;
	
	СлужебныеПараметры.ПоляТипаДата.Добавить("planIntervalFrom");
	СлужебныеПараметры.ПоляТипаДата.Добавить("planIntervalTo");
	СлужебныеПараметры.ПоляТипаДата.Добавить("updateTime");
	
	ОтветСервиса = ВыполнитьЗапросВСервис(
		УчетнаяЗапись,
		ТекстЗапроса,
		ПараметрыЗапроса,
		Новый Структура,
		"GET",
		СлужебныеПараметры);
	
	РезультатЗапроса = Новый Структура;
	
	РезультатЗапроса.Вставить("Результат", Неопределено);
	РезультатЗапроса.Вставить("Ошибка", Неопределено);
	
	Если ОтветСервиса.Ошибка = Неопределено Тогда
		РезультатЗапроса.Результат = ОтветСервиса.Результат;
	Иначе
		РезультатЗапроса.Ошибка = ОтветСервиса.Ошибка;
	КонецЕсли;
	
	Возврат РезультатЗапроса;
	
КонецФункции

// Переносит переданные заказы в следующую отгрузку.
// Описание метода см. https://yandex.ru/dev/market/partner-api/doc/ru/reference/shipments/transferOrdersFromShipment.
// 
// Параметры:
//  УчетнаяЗапись - СправочникСсылка.УчетныеЗаписиМаркетплейсов
//  ИдентификаторОтгрузки - Строка
//  ИдентификаторыЗаказов - Массив из Строка
// 
// Возвращаемое значение:
//  - Неопределено - при выполнении запроса к внешнему ресурсу ошибок не возникло.
//  - см. ИнтеграцияСМаркетплейсамиСервер.НоваяОшибка
//
Функция ПеренестиЗаказыВСледующуюОтгрузкуВСервисе(УчетнаяЗапись, ИдентификаторОтгрузки, ИдентификаторыЗаказов)
	
	ТекстЗапроса = СтрШаблон(
		"/v2/campaigns/{campaignId}/first-mile/shipments/%1/orders/transfer", ИдентификаторОтгрузки);
	
	ТелоЗапроса = Новый Структура;
	ТелоЗапроса.Вставить("orderIds", ИдентификаторыЗаказов);
	
	ОтветСервиса = ВыполнитьЗапросВСервис(
		УчетнаяЗапись,
		ТекстЗапроса,
		Новый Структура,
		ТелоЗапроса,
		"POST");

	Если ОтветСервиса.Ошибка<>Неопределено И ЗначениеЗаполнено(ОтветСервиса.Ошибка.ОписаниеОшибки) Тогда  
		Если СтрНайти(ОтветСервиса.Ошибка.ОписаниеОшибки,"already have processed requests for exclusion from shipment")>0 Тогда   
			ОтветСервиса.Ошибка.ОписаниеОшибки = СтрЗаменить(ОтветСервиса.Ошибка.ОписаниеОшибки, НСтр("ru = 'по причине:'"), НСтр("ru = 'по причине: выбранные заказы уже переносились в следующую отгрузку, перенос возможен однократно.'"));
		КонецЕсли;
	КонецЕсли;
	
	Возврат ОтветСервиса.Ошибка;
	
КонецФункции

