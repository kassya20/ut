		Данные.Инициатор = "customer";
		Данные.Доступность = Истина; 
		Детализация.Добавить(Данные);  
	КонецЕсли;
	
	Если ИдентификаторПричиныОтмены  = Неопределено 
		Или ИдентификаторПричиныОтмены = "USER_NOT_PAID" Тогда
