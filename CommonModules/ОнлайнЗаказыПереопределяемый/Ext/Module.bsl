	//++ Локализация
	ОнлайнЗаказыУТ.ПриОпределенииПараметровСозданияЗаказа(ДокументЗаказа, Результат);
	//-- Локализация
	
КонецПроцедуры

// Определяет состав печатных форм доступных для использования в качестве вложений в онлайн-заказ.
