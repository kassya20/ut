// @strict-types

#Область СлужебныйПрограммныйИнтерфейс

// Параметры:
//  РеквизитыДоверителя - см. ИнтеграцияЭДО.НовыеКлючевыеРеквизитыУчастникаЭДО
// 
// Возвращаемое значение:
//  Булево
Функция ЕстьУчетныеЗаписиЦентровЭДОПоДоверителю(РеквизитыДоверителя) Экспорт
	
	УчетныеЗаписиЦентровЭДО = РегистрыСведений.НастройкиИнтеграцииЦентраЭДО.УчетныеЗаписиЦентровЭДОПоРеквизитамОрганизации(
		РеквизитыДоверителя);
	
	Возврат ЗначениеЗаполнено(УчетныеЗаписиЦентровЭДО);
	
КонецФункции

// Параметры:
//  Доверенности - Массив из ОпределяемыйТип.МашиночитаемаяДоверенность
// 
// Возвращаемое значение:
//  Структура:
//  * ДоверенностиЛокальногоЭДО - Массив из ОпределяемыйТип.МашиночитаемаяДоверенность
//  * ДоверенностиЦентраЭДО - Массив из ОпределяемыйТип.МашиночитаемаяДоверенность
Функция ДоверенностиПоМестамОбработки(Доверенности) Экспорт
	
	ИдентификаторыПоСсылкам = 
		РегистрыСведений.ИдентификаторыСинхронизируемыхОбъектовЦентраЭДО.ИдентификаторыПоСсылкам(Доверенности);
	
	ДоверенностиЦентраЭДО = ОбщегоНазначения.ВыгрузитьКолонку(ИдентификаторыПоСсылкам, "Ключ");
	ДоверенностиЛокальногоЭДО = ОбщегоНазначенияКлиентСервер.РазностьМассивов(Доверенности, ДоверенностиЦентраЭДО);
	
	Результат = Новый Структура("ДоверенностиЛокальногоЭДО, ДоверенностиЦентраЭДО",
		ДоверенностиЛокальногоЭДО, ДоверенностиЦентраЭДО);
	
	Возврат Результат;
	
КонецФункции

// Параметры:
//  Доверенность - СправочникСсылка.МЧД003
//  ДанныеФайлаМЧД - ДвоичныеДанные
// 
// Возвращаемое значение:
//  Структура:
//  * Успех - Булево
//  * ЭтоНовыйОбъектСинхронизации - Булево
//  * ПараметрыСинхронизации - Неопределено
//                           - см. ИнтеграцияЦентраЭДО.НовыеПараметрыСинхронизацииОбъекта
//  * КонтекстДиагностики - см. ОбработкаНеисправностейБЭД.НовыйКонтекстДиагностики
Функция ЗаписатьЧерновикВЦентрЭДО(Доверенность, ДанныеФайлаМЧД) Экспорт
	
	КонтекстДиагностики = ОбработкаНеисправностейБЭД.НовыйКонтекстДиагностики();
	КонтекстДиагностики.ЗаголовокОперации =
		МашиночитаемыеДоверенностиИнтеграцияЦентраЭДОКлиентСервер.ВидОперацииЗаписьЧерновикаВЦентрЭДО();
	
	ИдентификаторДоверенности = "";
	УчетнаяЗаписьЦентраЭДО = Справочники.УчетныеЗаписиЦентровЭДО.ПустаяСсылка();
	ЭтоНовыйОбъектСинхронизации = Истина;
	
	Если ЗначениеЗаполнено(Доверенность) Тогда
		ПараметрыСинхронизацииОбъекта = ИнтеграцияЦентраЭДО.ПараметрыСинхронизацииОбъекта(Доверенность);
		Если ЗначениеЗаполнено(ПараметрыСинхронизацииОбъекта) Тогда
			ЭтоНовыйОбъектСинхронизации = Ложь;
			ИдентификаторДоверенности = ПараметрыСинхронизацииОбъекта.Идентификатор;
			УчетнаяЗаписьЦентраЭДО = ПараметрыСинхронизацииОбъекта.УчетнаяЗаписьЦентраЭДО;
		КонецЕсли;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(УчетнаяЗаписьЦентраЭДО) Тогда
		УчетнаяЗаписьЦентраЭДО = УчетнаяЗаписьЦентраЭДОПоДаннымФайлаМЧД(ДанныеФайлаМЧД);
	КонецЕсли;
	
	Результат = Новый Структура;
	Результат.Вставить("Успех", Ложь);
	Результат.Вставить("ЭтоНовыйОбъектСинхронизации", ЭтоНовыйОбъектСинхронизации);
	Результат.Вставить("ПараметрыСинхронизации", Неопределено);
	Результат.Вставить("КонтекстДиагностики", КонтекстДиагностики);
	
	Если Не ЗначениеЗаполнено(УчетнаяЗаписьЦентраЭДО) Тогда
		ВидОперации = НСтр("ru = 'Запись доверенности'");
		ТекстОшибки = НСтр("ru = 'Отсутствует подходящая учетная запись центра ЭДО'");
		ИнтеграцияЦентраЭДО.ДобавитьНеизвестнуюОшибку(КонтекстДиагностики, ВидОперации, ТекстОшибки);
		Возврат Результат;
	КонецЕсли;
	
	ДанныеФайлаМЧДВФорматеСервиса = Base64Строка(ДанныеФайлаМЧД);
	
	ПараметрыВыполнения = ИнтеграцияЦентраЭДО.ПараметрыВыполненияМетодаСервисаДляТекущегоПользователя(
		УчетнаяЗаписьЦентраЭДО, КонтекстДиагностики);
	Если ПараметрыВыполнения = Неопределено Тогда
		Возврат Результат;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ИдентификаторДоверенности) Тогда
		ОписаниеМетода = ИнтеграцияЦентраЭДО.ОписаниеМетодаСервиса(
			"ОбновитьЧерновикДоверенности", ИдентификаторДоверенности, ДанныеФайлаМЧДВФорматеСервиса);
	Иначе
		ОписаниеМетода = ИнтеграцияЦентраЭДО.ОписаниеМетодаСервиса(
			"СоздатьЧерновикДоверенности", ДанныеФайлаМЧДВФорматеСервиса);
	КонецЕсли;
	
	РезультатМетода = ИнтеграцияЦентраЭДО.ВыполнитьМетодСервиса(
		ПараметрыВыполнения, ОписаниеМетода, КонтекстДиагностики);
	
	Если Не ЗначениеЗаполнено(РезультатМетода) Тогда
		Возврат Результат;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ИдентификаторДоверенности) Тогда
		Результат.Успех = ОбработатьРезультатМетодаОбновитьЧерновикДоверенности(
			РезультатМетода, КонтекстДиагностики, УчетнаяЗаписьЦентраЭДО);
	Иначе
		ИдентификаторДоверенности = ОбработатьРезультатМетодаСоздатьЧерновикДоверенности(
			РезультатМетода, КонтекстДиагностики, УчетнаяЗаписьЦентраЭДО);
		Результат.Успех = ЗначениеЗаполнено(ИдентификаторДоверенности);
	КонецЕсли;
	
	ПараметрыСинхронизации = ИнтеграцияЦентраЭДО.НовыеПараметрыСинхронизацииОбъекта();
	ПараметрыСинхронизации.Идентификатор = ИдентификаторДоверенности;
	ПараметрыСинхронизации.УчетнаяЗаписьЦентраЭДО = УчетнаяЗаписьЦентраЭДО;
	Результат.ПараметрыСинхронизации = ПараметрыСинхронизации;
	
	Возврат Результат;
	
КонецФункции

// Параметры:
//  Доверенности - Массив из СправочникСсылка.МашиночитаемыеДоверенностиОрганизаций,СправочникСсылка.МЧД003
//  ОтпечаткиСертификатов - см. КриптографияБЭДКлиентСервер.НовыеРезультатыПолученияОтпечатков
//  ЗаявлениеНаОтмену - Булево
//  КонтекстДиагностики - см. ОбработкаНеисправностейБЭДКлиент.НовыйКонтекстДиагностики
// 
// Возвращаемое значение:
//  Массив из см. МашиночитаемыеДоверенности.НовоеОписаниеНабораДанныхДляИнтерактивногоПодписанияМЧД
Функция ДанныеДляПодписания(Доверенности, ОтпечаткиСертификатов, ЗаявлениеНаОтмену, КонтекстДиагностики) Экспорт
	
	ДанныеДляПодписания = Новый Массив; // См. ДанныеДляПодписания
	
	Для Каждого Доверенность Из Доверенности Цикл
		
		ДанныеДляПодписанияПоДоверенности = ДанныеДляПодписанияПоДоверенности(
			Доверенность, ОтпечаткиСертификатов, ЗаявлениеНаОтмену, КонтекстДиагностики);
		Если ЗначениеЗаполнено(ДанныеДляПодписанияПоДоверенности) Тогда
			ДанныеДляПодписания.Добавить(ДанныеДляПодписанияПоДоверенности);
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат ДанныеДляПодписания;
	
КонецФункции

// Параметры:
//  Доверенность - СправочникСсылка.МЧД003
//  СвойстваПодписи - см. ЭлектроннаяПодписьКлиентСервер.НовыеСвойстваПодписи
//  ЗарегистрироватьВРеестреФНС - Булево
//
// Возвращаемое значение:
//  - Неопределено
//  - См. МашиночитаемыеДоверенности.НовыйРезультатПодписанияРегистрацииМЧД
Функция ПодписатьЗарегистрироватьМЧД(Доверенность, СвойстваПодписи, ЗарегистрироватьВРеестреФНС) Экспорт
	
	ПараметрыСинхронизации = ИнтеграцияЦентраЭДОПовтИсп.ПараметрыСинхронизацииОбъекта(Доверенность);
	Если ПараметрыСинхронизации = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Результат = МашиночитаемыеДоверенности.НовыйРезультатПодписанияРегистрацииМЧД();
	
	КонтекстДиагностики = Результат.КонтекстДиагностики;
	УчетнаяЗаписьЦентраЭДО = ПараметрыСинхронизации.УчетнаяЗаписьЦентраЭДО;
	
	ПараметрыВыполнения = ИнтеграцияЦентраЭДО.ПараметрыВыполненияМетодаСервисаДляТекущегоПользователя(
		УчетнаяЗаписьЦентраЭДО, КонтекстДиагностики);
	Если ПараметрыВыполнения = Неопределено Тогда
		Возврат Результат;
	КонецЕсли;
	
	ДанныеПодписиВФорматеСервиса = Base64Строка(СвойстваПодписи.Подпись);
	
	ПакетМетодов = ИнтеграцияЦентраЭДО.НовыйПакетМетодовСервиса();
	
	ОписаниеМетода = ИнтеграцияЦентраЭДО.ОписаниеМетодаСервиса(
		"ДобавитьПодписьДоверенности",
		ПараметрыСинхронизации.Идентификатор, ДанныеПодписиВФорматеСервиса);
	ИнтеграцияЦентраЭДО.ДобавитьОписаниеМетодаВПакет(ПакетМетодов, ОписаниеМетода);
	
	Если ЗарегистрироватьВРеестреФНС Тогда
		ОписаниеМетода = ИнтеграцияЦентраЭДО.ОписаниеМетодаСервиса(
			"ЗарегистрироватьДоверенностьВРеестреФНС",
			ПараметрыСинхронизации.Идентификатор);
		ИнтеграцияЦентраЭДО.ДобавитьОписаниеМетодаВПакет(ПакетМетодов, ОписаниеМетода);
	КонецЕсли;
	
	РезультатыПакета = ИнтеграцияЦентраЭДО.ВыполнитьПакетМетодовСервиса(ПараметрыВыполнения, ПакетМетодов,
		КонтекстДиагностики);
	
	Если Не ЗначениеЗаполнено(РезультатыПакета) Тогда
		Возврат Результат;
	КонецЕсли;
	
	РезультатДобавленияПодписи = РезультатДобавленияПодписиИзФорматаСервиса(РезультатыПакета[0],
		КонтекстДиагностики, УчетнаяЗаписьЦентраЭДО);
	
	РезультатРегистрации = РезультатРегистрацииВРеестреФНСИзФорматаСервиса(РезультатыПакета[1]);
	
	Если Не ЗначениеЗаполнено(РезультатДобавленияПодписи) И Не ЗначениеЗаполнено(РезультатРегистрации) Тогда
		Возврат Результат;
	КонецЕсли;
	
	ДоверенностьОбъект = Доверенность.ПолучитьОбъект();
	
	Если ЗначениеЗаполнено(РезультатДобавленияПодписи) Тогда
		ДоверенностьОбъект.Подписана = РезультатДобавленияПодписи.Подписана;
		ДоверенностьОбъект.Верна = РезультатДобавленияПодписи.Верна;
		ДоверенностьОбъект.ТекстОшибкиПроверкиМЧД = РезультатДобавленияПодписи.ТекстОшибкиПроверкиМЧД;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(РезультатРегистрации) Тогда
		Результат.Статус = РезультатРегистрации.Статус;
		Результат.ИдентификаторТранзакции = РезультатРегистрации.ИдентификаторТранзакции;
		Результат.ОписаниеОшибкиРегистрации = РезультатРегистрации.ОписаниеОшибкиРегистрации;
		
		ДоверенностьОбъект.ИдентификаторТранзакции = РезультатРегистрации.ИдентификаторТранзакции;
		ДоверенностьОбъект.СтатусВРеестреФНС = РезультатРегистрации.Статус;
		ДоверенностьОбъект.ОписаниеОшибкиРегистрации = РезультатРегистрации.ОписаниеОшибкиРегистрации;
		Если ЗначениеЗаполнено(РезультатРегистрации.Статус) Тогда
			ДоверенностьОбъект.ДатаОбновленияСтатуса = ТекущаяДатаСеанса();
		КонецЕсли;
	КонецЕсли;
	
	ДоверенностьОбъект.Записать();
	
	МашиночитаемыеДоверенности.ОбновитьОчередьЗапросовВРеестрФНСПослеРегистрацииМЧД(Доверенность, РезультатРегистрации);
	
	Возврат Результат;
	
КонецФункции

// Параметры:
//  Доверенность - СправочникСсылка.МЧД003
// 
// Возвращаемое значение:
//  - Неопределено
//  - См. МашиночитаемыеДоверенности.НовыйРезультатРегистрацииВРеестреФНС
Функция ЗарегистрироватьВРеестреФНС(Доверенность) Экспорт
	
	ПараметрыСинхронизации = ИнтеграцияЦентраЭДОПовтИсп.ПараметрыСинхронизацииОбъекта(Доверенность);
	Если ПараметрыСинхронизации = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Результат = МашиночитаемыеДоверенности.НовыйРезультатРегистрацииВРеестреФНС();
	
	КонтекстДиагностики = Результат.КонтекстДиагностики;
	УчетнаяЗаписьЦентраЭДО = ПараметрыСинхронизации.УчетнаяЗаписьЦентраЭДО;
	
	ПараметрыВыполнения = ИнтеграцияЦентраЭДО.ПараметрыВыполненияМетодаСервисаДляТекущегоПользователя(
		УчетнаяЗаписьЦентраЭДО, КонтекстДиагностики);
	Если ПараметрыВыполнения = Неопределено Тогда
		Возврат Результат;
	КонецЕсли;
	
	ОписаниеМетода = ИнтеграцияЦентраЭДО.ОписаниеМетодаСервиса(
		"ЗарегистрироватьДоверенностьВРеестреФНС",
		ПараметрыСинхронизации.Идентификатор);
	
	РезультатМетода = ИнтеграцияЦентраЭДО.ВыполнитьМетодСервиса(
		ПараметрыВыполнения, ОписаниеМетода, КонтекстДиагностики); // См. ПрограммныйИнтерфейсЦентраЭДОВерсия3.ЗарегистрироватьДоверенностьВРеестреФНС
	
	Если Не ЗначениеЗаполнено(РезультатМетода) Тогда
		Возврат Результат;
	КонецЕсли;
	
	РезультатРегистрации = РезультатРегистрацииВРеестреФНСИзФорматаСервиса(РезультатМетода);
	ЗаполнитьЗначенияСвойств(Результат, РезультатРегистрации);
	
	ДоверенностьОбъект = Доверенность.ПолучитьОбъект();
	ДоверенностьОбъект.ИдентификаторТранзакции = РезультатРегистрации.ИдентификаторТранзакции;
	ДоверенностьОбъект.СтатусВРеестреФНС = РезультатРегистрации.Статус;
	ДоверенностьОбъект.ОписаниеОшибкиРегистрации = РезультатРегистрации.ОписаниеОшибкиРегистрации;
	Если ЗначениеЗаполнено(РезультатРегистрации.Статус) Тогда
		ДоверенностьОбъект.ДатаОбновленияСтатуса = ТекущаяДатаСеанса();
	КонецЕсли;
	
	ДоверенностьОбъект.Записать();
	
	МашиночитаемыеДоверенности.ОбновитьОчередьЗапросовВРеестрФНСПослеРегистрацииМЧД(Доверенность, РезультатРегистрации);
	
	Возврат Результат;
	
КонецФункции

// Параметры:
//  Доверенность - СправочникСсылка.МЧД003
//  СвойстваПодписи - см. ЭлектроннаяПодписьКлиентСервер.НовыеСвойстваПодписи
//
// Возвращаемое значение:
//  - Неопределено
//  - См. МашиночитаемыеДоверенности.НовыйРезультатПодписанияОтменыМЧД
Функция ПодписатьОтменитьМЧД(Доверенность, СвойстваПодписи) Экспорт
	
	ПараметрыСинхронизации = ИнтеграцияЦентраЭДОПовтИсп.ПараметрыСинхронизацииОбъекта(Доверенность);
	Если ПараметрыСинхронизации = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Результат = МашиночитаемыеДоверенности.НовыйРезультатПодписанияОтменыМЧД();
	
	КонтекстДиагностики = Результат.КонтекстДиагностики;
	УчетнаяЗаписьЦентраЭДО = ПараметрыСинхронизации.УчетнаяЗаписьЦентраЭДО;
	ИдентификаторДоверенности = ПараметрыСинхронизации.Идентификатор;
	
	ПараметрыВыполнения = ИнтеграцияЦентраЭДО.ПараметрыВыполненияМетодаСервисаДляТекущегоПользователя(
		УчетнаяЗаписьЦентраЭДО, КонтекстДиагностики);
	Если ПараметрыВыполнения = Неопределено Тогда
		Возврат Результат;
	КонецЕсли;
	
	ДанныеПодписиВФорматеСервиса = Base64Строка(СвойстваПодписи.Подпись);
	
	ПакетМетодов = ИнтеграцияЦентраЭДО.НовыйПакетМетодовСервиса();
	
	ОписаниеМетода = ИнтеграцияЦентраЭДО.ОписаниеМетодаСервиса(
		"ДобавитьПодписьЗаявленияНаОтменуДоверенности",
		ИдентификаторДоверенности, ДанныеПодписиВФорматеСервиса);
	ИнтеграцияЦентраЭДО.ДобавитьОписаниеМетодаВПакет(ПакетМетодов, ОписаниеМетода);
	
	ОписаниеМетода = ИнтеграцияЦентраЭДО.ОписаниеМетодаСервиса(
		"ОтправитьЗаявлениеНаОтменуДоверенности",
		ИдентификаторДоверенности);
	ИнтеграцияЦентраЭДО.ДобавитьОписаниеМетодаВПакет(ПакетМетодов, ОписаниеМетода);
	
	ОписаниеМетода = ИнтеграцияЦентраЭДО.ОписаниеМетодаСервиса(
		"ПолучитьДанныеДоверенности",
		ИдентификаторДоверенности);
	ИнтеграцияЦентраЭДО.ДобавитьОписаниеМетодаВПакет(ПакетМетодов, ОписаниеМетода);
	
	РезультатыПакета = ИнтеграцияЦентраЭДО.ВыполнитьПакетМетодовСервиса(ПараметрыВыполнения, ПакетМетодов,
		КонтекстДиагностики);
	
	Если Не ЗначениеЗаполнено(РезультатыПакета) Тогда
		Возврат Результат;
	КонецЕсли;
	
	РезультатДобавленияПодписи = РезультатыПакета[0]; // См. ПрограммныйИнтерфейсЦентраЭДОВерсия3.ДобавитьПодписьЗаявленияНаОтменуДоверенности
	Если ЗначениеЗаполнено(РезультатДобавленияПодписи) Тогда
		ВидОперации = МашиночитаемыеДоверенностиКлиентСервер.ВидОперацииПодписатьОтменитьМЧД();
		ОбработатьОшибкиВФорматеСервиса(ВидОперации, РезультатДобавленияПодписи.Ошибки, КонтекстДиагностики,
			УчетнаяЗаписьЦентраЭДО);
	КонецЕсли;
	
	РезультатОтправки = РезультатыПакета[1]; // См. ПрограммныйИнтерфейсЦентраЭДОВерсия3.ОтправитьЗаявлениеНаОтменуДоверенности
	Если ЗначениеЗаполнено(РезультатОтправки) Тогда
		Результат.ИдентификаторТранзакции = РезультатОтправки.ИдентификаторТранзакции;
		РезультатОтмены = Новый Структура("ИдентификаторТранзакции, ОписаниеОшибкиРегистрации",
			РезультатОтправки.ИдентификаторТранзакции, "");
		Если ЗначениеЗаполнено(РезультатОтправки.Ошибки) Тогда
			ОписанияОшибок = ОбщегоНазначения.ВыгрузитьКолонку(РезультатОтправки.Ошибки, "Кратко"); //@skip-check invocation-parameter-type-intersect
			РезультатОтмены.ОписаниеОшибкиРегистрации = СтрСоединить(ОписанияОшибок, Символы.ПС);
		КонецЕсли;
	КонецЕсли;
	
	ДанныеДоверенности = РезультатыПакета[2]; // См. ПрограммныйИнтерфейсЦентраЭДОВерсия3.ПолучитьДанныеДоверенности
	Если ЗначениеЗаполнено(ДанныеДоверенности) Тогда
		ЗагрузитьПоДаннымСервиса(ДанныеДоверенности, ИдентификаторДоверенности, УчетнаяЗаписьЦентраЭДО,
			КонтекстДиагностики);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Параметры:
//  Доверенность - ОпределяемыйТип.МашиночитаемаяДоверенность
// 
// Возвращаемое значение:
//  - Неопределено
//  - См. МашиночитаемыеДоверенности.НовыйРезультатОбновленияСтатусаМЧДИзРеестраФНС
Функция ОбновитьСтатусМЧДИзРеестраФНС(Доверенность) Экспорт
	
	ПараметрыСинхронизации = ИнтеграцияЦентраЭДОПовтИсп.ПараметрыСинхронизацииОбъекта(Доверенность);
	Если ПараметрыСинхронизации = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Результат = МашиночитаемыеДоверенности.НовыйРезультатОбновленияСтатусаМЧДИзРеестраФНС();
	
	КонтекстДиагностики = ОбработкаНеисправностейБЭД.НовыйКонтекстДиагностики();
	
	ПараметрыВыполнения = ИнтеграцияЦентраЭДО.ПараметрыВыполненияМетодаСервисаДляТекущегоПользователя(
		ПараметрыСинхронизации.УчетнаяЗаписьЦентраЭДО, КонтекстДиагностики);
	Если ПараметрыВыполнения = Неопределено Тогда
		Результат.ТекстОшибки = ОбработкаНеисправностейБЭД.ТекстОшибокКонтекстаДиагностики(КонтекстДиагностики);
		Возврат Результат;
	КонецЕсли;
	
	ОписаниеМетода = ИнтеграцияЦентраЭДО.ОписаниеМетодаСервиса(
		"ОбновитьСтатусДоверенности",
		ПараметрыСинхронизации.Идентификатор);
	
	РезультатМетода = ИнтеграцияЦентраЭДО.ВыполнитьМетодСервиса(
		ПараметрыВыполнения, ОписаниеМетода, КонтекстДиагностики); // См. ПрограммныйИнтерфейсЦентраЭДОВерсия3.ОбновитьСтатусДоверенности
	
	Если Не ЗначениеЗаполнено(РезультатМетода) Тогда
		Результат.ТекстОшибки = ОбработкаНеисправностейБЭД.ТекстОшибокКонтекстаДиагностики(КонтекстДиагностики);
		Возврат Результат;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(РезультатМетода.Ошибка) Тогда
		Результат.ТекстОшибки = РезультатМетода.Ошибка;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(РезультатМетода.Статус) Тогда
		СтатусВРеестреФНС = МашиночитаемыеДоверенности.НовыйСтатусВРеестреФНС();
		СтатусВРеестреФНС.СтатусВРеестреФНС = СтатусВРеестреФНСИзФорматаСервиса(РезультатМетода.Статус);
		СтатусВРеестреФНС.ДатаПолученияСтатуса = ОбщегоНазначенияБЭД.ДатаИзФорматаISO(РезультатМетода.ДатаОбновления);
		СтатусВРеестреФНС.ДатаОтзыва = ОбщегоНазначенияБЭД.ДатаИзФорматаISO(РезультатМетода.ДатаОтзыва);
		Результат.СтатусВРеестреФНС = СтатусВРеестреФНС;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Параметры:
//  Доверенность - ОпределяемыйТип.МашиночитаемаяДоверенность
//  Значение - Булево
// 
// Возвращаемое значение:
//  - Неопределено
//  - См. МашиночитаемыеДоверенности.НовыйРезультатУстановкиПометкиВерна
Функция УстановитьПометкуВерна(Доверенность, Значение) Экспорт
	
	ПараметрыСинхронизации = ИнтеграцияЦентраЭДОПовтИсп.ПараметрыСинхронизацииОбъекта(Доверенность);
	Если ПараметрыСинхронизации = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Результат = МашиночитаемыеДоверенности.НовыйРезультатУстановкиПометкиВерна();
	
	КонтекстДиагностики = Результат.КонтекстДиагностики;
	УчетнаяЗаписьЦентраЭДО = ПараметрыСинхронизации.УчетнаяЗаписьЦентраЭДО;
	
	ПараметрыВыполнения = ИнтеграцияЦентраЭДО.ПараметрыВыполненияМетодаСервисаДляТекущегоПользователя(
		УчетнаяЗаписьЦентраЭДО, КонтекстДиагностики);
	Если ПараметрыВыполнения = Неопределено Тогда
		Возврат Результат;
	КонецЕсли;
	
	ОписаниеМетода = ИнтеграцияЦентраЭДО.ОписаниеМетодаСервиса(
		"УстановитьПометкуДоверенностьВерна",
		ПараметрыСинхронизации.Идентификатор, Значение);
	
	РезультатМетода = ИнтеграцияЦентраЭДО.ВыполнитьМетодСервиса(ПараметрыВыполнения, ОписаниеМетода, КонтекстДиагностики); // См. ПрограммныйИнтерфейсЦентраЭДОВерсия3.УстановитьПометкуДоверенностьВерна
	Если Не ЗначениеЗаполнено(РезультатМетода) Тогда
		Возврат Результат;
	КонецЕсли;
	
	Результат.Успех = РезультатМетода.Успех;
	
	Если Результат.Успех Тогда
		РезультатВКлиентеЭДО = МашиночитаемыеДоверенности.УстановитьПометкуВерна(Доверенность, Значение);
		Результат.Успех = Результат.Успех И РезультатВКлиентеЭДО.Успех;
	КонецЕсли;
	
	ВидОперации = МашиночитаемыеДоверенностиКлиентСервер.ВидОперацииУстановкаПометкиВерна();
	ОбработатьОшибкиВФорматеСервиса(ВидОперации, РезультатМетода.Ошибки, КонтекстДиагностики, УчетнаяЗаписьЦентраЭДО);
	
	Возврат Результат;
	
КонецФункции

// Параметры:
//  Доверенность - ОпределяемыйТип.МашиночитаемаяДоверенность
//  Значение - Булево
//  ДатаОтзыва - Дата
// 
// Возвращаемое значение:
//  - Неопределено
//  - См. МашиночитаемыеДоверенности.НовыйРезультатУстановкиПометкиВерна
Функция УстановитьПометкуОтозвана(Доверенность, Значение, ДатаОтзыва) Экспорт
	
	ПараметрыСинхронизации = ИнтеграцияЦентраЭДОПовтИсп.ПараметрыСинхронизацииОбъекта(Доверенность);
	Если ПараметрыСинхронизации = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Результат = МашиночитаемыеДоверенности.НовыйРезультатУстановкиПометкиВерна();
	
	КонтекстДиагностики = Результат.КонтекстДиагностики;
	УчетнаяЗаписьЦентраЭДО = ПараметрыСинхронизации.УчетнаяЗаписьЦентраЭДО;
	
	ПараметрыВыполнения = ИнтеграцияЦентраЭДО.ПараметрыВыполненияМетодаСервисаДляТекущегоПользователя(
		УчетнаяЗаписьЦентраЭДО, КонтекстДиагностики);
	Если ПараметрыВыполнения = Неопределено Тогда
		Возврат Результат;
	КонецЕсли;
	
	ОписаниеМетода = ИнтеграцияЦентраЭДО.ОписаниеМетодаСервиса(
		"УстановитьПометкуДоверенностьОтозвана",
		ПараметрыСинхронизации.Идентификатор, Значение, ОбщегоНазначенияБЭД.ДатаВФорматеISO(ДатаОтзыва));
	
	РезультатМетода = ИнтеграцияЦентраЭДО.ВыполнитьМетодСервиса(ПараметрыВыполнения, ОписаниеМетода, КонтекстДиагностики); // См. ПрограммныйИнтерфейсЦентраЭДОВерсия3.УстановитьПометкуДоверенностьОтозвана
	Если Не ЗначениеЗаполнено(РезультатМетода) Тогда
		Возврат Результат;
	КонецЕсли;
	
	Результат.Успех = РезультатМетода.Успех;
	
	ВидОперации = МашиночитаемыеДоверенностиКлиентСервер.ВидОперацииУстановкаПометкиВерна();
	ОбработатьОшибкиВФорматеСервиса(ВидОперации, РезультатМетода.Ошибки, КонтекстДиагностики, УчетнаяЗаписьЦентраЭДО);
	
	Возврат Результат;
	
КонецФункции

// Параметры:
//  УчетнаяЗаписьЦентраЭДО - СправочникСсылка.УчетныеЗаписиЦентровЭДО
//  ИдентификаторДоверенности - Строка
//  
// Возвращаемое значение:
//  Неопределено,СправочникСсылка.МашиночитаемыеДоверенностиОрганизаций,СправочникСсылка.МЧД003
Функция ДоверенностьПоДаннымСервиса(УчетнаяЗаписьЦентраЭДО, ИдентификаторДоверенности) Экспорт
	
	ИдентификаторыДоверенностей = ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(ИдентификаторДоверенности);
	Возврат ДоверенностиПоДаннымСервиса(УчетнаяЗаписьЦентраЭДО, ИдентификаторыДоверенностей)[ИдентификаторДоверенности];
	
КонецФункции

// Параметры:
//  УчетнаяЗаписьЦентраЭДО - СправочникСсылка.УчетныеЗаписиЦентровЭДО
//  ИдентификаторыДоверенностей - Массив из Строка
// 
// Возвращаемое значение:
//  Соответствие из КлючИЗначение:
//  * Ключ - Строка
//  * Значение - ОпределяемыйТип.МашиночитаемаяДоверенность
Функция ДоверенностиПоДаннымСервиса(УчетнаяЗаписьЦентраЭДО, ИдентификаторыДоверенностей) Экспорт
	
	СсылкиПоИдентификаторамДоверенностей = ИнтеграцияЦентраЭДО.СсылкиПоИдентификаторамСинхронизации(
		УчетнаяЗаписьЦентраЭДО, ИдентификаторыДоверенностей);
	
	ПараметрыВыполнения = ИнтеграцияЦентраЭДО.ПараметрыВыполненияМетодаСервиса(УчетнаяЗаписьЦентраЭДО);
	Если ПараметрыВыполнения = Неопределено Тогда
		Возврат СсылкиПоИдентификаторамДоверенностей;
	КонецЕсли;
	
	ПакетМетодов = ИнтеграцияЦентраЭДО.НовыйПакетМетодовСервиса();
	
	ИдентификаторыДляЗагрузки = Новый Массив; // Массив из Строка
	
	Для Каждого СсылкаПоИдентификаторуДоверенности Из СсылкиПоИдентификаторамДоверенностей Цикл
		
		Если СсылкаПоИдентификаторуДоверенности.Значение <> Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		ИдентификаторДоверенности = СсылкаПоИдентификаторуДоверенности.Ключ;
		ИдентификаторыДляЗагрузки.Добавить(ИдентификаторДоверенности);
		
		ОписаниеМетода = ИнтеграцияЦентраЭДО.ОписаниеМетодаСервиса(
			"ПолучитьДанныеДоверенности", ИдентификаторДоверенности);
		ИнтеграцияЦентраЭДО.ДобавитьОписаниеМетодаВПакет(ПакетМетодов, ОписаниеМетода);
		
	КонецЦикла;
	
	Если Не ЗначениеЗаполнено(ПакетМетодов) Тогда
		Возврат СсылкиПоИдентификаторамДоверенностей;
	КонецЕсли;
	
	РезультатПакетаМетодов = ИнтеграцияЦентраЭДО.ВыполнитьПакетМетодовСервиса(ПараметрыВыполнения, ПакетМетодов);
	
	Если Не ЗначениеЗаполнено(РезультатПакетаМетодов) Тогда
		Возврат СсылкиПоИдентификаторамДоверенностей;
	КонецЕсли;
	
	Для Каждого РезультатМетодаПакета Из РезультатПакетаМетодов Цикл
		
		ИндексМетода = РезультатМетодаПакета.Ключ; // Число
		РезультатМетода = РезультатМетодаПакета.Значение; // См. ПрограммныйИнтерфейсЦентраЭДОВерсия3.ПолучитьДанныеДоверенности
		ИдентификаторДоверенности = ИдентификаторыДляЗагрузки[ИндексМетода];
		
		Доверенность = ЗагрузитьПоДаннымСервиса(РезультатМетода, ИдентификаторДоверенности, УчетнаяЗаписьЦентраЭДО);
		
		Если ЗначениеЗаполнено(Доверенность) Тогда
			СсылкиПоИдентификаторамДоверенностей.Вставить(ИдентификаторДоверенности, Доверенность);
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат СсылкиПоИдентификаторамДоверенностей;
	
КонецФункции

// Параметры:
//  Доверенность - ОпределяемыйТип.МашиночитаемаяДоверенность
//  КонтекстДиагностики - См. ОбработкаНеисправностейБЭД.НовыйКонтекстДиагностики
// 
// Возвращаемое значение:
//  Неопределено,Структура:
//   * Данные - Неопределено, Строка - двоичные данные в формате base64
//   * Статус - см. СтатусДоверенности
Функция ДанныеДоверенностиВФорматеСервиса(Доверенность, КонтекстДиагностики = Неопределено) Экспорт
	
	РезультатВыгрузки = МашиночитаемыеДоверенности.ВыгрузитьДанныеДоверенности(Доверенность);
	
	Если РезультатВыгрузки.Ошибка Тогда
		Если КонтекстДиагностики = Неопределено Тогда
			ВызватьИсключение РезультатВыгрузки.ТекстОшибки;
		КонецЕсли;
		ВидОперации = НСтр("ru = 'Выгрузка данных доверенности в центр ЭДО'");
		ИнтеграцияЦентраЭДО.ДобавитьНеизвестнуюОшибку(КонтекстДиагностики, ВидОперации,
			РезультатВыгрузки.ТекстОшибки);
		Возврат Неопределено;
	КонецЕсли;
	
	СтатусДоверенности = СтатусДоверенности(Доверенность);
	
	ДанныеВФорматеСервиса = Новый Структура("Данные, Статус",
		Base64Строка(РезультатВыгрузки.ОписаниеФайла.ДвоичныеДанные), СтатусДоверенности);
	
	Возврат ДанныеВФорматеСервиса;
	
КонецФункции

// Параметры:
//  УчетныеЗаписиЦентровЭДО - Массив из СправочникСсылка.УчетныеЗаписиЦентровЭДО
//  Доверенности - Массив из ОпределяемыйТип.МашиночитаемаяДоверенность
// 
// Возвращаемое значение:
//  См. МашиночитаемыеДоверенностиИнтеграцияЦентраЭДОКлиентСервер.НовыйРезультатВыгрузкиВЦентрЭДО
Функция ВыгрузитьВЦентрЭДО(УчетныеЗаписиЦентровЭДО, Доверенности) Экспорт
	
	КонтекстДиагностики = ОбработкаНеисправностейБЭД.НовыйКонтекстДиагностики();
	КонтекстДиагностики.ЗаголовокОперации =
		МашиночитаемыеДоверенностиИнтеграцияЦентраЭДОКлиентСервер.ВидОперацииВыгрузкаВЦентрЭДО();
	
	Результат = МашиночитаемыеДоверенностиИнтеграцияЦентраЭДОКлиентСервер.НовыйРезультатВыгрузкиВЦентрЭДО(
		КонтекстДиагностики);
	
	Для Каждого УчетнаяЗаписьЦентраЭДО Из УчетныеЗаписиЦентровЭДО Цикл
		
		ПараметрыВыполненияМетода = ИнтеграцияЦентраЭДО.ПараметрыВыполненияМетодаСервисаДляТекущегоПользователя(
			УчетнаяЗаписьЦентраЭДО, КонтекстДиагностики);
		Если ПараметрыВыполненияМетода = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		ПакетМетодов = ПакетМетодовДляВыгрузкиДоверенностей(Доверенности, КонтекстДиагностики);
		
		РезультатыМетодов = ИнтеграцияЦентраЭДО.ВыполнитьПакетМетодовСервиса(
			ПараметрыВыполненияМетода, ПакетМетодов, КонтекстДиагностики);
		
		Если Не ЗначениеЗаполнено(РезультатыМетодов) Тогда
			Продолжить;
		КонецЕсли;
		
		ВыгрузкаПоДоверенностямУчетнойЗаписи = ОбработатьРезультатыМетодовВыгрузкиДоверенностей(
			КонтекстДиагностики, РезультатыМетодов, Доверенности, УчетнаяЗаписьЦентраЭДО);
		
		Если ЗначениеЗаполнено(Результат.ВыгрузкаПоДоверенностям) Тогда
			ОбщегоНазначенияКлиентСервер.ДополнитьСоответствие(Результат.ВыгрузкаПоДоверенностям,
				ВыгрузкаПоДоверенностямУчетнойЗаписи, Истина);
		Иначе
			Результат.ВыгрузкаПоДоверенностям = ВыгрузкаПоДоверенностямУчетнойЗаписи;
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

// Параметры:
//  ПакетМетодов - См. ИнтеграцияЦентраЭДО.НовыйПакетМетодовСервиса
//  ПараметрыОперации - См. ЭлектронныеДокументыЭДОИнтеграцияЦентраЭДО.НовыеПараметрыОперацииПоДействиямЭДО
Процедура ДобавитьОписаниеМетодаПорцияСтатусовДоверенностейПоМеткамВремени(ПакетМетодов, ПараметрыОперации) Экспорт
	
	ТипДанных = Перечисления.ТипыСинхронизацииСЦентромЭДО.СтатусыДоверенностей;
	МеткиВремениПоИдентификаторамЭДО = ПараметрыОперации.ОбъектыОперации.МеткиВремениТиповСинхронизации[ТипДанных];
	Если Не ЗначениеЗаполнено(МеткиВремениПоИдентификаторамЭДО) Тогда
		Возврат;
	КонецЕсли;
	
	МеткаВремени = МеткиВремениПоИдентификаторамЭДО[0].МеткаВремени;
	ОписаниеМетода = ОписаниеМетодаПорцияСтатусовДоверенностейПоМеткеВремени(МеткаВремени);
	ИдентификаторМетода = ИдентификаторМетодаПорцияСтатусовДоверенностейПоМеткеВремени();
	ИнтеграцияЦентраЭДО.ДобавитьОписаниеМетодаВПакет(ПакетМетодов, ОписаниеМетода, ИдентификаторМетода);
	
КонецПроцедуры

// Параметры:
//  ПакетМетодов - См. ИнтеграцияЦентраЭДО.НовыйПакетМетодовСервиса
//  ПараметрыОперации - См. ЭлектронныеДокументыЭДОИнтеграцияЦентраЭДО.НовыеПараметрыОперацииПоДействиямЭДО
Процедура ДобавитьОписаниеМетодаСтатусыДоверенностейСОшибкамиСинхронизации(ПакетМетодов, ПараметрыОперации) Экспорт
	
	ТипДанных = Перечисления.ТипыСинхронизацииСЦентромЭДО.СтатусыДоверенностей;
	МеткиВремениПоИдентификаторамЭДО = ПараметрыОперации.ОбъектыОперации.МеткиВремениТиповСинхронизации[ТипДанных];
	ИдентификаторыЭДО = ОбщегоНазначения.ВыгрузитьКолонку(МеткиВремениПоИдентификаторамЭДО, "ИдентификаторЭДО"); //@skip-check invocation-parameter-type-intersect
	ИдентификаторыДоверенностей = РегистрыСведений.СостоянияСинхронизацииОбъектовСЦентромЭДО.ОбъектыСОшибками(
		ТипДанных, ИдентификаторыЭДО);
		
	Если Не ЗначениеЗаполнено(ИдентификаторыДоверенностей) Тогда
		Возврат;
	КонецЕсли;
	
	ОписаниеМетода = ИнтеграцияЦентраЭДО.ОписаниеМетодаСервиса(
		"ДанныеСинхронизацииСтатусовДоверенностей",
		ИдентификаторыДоверенностей);
	
	ИдентификаторМетода = ИдентификаторМетодаСтатусыДоверенностей();
	ИнтеграцияЦентраЭДО.ДобавитьОписаниеМетодаВПакет(ПакетМетодов, ОписаниеМетода, ИдентификаторМетода);
	
КонецПроцедуры

// Параметры:
//  ИдентификаторМетода - Строка
//  РезультатМетода - Структура,Массив из Структура
//  РезультатДействий - см. ЭлектронныеДокументыЭДОИнтеграцияЦентраЭДО.НовыйРезультатДействийЭДО
//  КонтекстДиагностики - см. ОбработкаНеисправностейБЭД.НовыйКонтекстДиагностики
//  ПакетМетодовПовторно - см. ИнтеграцияЦентраЭДО.НовыйПакетМетодовСервиса
//  УчетнаяЗаписьЦентраЭДО - СправочникСсылка.УчетныеЗаписиЦентровЭДО
Процедура ОбработатьРезультатМетодаПоДействиямЭДО(ИдентификаторМетода, РезультатМетода, РезультатДействий,
	КонтекстДиагностики, ПакетМетодовПовторно, УчетнаяЗаписьЦентраЭДО) Экспорт
	
	Если ИдентификаторМетода = ИдентификаторМетодаПорцияСтатусовДоверенностейПоМеткеВремени() Тогда
		
		ОбработатьРезультатМетодаПорцияСтатусовДоверенностейПоМеткеВремени(
			РезультатМетода, РезультатДействий, КонтекстДиагностики, ПакетМетодовПовторно,
			УчетнаяЗаписьЦентраЭДО);
		
	ИначеЕсли ИдентификаторМетода = ИдентификаторМетодаСтатусыДоверенностей() Тогда
		
		ОбработатьРезультатМетодаСтатусыДоверенностей(РезультатМетода, РезультатДействий, КонтекстДиагностики,
			УчетнаяЗаписьЦентраЭДО);
		
	КонецЕсли;
	
КонецПроцедуры

// Возвращаемое значение:
//  Соответствие из КлючИЗначение:
//  * Ключ - ОпределяемыйТип.МашиночитаемаяДоверенность
//  * Значение - Булево
Функция ОбработатьОчередьЗапросовВРеестрМЧД() Экспорт
	
	ОбработанныеДоверенности = Новый Соответствие;
	
	КонтекстДиагностики = ОбработкаНеисправностейБЭД.НовыйКонтекстДиагностики();
	КонтекстДиагностики.ЗаголовокОперации =  НСтр("ru = 'Обработка очереди запросов в реестр ФНС'");
	
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ
		|	ОчередьЗапросов.Доверенность КАК Доверенность,
		|	ИдентификаторыЦентраЭДО.Идентификатор КАК Идентификатор,
		|	ИдентификаторыЦентраЭДО.УчетнаяЗаписьЦентраЭДО КАК УчетнаяЗаписьЦентраЭДО
		|ИЗ
		|	РегистрСведений.ОчередьЗапросовВРеестрМЧДЭДО КАК ОчередьЗапросов
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.ИдентификаторыСинхронизируемыхОбъектовЦентраЭДО КАК
		|			ИдентификаторыЦентраЭДО
		|		ПО ОчередьЗапросов.Доверенность = ИдентификаторыЦентраЭДО.Ссылка
		|ИТОГИ ПО
		|	УчетнаяЗаписьЦентраЭДО";
	
	ВыборкаУчетныхЗаписей = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	Пока ВыборкаУчетныхЗаписей.Следующий() Цикл
		
		УчетнаяЗаписьЦентраЭДО = ВыборкаУчетныхЗаписей.УчетнаяЗаписьЦентраЭДО;
		ИдентификаторыДоверенностей = Новый Массив; // Массив из Строка
		СсылкиПоИдентификаторам = Новый Соответствие;
		
		ВыборкаДоверенностей = ВыборкаУчетныхЗаписей.Выбрать();
		Пока ВыборкаДоверенностей.Следующий() Цикл
			ОбработанныеДоверенности.Вставить(ВыборкаДоверенностей.Доверенность, Истина);
			ИдентификаторыДоверенностей.Добавить(ВыборкаДоверенностей.Идентификатор);
			СсылкиПоИдентификаторам.Вставить(ВыборкаДоверенностей.Идентификатор, ВыборкаДоверенностей.Доверенность);
		КонецЦикла;
		
		ПараметрыВыполнения = ИнтеграцияЦентраЭДО.ПараметрыВыполненияМетодаСервиса(УчетнаяЗаписьЦентраЭДО);
		Если ПараметрыВыполнения = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		ОписаниеМетода = ИнтеграцияЦентраЭДО.ОписаниеМетодаСервиса(
			"СтатусыОтложенныхЗапросовВРеестрФНСПоДоверенностям",
			ИдентификаторыДоверенностей);
		
		СтатусыЗапросов = ИнтеграцияЦентраЭДО.ВыполнитьМетодСервиса(
			ПараметрыВыполнения, ОписаниеМетода, КонтекстДиагностики); // см. ПрограммныйИнтерфейсЦентраЭДОВерсия3.СтатусыОтложенныхЗапросовВРеестрФНСПоДоверенностям
		
		ОбновитьСтатусыЗапросовВОчереди(СтатусыЗапросов, СсылкиПоИдентификаторам, КонтекстДиагностики);
		
	КонецЦикла;
	
	Возврат ОбработанныеДоверенности;
	
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Параметры:
//  ВидОперации - Строка
//  Ошибки - Массив из Структура:
//  * Тип - Строка
//  * Кратко - Строка
//  * Подробно - Строка
//  КонтекстДиагностики - см. ОбработкаНеисправностейБЭД.НовыйКонтекстДиагностики 
//  УчетнаяЗаписьЦентраЭДО - СправочникСсылка.УчетныеЗаписиЦентровЭДО
Процедура ОбработатьОшибкиВФорматеСервиса(ВидОперации, Ошибки, КонтекстДиагностики, УчетнаяЗаписьЦентраЭДО)
	
	Если Не ЗначениеЗаполнено(Ошибки) Тогда
		Возврат;
	КонецЕсли;
	
	Для Каждого Ошибка Из Ошибки Цикл
		ОбработатьОшибкуВФорматеСервиса(ВидОперации, Ошибка, КонтекстДиагностики, УчетнаяЗаписьЦентраЭДО);
	КонецЦикла;
	
КонецПроцедуры

// Параметры:
//  ВидОперации - Строка
//  Ошибка - Структура:
//  * Тип - Строка
//  * Кратко - Строка
//  * Подробно - Строка
//  КонтекстДиагностики - см. ОбработкаНеисправностейБЭД.НовыйКонтекстДиагностики 
//  УчетнаяЗаписьЦентраЭДО - СправочникСсылка.УчетныеЗаписиЦентровЭДО
Процедура ОбработатьОшибкуВФорматеСервиса(ВидОперации, Ошибка, КонтекстДиагностики, УчетнаяЗаписьЦентраЭДО)
	
	ИнтеграцияЦентраЭДО.ДобавитьНеизвестнуюОшибку(КонтекстДиагностики, ВидОперации,
		Ошибка.Кратко, Ошибка.Подробно, УчетнаяЗаписьЦентраЭДО);
	
КонецПроцедуры

// Параметры:
//  ДанныеФайлаМЧД - ДвоичныеДанные
// 
// Возвращаемое значение:
//  Массив из СправочникСсылка.УчетныеЗаписиЦентровЭДО
Функция УчетныеЗаписиЦентровЭДОПоДаннымФайлаМЧД(ДанныеФайлаМЧД)
	
	Результат = Новый Массив; // См. УчетныеЗаписиЦентровЭДОПоДаннымФайлаМЧД
	
	ИННКППДоверителей = МашиночитаемыеДоверенности.ИННКППДоверителей(ДанныеФайлаМЧД);
	
	КлючевыеРеквизитыОрганизации = ИнтеграцияЭДО.НовыеКлючевыеРеквизитыУчастникаЭДО();
	
	Если ЗначениеЗаполнено(ИННКППДоверителей.ИННЮЛ) Тогда
		КлючевыеРеквизитыОрганизации.ИНН = ИННКППДоверителей.ИННЮЛ;
		КлючевыеРеквизитыОрганизации.КПП = ИННКППДоверителей.КПП;
	ИначеЕсли ЗначениеЗаполнено(ИННКППДоверителей.ИННФЛ) Тогда 
		КлючевыеРеквизитыОрганизации.ИНН = ИННКППДоверителей.ИННЮЛ;
	Иначе
		Возврат Результат;
	КонецЕсли;
	
	Организация = ИнтеграцияЭДО.ОрганизацияПоКлючевымРеквизитам(КлючевыеРеквизитыОрганизации);
	Если Не ЗначениеЗаполнено(Организация) Тогда
		Возврат Результат;
	КонецЕсли;
	
	ИдентификаторыЭДО = УчетныеЗаписиЭДО.ИдентификаторыЭДОПоОрганизации(Организация, Истина);
	
	Результат = РегистрыСведений.НастройкиИнтеграцииЦентраЭДО.УчетныеЗаписиЦентровЭДО(ИдентификаторыЭДО);
	
	Возврат Результат;
	
КонецФункции

// Параметры:
//  ДанныеФайлаМЧД - ДвоичныеДанные
// 
// Возвращаемое значение:
//  СправочникСсылка.УчетныеЗаписиЦентровЭДО
Функция УчетнаяЗаписьЦентраЭДОПоДаннымФайлаМЧД(ДанныеФайлаМЧД)
	
	УчетныеЗаписиЦентровЭДО = УчетныеЗаписиЦентровЭДОПоДаннымФайлаМЧД(ДанныеФайлаМЧД);
	Если ЗначениеЗаполнено(УчетныеЗаписиЦентровЭДО) Тогда
		УчетнаяЗаписьЦентраЭДО = УчетныеЗаписиЦентровЭДО[0];
	Иначе
		УчетнаяЗаписьЦентраЭДО = Справочники.УчетныеЗаписиЦентровЭДО.ПустаяСсылка();
	КонецЕсли;
	
	Возврат УчетнаяЗаписьЦентраЭДО;
	
КонецФункции

// Параметры:
//  РезультатМетода - Неопределено
//                  - см. ПрограммныйИнтерфейсЦентраЭДОВерсия3.СоздатьЧерновикДоверенности
//  КонтекстДиагностики - см. ОбработкаНеисправностейБЭД.НовыйКонтекстДиагностики
//  УчетнаяЗаписьЦентраЭДО - СправочникСсылка.УчетныеЗаписиЦентровЭДО
// 
// Возвращаемое значение:
//  Строка
Функция ОбработатьРезультатМетодаСоздатьЧерновикДоверенности(РезультатМетода, КонтекстДиагностики,
	УчетнаяЗаписьЦентраЭДО)
	
	Результат = "";
	
	Если Не ЗначениеЗаполнено(РезультатМетода) Тогда
		Возврат Результат;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(РезультатМетода.Ошибки) Тогда
		ВидОперации = НСтр("ru = 'Создание черновика доверенности'");
		ОбработатьОшибкиВФорматеСервиса(ВидОперации, РезультатМетода.Ошибки, КонтекстДиагностики,
			УчетнаяЗаписьЦентраЭДО);
	КонецЕсли;
	
	Возврат РезультатМетода.Идентификатор;
	
КонецФункции

// Параметры:
//  РезультатМетода - Неопределено
//                  - см. ПрограммныйИнтерфейсЦентраЭДОВерсия3.ОбновитьЧерновикДоверенности
//  КонтекстДиагностики - см. ОбработкаНеисправностейБЭД.НовыйКонтекстДиагностики
//  УчетнаяЗаписьЦентраЭДО - СправочникСсылка.УчетныеЗаписиЦентровЭДО
// 
// Возвращаемое значение:
//  Булево
Функция ОбработатьРезультатМетодаОбновитьЧерновикДоверенности(РезультатМетода, КонтекстДиагностики, УчетнаяЗаписьЦентраЭДО)
	
	Если Не ЗначениеЗаполнено(РезультатМетода) Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(РезультатМетода.Ошибки) Тогда
		ВидОперации = НСтр("ru = 'Обновление черновика доверенности'");
		ОбработатьОшибкиВФорматеСервиса(ВидОперации, РезультатМетода.Ошибки, КонтекстДиагностики,
			УчетнаяЗаписьЦентраЭДО);
	КонецЕсли;
	
	Возврат РезультатМетода.Успех;
	
КонецФункции

// Параметры:
//  Доверенность - СправочникСсылка.МашиночитаемыеДоверенностиОрганизаций,СправочникСсылка.МЧД003
//  ОтпечаткиСертификатов - см. КриптографияБЭДКлиентСервер.НовыеРезультатыПолученияОтпечатков
//  ЗаявлениеНаОтмену - Булево
//  КонтекстДиагностики - см. ОбработкаНеисправностейБЭДКлиент.НовыйКонтекстДиагностики
// 
// Возвращаемое значение:
//  - Неопределено
//  - См. МашиночитаемыеДоверенности.НовоеОписаниеНабораДанныхДляИнтерактивногоПодписанияМЧД
Функция ДанныеДляПодписанияПоДоверенности(Доверенность, ОтпечаткиСертификатов, ЗаявлениеНаОтмену, КонтекстДиагностики)
	
	ПараметрыСинхронизации =
		РегистрыСведений.ИдентификаторыСинхронизируемыхОбъектовЦентраЭДО.ПараметрыСинхронизацииОбъекта(Доверенность);
	Если ПараметрыСинхронизации = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	ПараметрыВыполнения = ИнтеграцияЦентраЭДО.ПараметрыВыполненияМетодаСервисаДляТекущегоПользователя(
		ПараметрыСинхронизации.УчетнаяЗаписьЦентраЭДО, КонтекстДиагностики);
	Если ПараметрыВыполнения = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	ВсеОтпечатки = КриптографияБЭД.ПолучитьВсеОтпечаткиСертификатов(ОтпечаткиСертификатов);
	
	Если ЗаявлениеНаОтмену Тогда
		ОписаниеМетода = ИнтеграцияЦентраЭДО.ОписаниеМетодаСервиса(
			"ПодготовитьДанныеДляПодписанияЗаявленияНаОтменуДоверенности",
			ПараметрыСинхронизации.Идентификатор, ВсеОтпечатки);
	Иначе
		ОписаниеМетода = ИнтеграцияЦентраЭДО.ОписаниеМетодаСервиса(
			"ПодготовитьДанныеДляПодписанияДоверенности",
			ПараметрыСинхронизации.Идентификатор, ВсеОтпечатки);
	КонецЕсли;
	
	РезультатМетода = ИнтеграцияЦентраЭДО.ВыполнитьМетодСервиса(
		ПараметрыВыполнения, ОписаниеМетода, КонтекстДиагностики); // См. ПрограммныйИнтерфейсЦентраЭДОВерсия3.ПодготовитьДанныеДляПодписанияДоверенности
	
	Если Не ЗначениеЗаполнено(РезультатМетода) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(РезультатМетода.Ошибки) Тогда
		ВидОперации = НСтр("ru = 'Подписание доверенности'");
		ОбработатьОшибкиВФорматеСервиса(ВидОперации, РезультатМетода.Ошибки, КонтекстДиагностики,
			ПараметрыСинхронизации.УчетнаяЗаписьЦентраЭДО);
	КонецЕсли;
	
	ДанныеДляПодписанияВФорматеСервиса = РезультатМетода.ДанныеДляПодписания;
	Если Не ЗначениеЗаполнено(ДанныеДляПодписанияВФорматеСервиса) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	ДвоичныеДанныеФайлаМЧД = Base64Значение(ДанныеДляПодписанияВФорматеСервиса.Данные);
	СертификатыПоОтпечаткам = КриптографияБЭД.СертификатыПоОтпечаткам(
		ДанныеДляПодписанияВФорматеСервиса.ОтпечаткиСертификатов);
	
	ДанныеМЧД = Новый Структура;
	ДанныеМЧД.Вставить("Данные", ДвоичныеДанныеФайлаМЧД);
	ДанныеМЧД.Вставить("Представление", Новый Структура);
	ДанныеМЧД.Представление.Вставить("Значение", Доверенность);
	ДанныеМЧД.Представление.Вставить("Представление", Строка(Доверенность));
	ДанныеМЧД.Вставить("Доверенность", Доверенность);
	
	ОписаниеНабораДанных = МашиночитаемыеДоверенности.НовоеОписаниеНабораДанныхДляИнтерактивногоПодписанияМЧД();
	ОписаниеНабораДанных.НаборДанных.Добавить(ДанныеМЧД);
	ОписаниеНабораДанных.Сертификаты = ОбщегоНазначения.ВыгрузитьКолонку(СертификатыПоОтпечаткам, "Значение");
	
	Возврат ОписаниеНабораДанных;
	
КонецФункции

// Параметры:
//  РезультатВФорматеСервиса - Неопределено
//                          - см. ПрограммныйИнтерфейсЦентраЭДОВерсия3.ДобавитьПодписьДоверенности
//  КонтекстДиагностики - см. ОбработкаНеисправностейБЭД.НовыйКонтекстДиагностики
//  УчетнаяЗаписьЦентраЭДО - СправочникСсылка.УчетныеЗаписиЦентровЭДО
// 
// Возвращаемое значение:
//  Неопределено,Структура:
//  * Подписана - Булево
//  * Верна - Булево
//  * ТекстОшибкиПроверкиМЧД - Строка
Функция РезультатДобавленияПодписиИзФорматаСервиса(РезультатВФорматеСервиса, КонтекстДиагностики, УчетнаяЗаписьЦентраЭДО)
	
	Если Не ЗначениеЗаполнено(РезультатВФорматеСервиса) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Результат = Новый Структура;
	Результат.Вставить("Подписана", РезультатВФорматеСервиса.Добавлена);
	Результат.Вставить("Верна", РезультатВФорматеСервиса.Верна);
	Результат.Вставить("ТекстОшибкиПроверкиМЧД", "");
	
	Если Не ЗначениеЗаполнено(РезультатВФорматеСервиса.Ошибки) Тогда
		Возврат Результат;
	КонецЕсли;
	
	ВидОперации = МашиночитаемыеДоверенностиКлиентСервер.ВидОперацииПодписатьЗарегистрироватьМЧД();
	
	Для Каждого Ошибка Из РезультатВФорматеСервиса.Ошибки Цикл
		Если Ошибка.Тип = КриптографияБЭДКлиентСервер.ИдентификаторВидаОшибкиКриптография() Тогда
			Результат.ТекстОшибкиПроверкиМЧД = Ошибка.Подробно;
		Иначе
			ОбработатьОшибкуВФорматеСервиса(ВидОперации, Ошибка, КонтекстДиагностики, УчетнаяЗаписьЦентраЭДО);
		КонецЕсли;
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

// Параметры:
//  РезультатВФорматеСервиса - Неопределено
//                          - см. ПрограммныйИнтерфейсЦентраЭДОВерсия3.ЗарегистрироватьДоверенностьВРеестреФНС
// 
// Возвращаемое значение:
//  Неопределено,Структура:
//  * Статус - ПеречислениеСсылка.СтатусыМашиночитаемойДоверенностиВРеестреФНС
//  * ИдентификаторТранзакции - Строка
//  * ОписаниеОшибкиРегистрации - Строка
Функция РезультатРегистрацииВРеестреФНСИзФорматаСервиса(РезультатВФорматеСервиса)
	
	Если Не ЗначениеЗаполнено(РезультатВФорматеСервиса) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Результат = Новый Структура;
	Результат.Вставить("Статус", Перечисления.СтатусыМашиночитаемойДоверенностиВРеестреФНС.ПустаяСсылка());
	Результат.Вставить("ИдентификаторТранзакции", РезультатВФорматеСервиса.ИдентификаторТранзакции);
	Результат.Вставить("ОписаниеОшибкиРегистрации", "");
	
	Если ЗначениеЗаполнено(Результат.ИдентификаторТранзакции) Тогда
		Результат.Статус = Перечисления.СтатусыМашиночитаемойДоверенностиВРеестреФНС.Отправлено;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(РезультатВФорматеСервиса.Ошибки) Тогда
		ОписанияОшибок = ОбщегоНазначения.ВыгрузитьКолонку(РезультатВФорматеСервиса.Ошибки, "Кратко"); //@skip-check invocation-parameter-type-intersect
		Результат.ОписаниеОшибкиРегистрации = СтрСоединить(ОписанияОшибок, Символы.ПС);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Загрузить данные доверенности.
// 
// Параметры:
//  ДанныеДоверенности - см. ПрограммныйИнтерфейсЦентраЭДОВерсия3.ПолучитьДанныеДоверенности
//  ИдентификаторДоверенности - Строка 
//  УчетнаяЗаписьЦентраЭДО - СправочникСсылка.УчетныеЗаписиЦентровЭДО
//  КонтекстДиагностики - см. ОбработкаНеисправностейБЭД.НовыйКонтекстДиагностики
// 
// Возвращаемое значение:
//  Неопределено,ОпределяемыйТип.МашиночитаемаяДоверенность
Функция ЗагрузитьПоДаннымСервиса(ДанныеДоверенности, ИдентификаторДоверенности, УчетнаяЗаписьЦентраЭДО, КонтекстДиагностики = Неопределено)
	
	ВидОперации = НСтр("ru = 'Загрузка данных доверенности'");
	
	Если КонтекстДиагностики = Неопределено Тогда
		КонтекстДиагностики = ОбработкаНеисправностейБЭД.НовыйКонтекстДиагностики();
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ДанныеДоверенности.Ошибка) Тогда
		ИнтеграцияЦентраЭДО.ДобавитьНеизвестнуюОшибку(КонтекстДиагностики, ВидОперации, ДанныеДоверенности.Ошибка);
		Возврат Неопределено;
	КонецЕсли;
	
	ТребуетсяПроверкаМЧДНаКлиенте = Ложь;
	ОбновлятьСуществующий = Истина;
	
	ДвоичныеДанные = Base64Значение(ДанныеДоверенности.Данные);
	
	Статус = ДанныеДоверенности.Статус;
	
	ДополнительныеСведения = МашиночитаемыеДоверенностиКлиентСервер.ДополнительныеСведенияПоЗагрузкеМЧД();
	ДополнительныеСведения.СтатусВРеестреФНС = СтатусВРеестреФНСИзФорматаСервиса(Статус.СтатусВРеестреФНС);
	ДополнительныеСведения.ДатаОбновленияСтатуса = ОбщегоНазначенияБЭД.ДатаИзФорматаISO(Статус.ДатаПолученияСтатуса);
	ДополнительныеСведения.ДатаОтзыва = ОбщегоНазначенияБЭД.ДатаИзФорматаISO(Статус.ДатаОтзыва);
	
	РезультатЗагрузки = МашиночитаемыеДоверенности.ЗагрузитьМЧДИзФайла(ДвоичныеДанные, ТребуетсяПроверкаМЧДНаКлиенте,
		ОбновлятьСуществующий, ДополнительныеСведения);
	
	Если ЗначениеЗаполнено(РезультатЗагрузки.ТекстОшибки) Тогда
		ИнтеграцияЦентраЭДО.ДобавитьНеизвестнуюОшибку(КонтекстДиагностики, ВидОперации, РезультатЗагрузки.ТекстОшибки);
	КонецЕсли;
	
	Доверенность = РезультатЗагрузки.МЧД;
	Если Не ЗначениеЗаполнено(Доверенность) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	ПараметрыСинхронизацииОбъекта = ИнтеграцияЦентраЭДО.НовыеПараметрыСинхронизацииОбъекта();
	ПараметрыСинхронизацииОбъекта.Идентификатор = ИдентификаторДоверенности;
	ПараметрыСинхронизацииОбъекта.УчетнаяЗаписьЦентраЭДО = УчетнаяЗаписьЦентраЭДО;
	ИнтеграцияЦентраЭДО.УстановитьПараметрыСинхронизацииОбъекта(Доверенность, ПараметрыСинхронизацииОбъекта);
	
	ОбновитьСтатусДоверенностиПоДаннымСервиса(Доверенность, Статус);
	
КонецФункции

// Параметры:
//  СтатусВФорматеСервиса - Строка
//  МетаданныеПеречисления - ОбъектМетаданныхПеречисление
// 
// Возвращаемое значение:
//  ПеречислениеСсылка.СтатусыМашиночитаемойДоверенностиВРеестреФНС
Функция СтатусВРеестреФНСИзФорматаСервиса(СтатусВФорматеСервиса, МетаданныеПеречисления = Неопределено)
	
	Если МетаданныеПеречисления = Неопределено Тогда
		МетаданныеПеречисления = Метаданные.Перечисления.СтатусыМашиночитаемойДоверенностиВРеестреФНС;
	КонецЕсли;
	
	Возврат ОбщегоНазначенияБЭД.ЗначениеПеречисленияПоИмени(СтатусВФорматеСервиса, МетаданныеПеречисления);
	
КонецФункции

// Параметры:
//  Доверенности - Массив из ОпределяемыйТип.МашиночитаемаяДоверенность
//  КонтекстДиагностики - См. ОбработкаНеисправностейБЭД.НовыйКонтекстДиагностики
// 
// Возвращаемое значение:
//  См. ИнтеграцияЦентраЭДО.НовыйПакетМетодовСервиса
Функция ПакетМетодовДляВыгрузкиДоверенностей(Доверенности, КонтекстДиагностики)
	
	ПакетМетодов = ИнтеграцияЦентраЭДО.НовыйПакетМетодовСервиса();
	
	Для Каждого Доверенность Из Доверенности Цикл
		ДанныеДоверенности = ДанныеДоверенностиВФорматеСервиса(Доверенность, КонтекстДиагностики);
		Если ДанныеДоверенности = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		// См. ПрограммныйИнтерфейсЦентраЭДОВерсия3.ЗагрузитьДанныеДоверенности
		ОписаниеМетода = ИнтеграцияЦентраЭДО.ОписаниеМетодаСервиса(
			"ЗагрузитьДанныеДоверенности", ДанныеДоверенности);
		ИнтеграцияЦентраЭДО.ДобавитьОписаниеМетодаВПакет(ПакетМетодов, ОписаниеМетода);
	КонецЦикла;
	
	Возврат ПакетМетодов;
	
КонецФункции

// Параметры:
//  КонтекстДиагностики - См. ОбработкаНеисправностейБЭД.НовыйКонтекстДиагностики
//  РезультатыМетодов - Соответствие из КлючИЗначение:
//  * Ключ - Число
//  * Значение - Структура:
//    ** ИдентификаторДоверенности - Неопределено,Строка
//    ** Ошибка - Неопределено,Строка
//  Доверенности - См. ПакетМетодовДляВыгрузкиДоверенностей.Доверенности
//  УчетнаяЗаписьЦентраЭДО - СправочникСсылка.УчетныеЗаписиЦентровЭДО
// 
// Возвращаемое значение:
//  Соответствие из КлючИЗначение:
//  * Ключ - ОпределяемыйТип.МашиночитаемаяДоверенность
//  * Значение - Булево
Функция ОбработатьРезультатыМетодовВыгрузкиДоверенностей(КонтекстДиагностики, РезультатыМетодов, Доверенности,
	УчетнаяЗаписьЦентраЭДО)
	
	Результат = Новый Соответствие;
	
	Для Каждого РезультатМетода Из РезультатыМетодов Цикл
		
		Индекс = РезультатМетода.Ключ;
		РезультатВыгрузки = РезультатМетода.Значение;
		
		Доверенность = Доверенности[Индекс];
		Результат.Вставить(Доверенность, ЗначениеЗаполнено(РезультатВыгрузки.ИдентификаторДоверенности));
		
		Если ЗначениеЗаполнено(РезультатВыгрузки.ИдентификаторДоверенности) Тогда
			Продолжить;
		КонецЕсли;
		
		ВидОперации = МашиночитаемыеДоверенностиИнтеграцияЦентраЭДОКлиентСервер.ВидОперацииВыгрузкаВЦентрЭДО();
		ТекстСообщения = СтрШаблон(НСтр("ru = 'Не удалось выгрузить машиночитаемую доверенность %1'"),
			Доверенность) + Символы.ПС + РезультатВыгрузки.Ошибка;
		ИнтеграцияЦентраЭДО.ДобавитьНеизвестнуюОшибку(КонтекстДиагностики, ВидОперации, ТекстСообщения,,
			УчетнаяЗаписьЦентраЭДО);
		
	КонецЦикла;
	
	Возврат Результат
	
КонецФункции

// Параметры:
//  МеткаВремени - Число
// 
// Возвращаемое значение:
//  См. ИнтеграцияЦентраЭДО.ОписаниеМетодаСервиса
Функция ОписаниеМетодаПорцияСтатусовДоверенностейПоМеткеВремени(МеткаВремени)
	
	Возврат ИнтеграцияЦентраЭДО.ОписаниеМетодаСервиса(
		"ПорцияДанныхСинхронизацииСтатусовДоверенностейПоМеткеВремени",
		МеткаВремени);
	
КонецФункции

// Возвращаемое значение:
//  Строка
Функция ИдентификаторМетодаПорцияСтатусовДоверенностейПоМеткеВремени()
	
	Возврат "СтатусыДоверенностейПоМеткеВремени";
	
КонецФункции

// Возвращаемое значение:
//  Строка
Функция ИдентификаторМетодаСтатусыДоверенностей()
	
	Возврат "СтатусыДоверенностей";
	
КонецФункции

// Параметры:
//  ПорцияДанных - см. ПрограммныйИнтерфейсЦентраЭДОВерсия3.ПорцияДанныхСинхронизацииСтатусовДоверенностейПоМеткеВремени
//  РезультатДействий - см. ОбработатьРезультатМетодаПоДействиямЭДО.РезультатДействий
//  КонтекстДиагностики - см. ОбработкаНеисправностейБЭД.НовыйКонтекстДиагностики
//  ПакетМетодовПовторно - см. ИнтеграцияЦентраЭДО.НовыйПакетМетодовСервиса
//  УчетнаяЗаписьЦентраЭДО - СправочникСсылка.УчетныеЗаписиЦентровЭДО
Процедура ОбработатьРезультатМетодаПорцияСтатусовДоверенностейПоМеткеВремени(
		ПорцияДанных, РезультатДействий, КонтекстДиагностики, ПакетМетодовПовторно, УчетнаяЗаписьЦентраЭДО)
	
	Если Не ЗначениеЗаполнено(ПорцияДанных) Тогда
		Возврат;
	КонецЕсли;
	
	МеткаВремени = ОбновитьСтатусыДоверенностейПоДаннымСинхронизации(
		ПорцияДанных.НаборДанных, КонтекстДиагностики, УчетнаяЗаписьЦентраЭДО);
	
	Если МеткаВремени = 0 Тогда
		Возврат;
	КонецЕсли;
	
	ИдентификаторЭДО = "";
	ТипДанных = Перечисления.ТипыСинхронизацииСЦентромЭДО.СтатусыДоверенностей;
	
	Попытка
		РегистрыСведений.СостоянияСинхронизацииСЦентромЭДО.Записать(ИдентификаторЭДО, ТипДанных, МеткаВремени);
	Исключение
		ВидОперации = НСтр("ru = 'Синхронизация статусов доверенностей'");
		ТекстОшибки = СтрШаблон(НСтр("ru = 'Не удалось зафиксировать состояние синхронизации с центром ЭДО
			|для типа данных %1 по идентификатору ЭДО %2'"), ТипДанных, ИдентификаторЭДО);
		ТекстОшибкиПодробно = ТекстОшибки + Символы.ПС
			+ ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
		ИнтеграцияЦентраЭДО.ДобавитьНеизвестнуюОшибку(КонтекстДиагностики, ВидОперации,
			ТекстОшибки, ТекстОшибкиПодробно);
	КонецПопытки;
	
	Если ПорцияДанных.ЭтоПоследний Тогда
		Возврат;
	КонецЕсли;
	
	ОписаниеМетода = ОписаниеМетодаПорцияСтатусовДоверенностейПоМеткеВремени(МеткаВремени);
	ИдентификаторМетода = ИдентификаторМетодаПорцияСтатусовДоверенностейПоМеткеВремени();
	ИнтеграцияЦентраЭДО.ДобавитьОписаниеМетодаВПакет(ПакетМетодовПовторно, ОписаниеМетода, ИдентификаторМетода);
	
КонецПроцедуры

// Параметры:
//  НаборДанных - см. ПрограммныйИнтерфейсЦентраЭДОВерсия3.ДанныеСинхронизацииСтатусовДоверенностей
//  КонтекстДиагностики - см. ОбработкаНеисправностейБЭД.НовыйКонтекстДиагностики
//  УчетнаяЗаписьЦентраЭДО - СправочникСсылка.УчетныеЗаписиЦентровЭДО
// 
// Возвращаемое значение:
//  Число
Функция ОбновитьСтатусыДоверенностейПоДаннымСинхронизации(НаборДанных, КонтекстДиагностики, УчетнаяЗаписьЦентраЭДО)
	
	ТипДанных = Перечисления.ТипыСинхронизацииСЦентромЭДО.СтатусыДоверенностей;
	МеткаВремениТипаДанных = 0;
	ИзменятьМеткуВремениТипаДанных = Истина;
	
	ИдентификаторыДоверенностей = ОбщегоНазначения.ВыгрузитьКолонку(НаборДанных, "Идентификатор"); // Массив из Строка
	СсылкиПоИдентификаторам = ИнтеграцияЦентраЭДО.СсылкиПоИдентификаторамСинхронизации(
		УчетнаяЗаписьЦентраЭДО, ИдентификаторыДоверенностей);
	
	Доверенности = Новый Массив; // Массив из ОпределяемыйТип.МашиночитаемаяДоверенность
	Для Каждого СсылкаПоИдентификатору Из СсылкиПоИдентификаторам Цикл
		Доверенность = СсылкаПоИдентификатору.Значение;
		Если ЗначениеЗаполнено(Доверенность) Тогда
			Доверенности.Добавить(Доверенность);
		КонецЕсли;
	КонецЦикла;
	
	СвойстваДоверенностей = СвойстваДоверенностейДляКонтроляОбновленияДанных(Доверенности);
	
	Для Каждого ДанныеСинхронизации Из НаборДанных Цикл
		
		СостояниеСинхронизации = ДанныеСинхронизации.Состояние;
		Если Не ЗначениеЗаполнено(СостояниеСинхронизации) Тогда
			Продолжить;
		КонецЕсли;
		
		Если ИзменятьМеткуВремениТипаДанных И СостояниеСинхронизации.МеткаВремени > МеткаВремениТипаДанных Тогда
			МеткаВремениТипаДанных = СостояниеСинхронизации.МеткаВремени;
		КонецЕсли;
		
		Доверенность = СсылкиПоИдентификаторам[ДанныеСинхронизации.Идентификатор];
		Если Не ЗначениеЗаполнено(Доверенность) Тогда
			Продолжить;
		КонецЕсли;
		
		СостояниеОбъекта = РегистрыСведений.СостоянияСинхронизацииОбъектовСЦентромЭДО.НовоеСостояниеОбъекта();
		ЗаполнитьЗначенияСвойств(СостояниеОбъекта, СостояниеСинхронизации);
		СостояниеОбъекта.ИдентификаторОбъекта = ДанныеСинхронизации.Идентификатор;
		
		СвойстваДоверенности = СвойстваДоверенностей.Найти(Доверенность, "Ссылка");
		Если СвойстваДоверенности = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		СтатусДоверенности = ДанныеСинхронизации.СтатусДоверенности;
		ДатаОтзыва = ОбщегоНазначенияБЭД.ДатаИзФорматаISO(СтатусДоверенности.ДатаОтзыва);
		ТребуетсяОбновлениеДоверенности = СвойстваДоверенности.Подписана <> СтатусДоверенности.Подписана
			Или Не ЗначениеЗаполнено(СвойстваДоверенности.ДатаОтзыва) И ЗначениеЗаполнено(ДатаОтзыва)
			Или ЗначениеЗаполнено(СвойстваДоверенности.ДатаОтзыва) И Не ЗначениеЗаполнено(ДатаОтзыва);
		
		Попытка
			
			Если ТребуетсяОбновлениеДоверенности Тогда
				ОбновитьДоверенностьПоДаннымСервиса(УчетнаяЗаписьЦентраЭДО, Доверенность,
					СтатусДоверенности, ДанныеСинхронизации.Идентификатор);
			Иначе
				ОбновитьСтатусДоверенностиПоДаннымСервиса(Доверенность, СтатусДоверенности);
			КонецЕсли;
			
			РегистрыСведений.СостоянияСинхронизацииОбъектовСЦентромЭДО.ЗаписатьСостояние(ТипДанных, СостояниеОбъекта);
			
			Продолжить;
			
		Исключение
			
			ТекстОшибки = СтрШаблон(
				НСтр("ru = 'Не удалось синхронизировать статус доверенности с идентификатором %1'"),
				СостояниеОбъекта.ИдентификаторОбъекта);
			ТекстОшибкиПодробно = ТекстОшибки + Символы.ПС
				+ ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
			ВидОперации = НСтр("ru = 'Синхронизация статусов доверенностей'");
			ИнтеграцияЦентраЭДО.ДобавитьНеизвестнуюОшибку(КонтекстДиагностики, ВидОперации, ТекстОшибки, ТекстОшибкиПодробно);
		
		КонецПопытки;
		
		Попытка
			РегистрыСведений.СостоянияСинхронизацииОбъектовСЦентромЭДО.ЗаписатьОшибку(
				ТипДанных, СостояниеОбъекта, ТекстОшибкиПодробно);
		Исключение
			ИзменятьМеткуВремениТипаДанных = Ложь;
			ТекстОшибки = СтрШаблон(
				НСтр("ru = 'Не удалось зафиксировать ошибку при синхронизации статуса доверенности с идентификатором %1'"),
				СостояниеОбъекта.ИдентификаторОбъекта);
			ТекстОшибкиПодробно = ТекстОшибки + Символы.ПС
				+ ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
			ВидОперации = НСтр("ru = 'Синхронизация статусов доверенностей'");
			ИнтеграцияЦентраЭДО.ДобавитьНеизвестнуюОшибку(КонтекстДиагностики, ВидОперации, ТекстОшибки, ТекстОшибкиПодробно);
		КонецПопытки;
		
	КонецЦикла;
	
	Возврат МеткаВремениТипаДанных;
	
КонецФункции

// Параметры:
//  Доверенности - Массив из ОпределяемыйТип.МашиночитаемаяДоверенность
// 
// Возвращаемое значение:
//  ТаблицаЗначений:
//  * Ссылка - ОпределяемыйТип.МашиночитаемаяДоверенность
//  * ДатаОтзыва - Дата
//  * Подписана - Булево
Функция СвойстваДоверенностейДляКонтроляОбновленияДанных(Доверенности)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	МашиночитаемыеДоверенностиОрганизаций.Ссылка КАК Ссылка,
		|	МашиночитаемыеДоверенностиОрганизаций.ДатаОтзыва КАК ДатаОтзыва,
		|	МашиночитаемыеДоверенностиОрганизаций.Подписана КАК Подписана
		|ИЗ
		|	Справочник.МашиночитаемыеДоверенностиОрганизаций КАК МашиночитаемыеДоверенностиОрганизаций
		|ГДЕ
		|	МашиночитаемыеДоверенностиОрганизаций.Ссылка В (&Доверенности)
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	МашиночитаемыеДоверенностиКонтрагентов.Ссылка,
		|	МашиночитаемыеДоверенностиКонтрагентов.ДатаОтзыва,
		|	МашиночитаемыеДоверенностиКонтрагентов.Подписана
		|ИЗ
		|	Справочник.МашиночитаемыеДоверенностиКонтрагентов КАК МашиночитаемыеДоверенностиКонтрагентов
		|ГДЕ
		|	МашиночитаемыеДоверенностиКонтрагентов.Ссылка В (&Доверенности)
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	МЧД003.Ссылка,
		|	МЧД003.ДатаПрекращения,
		|	МЧД003.Подписана
		|ИЗ
		|	Справочник.МЧД003 КАК МЧД003
		|ГДЕ
		|	МЧД003.Ссылка В (&Доверенности)";
	
	Запрос.УстановитьПараметр("Доверенности", Доверенности);
	
	СвойстваДоверенностей = Запрос.Выполнить().Выгрузить();
	СвойстваДоверенностей.Индексы.Добавить("Ссылка");
	
	Возврат СвойстваДоверенностей;
	
КонецФункции

// Параметры:
//  УчетнаяЗаписьЦентраЭДО - СправочникСсылка.УчетныеЗаписиЦентровЭДО
//  Доверенность - СправочникСсылка.МЧД003,СправочникСсылка.МашиночитаемыеДоверенностиОрганизаций,СправочникСсылка.МашиночитаемыеДоверенностиКонтрагентов
//  СтатусДоверенности - Структура:
//  * Подписана - Булево
//  * Верна - Булево
//  * ОшибкаПроверки - Строка
//  * СтатусВРеестреФНС - Строка
//  * ОшибкаРеестраФНС - Строка
//  * ДатаОтзыва - см. ОбщегоНазначенияБЭД.ДатаВФорматеISO
//  * ДатаПолученияСтатуса - см. ОбщегоНазначенияБЭД.ДатаВФорматеISO
//  * СтатусыОтложенныхЗапросов - Массив из Структура:
//    ** ВидЗапроса - Строка
//    ** ДатаСоздания - см. ОбщегоНазначенияБЭД.ДатаВФорматеISO
//    ** ДатаПоследнейПопытки - см. ОбщегоНазначенияБЭД.ДатаВФорматеISO
//    ** НомерПопытки - Число
//  ИдентификаторДоверенности - Неопределено,Строка
Процедура ОбновитьДоверенностьПоДаннымСервиса(УчетнаяЗаписьЦентраЭДО, Доверенность, СтатусДоверенности, ИдентификаторДоверенности = Неопределено)
	
	Если ИдентификаторДоверенности = Неопределено Тогда
		ИдентификаторДоверенности = ИнтеграцияЦентраЭДО.ИдентификаторСинхронизации(Доверенность);
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(ИдентификаторДоверенности) Тогда
		Возврат;
	КонецЕсли;
	
	ПараметрыВыполнения = ИнтеграцияЦентраЭДОПовтИсп.ПараметрыВыполненияМетодаСервиса(УчетнаяЗаписьЦентраЭДО);
	
	ОписаниеМетода = ИнтеграцияЦентраЭДО.ОписаниеМетодаСервиса(
		"ПолучитьДанныеДоверенности", ИдентификаторДоверенности);
	
	ДанныеДоверенности = ИнтеграцияЦентраЭДО.ВыполнитьМетодСервиса(ПараметрыВыполнения, ОписаниеМетода); // См.  ПрограммныйИнтерфейсЦентраЭДОВерсия3.ПолучитьДанныеДоверенности
	
	Если Не ЗначениеЗаполнено(ДанныеДоверенности) Тогда
		Возврат;
	КонецЕсли;
	
	ЗагрузитьПоДаннымСервиса(ДанныеДоверенности, ИдентификаторДоверенности, УчетнаяЗаписьЦентраЭДО);
	
КонецПроцедуры

// Параметры:
//  Доверенность - СправочникСсылка.МЧД003,СправочникСсылка.МашиночитаемыеДоверенностиОрганизаций,СправочникСсылка.МашиночитаемыеДоверенностиКонтрагентов
//  СтатусДоверенности - Структура:
//  * Подписана - Булево
//  * Верна - Булево
//  * ОшибкаПроверки - Строка
//  * СтатусВРеестреФНС - Строка
//  * ОшибкаРеестраФНС - Строка
//  * ДатаОтзыва - см. ОбщегоНазначенияБЭД.ДатаВФорматеISO
//  * ДатаПолученияСтатуса - см. ОбщегоНазначенияБЭД.ДатаВФорматеISO
//  * СтатусыОтложенныхЗапросов - Массив из Структура:
//    ** ВидЗапроса - Строка
//    ** ДатаСоздания - см. ОбщегоНазначенияБЭД.ДатаВФорматеISO
//    ** ДатаПоследнейПопытки - см. ОбщегоНазначенияБЭД.ДатаВФорматеISO
//    ** НомерПопытки - Число
Процедура ОбновитьСтатусДоверенностиПоДаннымСервиса(Доверенность, СтатусДоверенности)
	
	ЭтоМЧД003 = МашиночитаемыеДоверенности.ЭтоМЧД003(Доверенность);
	
	ДоверенностьОбъект = Доверенность.ПолучитьОбъект();
	
	ДоверенностьОбъект.Подписана = СтатусДоверенности.Подписана;
	ДоверенностьОбъект.Верна = СтатусДоверенности.Верна;
	ДоверенностьОбъект.ТекстОшибкиПроверкиМЧД = СтатусДоверенности.ОшибкаПроверки;
	
	ДоверенностьОбъект.СтатусВРеестреФНС = СтатусВРеестреФНСИзФорматаСервиса(СтатусДоверенности.СтатусВРеестреФНС);
	ДоверенностьОбъект.ОписаниеОшибкиРегистрации = СтатусДоверенности.ОшибкаРеестраФНС;
	ДоверенностьОбъект.ДатаОбновленияСтатуса = ОбщегоНазначенияБЭД.ДатаИзФорматаISO(СтатусДоверенности.ДатаПолученияСтатуса);
	
	ДатаОтзыва = ОбщегоНазначенияБЭД.ДатаИзФорматаISO(СтатусДоверенности.ДатаОтзыва);
	Если ЭтоМЧД003 Тогда
		ДоверенностьОбъект.ДатаПрекращения = ДатаОтзыва;
	Иначе
		ДоверенностьОбъект.ДатаОтзыва = ДатаОтзыва;
	КонецЕсли;
	
	ДоверенностьОбъект.Записать();
	
	ОбновитьСтатусыОтложенныхЗапросовПоДоверенности(Доверенность, СтатусДоверенности.СтатусыОтложенныхЗапросов);
	
КонецПроцедуры

// Параметры:
//  НаборДанных - См. ПрограммныйИнтерфейсЦентраЭДОВерсия3.ДанныеСинхронизацииСтатусовДоверенностей
//  РезультатДействий - см. ЭлектронныеДокументыЭДОИнтеграцияЦентраЭДО.НовыйРезультатДействийЭДО
//  КонтекстДиагностики - см. ОбработкаНеисправностейБЭД.НовыйКонтекстДиагностики
//  УчетнаяЗаписьЦентраЭДО - см. СправочникСсылка.УчетныеЗаписиЦентровЭДО
Процедура ОбработатьРезультатМетодаСтатусыДоверенностей(НаборДанных, РезультатДействий, КонтекстДиагностики,
	УчетнаяЗаписьЦентраЭДО)
	
	Если Не ЗначениеЗаполнено(НаборДанных) Тогда
		Возврат;
	КонецЕсли;
	
	ОбновитьСтатусыДоверенностейПоДаннымСинхронизации(НаборДанных, КонтекстДиагностики, УчетнаяЗаписьЦентраЭДО);
	
КонецПроцедуры

// Параметры:
//  СтатусыЗапросовДоверенностей - см. ПрограммныйИнтерфейсЦентраЭДОВерсия3.СтатусыОтложенныхЗапросовВРеестрФНСПоДоверенностям
//  ДоверенностиПоИдентификаторам - Соответствие из КлючИЗначение:
//  * Ключ - Строка
//  * Значение - ОпределяемыйТип.МашиночитаемаяДоверенность
//  КонтекстДиагностики - см. ОбработкаНеисправностейБЭД.НовыйКонтекстДиагностики
Процедура ОбновитьСтатусыЗапросовВОчереди(СтатусыЗапросовДоверенностей, ДоверенностиПоИдентификаторам, КонтекстДиагностики)
	
	Если Не ЗначениеЗаполнено(СтатусыЗапросовДоверенностей) Тогда
		Возврат;
	КонецЕсли;
	
	СтатусыЗапросовПоДоверенностям = Новый Соответствие;
	
	Для Каждого СтатусЗапросаДоверенности Из СтатусыЗапросовДоверенностей Цикл
		
		Доверенность = ДоверенностиПоИдентификаторам[СтатусЗапросаДоверенности.ИдентификаторДоверенности];
		Если Не ЗначениеЗаполнено(Доверенность) Тогда
			Продолжить;
		КонецЕсли;
		
		СтатусыЗапросов = СтатусыЗапросовПоДоверенностям[Доверенность];
		Если СтатусыЗапросов = Неопределено Тогда
			СтатусыЗапросов = Новый Массив; // Массив из Структура
			СтатусыЗапросовПоДоверенностям.Вставить(Доверенность, СтатусыЗапросов);
		КонецЕсли;
		
		СтатусыЗапросов.Добавить(СтатусЗапросаДоверенности);
		
	КонецЦикла;
	
	Для Каждого СтатусыЗапросовПоДоверенности Из СтатусыЗапросовПоДоверенностям Цикл
		
		Доверенность = СтатусыЗапросовПоДоверенности.Ключ;
		СтатусыЗапросов = СтатусыЗапросовПоДоверенности.Значение; // Массив из Структура
		ОбновитьСтатусыОтложенныхЗапросовПоДоверенности(Доверенность, СтатусыЗапросов);
		
	КонецЦикла;
	
КонецПроцедуры

// Параметры:
//  Доверенность - ОпределяемыйТип.МашиночитаемаяДоверенность
//  СтатусыЗапросов - Массив из Структура:
//  * ВидЗапроса - Строка
//  * ДатаСоздания - см. ОбщегоНазначенияБЭД.ДатаВФорматеISO
//  * ДатаПоследнейПопытки - см. ОбщегоНазначенияБЭД.ДатаВФорматеISO
//  * НомерПопытки - Число
Процедура ОбновитьСтатусыОтложенныхЗапросовПоДоверенности(Доверенность, СтатусыЗапросов)
	
	НаборЗаписей = РегистрыСведений.ОчередьЗапросовВРеестрМЧДЭДО.СоздатьНаборЗаписей();
	НаборЗаписей.Отбор.Доверенность.Установить(Доверенность);
	
	Для Каждого СтатусЗапроса Из СтатусыЗапросов Цикл
		ЗаписьНабора = НаборЗаписей.Добавить();
		ЗаписьНабора.Доверенность = Доверенность;
		ЗаписьНабора.ВидЗапроса = СтатусЗапроса.ВидЗапроса;
		ЗаписьНабора.ДатаСоздания = ОбщегоНазначенияБЭД.ДатаИзФорматаISO(СтатусЗапроса.ДатаСоздания);
		ЗаписьНабора.ДатаПоследнейПопытки = ОбщегоНазначенияБЭД.ДатаИзФорматаISO(
			СтатусЗапроса.ДатаПоследнейПопытки);
		ЗаписьНабора.НомерПопытки = СтатусЗапроса.НомерПопытки;
	КонецЦикла;
	
	НаборЗаписей.Записать();
	
КонецПроцедуры

// Параметры:
//  Доверенность - ОпределяемыйТип.МашиночитаемаяДоверенность
// 
// Возвращаемое значение:
//  - Неопределено
//  - См. НовыйСтатусДоверенности
Функция СтатусДоверенности(Доверенность)
	
	СтатусДоверенности = НовыйСтатусДоверенности();
	
	ВыборкиДанных = ВыбратьДанныеСтатусаДоверенности(Доверенность);
	ВыборкаРеквизитов = ВыборкиДанных.ВыборкаРеквизитов;
	ВыборкаСтатусовЗапросов = ВыборкиДанных.ВыборкаСтатусовЗапросов;
	
	Если ВыборкаРеквизитов.Следующий() Тогда
		СтатусДоверенности.Подписана = ВыборкаРеквизитов.Подписана;
		СтатусДоверенности.Верна = ВыборкаРеквизитов.Верна;
		Если ЗначениеЗаполнено(ВыборкаРеквизитов.ТекстОшибкиПроверкиМЧД) Тогда
			СтатусДоверенности.ОшибкаПроверки = ВыборкаРеквизитов.ТекстОшибкиПроверкиМЧД;
		КонецЕсли;
		Если ЗначениеЗаполнено(ВыборкаРеквизитов.СтатусВРеестреФНС) Тогда
			СтатусДоверенности.СтатусВРеестреФНС = ОбщегоНазначения.ИмяЗначенияПеречисления(ВыборкаРеквизитов.СтатусВРеестреФНС);
		КонецЕсли;
		Если ЗначениеЗаполнено(ВыборкаРеквизитов.ОписаниеОшибкиРегистрации) Тогда
			СтатусДоверенности.ОшибкаРеестраФНС = ВыборкаРеквизитов.ОписаниеОшибкиРегистрации;
		КонецЕсли;
		СтатусДоверенности.ДатаОтзыва = ОбщегоНазначенияБЭД.ДатаВФорматеISO(ВыборкаРеквизитов.ДатаОтзыва);
		СтатусДоверенности.ДатаПолученияСтатуса = ОбщегоНазначенияБЭД.ДатаВФорматеISO(ВыборкаРеквизитов.ДатаОбновленияСтатуса);
	Иначе
		Возврат Неопределено;
	КонецЕсли;
	
	Пока ВыборкаСтатусовЗапросов.Следующий() Цикл
		СтатусОтложенногоЗапроса = НовыйСтатусОтложенногоЗапроса();
		СтатусОтложенногоЗапроса.ВидЗапроса = ВыборкаСтатусовЗапросов.ВидЗапроса;
		СтатусОтложенногоЗапроса.ДатаСоздания = ОбщегоНазначенияБЭД.ДатаВФорматеISO(
			ВыборкаСтатусовЗапросов.ДатаСоздания);
		СтатусОтложенногоЗапроса.ДатаПоследнейПопытки = ОбщегоНазначенияБЭД.ДатаВФорматеISO(
			ВыборкаСтатусовЗапросов.ДатаПоследнейПопытки);
		СтатусОтложенногоЗапроса.НомерПопытки = ВыборкаСтатусовЗапросов.НомерПопытки;
		СтатусДоверенности.СтатусыОтложенныхЗапросов.Добавить(СтатусОтложенногоЗапроса);
	КонецЦикла;
	
	Возврат СтатусДоверенности;
	
КонецФункции

// Возвращаемое значение:
//  Структура:
//  * Подписана - Булево
//  * Верна - Булево
//  * ОшибкаПроверки - Неопределено,Строка
//  * СтатусВРеестреФНС - Строка
//  * ОшибкаРеестраФНС - Неопределено,Строка
//  * ДатаОтзыва - см. ОбщегоНазначенияБЭД.ДатаВФорматеISO
//  * ДатаПолученияСтатуса - см. ОбщегоНазначенияБЭД.ДатаВФорматеISO
//  * СтатусыОтложенныхЗапросов - Массив из см. НовыйСтатусОтложенногоЗапроса
Функция НовыйСтатусДоверенности()
	
	Свойства = Новый Структура;
	Свойства.Вставить("Подписана", Ложь);
	Свойства.Вставить("Верна", Ложь);
	Свойства.Вставить("ОшибкаПроверки", Неопределено);
	Свойства.Вставить("СтатусВРеестреФНС", "");
	Свойства.Вставить("ОшибкаРеестраФНС", Неопределено);
	Свойства.Вставить("ДатаОтзыва", "");
	Свойства.Вставить("ДатаПолученияСтатуса", "");
	Свойства.Вставить("СтатусыОтложенныхЗапросов", Новый Массив);
	Возврат Свойства;
	
КонецФункции

// Возвращаемое значение:
//  Структура:
//  * ВидЗапроса - Строка
//  * ДатаСоздания - см. ОбщегоНазначенияБЭД.ДатаВФорматеISO
//  * ДатаПоследнейПопытки - см. ОбщегоНазначенияБЭД.ДатаВФорматеISO
//  * НомерПопытки - Число
Функция НовыйСтатусОтложенногоЗапроса()
	
	Свойства = Новый Структура;
	Свойства.Вставить("ВидЗапроса", "");
	Свойства.Вставить("ДатаСоздания", "");
	Свойства.Вставить("ДатаПоследнейПопытки", "");
	Свойства.Вставить("НомерПопытки", 0);
	Возврат Свойства;
	
КонецФункции

// Параметры:
//  Доверенность - ОпределяемыйТип.МашиночитаемаяДоверенность
// 
// Возвращаемое значение:
//  Структура:
//  * ВыборкаРеквизитов - ВыборкаИзРезультатаЗапроса:
//    ** СтатусВРеестреФНС - ПеречислениеСсылка.СтатусыМашиночитаемойДоверенностиВРеестреФНС
//    ** ОписаниеОшибкиРегистрации - Строка
//    ** ДатаОтзыва - Дата
//    ** ДатаОбновленияСтатуса - Дата
//    ** Подписана - Булево
//    ** Верна - Булево
//    ** ТекстОшибкиПроверкиМЧД - Строка
//  * ВыборкаСтатусовЗапросов - ВыборкаИзРезультатаЗапроса:
//    ** ВидЗапроса - Строка
//    ** ДатаСоздания - Дата
//    ** ДатаПоследнейПопытки - Дата
//    ** НомерПопытки - Число
Функция ВыбратьДанныеСтатусаДоверенности(Доверенность)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	МашиночитаемыеДоверенностиОрганизаций.СтатусВРеестреФНС КАК СтатусВРеестреФНС,
		|	МашиночитаемыеДоверенностиОрганизаций.ОписаниеОшибкиРегистрации КАК ОписаниеОшибкиРегистрации,
		|	МашиночитаемыеДоверенностиОрганизаций.ДатаОтзыва КАК ДатаОтзыва,
		|	МашиночитаемыеДоверенностиОрганизаций.ДатаОбновленияСтатуса КАК ДатаОбновленияСтатуса,
		|	МашиночитаемыеДоверенностиОрганизаций.Подписана КАК Подписана,
		|	МашиночитаемыеДоверенностиОрганизаций.Верна КАК Верна,
		|	МашиночитаемыеДоверенностиОрганизаций.ТекстОшибкиПроверкиМЧД КАК ТекстОшибкиПроверкиМЧД
		|ИЗ
		|	Справочник.МашиночитаемыеДоверенностиОрганизаций КАК МашиночитаемыеДоверенностиОрганизаций
		|ГДЕ
		|	МашиночитаемыеДоверенностиОрганизаций.Ссылка = &Доверенность
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	МашиночитаемыеДоверенностиКонтрагентов.СтатусВРеестреФНС,
		|	"""",
		|	МашиночитаемыеДоверенностиКонтрагентов.ДатаОтзыва,
		|	МашиночитаемыеДоверенностиКонтрагентов.ДатаОбновленияСтатуса,
		|	МашиночитаемыеДоверенностиКонтрагентов.Подписана,
		|	МашиночитаемыеДоверенностиКонтрагентов.Верна,
		|	МашиночитаемыеДоверенностиКонтрагентов.ТекстОшибкиПроверкиМЧД
		|ИЗ
		|	Справочник.МашиночитаемыеДоверенностиКонтрагентов КАК МашиночитаемыеДоверенностиКонтрагентов
		|ГДЕ
		|	МашиночитаемыеДоверенностиКонтрагентов.Ссылка = &Доверенность
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	МЧД003.СтатусВРеестреФНС,
		|	МЧД003.ОписаниеОшибкиРегистрации,
		|	МЧД003.ДатаПрекращения,
		|	МЧД003.ДатаОбновленияСтатуса,
		|	МЧД003.Подписана,
		|	МЧД003.Верна,
		|	МЧД003.ТекстОшибкиПроверкиМЧД
		|ИЗ
		|	Справочник.МЧД003 КАК МЧД003
		|ГДЕ
		|	МЧД003.Ссылка = &Доверенность
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ОчередьЗапросов.ВидЗапроса КАК ВидЗапроса,
		|	ОчередьЗапросов.ДатаСоздания КАК ДатаСоздания,
		|	ОчередьЗапросов.ДатаПоследнейПопытки КАК ДатаПоследнейПопытки,
		|	ОчередьЗапросов.НомерПопытки КАК НомерПопытки
		|ИЗ
		|	РегистрСведений.ОчередьЗапросовВРеестрМЧДЭДО КАК ОчередьЗапросов
		|ГДЕ
		|	ОчередьЗапросов.Доверенность = &Доверенность";
	
	Запрос.УстановитьПараметр("Доверенность", Доверенность);
	
	РезультатыЗапроса = Запрос.ВыполнитьПакет();
	
	ВыборкиДанных = Новый Структура("ВыборкаРеквизитов, ВыборкаСтатусовЗапросов",
		РезультатыЗапроса[0].Выбрать(), РезультатыЗапроса[1].Выбрать());
	
	Возврат ВыборкиДанных;
	
КонецФункции

#КонецОбласти
