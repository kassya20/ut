	ИначеЕсли Форма.ДоступныеСпособыОтработкиАктаПоСостояниюЭДО.НайтиПоЗначению(
		ПредопределенноеЗначение("Перечисление.СпособыОтраженияАктовОРасхожденияПослеПоступления.ИсправлениеПервичныхДокументов")) = Неопределено Тогда
		
		Если Форма.Объект.ТипОснованияАктаОРасхождении = ПредопределенноеЗначение("Перечисление.ТипыОснованияАктаОРасхождении.ПриемкаТоваровНаХранение") Тогда
			ТекстПояснения = НСтр("ru = 'Электронный документ по приемке подтвержден. Возможно только исправление приемки.'");
		Иначе
			ТекстПояснения = НСтр("ru = 'Электронный документ по поступлению подтвержден. Возможно только исправление поступления.'");
		КонецЕсли;
		
	ИначеЕсли Не ДоступноИсправление Тогда
		
		Если Форма.Объект.ТипОснованияАктаОРасхождении = ПредопределенноеЗначение("Перечисление.ТипыОснованияАктаОРасхождении.ПриемкаТоваровНаХранение") Тогда
			ТекстПояснения = НСтр("ru = 'Электронный документ по приемке был отклонен. Возможно только изменение приемки.'");
		Иначе
			ТекстПояснения = НСтр("ru = 'Электронный документ по поступлению был отклонен. Возможно только изменение поступления.'");
		КонецЕсли;
		
	КонецЕсли;
	
	Если ДоступноИсправление И Не Форма.ИспользоватьИсправлениеДокументов Тогда
		СообщениеОНевозможностиИспользованияИсправления =
			НСтр("ru = 'Для того чтобы оформить исправление отдельным документом, включите функциональную опцию ""Исправление и сторно финансовых документов""'");
		Если ПустаяСтрока(ТекстПояснения) Тогда
			ТекстПояснения = СообщениеОНевозможностиИспользованияИсправления;
		Иначе
			ТекстПояснения = ТекстПояснения + Символы.ПС + СообщениеОНевозможностиИспользованияИсправления;
		КонецЕсли;
	КонецЕсли;
	
	Если ТребуетсяСообщениеОНесоответствииСпособа Тогда
		СообщениеОНесоответствииСпособа = НСтр("ru = 'Текущий способ отражения некорректен. Изменить его можно в статусе ""Не согласовано"" или ""Обеспечивается""'");
		ТекстПояснения = ТекстПояснения + Символы.ПС + СообщениеОНесоответствииСпособа;
	КонецЕсли;
	
	Возврат ТекстПояснения;
	
КонецФункции

Процедура ЗаполнитьДокументОснованиеВСтроке(СтрокаТаблицыТовары, ДокументыОснования) Экспорт

	Если Не СтрокаТаблицыТовары.ЗаполненоПоОснованию И Не ЗначениеЗаполнено(СтрокаТаблицыТовары.ДокументОснование) Тогда
		Если ДокументыОснования.Количество() = 1 Тогда
			СтрокаТаблицыТовары.ДокументОснование = ДокументыОснования[0].ДокументОснование;
			УстановитьПризнакОснованиеПоЗаказам(СтрокаТаблицыТовары, ДокументыОснования[0]);
			ЗаполнитьЗаказВСтроке(СтрокаТаблицыТовары, ДокументыОснования);
		КонецЕсли;
	КонецЕсли;

КонецПроцедуры

Процедура ЗаполнитьЗаказВСтроке(СтрокаТаблицыТовары, ДокументыОснования) Экспорт

	НайденныеСтроки = ДокументыОснования.НайтиСтроки(Новый Структура("ДокументОснование", СтрокаТаблицыТовары.ДокументОснование));
	Если НайденныеСтроки.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;

	НайденнаяСтрока = НайденныеСтроки[0];

	Если Не ЗначениеЗаполнено(СтрокаТаблицыТовары.Заказ) Тогда
		Если НайденнаяСтрока.ЗаказыОснования.Количество() = 1 Тогда
			СтрокаТаблицыТовары.Заказ = НайденнаяСтрока.ЗаказыОснования.Получить(0).Значение;
		КонецЕсли;
	КонецЕсли;

КонецПроцедуры

Процедура УстановитьПризнакОснованиеПоЗаказам(СтрокаТаблицыТовары, СтрокаДокументыОснования) Экспорт
	
	СтрокаТаблицыТовары.ОснованиеПоЗаказам = (СтрокаДокументыОснования.ЗаказыОснования.Количество() > 0);
	
КонецПроцедуры

Процедура УстановитьОтборСтатусаДинамическогоСписка(ДинамическийСписок, СтатусДляОтбора) Экспорт
	
	УстанавливаетсяОтбор = ЗначениеЗаполнено(СтатусДляОтбора);
	
	ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(ДинамическийСписок, 
	                                                                        "Статус",
	                                                                        СтатусДляОтбора, 
	                                                                        ВидСравненияКомпоновкиДанных.Равно,
	                                                                        ,
	                                                                        УстанавливаетсяОтбор);
	
	ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(ДинамическийСписок, 
	                                                                        "Проведен",
	                                                                        Истина, 
	                                                                        ВидСравненияКомпоновкиДанных.Равно,
	                                                                        ,
	                                                                        УстанавливаетсяОтбор);
	
КонецПроцедуры

Процедура ЗаполнитьСделкуВСтроке(ТекущиеДанные, ЗаказыСделки) Экспорт

	Если ТекущиеДанные.ОснованиеПоЗаказам И ЗначениеЗаполнено(ТекущиеДанные.ЗаказПоставщику) Тогда
		
		НайденныеСтроки = ЗаказыСделки.НайтиСтроки(Новый Структура("ЗаказПоставщику", ТекущиеДанные.ЗаказПоставщику));
		Если НайденныеСтроки.Количество() > 0 Тогда
			ТекущиеДанные.Сделка = НайденныеСтроки[0].Сделка;
			Возврат;
		КонецЕсли;
	
	КонецЕсли;
	
	ТекущиеДанные.Сделка = ПредопределенноеЗначение("Справочник.СделкиСКлиентами.ПустаяСсылка");
	
КонецПроцедуры

Функция ИменаРеквизитовВЗависимостиОтТипаАкта(ЭтоАктОРасхожденияхПослеОтгрузки) Экспорт
	
	СтруктураИмен = Новый Структура;
	СтруктураИмен.Вставить("ЗаполненоПоОснованию", ?(ЭтоАктОРасхожденияхПослеОтгрузки,"ЗаполненоПоРеализации","ЗаполненоПоОснованию"));
	СтруктураИмен.Вставить("Основание", ?(ЭтоАктОРасхожденияхПослеОтгрузки,"Реализация","ДокументОснование"));
	СтруктураИмен.Вставить("Заказ", ?(ЭтоАктОРасхожденияхПослеОтгрузки,"ЗаказКлиента","ЗаказПоставщику"));
	СтруктураИмен.Вставить("ОснованиеПоЗаказам", ?(ЭтоАктОРасхожденияхПослеОтгрузки,"РеализацияПоЗаказам","ОснованиеПоЗаказам"));
	
	Возврат СтруктураИмен;
	
КонецФункции

// Процедура рассчитывает итоговые показатели формы.
// 
// Параметры:
//  Форма - ФормаКлиентскогоПриложения - форма документа Акта о расхождениях
//
Процедура РассчитатьИтоговыеПоказателиФормы(Форма) Экспорт
	
	Форма.Недостачи = 0;
	Форма.Излишки   = 0;
	Форма.НедостачиСуммаНДС = 0;
	Форма.ИзлишкиСуммаНДС   = 0;
	Форма.ЕстьИзлишки     = Ложь;
	Форма.ЕстьНедостачи   = Ложь;
	
	Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(Форма.Объект, "ХозяйственнаяОперация")
		И Форма.Объект.ХозяйственнаяОперация =
		ПредопределенноеЗначение("Перечисление.ХозяйственныеОперации.ОтгрузкаТоваровКлиенту") Тогда
		
		ОтображатьИтогСуммыНДС = Ложь;
		
	Иначе
		
		ОтображатьИтогСуммыНДС = УчетНДСУПКлиентСервер.ОтображатьНДСВИтогахДокументаПродажи(
			Форма.Объект.НалогообложениеНДС);
		
	КонецЕсли;
	
	Для Каждого СтрокаТовары Из Форма.Объект.Товары Цикл
		
		Если ОтображатьИтогСуммыНДС Тогда
			Если СтрокаТовары.СуммаСНДСРасхождения > 0 Тогда
				Форма.Излишки = Форма.Излишки + СтрокаТовары.СуммаСНДСРасхождения;
				Форма.ИзлишкиСуммаНДС = Форма.ИзлишкиСуммаНДС + СтрокаТовары.СуммаНДСРасхождения;
			ИначеЕсли СтрокаТовары.СуммаСНДСРасхождения < 0 Тогда
				Форма.Недостачи = Форма.Недостачи + (-СтрокаТовары.СуммаСНДСРасхождения);
				Форма.НедостачиСуммаНДС = Форма.НедостачиСуммаНДС + (-СтрокаТовары.СуммаНДСРасхождения);
			КонецЕсли;
		Иначе
			Если СтрокаТовары.СуммаРасхождения > 0 Тогда
				Форма.Излишки = Форма.Излишки + СтрокаТовары.СуммаРасхождения;
			ИначеЕсли СтрокаТовары.СуммаРасхождения < 0 Тогда
				Форма.Недостачи = Форма.Недостачи + (-СтрокаТовары.СуммаРасхождения);
			КонецЕсли;
		КонецЕсли;
		
		Если СтрокаТовары.КоличествоУпаковокРасхождения < 0 Тогда
			Форма.ЕстьНедостачи = Истина;
		КонецЕсли;
		Если СтрокаТовары.КоличествоУпаковокРасхождения > 0 Тогда
			Форма.ЕстьИзлишки = Истина;
		КонецЕсли;
		
	КонецЦикла;
	
	Если ОтображатьИтогСуммыНДС Тогда
		Форма.Расхождения = Форма.Объект.Товары.Итог("СуммаСНДС") - Форма.Объект.Товары.Итог("СуммаСНДСПоДокументу");
		Форма.РасхожденияСуммаНДС = Форма.Объект.Товары.Итог("СуммаНДС") - Форма.Объект.Товары.Итог("СуммаНДСПоДокументу");
	Иначе
		Форма.Расхождения = Форма.Объект.Товары.Итог("Сумма") - Форма.Объект.Товары.Итог("СуммаПоДокументу");
	КонецЕсли;
	
	Форма.Элементы.ГруппаИтогиБезНДС.Видимость = Не ОтображатьИтогСуммыНДС;
	Форма.Элементы.ГруппаИтогиСНДС.Видимость = ОтображатьИтогСуммыНДС;
	
КонецПроцедуры

Функция ЭтоАктОРасхожденияхПослеОтгрузки(ТипОснованияАктаОРасхождении) Экспорт
	
	Возврат ТипОснованияРеализацияТоваровУслуг(ТипОснованияАктаОРасхождении)
		Или ТипОснованияОтгрузкаТоваровКлиенту(ТипОснованияАктаОРасхождении)
		Или ТипОснованияОтгрузкаТоваровСХранения(ТипОснованияАктаОРасхождении)
		Или ТипОснованияПередачаТоваровХранителю(ТипОснованияАктаОРасхождении)
		Или ТипОснованияВозвратПоставщику(ТипОснованияАктаОРасхождении)
		Или ТипОснованияПередачаНаКомиссию(ТипОснованияАктаОРасхождении);
	
КонецФункции

// Изменить действие в строке.
// 
// Параметры:
// 	Строка - СтрокаТаблицыЗначений - содержит в том числе:
// 		* Действие - ПеречислениеСсылка.ВариантыДействийПоРасхождениямВАктеПослеОтгрузки, ПеречислениеСсылка.ВариантыДействийПоРасхождениямВАктеПослеПриемки -
// 	ДействиеСДокументомНедостачи            - ПеречислениеСсылка.ВариантыДействийПоРасхождениямВАктеПослеОтгрузки - 
// 	ДействиеСДокументомИзлишки              - ПеречислениеСсылка.ВариантыДействийПоРасхождениямВАктеПослеОтгрузки -
// 	ДействиеСТоваромНедостачи               - ПеречислениеСсылка.ВариантыДействийПоТоварамВАктеПослеОтгрузки -
// 	ДействиеСТоваромИзлишки                 - ПеречислениеСсылка.ВариантыДействийПоТоварамВАктеПослеОтгрузки -
// 	ПоВинеСтороннейКомпании                 - Булево -

// 
// Возвращаемое значение:
//  Булево - Изменить действие в строке
Функция ИзменитьДействиеВСтроке(
	Строка,
	ДействиеСДокументомНедостачи,
	ДействиеСДокументомИзлишки,
	ДействиеСТоваромНедостачи = Неопределено,
	ДействиеСТоваромИзлишки = Неопределено,
	ПоВинеСтороннейКомпании = Неопределено) Экспорт
	
	Если ЗначениеЗаполнено(ДействиеСДокументомНедостачи)
		И Строка.КоличествоУпаковокРасхождения < 0 Тогда
		ДействиеСДокументом = ДействиеСДокументомНедостачи;
	Иначе
		ДействиеСДокументом = ДействиеСДокументомИзлишки;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ДействиеСТоваромНедостачи)
		И Строка.КоличествоУпаковокРасхождения < 0 Тогда
		ДействиеСТоваром = ДействиеСТоваромНедостачи;
	ИначеЕсли ЗначениеЗаполнено(ДействиеСТоваромИзлишки) Тогда
		ДействиеСТоваром = ДействиеСТоваромИзлишки;
	КонецЕсли;
	
	ЕстьРеквизитПоВинеСтороннейКомпании = ПоВинеСтороннейКомпании <> Неопределено;
	ЕстьРеквизитДействиеСТоваром =
		(ДействиеСТоваромНедостачи <> Неопределено)
			Или (ДействиеСТоваромИзлишки <> Неопределено);
	
	Если Строка.Действие = ДействиеСДокументом
		И (Не ЕстьРеквизитДействиеСТоваром
			Или Строка.ДействиеСТоваром = ДействиеСТоваром) Тогда
		
		Если ЕстьРеквизитПоВинеСтороннейКомпании Тогда
			Если Строка.ПоВинеСтороннейКомпании = ПоВинеСтороннейКомпании Тогда
				Возврат Ложь;
			КонецЕсли;
		Иначе
			Возврат Ложь;
		КонецЕсли;
		
	КонецЕсли;
	
	Если ДействиеСДокументом = ПредопределенноеЗначение("Перечисление.ВариантыДействийПоРасхождениямВАктеПослеОтгрузки.ПокупкаПерепоставленного")
		Или ДействиеСДокументом = ПредопределенноеЗначение("Перечисление.ВариантыДействийПоРасхождениямВАктеПослеОтгрузки.ВозвратПерепоставленного")
		Или ДействиеСДокументом = ПредопределенноеЗначение("Перечисление.ВариантыДействийПоРасхождениямВАктеПослеОтгрузки.ОприходоватьСейчас")
		Или ДействиеСДокументом = ПредопределенноеЗначение("Перечисление.ВариантыДействийПоРасхождениямВАктеПослеОтгрузки.ПерепоставленноеДарится")
		Или ДействиеСДокументом = ПредопределенноеЗначение("Перечисление.ВариантыДействийПоРасхождениямВАктеПослеПриемки.ВернутьПерепоставленноеБезОформления")
		Или ДействиеСДокументом = ПредопределенноеЗначение("Перечисление.ВариантыДействийПоРасхождениямВАктеПослеПриемки.ОтнестиПерепоставленноеНаПрочиеДоходы")
		Или ДействиеСДокументом = ПредопределенноеЗначение("Перечисление.ВариантыДействийПоРасхождениямВАктеПослеПриемки.ОформитьПерепоставленноеИВернуть")
		Или ДействиеСДокументом = ПредопределенноеЗначение("Перечисление.ВариантыДействийПоРасхождениямВАктеПослеПриемки.ОформитьПерепоставленное")
		Или ДействиеСТоваром = ПредопределенноеЗначение("Перечисление.ВариантыДействийПоТоварамВАктеПослеОтгрузки.ОприходоватьВПуть") Тогда
		
		Если НЕ Строка.КоличествоУпаковокРасхождения > 0 Тогда
			Возврат Ложь;
		КонецЕсли;
		
	ИначеЕсли ДействиеСДокументом = ПредопределенноеЗначение("Перечисление.ВариантыДействийПоРасхождениямВАктеПослеОтгрузки.ТребуетсяДопоставка")
		Или ДействиеСДокументом = ПредопределенноеЗначение("Перечисление.ВариантыДействийПоРасхождениямВАктеПослеОтгрузки.ДопоставкаНеТребуется")
		Или ДействиеСДокументом = ПредопределенноеЗначение("Перечисление.ВариантыДействийПоРасхождениямВАктеПослеОтгрузки.ОтгрузитьСейчас")
		Или ДействиеСДокументом = ПредопределенноеЗначение("Перечисление.ВариантыДействийПоРасхождениямВАктеПослеОтгрузки.НедостачаНеПризнана")
		Или ДействиеСДокументом = ПредопределенноеЗначение("Перечисление.ВариантыДействийПоРасхождениямВАктеПослеПриемки.ОформитьНедостачу")
		Или ДействиеСДокументом = ПредопределенноеЗначение("Перечисление.ВариантыДействийПоРасхождениямВАктеПослеПриемки.ОформитьНедостачуИОжидатьДопоставку")
		Или ДействиеСДокументом = ПредопределенноеЗначение("Перечисление.ВариантыДействийПоРасхождениямВАктеПослеПриемки.ОтнестиНедостачуНаПрочиеРасходы")
		Или ДействиеСДокументом = ПредопределенноеЗначение("Перечисление.ВариантыДействийПоРасхождениямВАктеПослеПриемки.ОжидатьДопоставкуБезОформления")
		Или ДействиеСТоваром = ПредопределенноеЗначение("Перечисление.ВариантыДействийПоТоварамВАктеПослеОтгрузки.Списать")
		Или ДействиеСТоваром = ПредопределенноеЗначение("Перечисление.ВариантыДействийПоТоварамВАктеПослеОтгрузки.СписатьИзПути")
		Или ДействиеСТоваром = ПредопределенноеЗначение("Перечисление.ВариантыДействийПоТоварамВАктеПослеОтгрузки.Вернуть")
		Или ДействиеСТоваром = ПредопределенноеЗначение("Перечисление.ВариантыДействийПоТоварамВАктеПослеОтгрузки.Ожидать") Тогда
		
		Если НЕ Строка.КоличествоУпаковокРасхождения < 0 Тогда
			Возврат Ложь;
		КонецЕсли;
		
	КонецЕсли;
	
	Если (Строка.ТипНоменклатуры = ПредопределенноеЗначение("Перечисление.ТипыНоменклатуры.Услуга")
		Или Строка.ТипНоменклатуры = ПредопределенноеЗначение("Перечисление.ТипыНоменклатуры.Работа")) Тогда
		
		Если ДействиеСДокументом = ПредопределенноеЗначение("Перечисление.ВариантыДействийПоРасхождениямВАктеПослеОтгрузки.ВозвратПерепоставленного")
			Или ДействиеСДокументом = ПредопределенноеЗначение("Перечисление.ВариантыДействийПоРасхождениямВАктеПослеПриемки.ОтнестиНедостачуНаПрочиеРасходы") 
			Или ДействиеСДокументом = ПредопределенноеЗначение("Перечисление.ВариантыДействийПоРасхождениямВАктеПослеПриемки.ОформитьПерепоставленноеИВернуть") Тогда
			Возврат Ложь;
		КонецЕсли;
		
	КонецЕсли;
	
	Строка.Действие = ДействиеСДокументом;
	Если ЗначениеЗаполнено(ДействиеСТоваром) Тогда
		Строка.ДействиеСТоваром = ДействиеСТоваром;
	КонецЕсли;
	
	Если ЕстьРеквизитПоВинеСтороннейКомпании Тогда
		Если ДействиеСДокументом = ПредопределенноеЗначение("Перечисление.ВариантыДействийПоРасхождениямВАктеПослеПриемки.ОтнестиНедостачуНаПрочиеРасходы") Тогда
			Строка.ПоВинеСтороннейКомпании =  ПоВинеСтороннейКомпании;
		Иначе
			Строка.ПоВинеСтороннейКомпании =  Ложь;
		КонецЕсли;
	КонецЕсли;
	
	Возврат Истина;
	
КонецФункции

// Заполняет реквизиты строки для многооборотной тары
// 
// Параметры:
// 	Форма - ДанныеФормыСтруктура - Форма, в которой необходимо заполнить информацию
// 	ДокументыОснования - ДинамическийСписок - Документы, откуда необходимо взять информацию. Должны содержать:
// 		* ВернутьМногооборотнуюТару - Булево - 
// 		* ТребуетсяЗалогЗаТару - Булево - 
//
Процедура ЗаполнитьРеквизитыМногооборотнойТары(Форма, ДокументыОснования) Экспорт
	
	ТекущийДокументОснования = Неопределено;
	НайденнаяСтрока = Неопределено;
	Для каждого СтрокаТаблицыТовары Из Форма.Товары Цикл
		
		Если ТекущийДокументОснования <> СтрокаТаблицыТовары.Реализация Тогда
			ТекущийДокументОснования = СтрокаТаблицыТовары.Реализация;
			НайденныеСтроки = ДокументыОснования.НайтиСтроки(Новый Структура("Реализация", ТекущийДокументОснования));		
			Если НайденныеСтроки.Количество() > 0 Тогда
				НайденнаяСтрока = НайденныеСтроки[0];
			иначе	
				НайденнаяСтрока = Неопределено;
			КонецЕсли;
		КонецЕсли;
		
		Если НайденнаяСтрока <> Неопределено Тогда
			ЗаполнитьРеквизитыМногооборотнойТарыВСтроке(СтрокаТаблицыТовары, НайденнаяСтрока);		
		КонецЕсли;
	
	КонецЦикла;
	
КонецПроцедуры

Процедура ЗаполнитьРеквизитыМногооборотнойТарыВСтроке(СтрокаТаблицыТовары, СтрокаДокументыОснования) Экспорт
	
	СтрокаТаблицыТовары.ВернутьМногооборотнуюТару = СтрокаДокументыОснования.ВернутьМногооборотнуюТару;
	СтрокаТаблицыТовары.ТребуетсяЗалогЗаТару 	  = СтрокаДокументыОснования.ТребуетсяЗалогЗаТару;	
	
КонецПроцедуры


#КонецОбласти

