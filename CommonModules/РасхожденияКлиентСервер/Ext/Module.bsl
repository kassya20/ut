	ТипыОснованияАкта.Добавить(
		ПредопределенноеЗначение("Перечисление.ТипыОснованияАктаОРасхождении.ВозвратПоставщику"));
	ТипыОснованияАкта.Добавить(
		ПредопределенноеЗначение("Перечисление.ТипыОснованияАктаОРасхождении.ОтгрузкаТоваровСХранения"));
	ТипыОснованияАкта.Добавить(
		ПредопределенноеЗначение("Перечисление.ТипыОснованияАктаОРасхождении.ПередачаТоваровХранителю"));
	ТипыОснованияАкта.Добавить(
		ПредопределенноеЗначение("Перечисление.ТипыОснованияАктаОРасхождении.ПередачаНаКомиссию"));
	
