// @strict-types

#Область СлужебныйПрограммныйИнтерфейс

// Параметры:
//  АдресЗначение - Строка - JSON представление адреса
// 
// Возвращаемое значение:
//  Строка - идентификатор адреса
//
Функция ИдентификаторАдресаТочкиДоставки(АдресЗначение) Экспорт
	
	НайденныйИдентификатор = "";
	
	//++ Локализация
	Если НЕ ПустаяСтрока(АдресЗначение) Тогда
		
		СтруктураАдреса = JSONВКонтактнуюИнформациюПоПолям(
			АдресЗначение,
			Перечисления.ТипыКонтактнойИнформации.Адрес);
		
		Если АдресРФ(СтруктураАдреса) Тогда
			
			НайденныйИдентификатор = ИдентификаторАдресаНижнегоУровня(СтруктураАдреса);
			
		КонецЕсли;
		
	КонецЕсли;
	//-- Локализация
	
	Возврат НайденныйИдентификатор;
	
КонецФункции

// Параметры:
//  СведенияОбАдресе - см. УправлениеКонтактнойИнформацией.СведенияОбАдресе
//
Процедура УстановитьТипАдресаВСвободнойФорме(СведенияОбАдресе) Экспорт
	
	//++ Локализация
	ПредставлениеАдминистративныйАдрес = "Административно-территориальный";
	ПредставлениеСвободныйАдрес = "ВСвободнойФорме";
	Если СведенияОбАдресе.Свойство("ТипАдреса")
		И (СтрСравнить(СведенияОбАдресе.ТипАдреса, ПредставлениеАдминистративныйАдрес) = 0) Тогда
		
		СведенияОбАдресе.ТипАдреса = ПредставлениеСвободныйАдрес;
		
	КонецЕсли;
	//-- Локализация
	
	Возврат;
	
КонецПроцедуры

// Параметры:
//  Адрес - Строка - текстовое представление адреса
//  АдресЗначение - Строка - JSON представление адреса
//  ВСвободнойФорме - Булево, Неопределено -
// 
// Возвращаемое значение:
//  Строка -
//
Функция НаименованиеТочкиДоставкиПоАдресу(Адрес, АдресЗначение, ВСвободнойФорме = Неопределено) Экспорт
	
	Результат = Адрес;
	
	//++ Локализация
	
	Если НЕ ПустаяСтрока(АдресЗначение) Тогда
		
		Если ВСвободнойФорме = Неопределено Тогда
			
			ВСвободнойФорме = УправлениеКонтактнойИнформацией.АдресВведенВСвободнойФорме(АдресЗначение);
			
		КонецЕсли;
			
		Если НЕ ВСвободнойФорме Тогда
			
			Результат = Справочники.ТочкиДоставки.СокращенноеПредставлениеАдреса(АдресЗначение);
			
		КонецЕсли;
		
	КонецЕсли;
	
	//-- Локализация
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

//++ Локализация
Функция ИменаУровнейАдресаПоАдресу(СтруктураАдреса)
	
	ТипАдреса = СтруктураАдреса.addressType;
	
	Уровни = Новый Массив; // Массив из Строка
	Если РаботаСАдресамиКлиентСервер.ЭтоМуниципальныйАдрес(ТипАдреса)
	   И ЗначениеЗаполнено(СтруктураАдреса.munLevels) Тогда
		
		Уровни = СтруктураАдреса.munLevels;
		
	ИначеЕсли РаботаСАдресамиКлиентСервер.ЭтоАдминистративноТерриториальныйАдрес(ТипАдреса)
			И ЗначениеЗаполнено(СтруктураАдреса.admLevels) Тогда
			
		Уровни = СтруктураАдреса.admLevels;
			
	КонецЕсли;
	
	Если Уровни.Количество() > 0 Тогда
		
		Если Уровни.Найти("house") = Неопределено Тогда
			Уровни.Добавить("house");
		КонецЕсли;
		
		Если Уровни.Найти("stead") = Неопределено Тогда
			Уровни.Добавить("stead");
		КонецЕсли;
		
		УровниАдреса = Уровни;
		
	Иначе
		
		УровниАдреса = ИменаУровнейАдресаПоТипу(ТипАдреса);
		
	КонецЕсли;
	
	Возврат УровниАдреса;
	
КонецФункции

Функция ИменаУровнейАдресаПоТипу(ТипАдреса)
	
	Уровни = Новый Массив; // Массив из Строка
	
	Уровни.Добавить("area");
	Если РаботаСАдресамиКлиентСервер.ЭтоМуниципальныйАдрес(ТипАдреса) Тогда
		
		Уровни.Добавить("munDistrict");
		Уровни.Добавить("settlement");
		
	Иначе
		
		Уровни.Добавить("district");
		
	КонецЕсли;
	
	Уровни.Добавить("city");
	Уровни.Добавить("locality");
	Уровни.Добавить("territory");
	
	Уровни.Добавить("street");
	Уровни.Добавить("house");
	
	Возврат Уровни;
	
КонецФункции

Функция АдресРФ(СтруктураАдреса)
	
	ТипАдреса = СтруктураАдреса.addressType;
	
	Результат = РаботаСАдресамиКлиентСервер.ЭтоАдминистративноТерриториальныйАдрес(ТипАдреса)
				ИЛИ РаботаСАдресамиКлиентСервер.ЭтоМуниципальныйАдрес(ТипАдреса);
	
	Возврат Результат;
	
КонецФункции

Функция ИдентификаторАдресаНижнегоУровня(СтруктураАдреса)
	
	НайденныйИдентификатор = "";
	УровниАдреса = ИменаУровнейАдресаПоАдресу(СтруктураАдреса);
	
	ШаблонИдентификатора = "%1Id";
	
	Для ОбратныйИндекс = -УровниАдреса.ВГраница() По 0 Цикл
		
		ИмяУровня = УровниАдреса[-ОбратныйИндекс];
		ИмяИдентификатора = СтрШаблон(ШаблонИдентификатора, ИмяУровня);
		
		ЗначениеИдентификатора = Неопределено;
		Если СтруктураАдреса.Свойство(ИмяИдентификатора, ЗначениеИдентификатора)
		   И ЗначениеЗаполнено(ЗначениеИдентификатора) Тогда
			
			НайденныйИдентификатор = Строка(ЗначениеИдентификатора);
			Прервать;
			
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат НайденныйИдентификатор;
	
КонецФункции

// Параметры:
//  Значение - Строка 
//  ТипКонтактнойИнформации - СправочникСсылка.ВидыКонтактнойИнформации
//                          - Структура 
//                          - ПеречислениеСсылка.ТипыКонтактнойИнформации
//
// Возвращаемое значение:
//   см. РаботаСАдресамиКлиентСервер.ОписаниеНовойКонтактнойИнформации
//
Функция JSONВКонтактнуюИнформациюПоПолям(Знач Значение, ТипКонтактнойИнформации)
	
	Значение = СтрЗаменить(Значение, "\R\N", "\r\n"); // исправление перевода строки
	
	КонтактнаяИнформация = СтрокуJSONВСтруктуру(Значение);
	Результат = ОписаниеНовойКонтактнойИнформацииАдреса();
	ЗаполнитьЗначенияСвойств(Результат, КонтактнаяИнформация);
	
	Возврат Результат;
	
КонецФункции

Функция СтрокуJSONВСтруктуру(Значение)
	
	ЧтениеJSON = Новый ЧтениеJSON;
	ЧтениеJSON.УстановитьСтроку(Значение);
	
	Попытка
		
		Результат = ПрочитатьJSON(ЧтениеJSON,,,, "ВосстановлениеПолейКонтактнойИнформации", 
			УправлениеКонтактнойИнформациейСлужебный);
			
	Исключение
		
		Событие = НСтр("ru = 'Контактная информация'", ОбщегоНазначения.КодОсновногоЯзыка());
		ТекстОшибки = НСтр("ru = 'Некорректная контактная информация.'");
		ЗаписьЖурналаРегистрации(Событие,
			УровеньЖурналаРегистрации.Ошибка,,,
			ТекстОшибки + Символы.ПС + Строка(Значение));
			
		Результат = Новый Структура;
		
	КонецПопытки;
	
	ЧтениеJSON.Закрыть();
	Возврат Результат;
	
КонецФункции

// Описание национальных полей структуры контактной информации для хранения ее в формате JSON.
// Основной список полей определяется в одноименной функции общего модуля УправлениеКонтактнойИнформациейКлиентСервер.
//
// Возвращаемое значение:
//   Структура - поля контактной информации для типа Адрес добавленные к основным полям:
//     * value - Строка - представление контактной информации.
//     * comment - Строка - комментарий.
//     * type - Строка - тип контактной информации. См. значение в Перечисление.ТипыКонтактнойИнформации.Адрес.
//     * country - Строка - наименование страны, например "Уругвай".
//     * countryCode - Строка -код страны.
//     * ZIPcode- Строка - почтовый индекс.
//     * id - Строка -  идентификационный код последнего адресного объекта в иерархи адреса.
//     * addressType - Строка - установленный пользователем тип адреса(только для адресов РФ).
//                              Варианты: "Муниципальный", "Административно-территориальный".
//     * area - Строка - наименование региона.
//     * areaType - Строка - сокращение(тип) региона.
//     * areaCode - Строка - код региона РФ.
//     * areaID - Строка - идентификатор региона.
//     * district - Строка - представление района у адресов по административно-территориальному делению.
//     * districtType - Строка - сокращение района у адресов по административно-территориальному делению.
//     * districtID - Строка - идентификатор региона у адресов по административно-территориальному делению.
//     * munDistrict - Строка - представление муниципального района у адресов по муниципальному делению.
//     * munDistrictType - Строка - сокращение муниципального района у адресов по муниципальному делению.
//     * munDistrictID - Строка - идентификатор муниципального района у адресов по муниципальному делению.
//     * city - Строка - наименование города.
//     * cityType - Строка - сокращение (тип) города, например "г".
//     * cityID - Строка - идентификатор муниципального города у адресов по административно-территориальному делению.
//     * settlement - Строка - представление поселения у адресов по муниципальному делению.
//     * settlementType - Строка - сокращение поселения у адресов по муниципальному делению.
//     * settlementID - Строка - идентификатор поселения.
//     * cityDistrict - Строка - представление внутригородского района.
//     * cityDistrictType - Строка - сокращение внутригородского района.
//     * cityDistrictID - Строка - идентификатор внутригородского района.
//     * territory - Строка - представление территории.
//     * territoryType - Строка - сокращение территории.
//     * territoryID - Строка - идентификатор территории.
//     * locality - Строка - представление населенного пункта.
//     * localityType - Строка - сокращение населенного пункта.
//     * localityID - Строка - идентификатор населенного пункта.
//     * street - Строка - название улицы, проспекта, переулка и т.д.. Но также может содержать номер дома, квартиры или
//                         офиса.
//     * streetType - Строка - сокращение (тип) улицы, например "ул".
//     * streetID - Строка - идентификатор улицы.
//     * houseType - Строка - тип дома, владения.
//     * houseNumber - Строка - дополнительное поле, которое используется для уточнения или добавления информации. 
//                              Например, номер дома, Название здания, номер подъезда или этаж
//     * houseID - Строка - идентификатор дома.
//     * apartmentId - Строка - идентификатор помещения.
//     * buildings - Массив - содержит структуры(поля структуры: type, number) с перечнем корпусов (строений) адреса.
//     * apartments - Массив - содержит структуры(поля структуры: type, number) с перечнем помещений адреса.
//     * stead - Строка - земельный участок.
//     * steadId - Строка - идентификатор земельного участка.
//     * codeKLADR - Строка - код КЛАДР.
//     * oktmo - Строка - код ОКТМО.
//     * oktmoBudget - Строка - код ОКТМО бюджетополучателя.
//     * okato - Строка - код ОКАТО.
//     * ifnsFLCode - Строка - код ИФНСФЛ.
//     * ifnsULCode - Строка - код ИФНСЮЛ.
//     * ifnsFLAreaCode - Строка - код участка ИФНСФЛ.
//     * ifnsULAreaCode - Строка - код участка ИФНСЮЛ.
//     * admLevels - Массив - порядок административных полей в представлении адреса
//     * munLevels - Массив - порядок муниципальных полей в представлении адреса
//
Функция ОписаниеНовойКонтактнойИнформацииАдреса()
	
	Результат = УправлениеКонтактнойИнформациейКлиентСервер.ОписаниеНовойКонтактнойИнформации(
		Перечисления.ТипыКонтактнойИнформации.Адрес);
	
	Результат.Вставить("id", "");
	Результат.Вставить("areaCode", "");
	Результат.Вставить("areaId", "");
	Результат.Вставить("areaValue", "");
	Результат.Вставить("district", "");
	Результат.Вставить("districtType", "");
	Результат.Вставить("districtId", "");
	Результат.Вставить("munDistrict", "");
	Результат.Вставить("munDistrictType", "");
	Результат.Вставить("munDistrictId", "");
	Результат.Вставить("cityId", "");
	Результат.Вставить("settlement", "");
	Результат.Вставить("settlementType", "");
	Результат.Вставить("settlementId", "");
	Результат.Вставить("cityDistrict", "");
	Результат.Вставить("cityDistrictType", "");
	Результат.Вставить("cityDistrictId", "");
	Результат.Вставить("territory", "");
	Результат.Вставить("territoryType", "");
	Результат.Вставить("territoryId", "");
	Результат.Вставить("locality", "");
	Результат.Вставить("localityType", "");
	Результат.Вставить("localityId", "");
	Результат.Вставить("streetId", "");
	Результат.Вставить("houseType", "");
	Результат.Вставить("houseId", "");
	Результат.Вставить("apartmentId", "");
	Результат.Вставить("buildings", Новый Массив);
	Результат.Вставить("apartments", Новый Массив);
	Результат.Вставить("codeKLADR", "");
	Результат.Вставить("oktmo", "");
	Результат.Вставить("oktmoBudget", "");
	Результат.Вставить("okato", "");
	Результат.Вставить("asInDocument", "");
	Результат.Вставить("ifnsFLCode", "");
	Результат.Вставить("ifnsULCode", "");
	Результат.Вставить("ifnsFLAreaCode", "");
	Результат.Вставить("ifnsULAreaCode", "");
	Результат.Вставить("stead", "");
	Результат.Вставить("steadId", "");
	Результат.Вставить("admLevels", Новый Массив);
	Результат.Вставить("munLevels", Новый Массив);
	
	Возврат Результат;
	
КонецФункции
//-- Локализация

#КонецОбласти