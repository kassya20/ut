// См. ИнтеграцияShareПереопределяемый.ЗаполнитьНастройкиФормированияДокумента.
Процедура ЗаполнитьНастройкиФормированияДокумента(СсылкаНаДокумент, НастройкиФормирования) Экспорт
	
	ПоддерживаемыеФорматыЭДО = ОбменСКонтрагентами.ФорматыДокументов();
	ТипыДокументов           = ОбменСКонтрагентами.ТипыДокументов();
	НаправленияДокументов    = ОбменСКонтрагентами.НаправленияДокументов();
	
	ТипИсточника = ТипЗнч(СсылкаНаДокумент);

	Если ТипИсточника = Тип("ДокументСсылка.ЗаказПоставщику") Тогда
		
		Реквизиты = "Организация, Контрагент, Договор";
		ЗначенияРеквизитов = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(СсылкаНаДокумент, Реквизиты);
		
		НастройкиФормирования.ТипДокумента       = ТипыДокументов.ЗаказТовара;
		НастройкиФормирования.Формат             = ПоддерживаемыеФорматыЭДО.CML208;
		НастройкиФормирования.Направление        = НаправленияДокументов.Исходящий;
		НастройкиФормирования.Организация        = ЗначенияРеквизитов.Организация;
		НастройкиФормирования.Контрагент         = ЗначенияРеквизитов.Контрагент;
		НастройкиФормирования.ДоговорКонтрагента = ЗначенияРеквизитов.Договор;
		
	ИначеЕсли ТипИсточника = Тип("ДокументСсылка.ЗаказКлиента") Тогда
		
		Реквизиты = "Организация, Контрагент, Договор";
		ЗначенияРеквизитов = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(СсылкаНаДокумент, Реквизиты);
		
		НастройкиФормирования.ТипДокумента       = ТипыДокументов.ОтветНаЗаказ;
		НастройкиФормирования.Формат             = ПоддерживаемыеФорматыЭДО.CML208;
		НастройкиФормирования.Направление        = НаправленияДокументов.Исходящий;
		НастройкиФормирования.Организация        = ЗначенияРеквизитов.Организация;
		НастройкиФормирования.Контрагент         = ЗначенияРеквизитов.Контрагент;
		НастройкиФормирования.ДоговорКонтрагента = ЗначенияРеквизитов.Договор;
		
	ИначеЕсли ТипИсточника = Тип("ДокументСсылка.СчетНаОплатуКлиенту") Тогда
		
		Реквизиты = "Организация, Контрагент, Договор";
		ЗначенияРеквизитов = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(СсылкаНаДокумент, Реквизиты);
		
		НастройкиФормирования.ТипДокумента       = ТипыДокументов.СчетНаОплату;
		НастройкиФормирования.Формат             = ПоддерживаемыеФорматыЭДО.CML208;
		НастройкиФормирования.Направление        = НаправленияДокументов.Исходящий;
		НастройкиФормирования.Организация        = ЗначенияРеквизитов.Организация;
		НастройкиФормирования.Контрагент         = ЗначенияРеквизитов.Контрагент;
		НастройкиФормирования.ДоговорКонтрагента = ЗначенияРеквизитов.Договор;

	ИначеЕсли ТипИсточника = Тип("ДокументСсылка.СверкаВзаиморасчетов2_5_11") Тогда

		Реквизиты = "Организация, Контрагент, Договор";
		ЗначенияРеквизитов = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(СсылкаНаДокумент, Реквизиты);
		
		НастройкиФормирования.ТипДокумента       = ТипыДокументов.АктСверкиВзаиморасчетов;
		НастройкиФормирования.Формат             = ПоддерживаемыеФорматыЭДО.ФНС.АктСверкиВзаиморасчетов.ИнформацияОтправителя;
		НастройкиФормирования.Направление        = НаправленияДокументов.Исходящий;
		НастройкиФормирования.Организация        = ЗначенияРеквизитов.Организация;
		НастройкиФормирования.Контрагент         = ЗначенияРеквизитов.Контрагент;
		НастройкиФормирования.ДоговорКонтрагента = ЗначенияРеквизитов.Договор;
		НастройкиФормирования.ЭтоФорматФНС       = Истина;
		
	ИначеЕсли ТипИсточника = Тип("ДокументСсылка.КоммерческоеПредложениеКлиенту") Тогда
		
		Реквизиты = "Организация, Контрагент";
		ЗначенияРеквизитов = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(СсылкаНаДокумент, Реквизиты);
		
		НастройкиФормирования.ТипДокумента = ТипыДокументов.КоммерческоеПредложение;
		НастройкиФормирования.Формат       = ПоддерживаемыеФорматыЭДО.БизнесСеть.КоммерческиеПредложения;
		НастройкиФормирования.Направление  = НаправленияДокументов.Исходящий;
		НастройкиФормирования.Организация  = ЗначенияРеквизитов.Организация;
		НастройкиФормирования.Контрагент   = ЗначенияРеквизитов.Контрагент;
		
	ИначеЕсли ТипИсточника = Тип("ДокументСсылка.ОтчетКомитенту") Тогда
		
		Реквизиты = "Организация, Контрагент, Договор";
		ЗначенияРеквизитов = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(СсылкаНаДокумент, Реквизиты);
		
		НастройкиФормирования.ТипДокумента       = ТипыДокументов.ОтчетОПродажахКомиссионногоТовара;
		НастройкиФормирования.Формат             = ПоддерживаемыеФорматыЭДО.CML208;
		НастройкиФормирования.Направление        = НаправленияДокументов.Исходящий;
		НастройкиФормирования.Организация        = ЗначенияРеквизитов.Организация;
		НастройкиФормирования.Контрагент         = ЗначенияРеквизитов.Контрагент;
		НастройкиФормирования.ДоговорКонтрагента = ЗначенияРеквизитов.Договор;
		
	ИначеЕсли ТипИсточника = Тип("ДокументСсылка.ОтчетКомитентуОСписании") Тогда
		
		Реквизиты = "Организация, Контрагент, Договор";
		ЗначенияРеквизитов = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(СсылкаНаДокумент, Реквизиты);
		
		НастройкиФормирования.ТипДокумента       = ТипыДокументов.ОтчетОСписанииКомиссионногоТовара;
		НастройкиФормирования.Формат             = ПоддерживаемыеФорматыЭДО.CML208;
		НастройкиФормирования.Направление        = НаправленияДокументов.Исходящий;
		НастройкиФормирования.Организация        = ЗначенияРеквизитов.Организация;
		НастройкиФормирования.Контрагент         = ЗначенияРеквизитов.Контрагент;
		НастройкиФормирования.ДоговорКонтрагента = ЗначенияРеквизитов.Договор;
		
	ИначеЕсли ТипИсточника = Тип("ДокументСсылка.РеализацияТоваровУслуг") Тогда
	
		Реквизиты = "Организация, Контрагент, Договор, ХозяйственнаяОперация, ВариантОформленияПродажи";
		ЗначенияРеквизитов = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(СсылкаНаДокумент, Реквизиты);
		
		НастройкиФормирования.Направление        = НаправленияДокументов.Исходящий;
		НастройкиФормирования.Организация        = ЗначенияРеквизитов.Организация;
		НастройкиФормирования.Контрагент         = ЗначенияРеквизитов.Контрагент;
		НастройкиФормирования.ДоговорКонтрагента = ЗначенияРеквизитов.Договор;

		ТекстСообщенияВидаДокумента = "";
		Если (ЗначенияРеквизитов.ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.РеализацияЧерезКомиссионера
			Или ЗначенияРеквизитов.ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.РеализацияЧерезКомиссионераБезПереходаПраваСобственности) Тогда
			ТипДокумента = Неопределено;
			ТекстСообщенияВидаДокумента = Строка(ЗначенияРеквизитов.ХозяйственнаяОперация);
		Иначе
			Если ЗначенияРеквизитов.ВариантОформленияПродажи = Перечисления.ВариантыОформленияПродажи.АктНаПередачуПрав Тогда
				ТипДокумента = ТипыДокументов.АктНаПередачуПрав;
			Иначе
				ТипДокумента = ТипыДокументов.ТоварнаяНакладная;
			КонецЕсли;
		КонецЕсли;
		
		Если Не ЗначениеЗаполнено(ТипДокумента) Тогда
			ВидОперации = НСтр("ru = 'Заполнение настроек формирования документа.'");
			ТекстСообщения = СтрШаблон(
				НСтр("ru = 'Не поддержана возможность делиться документом по ссылке с хозяйственной операцией ""%1"".'"),
				ТекстСообщенияВидаДокумента);

			ОбработкаНеисправностейБЭД.ОбработатьОшибку(ВидОперации, ИнтеграцияShareКлиентСервер.ИмяПодсистемы(),
				ТекстСообщения, ТекстСообщения);
			Возврат;
		КонецЕсли;
		
		НастройкиФормирования.ТипДокумента = ТипДокумента;
		НастройкиФормирования.Формат       = ПоддерживаемыеФорматыЭДО.ФНС.УПД_5_03.ИнформацияПродавца;
		НастройкиФормирования.ЭтоФорматФНС = Истина;
		
	ИначеЕсли ТипИсточника = Тип("ДокументСсылка.АктВыполненныхРабот") Тогда
		
		Реквизиты = "Организация, Контрагент, Договор";
		ЗначенияРеквизитов = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(СсылкаНаДокумент, Реквизиты);
		
		НастройкиФормирования.ТипДокумента       = ТипыДокументов.АктВыполненныхРабот;
		НастройкиФормирования.Формат             = ПоддерживаемыеФорматыЭДО.ФНС.УПД_5_03.ИнформацияПродавца;
		НастройкиФормирования.Направление        = НаправленияДокументов.Исходящий;
		НастройкиФормирования.Организация        = ЗначенияРеквизитов.Организация;
		НастройкиФормирования.Контрагент         = ЗначенияРеквизитов.Контрагент;
		НастройкиФормирования.ДоговорКонтрагента = ЗначенияРеквизитов.Договор;
		
	ИначеЕсли ТипИсточника = Тип("ДокументСсылка.РеализацияУслугПрочихАктивов") Тогда
		
		Реквизиты = "Организация, Контрагент, Договор";
		ЗначенияРеквизитов = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(СсылкаНаДокумент, Реквизиты);
		
		НастройкиФормирования.ТипДокумента       = ТипыДокументов.ТоварнаяНакладная;
		НастройкиФормирования.Формат             = ПоддерживаемыеФорматыЭДО.ФНС.УПД_5_03.ИнформацияПродавца;
		НастройкиФормирования.Направление        = НаправленияДокументов.Исходящий;
		НастройкиФормирования.Организация        = ЗначенияРеквизитов.Организация;
		НастройкиФормирования.Контрагент         = ЗначенияРеквизитов.Контрагент;
		НастройкиФормирования.ДоговорКонтрагента = ЗначенияРеквизитов.Договор;
		
	ИначеЕсли ТипИсточника = Тип("ДокументСсылка.КорректировкаРеализации") Тогда

		Реквизиты = "Организация, Контрагент, Договор, ВидКорректировки, ВариантОформленияПродажи, ДокументОснование";
		ЗначенияРеквизитов = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(СсылкаНаДокумент, Реквизиты);
		
		НастройкиФормирования.Направление        = НаправленияДокументов.Исходящий;
		НастройкиФормирования.Организация        = ЗначенияРеквизитов.Организация;
		НастройкиФормирования.Контрагент         = ЗначенияРеквизитов.Контрагент;
		НастройкиФормирования.ДоговорКонтрагента = ЗначенияРеквизитов.Договор;

		Если ЗначенияРеквизитов.ВидКорректировки = Перечисления.ХозяйственныеОперации.КорректировкаПоСогласованиюСторон Тогда
			ТипДокумента = Неопределено;
			ТекстСообщенияВидаДокумента = Строка(ЗначенияРеквизитов.ВидКорректировки);
		ИначеЕсли ЗначениеЗаполнено(ЗначенияРеквизитов.ДокументОснование) Тогда
			Если ТипЗнч(ЗначенияРеквизитов.ДокументОснование) = Тип("ДокументСсылка.АктВыполненныхРабот") Тогда
				ТипДокумента = ТипыДокументов.АктВыполненныхРабот;
			ИначеЕсли ТипЗнч(ЗначенияРеквизитов.ДокументОснование) = Тип("ДокументСсылка.РеализацияТоваровУслуг") 
					И ЗначенияРеквизитов.ВариантОформленияПродажи = Перечисления.ВариантыОформленияПродажи.АктНаПередачуПрав Тогда
				ТипДокумента = ТипыДокументов.АктНаПередачуПрав;
			ИначеЕсли ТипЗнч(ЗначенияРеквизитов.ДокументОснование) = Тип("ДокументСсылка.РеализацияТоваровУслуг") 
					Или ТипЗнч(ЗначенияРеквизитов.ДокументОснование) = Тип("ДокументСсылка.РеализацияУслугПрочихАктивов") Тогда
				ТипДокумента = ТипыДокументов.ТоварнаяНакладная;
			ИначеЕсли ТипЗнч(ЗначенияРеквизитов.ДокументОснование) = Тип("ДокументСсылка.ПервичныйДокумент") Тогда
				ТипДокумента = ТипыДокументов.ТоварнаяНакладная;
			Иначе
				ТипДокумента = Неопределено;
				ТекстСообщенияВидаДокумента = СтрШаблон("%1 (%2)", ЗначенияРеквизитов.ВидКорректировки, ТипЗнч(ЗначенияРеквизитов.ДокументОснование));
			КонецЕсли;
		Иначе
			ТипДокумента = ТипыДокументов.ТоварнаяНакладная;
		КонецЕсли;
		
		Если Не ЗначениеЗаполнено(ТипДокумента) Тогда
			ВидОперации = НСтр("ru = 'Заполнение настроек формирования документа.'");
			ТекстСообщения = СтрШаблон(
				НСтр("ru = 'Не поддержана возможность делиться документом по ссылке с хозяйственной операцией ""%1"".'"),
				ТекстСообщенияВидаДокумента);

			ОбработкаНеисправностейБЭД.ОбработатьОшибку(ВидОперации, ИнтеграцияShareКлиентСервер.ИмяПодсистемы(),
				ТекстСообщения, ТекстСообщения);
			Возврат;
		КонецЕсли;
		
		НастройкиФормирования.ТипДокумента = ТипДокумента;
		НастройкиФормирования.Формат       = ПоддерживаемыеФорматыЭДО.ФНС.УПД_5_03.ИнформацияПродавца;
		НастройкиФормирования.ЭтоФорматФНС = Истина;

	КонецЕсли;

КонецПроцедуры

// См. ИнтеграцияShareПереопределяемый.ПриОпределенииНастроекЗагрузкиДокумента.
Процедура ПриОпределенииНастроекЗагрузкиДокумента(НастройкиЗагрузки, Знач ОписаниеЭлектронногоДокумента) Экспорт

	Если Не ЗначениеЗаполнено(ОписаниеЭлектронногоДокумента.СведенияОЗагруженномДокументе.ОбъектУчета)
							И ОписаниеЭлектронногоДокумента.ТипДокумента = Перечисления.ТипыДокументовЭДО.СчетНаОплату Тогда
							
		ПараметрыОтраженияВУчете = НастройкиЗагрузки.ПараметрыОтраженияВУчете;
		ПараметрыОтраженияВУчете.Очистить();
		
		Если ПолучитьФункциональнуюОпцию("ИспользоватьЗаявкиНаРасходованиеДенежныхСредств") Тогда
			НовыйПараметрОтраженияВУчете = ПараметрыОтраженияВУчете.Добавить();
			
			ПредставлениеДокумента   = СтрШаблон(НСтр("ru = '%1 от %2'",
				ОбщегоНазначения.КодОсновногоЯзыка()), ОписаниеЭлектронногоДокумента.ПредставлениеДокументаОтправителя,
				ОписаниеЭлектронногоДокумента.НаименованиеОтправителя);
			
			НовыйПараметрОтраженияВУчете.СпособОтраженияВУчете    = "ЗаявкаНаРасходованиеДенежныхСредств";
			НовыйПараметрОтраженияВУчете.ПредставлениеДокумента   = ПредставлениеДокумента;
			НовыйПараметрОтраженияВУчете.КартинкаРезультатаПоиска = БиблиотекаКартинок.ЗагрузитьShare;
			НовыйПараметрОтраженияВУчете.ПредставлениеВПодменюЗагрузить = СтрШаблон(НСтр("ru = 'Как %1'",
				ОбщегоНазначения.КодОсновногоЯзыка()), НСтр("ru = 'Заявка на расходование денежных средств'"));
			НовыйПараметрОтраженияВУчете.ПредставлениеРезультатаПоиска = СтрШаблон(НСтр("ru = 'Загрузить как %1'",
				ОбщегоНазначения.КодОсновногоЯзыка()), НСтр("ru = 'Заявка на расходование денежных средств'"));
		КонецЕсли;
		
		Если ПолучитьФункциональнуюОпцию("ИспользоватьЗаказыПоставщикам") Тогда
			НовыйПараметрОтраженияВУчете = ПараметрыОтраженияВУчете.Добавить();
			
			ПредставлениеДокумента   = СтрШаблон(НСтр("ru = '%1 от %2'",
				ОбщегоНазначения.КодОсновногоЯзыка()), ОписаниеЭлектронногоДокумента.ПредставлениеДокументаОтправителя,
				ОписаниеЭлектронногоДокумента.НаименованиеОтправителя);
			
			НовыйПараметрОтраженияВУчете.СпособОтраженияВУчете    = "ЗаказПоставщику";
			НовыйПараметрОтраженияВУчете.ПредставлениеДокумента   = ПредставлениеДокумента;
			НовыйПараметрОтраженияВУчете.КартинкаРезультатаПоиска = БиблиотекаКартинок.ЗагрузитьShare;
			НовыйПараметрОтраженияВУчете.ПредставлениеВПодменюЗагрузить = СтрШаблон(НСтр("ru = 'Как %1'",
				ОбщегоНазначения.КодОсновногоЯзыка()), НСтр("ru = 'Заказ поставщику'"));
			НовыйПараметрОтраженияВУчете.ПредставлениеРезультатаПоиска = СтрШаблон(НСтр("ru = 'Загрузить как %1'",
				ОбщегоНазначения.КодОсновногоЯзыка()), НСтр("ru = 'Заказ поставщику'"));
		КонецЕсли;

		НовыйПараметрОтраженияВУчете = ПараметрыОтраженияВУчете.Добавить();
			
		ПредставлениеДокумента   = СтрШаблон(НСтр("ru = '%1 от %2'",
			ОбщегоНазначения.КодОсновногоЯзыка()), ОписаниеЭлектронногоДокумента.ПредставлениеДокументаОтправителя,
			ОписаниеЭлектронногоДокумента.НаименованиеОтправителя);
			
		НовыйПараметрОтраженияВУчете.СпособОтраженияВУчете    = "СписаниеБезналичныхДенежныхСредств";
		НовыйПараметрОтраженияВУчете.ПредставлениеДокумента   = ПредставлениеДокумента;
		НовыйПараметрОтраженияВУчете.КартинкаРезультатаПоиска = БиблиотекаКартинок.ЗагрузитьShare;
		НовыйПараметрОтраженияВУчете.ПредставлениеВПодменюЗагрузить = СтрШаблон(НСтр("ru = 'Как %1'",
			ОбщегоНазначения.КодОсновногоЯзыка()), НСтр("ru = 'Списание безналичных денежных средств'"));
		НовыйПараметрОтраженияВУчете.ПредставлениеРезультатаПоиска = СтрШаблон(НСтр("ru = 'Загрузить как %1'",
			ОбщегоНазначения.КодОсновногоЯзыка()), НСтр("ru = 'Списание безналичных денежных средств'"));

	ИначеЕсли Не ЗначениеЗаполнено(ОписаниеЭлектронногоДокумента.СведенияОЗагруженномДокументе.ОбъектУчета)
							И ОписаниеЭлектронногоДокумента.ТипДокумента = Перечисления.ТипыДокументовЭДО.ТоварнаяНакладная 
							Или ОписаниеЭлектронногоДокумента.ТипДокумента = Перечисления.ТипыДокументовЭДО.АктВыполненныхРабот Тогда
							
		ПараметрыОтраженияВУчете = НастройкиЗагрузки.ПараметрыОтраженияВУчете;
		ПараметрыОтраженияВУчете.Очистить();
							
		// ПриобретениеТоваровУслуг
		НовыйПараметрОтраженияВУчете = ПараметрыОтраженияВУчете.Добавить();
		
		ПредставлениеДокумента   = СтрШаблон(НСтр("ru = '%1 от %2'",
			ОбщегоНазначения.КодОсновногоЯзыка()), ОписаниеЭлектронногоДокумента.ПредставлениеДокументаОтправителя,
			ОписаниеЭлектронногоДокумента.НаименованиеОтправителя);
		
		НовыйПараметрОтраженияВУчете.СпособОтраженияВУчете    = "ПриобретениеТоваровУслуг";
		НовыйПараметрОтраженияВУчете.ПредставлениеДокумента   = ПредставлениеДокумента;
		НовыйПараметрОтраженияВУчете.КартинкаРезультатаПоиска = БиблиотекаКартинок.ЗагрузитьShare;
		НовыйПараметрОтраженияВУчете.ПредставлениеВПодменюЗагрузить = СтрШаблон(НСтр("ru = 'Как %1'",
			ОбщегоНазначения.КодОсновногоЯзыка()), НСтр("ru = 'Приобретение товаров и услуг или Корректировка приобретения'"));
		НовыйПараметрОтраженияВУчете.ПредставлениеРезультатаПоиска = СтрШаблон(НСтр("ru = 'Загрузить как %1'",
			ОбщегоНазначения.КодОсновногоЯзыка()), НСтр("ru = 'Приобретение товаров и услуг или Корректировка приобретения'"));

		// ПриобретениеУслугПрочихАктивов
		НовыйПараметрОтраженияВУчете = ПараметрыОтраженияВУчете.Добавить();
		
		ПредставлениеДокумента   = СтрШаблон(НСтр("ru = '%1 от %2'",
			ОбщегоНазначения.КодОсновногоЯзыка()), ОписаниеЭлектронногоДокумента.ПредставлениеДокументаОтправителя,
			ОписаниеЭлектронногоДокумента.НаименованиеОтправителя);
		
		НовыйПараметрОтраженияВУчете.СпособОтраженияВУчете    = "ПриобретениеУслугПрочихАктивов";
		НовыйПараметрОтраженияВУчете.ПредставлениеДокумента   = ПредставлениеДокумента;
		НовыйПараметрОтраженияВУчете.КартинкаРезультатаПоиска = БиблиотекаКартинок.ЗагрузитьShare;
		НовыйПараметрОтраженияВУчете.ПредставлениеВПодменюЗагрузить = СтрШаблон(НСтр("ru = 'Как %1'",
			ОбщегоНазначения.КодОсновногоЯзыка()), НСтр("ru = 'Приобретение услуг и прочих активов'"));
		НовыйПараметрОтраженияВУчете.ПредставлениеРезультатаПоиска = СтрШаблон(НСтр("ru = 'Загрузить как %1'",
			ОбщегоНазначения.КодОсновногоЯзыка()), НСтр("ru = 'Приобретение услуг и прочих активов'"));
			
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти
