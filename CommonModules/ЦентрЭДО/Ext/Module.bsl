//                         - см. НовыеДанныеАутентификацииСлужебногоПользователя
//  * ТекстОшибки - Строка
Функция НовыйРезультатСозданияСлужебногоПользователя()
	Результат = Новый Структура;
	Результат.Вставить("Пользователь", Неопределено);
	Результат.Вставить("ДанныеАутентификации", Неопределено);
	Результат.Вставить("ТекстОшибки", "");
