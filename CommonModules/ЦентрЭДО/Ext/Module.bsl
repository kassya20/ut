КонецФункции

// Возвращаемое значение:
//  См. НовыйРезультатСозданияСлужебногоПользователя
Функция СоздатьСлужебногоПользователяЧерезМенеджерСервиса() 
	
	Результат = НовыйРезультатСозданияСлужебногоПользователя();
	
	МодульРаботаВМоделиСервиса = ОбщегоНазначения.ОбщийМодуль("РаботаВМоделиСервиса");
	НомерОбластиДанных = МодульРаботаВМоделиСервиса.ЗначениеРазделителяСеанса();
	Если Не ЗначениеЗаполнено(НомерОбластиДанных) Тогда
		Результат.ТекстОшибки = НСтр("ru = 'Не удалось получить номер области данных.'");
		Возврат Результат;
	КонецЕсли;
	
	ОсновныеСвойстваОтвета = ПрограммныйИнтерфейсСервиса.НовыйОсновныеСвойстваОтвета();
	
	СвойстваПриложения = ПрограммныйИнтерфейсСервиса.СвойстваПриложения(НомерОбластиДанных, Ложь,
		ОсновныеСвойстваОтвета);
	Если ОсновныеСвойстваОтвета.КодСостояния <> 200
		Или ОсновныеСвойстваОтвета.КодОтвета <> 10200 Тогда
		Результат.ТекстОшибки = ОсновныеСвойстваОтвета.Сообщение;
		Возврат Результат;
	КонецЕсли;
	
	Если СвойстваПриложения.СостояниеПриложения <> Перечисления.СостоянияПриложений.Готово
		И СвойстваПриложения.СостояниеПриложения <> Перечисления.СостоянияПриложений.Используется Тогда
		Результат.ТекстОшибки = НСтр("ru = 'Приложение не готово к использованию.'");
		Возврат Результат;
	КонецЕсли;
	
	Логин = ИмяСлужебногоПользователяЛокально() + "_" + Формат(НомерОбластиДанных, "ЧГ=;");
	Пароль = СгенерироватьСлучайныйПароль();
	
	ПрограммныйИнтерфейсСервиса.СвойстваПользователяАбонента(Логин, Ложь, ОсновныеСвойстваОтвета);
	Если ОсновныеСвойстваОтвета.КодСостояния <> 200 Тогда
		Результат.ТекстОшибки = ОсновныеСвойстваОтвета.Сообщение;
		Возврат Результат;
	КонецЕсли;
	
	Если ОсновныеСвойстваОтвета.КодОтвета = 10404 Тогда
		
		ПараметрыСоздания = ПрограммныйИнтерфейсСервиса.НовыйПараметрыСозданияПользователя();
		ПараметрыСоздания.Логин = Логин;
		ПараметрыСоздания.Пароль = Пароль;
		ПараметрыСоздания.ПолноеИмя = ПолноеИмяСлужебногоПользователя() + " (" + НомерОбластиДанных + ")";
		ПараметрыСоздания.ПочтаОбязательна = Ложь;
		
		ПрограммныйИнтерфейсСервиса.СоздатьПользователяАбонента(ПараметрыСоздания, Ложь, ОсновныеСвойстваОтвета);
		
		Если ОсновныеСвойстваОтвета.КодСостояния <> 200
			Или ОсновныеСвойстваОтвета.КодОтвета <> 10200 Тогда
			Результат.ТекстОшибки = ОсновныеСвойстваОтвета.Сообщение;
			Возврат Результат;
		КонецЕсли;
		
	ИначеЕсли ОсновныеСвойстваОтвета.КодОтвета <> 10200 Тогда
		Результат.ТекстОшибки = ОсновныеСвойстваОтвета.Сообщение;
		Возврат Результат;
	КонецЕсли;
	
	ПараметрыДобавления = ПрограммныйИнтерфейсСервиса.НовыйПараметрыДобавленияПользователяВПриложение();
	ПараметрыДобавления.КодПриложения = РаботаВМоделиСервиса.ЗначениеРазделителяСеанса();
	ПараметрыДобавления.Логин = Логин;
	ПараметрыДобавления.Право = Перечисления.ПраваПользователяПриложения.ДоступКAPI;
	
	ПрограммныйИнтерфейсСервиса.ДобавитьПользователяВПриложение(ПараметрыДобавления, Ложь, ОсновныеСвойстваОтвета);
	
	Если ОсновныеСвойстваОтвета.КодСостояния <> 200
		Или ОсновныеСвойстваОтвета.КодОтвета <> 10200 Тогда
		Результат.ТекстОшибки = ОсновныеСвойстваОтвета.Сообщение;
		Возврат Результат;
	КонецЕсли;
	
	Результат.Пользователь = Пользователи.НайтиПоИмени(Логин);
	Если Не ЗначениеЗаполнено(Результат.Пользователь) Тогда
		Результат.ТекстОшибки = НСтр("ru = 'Неизвестная ошибка'");
	КонецЕсли;
	
	ДанныеАутентификации = НовыеДанныеАутентификацииСлужебногоПользователя(Логин, Пароль);
	ЗаписатьДанныеАутентификацииСлужебногоПользователя(ДанныеАутентификации);
	Результат.ДанныеАутентификации = ДанныеАутентификации;
	
	Возврат Результат;
	
КонецФункции

// Возвращаемое значение:
//  См. НовыйРезультатСозданияСлужебногоПользователя
Функция СоздатьСлужебногоПользователяЛокально()
	
	Результат = НовыйРезультатСозданияСлужебногоПользователя();
	
	Логин = ИмяСлужебногоПользователяЛокально();
	
	СвойстваПользователяИБ = Пользователи.СвойстваПользователяИБ(Логин);
	ТребуетсяОбновитьДанныеПользователяИБ = ЗначениеЗаполнено(СвойстваПользователяИБ)
		И СвойстваПользователяИБ.ПолноеИмя <> ПолноеИмяСлужебногоПользователя();
	
	Результат.Пользователь = Пользователи.НайтиПоИмени(Логин);
	
	Если ЗначениеЗаполнено(Результат.Пользователь)
		И Не ТребуетсяОбновитьДанныеПользователяИБ Тогда
		Результат.ДанныеАутентификации = ДанныеАутентификацииСлужебногоПользователя();
		Возврат Результат;
	КонецЕсли;
	
	Если НЕ ОбщегоНазначения.РазделениеВключено()
		И НЕ ПользователиИнформационнойБазы.ПолучитьПользователей().Количество() Тогда
		Возврат Результат;
	КонецЕсли;
	
	Пароль = СгенерироватьСлучайныйПароль();
	ЭтоСозданиеПользователя = Ложь;
	
	Попытка
		
		Если ТребуетсяОбновитьДанныеПользователяИБ
			И ЗначениеЗаполнено(Результат.Пользователь) Тогда
			СвойстваПользователяИБ.ПолноеИмя = ПолноеИмяСлужебногоПользователя();
			СвойстваПользователяИБ.Пароль = Пароль;
			СвойстваПользователяИБ.СохраняемоеЗначениеПароля = Неопределено;
			СвойстваПользователяИБ.Вставить("Действие", "Записать");
			СвойстваПользователяИБ.Вставить("ВходВПрограммуРазрешен", Истина);

			ПользовательОбъект = Результат.Пользователь.ПолучитьОбъект();
			ПользовательОбъект.Наименование = СвойстваПользователяИБ.ПолноеИмя;
			ПользовательОбъект.ДополнительныеСвойства.Вставить("ОписаниеПользователяИБ", СвойстваПользователяИБ);
			ПользовательОбъект.Записать();
			
			ПользовательСсылка = ПользовательОбъект.Ссылка;
		Иначе
			ЭтоСозданиеПользователя = Истина;
			
			ОписаниеПользователяИБ = Пользователи.НовоеОписаниеПользователяИБ();
			ОписаниеПользователяИБ.Имя = Логин;
			ОписаниеПользователяИБ.ПолноеИмя = ПолноеИмяСлужебногоПользователя();
			ОписаниеПользователяИБ.АутентификацияСтандартная = Истина;
			ОписаниеПользователяИБ.АутентификацияOpenIDConnect = Ложь;
			ОписаниеПользователяИБ.АутентификацияТокеномДоступа = Ложь;
			ОписаниеПользователяИБ.ПоказыватьВСпискеВыбора = Ложь;
			ОписаниеПользователяИБ.Вставить("Действие", "Записать");
			ОписаниеПользователяИБ.Вставить("ВходВПрограммуРазрешен", Истина);
			ОписаниеПользователяИБ.ЗапрещеноИзменятьПароль = Истина;
			ОписаниеПользователяИБ.Пароль = Пароль;
			ОписаниеПользователяИБ.Роли = РолиСлужебногоПользователя();
			
			НовыйПользователь = Справочники.Пользователи.СоздатьЭлемент();
			НовыйПользователь.Наименование = ОписаниеПользователяИБ.ПолноеИмя;
			НовыйПользователь.Служебный = Истина;
			НовыйПользователь.ДополнительныеСвойства.Вставить("ОписаниеПользователяИБ", ОписаниеПользователяИБ);
			НовыйПользователь.Записать();
			
			ПользовательСсылка = НовыйПользователь.Ссылка;
		КонецЕсли;
		
		Результат.Пользователь = ПользовательСсылка;
		Результат.ДанныеАутентификации = НовыеДанныеАутентификацииСлужебногоПользователя(Логин, Пароль);
		ЗаписатьДанныеАутентификацииСлужебногоПользователя(Результат.ДанныеАутентификации);
	Исключение
		
		МетаданныеОбъекта = Метаданные.Справочники.Пользователи;
		ТекстОшибки = ?(ЭтоСозданиеПользователя,
			НСтр("ru = 'Не удалось создать служебного пользователя центра ЭДО по причине:'"),
			НСтр("ru = 'Не удалось обновить служебного пользователя центра ЭДО по причине:'"))
			+ Символы.ПС + ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
		ЗаписьЖурналаРегистрации(ПредставлениеПодсистемы(),
			УровеньЖурналаРегистрации.Ошибка, МетаданныеОбъекта, , ТекстОшибки);
		Результат.ТекстОшибки = ОбработкаОшибок.КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
		
	КонецПопытки;
	
	Возврат Результат;
	
КонецФункции

// Возвращаемое значение:
//  Массив Из Строка
Функция РолиСлужебногоПользователя()
	
	НаборРолей = Новый Массив;
	НаборРолей.Добавить(Метаданные.Роли.ИспользованиеЦентраЭДО.Имя);
	НаборРолей.Добавить(Метаданные.Роли.БазовыеПраваЭД.Имя);
	НаборРолей.Добавить(Метаданные.Роли.БазовыеПраваБСП.Имя);
	НаборРолей.Добавить(Метаданные.Роли.ЧтениеНастроекОбменаСКонтрагентами.Имя);
	НаборРолей.Добавить(Метаданные.Роли.ЧтениеМаршрутовПодписания.Имя);
	НаборРолей.Добавить(Метаданные.Роли.ЧтениеЭлектронныхДокументов.Имя);
	НаборРолей.Добавить(Метаданные.Роли.ВыполнениеОбменаСКонтрагентами.Имя);
	НаборРолей.Добавить(Метаданные.Роли.ИспользованиеУведомленийЭДО.Имя);
	НаборРолей.Добавить(Метаданные.Роли.ЧтениеМЧДЭДО.Имя);
	НаборРолей.Добавить(Метаданные.Роли.ВыводНаПринтерФайлБуферОбмена.Имя);

	Возврат НаборРолей;
	
КонецФункции

// Возвращаемое значение:
//  Строка
Функция СгенерироватьСлучайныйПароль()
	
	ВерсияРежимаСовместимости = СтандартныеПодсистемыСервер.ВерсияРежимаСовместимости();
	Если ОбщегоНазначенияКлиентСервер.СравнитьВерсии(ВерсияРежимаСовместимости, "8.3.22.0") >= 0 Тогда
		ГенераторСлучайныхПаролей = ОбщегоНазначения.ВычислитьВБезопасномРежиме("Новый ГенераторСлучайныхПаролей");
		ДлинаПароля = 15;
		Возврат ГенераторСлучайныхПаролей.СлучайныйПароль(ДлинаПароля, Ложь);
	КонецЕсли;
	
	Идентификатор = СтрЗаменить(Строка(Новый УникальныйИдентификатор), "-", "");
	
	ЕстьСпецсимволы = Ложь;
	ЕстьЗаглавныеБуквы = Ложь;
	
	Пароль = "";
	
	Для Индекс = 1 По СтрДлина(Идентификатор) Цикл
		
		Если ЕстьСпецсимволы И ЕстьЗаглавныеБуквы Тогда
			Пароль = Пароль + Сред(Идентификатор, Индекс);
			Прервать;
		КонецЕсли;
		
		Символ = Сред(Идентификатор, Индекс, 1);
		
		Если СтроковыеФункцииКлиентСервер.ТолькоЦифрыВСтроке(Символ) Тогда
			Если ЕстьСпецсимволы Тогда
				НовыйСимвол = Символ;
			Иначе
				Число = СтроковыеФункцииКлиентСервер.СтрокаВЧисло(Символ);
				НовыйСимвол = Сред("_~!?@#$%&^", Число + 1, 1);
				ЕстьСпецсимволы = Истина;
			КонецЕсли;
		Иначе
			Если ЕстьЗаглавныеБуквы Тогда
				НовыйСимвол = Символ;
			Иначе
				НовыйСимвол = ВРег(Символ);
				ЕстьЗаглавныеБуквы = Истина;
			КонецЕсли;
		КонецЕсли;
		
		Пароль = Пароль + НовыйСимвол;
		
	КонецЦикла;
	
	Возврат Пароль;
	
КонецФункции

// Устанавливает служебному пользователю центра ЭДО права доступа к API области данных.
//
// Параметры:
//  Пользователь - СправочникСсылка.Пользователи - Пользователь, которому нужно установить права.
//
Процедура УстановитьДоступКAPIДляСлужебногоПользователя(Пользователь)

	РольУдаленныйДоступПередачаДанных = Метаданные.Роли.Найти("УдаленныйДоступПередачаДанных");
	
	Если РольУдаленныйДоступПередачаДанных = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ПользовательИБ = ПользователиИнформационнойБазы.НайтиПоУникальномуИдентификатору(
		ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Пользователь, "ИдентификаторПользователяИБ"));
	
	Если ПользовательИБ.Роли.Содержит(РольУдаленныйДоступПередачаДанных) Тогда
		Возврат;
	КонецЕсли;
	
	ПользовательИБ.Роли.Добавить(РольУдаленныйДоступПередачаДанных);
	
	Если ОбщегоНазначенияБЭД.ЭтоРежимЦентрЭДО() Тогда
		НаборРолейСлужебногоПользования = РолиСлужебногоПользователя();
		Для Каждого НаименованиеРоли Из НаборРолейСлужебногоПользования Цикл
			Роль = Метаданные.Роли.Найти(НаименованиеРоли);
			Если Роль = Неопределено Или ПользовательИБ.Роли.Содержит(Роль) Тогда
				Продолжить;
			КонецЕсли;
			
			ПользовательИБ.Роли.Добавить(Роль);
		КонецЦикла;
	КонецЕсли;

	ПользовательИБ.Записать();
	
КонецПроцедуры

// Снимает у служебного пользователя центра ЭДО права доступа к API области данных.
//
// Параметры:
//  Пользователь - СправочникСсылка.Пользователи - Пользователь, у которого нужно снять права.
//
Процедура СнятьДоступКAPIДляСлужебногоПользователя(Пользователь)
	
	ПользовательИБ = ПользователиИнформационнойБазы.НайтиПоУникальномуИдентификатору(
		ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Пользователь, "ИдентификаторПользователяИБ"));
	ПользовательИБ.Роли.Очистить();
	ПользовательИБ.Записать();
	
КонецПроцедуры

#КонецОбласти

#КонецОбласти
