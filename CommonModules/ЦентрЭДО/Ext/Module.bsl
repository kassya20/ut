// Возвращаемое значение:
//  См. НовыйРезультатСозданияСлужебногоПользователя
Функция СоздатьСлужебногоПользователя() Экспорт
	
	Если ОбщегоНазначения.РазделениеВключено() Тогда
		РезультатСоздания = СоздатьСлужебногоПользователяЧерезМенеджерСервиса();
	Иначе
		РезультатСоздания = СоздатьСлужебногоПользователяЛокально();
	КонецЕсли;
	
	Возврат РезультатСоздания;
	
КонецФункции

// Возвращаемое значение:
//  Неопределено,Произвольный,Структура:
//  * Логин - Строка
//  * Пароль - Строка
Функция ДанныеАутентификацииСлужебногоПользователя() Экспорт
	УстановитьПривилегированныйРежим(Истина);
	ДанныеАутентификации = ОбщегоНазначения.ПрочитатьДанныеИзБезопасногоХранилища(
		ИдентификаторДанныхАутентификацииСлужебногоПользователя(), "Логин, Пароль"); // См. НовыеДанныеАутентификацииСлужебногоПользователя
	Возврат ДанныеАутентификации;
КонецФункции

// Возвращаемое значение:
//  Булево
Функция АвторизованСлужебныйПользователь() Экспорт
	
	ДанныеАутентификации = ДанныеАутентификацииСлужебногоПользователя();
	Если Не ЗначениеЗаполнено(ДанныеАутентификации) Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Возврат ДанныеАутентификации.Логин = ИмяПользователя();
	
КонецФункции

