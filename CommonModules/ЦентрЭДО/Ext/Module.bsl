#Область УдаленныйВызовМетода

// Удаленный вызов метода.
// 
// Параметры:
//  Запрос - HTTPСервисЗапрос
// 
// Возвращаемое значение:
//  HTTPСервисОтвет
Функция УдаленныйВызовМетода(Запрос) Экспорт
	
	Попытка
		
		ВремяНачала = ТекущаяУниверсальнаяДатаВМиллисекундах();
		
		ИдентификаторЗапроса = Строка(Новый УникальныйИдентификатор);
		
		ЗаписатьВызовСервисаВЖурналРегистрации(Запрос, ИдентификаторЗапроса);
		
		ОтветHTTP = ВыполнитьЗапрос(Запрос, ИдентификаторЗапроса);
		
	Исключение
		Ошибка = ОшибкаЗапроса(ТипОшибкиЗапросаВнутренняяОшибкаСервера(),
			НСтр("ru = 'Внутренняя ошибка сервера'"), ИнформацияОбОшибке());
		ОтветHTTP = ОтветПоОшибкеЗапроса(Ошибка, ИдентификаторЗапроса);
	КонецПопытки;
	
	ЗаписатьОтветСервисаВЖурналРегистрации(ОтветHTTP, ИдентификаторЗапроса, ВремяНачала);
	
	Возврат ОтветHTTP;
	
КонецФункции

// Параметры:
//  Запрос - HTTPСервисЗапрос
//  ИдентификаторЗапроса - Строка
// 
// Возвращаемое значение:
//  HTTPСервисОтвет
Функция ВыполнитьЗапрос(Запрос, ИдентификаторЗапроса)
	
	ТипКонтентаЗапроса = ТипКонтентаЗапроса(Запрос);
	Ошибка = ПроверитьТипКонтентаЗапроса(ТипКонтентаЗапроса);
	Если ЗначениеЗаполнено(Ошибка) Тогда
		Возврат ОтветПоОшибкеЗапроса(Ошибка, ИдентификаторЗапроса);
	КонецЕсли;
	
	Если Запрос.HTTPМетод = "POST" Тогда
		РезультатЧтенияЗапроса = ПрочитатьОписанияМетодовИзТелаЗапроса(Запрос);
	ИначеЕсли Запрос.HTTPМетод = "GET" Тогда 
		РезультатЧтенияЗапроса = ПрочитатьОписанияМетодовИзПараметровЗапроса(Запрос);
	Иначе
		РезультатЧтенияЗапроса = НовыйРезультатЧтенияОписанияМетодовИзЗапроса();
		РезультатЧтенияЗапроса.Ошибка = ОшибкаЗапроса(ТипОшибкиЗапросаНеНайдено(),
			НСтр("ru = 'Переданный http метод не поддерживается'"));
	КонецЕсли;
	
	Если ЗначениеЗаполнено(РезультатЧтенияЗапроса.ОписанияМетодов) Тогда
		Версия = ТипКонтентаЗапроса.Версия;
		РезультатыМетодов = ВыполнитьМетодыЗапроса(РезультатЧтенияЗапроса.ОписанияМетодов, Версия,
			ИдентификаторЗапроса);
		ОтветHTTP = ОтветПоРезультатамМетодов(РезультатыМетодов, РезультатЧтенияЗапроса.ЭтоПакетМетодов, Версия);
	ИначеЕсли ЗначениеЗаполнено(РезультатЧтенияЗапроса.Ошибка) Тогда
		ОтветHTTP = ОтветПоОшибкеЗапроса(РезультатЧтенияЗапроса.Ошибка, ИдентификаторЗапроса);
	Иначе
		Ошибка = ОшибкаЗапроса(ТипОшибкиЗапросаОшибкаДанных(), НСтр("ru='Некорректный запрос'"));
		ОтветHTTP = ОтветПоОшибкеЗапроса(Ошибка, ИдентификаторЗапроса);
	КонецЕсли;
	
	Возврат ОтветHTTP;
	
КонецФункции

// Параметры:
//  Запрос - HTTPСервисЗапрос
// 
// Возвращаемое значение:
//  Неопределено,Структура:
//  * Тип - Строка
//  * Версия - Строка
Функция ТипКонтентаЗапроса(Запрос)
	
	ЗначениеЗаголовкаТипКонтента = Запрос.Заголовки[ИмяЗаголовкаТипПередаваемогоКонтента()];
	Если Не ЗначениеЗаполнено(ЗначениеЗаголовкаТипКонтента) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	СекцииОписанияТипа = СтрРазделить(ЗначениеЗаголовкаТипКонтента, ";", Ложь);
	
	Результат = Новый Структура("Тип, Версия", СекцииОписанияТипа[0], "");
	
	Если СекцииОписанияТипа.Количество() = 1 Тогда
		Возврат Результат;
	КонецЕсли;
	
	Позиция = СтрНайти(СекцииОписанияТипа[1], "version=");
	Если Позиция = 0 Тогда
		Возврат Результат;
	КонецЕсли;
	
	ДлинаИмениПараметраВерсия = 8;
	
	Результат.Версия = СокрП(Сред(СекцииОписанияТипа[1], Позиция + ДлинаИмениПараметраВерсия));
	
	Возврат Результат;
	
КонецФункции

// Возвращаемое значение:
//  Строка
Функция ИмяЗаголовкаТипПередаваемогоКонтента()
	Возврат "Content-Type";
КонецФункции

// Возвращаемое значение:
//  Строка
Функция ПоддерживаемыйТипКонтентаЗапроса()
	Возврат "vnd.1cedo.rpc+json";
КонецФункции

// Параметры:
//  ТипКонтента - см. ТипКонтентаЗапроса
// 
// Возвращаемое значение:
//  - Неопределено
//  - См. ОшибкаЗапроса
Функция ПроверитьТипКонтентаЗапроса(ТипКонтента)
		
	Если Не ЗначениеЗаполнено(ТипКонтента) Тогда
		Ошибка = ОшибкаЗапроса(ТипОшибкиЗапросаКонтентНеПоддерживается(),
			НСтр("ru = 'Заголовок Content-Type не указан'"));
		Возврат Ошибка;
	КонецЕсли;
	
	Если ТипКонтента.Тип <> ПоддерживаемыйТипКонтентаЗапроса() Тогда
		Ошибка = ОшибкаЗапроса(ТипОшибкиЗапросаКонтентНеПоддерживается(),
			НСтр("ru = 'Переданный Content-Type не поддерживается'"));
		Возврат Ошибка;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(ТипКонтента.Версия) Тогда
		Ошибка = ОшибкаЗапроса(ТипОшибкиЗапросаКонтентНеПоддерживается(),
			НСтр("ru = 'Не указана версия переданного Content-Type'"));
		Возврат Ошибка;
	КонецЕсли;
	
	Возврат Неопределено;
	
КонецФункции

// Возвращаемое значение:
//  Структура:
//  * Ошибка - Неопределено
//           - см. НоваяОшибкаЗапроса
//  * ОписанияМетодов - Массив из см. НовоеОписаниеМетодаСервиса
//  * ЭтоПакетМетодов - Булево
Функция НовыйРезультатЧтенияОписанияМетодовИзЗапроса()
	Результат = Новый Структура;
	Результат.Вставить("Ошибка", Неопределено);
	Результат.Вставить("ОписанияМетодов", Новый Массив);
	Результат.Вставить("ЭтоПакетМетодов", Ложь);
	Возврат Результат;
КонецФункции

// Возвращаемое значение:
//  Структура:
//  * method - Строка - имя метода.
//  * params - Массив из Структура - параметры метода.
//  * id - Число - идентификатор метода.
Функция НовоеОписаниеМетодаСервиса()
	ОписаниеМетода = Новый Структура;
	ОписаниеМетода.Вставить("method", "");
	ОписаниеМетода.Вставить("params", Новый Массив);
	ОписаниеМетода.Вставить("id", 0);
	Возврат ОписаниеМетода;
КонецФункции

// Параметры:
//  Запрос - HTTPСервисЗапрос
// 
// Возвращаемое значение:
//  См. НовыйРезультатЧтенияОписанияМетодовИзЗапроса
Функция ПрочитатьОписанияМетодовИзТелаЗапроса(Запрос)
	
	Результат = НовыйРезультатЧтенияОписанияМетодовИзЗапроса();
	
	ТелоЗапроса = Запрос.ПолучитьТелоКакСтроку();
	
	Если Не ЗначениеЗаполнено(ТелоЗапроса) Тогда
		Результат.Ошибка = ОшибкаЗапроса(ТипОшибкиЗапросаОшибкаДанных(), НСтр("ru='Пустое тело запроса'"));
		Возврат Результат;
	КонецЕсли;
	
	Попытка
		Результат.ОписанияМетодов = ОбщегоНазначения.JSONВЗначение(ТелоЗапроса,,Ложь);
	Исключение
		Результат.Ошибка = ОшибкаЗапроса(ТипОшибкиЗапросаОшибкаДанных(),
			НСтр("ru='Не удалость прочитать переданное тело запроса.'"), ИнформацияОбОшибке());
		Возврат Результат;
	КонецПопытки;
	
	Если ТипЗнч(Результат.ОписанияМетодов) = Тип("Массив") Тогда
		Результат.ЭтоПакетМетодов = Истина;
	Иначе
		Результат.ОписанияМетодов = ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(Результат.ОписанияМетодов);
	КонецЕсли;
	
	Для Каждого ОписаниеМетода Из Результат.ОписанияМетодов Цикл
		ЗначениеСвойства = Неопределено;
		Если Не (ОписаниеМетода.Свойство("method", ЗначениеСвойства) И ЗначениеЗаполнено(ЗначениеСвойства)
			И ОписаниеМетода.Свойство("params")
			И ОписаниеМетода.Свойство("id", ЗначениеСвойства) И ЗначениеСвойства <> Неопределено) Тогда
			Результат.Ошибка = ОшибкаЗапроса(ТипОшибкиЗапросаОшибкаДанных(),
				НСтр("ru='Запрос не соответствует спецификации json-rpc 1.0.'"));
			Результат.ОписанияМетодов = Неопределено;
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

// Параметры:
//  ПараметрыЗапроса - Соответствие из КлючИЗначение - Параметры запроса
// 
// Возвращаемое значение:
//  См. НовыйРезультатЧтенияОписанияМетодовИзЗапроса
Функция ПрочитатьОписанияМетодовИзПараметровЗапроса(ПараметрыЗапроса)
	
	Результат = НовыйРезультатЧтенияОписанияМетодовИзЗапроса();
	
	ОписаниеМетода = НовоеОписаниеМетодаСервиса();
	
	ЗначениеПараметра = ПараметрыЗапроса.Получить("method");
	Если ЗначениеЗаполнено(ЗначениеПараметра) Тогда
		ОписаниеМетода.method = РаскодироватьСтроку(ЗначениеПараметра, СпособКодированияСтроки.URLВКодировкеURL);
	Иначе
		Возврат Результат;
	КонецЕсли;
	
	ЗначениеПараметра = ПараметрыЗапроса.Получить("params");
	Если ЗначениеЗаполнено(ЗначениеПараметра) Тогда
		ПараметрыМетодаСтрокойJSON = РаскодироватьСтроку(ЗначениеПараметра, СпособКодированияСтроки.URLВКодировкеURL);
		ОписаниеМетода.params = ОбщегоНазначения.JSONВЗначение(ПараметрыМетодаСтрокойJSON,,Ложь);
	Иначе
		Возврат Результат;
	КонецЕсли;
	
	ЗначениеПараметра = ПараметрыЗапроса.Получить("id");
	Если ЗначениеЗаполнено(ЗначениеПараметра) Тогда
		ОписаниеМетода.id = СтроковыеФункцииКлиентСервер.СтрокаВЧисло(ЗначениеПараметра);
	Иначе
		Возврат Результат;
	КонецЕсли;
	
	Результат.ОписанияМетодов.Добавить(ОписаниеМетода);
	
	Возврат Результат;
	
КонецФункции

// Параметры:
//  ОписанияМетодов - Массив из См. НовоеОписаниеМетодаСервиса
//  Версия - Строка
//  ИдентификаторЗапроса - Строка
// 
// Возвращаемое значение:
//  Массив из см. ВыполнитьМетод
Функция ВыполнитьМетодыЗапроса(ОписанияМетодов, Версия, ИдентификаторЗапроса)
	
	РезультатыМетодов = Новый Массив;
	Для Каждого ОписаниеМетода Из ОписанияМетодов Цикл
		РезультатМетода = ВыполнитьМетод(ОписаниеМетода, Версия, ИдентификаторЗапроса);
		РезультатыМетодов.Добавить(РезультатМетода);
	КонецЦикла;
	
	Возврат РезультатыМетодов;
	
КонецФункции

// Параметры:
//  ОписаниеМетода - См. НовоеОписаниеМетодаСервиса
//  Версия - Строка
//  ИдентификаторЗапроса - Строка
// 
// Возвращаемое значение:
//  См. НовыйРезультатМетода
Функция ВыполнитьМетод(ОписаниеМетода, Версия, ИдентификаторЗапроса)
	
	ИмяМетода = ОписаниеМетода.method;
	Параметры = ОписаниеМетода.params;
	
	ИмяМодуля = "";
	Если Версия = "3" Тогда
		ИмяМодуля = "ПрограммныйИнтерфейсЦентраЭДОВерсия3";
	ИначеЕсли Версия = "2" Тогда
		ИмяМодуля = "ПрограммныйИнтерфейсЦентраЭДОВерсия2";
	ИначеЕсли Версия = "1" Тогда
		ИмяМодуля = "ПрограммныйИнтерфейсЦентраЭДОВерсия1";
	Иначе
		Возврат РезультатМетодаОшибка(НСтр("ru='Указанная версия метода не поддерживается'"),
			КодОшибкиRPCМетодНеНайден());
	КонецЕсли;
	
	РезультатМетода = НовыйРезультатМетода();
	Попытка
		РезультатМетода.result = ОбщегоНазначения.ВызватьФункциюКонфигурации(
			ИмяМодуля + "." + ИмяМетода, Параметры);
	Исключение
		ИнформацияОбОшибке = ИнформацияОбОшибке();
		ТекстОшибки = ОбработкаОшибок.КраткоеПредставлениеОшибки(ИнформацияОбОшибке);
		РезультатМетода.error = НоваяОшибкаМетода(ТекстОшибки);
		
		ИмяСобытия = ИмяСобытияЖурналаРегистрацииВыполнениеМетода();
		Уровень = УровеньЖурналаРегистрации.Ошибка;
		ОбъектМетаданных = Метаданные.HTTPСервисы.edo;
		Комментарий = СтрШаблон(НСтр("ru='Ошибка при выполнении метода: %1'"), ИмяМетода)
			+ Символы.ПС + ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке);
		ЗаписьЖурналаРегистрации(ИмяСобытия, Уровень, ОбъектМетаданных, ИдентификаторЗапроса, Комментарий);
	КонецПопытки;
	
	РезультатМетода.id = ОписаниеМетода.id;
	
	Возврат РезультатМетода;
	
КонецФункции

// Возвращаемое значение:
//  Структура:
//  * result - Неопределено
//           - Структура
//           - Массив из Структура
//  * error - Неопределено
//          - См. НоваяОшибкаМетода
//  * id - Число
Функция НовыйРезультатМетода()
	Результат = Новый Структура;
	Результат.Вставить("result", Неопределено);
	Результат.Вставить("error", Неопределено);
	Результат.Вставить("id", 0);
	Возврат Результат;
КонецФункции

// Параметры:
//  ТекстОшибки - Строка
//  Код - Число
// 
// Возвращаемое значение:
//  Структура:
//  * code - Число
//  * message - Строка
//  * id - Число
Функция НоваяОшибкаМетода(ТекстОшибки = "", Код = 0)
	Ошибка = Новый Структура;
	Ошибка.Вставить("code", Код);
	Ошибка.Вставить("message", ТекстОшибки);
	Ошибка.Вставить("id", 0);
	Возврат Ошибка;
КонецФункции

// Параметры:
//  ТекстОшибки - Строка
//  Код - Число
// 
// Возвращаемое значение:
//  См. НовыйРезультатМетода
Функция РезультатМетодаОшибка(ТекстОшибки, Код = 0)
	РезультатМетода = НовыйРезультатМетода();
	РезультатМетода.error = НоваяОшибкаМетода(ТекстОшибки, Код);
	Возврат РезультатМетода;
КонецФункции

// Параметры:
//  РезультатыМетодов - Массив из см. ВыполнитьМетод
//  ЭтоПакетМетодов - Булево
//  Версия - Строка
// 
// Возвращаемое значение:
//  HTTPСервисОтвет
Функция ОтветПоРезультатамМетодов(РезультатыМетодов, ЭтоПакетМетодов, Версия)
	
	Если ЭтоПакетМетодов Тогда
		Тело = ОбщегоНазначения.ЗначениеВJSON(РезультатыМетодов);
	Иначе
		Тело = ОбщегоНазначения.ЗначениеВJSON(РезультатыМетодов[0]);
	КонецЕсли;
	
	Ответ = Новый HTTPСервисОтвет(КодСостоянияВыполнено());
	Ответ.Заголовки.Вставить(ИмяЗаголовкаТипПередаваемогоКонтента(), ПоддерживаемыйТипКонтентаОтвета(Версия));
	Ответ.УстановитьТелоИзСтроки(Тело);
	
	Возврат Ответ;
	
КонецФункции

// Параметры:
//  Версия - Строка
//
// Возвращаемое значение:
//  Строка
Функция ПоддерживаемыйТипКонтентаОтвета(Версия)
	Возврат "vnd.1cedo.rpc+json;version=" + Версия;
КонецФункции

// Возвращаемое значение:
//  Строка
Функция ИмяСобытияЖурналаРегистрацииВыполнениеМетода()
	Возврат ПредставлениеПодсистемы() + "." + НСтр("ru = 'Выполнение метода'");
КонецФункции

#КонецОбласти

#Область ОбработкаОшибок

// Возвращаемое значение:
//  Структура:
//  * Тип - Строка
//  * Текст - Строка
//  * Информация - Неопределено,ИнформацияОбОшибке
Функция НоваяОшибкаЗапроса()
	Ошибка = Новый Структура;
	Ошибка.Вставить("Тип", "");
	Ошибка.Вставить("Текст", "");
	Ошибка.Вставить("Информация", Неопределено);
	Возврат Ошибка;
КонецФункции

// Возвращаемое значение:
//  См. НоваяОшибкаЗапроса
Функция ОшибкаЗапроса(Тип, Текст, Информация = Неопределено)
	Ошибка = НоваяОшибкаЗапроса();
	Ошибка.Тип = Тип;
	Ошибка.Текст = Текст;
	Ошибка.Информация = Информация;
	Возврат Ошибка;
КонецФункции

// Возвращаемое значение:
//  Строка
Функция ТипОшибкиЗапросаНеНайдено()
	Возврат "NotFound";
КонецФункции

// Возвращаемое значение:
//  Строка
Функция ТипОшибкиЗапросаКонтентНеПоддерживается()
	Возврат "UnsupportedMediaType";
КонецФункции

// Возвращаемое значение:
//  Строка
Функция ТипОшибкиЗапросаОшибкаДанных()
	Возврат "BadRequest";
КонецФункции

// Возвращаемое значение:
//  Строка
Функция ТипОшибкиЗапросаВнутренняяОшибкаСервера()
	Возврат "InternalServerError";
КонецФункции

// Параметры:
//  Ошибка - см. НоваяОшибкаЗапроса
//  ИдентификаторЗапроса - Строка
// 
// Возвращаемое значение:
//  HTTPСервисОтвет
Функция ОтветПоОшибкеЗапроса(Ошибка, ИдентификаторЗапроса)
	
	КодСостояния = КодСостоянияОтветаПоТипуОшибки(Ошибка.Тип);
	
	Ответ = Новый HTTPСервисОтвет(КодСостояния, Ошибка.Текст);
	Тело = ТелоОтветаПоОшибкеЗапроса(Ответ.Причина, Ошибка.Текст, ИдентификаторЗапроса);
	Ответ.УстановитьТелоИзСтроки(Тело);
	
	Возврат Ответ;
	
КонецФункции

// Параметры:
//  Заголовок - Строка
//  Текст - Строка
//  ИдентификаторЗапроса - Строка
// 
// Возвращаемое значение:
//  Строка
Функция ТелоОтветаПоОшибкеЗапроса(Заголовок, Текст, ИдентификаторЗапроса)
	Возврат СтрШаблон(
		"{
		|  ""type"": ""https://1cfresh.com/a/cedo"",
		|  ""title"": ""%1"",
		|  ""detail"": ""%2"",
		|  ""traceId"": ""%3""
		|}",
		Заголовок, Текст, ИдентификаторЗапроса);
КонецФункции

#КонецОбласти

#Область КодыСостоянияОтветаHTTP

// Параметры:
//  ТипОшибки - Строка:
// 
// Возвращаемое значение:
//  Число
Функция КодСостоянияОтветаПоТипуОшибки(ТипОшибки)
	
	Если ТипОшибки = ТипОшибкиЗапросаНеНайдено() Тогда
		Возврат КодСостоянияНеНайдено();
	ИначеЕсли ТипОшибки = ТипОшибкиЗапросаКонтентНеПоддерживается() Тогда
		Возврат КодСостоянияКонтентНеПоддерживается();
	ИначеЕсли ТипОшибки = ТипОшибкиЗапросаОшибкаДанных() Тогда
		Возврат КодСостоянияОшибкаДанных();
	ИначеЕсли ТипОшибки = ТипОшибкиЗапросаВнутренняяОшибкаСервера() Тогда
		Возврат КодСостоянияВнутренняяОшибка();
	Иначе
		ВызватьИсключение СтрШаблон(НСтр("ru='Не найден код состояния ответа по типу ошибки ""%1"".'"), ТипОшибки);
	КонецЕсли;
	
КонецФункции

// Возвращаемое значение:
//  Число
Функция КодСостоянияВыполнено()
