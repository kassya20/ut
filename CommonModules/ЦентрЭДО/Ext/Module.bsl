// Параметры:
//  Запрос - HTTPСервисЗапрос
//  ИдентификаторЗапроса - Строка
Процедура ЗаписатьВызовСервисаВЖурналРегистрации(Запрос, ИдентификаторЗапроса)
	ИмяСобытия = ИмяСобытияЖурналаРегистрацииВызовСервиса();
	Уровень = УровеньЖурналаРегистрации.Информация;
	ОбъектМетаданных = Метаданные.HTTPСервисы.edo;
	Комментарий = ПредставлениеHTTPСервисЗапроса(Запрос);
	ЗаписьЖурналаРегистрации(ИмяСобытия, Уровень, ОбъектМетаданных, ИдентификаторЗапроса, Комментарий);
КонецПроцедуры

// Параметры:
//  Ответ - HTTPСервисОтвет
//  ИдентификаторЗапроса - Строка
//  ВремяНачала - Число - Длительность
Процедура ЗаписатьОтветСервисаВЖурналРегистрации(Ответ, ИдентификаторЗапроса, ВремяНачала)
	ИмяСобытия = ИмяСобытияЖурналаРегистрацииОтветСервиса();
	Уровень = ?(Ответ = Неопределено Или Ответ.КодСостояния >= КодСостоянияВнутренняяОшибка(),
		УровеньЖурналаРегистрации.Ошибка, УровеньЖурналаРегистрации.Информация);
	ОбъектМетаданных = Метаданные.HTTPСервисы.edo;
	Комментарий = ПредставлениеHTTPСервисОтвета(Ответ, ВремяНачала);
	ЗаписьЖурналаРегистрации(ИмяСобытия, Уровень, ОбъектМетаданных, ИдентификаторЗапроса, Комментарий);
КонецПроцедуры

// Параметры:
//  Запрос - HTTPСервисЗапрос
// 
// Возвращаемое значение:
//  Строка
Функция ПредставлениеHTTPСервисЗапроса(Запрос)
	
	Заголовки = Запрос.Заголовки;
	БазовыйURLБезПрокси = Заголовки.Получить("X-Root-URL");
	Если БазовыйURLБезПрокси <> Неопределено Тогда
		СтруктураЗапроса = ОбщегоНазначенияКлиентСервер.СтруктураURI(БазовыйURLБезПрокси);
		АдресБезПараметров = СтруктураЗапроса.ПутьНаСервере;
	Иначе
		СтруктураЗапроса = ОбщегоНазначенияКлиентСервер.СтруктураURI(Запрос.БазовыйURL);
		АдресБезПараметров = СтруктураЗапроса.ПутьНаСервере + Запрос.ОтносительныйURL;
	КонецЕсли;
	
	ПараметрыЗапроса = "";
	Для каждого ЭлементКоллекции Из Запрос.ПараметрыЗапроса Цикл
		ПараметрыЗапроса = ПараметрыЗапроса + ?(ПустаяСтрока(ПараметрыЗапроса), "?", "&")
			+ ЭлементКоллекции.Ключ + "=" + ЭлементКоллекции.Значение;
	КонецЦикла;
	
	ПредставлениеЗаголовков = ИнтернетСоединениеБЭД.ПредставлениеЗаголовковHTTPСписком(Заголовки);
	
	Представление = СтрШаблон(
		"%1 /%2%3
		|%4", Запрос.HTTPМетод, АдресБезПараметров, ПараметрыЗапроса, ПредставлениеЗаголовков);
	
	ТипКонтентаЗапроса = ТипКонтентаЗапроса(Запрос);
	Если ТипКонтентаЗапроса.Тип = ПоддерживаемыйТипКонтентаЗапроса() Тогда
		Тело = Запрос.ПолучитьТелоКакСтроку();
		Если ЗначениеЗаполнено(Тело) Тогда
			Представление = СтрШаблон(
				"%1
				|
				|%2", Представление, Тело);
		КонецЕсли;
	КонецЕсли; 
	
	Возврат Представление;
	
КонецФункции

// Параметры:
//  Ответ - Неопределено,HTTPСервисОтвет
//  ВремяНачала - Число
// 
// Возвращаемое значение:
//  Строка
Функция ПредставлениеHTTPСервисОтвета(Ответ, ВремяНачала)
	
	Длительность = (ТекущаяУниверсальнаяДатаВМиллисекундах() - ВремяНачала)/1000;
	
	Если Ответ = Неопределено Тогда
		ПредставлениеСостояния = "error";
	Иначе
		ПредставлениеСостояния = ИнтернетСоединениеБЭД.РасшифровкаКодаСостоянияHTTP(Ответ.КодСостояния);
	КонецЕсли;
	
	ОсновныеСвойства = СтрШаблон("%1 - %2.%3 (%4 sec)",
		ПредставлениеСостояния,
		Формат(ТекущаяДатаСеанса(), "ДФ='dd.MM.yyyy HH:mm:ss'"),
		Формат(ВремяНачала % 1000, "ЧЦ=3; ЧВН="),
		Формат(Длительность, "ЧДЦ=3; ЧН=0"));
	
	Если Ответ = Неопределено Тогда
		Возврат ОсновныеСвойства;
	КонецЕсли;
	
	ЧастиПредставления = Новый Массив; // Массив из Строка
	ЧастиПредставления.Добавить(ОсновныеСвойства);
	
	ПредставлениеЗаголовков = ИнтернетСоединениеБЭД.ПредставлениеЗаголовковHTTPСписком(Ответ.Заголовки);
	ЧастиПредставления.Добавить(ПредставлениеЗаголовков);
	
	Тело = Ответ.ПолучитьТелоКакСтроку();
	Если ЗначениеЗаполнено(Тело) Тогда
		ЧастиПредставления.Добавить("");
		ЧастиПредставления.Добавить(Тело);
	КонецЕсли;
	
	Возврат СтрСоединить(ЧастиПредставления, Символы.ПС);
	
КонецФункции

