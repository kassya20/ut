// Обработка события "После загрузки подтверждения по счету фактуре".
// 
// Параметры:
//  ЭлектронныйДокумент - ДокументСсылка.ЭлектронныйДокументВходящийЭДО,ДокументСсылка.ЭлектронныйДокументИсходящийЭДО
//  ДокументыПодтверждения - См. ЭлектронныеДокументыЭДОСобытия.ПослеЗагрузкиПодтвержденияПоСчетуФактуре.ДокументыПодтверждения
Процедура ПослеЗагрузкиПодтвержденияПоСчетуФактуре(ЭлектронныйДокумент, ДокументыПодтверждения) Экспорт
	
	ТекущееПодтверждение = ДокументыПодтверждения.Найти(Истина, "Текущий");
	Если ТекущееПодтверждение = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ТипЭлементаРегламента = ТекущееПодтверждение.ТипЭлементаРегламента;
	Если ТипЭлементаРегламента = Перечисления.ТипыЭлементовРегламентаЭДО.ПДП Тогда
		ТипСобытия = Перечисления.ТипыСобытийДокументаЦентраЭДО.ПослеПолученияПоСчетуФактуреПДП;
	ИначеЕсли ТипЭлементаРегламента = Перечисления.ТипыЭлементовРегламентаЭДО.ПДО Тогда
		ТипСобытия = Перечисления.ТипыСобытийДокументаЦентраЭДО.ПослеПолученияПоСчетуФактуреПДО;
	ИначеЕсли ТипЭлементаРегламента = Перечисления.ТипыЭлементовРегламентаЭДО.ИОП Тогда
		ТипСобытия = Перечисления.ТипыСобытийДокументаЦентраЭДО.ПослеПолученияПоСчетуФактуреИОП;
	ИначеЕсли ТипЭлементаРегламента = Перечисления.ТипыЭлементовРегламентаЭДО.ИОП_ПДП Тогда
		ТипСобытия = Перечисления.ТипыСобытийДокументаЦентраЭДО.ПослеПолученияПоСчетуФактуреИОП_ПДО;
	Иначе
		Возврат;
	КонецЕсли;
	
	МеткиВремениДанныхЭДО.ЗафиксироватьСобытиеДокументаЭДО(ЭлектронныйДокумент, ТипСобытия);
	
КонецПроцедуры

