// Параметры:
//   Ограничение - см. УправлениеДоступомПереопределяемый.ПриЗаполненииОграниченияДоступа.Ограничение.
//
Процедура ПриЗаполненииОграниченияДоступа(Ограничение) Экспорт
	
	Ограничение.Текст =
	"РазрешитьЧтениеИзменение
	|ГДЕ
	|	ЧтениеСпискаРазрешено(ТипСсылки)";
	
КонецПроцедуры

// Конец СтандартныеПодсистемы.УправлениеДоступом

#КонецОбласти

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция НовыйНаборДляЗаписи(ОписаниеТиповТаблицы) Экспорт
	
	ТаблицаДляЗаписи = Новый ТаблицаЗначений;
	Колонки = "ТипСсылки,ГруппаДублей,Дубль,Источник,ДатаДобавления,КоличествоМестИспользования,ДатаПоискаМестИспользования";
	
	Для Каждого Колонка Из СтрРазделить(Колонки, ",", Ложь) Цикл
		ТаблицаДляЗаписи.Колонки.Добавить(Колонка, ОписаниеТиповТаблицы[Колонка]);
	КонецЦикла;
	
	Возврат ТаблицаДляЗаписи;
	
КонецФункции

Функция ОписаниеТиповТаблицыРегистра() Экспорт
	
	Результат = Новый Структура;
	
	Регистр = Метаданные.РегистрыСведений.ДублиНСИКПодтверждению;
	
	Для Каждого Измерение Из Регистр.Измерения Цикл
		Результат.Вставить(Измерение.Имя, Измерение.Тип);
	КонецЦикла;
	
	Для Каждого Ресурс Из Регистр.Ресурсы Цикл
		Результат.Вставить(Ресурс.Имя, Ресурс.Тип);
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Функция НормализованнаяИнформацияОДублях(Дубли)
	
	Результат = Новый Структура;
	Результат.Вставить("ДублиОтбор");
	Результат.Вставить("ПарыДублей");
	
	Если ТипЗнч(Дубли) = Тип("Массив") Тогда
		Результат.ДублиОтбор = Дубли;
		Результат.ПарыДублей = ПарыДублей(Дубли);
	Иначе
		ДублиОтбор = Новый Массив;
		ОбщегоНазначенияКлиентСервер.ДополнитьМассив(ДублиОтбор, Дубли.ВыгрузитьКолонку(0), Истина);
		ОбщегоНазначенияКлиентСервер.ДополнитьМассив(ДублиОтбор, Дубли.ВыгрузитьКолонку(1), Истина);
		
		Результат.ДублиОтбор = ДублиОтбор;
		Результат.ПарыДублей = Дубли;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ПарыДублей(Дубли)
	
	КопияМассива = ОбщегоНазначения.СкопироватьРекурсивно(Дубли);
	
	ПарыДублей = Новый ТаблицаЗначений;
	ПарыДублей.Колонки.Добавить("Ссылка1");
	ПарыДублей.Колонки.Добавить("Ссылка2");
	
	ВсегоВМассиве = КопияМассива.количество() - 1;
	Для Индекс = 0 По ВсегоВМассиве Цикл
		
		ОбратныйИндекс = ВсегоВМассиве - Индекс;
		
		Для Каждого ЭлементМассива Из КопияМассива Цикл
			Если КопияМассива[ОбратныйИндекс] <> ЭлементМассива Тогда
				Строка = ПарыДублей.Добавить();
				Строка.Ссылка1 = КопияМассива[ОбратныйИндекс];
				Строка.Ссылка2 = ЭлементМассива;
			КонецЕсли;
		КонецЦикла;
		
		КопияМассива.Удалить(ОбратныйИндекс);
		
	КонецЦикла;
	
	Возврат ПарыДублей;
	
КонецФункции

Процедура ДобавитьДубльВИндекс(ИндексыГрупп, Дубль, ГруппаДублей, Источник)
	
	НоваяСтрока = ИндексыГрупп.Добавить();
	НоваяСтрока.Дубль = Дубль;
	НоваяСтрока.ГруппаДублей = ГруппаДублей;
	НоваяСтрока.Источник = Источник;
	
КонецПроцедуры

// Возвращает массив групп, в которых содержится указанный дублирующий объект.
//
// Параметры:
//   ИндексДублиИГруппы - ТаблицаЗначений - таблица-индекс, содержащая связи дублей с группами и источниками
//   Дубль - СправочникСсылка
//         - ПланВидовХарактеристикСсылка - объект, для которого ищутся группы
//
// Возвращаемое значение:
//   Массив из Структура:
//                       * ГруппаДублей - Строка
//                       * Источник - СправочникСсылка.ПравилаПоискаДублейНСИ,СправочникСсылка.Пользователи
//
Функция ГруппыДубляВИндексе(ИндексДублиИГруппы, Дубль)
	
	Результат = Новый Массив;
	
	СтрокиПоиска = ИндексДублиИГруппы.НайтиСтроки(Новый Структура("Дубль", Дубль));
	Для Каждого СтрокаПоиска Из СтрокиПоиска Цикл
		Результат.Добавить(Новый Структура("ГруппаДублей, Источник", СтрокаПоиска.ГруппаДублей, СтрокаПоиска.Источник));
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Процедура ДобавитьСтрокуВНабор(ТаблицаДляЗаписи, Дубль, ГруппаДублей, Источник)
	
	НоваяСтрока = ТаблицаДляЗаписи.Добавить();
	НоваяСтрока.Дубль = Дубль;
	НоваяСтрока.ГруппаДублей = ГруппаДублей;
	НоваяСтрока.Источник = Источник;
	
КонецПроцедуры

Функция НужноСоздатьНовуюГруппу(ГруппыДубляОдин, ГруппыДубляДва)
	
	ОбеНепустые = ГруппыДубляОдин.Количество() > 0 И ГруппыДубляДва.Количество() > 0;
	ОбеПустые = ГруппыДубляОдин.Количество() = 0 И ГруппыДубляДва.Количество() = 0;
	
	Если ОбеНепустые Или ОбеПустые Тогда
		Возврат Истина;
	Иначе
		Возврат Ложь;
	КонецЕсли;
	
КонецФункции

Функция ДублиНаходятсяВОднойГруппе(Группа1, Группа2)
	
	ВсеГруппы = Новый Массив;
	
	Для Каждого ЭлементМасива Из Группа1 Цикл
		ВсеГруппы.Добавить(ЭлементМасива.ГруппаДублей);
	КонецЦикла;
	
	Для Каждого ЭлементМасива Из Группа2 Цикл
		ВсеГруппы.Добавить(ЭлементМасива.ГруппаДублей);
	КонецЦикла;
	
	УникальныеГруппы = Новый Массив;
	ОбщегоНазначенияКлиентСервер.ДополнитьМассив(УникальныеГруппы, ВсеГруппы, Истина);
	
	ЭтоДублиИзОднойГруппы = ВсеГруппы.Количество() <> УникальныеГруппы.Количество();
	
	Возврат ЭтоДублиИзОднойГруппы;
	
КонецФункции

// Дополняет таблицу строк информацией о типах ссылок и количестве мест использования дублей НСИ.
//
// Параметры:
//   ТаблицаДляЗаписи - ТаблицаЗначений - таблица, содержащая колонку "Дубль" со ссылками для обработки.
//   РежимОбновленияМестИспользования - Булево, Неопределено - определяет режим обновления количества мест использования.
//      Если Неопределено, тогда обновления не происходит.
//      Если Истина, тогда обновление происходит.
//      Если Ложь, тогда обновление зависит от значения константы ВыполнятьПоискМестИспользованияДублейНСИ.
//
Процедура ДополнитьИнформациейПоСсылкам(ТаблицаДляЗаписи, РежимОбновленияМестИспользования = Неопределено) Экспорт
	
	Дубли = ТаблицаДляЗаписи.ВыгрузитьКолонку("Дубль");
	ПодсчетСсылок = Новый Соответствие;
	Для Каждого Дубль Из Дубли Цикл
		ИнформацияОСсылке = Новый Структура;
		ИнформацияОСсылке.Вставить("МестИспользования", 0);
		ИнформацияОСсылке.Вставить("ПолноеИмяОбъектаМетаданных", ОбщегоНазначения.ИмяТаблицыПоСсылке(Дубль));
		ИнформацияОСсылке.Вставить("ДатаПоискаМестИспользования");
		ИнформацияОСсылке.Вставить("ДатаДобавления");
		
		ПодсчетСсылок.Вставить(Дубль, ИнформацияОСсылке);
	КонецЦикла;
	
	Если РежимОбновленияМестИспользования = Неопределено Тогда
		ИскатьМестаИспользования = Ложь;
	Иначе
		УстановитьПривилегированныйРежим(Истина);
		ИскатьМестаИспользования = Константы.ВыполнятьПоискМестИспользованияДублейНСИ.Получить()
			Или РежимОбновленияМестИспользования;
		УстановитьПривилегированныйРежим(Ложь);
	КонецЕсли;
	
	Если ИскатьМестаИспользования Тогда
		РезультатПоиска = ОбщегоНазначения.МестаИспользования(Дубли);
		ДатаПоиска = ТекущаяДатаСеанса();
		
		Для Каждого СтрокаПоиска Из РезультатПоиска Цикл
			Если Не СтрокаПоиска.ЭтоСлужебныеДанные Тогда
				ИнформацияОСсылке = ПодсчетСсылок[СтрокаПоиска.Ссылка];
				ИнформацияОСсылке.МестИспользования = ИнформацияОСсылке.МестИспользования + 1;
				ИнформацияОСсылке.ДатаПоискаМестИспользования = ДатаПоиска;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
	ДатаДобавления = ТекущаяДатаСеанса();
	Для Каждого СтрокаДляЗаписи Из ТаблицаДляЗаписи Цикл
		ИнформацияОСсылке = ПодсчетСсылок[СтрокаДляЗаписи.Дубль];
		
		СтрокаДляЗаписи.ТипСсылки = ОбщегоНазначения.ИдентификаторОбъектаМетаданных(ИнформацияОСсылке.ПолноеИмяОбъектаМетаданных);
		Если Не ЗначениеЗаполнено(СтрокаДляЗаписи.ДатаДобавления) Тогда
			СтрокаДляЗаписи.ДатаДобавления = ДатаДобавления;
		КонецЕсли;
		
		Если ИскатьМестаИспользования Тогда
			СтрокаДляЗаписи.КоличествоМестИспользования = ИнформацияОСсылке.МестИспользования;
			СтрокаДляЗаписи.ДатаПоискаМестИспользования = ИНформацияОСсылке.ДатаПоискаМестИспользования;
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

// Возвращает количество дублирующихся записей для каждого типа справочника из доступных.
//
// Возвращаемое значение:
//   ТаблицаЗначений:
//     * ТипСсылки - СправочникСсылка.ИдентификаторыОбъектовМетаданных
//     * КоличествоДублей - Число
//
Функция ТипыДубейСКоличеством() Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	ДублиНСИКПодтверждению.ТипСсылки КАК ТипСсылки,
		|	КОЛИЧЕСТВО(ДублиНСИКПодтверждению.Дубль) КАК КоличествоДублей
		|ИЗ
		|	РегистрСведений.ДублиНСИКПодтверждению КАК ДублиНСИКПодтверждению
		|СГРУППИРОВАТЬ ПО
		|	ДублиНСИКПодтверждению.ТипСсылки";
	Результат = Запрос.Выполнить().Выгрузить();
	
	Возврат Результат;
	
КонецФункции

// Возвращает выборку записей по указанным дублям.
//
// Параметры:
//   ДублиОтбор - Массив из СправочникСсылка,ПланВидовХарактеристикСсылка - значения для отбора по полю "Дубль"
//
// Возвращаемое значение:
//   ВыборкаИзРезультатаЗапроса - Выборка из результата запроса:
//     * Дубль - СправочникСсылка,ПланВидовХарактеристикСсылка - ссылка на дубль.
//     * ГруппаДублей - Строка - идентификатор группы дублей.
//     * Источник - СправочникСсылка.ПравилаПоискаДублейНСИ,СправочникСсылка.Пользователи.
//
Функция СуществующиеДубли(ДублиОтбор) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ДублиНСИКПодтверждению.Дубль КАК Дубль,
	|	ДублиНСИКПодтверждению.ГруппаДублей КАК ГруппаДублей,
	|	ДублиНСИКПодтверждению.Источник КАК Источник
	|ИЗ
	|	РегистрСведений.ДублиНСИКПодтверждению КАК ДублиНСИКПодтверждению
	|ГДЕ
	|	ДублиНСИКПодтверждению.Дубль В (&ДублиОтбор)";
	Запрос.УстановитьПараметр("ДублиОтбор", ДублиОтбор);
	
	УстановитьПривилегированныйРежим(Истина);
	РезутьтатЗапроса = Запрос.Выполнить();
	УстановитьПривилегированныйРежим(Ложь);
	
	Возврат РезутьтатЗапроса.Выбрать();
	
КонецФункции

// Распределяет дубли по группам на основе переданных пар дублей и источника данных.
//
// Параметры:
//   ПарыДублей - ТаблицаЗначений - дублей для распределения:
//     * Ссылка1 - СправочникСсылка,ПланВидовХарактеристикСсылка - ссылка на дубль.
//     * Ссылка2 - СправочникСсылка,ПланВидовХарактеристикСсылка - ссылка на дубль.
//   Источник - СправочникСсылка.ПравилаПоискаДублейНСИ,СправочникСсылка.Пользователи - правило поиска дублей или ответсвтенный.
//   ДублиВБазе - ВыборкаИзРезультатаЗапроса - см. СуществующиеДубли
//
// Возвращаемое значение:
//   ТаблицаЗначений - таблица с распределенными по группам дублями:
//     * Дубль - СправочникСсылка,ПланВидовХарактеристикСсылка - ссылка на дубль.
//     * ГруппаДублей - Строка - идентификатор группы дублей.
//     * Источник - СправочникСсылка.ПравилаПоискаДублейНСИ,СправочникСсылка.Пользователи
//
Функция РаспределитьДублиПоГруппам(ПарыДублей, Источник, ДублиВБазе = Неопределено) Экспорт
	
	ОписаниеТиповТаблицы = ОписаниеТиповТаблицыРегистра();
	ОписаниеТиповТаблицы.Дубль = ПарыДублей.Колонки[0].ТипЗначения;
	
	ИндексДублиИГруппы = Новый ТаблицаЗначений;
	ИндексДублиИГруппы.Колонки.Добавить("Дубль", ОписаниеТиповТаблицы.Дубль);
	ИндексДублиИГруппы.Колонки.Добавить("ГруппаДублей", ОписаниеТиповТаблицы.ГруппаДублей);
	ИндексДублиИГруппы.Колонки.Добавить("Источник", ОписаниеТиповТаблицы.Источник);
	ИндексДублиИГруппы.Индексы.Добавить("Дубль");
	ИндексДублиИГруппы.Индексы.Добавить("Источник");
	
	Если ТипЗнч(ДублиВБазе) = Тип("ВыборкаИзРезультатаЗапроса") Тогда
		Пока ДублиВБазе.Следующий() Цикл
			ДобавитьДубльВИндекс(ИндексДублиИГруппы, ДублиВБазе.Дубль, ДублиВБазе.ГруппаДублей, ДублиВБазе.Источник);
		КонецЦикла;
	КонецЕсли;
	
	ДублиПоГруппам = НовыйНаборДляЗаписи(ОписаниеТиповТаблицы);
	
	Для Каждого ПараДублей Из ПарыДублей Цикл
		
		ДубльОдин = ПараДублей[0];
		ДубльДва = ПараДублей[1];
		
		ГруппыДубляОдин = ГруппыДубляВИндексе(ИндексДублиИГруппы, ДубльОдин);
		ГруппыДубляДва = ГруппыДубляВИндексе(ИндексДублиИГруппы, ДубльДва);
		
		Если ДублиНаходятсяВОднойГруппе(ГруппыДубляОдин, ГруппыДубляДва) Тогда
			
			Продолжить;
			
		ИначеЕсли НужноСоздатьНовуюГруппу(ГруппыДубляОдин, ГруппыДубляДва) Тогда
			
			НоваяГруппа = Строка(Новый УникальныйИдентификатор());
			ДобавитьДубльВИндекс(ИндексДублиИГруппы, ДубльОдин, НоваяГруппа, Источник);
			ДобавитьДубльВИндекс(ИндексДублиИГруппы, ДубльДва, НоваяГруппа, Источник);
			ДобавитьСтрокуВНабор(ДублиПоГруппам, ДубльОдин, НоваяГруппа, Источник);
			ДобавитьСтрокуВНабор(ДублиПоГруппам, ДубльДва, НоваяГруппа, Источник);
			
		ИначеЕсли ГруппыДубляОдин.Количество() = 0 Тогда
			
			Для Каждого ГруппаИсточник Из ГруппыДубляДва Цикл
				Если ГруппаИсточник.Источник = Источник Тогда
					Группа = ГруппаИсточник.ГруппаДублей;
					ДобавитьДубльВИндекс(ИндексДублиИГруппы, ДубльОдин, Группа, Источник);
					ДобавитьСтрокуВНабор(ДублиПоГруппам, ДубльОдин, Группа, Источник);
					Прервать;
				Иначе
					НоваяГруппа = Строка(Новый УникальныйИдентификатор());
					ДобавитьДубльВИндекс(ИндексДублиИГруппы, ДубльОдин, НоваяГруппа, Источник);
					ДобавитьДубльВИндекс(ИндексДублиИГруппы, ДубльДва, НоваяГруппа, Источник);
					ДобавитьСтрокуВНабор(ДублиПоГруппам, ДубльОдин, НоваяГруппа, Источник);
					ДобавитьСтрокуВНабор(ДублиПоГруппам, ДубльДва, НоваяГруппа, Источник);
				КонецЕсли;
			КонецЦикла;
			
		ИначеЕсли ГруппыДубляДва.Количество() = 0 Тогда
			
			Для Каждого ГруппаИсточник Из ГруппыДубляОдин Цикл
				Если ГруппаИсточник.Источник = Источник Тогда
					Группа = ГруппаИсточник.ГруппаДублей;
					ДобавитьДубльВИндекс(ИндексДублиИГруппы, ДубльДва, Группа, Источник);
					ДобавитьСтрокуВНабор(ДублиПоГруппам, ДубльДва, Группа, Источник);
					Прервать;
				Иначе
					НоваяГруппа = Строка(Новый УникальныйИдентификатор());
					ДобавитьДубльВИндекс(ИндексДублиИГруппы, ДубльОдин, НоваяГруппа, Источник);
					ДобавитьДубльВИндекс(ИндексДублиИГруппы, ДубльДва, НоваяГруппа, Источник);
					ДобавитьСтрокуВНабор(ДублиПоГруппам, ДубльОдин, НоваяГруппа, Источник);
					ДобавитьСтрокуВНабор(ДублиПоГруппам, ДубльДва, НоваяГруппа, Источник);
				КонецЕсли;
			КонецЦикла;
			
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат ДублиПоГруппам;
	
КонецФункции

// Формирует строковое представление группы по наименованиям элементов из входящего массива.
//
// Параметры:
//   Массив - Массив из СправочникСсылка.ПравилаПоискаДублейНСИ - коллекция значений, содержащая ссылки на элементы справочников-дублей
//
// Возвращаемое значение:
//   Строка - Представление группы
//
Функция ПредставлениеГруппы(Массив) Экспорт
	
	Результат = "";
	ОграничениеДлины = 100;
	
	МассивРезультатов = Новый Массив;
	Для Каждого Элемент Из Массив Цикл
		Если МассивРезультатов.Найти(Элемент) = Неопределено Тогда
			МассивРезультатов.Добавить(СокрЛП(Элемент));
		КонецЕсли;
	КонецЦикла;
	Результат = Лев(СтрСоединить(МассивРезультатов, ","),ОграничениеДлины) + "...";
	
	Возврат Результат;
	
КонецФункции

// Возвращает массив идентификаторов групп, связанных с указанной группой через общие дубли.
//
// Параметры:
//   Группа - Строка - идентификатор группы дублей.
//
// Возвращаемое значение:
//   Массив из Строка
//
Функция СвязанныеГруппы(Группа) Экспорт
	
	СвязанныеГруппы = Новый Соответствие;
	СвязанныеГруппы.Вставить(Группа, Истина);
	
	Стек = Новый Массив;
	Стек.Добавить(Группа);
	
	Пока Стек.Количество() > 0 Цикл
		Индекс = Стек.ВГраница();
		ТекущаяГруппа = Стек.Получить(Индекс);
		Стек.Удалить(Индекс);
		
		Запрос = Новый Запрос;
		Запрос.Текст =
			"ВЫБРАТЬ РАЗЛИЧНЫЕ
			|	Таблица2.ГруппаДублей КАК СвязаннаяГруппа
			|ИЗ
			|	РегистрСведений.ДублиНСИКПодтверждению КАК Таблица1
			|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.ДублиНСИКПодтверждению КАК Таблица2
			|		ПО Таблица1.Дубль = Таблица2.Дубль
			|ГДЕ
			|	Таблица1.ГруппаДублей = &ТекущаяГруппа
			|	И Таблица2.ГруппаДублей <> &ТекущаяГруппа
			|	И Таблица2.ГруппаДублей НЕ В (&ПосещенныеГруппы)";
		
		ПосещенныеГруппы = Новый Массив;
		Для Каждого КлючЗначение Из СвязанныеГруппы Цикл
			ПосещенныеГруппы.Добавить(КлючЗначение.Ключ);
		КонецЦикла;
		
		Запрос.УстановитьПараметр("ТекущаяГруппа", ТекущаяГруппа);
		Запрос.УстановитьПараметр("ПосещенныеГруппы", ПосещенныеГруппы);
		
		СвязанныеГруппыВыборка = Запрос.Выполнить().Выбрать();
		Пока СвязанныеГруппыВыборка.Следующий() Цикл
			СвязаннаяГруппа = СвязанныеГруппыВыборка.СвязаннаяГруппа;
			Если СвязанныеГруппы[СвязаннаяГруппа] = Неопределено Тогда
				СвязанныеГруппы.Вставить(СвязаннаяГруппа, Истина);
				Стек.Добавить(СвязаннаяГруппа);
			КонецЕсли;
		КонецЦикла;
	КонецЦикла;
	
	Результат = Новый Массив;
	Для Каждого КлючЗначение Из СвязанныеГруппы Цикл
		Результат.Добавить(КлючЗначение.Ключ);
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции


#КонецОбласти

#КонецЕсли
