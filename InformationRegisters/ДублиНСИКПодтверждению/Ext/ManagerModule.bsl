#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда
	
#Область ПрограммныйИнтерфейс

// Добавляет дубли к подтверждению
//
// Параметры:
//   Дубли - Массив из СправочникСсылка.ПравилаПоискаДублейНСИ,СправочникСсылка.Пользователи
//         - ТаблицаЗначений - таблица, содержащая пары дублей для добавления:
//           * Ссылка1 - СправочникСсылка, ПланВидовХарактеристикСсылка - ссылка на дубль
//           * Ссылка2 - СправочникСсылка, ПланВидовХарактеристикСсылка - ссылка на дубль,
//   Источник - СправочникСсылка.ПравилаПоискаДублейНСИ - правило поиска, по которому найдены дубли
//            - СправочникСсылка.Пользователи - пользователь, который отметил элементы дублями
//   РассчетМестИспользования - Неопределено, Булево - необходимость дополнить записи информацией об использовании ссылок.
//
Процедура ДобавитьДубли(Дубли, Источник, РассчетМестИспользования = Неопределено) Экспорт
	
	Данные = НормализованнаяИнформацияОДублях(Дубли);
	ДублиОтбор = Данные.ДублиОтбор;
	ПарыДублей = Данные.ПарыДублей;
	
	ТаблицаДляЗаписи = РаспределитьДублиПоГруппам(ПарыДублей, Источник, СуществующиеДубли(ДублиОтбор));
	ДополнитьИнформациейПоСсылкам(ТаблицаДляЗаписи, РассчетМестИспользования);
	
	НаборЗаписей = СоздатьНаборЗаписей();
	НаборЗаписей.Загрузить(ТаблицаДляЗаписи);
	УстановитьПривилегированныйРежим(Истина);
	НаборЗаписей.Записать(РежимЗамещения.Добавление);
	УстановитьПривилегированныйРежим(Ложь);
	
КонецПроцедуры

// Обновляет информацию о местах использования для указанных дублей НСИ.
//
// Параметры:
//   ДублиКОбновлению - Массив из СправочникСсылка,ПланВидовХарактеристикСсылка - дубли для которых требуется пересчет
//                                                                                мест использования.
//
// Возвращаемое значение:
//   Соответствие из СправочникСсылка,ПланВидовХарактеристикСсылка:
//     * Ключ - СправочникСсылка,ПланВидовХарактеристикСсылка - дубль.
//     * Значение - Структура - с ключами "ДатаПоискаМестИспользования" и "КоличествоМестИспользования":
//        ** ДатаПоискаМестИспользования - Дата.
//        ** КоличествоМестИспользования - Число.
//
Функция ПеречитатьМестаИспользования(ДублиКОбновлению) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ДублиНСИКПодтверждению.ТипСсылки КАК ТипСсылки,
		|	ДублиНСИКПодтверждению.ГруппаДублей КАК ГруппаДублей,
		|	ДублиНСИКПодтверждению.Дубль КАК Дубль,
		|	ДублиНСИКПодтверждению.Источник КАК Источник,
		|	ДублиНСИКПодтверждению.ДатаДобавления КАК ДатаДобавления,
		|	ДублиНСИКПодтверждению.ДатаПоискаМестИспользования КАК ДатаПоискаМестИспользования,
		|	ДублиНСИКПодтверждению.КоличествоМестИспользования КАК КоличествоМестИспользования
		|ИЗ
		|	РегистрСведений.ДублиНСИКПодтверждению КАК ДублиНСИКПодтверждению
		|ГДЕ
		|ДублиНСИКПодтверждению.Дубль В (&Дубли)";
	Запрос.УстановитьПараметр("Дубли", ДублиКОбновлению);
	
	НаборВыгрузка = Запрос.Выполнить().Выгрузить();
	ДополнитьИнформациейПоСсылкам(НаборВыгрузка, Истина);
	
	НаборЗаписей = СоздатьНаборЗаписей();
	НаборЗаписей.Загрузить(НаборВыгрузка);
	НаборЗаписей.Записать(РежимЗамещения.Обновление);
	
	Результат = Новый Соответствие;
	Для Каждого Запись Из НаборВыгрузка Цикл
		Если Результат[Запись.Дубль] = Неопределено Тогда
			ДанныеДубля = Новый Структура;
			ДанныеДубля.Вставить("ДатаПоискаМестИспользования", Запись.ДатаПоискаМестИспользования);
			ДанныеДубля.Вставить("КоличествоМестИспользования", Запись.КоличествоМестИспользования);
			
			Результат.Вставить(Запись.Дубль, ДанныеДубля);
		КонецЕсли;
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

// Удаляет записи регистра, входящие в указанные группы дублей. Если переданы дубли, то удаляются записи только
// с этими дублями, если не переданы, то удаляется все группы целиком.
//
// Параметры:
//   ИдентификаторыГрупп - Строка - идентификатор группы дублей, записи которой необходимо удалить.
//                       - Массив из Строка - идентификаторы группы дублей, записи которых необходимо удалить.
//   Дубли - СправочникСсылка,ПланВидовХарактеристикСсылка.
//         - Массив из СправочникСсылка,ПланВидовХарактеристикСсылка - дубли, которые необходимо удалить.
//
Процедура УдалитьДубли(ИдентификаторыГрупп, Дубли = Неопределено) Экспорт
	
	Если ТипЗнч(ИдентификаторыГрупп) <> Тип("Массив") Тогда
		Группы = ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(ИдентификаторыГрупп);
	Иначе
		Группы = ИдентификаторыГрупп;
	КонецЕсли;
	
	ТекстЗапроса = 
		"ВЫБРАТЬ
		|	ДублиНСИКПодтверждению.ТипСсылки КАК ТипСсылки,
		|	ДублиНСИКПодтверждению.ГруппаДублей КАК ГруппаДублей,
		|	ДублиНСИКПодтверждению.Дубль КАК Дубль,
		|	ДублиНСИКПодтверждению.Источник КАК Источник,
		|	ДублиНСИКПодтверждению.ДатаДобавления КАК ДатаДобавления,
		|	ДублиНСИКПодтверждению.КоличествоМестИспользования КАК КоличествоМестИспользования,
		|	ДублиНСИКПодтверждению.ДатаПоискаМестИспользования КАК ДатаПоискаМестИспользования,
		|	АВТОНОМЕРЗАПИСИ() КАК НомерПоПорядку
		|ПОМЕСТИТЬ ВременнаяТаблица
		|ИЗ
		|	РегистрСведений.ДублиНСИКПодтверждению КАК ДублиНСИКПодтверждению
		|ГДЕ
		|	ДублиНСИКПодтверждению.ГруппаДублей В (&Группы)
		|	И &ОтборДубли
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВременнаяТаблица.ТипСсылки КАК ТипСсылки,
		|	ВременнаяТаблица.ГруппаДублей КАК ГруппаДублей,
		|	ВременнаяТаблица.Дубль КАК Дубль,
		|	ВременнаяТаблица.Источник КАК Источник,
		|	ВременнаяТаблица.ДатаДобавления КАК ДатаДобавления,
		|	ВременнаяТаблица.КоличествоМестИспользования КАК КоличествоМестИспользования,
		|	ВременнаяТаблица.ДатаПоискаМестИспользования КАК ДатаПоискаМестИспользования,
		|	ЦЕЛ(ВременнаяТаблица.НомерПоПорядку / &КратностьГрупп) КАК Группа
		|ПОМЕСТИТЬ Результат
		|ИЗ
		|	ВременнаяТаблица КАК ВременнаяТаблица
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Результат.ТипСсылки КАК ТипСсылки,
		|	Результат.ГруппаДублей КАК ГруппаДублей,
		|	Результат.Дубль КАК Дубль,
		|	Результат.Источник КАК Источник,
		|	Результат.ДатаДобавления КАК ДатаДобавления,
		|	Результат.КоличествоМестИспользования КАК КоличествоМестИспользования,
		|	Результат.ДатаПоискаМестИспользования КАК ДатаПоискаМестИспользования,
		|	Результат.Группа КАК Группа
		|ИЗ
		|	Результат КАК Результат
		|ИТОГИ
		|ПО
		|	Группа";
		
	Запрос = Новый Запрос;
	
	Если Дубли <> Неопределено Тогда
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&ОтборДубли", "ДублиНСИКПодтверждению.Дубль В (&Дубли)");
		Запрос.УстановитьПараметр("Дубли", Дубли);
	Иначе
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&ОтборДубли", "ИСТИНА");
	КонецЕсли;
	
	Запрос.Текст = ТекстЗапроса;
	Запрос.УстановитьПараметр("Группы", Группы);
	Запрос.УстановитьПараметр("КратностьГрупп", 100);
	
	РезультатЗапроса = Запрос.Выполнить();
	ВыборкаГруппа = РезультатЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	Пока ВыборкаГруппа.Следующий() Цикл
		НаборКУдалению = СоздатьНаборЗаписей();
		
		Выборка = ВыборкаГруппа.Выбрать();
		Пока Выборка.Следующий() Цикл
			ЗаполнитьЗначенияСвойств(НаборКУдалению.Добавить(), Выборка);
		КонецЦикла;
		
		НаборКУдалению.Записать(РежимЗамещения.Удаление);
	КонецЦикла;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ
		|	ДублиНСИКПодтверждению.ГруппаДублей КАК ГруппаДублей,
		|	КОЛИЧЕСТВО(ДублиНСИКПодтверждению.Дубль) КАК Дубль
		|ПОМЕСТИТЬ ГруппыКУдалению
		|ИЗ
		|	РегистрСведений.ДублиНСИКПодтверждению КАК ДублиНСИКПодтверждению
		|СГРУППИРОВАТЬ ПО
		|	ДублиНСИКПодтверждению.ГруппаДублей
		|ИМЕЮЩИЕ
		|	КОЛИЧЕСТВО(ДублиНСИКПодтверждению.Дубль) = 1
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ДублиНСИКПодтверждению.ТипСсылки КАК ТипСсылки,
		|	ДублиНСИКПодтверждению.ГруппаДублей КАК ГруппаДублей,
		|	ДублиНСИКПодтверждению.Дубль КАК Дубль,
		|	ДублиНСИКПодтверждению.Источник КАК Источник,
		|	ДублиНСИКПодтверждению.ДатаДобавления КАК ДатаДобавления,
		|	ДублиНСИКПодтверждению.КоличествоМестИспользования КАК КоличествоМестИспользования,
		|	ДублиНСИКПодтверждению.ДатаПоискаМестИспользования КАК ДатаПоискаМестИспользования
		|ИЗ
		|	РегистрСведений.ДублиНСИКПодтверждению КАК ДублиНСИКПодтверждению
		|ГДЕ
		|	ДублиНСИКПодтверждению.ГруппаДублей В
		|		(ВЫБРАТЬ
		|			Т.ГруппаДублей
		|		ИЗ
		|			ГруппыКУдалению КАК Т)";
	ГруппыСОднимДублем = Запрос.Выполнить().Выгрузить();
	НаборКУдалению = СоздатьНаборЗаписей();
	НаборКУдалению.Загрузить(ГруппыСОднимДублем);
	НаборКУдалению.Записать(РежимЗамещения.Удаление);
	
КонецПроцедуры

// Удаляет из регистра сведений ДублиНСИКПодтверждению записи о потенциальных дублях, которые
// больше не соответствуют правилу поиска.
//
// Параметры:
//   ПарыДублей - ТаблицаЗначений - таблица, содержащая пары дублей:
//           * Ссылка1 - СправочникСсылка, ПланВидовХарактеристикСсылка - ссылка на дубль.
//           * Ссылка2 - СправочникСсылка, ПланВидовХарактеристикСсылка - ссылка на дубль.
//   Источник - СправочникСсылка.ПравилаПоискаДублейНСИ - правило поиска, по которому найдены дубли.
//
Процедура ПроверитьДублиНаСоответствиеПравилуПоиска(ПарыДублей, Источник) Экспорт
	
	Дубли = Новый Массив;
	ОбщегоНазначенияКлиентСервер.ДополнитьМассив(Дубли, ПарыДублей.ВыгрузитьКолонку(0), Истина);
	ОбщегоНазначенияКлиентСервер.ДополнитьМассив(Дубли, ПарыДублей.ВыгрузитьКолонку(1), Истина);
	
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ
		|	ДублиНСИКПодтверждению.ТипСсылки КАК ТипСсылки,
		|	ДублиНСИКПодтверждению.ГруппаДублей КАК ГруппаДублей,
		|	ДублиНСИКПодтверждению.Дубль КАК Дубль,
		|	ДублиНСИКПодтверждению.Источник КАК Источник
		|ПОМЕСТИТЬ втНовыеДубли
		|ИЗ
		|	РегистрСведений.ДублиНСИКПодтверждению КАК ДублиНСИКПодтверждению
		|ГДЕ
		|	ДублиНСИКПодтверждению.Источник = &Источник
		|	И ДублиНСИКПодтверждению.Дубль В (&Дубли)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ДублиНСИКПодтверждению.ТипСсылки КАК ТипСсылки,
		|	ДублиНСИКПодтверждению.ГруппаДублей КАК ГруппаДублей,
		|	ДублиНСИКПодтверждению.Дубль КАК Дубль,
		|	ДублиНСИКПодтверждению.Источник КАК Источник,
		|	ДублиНСИКПодтверждению.ДатаДобавления КАК ДатаДобавления,
		|	ДублиНСИКПодтверждению.КоличествоМестИспользования КАК КоличествоМестИспользования,
		|	ДублиНСИКПодтверждению.ДатаПоискаМестИспользования КАК ДатаПоискаМестИспользования
		|ПОМЕСТИТЬ втДублиПоПравилу
		|ИЗ
		|	РегистрСведений.ДублиНСИКПодтверждению КАК ДублиНСИКПодтверждению
		|ГДЕ
		|	ДублиНСИКПодтверждению.Источник = &Источник
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	втДублиПоПравилу.ТипСсылки КАК ТипСсылки,
		|	втДублиПоПравилу.ГруппаДублей КАК ГруппаДублей,
		|	втДублиПоПравилу.Дубль КАК Дубль,
		|	втДублиПоПравилу.Источник КАК Источник,
		|	втДублиПоПравилу.ДатаДобавления КАК ДатаДобавления,
		|	втДублиПоПравилу.КоличествоМестИспользования КАК КоличествоМестИспользования,
		|	втДублиПоПравилу.ДатаПоискаМестИспользования КАК ДатаПоискаМестИспользования
		|ИЗ
		|	втДублиПоПравилу КАК втДублиПоПравилу
		|		ЛЕВОЕ СОЕДИНЕНИЕ втНовыеДубли КАК втНовыеДубли
		|		ПО втДублиПоПравилу.ТипСсылки = втНовыеДубли.ТипСсылки
		|		И втДублиПоПравилу.Дубль = втНовыеДубли.Дубль
		|		И втДублиПоПравилу.ГруппаДублей = втНовыеДубли.ГруппаДублей
		|		И втДублиПоПравилу.Источник = втНовыеДубли.Источник
		|ГДЕ
		|	втНовыеДубли.Дубль ЕСТЬ NULL";
		
	Запрос.УстановитьПараметр("Источник", Источник);
	Запрос.УстановитьПараметр("Дубли", Дубли);
	
	ЗаписиКУдалению = Запрос.Выполнить().Выгрузить();
	НаборЗаписей = СоздатьНаборЗаписей();
	НаборЗаписей.Загрузить(ЗаписиКУдалению);
	НаборЗаписей.Записать(РежимЗамещения.Удаление);
	
КонецПроцедуры

#Область ДляВызоваИзДругихПодсистем

