&НаКлиенте
Процедура ПриАктивизацииСтрокиСертификата()

	ТекущиеДанные = Элементы.ТаблицаСертификатов.ТекущиеДанные;

	Элементы.ТаблицаСертификатовПросмотрСертификата.Доступность = ТекущиеДанные <> Неопределено
			И Не Запись.ИсходныйКлючЗаписи.Пустой()
			И Не ФормаЗаблокирована
			И ТекущиеДанные.Статус <> ПредопределенноеЗначение("Перечисление.СтатусыОбъектовМаркетплейсаOzon.ПустаяСсылка");

	Элементы.ТаблицаСертификатовОтправитьСертификатыКПубликации.Доступность = ТекущиеДанные <> Неопределено
			И Не ФормаЗаблокирована 
			И ОбновленияДанныхРазрешено
			И ТекущиеДанные.Статус <> ПредопределенноеЗначение("Перечисление.СтатусыОбъектовМаркетплейсаOzon.КПубликации")
			И ТекущиеДанные.Статус <> ПредопределенноеЗначение("Перечисление.СтатусыОбъектовМаркетплейсаOzon.ПустаяСсылка");

	Элементы.ТаблицаСертификатовРедактироватьСписокСертификатов.Доступность = ЗначениеЗаполнено(Запись.Номенклатура)
			И Не ФормаЗаблокирована;

	Элементы.ТаблицаСертификатовДанныеНаOzonИзменены.Доступность = ТекущиеДанные <> Неопределено
			И Не ПустаяСтрока(ТекущиеДанные.ИдентификаторОбъектаМаркетплейса)
			И (ТекущиеДанные.ИзмененыРеквизиты
			Или ТекущиеДанные.Статус = ПредопределенноеЗначение("Перечисление.СтатусыОбъектовМаркетплейсаOzon.НеИспользуется"));

	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;

	Если Не ТекущиеДанные.ВедетсяУчетСертификатовНоменклатуры И Не ПустаяСтрока(ТекущиеДанные.ИдентификаторОбъектаМаркетплейса) Тогда
		ПодсказкаПоСертификатам = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
				НСтр("ru = 'Сертификат не используется, т.к. снят признак ""Учет сертификатов номенклатуры"" у номенклатуры <%1>. Следует удалить его на площадке маркетплейса и подтвердить изменения данных в 1С.'"),
				Запись.Номенклатура);
	ИначеЕсли Не ТекущиеДанные.ВедетсяУчетСертификатовНоменклатуры Тогда
		ПодсказкаПоСертификатам = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
				НСтр("ru = 'Сертификат не используется, т.к. снят признак ""Учет сертификатов номенклатуры"" у номенклатуры <%1>.'"),
				Запись.Номенклатура);
	ИначеЕсли ТекущиеДанные.Статус = ПредопределенноеЗначение("Перечисление.СтатусыОбъектовМаркетплейсаOzon.НеИспользуется")
		И Не ТекущиеДанные.ПубликуетсяВСервисах И Не ПустаяСтрока(ТекущиеДанные.ИдентификаторОбъектаМаркетплейса) Тогда
		ПодсказкаПоСертификатам = НСтр("ru = 'Сертификат не используется по причине снятия признака ""Публикуется в сервисах"". Следует удалить его на площадке маркетплейса и подтвердить изменения данных в 1С.'");
	ИначеЕсли ТекущиеДанные.Статус = ПредопределенноеЗначение("Перечисление.СтатусыОбъектовМаркетплейсаOzon.НеИспользуется")
		И Не ТекущиеДанные.Недействующий И Не ПустаяСтрока(ТекущиеДанные.ИдентификаторОбъектаМаркетплейса) Тогда
		ПодсказкаПоСертификатам = НСтр("ru = 'Сертификат не используется, т.к. помечен на удаление или изменена область действия сертификата. Следует удалить его на площадке маркетплейса и подтвердить изменения данных в 1С.'");
	ИначеЕсли ТекущиеДанные.Недействующий Тогда
		ПодсказкаПоСертификатам = НСтр("ru = 'Сертификат не действующий.'");
	ИначеЕсли ТекущиеДанные.Статус = ПредопределенноеЗначение("Перечисление.СтатусыОбъектовМаркетплейсаOzon.НеИспользуется") Тогда
		ПодсказкаПоСертификатам = НСтр("ru = 'Сертификат не используется, т.к. или снят признак ""Публикуется в сервисах"", или помечен на удаление, или изменена область действия сертификата.'");
	ИначеЕсли ТекущиеДанные.Статус = ПредопределенноеЗначение("Перечисление.СтатусыОбъектовМаркетплейсаOzon.Загружен")
		И ТекущиеДанные.ИзмененыРеквизиты Тогда
		ПодсказкаПоСертификатам = НСтр("ru = 'Сертификат загружен, но у него изменились данные. Следует внести для него изменения на площадке маркетплейса и подтвердить изменения данных в 1С.'");
	ИначеЕсли ТекущиеДанные.Статус = ПредопределенноеЗначение("Перечисление.СтатусыОбъектовМаркетплейсаOzon.Загружен") Тогда
		ПодсказкаПоСертификатам = НСтр("ru = 'Сертификат загружен. Следует проверять его актуальность на площадке маркетплейса, т.к. автоматически не отслеживается его состояние после прохождения модерации.'");
	ИначеЕсли ТекущиеДанные.Статус = ПредопределенноеЗначение("Перечисление.СтатусыОбъектовМаркетплейсаOzon.КПубликации")
		И Не ПустаяСтрока(ТекущиеДанные.ОписаниеОшибки) Тогда
		ПодсказкаПоСертификатам = НСтр("ru = 'Требуется исправление ошибок.'");
	ИначеЕсли ТекущиеДанные.Статус = ПредопределенноеЗначение("Перечисление.СтатусыОбъектовМаркетплейсаOzon.КПубликации") Тогда
		ПодсказкаПоСертификатам = НСтр("ru = 'Сертификат подготовлен к публикации.'");
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ПриИзмененииЗначенияАтрибутаВДеревеРеквизитов()

	ТекущиеДанные = Элементы.ДеревоРеквизитов.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если ТекущиеДанные.ТипЗначенияАтрибута1С = "Строка" И Не ТекущиеДанные.ТипЗначенияАтрибута = "multiline" Тогда
		ТекущиеДанные.ЗначениеАтрибутаМаркетплейса = СтрЗаменить(ТекущиеДанные.ЗначениеАтрибутаМаркетплейса, Символы.ПС, " ");
	КонецЕсли;

	ТекущиеДанные.ЗначениеАтрибутаЗаданоПользователем = Истина;
	ТекущиеДанные.ИзменилсяРеквизит1С = Ложь;

	ТекущиеДанные.ЗначениеАтрибутаЗаполнено = (ТекущиеДанные.ЗначенияАтрибутаМаркетплейса.Количество() > 0)
			Или ЗначениеЗаполнено(ТекущиеДанные.ЗначениеАтрибутаМаркетплейса);
	ТекущиеДанные.НеЗаполненАтрибут = (ТекущиеДанные.ЗначенияАтрибутаМаркетплейса.Количество() = 0)
			И Не ЗначениеЗаполнено(ТекущиеДанные.ЗначениеАтрибутаМаркетплейса);

	ИзменитьЗначениеВТаблицеРеквизитов(ТекущиеДанные);

	Модифицированность = Истина;

КонецПроцедуры

&НаКлиенте
Процедура ОбновитьОписаниеТовараИзСервисаПродолжить(Ответ, ДополнительныеПараметры) Экспорт

	Если Ответ <> КодВозвратаДиалога.Да Тогда
		Возврат;
	КонецЕсли;
	
	ИзмененыПараметрыТовара = Ложь;
	
	ПараметрыИмпорта = ИнтеграцияСМаркетплейсамиКлиентСервер.ПараметрыПолученияТоваровИзСервиса(
		ПредопределенноеЗначение("Перечисление.ВидыМаркетплейсов.МаркетплейсOzon"));
	ПараметрыИмпорта.УникальныйИдентификатор = УникальныйИдентификатор;
	ПараметрыИмпорта.КлючЗадания             = ИнтеграцияСМаркетплейсамиКлиентСервер.КлючЗаданияИмпортаТоварногоКаталога(
		Запись.ИдентификаторОбъектаМаркетплейса);
	
	// Настройки получения порции вызываемого метода - параметры выполнения вызываемого метода.
	ПараметрыИмпорта.ПараметрыМетода.УчетнаяЗапись = Запись.УчетнаяЗаписьМаркетплейса;
	
	ПараметрыИмпорта.ПараметрыМетода.Идентификаторы.ИдентификаторыМаркетплейса.Добавить(
		Запись.ИдентификаторОбъектаМаркетплейса);
	
	ПараметрыИмпорта.ПараметрыМетода.НастройкиИмпорта.ОбновлятьНесопоставленные = Истина;
	ПараметрыИмпорта.ПараметрыМетода.НастройкиИмпорта.ОбновлятьСопоставленные   = Истина;
	ПараметрыИмпорта.ПараметрыМетода.НастройкиИмпорта.ОбновлятьВЛюбомСтатусе    = Истина;
	
	ИнтеграцияСМаркетплейсамиКлиент.ВыполнитьПолучениеТоваровИзСервиса(ЭтотОбъект, ПараметрыИмпорта);

КонецПроцедуры

&НаКлиенте
Процедура ИдентификаторПубликацииОткрытьРедактирование(Ответ, Знач ЗначениеДоИзменения = Неопределено) Экспорт

	Если Ответ <> КодВозвратаДиалога.Да Тогда
		Возврат;
	КонецЕсли;
	
	Если ЗначениеДоИзменения = Неопределено Тогда
		Элементы.ИдентификаторПубликации.КнопкаВыбора = Ложь;
		Элементы.ИдентификаторПубликации.РедактированиеТекста = Истина;
	Иначе
		ОбработчикВводаЗначения = Новый ОписаниеОповещения(
			"ИзменитьИдентификаторПубликации",
			ЭтотОбъект,
			ЗначениеДоИзменения);
		
		ПоказатьВводЗначения(ОбработчикВводаЗначения,
			ЗначениеДоИзменения,
			НСтр("ru = 'Новый идентификатор публикации товара:'"),
			Новый ОписаниеТипов("Строка",,,, Новый КвалификаторыСтроки(50)));
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ИзменитьИдентификаторПубликации(НовоеЗначение, ЗначениеДоИзменения = Неопределено) Экспорт

	Если Не ЗначениеЗаполнено(НовоеЗначение)
			Или СокрЛП(НовоеЗначение) = ЗначениеДоИзменения Тогда
		Возврат;
	КонецЕсли;
	
	ИнформацияПоИдентификаторам = Новый Массив;
	ИнформацияПоИдентификаторам.Добавить(
		Новый Структура("ТекущийИдентификаторПубликации, НовыйИдентификаторПубликации",
			ЗначениеДоИзменения, СокрЛП(НовоеЗначение)));
	
	Результат =
		ИзменитьИдентификаторПубликацииНаСервере(Запись.УчетнаяЗаписьМаркетплейса, ИнформацияПоИдентификаторам);
	
	Если Результат.Количество() > 0 Тогда
		ОбщегоНазначенияКлиент.СообщитьПользователю(
			СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
				НСтр("ru = 'Не удалось изменить идентификатор публикации товара по причине: ""%1"".'"),
				Результат[ЗначениеДоИзменения]));
	Иначе
		Прочитать();
	КонецЕсли;

КонецПроцедуры

&НаСервереБезКонтекста
Функция ИзменитьИдентификаторПубликацииНаСервере(УчетнаяЗапись, ИнформацияПоИдентификаторам)

	Возврат ИнтеграцияСМаркетплейсомOzonСервер.ИзменитьИдентификаторыПубликации(УчетнаяЗапись, ИнформацияПоИдентификаторам);

КонецФункции

&НаСервере
Процедура УстановитьСтатусКПубликации(ОбъектПубликации)

	НовыйСтатус = Перечисления.СтатусыОбъектовМаркетплейсаOzon.КПубликации;
	
	Если ТипЗнч(ОбъектПубликации) = Тип("СправочникСсылка.СертификатыНоменклатуры") Тогда
		МенеджерЗаписи = ИнтеграцияСМаркетплейсомOzonСервер.ЗаписьСтатусаПубликацииПоОтбору(
			Запись,
			Перечисления.ВидыОбъектовМаркетплейсов.Сертификат,
			Запись.УчетнаяЗаписьМаркетплейса,
			ОбъектПубликации);
		МенеджерЗаписи.Статус = НовыйСтатус;
		МенеджерЗаписи.Записать();
	Иначе
		ВидОбъекта = Перечисления.ВидыОбъектовМаркетплейсов.Изображение;

		НачатьТранзакцию();
		Попытка
			БлокировкаДанных = Новый БлокировкаДанных;
			ЭлементБлокировкиДанных = БлокировкаДанных.Добавить("РегистрСведений.СтатусыПубликацииОбъектовМаркетплейсаOzon");
			ЭлементБлокировкиДанных.УстановитьЗначение("УчетнаяЗаписьМаркетплейса", Запись.УчетнаяЗаписьМаркетплейса);
			ЭлементБлокировкиДанных.УстановитьЗначение("ВидОбъектаМаркетплейса", ВидОбъекта);
			ЭлементБлокировкиДанных.УстановитьЗначение("Номенклатура", Запись.Номенклатура);
			ЭлементБлокировкиДанных.УстановитьЗначение("Характеристика", Запись.Характеристика);
			ЭлементБлокировкиДанных.УстановитьЗначение("Упаковка", Запись.Упаковка);
			ЭлементБлокировкиДанных.УстановитьЗначение("НоменклатураПартнера", Запись.НоменклатураПартнера);
			БлокировкаДанных.Заблокировать();
			
			НаборЗаписей = РегистрыСведений.СтатусыПубликацииОбъектовМаркетплейсаOzon.СоздатьНаборЗаписей();
			НаборЗаписей.Отбор.УчетнаяЗаписьМаркетплейса.Установить(Запись.УчетнаяЗаписьМаркетплейса);
			НаборЗаписей.Отбор.ВидОбъектаМаркетплейса.Установить(ВидОбъекта);
			НаборЗаписей.Отбор.Номенклатура.Установить(Запись.Номенклатура);
			НаборЗаписей.Отбор.Характеристика.Установить(Запись.Характеристика);
			НаборЗаписей.Отбор.Упаковка.Установить(Запись.Упаковка);
			НаборЗаписей.Отбор.НоменклатураПартнера.Установить(Запись.НоменклатураПартнера);
			НаборЗаписей.Прочитать();
			
			ВсеИзображения = НаборЗаписей.ВыгрузитьКолонку("ОбъектПубликации");
			РеквизитыИзображений = ОбщегоНазначения.ЗначенияРеквизитовОбъектов(
				ВсеИзображения,
				"ПометкаУдаления, ПубликуетсяВСервисах");

			Если НаборЗаписей.Количество() > 0 Тогда
				Для Каждого ЗаписьНабора Из НаборЗаписей Цикл
					РеквизитыИзображения = РеквизитыИзображений.Получить(ЗаписьНабора.ОбъектПубликации);
					Если РеквизитыИзображения = Неопределено Тогда
						Продолжить;
					КонецЕсли;
					
					Если РеквизитыИзображения.ПубликуетсяВСервисах И Не РеквизитыИзображения.ПометкаУдаления Тогда
						ЗаписьНабора.Статус = НовыйСтатус;
					КонецЕсли;
				КонецЦикла;
			КонецЕсли;

			НаборЗаписей.Записать();
			
			ЗафиксироватьТранзакцию();
		Исключение
			ОтменитьТранзакцию();
			ТекстИсключения = НСтр("ru = 'Не удалось установить статус ""К публикации"" для изображений.'");
			ВызватьИсключение ТекстИсключения;
		КонецПопытки;
	КонецЕсли;

КонецПроцедуры

// Если между чтением и записью данных текущей записи регистра был изменен партнер учетной записи,
// возникнет ситуация, при которой в исходном ключе записи регистра будет установлена ссылка на номенклатуру партнера
// со старым значением владельца, а в данных регистра - ссылка на номенклатуру партнера с новым значением владельца.
//
&НаСервереБезКонтекста
Процедура ПроверитьИзменениеПартнераУчетнойЗаписи(ТекущийПартнер, ТекущаяЗапись, Отказ)
	
	Если ТекущаяЗапись.НоменклатураПартнера = Справочники.НоменклатураКонтрагентов.ПустаяСсылка() Тогда
		ВладелецНоменклатурыПартнера = Справочники.Партнеры.ПустаяСсылка();
	Иначе
		ВладелецНоменклатурыПартнера = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(
			ТекущаяЗапись.НоменклатураПартнера, "ВладелецНоменклатуры");
	КонецЕсли;
	
	Если ТекущийПартнер = ВладелецНоменклатурыПартнера Тогда
		Возврат;
	КонецЕсли;
	
	Если ЗаписьСуществует(ТекущаяЗапись) Тогда
		Возврат; // Номенклатура партнера еще не была заменена в записи регистра
	КонецЕсли;
	
	ТекстСообщения = НСтр(
		"ru = 'Сохранение изменений невозможно, так как был изменен партнер, представляющий торговую площадку.
		|Для редактирования публикации товара требуется закрыть текущую форму и открыть снова.'");
	ОбщегоНазначения.СообщитьПользователю(ТекстСообщения, ТекущаяЗапись.УчетнаяЗаписьМаркетплейса, , , Отказ);
	
КонецПроцедуры

&НаКлиенте
Процедура ПриИзменениеОписанияКарточкиТовара(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Запись.ОписаниеОбъектаМаркетплейса = Результат;
	Модифицированность = Истина;
	
	КонстантыСервиса = ИнтеграцияСМаркетплейсомOzonКлиентСервер.КонстантыСервиса();
	ИдентификаторАтрибута_Аннотация = КонстантыСервиса["ИдентификаторАтрибута_Аннотация"];

	Для Каждого ЭлементДерева Из ДеревоРеквизитов.ПолучитьЭлементы() Цикл
		Если ЭлементДерева.ИдентификаторАтрибутаМаркетплейса = ИдентификаторАтрибута_Аннотация Тогда
			
			ЭлементДерева.ЗначениеАтрибутаМаркетплейса = Результат;
			ЭлементДерева.ЗначениеАтрибутаЗаданоПользователем = Истина;
			
			ЭлементДерева.ЗначениеАтрибутаЗаполнено = (ЭлементДерева.ЗначенияАтрибутаМаркетплейса.Количество() > 0)
				Или ЗначениеЗаполнено(ЭлементДерева.ЗначениеАтрибутаМаркетплейса);
			ЭлементДерева.НеЗаполненАтрибут = (ЭлементДерева.ЗначенияАтрибутаМаркетплейса.Количество() = 0)
				И Не ЗначениеЗаполнено(ЭлементДерева.ЗначениеАтрибутаМаркетплейса);
			
			ИзменитьЗначениеВТаблицеРеквизитов(ЭлементДерева);
			
			Возврат;
			
		КонецЕсли;
	КонецЦикла;
	
	// Длительная операция переноса "аннотации" из таблицы доступных атрибутов в таблицу используемых
	ВключенПереносАннотации = Ложь;
	Для Каждого ЭлементДерева Из ДеревоАтрибутов.ПолучитьЭлементы() Цикл
		Если ЭлементДерева.ИдентификаторАтрибутаМаркетплейса = ИдентификаторАтрибута_Аннотация Тогда
			ЗначенияПолей = Новый Структура;
			ЗначенияПолей.Вставить("ЗначениеАтрибутаМаркетплейса", Запись.ОписаниеОбъектаМаркетплейса);
			ЗначенияПолей.Вставить("ЗначениеАтрибутаЗаданоПользователем", Истина);
			ПеренестиАннотациюВТаблицуЗначениийРеквизитов(ЭлементДерева, ЗначенияПолей);
			ВключенПереносАннотации = Истина;
		КонецЕсли;
	КонецЦикла;
	
	Если Не ВключенПереносАннотации Тогда
		// Длительная операция по заполнению используемого атрибута "Аннотация"
		ПараметрыДействий = ИнтеграцияСМаркетплейсомOzonКлиентСервер.ПараметрыДействийДляКарточкиТовара();
		ПараметрыДействий.Событие = "РедактироватьАтрибуты";
		ВариантОтображенияАтрибутов = "Все";
		ПараметрыДействий.ЗаполнитьДеревоАтрибутов = Истина;
		ПараметрыДействий.Вставить("ЗаполнитьАннотациюОписанием", Истина);
		ПараметрыДействий.ПолучитьОписаниеТовара = Истина;
	
		ЗаполнитьДанныеТовара(ПараметрыДействий);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьАннотациюОписанием()
	
	КонстантыСервиса = ИнтеграцияСМаркетплейсомOzonКлиентСервер.КонстантыСервиса();
	ИдентификаторАтрибута_Аннотация = КонстантыСервиса["ИдентификаторАтрибута_Аннотация"];
	
	ЭлементыДерева = ДеревоАтрибутов.ПолучитьЭлементы();
	Для Каждого ЭлементДерева Из ЭлементыДерева Цикл
		Если ЭлементДерева.ИдентификаторАтрибутаМаркетплейса = ИдентификаторАтрибута_Аннотация Тогда
			ЗначенияПолей = Новый Структура;
			ЗначенияПолей.Вставить("ЗначениеАтрибутаМаркетплейса", Запись.ОписаниеОбъектаМаркетплейса);
			ЗначенияПолей.Вставить("ЗначениеАтрибутаЗаданоПользователем", Истина);
			ПеренестиАннотациюВТаблицуЗначениийРеквизитов(ЭлементДерева, ЗначенияПолей);
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура ПеренестиАннотациюВТаблицуЗначениийРеквизитов(ДанныеИсточник, ЗначенияПолей)
	
	НоваяСтрока = ТаблицаЗначенийРеквизитов.Добавить();
	ЗаполнитьЗначенияСвойств(НоваяСтрока, Запись, "Номенклатура, Характеристика, Упаковка, ИсточникКатегорииМаркетплейса, НаименованиеКатегорииМаркетплейса");
	НоваяСтрока.Категория1С = Запись.Категория;
	Если ЗначениеЗаполнено(НоваяСтрока.ИсточникКатегорииМаркетплейса) Тогда
		НоваяСтрока.ИдентификаторИсточникаКатегорииМаркетплейса = 
				СтрЗаменить(НоваяСтрока.ИсточникКатегорииМаркетплейса.УникальныйИдентификатор(), "-", "_");
	КонецЕсли;
	ЗаполнитьЗначенияСвойств(НоваяСтрока, ДанныеИсточник);
	
	ЗаполнитьЗначенияСвойств(НоваяСтрока, ЗначенияПолей);
	
	ПараметрыДействий = ИнтеграцияСМаркетплейсомOzonКлиентСервер.ПараметрыДействийДляКарточкиТовара();
	ПараметрыДействий.ЗаполнитьДеревоРеквизитов = Истина;
	ПараметрыДействий.Событие = "АктивизироватьСтрокуДереваРеквизитовПриДобавленииНового";
	ПараметрыДействий.Вставить("ИдентификаторАтрибутаМаркетплейсаДляДереваРеквизитов", ДанныеИсточник.ИдентификаторАтрибутаМаркетплейса);
	ПараметрыДействий.ПолучитьОписаниеТовара = Истина;

	ЗаполнитьДанныеТовара(ПараметрыДействий);

	Модифицированность = Истина;
	
КонецПроцедуры

&НаСервере
Процедура УстановитьКэшированныеЗначения()
	
	Кэш = Новый Структура;
	Кэш.Вставить("ПараметрыМенеджераДлительныхОпераций");
	Кэш.Вставить("ИспользоватьSellmonitor", ПолучитьФункциональнуюОпцию("ИспользоватьИнтеграциюСSellmonitor"));
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция КлючТекущейЗаписи(ДанныеЗаписи)
	
	Результат = Новый Структура;
	
	Результат.Вставить("УчетнаяЗаписьМаркетплейса", ДанныеЗаписи.УчетнаяЗаписьМаркетплейса);
	Результат.Вставить("ВидОбъектаМаркетплейса", ДанныеЗаписи.ВидОбъектаМаркетплейса);
	Результат.Вставить("Номенклатура", ДанныеЗаписи.Номенклатура);
	Результат.Вставить("Характеристика", ДанныеЗаписи.Характеристика);
	Результат.Вставить("Упаковка", ДанныеЗаписи.Упаковка);
	Результат.Вставить("НоменклатураПартнера", ДанныеЗаписи.НоменклатураПартнера);
	Результат.Вставить("ОбъектПубликации", ДанныеЗаписи.ОбъектПубликации);
	
	Возврат Результат;
	
КонецФункции

&НаСервере
Процедура ЗаполнитьОписаниеОбъектаИНастроитьЭлементыФормы()
	
	КонстантыСервиса = ИнтеграцияСМаркетплейсомOzonКлиентСервер.КонстантыСервиса();
	ОписаниеОбъекта = Запись.ОписаниеОбъектаМаркетплейса;
	
	Отбор = Новый Структура("ИдентификаторАтрибутаМаркетплейса", КонстантыСервиса["ИдентификаторАтрибута_Аннотация"]);
	СтрокиАтрибутовОписанияТовара = ТаблицаЗначенийРеквизитов.НайтиСтроки(Отбор);
	Если СтрокиАтрибутовОписанияТовара.Количество() > 0 Тогда
		СтрокаАтрибутовОписанияТовара = СтрокиАтрибутовОписанияТовара[0];
		
		ОписаниеОбъекта = СтрокаАтрибутовОписанияТовара.ЗначениеАтрибутаМаркетплейса;
		ПредставлениеАтрибута = НРег(СтрокаАтрибутовОписанияТовара.НаименованиеАтрибутаМаркетплейса);
		ПодсказкаОписания = ПодсказкаОписанияОбъекта(СтрокаАтрибутовОписанияТовара);
	Иначе
		ОписаниеОбъекта = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Запись.Номенклатура, "Описание");
		ПредставлениеАтрибута = "";
		ПодсказкаОписания = ПодсказкаОписанияОбъекта(Неопределено);
	КонецЕсли;
	
	Запись.ОписаниеОбъектаМаркетплейса = ОписаниеОбъекта;
	
	ЗаголовокОписания = ЗаголовокОписанияОбъекта(УчетнаяЗаписьПодключенаКSellmonitor, ПредставлениеАтрибута);
	
	Элементы.ДекорацияОписаниеОбъектаМаркетплейса.Заголовок = ЗаголовокОписания;
	Элементы.ОписаниеОбъектаМаркетплейса.Подсказка = ПодсказкаОписания;
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ЗаголовокОписанияОбъекта(ДобавитьГиперссылкуДляГенерации, ПредставлениеАтрибута)
	
	АтрибутПередан = Не ПустаяСтрока(ПредставлениеАтрибута);
	
	ПредставлениеГиперссылки = "";
	
	Если ДобавитьГиперссылкуДляГенерации Тогда
		
		Если АтрибутПередан Тогда
			ПредставлениеАтрибутаВинительныйПадеж = СклонениеПредставленийОбъектов.ПросклонятьПредставление(
				ПредставлениеАтрибута, 4);
			ПредставлениеГиперссылки = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
				НСтр("ru = 'Изменить %1 с помощью ИИ'"),
				ПредставлениеАтрибутаВинительныйПадеж);
		Иначе
			ПредставлениеГиперссылки = НСтр("ru = 'Изменить с помощью ИИ'");
		КонецЕсли;
		
		Гиперссылка = Новый ФорматированнаяСтрока(
			ПредставлениеГиперссылки, , , , "СгенерироватьОписаниеSellmonitor");
		
	КонецЕсли;
	
	ЧастиОписания = Новый Массив; // Массив из Строка
	ЧастиОписания.Добавить(НСтр("ru = 'Описание товара'"));
	
	Если Не ПустаяСтрока(ПредставлениеАтрибута) Или Не ПустаяСтрока(Гиперссылка) Тогда
		
		ЧастиОписания.Добавить(" (");
		Если Не ПустаяСтрока(Гиперссылка) Тогда
			ЧастиОписания.Добавить(Гиперссылка);
		Иначе
			ЧастиОписания.Добавить(ПредставлениеАтрибута);
		КонецЕсли;
		ЧастиОписания.Добавить(")");
		
	КонецЕсли;
	
	ЧастиОписания.Добавить(":");
	
	Результат = Новый ФорматированнаяСтрока(ЧастиОписания);
	Возврат Результат;
	
КонецФункции

&НаСервереБезКонтекста
Функция ПодсказкаОписанияОбъекта(СтрокаАтрибутов = Неопределено)
	
	Результат = "";
	
	Если СтрокаАтрибутов <> Неопределено Тогда
		
		ДанныеПодсказки = Новый Массив; // Массив из Строка
		ДанныеПодсказки.Добавить(СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
			НСтр("ru = 'Описание товара из атрибута ""%1"" публикации товара.'"),
			СтрокаАтрибутов.НаименованиеАтрибутаМаркетплейса));
		
		ЗначениеПоУмолчанию = СтрокаАтрибутов.ЗначениеПоУмолчанию; // Строка
		Если Не ПустаяСтрока(СтрокаАтрибутов.ПредставлениеРеквизита1С) Тогда
			Если ПустаяСтрока(ЗначениеПоУмолчанию) Тогда
				ДанныеПодсказки.Добавить(СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
					НСтр("ru = 'Может быть заполнено из реквизита ""%1"".'"),
					СтрокаАтрибутов.ПредставлениеРеквизита1С));
			Иначе
				ДанныеПодсказки.Добавить(СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
					НСтр("ru = 'Может быть заполнено из реквизита ""%1"" или значением по умолчанию, если указанный реквизит не заполнен.'"),
					СтрокаАтрибутов.ПредставлениеРеквизита1С));
			КонецЕсли;
		ИначеЕсли Не ПустаяСтрока(ЗначениеПоУмолчанию) Тогда
			ДанныеПодсказки.Добавить(НСтр("ru = 'Может быть заполнено значением по умолчанию.'"));
		КонецЕсли;
		
		Результат = СтрСоединить(ДанныеПодсказки, " ");
	Иначе
		ПредставлениеРеквизитаОписания = Метаданные.Справочники.Номенклатура.Реквизиты.Описание.Представление();
		Результат = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
			НСтр("ru = 'Описание товара из реквизита ""%1"" выбранной номенклатуры.'"),
			ПредставлениеРеквизитаОписания);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти
