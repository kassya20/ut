КонецФункции

Функция ПодборЗначенийВТаблицеИдентификаторов(Идентификаторы, ИмяТаблицы, ИмяТаблицыВидовПродукции, СтруктураПодбора)
	
	НайденныеСтроки = Неопределено;
	ПрерватьПодбор  = Ложь;
	
	СтруктураПоиска = Новый Структура;
	СтруктураПоиска.Вставить("ИмяТаблицы",    ИмяТаблицы);
	СтруктураПоиска.Вставить("Идентификатор", СтруктураПодбора.Идентификатор);
	
	Если Не ЗначениеЗаполнено(СтруктураПодбора.Идентификатор) Тогда
		СтруктураПоискаВидаПродукции = Новый Структура;
		СтруктураПоискаВидаПродукции.Вставить("ИмяТаблицы",    ИмяТаблицыВидовПродукции);
		СтруктураПоискаВидаПродукции.Вставить("Идентификатор", СтруктураПодбора.ВидПродукцииИдентификатор);
		СтруктураПоискаВидаПродукции.Вставить("Наименование",  СтруктураПодбора.ВидПродукцииНаименование);
		
		НайденныеСтрокиВидаПродукции = Идентификаторы.НайтиСтроки(СтруктураПоискаВидаПродукции);
		
		Если НайденныеСтрокиВидаПродукции.Количество() Тогда
			ВидПродукцииСсылка = НайденныеСтрокиВидаПродукции[0].Ссылка;
			
			СоставКлюча = Новый СписокЗначений;
			СоставКлюча.Добавить(СтруктураПодбора.Код);
			СоставКлюча.Добавить(ВидПродукцииСсылка);
			СоставКлюча.СортироватьПоЗначению();
			
			СтруктураПоиска.Вставить("КлючЗначения", ОбщегоНазначенияИС.ХэшСуммаСтроки(СтрСоединить(
			СоставКлюча.ВыгрузитьЗначения())));
			
		Иначе
			ПрерватьПодбор = Ложь;
			
		КонецЕсли;
		
	КонецЕсли;
	
	Если Не ПрерватьПодбор Тогда
		НайденныеСтроки = Идентификаторы.НайтиСтроки(СтруктураПоиска);
	КонецЕсли;
	
	Возврат НайденныеСтроки;
	
КонецФункции

