#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Если Параметры.ТолькоИзменение Тогда
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(
			Элементы, "ИдентификаторЭДО", "Доступность", Ложь);
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(
			Элементы, "ТипДанных", "Доступность", Ложь);
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(
			Элементы, "ИдентификаторОбъекта", "Доступность", Ложь);
	КонецЕсли;
	
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(
		Элементы, "МеткаВремениВЦентреЭДО", "Видимость", ЗначениеЗаполнено(Параметры.МеткаВремениВЦентреЭДО));
	Если ЗначениеЗаполнено(Параметры.МеткаВремениВЦентреЭДО) Тогда
		МеткаВремениВЦентреЭДО = ОбщегоНазначенияБЭДКлиентСервер.ПредставлениеДатыВМиллисекундах(
			Параметры.МеткаВремениВЦентреЭДО);
	КонецЕсли;
	Если СтрДлина(МеткаВремениВЦентреЭДО) = 22 Тогда
		МеткаВремениВЦентреЭДО = СтрЗаменить(МеткаВремениВЦентреЭДО, " ", "  ");
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ПриЧтенииНаСервере(ТекущийОбъект)
	
	МеткаВремениПредставление = ОбщегоНазначенияБЭДКлиентСервер.ПредставлениеДатыВМиллисекундах(
		ТекущийОбъект.МеткаВремени);
	Если СтрДлина(МеткаВремениПредставление) = 22 Тогда
		МеткаВремениПредставление = СтрЗаменить(МеткаВремениПредставление, " ", "  ");
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ПередЗаписьюНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	
	МеткаВремени = ОбщегоНазначенияБЭДКлиентСервер.СтрокаВМиллисекунды(МеткаВремениПредставление);
	Если МеткаВремени <> Неопределено Тогда
		ТекущийОбъект.МеткаВремени = МеткаВремени;
	Иначе
		ОбщегоНазначения.СообщитьПользователю(ОбщегоНазначенияБЭДКлиентСервер.ТекстСообщения(
			"Поле", "Корректность", НСтр("ru = 'Метка времени'")),
			, "МеткаВремениПредставление", , Отказ);
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти