
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Если Не Параметры.Ключ.Пустой() Тогда
		ПредыдущаяОрганизация = Запись.Организация;
		ПредыдущееСостояние   = Запись.Состояние;
	КонецЕсли;
	
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы,
		"ФормаИзменитьФорму", 
		"Видимость",
		Пользователи.ЭтоПолноправныйПользователь());
	
КонецПроцедуры

&НаСервере
Процедура ПриЧтенииНаСервере(ТекущийОбъект)
	
	// СтандартныеПодсистемы.УправлениеДоступом
	Если ОбщегоНазначения.ПодсистемаСуществует("СтандартныеПодсистемы.УправлениеДоступом") Тогда
		МодульУправлениеДоступом = ОбщегоНазначения.ОбщийМодуль("УправлениеДоступом");
		МодульУправлениеДоступом.ПриЧтенииНаСервере(ЭтотОбъект, ТекущийОбъект);
	КонецЕсли;
	// Конец СтандартныеПодсистемы.УправлениеДоступом
	
КонецПроцедуры

&НаСервере
Процедура ПослеЗаписиНаСервере(ТекущийОбъект, ПараметрыЗаписи)
	
	// СтандартныеПодсистемы.УправлениеДоступом
	Если ОбщегоНазначения.ПодсистемаСуществует("СтандартныеПодсистемы.УправлениеДоступом") Тогда
		МодульУправлениеДоступом = ОбщегоНазначения.ОбщийМодуль("УправлениеДоступом");
		МодульУправлениеДоступом.ПослеЗаписиНаСервере(ЭтотОбъект, ТекущийОбъект, ПараметрыЗаписи);
	КонецЕсли;
	// Конец СтандартныеПодсистемы.УправлениеДоступом
	
КонецПроцедуры

&НаКлиенте
Процедура ПослеЗаписи(ПараметрыЗаписи)
	
	Если ПредыдущаяОрганизация <> Запись.Организация Тогда
		Оповестить("Запись_СостоянияВыгрузкиНоменклатуры", 
			Новый Структура("Состояние, ПредыдущееСостояние", 
				"НеИзвестно", 
				ИмяЗначенияПеречисления(ПредыдущееСостояние)), 
			ПредыдущаяОрганизация);
		Оповестить("Запись_СостоянияВыгрузкиНоменклатуры", 
			Новый Структура("Состояние, ПредыдущееСостояние", 
				ИмяЗначенияПеречисления(Запись.Состояние),
				"НеИзвестно"), 
			Запись.Организация);
		
	ИначеЕсли ПредыдущееСостояние <> Запись.Состояние Тогда
		Оповестить("Запись_СостоянияВыгрузкиНоменклатуры", 
			Новый Структура("Состояние, ПредыдущееСостояние", 
				ИмяЗначенияПеречисления(Запись.Состояние), 
				ИмяЗначенияПеречисления(ПредыдущееСостояние)), 
			Запись.Организация);
	КонецЕсли;
	
	ПредыдущаяОрганизация = Запись.Организация;
	ПредыдущееСостояние   = Запись.Состояние;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервереБезКонтекста
Функция ИмяЗначенияПеречисления(Знач Значение)
	
	Если Не ЗначениеЗаполнено(Значение) Тогда
		Возврат "НеИзвестно";
	КонецЕсли;
	
	Возврат ОбщегоНазначения.ИмяЗначенияПеречисления(Значение);
	
КонецФункции

#КонецОбласти
