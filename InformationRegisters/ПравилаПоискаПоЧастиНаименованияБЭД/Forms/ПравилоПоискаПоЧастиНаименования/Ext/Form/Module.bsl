
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Если Параметры.Ключ.Пустой() Тогда
		Если Не ЗначениеЗаполнено(ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(Параметры, "ЗначениеКопирования")) Тогда
			Запись.Владелец = Параметры.Владелец;
			Запись.Номенклатура = Параметры.Номенклатура;
			Запись.Характеристика = Параметры.Характеристика;
			Запись.Упаковка = Параметры.Упаковка;
			Запись.ПоисковаяСтрока = Параметры.ПоисковаяСтрока;
		КонецЕсли;
		НоменклатураПриИзмененииНаСервере();
	КонецЕсли;
	
	ОбязательноеЗаполнениеХарактеристики = Параметры.ОбязательноеЗаполнениеХарактеристики;
	Если ОбязательноеЗаполнениеХарактеристики = Неопределено И ЗначениеЗаполнено(Запись.Номенклатура) Тогда
		ОбязательноеЗаполнениеХарактеристики = ОбязательноеЗаполнениеХарактеристики(Запись.Номенклатура);
	КонецЕсли;
	
	Если ОбязательноеЗаполнениеХарактеристики = Истина Тогда
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "Характеристика", 
			"АвтоОтметкаНезаполненного", Истина);
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(Запись.Номенклатура) 
		Или Параметры.ОграничениеТипаНоменклатуры.СодержитТип(ТипЗнч(Запись.Номенклатура)) Тогда
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "Номенклатура",
			"ОграничениеТипа", Параметры.ОграничениеТипаНоменклатуры);
	КонецЕсли;
	
	СоставнойТип = СопоставлениеНоменклатурыКонтрагентовПовтИсп.ИспользуемыеТипыНоменклатурыБЭД().Количество() > 1;
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "Номенклатура",
		"КнопкаОчистки", СоставнойТип);
	
	УстановитьСвойстваПереопределяемыхЭлементовФормы();
	
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы,
		"ФормаИзменитьФорму", 
		"Видимость",
		Пользователи.ЭтоПолноправныйПользователь());
	
КонецПроцедуры

&НаСервере
Процедура ПриЧтенииНаСервере(ТекущийОбъект)
	
	НоменклатураПриИзмененииНаСервере();
	
КонецПроцедуры

&НаСервере
Процедура ПередЗаписьюНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	
	ТекущийОбъект.ХешПоисковойСтроки = КонтрольнаяСуммаСтрокой(Запись.ПоисковаяСтрока);
	Если ЗаписьСТакимиКлючевымиПолямиСуществует(Запись.ИсходныйКлючЗаписи, ТекущийОбъект) Тогда 
		Ошибки      = Неопределено;
		ТекстОшибки = СтрШаблон(НСтр("ru = 'Правило поиска для %1 по строке ""%2"" уже существует'"), 
			ТекущийОбъект.Владелец,
			ТекущийОбъект.ПоисковаяСтрока);
		ОбщегоНазначенияКлиентСервер.ДобавитьОшибкуПользователю(Ошибки,, ТекстОшибки);
		ОбщегоНазначенияКлиентСервер.СообщитьОшибкиПользователю(Ошибки, Отказ);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПослеЗаписи(ПараметрыЗаписи)
	НовыеДанныеПравилаПоиска = 
		СопоставлениеНоменклатурыКонтрагентовСлужебныйКлиентСервер.НовоеПравилоПоискаПоЧастиНаименования();
	ЗаполнитьЗначенияСвойств(НовыеДанныеПравилаПоиска, Запись);
	ОповеститьОВыборе(НовыеДанныеПравилаПоиска);
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура НоменклатураПриИзменении(Элемент)
	
	НоменклатураПриИзмененииНаСервере();
	
КонецПроцедуры

&НаКлиенте
Процедура НоменклатураОчистка(Элемент, СтандартнаяОбработка)
	
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "Номенклатура",
		"ОграничениеТипа", Новый ОписаниеТипов());
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "Номенклатура",
		"Заголовок", НоменклатураЗаголовокПоУмолчанию);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура УстановитьСвойстваПереопределяемыхЭлементовФормы()
	
	МетаданныеСопоставления = СопоставлениеНоменклатурыКонтрагентовСлужебный.МетаданныеСопоставленияНоменклатуры();
	
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "Владелец", "Заголовок",
		МетаданныеСопоставления.ВладелецНоменклатурыПредставлениеОбъекта);
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "Номенклатура", "Заголовок",
		МетаданныеСопоставления.НоменклатураПредставлениеОбъекта);
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "Характеристика", "Заголовок",
		МетаданныеСопоставления.ХарактеристикаПредставлениеОбъекта);
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "Упаковка", "Заголовок",
		МетаданныеСопоставления.УпаковкаПредставлениеОбъекта);
	
	НоменклатураЗаголовокПоУмолчанию = МетаданныеСопоставления.НоменклатураПредставлениеОбъекта;
	
	Если Метаданные.ОпределяемыеТипы.НоменклатураБЭД.Тип.Типы().Количество() > 1 
		И Не ЗначениеЗаполнено(Элементы.Номенклатура.ОграничениеТипа) Тогда
		ИспользуемыеТипы = СопоставлениеНоменклатурыКонтрагентовПовтИсп.ИспользуемыеТипыНоменклатурыБЭД(); 
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "Номенклатура", "ОграничениеТипа",
			Новый ОписаниеТипов(ИспользуемыеТипы));
	КонецЕсли;
	
	УстановитьЗаголовокЭлементаСопоставлениеНоменклатураПоТипу();
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция КонтрольнаяСуммаСтрокой(Знач Данные)
	Возврат ОбщегоНазначения.КонтрольнаяСуммаСтрокой(Данные);
КонецФункции

&НаСервереБезКонтекста
Функция ОбязательноеЗаполнениеХарактеристики(Знач Номенклатура)
	
	Если Не ЗначениеЗаполнено(Номенклатура) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Результат   = Ложь;
	Свойства    = Неопределено;
	ВсеСвойства = СопоставлениеНоменклатурыКонтрагентовСлужебный.СвойстваНоменклатурыИнформационнойБазы(Номенклатура);
	
	Если ВсеСвойства <> Неопределено Тогда
		Свойства = ВсеСвойства.Получить(Номенклатура);
	КонецЕсли;
	
	Если Свойства <> Неопределено Тогда
		Результат = Свойства.ИспользоватьХарактеристики И Свойства.ОбязательноеЗаполнениеХарактеристики;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

&НаСервере
Процедура УстановитьЗаголовокЭлементаСопоставлениеНоменклатураПоТипу()
	
	ЭлементНоменклатура = Элементы.Номенклатура;
	ЭлементНоменклатура.Заголовок = СопоставлениеНоменклатурыКонтрагентовСлужебный.ПредставлениеОбъектаПоТипу(
		ЭлементНоменклатура.ОграничениеТипа,
		НоменклатураЗаголовокПоУмолчанию);
	
КонецПроцедуры

&НаСервере
Процедура НоменклатураПриИзмененииНаСервере()
	
	СопоставлениеНоменклатурыКонтрагентовСлужебный.НоменклатураПриИзменении(ЭтотОбъект, "Запись");
	
КонецПроцедуры

&НаСервере
Функция ЗаписьСТакимиКлючевымиПолямиСуществует(ИсходныйКлючЗаписи, ТекущаяЗапись)
	
	Возврат (ИсходныйКлючЗаписи.ХешПоисковойСтроки <> ТекущаяЗапись.ХешПоисковойСтроки 
		Или ИсходныйКлючЗаписи.Владелец <> ТекущаяЗапись.Владелец)
		И РегистрыСведений.ПравилаПоискаПоЧастиНаименованияБЭД.ЕстьПравилоПоиска(ТекущаяЗапись.Владелец, ТекущаяЗапись.ХешПоисковойСтроки);
	
КонецФункции

#КонецОбласти