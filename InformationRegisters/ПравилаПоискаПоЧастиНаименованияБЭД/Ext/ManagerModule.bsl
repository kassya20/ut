
#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ПрограммныйИнтерфейс

// Проверяет наличие правила поиска по владельцу и хешу поисковой строки
// 
// Параметры:
//  Владелец - ОпределяемыйТип.ВладелецНоменклатурыБЭД
//  ХешПоисковойСтроки - Строка
// 
// Возвращаемое значение:
// 	Булево
//
Функция ЕстьПравилоПоиска(Владелец, ХешПоисковойСтроки) Экспорт
	
	Запрос = Новый Запрос(ТекстЗапросаЕстьПравилоПоиска());
	Запрос.УстановитьПараметр("Владелец", Владелец);
	Запрос.УстановитьПараметр("ХешПоисковойСтроки", ХешПоисковойСтроки);
	
	Возврат Не Запрос.Выполнить().Пустой();
	
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция ТекстЗапросаЕстьПравилоПоиска()
	
	Возврат "ВЫБРАТЬ ПЕРВЫЕ 1
	|	ИСТИНА КАК ЕстьПравилоПоиска
	|ИЗ
	|	РегистрСведений.ПравилаПоискаПоЧастиНаименованияБЭД КАК ПравилаПоискаПоЧастиНаименованияБЭД
	|ГДЕ
	|	ПравилаПоискаПоЧастиНаименованияБЭД.Владелец = &Владелец
	|	И ПравилаПоискаПоЧастиНаименованияБЭД.ХешПоисковойСтроки = &ХешПоисковойСтроки";
	
КонецФункции

#КонецОбласти

#КонецЕсли