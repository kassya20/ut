&НаСервереБезКонтекста
Функция ЭтоВесовойТовар(Номенклатура, Упаковка)
	
	ТипИзмеряемойВеличины = Неопределено;
	
	Если ЗначениеЗаполнено(Упаковка) Тогда
		
		Запрос = Новый Запрос;
		Запрос.Текст =
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	ВЫБОР
		|		КОГДА ЕСТЬNULL(УпаковкиЕдиницыИзмерения.ТипИзмеряемойВеличины, НЕОПРЕДЕЛЕНО) = ЗНАЧЕНИЕ(Перечисление.ТипыИзмеряемыхВеличин.Упаковка)
		|			ТОГДА ЕСТЬNULL(УпаковкиЕдиницыИзмерения.ЕдиницаИзмерения.ТипИзмеряемойВеличины, НЕОПРЕДЕЛЕНО)
		|		ИНАЧЕ УпаковкиЕдиницыИзмерения.ТипИзмеряемойВеличины
		|	КОНЕЦ КАК ТипИзмеряемойВеличины
		|ИЗ
		|	Справочник.УпаковкиЕдиницыИзмерения КАК УпаковкиЕдиницыИзмерения
		|ГДЕ
		|	УпаковкиЕдиницыИзмерения.Ссылка = &Упаковка";
		
		Запрос.УстановитьПараметр("Упаковка", Упаковка);
		
		Выборка = Запрос.Выполнить().Выбрать();
		
		Если Выборка.Следующий() Тогда
			ТипИзмеряемойВеличины = Выборка.ТипИзмеряемойВеличины;
		КонецЕсли;
		
	Иначе
		ТипИзмеряемойВеличины = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Номенклатура,
																			"ЕдиницаИзмерения.ТипИзмеряемойВеличины",
																			Истина);
	КонецЕсли;
	
	Возврат ТипИзмеряемойВеличины = Перечисления.ТипыИзмеряемыхВеличин.Вес;
	
КонецФункции

