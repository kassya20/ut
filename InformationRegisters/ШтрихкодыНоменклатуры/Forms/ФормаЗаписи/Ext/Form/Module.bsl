&НаКлиентеНаСервереБезКонтекста
Функция РеквизитыНоменклатуры()
	
	УпаковкаЕдиницаИзмеренияПоУмолчанию	= ПредопределенноеЗначение("Справочник.УпаковкиЕдиницыИзмерения.ПустаяСсылка");
	
	РеквизитыНоменклатурыШаблон = Новый Структура;
	РеквизитыНоменклатурыШаблон.Вставить("ХарактеристикиИспользуются",	Ложь);
	РеквизитыНоменклатурыШаблон.Вставить("СерииИспользуются",			Ложь);
	РеквизитыНоменклатурыШаблон.Вставить("Упаковка",					УпаковкаЕдиницаИзмеренияПоУмолчанию);
	РеквизитыНоменклатурыШаблон.Вставить("ЕдиницаИзмерения",			УпаковкаЕдиницаИзмеренияПоУмолчанию);
	
	Возврат РеквизитыНоменклатурыШаблон;
	
КонецФункции

&НаСервереБезКонтекста
Процедура ОбновитьРеквизитыНоменклатуры(Запись, РеквизитыНоменклатуры)
	
	РеквизитыНоменклатурыШаблон = РеквизитыНоменклатуры();
	ЗаполнитьЗначенияСвойств(РеквизитыНоменклатурыШаблон, Запись);
	
	Если ЗначениеЗаполнено(Запись.Номенклатура) Тогда
		
		Запрос = Новый Запрос;
		Запрос.Текст =
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	ВЫБОР
		|		КОГДА ДанныеНоменклатуры.ИспользованиеХарактеристик = ЗНАЧЕНИЕ(Перечисление.ВариантыИспользованияХарактеристикНоменклатуры.ОбщиеДляВидаНоменклатуры)
		|				ИЛИ ДанныеНоменклатуры.ИспользованиеХарактеристик = ЗНАЧЕНИЕ(Перечисление.ВариантыИспользованияХарактеристикНоменклатуры.ИндивидуальныеДляНоменклатуры)
		|				ИЛИ ДанныеНоменклатуры.ИспользованиеХарактеристик = ЗНАЧЕНИЕ(Перечисление.ВариантыИспользованияХарактеристикНоменклатуры.ОбщиеСДругимВидомНоменклатуры)
		|			ТОГДА ИСТИНА
		|		ИНАЧЕ ЛОЖЬ
		|	КОНЕЦ								КАК ХарактеристикиИспользуются,
		|	ЕСТЬNULL(ДанныеНоменклатуры.ВидНоменклатуры.ИспользоватьСерии, ЛОЖЬ) КАК СерииИспользуются,
		|	ДанныеНоменклатуры.ЕдиницаИзмерения	КАК ЕдиницаИзмерения
		|ИЗ
		|	Справочник.Номенклатура КАК ДанныеНоменклатуры
		|ГДЕ
		|	ДанныеНоменклатуры.Ссылка = &Номенклатура";
		
		Запрос.УстановитьПараметр("Номенклатура", Запись.Номенклатура);
		
		Выборка = Запрос.Выполнить().Выбрать();
		
		Если Выборка.Следующий() Тогда
			ЗаполнитьЗначенияСвойств(РеквизитыНоменклатурыШаблон, Выборка);
		КонецЕсли;
		
	КонецЕсли;
	
	РеквизитыНоменклатуры = Новый ФиксированнаяСтруктура(РеквизитыНоменклатурыШаблон);
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Процедура УстановитьДоступностьЭлементов(Элементы, РеквизитыНоменклатуры)
	
	ХарактеристикаПодсказкаВвода	= ?(Не РеквизитыНоменклатуры.ХарактеристикиИспользуются,
										НСтр("ru = '<характеристики не используются>'"),
										"");
	СерияПодсказкаВвода				= ?(Не РеквизитыНоменклатуры.СерииИспользуются,
										НСтр("ru = '<серии не используются>'"),
										"");
	УпаковкаПодсказкаВвода			= ?(Не ЗначениеЗаполнено(РеквизитыНоменклатуры.Упаковка),
										Строка(РеквизитыНоменклатуры.ЕдиницаИзмерения),
										"");
	
	ОбщегоНазначенияУТКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы,
																	"Характеристика",
																	"Доступность",
																	РеквизитыНоменклатуры.ХарактеристикиИспользуются);
	ОбщегоНазначенияУТКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы,
																	"Характеристика",
																	"ПодсказкаВвода",
																	ХарактеристикаПодсказкаВвода);
	ОбщегоНазначенияУТКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы,
																	"Серия",
																	"Доступность",
																	РеквизитыНоменклатуры.СерииИспользуются);
	ОбщегоНазначенияУТКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы,
																	"Серия",
																	"ПодсказкаВвода",
																	СерияПодсказкаВвода);
	ОбщегоНазначенияУТКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы,
																	"Упаковка",
																	"ПодсказкаВвода",
																	УпаковкаПодсказкаВвода);
	
КонецПроцедуры

#КонецОбласти

#КонецОбласти
