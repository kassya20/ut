#Область ОписаниеПеременных

&НаКлиенте
Перем КэшированныеЗначения; //используется механизмом обработки изменения реквизитов ТЧ

#КонецОбласти

#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	// Возврат при получении формы для анализа.
	Если Параметры.Свойство("АвтоТест") Тогда
		Возврат;
	КонецЕсли;

	Если Параметры.ЗначенияЗаполнения.Свойство("Штрихкод") Тогда
		Запись.Штрихкод = Параметры.ЗначенияЗаполнения.Штрихкод;
	КонецЕсли;
	
	ОбновлениеИнформационнойБазы.ПроверитьОбъектОбработан(Запись, ЭтотОбъект);

	ОбщегоНазначенияУТ.НастроитьПодключаемоеОборудование(ЭтотОбъект);
	
	Если Запись.ИсходныйКлючЗаписи.Пустой() Тогда
		ОбновитьРеквизитыНоменклатуры(Запись, РеквизитыНоменклатуры);
		УстановитьДоступностьЭлементов(Элементы, РеквизитыНоменклатуры);
	КонецЕсли;
	
	СобытияФорм.ПриСозданииНаСервере(ЭтотОбъект, Отказ, СтандартнаяОбработка, Параметры);
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	МенеджерОборудованияКлиент.НачатьПодключениеОборудованиеПриОткрытииФормы(Неопределено, ЭтотОбъект, "СканерШтрихкода");
	
КонецПроцедуры

&НаКлиенте
Процедура ПриЗакрытии()
	
	МенеджерОборудованияКлиент.НачатьОтключениеОборудованиеПриЗакрытииФормы(Неопределено, ЭтотОбъект);
	
КонецПроцедуры

&НаКлиенте
Процедура ПослеЗаписи(ПараметрыЗаписи)
	
	Оповестить("Запись_ШтрихкодыНоменклатуры", Запись.Номенклатура);
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	// ПодключаемоеОборудование
	Если ВводДоступен()
		И Источник = "ПодключаемоеОборудование" Тогда
		
		Если ИмяСобытия = "ScanData"
			И МенеджерОборудованияУТКлиент.ЕстьНеобработанноеСобытие() Тогда
			
			ОбработатьШтрихкоды(МенеджерОборудованияУТКлиент.ПреобразоватьДанныеСоСканераВМассив(Параметр));
			
		КонецЕсли;
		
	КонецЕсли;
	// Конец ПодключаемоеОборудование
	
КонецПроцедуры

&НаСервере
Процедура ОбработкаПроверкиЗаполненияНаСервере(Отказ, ПроверяемыеРеквизиты)
	
	Запрос		= Новый Запрос;
	Штрихкод	= СокрЛП(Запись.Штрихкод);
	
	Если ПолучитьФункциональнуюОпцию("ИспользоватьНеуникальныеШтрихкодыНоменклатуры") Тогда
		Запрос.Текст =
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	ШтрихкодыНоменклатуры.Штрихкод						КАК Штрихкод,
		|	ПРЕДСТАВЛЕНИЕ(ШтрихкодыНоменклатуры.Номенклатура)	КАК Номенклатура,
		|	ПРЕДСТАВЛЕНИЕ(ШтрихкодыНоменклатуры.Характеристика)	КАК Характеристика,
		|	ПРЕДСТАВЛЕНИЕ(ШтрихкодыНоменклатуры.Серия)			КАК Серия,
		|	ПРЕДСТАВЛЕНИЕ(ШтрихкодыНоменклатуры.Упаковка)		КАК Упаковка
		|ИЗ
		|	РегистрСведений.ШтрихкодыНоменклатуры КАК ШтрихкодыНоменклатуры
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК СправочникНоменклатура
		|		ПО ШтрихкодыНоменклатуры.Номенклатура = СправочникНоменклатура.Ссылка
		|		
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ВидыНоменклатуры.РеквизитыДляКонтроляНоменклатуры КАК РеквизитыКонтроляУникальности
		|		ПО СправочникНоменклатура.Видноменклатуры = РеквизитыКонтроляУникальности.Ссылка
		|			И РеквизитыКонтроляУникальности.ИмяРеквизита = &ИмяРеквизитаШтрихкод
		|			И РеквизитыКонтроляУникальности.Уникален
		|ГДЕ
		|	ШтрихкодыНоменклатуры.Штрихкод = &Штрихкод
		|	И НЕ (ШтрихкодыНоменклатуры.Номенклатура = &Номенклатура
		|		И ШтрихкодыНоменклатуры.Характеристика = &Характеристика
		|		И ШтрихкодыНоменклатуры.Серия = &Серия
		|		И ШтрихкодыНоменклатуры.Упаковка = &Упаковка
		|		)
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ ПЕРВЫЕ 1
		|	ШтрихкодыНоменклатуры.Штрихкод						КАК Штрихкод,
		|	ПРЕДСТАВЛЕНИЕ(ШтрихкодыНоменклатуры.Номенклатура)	КАК Номенклатура,
		|	ПРЕДСТАВЛЕНИЕ(ШтрихкодыНоменклатуры.Характеристика)	КАК Характеристика,
		|	ПРЕДСТАВЛЕНИЕ(ШтрихкодыНоменклатуры.Серия)			КАК Серия,
		|	ПРЕДСТАВЛЕНИЕ(ШтрихкодыНоменклатуры.Упаковка)		КАК Упаковка
		|ИЗ
		|	РегистрСведений.ШтрихкодыНоменклатуры КАК ШтрихкодыНоменклатуры
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК СправочникНоменклатура
		|		ПО ШтрихкодыНоменклатуры.Номенклатура = СправочникНоменклатура.Ссылка
		|		
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ВидыНоменклатуры.РеквизитыДляКонтроляНоменклатуры КАК РеквизитыКонтроляУникальности
		|		ПО СправочникНоменклатура.Видноменклатуры = РеквизитыКонтроляУникальности.Ссылка
		|			И РеквизитыКонтроляУникальности.ИмяРеквизита = &ИмяРеквизитаШтрихкод
		|			И НЕ РеквизитыКонтроляУникальности.Уникален
		|ГДЕ
		|	ШтрихкодыНоменклатуры.Штрихкод = &Штрихкод
		|	И НЕ ЕСТЬNULL(РеквизитыКонтроляУникальности.Уникален, ЛОЖЬ)
		|	И НЕ (ШтрихкодыНоменклатуры.Номенклатура = &Номенклатура
		|		И ШтрихкодыНоменклатуры.Характеристика = &Характеристика
		|		И ШтрихкодыНоменклатуры.Серия = &Серия
		|		И ШтрихкодыНоменклатуры.Упаковка = &Упаковка
		|		)
		|	И ИСТИНА В
		|			(ВЫБРАТЬ
		|				ИСТИНА
		|			ИЗ
		|				Справочник.Номенклатура КАК СправочникНоменклатура
		|					ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ВидыНоменклатуры.РеквизитыДляКонтроляНоменклатуры КАК РеквизитыКонтроля
		|					ПО СправочникНоменклатура.Видноменклатуры = РеквизитыКонтроля.Ссылка
		|						И РеквизитыКонтроля.ИмяРеквизита = &ИмяРеквизитаШтрихкод
		|						И РеквизитыКонтроля.Уникален
		|			ГДЕ
		|				СправочникНоменклатура.Ссылка = &Номенклатура)
		|";
		
		Запрос.УстановитьПараметр("ИмяРеквизитаШтрихкод", "Штрихкод");
	Иначе
		Запрос.Текст =
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	ШтрихкодыНоменклатуры.Штрихкод						КАК Штрихкод,
		|	ПРЕДСТАВЛЕНИЕ(ШтрихкодыНоменклатуры.Номенклатура)	КАК Номенклатура,
		|	ПРЕДСТАВЛЕНИЕ(ШтрихкодыНоменклатуры.Характеристика)	КАК Характеристика,
		|	ПРЕДСТАВЛЕНИЕ(ШтрихкодыНоменклатуры.Серия)			КАК Серия,
		|	ПРЕДСТАВЛЕНИЕ(ШтрихкодыНоменклатуры.Упаковка)		КАК Упаковка
		|ИЗ
		|	РегистрСведений.ШтрихкодыНоменклатуры КАК ШтрихкодыНоменклатуры
		|ГДЕ
		|	ШтрихкодыНоменклатуры.Штрихкод = &Штрихкод
		|	И НЕ (ШтрихкодыНоменклатуры.Номенклатура = &Номенклатура
		|		И ШтрихкодыНоменклатуры.Характеристика = &Характеристика
		|		И ШтрихкодыНоменклатуры.Серия = &Серия
		|		И ШтрихкодыНоменклатуры.Упаковка = &Упаковка
		|		)
		|";
	КонецЕсли;
	
	Запрос.УстановитьПараметр("Штрихкод",		Штрихкод);
	Запрос.УстановитьПараметр("Номенклатура",	Запись.Номенклатура);
	Запрос.УстановитьПараметр("Характеристика",	Запись.Характеристика);
	Запрос.УстановитьПараметр("Серия",			Запись.Серия);
	Запрос.УстановитьПараметр("Упаковка",		Запись.Упаковка);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Если РезультатЗапроса.Пустой() Тогда
		Возврат;
	КонецЕсли;
	
	Выборка = РезультатЗапроса.Выбрать();
	Выборка.Следующий();
	
	Если Запись.ИсходныйКлючЗаписи.Штрихкод <> Штрихкод Тогда
		ПредставленияНоменклатуры = Новый Массив;
		
		ШаблонНоменклатуры = НСтр("ru = '""%1""'");
		
		ПредставлениеНоменклатуры = НоменклатураКлиентСервер.ПредставлениеНоменклатуры(
										СокрЛП(Выборка.Номенклатура),
										СокрЛП(Выборка.Характеристика));
		ПредставлениеНоменклатуры = СтрШаблон(ШаблонНоменклатуры, ПредставлениеНоменклатуры);
		ПредставленияНоменклатуры.Добавить(ПредставлениеНоменклатуры);
		
		Если Не ПустаяСтрока(Выборка.Серия) Тогда
			ПредставлениеСерии = НСтр("ru = 'с серией ""%1""'");
			ПредставлениеСерии = СтрШаблон(ПредставлениеСерии, СокрЛП(Выборка.Серия));
			
			ПредставленияНоменклатуры.Добавить(ПредставлениеСерии);
		КонецЕсли;
		
		Если Не ПустаяСтрока(Выборка.Упаковка) Тогда
			ПредставлениеУпаковки = НСтр("ru = 'в упаковке ""%1""'");
			ПредставлениеУпаковки = СтрШаблон(ПредставлениеУпаковки, СокрЛП(Выборка.Упаковка));
			
			ПредставленияНоменклатуры.Добавить(ПредставлениеУпаковки);
		КонецЕсли;
		
		ТекстСообщения = НСтр("ru = 'Такой штрихкод уже назначен для номенклатуры %1.'");
		ТекстСообщения = СтрШаблон(ТекстСообщения, СтрСоединить(ПредставленияНоменклатуры, " "));
		
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения, Неопределено, "Штрихкод", "Запись", Отказ);
	КонецЕсли;
	
	НоменклатураЛокализация.ОбработкаПроверкиЗаполненияШтрихкодыНоменклатуры(ЭтотОбъект, Отказ, ПроверяемыеРеквизиты);
	
КонецПроцедуры

&НаСервере
Процедура ПриЧтенииНаСервере(ТекущийОбъект)
	
	// СтандартныеПодсистемы.УправлениеДоступом
	УправлениеДоступом.ПриЧтенииНаСервере(ЭтотОбъект, ТекущийОбъект);
	// Конец СтандартныеПодсистемы.УправлениеДоступом
	
	ОбновитьРеквизитыНоменклатуры(Запись, РеквизитыНоменклатуры);
	УстановитьДоступностьЭлементов(Элементы, РеквизитыНоменклатуры);
	
	СобытияФорм.ПриЧтенииНаСервере(ЭтотОбъект, ТекущийОбъект);
	
КонецПроцедуры

&НаСервере
Процедура ПослеЗаписиНаСервере(ТекущийОбъект, ПараметрыЗаписи)
	
	// СтандартныеПодсистемы.УправлениеДоступом
	УправлениеДоступом.ПослеЗаписиНаСервере(ЭтотОбъект, ТекущийОбъект, ПараметрыЗаписи);
	// Конец СтандартныеПодсистемы.УправлениеДоступом
	
КонецПроцедуры

&НаСервере
Процедура ПриЗаписиНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	
	СобытияФорм.ПриЗаписиНаСервере(ЭтотОбъект, Отказ, ТекущийОбъект, ПараметрыЗаписи);
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура НоменклатураПриИзменении(Элемент)
	
	РеквизитыСтроки =
		"Номенклатура,
		|Характеристика,
		|ХарактеристикиИспользуются,
		|СерииИспользуются,
		|Серия,
		|Упаковка,
		|ЕдиницаИзмерения";
	
	//++ Локализация
	ВестиУчетМаркируемойПродукции = ИнтеграцияИСМПКлиентСерверПовтИсп.ВестиУчетМаркируемойПродукции();
	Если ВестиУчетМаркируемойПродукции Тогда
		РеквизитыСтроки = РеквизитыСтроки + ",ВидПродукцииИС";
	КонецЕсли;
	//-- Локализация
	
	ТекущаяСтрока = Новый Структура(РеквизитыСтроки);
	ЗаполнитьЗначенияСвойств(ТекущаяСтрока, Запись);
	
	ЗаполнитьПризнакЕдиницаИзмерения = Новый Структура("Номенклатура", "ЕдиницаИзмерения");
	
	ДействияСтроки = Новый Структура;
	ДействияСтроки.Вставить("ПроверитьХарактеристикуПоВладельцу",		Запись.Характеристика);
	ДействияСтроки.Вставить("ПроверитьСериюПоВладельцу",				Запись.Серия);
	ДействияСтроки.Вставить("ПроверитьЗаполнитьУпаковкуПоВладельцу",	Запись.Упаковка);
	ДействияСтроки.Вставить("ЗаполнитьПризнакЕдиницаИзмерения",			ЗаполнитьПризнакЕдиницаИзмерения);
	
	//++ Локализация
	Если ВестиУчетМаркируемойПродукции Тогда
		ДействияСтроки.Вставить("ЗаполнитьВидПродукцииИС", Новый Структура("Номенклатура", "ВидПродукцииИС"));
	КонецЕсли;
	//-- Локализация
	
	ПакетнаяОбработкаТабличнойЧастиКлиент.ОбработатьСтрокуТЧ(ТекущаяСтрока, ДействияСтроки, КэшированныеЗначения);
	
	ЗаполнитьЗначенияСвойств(Запись, ТекущаяСтрока);
	
	РеквизитыНоменклатурыШаблон = РеквизитыНоменклатуры();
	ЗаполнитьЗначенияСвойств(РеквизитыНоменклатурыШаблон, ТекущаяСтрока);
	
	РеквизитыНоменклатуры = Новый ФиксированнаяСтруктура(РеквизитыНоменклатурыШаблон);
	
	УстановитьДоступностьЭлементов(Элементы, РеквизитыНоменклатуры);
	
	//++ Локализация
	Если ВестиУчетМаркируемойПродукции Тогда
		РеквизитыФормы = Новый Структура;
		РеквизитыФормы.Вставить("ВидПродукцииИС", ТекущаяСтрока.ВидПродукцииИС);
		Если Не ЗначениеЗаполнено(ТекущаяСтрока.ВидПродукцииИС) Тогда
			РеквизитыФормы.Вставить("ВидУпаковкиИС", Неопределено);
			РеквизитыФормы.Вставить("КоличествоПотребительскихУпаковокИС", 0);
		КонецЕсли;
		ЗаполнитьЗначенияСвойств(ЭтотОбъект, РеквизитыФормы);
		ИнтеграцияИСУТКлиентСервер.УправлениеЭлементамиФормыШтрихкодаНоменклатуры(ЭтотОбъект);
	КонецЕсли;
	//-- Локализация
	
КонецПроцедуры

&НаКлиенте
Процедура УпаковкаПриИзменении(Элемент)
	
	РеквизитыНоменклатурыШаблон = РеквизитыНоменклатуры();
	ЗаполнитьЗначенияСвойств(РеквизитыНоменклатурыШаблон, РеквизитыНоменклатуры);
	ЗаполнитьЗначенияСвойств(РеквизитыНоменклатурыШаблон, Запись);
	
	РеквизитыНоменклатуры = Новый ФиксированнаяСтруктура(РеквизитыНоменклатурыШаблон);
	
	УстановитьДоступностьЭлементов(Элементы, РеквизитыНоменклатуры);
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура НовыйШтрихкод(Команда)
	
	ОчиститьСообщения();
	
	Если ЭтоВесовойТовар(Запись.Номенклатура, Запись.Упаковка) Тогда
		Запись.Штрихкод = СформироватьШтрихкодEAN13ВесовогоТовара();
	Иначе
		Запись.Штрихкод = СформироватьШтрихкодEAN13();
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

#Область ШтрихкодыИТорговоеОборудование

&НаКлиенте
Процедура ОбработатьШтрихкоды(ДанныеШтрихкодов)
	
	Модифицированность = Истина;
	
	Если ДанныеШтрихкодов.Количество() > 0 Тогда
		Запись.Штрихкод = ДанныеШтрихкодов[ДанныеШтрихкодов.Количество() - 1].Штрихкод;
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

