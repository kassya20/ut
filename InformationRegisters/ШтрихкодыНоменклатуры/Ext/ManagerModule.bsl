#Если НЕ МобильныйАвтономныйСервер Тогда

#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ПрограммныйИнтерфейс

// Кэширует сведения о штрихкодах номенклатуры, по найденным данным в информационной базе, на основании передаваемой
// коллекции штрихкодов.
//
// Параметры:
//	КэшированныеЗначения - см. ПакетнаяОбработкаТабличнойЧастиКлиентСервер.ПолучитьСтруктуруКэшируемыеЗначения.
//	Штрихкоды - Массив Из Строка - штрихкоды, для которых необходимо получить сведения.
//	ПолучатьНеуникальныеШтрихкоды - Булево - признак получения данных о неуникальных штрихкодах номенклатуры.
//
Процедура ПолучитьДанныеПоШтрихкодам(КэшированныеЗначения, Штрихкоды, ПолучатьНеуникальныеШтрихкоды = Ложь) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	Штрихкоды.Штрихкод				КАК Штрихкод,
	|	КОЛИЧЕСТВО(Штрихкоды.Штрихкод)	КАК КоличествоШтрихкодов
	|ПОМЕСТИТЬ ИнформацияОШтрихкодах
	|ИЗ
	|	РегистрСведений.ШтрихкодыНоменклатуры КАК Штрихкоды
	|ГДЕ
	|	Штрихкоды.Штрихкод В (&МассивШтрихкодов)
	|
	|СГРУППИРОВАТЬ ПО
	|	Штрихкоды.Штрихкод
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Штрихкод
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ШтрихкодыНоменклатуры.Штрихкод					КАК Штрихкод,
	|	ШтрихкодыНоменклатуры.Номенклатура				КАК Номенклатура,
	|	СправочникНоменклатура.НаборУпаковок			КАК НаборУпаковок,
	|	СправочникНоменклатура.ЕдиницаИзмерения			КАК ЕдиницаИзмерения,
	|	ШтрихкодыНоменклатуры.Характеристика			КАК Характеристика,
	|	ШтрихкодыНоменклатуры.Серия						КАК Серия,
	|	ШтрихкодыНоменклатуры.Упаковка					КАК Упаковка,
	|	ИнформацияОШтрихкодах.КоличествоШтрихкодов > 1	КАК НеуникальныйШтрихкод
	|ПОМЕСТИТЬ ВТШтрихкодыНоменклатуры
	|ИЗ
	|	ИнформацияОШтрихкодах КАК ИнформацияОШтрихкодах
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.ШтрихкодыНоменклатуры КАК ШтрихкодыНоменклатуры
	|		ПО ИнформацияОШтрихкодах.Штрихкод = ШтрихкодыНоменклатуры.Штрихкод
	|		
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК СправочникНоменклатура
	|		ПО ШтрихкодыНоменклатуры.Номенклатура = СправочникНоменклатура.Ссылка
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ШтрихкодыНоменклатуры.Номенклатура	КАК Номенклатура,
	|	УпаковкиНоменклатуры.Ссылка			КАК Упаковка
	|ПОМЕСТИТЬ УпаковкиНоменклатуры
	|ИЗ
	|	ВТШтрихкодыНоменклатуры КАК ШтрихкодыНоменклатуры
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.УпаковкиЕдиницыИзмерения КАК УпаковкиНоменклатуры
	|		ПО ШтрихкодыНоменклатуры.Номенклатура = УпаковкиНоменклатуры.Владелец
	|			И ШтрихкодыНоменклатуры.ЕдиницаИзмерения = УпаковкиНоменклатуры.ЕдиницаИзмерения
	|			И УпаковкиНоменклатуры.ТипИзмеряемойВеличины = ЗНАЧЕНИЕ(Перечисление.ТипыИзмеряемыхВеличин.Упаковка)
	|			И ЕСТЬNULL(УпаковкиНоменклатуры.Знаменатель, 0) <> 0
	|
	|ГДЕ
	|	НЕ УпаковкиНоменклатуры.ПометкаУдаления
	|	И ШтрихкодыНоменклатуры.НаборУпаковок = ЗНАЧЕНИЕ(Справочник.НаборыУпаковок.ИндивидуальныйДляНоменклатуры)
	|	И ВЫРАЗИТЬ(УпаковкиНоменклатуры.Числитель / УпаковкиНоменклатуры.Знаменатель КАК ЧИСЛО(27, 11)) = 1
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ШтрихкодыНоменклатуры.Номенклатура	КАК Номенклатура,
	|	УпаковкиНоменклатуры.Ссылка			КАК Упаковка
	|ИЗ
	|	ВТШтрихкодыНоменклатуры КАК ШтрихкодыНоменклатуры
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.УпаковкиЕдиницыИзмерения КАК УпаковкиНоменклатуры
	|		ПО ШтрихкодыНоменклатуры.НаборУпаковок = УпаковкиНоменклатуры.Владелец
	|			И ШтрихкодыНоменклатуры.ЕдиницаИзмерения = УпаковкиНоменклатуры.ЕдиницаИзмерения
	|			И УпаковкиНоменклатуры.ТипИзмеряемойВеличины = ЗНАЧЕНИЕ(Перечисление.ТипыИзмеряемыхВеличин.Упаковка)
	|			И ЕСТЬNULL(УпаковкиНоменклатуры.Знаменатель, 0) <> 0
	|
	|ГДЕ
	|	НЕ УпаковкиНоменклатуры.ПометкаУдаления
	|	И ШтрихкодыНоменклатуры.НаборУпаковок <> ЗНАЧЕНИЕ(Справочник.НаборыУпаковок.ИндивидуальныйДляНоменклатуры)
	|	И ВЫРАЗИТЬ(УпаковкиНоменклатуры.Числитель / УпаковкиНоменклатуры.Знаменатель КАК ЧИСЛО(27, 11)) = 1
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ШтрихкодыНоменклатуры.Штрихкод						КАК Штрихкод,
	|	СправочникНоменклатура.Ссылка						КАК Номенклатура,
	|	СправочникНоменклатура.ТипНоменклатуры				КАК ТипНоменклатуры,
	|	&РеквизитыНоменклатурыВыборка,
	|	ВЫБОР
	|		КОГДА ЕСТЬNULL(СправочникНоменклатура.ВладелецСерий, НЕОПРЕДЕЛЕНО) = ЗНАЧЕНИЕ(Справочник.ВидыНоменклатуры.ПустаяСсылка)
	|			ТОГДА ЕСТЬNULL(СправочникНоменклатура.ВидНоменклатуры.ИспользоватьКоличествоСерии, ЛОЖЬ)
	|		ИНАЧЕ СправочникНоменклатура.ВладелецСерий.ИспользоватьКоличествоСерии
	|	КОНЕЦ												КАК ИспользоватьКоличествоСерии,
	|	ШтрихкодыНоменклатуры.Характеристика				КАК Характеристика,
	|	ШтрихкодыНоменклатуры.Серия							КАК Серия,
	|	ЕСТЬNULL(СправочникНоменклатура.ВидНоменклатуры.ИспользоватьСерии, ЛОЖЬ) КАК СерииИспользуются,
	|	ШтрихкодыНоменклатуры.Упаковка						КАК Упаковка,
	|	ЕСТЬNULL(СправочникУпаковок.ТипУпаковки, НЕОПРЕДЕЛЕНО) = ЗНАЧЕНИЕ(Перечисление.ТипыУпаковокНоменклатуры.ТоварноеМесто) КАК ТоварноеМесто,
	|	ПРЕДСТАВЛЕНИЕ(СправочникНоменклатура.Ссылка)		КАК НоменклатураПредставление,
	|	ПРЕДСТАВЛЕНИЕ(ШтрихкодыНоменклатуры.Характеристика)	КАК ХарактеристикаПредставление,
	|	ЕСТЬNULL(&ТекстЗапросаКоэффициентУпаковки1, 1)		КАК Коэффициент,
	|	ВЫБОР
	|		КОГДА ЕСТЬNULL(СправочникНоменклатура.ИспользованиеХарактеристик, НЕОПРЕДЕЛЕНО) = ЗНАЧЕНИЕ(Перечисление.ВариантыИспользованияХарактеристикНоменклатуры.НеИспользовать)
	|			ТОГДА ЛОЖЬ
	|		ИНАЧЕ ИСТИНА
	|	КОНЕЦ													КАК ХарактеристикиИспользуются,
	|	СправочникНоменклатура.ПоставляетсяВМногооборотнойТаре	КАК ПоставляетсяВМногооборотнойТаре,
	|	СправочникНоменклатура.ИспользоватьУпаковки				КАК ИспользоватьУпаковки,
	|	МАКСИМУМ(УпаковкиНоменклатуры.Упаковка)					КАК ЕдиничнаяУпаковка,
	|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ УпаковкиНоменклатуры.Упаковка)		КАК КоличествоЕдиничныхУпаковок,
	|	ШтрихкодыНоменклатуры.НеуникальныйШтрихкод				КАК НеуникальныйШтрихкод,
	|	ВЫБОР
	|		КОГДА ВариантыКомплектацииНоменклатуры.ВариантРасчетаЦеныНабора ЕСТЬ NULL
	|			ТОГДА ЗНАЧЕНИЕ(Перечисление.ВариантыРасчетаЦенНаборов.ПустаяСсылка)
	|		ИНАЧЕ ВариантыКомплектацииНоменклатуры.ВариантРасчетаЦеныНабора
	|	КОНЕЦ													КАК ВариантРасчетаЦеныНабора,
	|	ШтрихкодыНоменклатуры.ЕдиницаИзмерения					КАК ЕдиницаИзмерения
	|ИЗ
	|	ВТШтрихкодыНоменклатуры КАК ШтрихкодыНоменклатуры
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК СправочникНоменклатура
	|		ПО ШтрихкодыНоменклатуры.Номенклатура = СправочникНоменклатура.Ссылка
	|		
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.УпаковкиЕдиницыИзмерения КАК СправочникУпаковок
	|		ПО ШтрихкодыНоменклатуры.Упаковка = СправочникУпаковок.Ссылка
	|		
	|		ЛЕВОЕ СОЕДИНЕНИЕ УпаковкиНоменклатуры КАК УпаковкиНоменклатуры
	|		ПО ШтрихкодыНоменклатуры.Номенклатура = УпаковкиНоменклатуры.Номенклатура
	|		
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ВариантыКомплектацииНоменклатуры КАК ВариантыКомплектацииНоменклатуры
	|		ПО ВариантыКомплектацииНоменклатуры.Владелец = ШтрихкодыНоменклатуры.Номенклатура
	|			И ВариантыКомплектацииНоменклатуры.Характеристика = ШтрихкодыНоменклатуры.Характеристика
	|			И ВариантыКомплектацииНоменклатуры.Основной
	|	, ТаблицаСоединения
	|СГРУППИРОВАТЬ ПО
	|	ШтрихкодыНоменклатуры.Штрихкод,
	|	СправочникНоменклатура.Ссылка,
	|	&РеквизитыНоменклатурыГруппировка,
	|	ВЫБОР
	|		КОГДА ЕСТЬNULL(СправочникНоменклатура.ВладелецСерий, НЕОПРЕДЕЛЕНО) = ЗНАЧЕНИЕ(Справочник.ВидыНоменклатуры.ПустаяСсылка)
	|			ТОГДА ЕСТЬNULL(СправочникНоменклатура.ВидНоменклатуры.ИспользоватьКоличествоСерии, ЛОЖЬ)
	|		ИНАЧЕ СправочникНоменклатура.ВладелецСерий.ИспользоватьКоличествоСерии
	|	КОНЕЦ,
	|	ШтрихкодыНоменклатуры.Характеристика,
	|	ШтрихкодыНоменклатуры.Серия,
	|	ЕСТЬNULL(СправочникНоменклатура.ВидНоменклатуры.ИспользоватьСерии, ЛОЖЬ),
	|	ШтрихкодыНоменклатуры.Упаковка,
	|	СправочникУпаковок.Ссылка,
	|	ШтрихкодыНоменклатуры.НеуникальныйШтрихкод,
	|	ВЫБОР
	|		КОГДА ВариантыКомплектацииНоменклатуры.ВариантРасчетаЦеныНабора ЕСТЬ NULL
	|			ТОГДА ЗНАЧЕНИЕ(Перечисление.ВариантыРасчетаЦенНаборов.ПустаяСсылка)
	|		ИНАЧЕ ВариантыКомплектацииНоменклатуры.ВариантРасчетаЦеныНабора
	|	КОНЕЦ,
	|	ШтрихкодыНоменклатуры.ЕдиницаИзмерения";
	
	Запрос.Текст = СтрЗаменить(Запрос.Текст,
		"&ТекстЗапросаКоэффициентУпаковки1",
		Справочники.УпаковкиЕдиницыИзмерения.ТекстЗапросаКоэффициентаУпаковки("ШтрихкодыНоменклатуры.Упаковка",
		"СправочникНоменклатура"));
	
	ТекстыЗапросаРеквизитовНоменклатуры = НоменклатураЛокализация.ТекстыЗапросаРеквизитовНоменклатуры();
	НоменклатураЛокализация.ЗаполнитьТекстЗапросаРеквизитыНоменклатуры(
		"СправочникНоменклатура",
		ТекстыЗапросаРеквизитовНоменклатуры);
	
	Запрос.Текст = СтрЗаменить(Запрос.Текст,
								"&РеквизитыНоменклатурыВыборка",
								ТекстыЗапросаРеквизитовНоменклатуры.РеквизитыНоменклатурыВыборка);
	Запрос.Текст = СтрЗаменить(Запрос.Текст,
								"&РеквизитыНоменклатурыГруппировка",
								ТекстыЗапросаРеквизитовНоменклатуры.РеквизитыНоменклатурыГруппировка);
	Запрос.Текст = СтрЗаменить(Запрос.Текст,
								", ТаблицаСоединения",
								ТекстыЗапросаРеквизитовНоменклатуры.РеквизитыНоменклатурыСоединения);
	
	МассивШтрихкодов = Новый Массив;
	
	Для Каждого ТекШтрихкод Из Штрихкоды Цикл
		Штрихкод = ВРег(СокрЛП(ТекШтрихкод));
		МассивШтрихкодов.Добавить(Штрихкод);
		
		ИнформацияПоШтрихкодам = ПакетнаяОбработкаТабличнойЧастиКлиентСервер.СтруктураКэшируемойИнформацииПоШтрихкоду();
		ИнформацияПоШтрихкодам.Штрихкод = Штрихкод;
		
		КэшированныеЗначения.Штрихкоды.Вставить(Штрихкод, ИнформацияПоШтрихкодам);
	КонецЦикла;
	
	Запрос.УстановитьПараметр("МассивШтрихкодов", МассивШтрихкодов);
	
	УстановитьПривилегированныйРежим(Истина);
	РезультатЗапроса = Запрос.Выполнить();
	УстановитьПривилегированныйРежим(Ложь);
	
	ДанныеПоШтрихкодам = РезультатЗапроса.Выгрузить();
	ДанныеПоШтрихкодам.Индексы.Добавить("Штрихкод");
	
	ЗаполнитьКэшированныеЗначенияПоДаннымИБ(КэшированныеЗначения,
											ДанныеПоШтрихкодам,
											МассивШтрихкодов,
											ПолучатьНеуникальныеШтрихкоды);
	
КонецПроцедуры

// Кэширует сведения о штрихкодах номенклатуры, по найденным данным в информационной базе, на основании передаваемой
// коллекции штрихкодов.
//
// Параметры:
//	КэшированныеЗначения - см. ПакетнаяОбработкаТабличнойЧастиКлиентСервер.ПолучитьСтруктуруКэшируемыеЗначения.
//	Штрихкоды - Массив Из Строка - штрихкоды, для которых необходимо получить сведения.
//	ПолучатьНеуникальныеШтрихкоды - Булево - признак получения данных о неуникальных штрихкодах номенклатуры.
//
Процедура ПолучитьДанныеПоШтрихкодамРасширенный(КэшированныеЗначения, Штрихкоды, ПолучатьНеуникальныеШтрихкоды = Ложь) Экспорт
	
	ПолучитьДанныеПоШтрихкодам(КэшированныеЗначения, Штрихкоды, ПолучатьНеуникальныеШтрихкоды);
	ПолучитьДанныеПоШтрихкодамЭтикетокСерий(КэшированныеЗначения, Штрихкоды, ПолучатьНеуникальныеШтрихкоды);
	
КонецПроцедуры

// Кэширует сведения о штрихкодах номенклатуры, по найденным данным в информационной базе, на основании передаваемой
// коллекции сведений о штрихкодах номенклатуры.
//
// Параметры:
//	КэшированныеЗначения - см. ПакетнаяОбработкаТабличнойЧастиКлиентСервер.ПолучитьСтруктуруКэшируемыеЗначения.
//	ШтрихкодыНоменклатуры - Массив Из Структура- коллекция сведений о штрихкодах номенклатуры, которая содержит следующие свойства:
//		* Штрихкод - Строка - штрихкод номенклатуры.
//		* Номенклатура - СправочникСсылка.Номенклатура - номенклатура.
//		* Характеристика - СправочникСсылка.ХарактеристикиНоменклатуры - характеристика номенклатуры.
//		* Серия - СправочникСсылка.СерииНоменклатуры - серия номенклатуры.
//		* Упаковка - СправочникСсылка.УпаковкиЕдиницыИзмерения - упаковка номенклатуры.
//
Процедура ПолучитьДанныеПоШтрихкодамНоменклатуры(КэшированныеЗначения, ШтрихкодыНоменклатуры) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Штрихкоды.Штрихкод			КАК Штрихкод,
	|	Штрихкоды.Номенклатура		КАК Номенклатура,
	|	Штрихкоды.Характеристика	КАК Характеристика,
