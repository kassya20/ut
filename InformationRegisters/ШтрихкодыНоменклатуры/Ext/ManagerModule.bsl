// Функция осуществляет формирование штрихкода EAN13 для
// штучного товара.
//
// Возвращаемое значение:
//  Строка - Штрихкод штучного товара.
//
Функция СформироватьШтрихкодEAN13() Экспорт

	ПрефиксУзлаШтрихкода = ПрефиксУзлаШтрихкода();
	
	Код = Неопределено;
	Диапазон = Неопределено;
	Диапазоны = ПолучитьМаксимальныеЗначенияКодовШтучныхШтрихкодов();
	Если Диапазоны = Неопределено Тогда
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщенияНеНастроеныДоступныеДиапазоныШтучныхШтрихкодов());
		Возврат Неопределено;
	КонецЕсли;
	Для Каждого СтрокаТЧ Из Диапазоны Цикл
		Код = СтрокаТЧ.Код + 1;
		Диапазон = СтрокаТЧ.Диапазон;
		Прервать;
	КонецЦикла;
	
	Если Код = Неопределено Тогда
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщенияНетСвободныхКодовШтучныхШтрихкодов());
		Возврат Неопределено;
	КонецЕсли;
	
	Возврат ПолучитьШтрихкодПоКоду(Код, Диапазон, ПрефиксУзлаШтрихкода);

КонецФункции

// Функция осуществляет формирование штрихкода EAN13 для
// весового товара.
//
// Возвращаемое значение:
//  Строка - Штрихкод весового товара.
//
Функция СформироватьШтрихкодВесовогоТовараEAN13() Экспорт

	ПрефиксУзлаШтрихкода = ПрефиксУзлаШтрихкода();

	Код = ПолучитьМаксимальноеЗначениеКодаВесовыхШтрихкодов();
	
	Если Код = Неопределено Тогда
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщенияНетСвободныхКодовВесовыхШтрихкодов());
		Возврат Неопределено;
	КонецЕсли;
	
	Возврат ПолучитьШтрихкодВесовогоТовараПоКоду(Код + 1, ПрефиксУзлаШтрихкода);

КонецФункции

// Функция возвращает штрихкод, создаваемый из кода с префиксами и контрольным символом.
//
// Параметры:
//  Код                  - Число  - Код.
//  Диапазон             - Строка - Диапазон.
//  ПрефиксУзлаШтрихкода - Строка - Префикс узла.
//
// Возвращаемое значение:
//  Строка - Штрихкод.
//
Функция ПолучитьШтрихкодПоКоду(Код, Диапазон, ПрефиксУзлаШтрихкода) Экспорт

	Штрихкод = Строка(Диапазон) + ПрефиксУзлаШтрихкода + Формат(Код, "ЧЦ=9; ЧВН=; ЧГ=");
	Штрихкод = Штрихкод + КонтрольныйСимволEAN(ШтрихКод, 13);

	Возврат Штрихкод;

КонецФункции

// Возвращает штрихкод весового товара, создаваемый из кода с префиксом весового товара и контрольным символом.
//
// Параметры:
//  Код                   - Число  - Код.
//  ПрефиксУзлаШтрихкода - Строка - Префикс весового товара.
//  Загрузка              - Булево - Признак загрузки.
//
// Возвращаемое значение:
//  Строка - Шаблон штрихкода весового товара.
//
Функция ПолучитьШтрихкодВесовогоТовараПоКоду(Код, ПрефиксУзлаШтрихкода = "_", Загрузка = Ложь) Экспорт

	Если Загрузка Тогда
		КодТовара = Формат(Код, "ЧЦ=5; ЧВН=; ЧГ=");
	Иначе
		КодТовара = Строка(ПрефиксУзлаШтрихкода) + Формат(Код, "ЧЦ=4; ЧВН=; ЧГ=");
	КонецЕсли;
	
	Штрихкод = "2_" + КодТовара + "00000";
	
	КонтрольныйСимволEAN = "_";
	Штрихкод = Штрихкод + КонтрольныйСимволEAN;

	Возврат Штрихкод;

КонецФункции

// Возвращает настройки диапазонов штрихкодов по умолчанию.
//
// Возвращаемое значение:
//	Массив Из см. НастройкаДиапазонаШтрихкода.
//
Функция НастройкиДиапазоновШтрихкодовПоУмолчанию() Экспорт
	
	НастройкиДиапазоновШтрихкодов = Новый Массив;
	НастройкиДиапазоновШтрихкодов.Добавить(НастройкаДиапазонаШтрихкода(Ложь,	"20"));
	НастройкиДиапазоновШтрихкодов.Добавить(НастройкаДиапазонаШтрихкода(Истина,	"21"));
	НастройкиДиапазоновШтрихкодов.Добавить(НастройкаДиапазонаШтрихкода(Истина,	"22"));
	НастройкиДиапазоновШтрихкодов.Добавить(НастройкаДиапазонаШтрихкода(Истина,	"23"));
	НастройкиДиапазоновШтрихкодов.Добавить(НастройкаДиапазонаШтрихкода(Истина,	"24"));
	НастройкиДиапазоновШтрихкодов.Добавить(НастройкаДиапазонаШтрихкода(Истина,	"25"));
	НастройкиДиапазоновШтрихкодов.Добавить(НастройкаДиапазонаШтрихкода(Истина,	"26"));
	НастройкиДиапазоновШтрихкодов.Добавить(НастройкаДиапазонаШтрихкода(Истина,	"27"));
	НастройкиДиапазоновШтрихкодов.Добавить(НастройкаДиапазонаШтрихкода(Истина,	"28"));
	НастройкиДиапазоновШтрихкодов.Добавить(НастройкаДиапазонаШтрихкода(Истина,	"29"));
	
	Возврат НастройкиДиапазоновШтрихкодов;
	
КонецФункции

// Возвращает настройки диапазонов штрихкодов.
//
// Возвращаемое значение:
//	Массив Из см. НастройкаДиапазонаШтрихкода.
//
Функция НастройкиДиапазоновШтрихкодов() Экспорт
	
	Настройки = Константы.НастройкиПрефиксацииШтрихкодов.Получить().Получить();
	НастройкиДиапазоновШтрихкодов = Новый Массив;
	
	Если Настройки = Неопределено Тогда
		НастройкиДиапазоновШтрихкодов = НастройкиДиапазоновШтрихкодовПоУмолчанию();
	Иначе
		
		Попытка
			Для Каждого СтрокаТЧ Из Настройки Цикл
				НастройкиДиапазоновШтрихкодов.Добавить(НастройкаДиапазонаШтрихкода(СтрокаТЧ.Весовой, СтрокаТЧ.Диапазон));
			КонецЦикла;
		Исключение
			ТекстСообщения = НСтр("ru = 'Ошибка формата настроек диапазонов штрихкодов. Загружены настройки по умолчанию.'");
			
			ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);
			
			НастройкиДиапазоновШтрихкодов = НастройкиДиапазоновШтрихкодовПоУмолчанию();
		КонецПопытки
		
	КонецЕсли;
	
	Возврат НастройкиДиапазоновШтрихкодов;
	
КонецФункции

// Возвращает настройку диапазона штрихкода по заданным параметрам.
//
// Параметры:
//	Весовой - Булево - Истина, если штрихкод является весовым.
//	Диапазон - Строка - числовое значение диапазона.
//
// Возвращаемое значение:
//	Структура - структура настроек диапазона штрихкода по заданным параметрам, которая содержит свойства:
//		* Весовой - Булево - Истина - признак того, что штрихкод является весовым.
//		* Диапазон - Строка - числовое значение диапазона.
//
Функция НастройкаДиапазонаШтрихкода(Весовой, Диапазон) Экспорт
	
	НастройкаДиапазонаШтрихкода = Новый Структура("Весовой, Диапазон", Весовой, Диапазон);
	
	Возврат НастройкаДиапазонаШтрихкода;
	
КонецФункции

// Функция возвращает массив максимальное значений кодов штучных штрихкодов
// по диапазонам.
//
// Возвращаемое значение:
//  ТаблицаЗначений - Максимальные значения кодов по диапазонам.
//
Функция ПолучитьМаксимальныеЗначенияКодовШтучныхШтрихкодов() Экспорт
	
	ДиапазоныШтучныхШтрихкодов = ЗначениеНастроекПовтИсп.ДиапазоныШтучныхШтрихкодов();
	
	Если ДиапазоныШтучныхШтрихкодов.Количество() = 0 Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	ОписаниеТипаЧисла = ОбщегоНазначения.ОписаниеТипаЧисло(15, 0);
	
	МаксимальныеЗначения = Новый ТаблицаЗначений();
	МаксимальныеЗначения.Колонки.Добавить("Код",		ОписаниеТипаЧисла);
	МаксимальныеЗначения.Колонки.Добавить("Диапазон",	ОбщегоНазначения.ОписаниеТипаСтрока(2));
	
	ПрефиксУзла			= Строка(Константы.ПрефиксШтрихкодовУзлаРИБ.Получить());
	ТекстыЗапросов		= Новый Массив;
	СтрокиНачалаКода	= Новый Массив;
	
	Для Каждого СтрокаТЧ Из ДиапазоныШтучныхШтрихкодов Цикл
		
		ТекстЗапросаСтроки =
		"ВЫБРАТЬ
		|	""#СтрокаТЧДиапазон""							КАК Диапазон,
		|	ПОДСТРОКА(ШтрихкодыНоменклатуры.Штрихкод, 4, 9)	КАК КодСтрока,
		|	ШтрихкодыНоменклатуры.Штрихкод					КАК Штрихкод
		|ИЗ
		|	РегистрСведений.ШтрихкодыНоменклатуры КАК ШтрихкодыНоменклатуры
		|ГДЕ
		|	ШтрихкодыНоменклатуры.Штрихкод ПОДОБНО ""#СтрокаТЧНачалоКода__________""";
		
		СтрокаТЧНачалоКода = СтрокаТЧ.Диапазон + ПрефиксУзла;
		
		ТекстЗапросаСтроки = СтрЗаменить(ТекстЗапросаСтроки, "#СтрокаТЧДиапазон", СтрокаТЧ.Диапазон);
		ТекстЗапросаСтроки = СтрЗаменить(ТекстЗапросаСтроки, "#СтрокаТЧНачалоКода", СтрокаТЧНачалоКода);
		
		ТекстыЗапросов.Добавить(ТекстЗапросаСтроки);
		
		СтрокаМаксимальногоЗначения = МаксимальныеЗначения.Добавить();
		СтрокаМаксимальногоЗначения.Диапазон	= СтрокаТЧ.Диапазон;
		СтрокаМаксимальногоЗначения.Код			= 0;
		
		СтрокиНачалаКода.Добавить(СтрокаТЧНачалоКода);
		
	КонецЦикла;
	
	Запрос = Новый Запрос;
	Запрос.Текст = СтрСоединить(ТекстыЗапросов, ОбщегоНазначенияУТ.РазделительЗапросовВОбъединении());
	Запрос.Текст = Запрос.Текст + "
	|УПОРЯДОЧИТЬ ПО
	|	КодСтрока УБЫВ";
	
	РезультатЗапроса = Запрос.Выполнить().Выгрузить();
	
	ПроверенныеДиапазоны = Новый Массив;
	КоличествоДиапазонов = МаксимальныеЗначения.Количество();
	
	МаксимальныйКодШтучногоТовара = МаксимальныйКодШтучногоТовара();
	
	Для Каждого СтрокаТЧ Из РезультатЗапроса Цикл
		
		Если ПроверенныеДиапазоны.Количество() = КоличествоДиапазонов Тогда
			Прервать;
		ИначеЕсли СтрокиНачалаКода.Найти(Лев(СтрокаТЧ.Штрихкод, 3)) = Неопределено
			Или ПроверенныеДиапазоны.Найти(СтрокаТЧ.Диапазон) <> Неопределено Тогда
			
			Продолжить;
			
		КонецЕсли;
		
		Код = ОписаниеТипаЧисла.ПривестиЗначение(СтрокаТЧ.КодСтрока);
		СтрокаМаксимальногоЗначения = МаксимальныеЗначения.Найти(СтрокаТЧ.Диапазон, "Диапазон");
		
		Если Код = 0 Тогда
			Продолжить;
		ИначеЕсли Код >= МаксимальныйКодШтучногоТовара Тогда
			ПроверенныеДиапазоны.Добавить(СтрокаТЧ.Диапазон);
			МаксимальныеЗначения.Удалить(СтрокаМаксимальногоЗначения);
			
			Продолжить;
		КонецЕсли;
		
		СтрокаМаксимальногоЗначения.Код = Код;
		
		ПроверенныеДиапазоны.Добавить(СтрокаТЧ.Диапазон);
		
	КонецЦикла;
	
	Возврат МаксимальныеЗначения;
	
КонецФункции

// Функция возвращает максимальное значение кода весового товара
// из зарегистрированных в системе штрихкодов.
//
// Возвращаемое значение:
//  Число - Максимальный код весового товара.
//
Функция ПолучитьМаксимальноеЗначениеКодаВесовыхШтрихкодов() Экспорт
	
	ПрефиксУзла = Строка(Константы.ПрефиксШтрихкодовУзлаРИБ.Получить());
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ШтрихкодыНоменклатуры.Штрихкод					КАК Штрихкод,
	|	ПОДСТРОКА(ШтрихкодыНоменклатуры.Штрихкод, 4, 4)	КАК КодСтрока
	|ИЗ
	|	РегистрСведений.ШтрихкодыНоменклатуры КАК ШтрихкодыНоменклатуры
	|ГДЕ
	|	ШтрихкодыНоменклатуры.Штрихкод ПОДОБНО ""2_#ПрефиксУзла#____00000_""
	|
	|УПОРЯДОЧИТЬ ПО
	|	КодСтрока УБЫВ";
	
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "#ПрефиксУзла#", ПрефиксУзла);
	
	РезультатЗапроса = Запрос.Выполнить().Выгрузить();
	
	ОписаниеТипаЧисла				= ОбщегоНазначения.ОписаниеТипаЧисло(15, 0);
	КоличествоСтроковыхЗначений		= 0;
	МаксимальныйКодВесовогоТовара	= МаксимальныйКодВесовогоТовара();
	
	СтрокиНачалаКода = Новый Массив;
	СтрокиНачалаКода.Добавить("20" + ПрефиксУзла);
	СтрокиНачалаКода.Добавить("21" + ПрефиксУзла);
	СтрокиНачалаКода.Добавить("22" + ПрефиксУзла);
	СтрокиНачалаКода.Добавить("23" + ПрефиксУзла);
	СтрокиНачалаКода.Добавить("24" + ПрефиксУзла);
	СтрокиНачалаКода.Добавить("25" + ПрефиксУзла);
	СтрокиНачалаКода.Добавить("26" + ПрефиксУзла);
	СтрокиНачалаКода.Добавить("27" + ПрефиксУзла);
	СтрокиНачалаКода.Добавить("28" + ПрефиксУзла);
	СтрокиНачалаКода.Добавить("29" + ПрефиксУзла);
	СтрокиНачалаКода.Добавить("2_" + ПрефиксУзла);
	
	КонтрольныеСимволы = Новый Массив;
	КонтрольныеСимволы.Добавить("0");
	КонтрольныеСимволы.Добавить("1");
	КонтрольныеСимволы.Добавить("2");
	КонтрольныеСимволы.Добавить("3");
	КонтрольныеСимволы.Добавить("4");
	КонтрольныеСимволы.Добавить("5");
	КонтрольныеСимволы.Добавить("6");
	КонтрольныеСимволы.Добавить("7");
	КонтрольныеСимволы.Добавить("8");
	КонтрольныеСимволы.Добавить("9");
	КонтрольныеСимволы.Добавить("_");
	
	Для Каждого СтрокаТЧ Из РезультатЗапроса Цикл
		
		Если СтрокиНачалаКода.Найти(Лев(СтрокаТЧ.Штрихкод, 3)) = Неопределено
			Или КонтрольныеСимволы.Найти(Прав(СтрокаТЧ.Штрихкод, 1)) = Неопределено Тогда
			
			КоличествоСтроковыхЗначений = КоличествоСтроковыхЗначений + 1;
			
			Продолжить;
			
		КонецЕсли;
		
		Код = ОписаниеТипаЧисла.ПривестиЗначение(СтрокаТЧ.КодСтрока);
		
		Если Код >= МаксимальныйКодВесовогоТовара Тогда
			Продолжить;
		ИначеЕсли Код = 0 Тогда
			КоличествоСтроковыхЗначений = КоличествоСтроковыхЗначений + 1;
			
			Продолжить;
		КонецЕсли;
		
		Возврат Код;
		
	КонецЦикла;
	
	Если МаксимальныйКодВесовогоТовара > 0
		И КоличествоСтроковыхЗначений = РезультатЗапроса.Количество() Тогда
		
		Код = 0;
		
		Возврат Код;
		
	КонецЕсли;
	
	Возврат Неопределено;
	
КонецФункции

// Функция возвращает максимальный код штучного товара.
//
// Возвращаемое значение:
//  Число - Максимальный код штучного товара.
//
Функция МаксимальныйКодШтучногоТовара() Экспорт
	
	Возврат 999999999;
	
КонецФункции

// Функция возвращает максимальный код весового товара.
//
// Возвращаемое значение:
//  Число - Максимальный код весового товара.
//
Функция МаксимальныйКодВесовогоТовара() Экспорт
	
	Возврат 9999;
	
КонецФункции

// Обработчик обновления УТ 11.1.5.7
// 
Процедура ЗаполнитьКонстантыПодсистемыШтрихкодирования() Экспорт

	НастройкиДиапазоновШтрихкодов = РегистрыСведений.ШтрихкодыНоменклатуры.НастройкиДиапазоновШтрихкодовПоУмолчанию();
	ПрефиксШтучногоШтрихкода = Константы.ПрефиксШтучногоШтрихкода.Получить();
	
	Если ЗначениеЗаполнено(СокрЛП(ПрефиксШтучногоШтрихкода)) Тогда
		Константы.ПрефиксШтрихкодовУзлаРИБ.Установить(ПрефиксШтучногоШтрихкода);
	Иначе
		Константы.ПрефиксШтрихкодовУзлаРИБ.Установить("0");
	КонецЕсли;
	
	Константы.ВыгружатьВнутренниеШтрихкодыШтучныхТоваров.Установить(Истина);
	Константы.НастройкиПрефиксацииШтрихкодов.Установить(Новый ХранилищеЗначения(НастройкиДиапазоновШтрихкодов));
	
КонецПроцедуры

// Выполняет проверку записываемых сведений на корректность указания упаковки для товара с политикой учета серий
// номенклатуры, указываемых поэкземплярно.
//
// Параметры:
//	ШтрихкодыНоменклатуры - ДанныеФормыКоллекция - таблица, содержащая сведения о штрихкодах номенклатуры.
//	Отказ - Булево - признак успешности выполнения проверки. Истина - при проверке выявлены ошибки.
//	РежимУказанияШтрихкода - Булево - признак, режима уточнения сведений о штрихкодах. Истина - сведения уточняются для
//										одной записи штрихкода.
//
Процедура ПроверитьЗаполнениеСерии(ШтрихкодыНоменклатуры, Отказ, РежимУказанияШтрихкода = Ложь) Экспорт
	
	Если Не ПолучитьФункциональнуюОпцию("ИспользоватьСерииНоменклатурыСклад") Тогда
		Возврат;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ТаблицаТоваров.Номенклатура		КАК Номенклатура,
	|	ТаблицаТоваров.Характеристика	КАК Характеристика,
	|	ТаблицаТоваров.Серия			КАК Серия,
	|	ТаблицаТоваров.Упаковка			КАК Упаковка
	|ПОМЕСТИТЬ ТаблицаТоваров
	|ИЗ
	|	&ТаблицаТоваров КАК ТаблицаТоваров
	|ГДЕ
	|	НЕ ТаблицаТоваров.Зарегистрирован
	|	И ТаблицаТоваров.Серия <> ЗНАЧЕНИЕ(Справочник.СерииНоменклатуры.ПустаяСсылка)
	|	И ТаблицаТоваров.Упаковка <> ЗНАЧЕНИЕ(Справочник.УпаковкиЕдиницыИзмерения.ПустаяСсылка)
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Номенклатура,
	|	Упаковка
	|;
	|
	|//////////////////////////////////////////////////////////////////////////////// 1
	|ВЫБРАТЬ
	|	ТаблицаТоваров.Номенклатура		КАК Номенклатура,
	|	ТаблицаТоваров.Характеристика	КАК Характеристика,
	|	ТаблицаТоваров.Серия			КАК Серия,
	|	ТаблицаТоваров.Упаковка			КАК Упаковка
	|ИЗ
	|	ТаблицаТоваров КАК ТаблицаТоваров
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК СправочникНоменклатура
	|		ПО ТаблицаТоваров.Номенклатура = СправочникНоменклатура.Ссылка
	|		
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.УпаковкиЕдиницыИзмерения КАК Упаковки
	|		ПО ТаблицаТоваров.Упаковка = Упаковки.Ссылка
	|			И Упаковки.Знаменатель <> 0
	|			И Упаковки.ТипУпаковки <> ЗНАЧЕНИЕ(Перечисление.ТипыУпаковокНоменклатуры.ТоварноеМесто)
	|
	|ГДЕ
	|	СправочникНоменклатура.ВидНоменклатуры.ИспользоватьКоличествоСерии = ЛОЖЬ
	|	И Упаковки.ТипУпаковки <> ЗНАЧЕНИЕ(Перечисление.ТипыУпаковокНоменклатуры.ТоварноеМесто)
	|	И Упаковки.Числитель / Упаковки.Знаменатель <> 1";
	
	ВыгружаемыеКолонки = "Зарегистрирован, Номенклатура, Характеристика, Серия, Упаковка";
	
	Запрос.УстановитьПараметр("ТаблицаТоваров", ШтрихкодыНоменклатуры.Выгрузить(, ВыгружаемыеКолонки));
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Если РезультатЗапроса.Пустой() Тогда
		Возврат;
	КонецЕсли;
	
	ИменаКолонок = "Номенклатура, Характеристика, Серия, Упаковка";
	
	ТаблицаТоваров = РезультатЗапроса.Выгрузить();
	ТаблицаТоваров.Индексы.Добавить(ИменаКолонок);
	
	ОтборСтрок = Новый Структура(ИменаКолонок);
	
	ШаблонСообщения = НСтр("ru = 'Политика учета серий номенклатуры ""%1"" предусматривает, что серии указываются для каждого экземпляра. Укажите единичную упаковку.'");
	
	НомерСтроки = 0;
	
	Для Каждого СтрокаШтрихкода Из ШтрихкодыНоменклатуры Цикл
		НомерСтроки = НомерСтроки + 1;
		
		Если Не (Не СтрокаШтрихкода.Зарегистрирован
			И ЗначениеЗаполнено(СтрокаШтрихкода.Серия)
			И ЗначениеЗаполнено(СтрокаШтрихкода.Упаковка)) Тогда
			
			Продолжить;
			
		КонецЕсли;
		
		ЗаполнитьЗначенияСвойств(ОтборСтрок, СтрокаШтрихкода);
		НайденныеСтроки = ТаблицаТоваров.НайтиСтроки(ОтборСтрок);
		
		Если НайденныеСтроки.Количество() = 0 Тогда
			Продолжить;
		КонецЕсли;
		
		ПредставлениеНоменклатуры = НоменклатураКлиентСервер.ПредставлениеНоменклатуры(
										СокрЛП(Строка(СтрокаШтрихкода.Номенклатура)),
										СокрЛП(Строка(СтрокаШтрихкода.Характеристика)));
		
		ТекстСообщения	= СтрШаблон(ШаблонСообщения, ПредставлениеНоменклатуры);
		Поле			= ?(РежимУказанияШтрихкода,
							"Упаковка",
							"ШтрихкодыНоменклатуры[" + (НомерСтроки - 1) + "].Упаковка");
		
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения, Неопределено, Поле, "", Отказ);
	КонецЦикла;
	
КонецПроцедуры

// Выполняет проверку записываемых сведений на наличие неуникальных записей по данным информационной базы.
//
// Параметры:
//	ШтрихкодыНоменклатуры - ДанныеФормыКоллекция - таблица, содержащая сведения о штрихкодах номенклатуры.
//	Отказ - Булево - признак успешности выполнения проверки. Истина - при проверке выявлены ошибки.
//	РежимУказанияШтрихкода - Булево - признак, режима уточнения сведений о штрихкодах. Истина - сведения уточняются для
//										одной записи штрихкода.
//
Процедура ПроверкаНеуникальныхШтрихкодовНоменклатуры(ШтрихкодыНоменклатуры, Отказ, РежимУказанияШтрихкода = Ложь) Экспорт
	
	ТекстыЗапросов = Новый Массив;
	
	ЧастьТекстаЗапроса =
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ВЫРАЗИТЬ(Штрихкоды.Штрихкод КАК СТРОКА(200)) КАК Штрихкод,
	|	Штрихкоды.Номенклатура		КАК Номенклатура,
	|	Штрихкоды.Характеристика	КАК Характеристика,
	|	Штрихкоды.Серия				КАК Серия,
	|	Штрихкоды.Упаковка			КАК Упаковка
	|ПОМЕСТИТЬ ИнформацияОШтрихкодах
	|ИЗ
	|	&ДанныеПоШтрихкодам КАК Штрихкоды
	|ГДЕ
	|	НЕ Штрихкоды.Зарегистрирован
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Штрихкод,
	|	Номенклатура,
	|	Характеристика,
	|	Серия,
	|	Упаковка";
	ТекстыЗапросов.Добавить(ЧастьТекстаЗапроса);
	
	Если ПолучитьФункциональнуюОпцию("ИспользоватьНеуникальныеШтрихкодыНоменклатуры") Тогда
		ЧастьТекстаЗапроса =
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	ШтрихкодыНоменклатуры.Штрихкод						КАК Штрихкод,
		|	ПРЕДСТАВЛЕНИЕ(ШтрихкодыНоменклатуры.Номенклатура)	КАК Номенклатура,
		|	ПРЕДСТАВЛЕНИЕ(ШтрихкодыНоменклатуры.Характеристика)	КАК Характеристика,
		|	ПРЕДСТАВЛЕНИЕ(ШтрихкодыНоменклатуры.Серия)			КАК Серия,
		|	ПРЕДСТАВЛЕНИЕ(ШтрихкодыНоменклатуры.Упаковка)		КАК Упаковка
		|ИЗ
		|	РегистрСведений.ШтрихкодыНоменклатуры КАК ШтрихкодыНоменклатуры
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ИнформацияОШтрихкодах КАК ИнформацияОШтрихкодах
		|		ПО ШтрихкодыНоменклатуры.Штрихкод = ИнформацияОШтрихкодах.Штрихкод
		|		
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК СправочникНоменклатура
		|		ПО ШтрихкодыНоменклатуры.Номенклатура = СправочникНоменклатура.Ссылка
		|		
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ВидыНоменклатуры.РеквизитыДляКонтроляНоменклатуры КАК РеквизитыКонтроляУникальности
		|		ПО СправочникНоменклатура.Видноменклатуры = РеквизитыКонтроляУникальности.Ссылка
		|			И РеквизитыКонтроляУникальности.ИмяРеквизита = &ИмяРеквизитаШтрихкод
		|			И РеквизитыКонтроляУникальности.Уникален
		|ГДЕ
		|	НЕ (ШтрихкодыНоменклатуры.Номенклатура, ШтрихкодыНоменклатуры.Характеристика, ШтрихкодыНоменклатуры.Серия, ШтрихкодыНоменклатуры.Упаковка) В
		|			(ВЫБРАТЬ
		|				Штрихкоды.Номенклатура		КАК Номенклатура,
		|				Штрихкоды.Характеристика	КАК Характеристика,
		|				Штрихкоды.Серия				КАК Серия,
		|				Штрихкоды.Упаковка			КАК Упаковка
		|			ИЗ
		|				ИнформацияОШтрихкодах КАК Штрихкоды
		|			ГДЕ
		|				Штрихкоды.Штрихкод = ШтрихкодыНоменклатуры.Штрихкод)
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ ПЕРВЫЕ 1
		|	ШтрихкодыНоменклатуры.Штрихкод						КАК Штрихкод,
		|	ПРЕДСТАВЛЕНИЕ(ШтрихкодыНоменклатуры.Номенклатура)	КАК Номенклатура,
		|	ПРЕДСТАВЛЕНИЕ(ШтрихкодыНоменклатуры.Характеристика)	КАК Характеристика,
		|	ПРЕДСТАВЛЕНИЕ(ШтрихкодыНоменклатуры.Серия)			КАК Серия,
		|	ПРЕДСТАВЛЕНИЕ(ШтрихкодыНоменклатуры.Упаковка)		КАК Упаковка
		|ИЗ
		|	РегистрСведений.ШтрихкодыНоменклатуры КАК ШтрихкодыНоменклатуры
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ИнформацияОШтрихкодах КАК ИнформацияОШтрихкодах
		|		ПО ШтрихкодыНоменклатуры.Штрихкод = ИнформацияОШтрихкодах.Штрихкод
		|		
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК СправочникНоменклатура
		|		ПО ШтрихкодыНоменклатуры.Номенклатура = СправочникНоменклатура.Ссылка
		|		
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ВидыНоменклатуры.РеквизитыДляКонтроляНоменклатуры КАК РеквизитыКонтроляУникальности
		|		ПО СправочникНоменклатура.Видноменклатуры = РеквизитыКонтроляУникальности.Ссылка
		|			И РеквизитыКонтроляУникальности.ИмяРеквизита = &ИмяРеквизитаШтрихкод
		|			И НЕ РеквизитыКонтроляУникальности.Уникален
		|ГДЕ
		|	НЕ ЕСТЬNULL(РеквизитыКонтроляУникальности.Уникален, ЛОЖЬ)
		|	И НЕ (ШтрихкодыНоменклатуры.Номенклатура, ШтрихкодыНоменклатуры.Характеристика, ШтрихкодыНоменклатуры.Серия, ШтрихкодыНоменклатуры.Упаковка) В
		|			(ВЫБРАТЬ
		|				Штрихкоды.Номенклатура		КАК Номенклатура,
		|				Штрихкоды.Характеристика	КАК Характеристика,
		|				Штрихкоды.Серия				КАК Серия,
		|				Штрихкоды.Упаковка			КАК Упаковка
		|			ИЗ
		|				ИнформацияОШтрихкодах КАК Штрихкоды
		|			ГДЕ
		|				Штрихкоды.Штрихкод = ШтрихкодыНоменклатуры.Штрихкод)
		|	И ИСТИНА В
		|			(ВЫБРАТЬ
		|				ИСТИНА
		|			ИЗ
		|				ИнформацияОШтрихкодах КАК Штрихкоды
		|					ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК СправочникНоменклатура
		|					ПО Штрихкоды.Номенклатура = СправочникНоменклатура.Ссылка
		|					
		|					ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ВидыНоменклатуры.РеквизитыДляКонтроляНоменклатуры КАК РеквизитыКонтроля
		|					ПО СправочникНоменклатура.Видноменклатуры = РеквизитыКонтроля.Ссылка
		|						И РеквизитыКонтроля.ИмяРеквизита = &ИмяРеквизитаШтрихкод
		|						И РеквизитыКонтроля.Уникален
		|			ГДЕ
		|				Штрихкоды.Штрихкод = ШтрихкодыНоменклатуры.Штрихкод)
		|";
	Иначе
		ЧастьТекстаЗапроса =
		"ВЫБРАТЬ
		|	ШтрихкодыНоменклатуры.Штрихкод						КАК Штрихкод,
		|	ПРЕДСТАВЛЕНИЕ(ШтрихкодыНоменклатуры.Номенклатура)	КАК Номенклатура,
		|	ПРЕДСТАВЛЕНИЕ(ШтрихкодыНоменклатуры.Характеристика)	КАК Характеристика,
		|	ПРЕДСТАВЛЕНИЕ(ШтрихкодыНоменклатуры.Серия)			КАК Серия,
		|	ПРЕДСТАВЛЕНИЕ(ШтрихкодыНоменклатуры.Упаковка)		КАК Упаковка
		|ИЗ
		|	РегистрСведений.ШтрихкодыНоменклатуры КАК ШтрихкодыНоменклатуры
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ИнформацияОШтрихкодах КАК ИнформацияОШтрихкодах
		|		ПО ШтрихкодыНоменклатуры.Штрихкод = ИнформацияОШтрихкодах.Штрихкод
		|ГДЕ
		|	НЕ (ШтрихкодыНоменклатуры.Номенклатура, ШтрихкодыНоменклатуры.Характеристика, ШтрихкодыНоменклатуры.Серия, ШтрихкодыНоменклатуры.Упаковка) В
		|			(ВЫБРАТЬ
		|				Штрихкоды.Номенклатура		КАК Номенклатура,
		|				Штрихкоды.Характеристика	КАК Характеристика,
		|				Штрихкоды.Серия				КАК Серия,
		|				Штрихкоды.Упаковка			КАК Упаковка
		|			ИЗ
		|				ИнформацияОШтрихкодах КАК Штрихкоды)";
	КонецЕсли;
	
	ТекстыЗапросов.Добавить(ЧастьТекстаЗапроса);
	
	Запрос = Новый Запрос;
	Запрос.Текст = СтрСоединить(ТекстыЗапросов, ОбщегоНазначения.РазделительПакетаЗапросов());
	
	ВыгружаемыеКолонки = "Зарегистрирован, Штрихкод, Номенклатура, Характеристика, Серия, Упаковка";
	
	Запрос.УстановитьПараметр("ИмяРеквизитаШтрихкод",	"Штрихкод");
	Запрос.УстановитьПараметр("ДанныеПоШтрихкодам",		ШтрихкодыНоменклатуры.Выгрузить(, ВыгружаемыеКолонки));
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Если РезультатЗапроса.Пустой() Тогда
		Возврат;
	КонецЕсли;
	
	ДанныеШтрихкодов = РезультатЗапроса.Выгрузить();
	ДанныеШтрихкодов.Индексы.Добавить("Штрихкод");
	
	ШаблонТекстаСообщения = НСтр("ru = 'Такой штрихкод уже назначен для номенклатуры %1.'");
	
	НомерСтроки = 0;
	
	Для Каждого СтрокаШтрихкода Из ШтрихкодыНоменклатуры Цикл
		НомерСтроки = НомерСтроки + 1;
		
		Если СтрокаШтрихкода.Зарегистрирован Тогда
			Продолжить;
		КонецЕсли;
		
		ЗаписьРегистра = ДанныеШтрихкодов.Найти(СтрокаШтрихкода.Штрихкод, "Штрихкод");
		
		Если ЗаписьРегистра = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		ПредставленияНоменклатуры = Новый Массив;
		
		ШаблонНоменклатуры = НСтр("ru = '""%1""'");
		
		ПредставлениеНоменклатуры = НоменклатураКлиентСервер.ПредставлениеНоменклатуры(
										СокрЛП(ЗаписьРегистра.Номенклатура),
										СокрЛП(ЗаписьРегистра.Характеристика));
		ПредставлениеНоменклатуры = СтрШаблон(ШаблонНоменклатуры, ПредставлениеНоменклатуры);
		ПредставленияНоменклатуры.Добавить(ПредставлениеНоменклатуры);
		
		Если Не ПустаяСтрока(ЗаписьРегистра.Серия) Тогда
			ПредставлениеСерии = НСтр("ru = 'с серией ""%1""'");
			ПредставлениеСерии = СтрШаблон(ПредставлениеСерии, СокрЛП(ЗаписьРегистра.Серия));
			
			ПредставленияНоменклатуры.Добавить(ПредставлениеСерии);
		КонецЕсли;
		
		Если Не ПустаяСтрока(ЗаписьРегистра.Упаковка) Тогда
			ПредставлениеУпаковки = НСтр("ru = 'в упаковке ""%1""'");
			ПредставлениеУпаковки = СтрШаблон(ПредставлениеУпаковки, СокрЛП(ЗаписьРегистра.Упаковка));
			
			ПредставленияНоменклатуры.Добавить(ПредставлениеУпаковки);
		КонецЕсли;
		
		ТекстСообщения = СтрШаблон(ШаблонТекстаСообщения, СтрСоединить(ПредставленияНоменклатуры, " "));
		Поле			= ?(РежимУказанияШтрихкода,
							"Штрихкод",
							"ШтрихкодыНоменклатуры[" + (НомерСтроки - 1) + "].Штрихкод");
		
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения, Неопределено, Поле, "", Отказ);
	КонецЦикла;
	
КонецПроцедуры

// Регистрирует штрихкоды этикеток серий номенклатуры. Обновляет сведения кэшируемых значений по штрихкодам.
//
// Параметры:
//	ШтрихкодыСерий - Массив Из Строка - коллекция штрихкодов серий этикеток номенклатуры.
//	КэшированныеЗначения - см. ПакетнаяОбработкаТабличнойЧастиКлиентСервер.ПолучитьСтруктуруКэшируемыеЗначения.
//
Процедура ЗарегистрироватьШтрихкодыЭтикетокСерийНоменклатуры(ШтрихкодыСерий, КэшированныеЗначения) Экспорт
	
	ДанныеПоШтрихкодам = ТаблицаДанныеПоШтрихкодам();
	
	Для Каждого Штрихкод Из ШтрихкодыСерий Цикл
		ДанныеШтрихкода = КэшированныеЗначения.Штрихкоды.Получить(Штрихкод);
		
		Если ДанныеШтрихкода = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		НоваяСтрока = ДанныеПоШтрихкодам.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, ДанныеШтрихкода);
	КонецЦикла;
	
	Если Не КэшированныеЗначения.ПравоРегистрацииШтрихкодовНоменклатурыДоступно Тогда
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;
	
	ЕстьОшибки = Ложь;
	
	НачатьТранзакцию();
	
	Попытка
		Блокировка = Новый БлокировкаДанных;
		
		ЭлементБлокировки = Блокировка.Добавить("РегистрСведений.ШтрихкодыНоменклатуры");
		ЭлементБлокировки.ИсточникДанных = ДанныеПоШтрихкодам;
		
		ЭлементБлокировки.ИспользоватьИзИсточникаДанных("Штрихкод",			"Штрихкод");
		ЭлементБлокировки.ИспользоватьИзИсточникаДанных("Номенклатура",		"Номенклатура");
		ЭлементБлокировки.ИспользоватьИзИсточникаДанных("Характеристика",	"Характеристика");
		ЭлементБлокировки.ИспользоватьИзИсточникаДанных("Серия",			"Серия");
		ЭлементБлокировки.ИспользоватьИзИсточникаДанных("Упаковка",			"Упаковка");
		
		Блокировка.Заблокировать();
		
		НаборЗаписей = СоздатьНаборЗаписей();
		НаборЗаписей.Загрузить(ДанныеПоШтрихкодам);
		НаборЗаписей.Записать(РежимЗамещения.Слияние);
		
		ЗафиксироватьТранзакцию();
	Исключение
		ОтменитьТранзакцию();
		
		ЕстьОшибки = Истина;
		
		ТекстСобытия = НСтр("ru = 'Регистрация штрихкодов этикеток серий номенклатуры.'");
		
		ТекстОшибки = ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
		Комментарий = НСтр("ru = 'Не удалось зарегистрировать штрихкоды номенклатуры по причине: %1'");
		Комментарий = СтрШаблон(Комментарий, ТекстОшибки);
		
		ЗаписьЖурналаРегистрации(
			ТекстСобытия,
			УровеньЖурналаРегистрации.Ошибка,
			Метаданные.РегистрыСведений.ШтрихкодыНоменклатуры,
			,
			Комментарий);
		
	КонецПопытки;
	
	Если ЕстьОшибки Тогда
		Возврат;
	КонецЕсли;
	
	Для Каждого Штрихкод Из ШтрихкодыСерий Цикл
		ДанныеШтрихкода = КэшированныеЗначения.Штрихкоды.Получить(Штрихкод);
		
		Если ДанныеШтрихкода = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		ДанныеШтрихкода.ШтрихкодНоменклатуры = Истина;
	КонецЦикла;
	
КонецПроцедуры

// Выполняет регистрацию сведений о штрихкодах номенклатуры.
//
// Параметры:
//	ШтрихкодыНоменклатуры - ТаблицаЗначений - коллекция сведений о штрихкодах номенклатуры.
//
Процедура РегистрацияШтрихкодовНоменклатуры(ШтрихкодыНоменклатуры) Экспорт
	
	НачатьТранзакцию();
	
	Попытка
		Блокировка = Новый БлокировкаДанных;
		
		ЭлементБлокировки = Блокировка.Добавить("РегистрСведений.ШтрихкодыНоменклатуры");
		ЭлементБлокировки.ИсточникДанных = ШтрихкодыНоменклатуры;
		
		ЭлементБлокировки.ИспользоватьИзИсточникаДанных("Штрихкод",			"Штрихкод");
		ЭлементБлокировки.ИспользоватьИзИсточникаДанных("Номенклатура",		"Номенклатура");
		ЭлементБлокировки.ИспользоватьИзИсточникаДанных("Характеристика",	"Характеристика");
		ЭлементБлокировки.ИспользоватьИзИсточникаДанных("Серия",			"Серия");
		ЭлементБлокировки.ИспользоватьИзИсточникаДанных("Упаковка",			"Упаковка");
		
		Блокировка.Заблокировать();
		
		НаборЗаписей = СоздатьНаборЗаписей();
		НаборЗаписей.Загрузить(ШтрихкодыНоменклатуры);
		НаборЗаписей.Записать(РежимЗамещения.Слияние);
		
		ЗафиксироватьТранзакцию();
	Исключение
		ОтменитьТранзакцию();
		
		ВызватьИсключение;
	КонецПопытки;
	
КонецПроцедуры

#Область ДляВызоваИзДругихПодсистем

// СтандартныеПодсистемы.УправлениеДоступом

// См. УправлениеДоступомПереопределяемый.ПриЗаполненииСписковСОграничениемДоступа.
//
// Параметры:
//	Ограничение - см. УправлениеДоступомПереопределяемый.ПриЗаполненииОграниченияДоступа.Ограничение.
//
Процедура ПриЗаполненииОграниченияДоступа(Ограничение) Экспорт

	Ограничение.Текст =
	"РазрешитьЧтение
	|ГДЕ ИСТИНА
	|;
	|РазрешитьИзменениеЕслиРазрешеноЧтение
	|ГДЕ
	|	ЗначениеРазрешено(Номенклатура)";

КонецПроцедуры

// Конец СтандартныеПодсистемы.УправлениеДоступом

#КонецОбласти

#Область ОбновлениеИнформационнойБазы

// см. ОбновлениеИнформационнойБазыБСП.ПриДобавленииОбработчиковОбновления
Процедура ПриДобавленииОбработчиковОбновления(Обработчики) Экспорт
	
	Обработчик = Обработчики.Добавить();
	Обработчик.Процедура = "РегистрыСведений.ШтрихкодыНоменклатуры.ОбработатьДанныеДляПереходаНаНовуюВерсию";
	Обработчик.Версия = "11.5.26.73";
	Обработчик.РежимВыполнения = "Отложенно";
	Обработчик.ЗапускатьИВПодчиненномУзлеРИБСФильтрами = Истина;
	Обработчик.Идентификатор = Новый УникальныйИдентификатор("21caedb2-58d8-43d1-8eff-3cc479fa23c8");
	Обработчик.Многопоточный = Истина;
	Обработчик.ПроцедураЗаполненияДанныхОбновления = "РегистрыСведений.ШтрихкодыНоменклатуры.ЗарегистрироватьДанныеКОбработкеДляПереходаНаНовуюВерсию";
	Обработчик.ПроцедураПроверки = "ОбновлениеИнформационнойБазы.ДанныеОбновленыНаНовуюВерсиюПрограммы";
	Обработчик.Порядок = Перечисления.ПорядокОбработчиковОбновления.Критичный;
	Обработчик.Комментарий = НСтр("ru = 'Выполняет перенос сведений из ресурсов ""Номенклатура"", ""Характеристика"" и ""Упаковка"" регистра сведений ""Штрихкоды номенклатуры"" в добавленные одноименные измерения.'");
	
	Изменяемые = Новый Массив;
	Изменяемые.Добавить(Метаданные.РегистрыСведений.ШтрихкодыНоменклатуры.ПолноеИмя());
	Обработчик.ИзменяемыеОбъекты = СтрСоединить(Изменяемые, ",");
	
	Блокируемые = Новый Массив;
	Блокируемые.Добавить(Метаданные.РегистрыСведений.ШтрихкодыНоменклатуры.ПолноеИмя());
	Обработчик.БлокируемыеОбъекты = СтрСоединить(Блокируемые, ",");
	
КонецПроцедуры

// Регистрирует записи регистра к обработке.
//
// Параметры:
//	Параметры - см. ОбновлениеИнформационнойБазы.ОсновныеПараметрыОтметкиКОбработке.
//
Процедура ЗарегистрироватьДанныеКОбработкеДляПереходаНаНовуюВерсию(Параметры) Экспорт 
	
	ПолноеИмяРегистра = "РегистрСведений.ШтрихкодыНоменклатуры";
	
	ПараметрыВыборки = Параметры.ПараметрыВыборки;
	ПараметрыВыборки.ПолныеИменаРегистров = ПолноеИмяРегистра;
	ПараметрыВыборки.СпособВыборки = ОбновлениеИнформационнойБазы.СпособВыборкиИзмеренияНезависимогоРегистраСведений();
	
	ДополнительныеПараметры = ОбновлениеИнформационнойБазы.ДополнительныеПараметрыОтметкиОбработки();
	ДополнительныеПараметры.Вставить("ПолноеИмяРегистра", ПолноеИмяРегистра);
	ДополнительныеПараметры.Вставить("ЭтоНезависимыйРегистрСведений", Истина);
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ДанныеОбъекта.Штрихкод КАК Штрихкод
	|ИЗ
	|	РегистрСведений.ШтрихкодыНоменклатуры КАК ДанныеОбъекта
	|ГДЕ
	|	ДанныеОбъекта.Номенклатура = ЗНАЧЕНИЕ(Справочник.Номенклатура.ПустаяСсылка)
	|	И ДанныеОбъекта.УдалитьНоменклатура <> ЗНАЧЕНИЕ(Справочник.Номенклатура.ПустаяСсылка)";
	
	ОбновлениеИнформационнойБазы.ОтметитьКОбработке(Параметры,
													Запрос.Выполнить().Выгрузить(),
													ДополнительныеПараметры);
	
КонецПроцедуры

// Обработчик обновления.
//
// Параметры:
//	Параметры - см. ОбновлениеИнформационнойБазы.ОсновныеПараметрыОтметкиКОбработке.
//
Процедура ОбработатьДанныеДляПереходаНаНовуюВерсию(Параметры) Экспорт
	
	ПолноеИмяРегистра = Метаданные.РегистрыСведений.ШтрихкодыНоменклатуры.ПолноеИмя();
	
	Если Не ОбновлениеИнформационнойБазы.ЕстьДанныеДляОбработки(Параметры.Очередь, ПолноеИмяРегистра) Тогда
		Параметры.ОбработкаЗавершена = Истина;
		
		Возврат;
	КонецЕсли;
	
	ОбновляемыеДанные = ОбновлениеИнформационнойБазы.ДанныеДляОбновленияВМногопоточномОбработчике(Параметры);
	
	Если ОбновляемыеДанные.Количество() = 0 Тогда
		Параметры.ОбработкаЗавершена = ОбновлениеИнформационнойБазы.ОбработкаДанныхЗавершена(Параметры.Очередь,
																							ПолноеИмяРегистра);
		
		Возврат;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ДанныеОбъекта.Штрихкод				КАК Штрихкод,
	|	ДанныеОбъекта.УдалитьНоменклатура	КАК Номенклатура,
	|	ДанныеОбъекта.УдалитьХарактеристика	КАК Характеристика,
	|	ЗНАЧЕНИЕ(Справочник.СерииНоменклатуры.ПустаяСсылка) КАК Серия,
	|	ДанныеОбъекта.УдалитьУпаковка		КАК Упаковка,
	|	ДанныеОбъекта.УдалитьНоменклатура	КАК УдалитьНоменклатура,
	|	ДанныеОбъекта.УдалитьХарактеристика	КАК УдалитьХарактеристика,
	|	ДанныеОбъекта.УдалитьУпаковка		КАК УдалитьУпаковка
	|ИЗ
	|	РегистрСведений.ШтрихкодыНоменклатуры КАК ДанныеОбъекта
	|ГДЕ
	|	ДанныеОбъекта.Штрихкод В (&ОбрабатываемыеШтрихкоды)
	|	И ДанныеОбъекта.Номенклатура = ЗНАЧЕНИЕ(Справочник.Номенклатура.ПустаяСсылка)
	|	И ДанныеОбъекта.УдалитьНоменклатура <> ЗНАЧЕНИЕ(Справочник.Номенклатура.ПустаяСсылка)";
	
	Запрос.УстановитьПараметр("ОбрабатываемыеШтрихкоды", ОбновляемыеДанные.ВыгрузитьКолонку("Штрихкод"));
	
	ДополнительныеПараметры = ОбновлениеИнформационнойБазы.ДополнительныеПараметрыОтметкиОбработки();
	ДополнительныеПараметры.ЭтоНезависимыйРегистрСведений = Истина;
	ДополнительныеПараметры.ПолноеИмяРегистра = ПолноеИмяРегистра;
	
	Блокировка = Новый БлокировкаДанных;
	ЭлементБлокировки = Блокировка.Добавить(ПолноеИмяРегистра);
	ЭлементБлокировки.ИсточникДанных = ОбновляемыеДанные;
	
	ЭлементБлокировки.ИспользоватьИзИсточникаДанных("Штрихкод",			"Штрихкод");
	ЭлементБлокировки.ИспользоватьИзИсточникаДанных("Номенклатура",		"Номенклатура");
	ЭлементБлокировки.ИспользоватьИзИсточникаДанных("Характеристика",	"Характеристика");
	ЭлементБлокировки.ИспользоватьИзИсточникаДанных("Серия",			"Серия");
	ЭлементБлокировки.ИспользоватьИзИсточникаДанных("Упаковка",			"Упаковка");
	
	ЕстьПлохиеДанные = Ложь;
	
	НачатьТранзакцию();
	
	Попытка
		Блокировка.Заблокировать();
		
		РезультатыЗапроса = Запрос.Выполнить();
		
		НаборЗаписей = СоздатьНаборЗаписей();
		
		НаборЗаписей.ОбменДанными.Загрузка = Истина;
		НаборЗаписей.ОбменДанными.Получатели.АвтоЗаполнение = Ложь;
		
		НаборЗаписей.Загрузить(ОбновляемыеДанные);
		НаборЗаписей.ДополнительныеСвойства.Вставить("РегистрироватьНаУзлахПлановОбменаПриОбновленииИБ", Ложь);
		
		НаборЗаписей.Записать(РежимЗамещения.Удаление);
		
		Если Не РезультатыЗапроса.Пустой() Тогда
			НаборЗаписей = СоздатьНаборЗаписей();
			НаборЗаписей.Загрузить(РезультатыЗапроса.Выгрузить());
			
			ОбновлениеИнформационнойБазы.ЗаписатьНаборЗаписей(НаборЗаписей, Ложь);
		КонецЕсли;
		
		ОбновлениеИнформационнойБазы.ОтметитьВыполнениеОбработки(ОбновляемыеДанные, ДополнительныеПараметры);
		
		ЗафиксироватьТранзакцию();
	Исключение
		ОтменитьТранзакцию();
		
		ЕстьПлохиеДанные = Истина;
		
		ТекстСообщения = НСтр("ru = 'Не удалось обновить данные в регистре %1 по причине: %2'");
		ТекстСообщения = СтрШаблон(ТекстСообщения,
									ПолноеИмяРегистра,
									ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
		
		ЗаписьЖурналаРегистрации(ОбновлениеИнформационнойБазы.СобытиеЖурналаРегистрации(),
									УровеньЖурналаРегистрации.Предупреждение,
									Метаданные.РегистрыСведений.ШтрихкодыНоменклатуры,
									,
									ТекстСообщения);
	КонецПопытки;
	
	ОбъектовОбработано = 0;
	ПроблемныхОбъектов = 0;
	ИсключенияПриОбновлении = Новый Массив;
	
	СписокОписаний = Новый Массив;
	СписокОписаний.Добавить(НСтр("ru = 'Не удалось обработать записи регистра сведений ""Штрихкоды номенклатуры"".'"));
	
	Если ЕстьПлохиеДанные Тогда
		
		Для Каждого ЗаписьРегистра Из ОбновляемыеДанные Цикл
			НачатьТранзакцию();
			
			Попытка
				ПричинаИсключения = "Блокировка";
				
				Блокировка = Новый БлокировкаДанных;
				
				ЭлементБлокировки = Блокировка.Добавить(ПолноеИмяРегистра);
				ЭлементБлокировки.УстановитьЗначение("Штрихкод", ЗаписьРегистра.Штрихкод);
				ЭлементБлокировки.Режим = РежимБлокировкиДанных.Исключительный;
				
				Блокировка.Заблокировать();
				
				НаборЗаписей = РегистрыСведений.ШтрихкодыНоменклатуры.СоздатьНаборЗаписей();
				НаборЗаписей.Отбор.Штрихкод.Установить(ЗаписьРегистра.Штрихкод);
				НаборЗаписей.Прочитать();
				
				Для Каждого ЗаписьНабора Из НаборЗаписей Цикл
					Если Не ЗначениеЗаполнено(ЗаписьНабора.Номенклатура)
						И ЗначениеЗаполнено(ЗаписьНабора.УдалитьНоменклатура) Тогда
						
						ЗаписьНабора.Номенклатура = ЗаписьНабора.УдалитьНоменклатура;
						
					КонецЕсли;
					
					Если Не ЗначениеЗаполнено(ЗаписьНабора.Характеристика)
						И ЗначениеЗаполнено(ЗаписьНабора.УдалитьХарактеристика) Тогда
						
						ЗаписьНабора.Характеристика = ЗаписьНабора.УдалитьХарактеристика;
						
					КонецЕсли;
					
					Если Не ЗначениеЗаполнено(ЗаписьНабора.Упаковка)
						И ЗначениеЗаполнено(ЗаписьНабора.УдалитьУпаковка) Тогда
						
						ЗаписьНабора.Упаковка = ЗаписьНабора.УдалитьУпаковка;
						
					КонецЕсли;
				КонецЦикла;
				
				ПричинаИсключения = "Запись";
				
				Если НаборЗаписей.Модифицированность() Тогда
					ОбновлениеИнформационнойБазы.ЗаписатьНаборЗаписей(НаборЗаписей);
				Иначе
					ОбновлениеИнформационнойБазы.ОтметитьВыполнениеОбработки(НаборЗаписей);
				КонецЕсли;
				
				ОбъектовОбработано = ОбъектовОбработано + 1;
				
				ЗафиксироватьТранзакцию();
			Исключение
				ОтменитьТранзакцию();
				
				ПроблемныхОбъектов = ПроблемныхОбъектов + 1;
				
				ТекстСообщения = НСтр("ru = 'Не удалось обновить данные в регистре %1 по причине: %2'");
				ТекстСообщения = СтрШаблон(ТекстСообщения,
											ПолноеИмяРегистра,
											ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
				
				ЗаписьЖурналаРегистрации(ОбновлениеИнформационнойБазы.СобытиеЖурналаРегистрации(),
											УровеньЖурналаРегистрации.Предупреждение,
											Метаданные.РегистрыСведений.ШтрихкодыНоменклатуры,
											,
											ТекстСообщения);
				
				Если ПричинаИсключения = "Запись" Тогда
					ОбновлениеИнформационнойБазыУТ.ЗаписатьПлохиеДанные(ИсключенияПриОбновлении,
																		ОбъектовОбработано,
																		Параметры);
					
					ВызватьИсключение СтрСоединить(СписокОписаний, Символы.ПС);
				КонецЕсли;
				
			КонецПопытки;
			
		КонецЦикла;
		
	КонецЕсли;
	
	Если ОбъектовОбработано = 0
		И ПроблемныхОбъектов <> 0 Тогда
		
		СписокОписаний.Добавить(НСтр("ru = 'Всего пропущено: %1'"));
		
		ТекстСообщения = СтрШаблон(СтрСоединить(СписокОписаний, Символы.ПС), Строка(ПроблемныхОбъектов));
		
		ВызватьИсключение ТекстСообщения;
		
	КонецЕсли;
	
	ОбновлениеИнформационнойБазыУТ.ЗаписатьПлохиеДанные(ИсключенияПриОбновлении, ОбъектовОбработано, Параметры);
	
	Параметры.ОбработкаЗавершена = ОбновлениеИнформационнойБазы.ОбработкаДанныхЗавершена(Параметры.Очередь,
																						ПолноеИмяРегистра);
	
КонецПроцедуры

#КонецОбласти

#Область ПакетнаяОбработкаТабличныхЧастей

// Добавляет запрос в пакет запросов для проверки наличия штрихкода номенклатуры по значениям измерений
// регистра сведений Штрихкоды номенклатуры.
//
// Параметры:
//	СтруктураДействий - см. ПакетнаяОбработкаТабличнойЧастиКлиентСервер.ПолучитьСтруктуруКэшируемыеЗначения.
//	ОписаниеЗапроса - см. ПакетнаяОбработкаТабличнойЧастиСервер.ОписаниеЗапроса.
//	КэшированныеЗначения - Структура.
//
Процедура ДополнитьТекстЗапросаПроверитьРегистрациюШтрихкода(СтруктураДействий, ОписаниеЗапроса, КэшированныеЗначения) Экспорт
	
	Перем ПараметрыДействия;
	
	Если ПакетнаяОбработкаТабличнойЧастиСервер.ТребуетсяВыполнитьДействие(
			"ПроверитьРегистрациюШтрихкода",
			СтруктураДействий,
			КэшированныеЗначения,
			ПараметрыДействия) Тогда
		
		СписокЗапросов = ТекстыЗапросовПроверитьРегистрациюШтрихкода();
		
		Для Каждого ЭлементСписка Из СписокЗапросов Цикл
			ОписаниеЗапроса.ТекстыЗапросов.Добавить(ЭлементСписка.Значение, ЭлементСписка.Представление);
		КонецЦикла;
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

#Область Прочее

// Кэширует сведения о штрихкодах номенклатуры, по найденным данным в информационной базе, на основании передаваемой
// коллекции штрихкодов.
//
// Параметры:
//	КэшированныеЗначения - см. ПакетнаяОбработкаТабличнойЧастиКлиентСервер.ПолучитьСтруктуруКэшируемыеЗначения.
//	Штрихкоды - Массив Из Строка - штрихкоды, для которых необходимо получить сведения.
//	ПолучатьНеуникальныеШтрихкоды - Булево - признак получения данных о неуникальных штрихкодах номенклатуры.
//
Процедура ПолучитьДанныеПоШтрихкодамЭтикетокСерий(КэшированныеЗначения, Штрихкоды, ПолучатьНеуникальныеШтрихкоды)
	
	Если Не ПолучитьФункциональнуюОпцию("ИспользоватьСерииНоменклатурыСклад") Тогда
		Возврат;
	КонецЕсли;
	
	МассивШтрихкодов		= Новый Массив;
	ДанныеПоШтрихкодамСерий	= ТаблицаДанныеПоШтрихкодамСерий();
	
	// Часть штрихкодов обработана раннее по данным регистра сведений.
	Для Каждого ТекШтрихкод Из Штрихкоды Цикл
		Штрихкод			= ВРег(СокрЛП(ТекШтрихкод));
		ДанныеПоШтрихкоду	= КэшированныеЗначения.Штрихкоды[Штрихкод];
		
		Если ТипЗнч(ДанныеПоШтрихкоду) = Тип("Массив") Тогда
			Продолжить;
		ИначеЕсли Не ДанныеПоШтрихкоду.НеизвестныйШтрихкод Тогда
			Продолжить;
		КонецЕсли;
		
		ИнформацияОСерии = ШтрихкодированиеНоменклатурыСервер.ИнформацияОСерииИзШтрихкода(Штрихкод, Истина, Истина, Ложь);
		
		Если ИнформацияОСерии.ЕстьОшибка Тогда
			Продолжить;
		КонецЕсли;
		
		НоваяСтрока = ДанныеПоШтрихкодамСерий.Добавить();
		НоваяСтрока.Штрихкод	= Штрихкод;
		НоваяСтрока.НомерСерии	= ИнформацияОСерии.Номер;
		НоваяСтрока.ГоденДо		= ИнформацияОСерии.ГоденДо;
		
		МассивШтрихкодов.Добавить(Штрихкод);
	КонецЦикла;
	
	Если ДанныеПоШтрихкодамСерий.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Штрихкоды.Штрихкод		КАК Штрихкод,
	|	Штрихкоды.НомерСерии	КАК НомерСерии,
	|	Штрихкоды.ГоденДо		КАК ГоденДо
	|ПОМЕСТИТЬ ДанныеСерий
	|ИЗ
	|	&ШтрихкодыНоменклатуры КАК Штрихкоды
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ДанныеСерий.Штрихкод				КАК Штрихкод,
	|	ДвиженияСерийТоваров.Номенклатура	КАК Номенклатура,
	|	ДвиженияСерийТоваров.Характеристика	КАК Характеристика,
	|	ДвиженияСерийТоваров.Серия			КАК Серия
	|ПОМЕСТИТЬ ДанныеДвиженийСерий
	|ИЗ
	|	РегистрНакопления.ДвиженияСерийТоваров КАК ДвиженияСерийТоваров
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.СерииНоменклатуры КАК СерииНоменклатуры
	|		ПО ДвиженияСерийТоваров.Серия = СерииНоменклатуры.Ссылка
	|		
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ДанныеСерий КАК ДанныеСерий
	|		ПО СерииНоменклатуры.Номер = ДанныеСерий.НомерСерии
	|			И СерииНоменклатуры.ГоденДо = ДанныеСерий.ГоденДо
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Штрихкоды.Штрихкод				КАК Штрихкод,
	|	КОЛИЧЕСТВО(Штрихкоды.Штрихкод)	КАК КоличествоШтрихкодов
	|ПОМЕСТИТЬ ИнформацияОШтрихкодах
	|ИЗ
	|	ДанныеДвиженийСерий КАК Штрихкоды
	|
	|СГРУППИРОВАТЬ ПО
	|	Штрихкоды.Штрихкод
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Штрихкод
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ИнформацияОШтрихкодах.Штрихкод					КАК Штрихкод,
	|	ШтрихкодыНоменклатуры.Номенклатура				КАК Номенклатура,
	|	СправочникНоменклатура.ТипНоменклатуры			КАК ТипНоменклатуры,
	|	&РеквизитыНоменклатурыВыборка,
	|	ВЫБОР
	|		КОГДА ЕСТЬNULL(СправочникНоменклатура.ВладелецСерий, НЕОПРЕДЕЛЕНО) = ЗНАЧЕНИЕ(Справочник.ВидыНоменклатуры.ПустаяСсылка)
	|			ТОГДА СправочникНоменклатура.ВидНоменклатуры.ИспользоватьКоличествоСерии
	|		ИНАЧЕ СправочникНоменклатура.ВладелецСерий.ИспользоватьКоличествоСерии
	|	КОНЕЦ											КАК ИспользоватьКоличествоСерии,
	|	ШтрихкодыНоменклатуры.Характеристика			КАК Характеристика,
	|	ШтрихкодыНоменклатуры.Серия						КАК Серия,
	|	ИСТИНА											КАК СерииИспользуются,
	|	ЗНАЧЕНИЕ(Справочник.УпаковкиЕдиницыИзмерения.ПустаяСсылка) КАК Упаковка,
	|	ЛОЖЬ											КАК ТоварноеМесто,
	|	ПРЕДСТАВЛЕНИЕ(ШтрихкодыНоменклатуры.Номенклатура) КАК НоменклатураПредставление,
	|	ПРЕДСТАВЛЕНИЕ(ШтрихкодыНоменклатуры.Характеристика) КАК ХарактеристикаПредставление,
	|	1												КАК Коэффициент,
	|	ВЫБОР
	|		КОГДА ЕСТЬNULL(СправочникНоменклатура.ИспользованиеХарактеристик, НЕОПРЕДЕЛЕНО) = ЗНАЧЕНИЕ(Перечисление.ВариантыИспользованияХарактеристикНоменклатуры.НеИспользовать)
	|			ТОГДА ЛОЖЬ
	|		ИНАЧЕ ИСТИНА
	|	КОНЕЦ											КАК ХарактеристикиИспользуются,
	|	ВЫБОР
	|		КОГДА СправочникНоменклатура.ПоставляетсяВМногооборотнойТаре
	|			ТОГДА ИСТИНА
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ											КАК ПоставляетсяВМногооборотнойТаре,
	|	СправочникНоменклатура.ИспользоватьУпаковки		КАК ИспользоватьУпаковки,
	|	НЕОПРЕДЕЛЕНО									КАК ЕдиничнаяУпаковка,
	|	0												КАК КоличествоЕдиничныхУпаковок,
	|	ВЫБОР
	|		КОГДА ВариантыКомплектацииНоменклатуры.ВариантРасчетаЦеныНабора ЕСТЬ NULL
	|			ТОГДА ЗНАЧЕНИЕ(Перечисление.ВариантыРасчетаЦенНаборов.ПустаяСсылка)
	|		ИНАЧЕ ВариантыКомплектацииНоменклатуры.ВариантРасчетаЦеныНабора
	|	КОНЕЦ											КАК ВариантРасчетаЦеныНабора,
	|	СправочникНоменклатура.ЕдиницаИзмерения			КАК ЕдиницаИзмерения,
	|	ИнформацияОШтрихкодах.КоличествоШтрихкодов > 1	КАК НеуникальныйШтрихкод,
	|	ЛОЖЬ											КАК ШтрихкодНоменклатуры
	|ИЗ
	|	ИнформацияОШтрихкодах КАК ИнформацияОШтрихкодах
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ДанныеДвиженийСерий КАК ШтрихкодыНоменклатуры
	|		ПО ИнформацияОШтрихкодах.Штрихкод = ШтрихкодыНоменклатуры.Штрихкод
	|		
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК СправочникНоменклатура
	|		ПО ШтрихкодыНоменклатуры.Номенклатура = СправочникНоменклатура.Ссылка
	|		
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ВариантыКомплектацииНоменклатуры КАК ВариантыКомплектацииНоменклатуры
	|		ПО ШтрихкодыНоменклатуры.Номенклатура = ВариантыКомплектацииНоменклатуры.Владелец
	|			И ШтрихкодыНоменклатуры.Характеристика = ВариантыКомплектацииНоменклатуры.Характеристика
	|			И ВариантыКомплектацииНоменклатуры.Основной
	|	, ТаблицаСоединения";
	
	ТекстыЗапросаРеквизитовНоменклатуры = НоменклатураЛокализация.ТекстыЗапросаРеквизитовНоменклатуры();
	НоменклатураЛокализация.ЗаполнитьТекстЗапросаРеквизитыНоменклатуры(
		"СправочникНоменклатура",
		ТекстыЗапросаРеквизитовНоменклатуры);
	
	Запрос.Текст = СтрЗаменить(Запрос.Текст,
								"&РеквизитыНоменклатурыВыборка",
								ТекстыЗапросаРеквизитовНоменклатуры.РеквизитыНоменклатурыВыборка);
	Запрос.Текст = СтрЗаменить(Запрос.Текст,
								", ТаблицаСоединения",
								ТекстыЗапросаРеквизитовНоменклатуры.РеквизитыНоменклатурыСоединения);
	
	Запрос.УстановитьПараметр("ШтрихкодыНоменклатуры", ДанныеПоШтрихкодамСерий);
	
	УстановитьПривилегированныйРежим(Истина);
	РезультатЗапроса = Запрос.Выполнить();
	УстановитьПривилегированныйРежим(Ложь);
	
	Если РезультатЗапроса.Пустой() Тогда
		Возврат;
	КонецЕсли;
	
	ДанныеПоШтрихкодам = РезультатЗапроса.Выгрузить();
	ДанныеПоШтрихкодам.Индексы.Добавить("Штрихкод");
	
	ЗаполнитьКэшированныеЗначенияПоДаннымИБ(КэшированныеЗначения,
											ДанныеПоШтрихкодам,
											МассивШтрихкодов,
											ПолучатьНеуникальныеШтрихкоды);
	
КонецПроцедуры

// Возвращает пустую таблицу, содержащую описание сведений о штрихкодах серий.
//
// Возвращаемое значение:
//	ТаблицаЗначений - пустая таблица, содержащая описание сведений о штрихкодах номенклатуры:
//		* Штрихкод - Строка - штрихкод номенклатуры.
//		* Серия - СправочникСсылка.СерииНоменклатуры - серия номенклатуры.
//		* НомерСерии - ОпределяемыйТип.НомерСерии - номер серии номенклатуры.
//		* ГоденДо - Дата - срок годности серии номенклатуры.
//
Функция ТаблицаДанныеПоШтрихкодамСерий()
	
	ДанныеПоШтрихкодамСерий = Новый ТаблицаЗначений;
	ДанныеПоШтрихкодамСерий.Колонки.Добавить("Штрихкод",
											Метаданные.РегистрыСведений.ШтрихкодыНоменклатуры.Измерения.Штрихкод.Тип);
	ДанныеПоШтрихкодамСерий.Колонки.Добавить("НомерСерии",
											Метаданные.ОпределяемыеТипы.НомерСерии.Тип);
	ДанныеПоШтрихкодамСерий.Колонки.Добавить("ГоденДо",
											Новый ОписаниеТипов("Дата"));
	
	Возврат ДанныеПоШтрихкодамСерий;
	
КонецФункции

// Возвращает пустую таблицу, содержащую описание сведений о штрихкодах номенклатуры.
//
// Возвращаемое значение:
//	ТаблицаЗначений - пустая таблица, содержащая описание сведений о штрихкодах номенклатуры:
//		* Штрихкод - Строка - штрихкод номенклатуры.
//		* Номенклатура - СправочникСсылка.Номенклатура - номенклатура.
//		* Характеристика - СправочникСсылка.ХарактеристикиНоменклатуры - характеристика номенклатуры.
//		* Серия - СправочникСсылка.СерииНоменклатуры - серия номенклатуры.
//		* Упаковка - СправочникСсылка.УпаковкиЕдиницыИзмерения - упаковка номенклатуры.
//
Функция ТаблицаДанныеПоШтрихкодам()
	
	ДанныеПоШтрихкодам = Новый ТаблицаЗначений;
	ДанныеПоШтрихкодам.Колонки.Добавить("Штрихкод",
										Метаданные.РегистрыСведений.ШтрихкодыНоменклатуры.Измерения.Штрихкод.Тип);
	ДанныеПоШтрихкодам.Колонки.Добавить("Номенклатура",
										Новый ОписаниеТипов("СправочникСсылка.Номенклатура"));
	ДанныеПоШтрихкодам.Колонки.Добавить("Характеристика",
										Новый ОписаниеТипов("СправочникСсылка.ХарактеристикиНоменклатуры"));
	ДанныеПоШтрихкодам.Колонки.Добавить("Серия",
										Новый ОписаниеТипов("СправочникСсылка.СерииНоменклатуры"));
	ДанныеПоШтрихкодам.Колонки.Добавить("Упаковка",
										Новый ОписаниеТипов("СправочникСсылка.УпаковкиЕдиницыИзмерения"));
	
	Возврат ДанныеПоШтрихкодам;
	
КонецФункции

// Заполняет коллекцию кэшированных значений данными ИБ.
//
// Параметры:
//	КэшированныеЗначения - см. ПакетнаяОбработкаТабличнойЧастиКлиентСервер.ПолучитьСтруктуруКэшируемыеЗначения.
//	ДанныеПоШтрихкодам - ТаблицаЗначений - таблица, содержащая результат получения данных из ИБ.
//	Штрихкоды - Массив Из Строка - штрихкоды, для которых необходимо получить сведения.
//	ПолучатьНеуникальныеШтрихкоды - Булево - признак получения данных о неуникальных штрихкодах номенклатуры.
//
Процедура ЗаполнитьКэшированныеЗначенияПоДаннымИБ(КэшированныеЗначения, ДанныеПоШтрихкодам, Штрихкоды, ПолучатьНеуникальныеШтрихкоды)
	
	ОтборСтрок = Новый Структура("Штрихкод");
	
	Для Каждого ТекШтрихкод Из Штрихкоды Цикл
		Штрихкод			= ВРег(СокрЛП(ТекШтрихкод));
		ОтборСтрок.Штрихкод	= Штрихкод;
		НайденныеСтроки		= ДанныеПоШтрихкодам.НайтиСтроки(ОтборСтрок);
		КоличествоДанных	= НайденныеСтроки.Количество();
		
		Если КоличествоДанных = 0 Тогда
			Продолжить;
		ИначеЕсли ПолучатьНеуникальныеШтрихкоды Тогда
			ДанныеШтрихкода = Новый Массив;
			
			Для Каждого СтрокаШтрихкода Из НайденныеСтроки Цикл
				ИнформацияПоШтрихкоду = ПакетнаяОбработкаТабличнойЧастиКлиентСервер.СтруктураКэшируемойИнформацииПоШтрихкоду();
				ЗаполнитьИнформациюПоШтрихкоду(ИнформацияПоШтрихкоду, СтрокаШтрихкода);
				
				ДанныеШтрихкода.Добавить(ИнформацияПоШтрихкоду);
			КонецЦикла;
			
			КэшированныеЗначения.Штрихкоды.Вставить(Штрихкод, ДанныеШтрихкода);
		Иначе
			ИнформацияПоШтрихкоду = КэшированныеЗначения.Штрихкоды[Штрихкод];
			
			Если КоличествоДанных > 1 Тогда
				ИнформацияПоШтрихкоду.НеуникальныйШтрихкод = Истина;
			ИначеЕсли КоличествоДанных = 1 Тогда
				ЗаполнитьИнформациюПоШтрихкоду(ИнформацияПоШтрихкоду, НайденныеСтроки[0]);
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

// Заполняет информацию по штрихкоду данными ИБ.
//
// Параметры:
//	ИнформацияПоШтрихкоду - см. ПакетнаяОбработкаТабличнойЧастиКлиентСервер.ПолучитьСтруктуруКэшируемыеЗначения.
//	ДанныеШтрихкода - СтрокаТаблицыЗначений, ВыборкаИзРезультатаЗапроса - сведения о штрихкоде номенклатуры.
//
Процедура ЗаполнитьИнформациюПоШтрихкоду(ИнформацияПоШтрихкоду, ДанныеШтрихкода)
	
	ЗаполнитьЗначенияСвойств(ИнформацияПоШтрихкоду, ДанныеШтрихкода);
	
	ИнформацияПоШтрихкоду.Штрихкод						= ВРег(СокрЛП(ДанныеШтрихкода.Штрихкод));
	ИнформацияПоШтрихкоду.КоличествоУпаковок			= 1;
	ИнформацияПоШтрихкоду.ЕдиничнаяУпаковка				= ?(ДанныеШтрихкода.КоличествоЕдиничныхУпаковок = 1
																И ДанныеШтрихкода.Коэффициент = 1,
															ДанныеШтрихкода.ЕдиничнаяУпаковка,
															Неопределено);
	ИнформацияПоШтрихкоду.НесколькоЕдиничныхУпаковок	= ДанныеШтрихкода.КоличествоЕдиничныхУпаковок > 1
															И Не ДанныеШтрихкода.ТоварноеМесто;
	ИнформацияПоШтрихкоду.НеизвестныйШтрихкод			= Ложь;
	ИнформацияПоШтрихкоду.ПредставлениеНоменклатуры		= НоменклатураКлиентСервер.ПредставлениеНоменклатурыДляПечати(
															ДанныеШтрихкода.НоменклатураПредставление,
															ДанныеШтрихкода.ХарактеристикаПредставление);
	
КонецПроцедуры

#КонецОбласти

#Область ПакетнаяОбработкаТабличныхЧастейСлужебная

// Возвращает список запросов для проверки регистрации штрихкода номенклатуры в информационной базе.
//
// Возвращаемое значение:
// 	СписокЗначений Из Строка.
//
Функция ТекстыЗапросовПроверитьРегистрациюШтрихкода()
	
	Результат = Новый СписокЗначений;
	
	ТекстЗапроса =
	"ВЫБРАТЬ
	|	ВтИсточникДанных.ИдентификаторСтрокиВТ	КАК ИдентификаторСтрокиВТ,
	|	ВЫБОР
	|		КОГДА ШтрихкодыНоменклатуры.Штрихкод ЕСТЬ NULL
	|			ТОГДА ЛОЖЬ
	|		ИНАЧЕ ИСТИНА
	|	КОНЕЦ									КАК Зарегистрирован
	|ИЗ
	|	ВтИсточникДанных КАК ВтИсточникДанных
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ШтрихкодыНоменклатуры КАК ШтрихкодыНоменклатуры
	|		ПО ВтИсточникДанных.Штрихкод = ШтрихкодыНоменклатуры.Штрихкод
	|			И ВтИсточникДанных.Номенклатура = ШтрихкодыНоменклатуры.Номенклатура
	|			И ВтИсточникДанных.Характеристика = ШтрихкодыНоменклатуры.Характеристика
	|			И ВтИсточникДанных.Серия = ШтрихкодыНоменклатуры.Серия
	|			И ВтИсточникДанных.Упаковка = ШтрихкодыНоменклатуры.Упаковка";
	
	Результат.Добавить(ТекстЗапроса, "ПроверитьРегистрациюШтрихкода");
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти

#КонецОбласти

#КонецЕсли

#КонецЕсли