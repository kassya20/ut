#Область СлужебныйПрограммныйИнтерфейс

Процедура ЗаписатьПлатежнуюСсылку(Документ, ДополнительныеСведения) Экспорт

	НачатьТранзакцию();
	
	Попытка
		
		Блокировка = Новый БлокировкаДанных;
		ЭлементБлокировки = Блокировка.Добавить("РегистрСведений.ВходящиеПлатежныеСсылкиСБП");
		ЭлементБлокировки.УстановитьЗначение("ДокументОперации", Документ);
		ЭлементБлокировки.Режим = РежимБлокировкиДанных.Исключительный;
		Блокировка.Заблокировать();
		
		Запись = РегистрыСведений.ВходящиеПлатежныеСсылкиСБП.СоздатьМенеджерЗаписи();
		Запись.ДокументОперации = Документ;
		Запись.ПлатежнаяСсылка = СокрЛП(ДополнительныеСведения.ПлатежнаяСсылка);
		Запись.СуммаОперации = ДополнительныеСведения.СуммаОплаты;
		Запись.СуммаНДС = ДополнительныеСведения.СуммаНДС;
		Запись.ИНН = ДополнительныеСведения.ИНН;
		Запись.НомерСчета = ДополнительныеСведения.СчетПолучателя;
		Запись.ТипСсылки = ДополнительныеСведения.ТипСсылки;
		Запись.НастройкаПодключения = ДополнительныеСведения.НастройкаПодключения;
		Запись.ИдентификаторПлатежа = СокрЛП(ДополнительныеСведения.ИдентификаторПлатежа);
		Запись.ДатаСоздания = ТекущаяДатаСеанса();
		Запись.ПроверкаПройдена = Истина;
		
		Запись.Записать();
		
		ЗафиксироватьТранзакцию();
		
	Исключение
		
		ОтменитьТранзакцию();
		
		ТекстШаблона = НСтр("ru = 'Ошибка записи входящей платежной ссылки СБП:
						|%1'");
		ТекстОшибки = СтрШаблон(ТекстШаблона, ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
		
		ЗаписьЖурналаРегистрации(
				НСтр("ru = 'Ввод платежной ссылки СБП'", ОбщегоНазначения.КодОсновногоЯзыка()),
				УровеньЖурналаРегистрации.Ошибка, , ,
				ТекстОшибки);
		
		ТекстОшибкиКратко = 
			СтрШаблон(ТекстШаблона, ОбработкаОшибок.КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));
		
		ВызватьИсключение ТекстОшибкиКратко;
		
	КонецПопытки;

КонецПроцедуры

#КонецОбласти

#КонецЕсли