#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Если Параметры.Свойство("АвтоТест") Тогда // Возврат при получении формы для анализа.
		Возврат;
	КонецЕсли;
	
	Если Параметры.ЗначенияЗаполнения.Свойство("Изменен")
		И Параметры.ЗначенияЗаполнения.Изменен Тогда
		Элементы.Изменен.ТолькоПросмотр = Истина;
	КонецЕсли;
	
	Если Параметры.ЗначенияЗаполнения.Свойство("ЭлементКонструктора")
		И ЗначениеЗаполнено(Параметры.ЗначенияЗаполнения.ЭлементКонструктора) Тогда
		Элементы.ЭлементКонструктора.ТолькоПросмотр = Истина;
	КонецЕсли;
	
	ОбщегоНазначенияСобытияФормИСПереопределяемый.ПриСозданииНаСервере(ЭтотОбъект, Отказ, СтандартнаяОбработка);

КонецПроцедуры

#КонецОбласти