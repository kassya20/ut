
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Если Параметры.ТолькоИзменение Тогда
		ТолькоИзменение = Истина;
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "Список", "ИзменятьСоставСтрок", Ложь);
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "Список", "ИзменятьПорядокСтрок", Ложь);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Параметры.ИдентификаторыЭДО) Тогда
		ЭлементОтбора = Список.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
		ЭлементОтбора.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("ИдентификаторЭДО");
		ЭлементОтбора.ВидСравнения = ВидСравненияКомпоновкиДанных.ВСписке;
		ЭлементОтбора.Использование = Истина;
		ЭлементОтбора.РежимОтображения = РежимОтображенияЭлементаНастройкиКомпоновкиДанных.Недоступный;
		ЭлементОтбора.ПравоеЗначение = Параметры.ИдентификаторыЭДО;
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти
// @strict-types

#Область ОбработчикиСобытийЭлементовТаблицыФормыСписок

&НаКлиенте
Процедура СписокВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("Ключ", ВыбраннаяСтрока);
	ПараметрыФормы.Вставить("ТолькоИзменение", ТолькоИзменение);
	ОткрытьФорму("РегистрСведений.СостоянияАвтоматическогоПолученияЭДО.ФормаЗаписи", ПараметрыФормы, ЭтотОбъект,,,,,
		РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура Возобновить(Команда)
	
	ИдентификаторыЭДО = Новый Массив; // Массив из Строка
	
	ЭлементыСписок = Элементы.Список;
	ВыделенныеСтроки = ЭлементыСписок.ВыделенныеСтроки;
	Для Каждого ВыделеннаяСтрока Из ВыделенныеСтроки Цикл
		ТекущиеДанные = ЭлементыСписок.ДанныеСтроки(ВыделеннаяСтрока);
		ИдентификаторыЭДО.Добавить(ТекущиеДанные.ИдентификаторЭДО);
	КонецЦикла;
	
	Если Не ЗначениеЗаполнено(ИдентификаторыЭДО) Тогда
		Возврат;
	КонецЕсли;
	
	ИдентификаторыЭДОСПросроченнымиСертификатами = ИдентификаторыЭДОСПросроченнымиСертификатами(ИдентификаторыЭДО);
	Если ЗначениеЗаполнено(ИдентификаторыЭДОСПросроченнымиСертификатами) Тогда
		Если ИдентификаторыЭДОСПросроченнымиСертификатами.Количество() = 1 Тогда
			УчетныеЗаписиЭДОИнтеграцияЦентраЭДОКлиент.ОткрытьФормуУчетнойЗаписиЭДО(
				ИдентификаторыЭДОСПросроченнымиСертификатами[0]);
		Иначе
			ТекстПредупреждения = СтрШаблон("По учетным записям ЭДО:
											|%1
											|есть просроченные сертификаты.
											|Требуется обновить сертификаты.", 
				СтрСоединить(ИдентификаторыЭДОСПросроченнымиСертификатами, Символы.ПС));
			ПоказатьПредупреждение(,ТекстПредупреждения);
		КонецЕсли;
		Возврат;
	КонецЕсли;
	
	Оповещение = Новый ОписаниеОповещения("ВключитьПоУчетнымЗаписямЭДОЗавершение", ЭтотОбъект);
	
	ПараметрыАвторизации = УчетныеЗаписиЭДОКлиент.НовыеПараметрыАвторизацииВСервисеЭДО();
	ПараметрыАвторизации.ИдентификаторыЭДО = ИдентификаторыЭДО;
	ПараметрыАвторизации.ФормаВладелец = ЭтотОбъект;
	ПараметрыАвторизации.ВыводитьОкноОжидания = Истина;
	
	АвтоматическоеПолучениеЭДОКлиент.ВключитьПоУчетнымЗаписямЭДО(Оповещение, ПараметрыАвторизации);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Параметры:
//  ИдентификаторыЭДО - Массив Из Строка
// 
// Возвращаемое значение:
//  Массив Из Строка
&НаСервере
Функция ИдентификаторыЭДОСПросроченнымиСертификатами(ИдентификаторыЭДО)
	ОтборСертификатовУчетныхЗаписей = УчетныеЗаписиЭДО.НовыйОтборСертификатовУчетныхЗаписей();
	ОтборСертификатовУчетныхЗаписей.УчетныеЗаписи = "&ИдентификаторЭДО";
	
	ЗапросСертификатовУчетныхЗаписей = УчетныеЗаписиЭДО.ЗапросСертификатовУчетныхЗаписей("СертификатыУчетныхЗаписей",
		ОтборСертификатовУчетныхЗаписей);
	
	Запросы = Новый Массив;
	Запросы.Добавить(ЗапросСертификатовУчетныхЗаписей);
	
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ
		|	СертификатыУчетныхЗаписей.Сертификат,
		|	СертификатыУчетныхЗаписей.ИдентификаторЭДО
		|ИЗ
		|	СертификатыУчетныхЗаписей КАК СертификатыУчетныхЗаписей";
			
	ИтоговыйЗапрос = ОбщегоНазначенияБЭД.СоединитьЗапросы(Запрос, Запросы);
	
	ИтоговыйЗапрос.УстановитьПараметр("ИдентификаторЭДО", ИдентификаторыЭДО);
	
	РезультатЗапроса = ИтоговыйЗапрос.Выполнить();
	Если РезультатЗапроса.Пустой() Тогда
		Возврат ИдентификаторыЭДО;
	КонецЕсли;
	Выборка = РезультатЗапроса.Выбрать();
	МассивСертификатов = Новый Массив;
	Пока Выборка.Следующий() Цикл
		МассивСертификатов.Добавить(Выборка.Сертификат);
	КонецЦикла;
	СвойстваСертификатов = КриптографияБЭД.СвойстваСертификатов(МассивСертификатов);
	
	Результат = Новый Массив;
	Выборка.Сбросить();
	Пока Выборка.Следующий() Цикл
		Если СвойстваСертификатов[Выборка.Сертификат].ДействителенДо < ТекущаяДатаСеанса() Тогда
			Результат.Добавить(Выборка.ИдентификаторЭДО);
		КонецЕсли;
	КонецЦикла;
	Возврат Результат;
КонецФункции

// Параметры:
//  Результат - см. АвтоматическоеПолучениеЭДОКлиент.ВключитьПоУчетнымЗаписямЭДОЗавершение
//  Контекст - Неопределено
&НаКлиенте
Процедура ВключитьПоУчетнымЗаписямЭДОЗавершение(Результат, Контекст = Неопределено) Экспорт
	
	Если ЗначениеЗаполнено(Результат.ИзменениеСостояния) Тогда
		Элементы.Список.Обновить();
	КонецЕсли;
	
	ОбработкаНеисправностейБЭДКлиент.ОбработатьОшибки(Результат.КонтекстДиагностики);
	
КонецПроцедуры

#КонецОбласти