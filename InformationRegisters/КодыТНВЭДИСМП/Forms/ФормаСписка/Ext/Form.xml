		<Attribute name="Классификатор" id="12">
			<Title>
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Классификатор</v8:content>
				</v8:item>
			</Title>
			<Type>
				<v8:Type>cfg:DynamicList</v8:Type>
			</Type>
			<UseAlways>
				<Field>Классификатор.ВидПродукции</Field>
				<Field>Классификатор.Загружен</Field>
				<Field>Классификатор.Код</Field>
				<Field>Классификатор.НаименованиеПолное</Field>
			</UseAlways>
			<Settings xsi:type="DynamicList">
				<ManualQuery>true</ManualQuery>
				<DynamicDataRead>true</DynamicDataRead>
				<QueryText>ВЫБРАТЬ
	ТНВЭДПоВидамПродукцииИС.Код,
	ТНВЭДПоВидамПродукцииИС.КодЧЗ,
	ТНВЭДПоВидамПродукцииИС.Ссылка,
	ТНВЭДПоВидамПродукцииИС.ПометкаУдаления,
	ТНВЭДПоВидамПродукцииИС.ВидПродукции,
	ТНВЭДПоВидамПродукцииИС.НаименованиеПолное,
	ВЫБОР
		КОГДА КодыТНВЭДИСМП.КодТНВЭД ЕСТЬ NULL
			ТОГДА 0
		ИНАЧЕ 1
	КОНЕЦ КАК Загружен
ИЗ
	Справочник.ТНВЭДПоВидамПродукцииИС КАК ТНВЭДПоВидамПродукцииИС
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.КодыТНВЭДИСМП КАК КодыТНВЭДИСМП
		ПО ТНВЭДПоВидамПродукцииИС.Код = КодыТНВЭДИСМП.КодТНВЭД
		И ТНВЭДПоВидамПродукцииИС.ВидПродукции = КодыТНВЭДИСМП.ВидПродукции
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ (ВЫБРАТЬ РАЗЛИЧНЫЕ
			ЗначенияЭлементовКонструктора.ВидПродукции КАК ВидПродукции
		ИЗ
			РегистрСведений.ЗначенияЭлементовКонструктораВидовПродукцииИС КАК ЗначенияЭлементовКонструктора
				ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ЗначенияПользователяЭлементовКонструктораВидовПродукцииИС КАК
					ЗначенияПользователяЭлементовКонструктора
				ПО ЗначенияЭлементовКонструктора.ЭлементКонструктора = ЗначенияПользователяЭлементовКонструктора.ЭлементКонструктора
				И ЗначенияЭлементовКонструктора.ВидПродукции = ЗначенияПользователяЭлементовКонструктора.ВидПродукции
		ГДЕ
			ЗначенияЭлементовКонструктора.ЭлементКонструктора = ЗНАЧЕНИЕ(Справочник.ЭлементыКонструктораВидовПродукцииИС.ВидыПродукцииГИСМТ)
			И ЗначенияПользователяЭлементовКонструктора.ЭлементКонструктора ЕСТЬ NULL

		ОБЪЕДИНИТЬ

		ВЫБРАТЬ
			ЗначенияПользователяЭлементовКонструктора.ВидПродукции
		ИЗ
			РегистрСведений.ЗначенияПользователяЭлементовКонструктораВидовПродукцииИС КАК
				ЗначенияПользователяЭлементовКонструктора
		ГДЕ
			ЗначенияПользователяЭлементовКонструктора.ЭлементКонструктора = ЗНАЧЕНИЕ(Справочник.ЭлементыКонструктораВидовПродукцииИС.ВидыПродукцииГИСМТ)
			И НЕ ЗначенияПользователяЭлементовКонструктора.ПометкаУдаления) КАК ЗначенияВидыПродукции
		ПО ТНВЭДПоВидамПродукцииИС.ВидПродукции = ЗначенияВидыПродукции.ВидПродукции
ГДЕ
	ДЛИНАСТРОКИ(ТНВЭДПоВидамПродукцииИС.Код) = 10
	И ТНВЭДПоВидамПродукцииИС.Статус &lt;&gt; ЗНАЧЕНИЕ(Перечисление.СтатусыКлассификаторовВидовПродукцииИС.Архивный)</QueryText>
				<Field xsi:type="dcssch:DataSetFieldField">
					<dcssch:dataPath>Ссылка</dcssch:dataPath>
					<dcssch:field>Ссылка</dcssch:field>
				</Field>
				<Field xsi:type="dcssch:DataSetFieldField">
					<dcssch:dataPath>ПометкаУдаления</dcssch:dataPath>
					<dcssch:field>ПометкаУдаления</dcssch:field>
				</Field>
				<Field xsi:type="dcssch:DataSetFieldField">
					<dcssch:dataPath>Код</dcssch:dataPath>
					<dcssch:field>Код</dcssch:field>
				</Field>
				<Field xsi:type="dcssch:DataSetFieldField">
					<dcssch:dataPath>ВидПродукции</dcssch:dataPath>
					<dcssch:field>ВидПродукции</dcssch:field>
				</Field>
