// @strict-types

#Область ОбработчикиКомандФормы

&НаКлиенте
Асинх Процедура ЗаполнитьПоУмолчанию(Команда)
	
	ЗаголовокВопроса = НСтр("ru = 'Обновление настроек'");
	ТекстВопроса = НСтр("ru = 'Данные регистра будут очищены. Хотите продолжить?'");
	
	КнопкиВопроса = Новый СписокЗначений; // СписокЗначений из КодВозвратаДиалога
	КнопкиВопроса.Добавить(КодВозвратаДиалога.Да);
	КнопкиВопроса.Добавить(КодВозвратаДиалога.Отмена);
	
	Ответ = Ждать ВопросАсинх(ТекстВопроса, КнопкиВопроса, , , ЗаголовокВопроса); // Обещание
	
	Если Ответ = КодВозвратаДиалога.Да Тогда
		
		ДлительнаяОперация = ПолучитьДанныеНастроекНаСервере();
	
		ОповещениеОЗавершении = Новый ОписаниеОповещения("ПолучитьДанныеНастроекПродолжение", ЭтотОбъект);
		ПараметрыОжидания = ДлительныеОперацииКлиент.ПараметрыОжидания(ЭтотОбъект);
		ПараметрыОжидания.ВыводитьОкноОжидания = Ложь;
	
		ДлительныеОперацииКлиент.ОжидатьЗавершение(ДлительнаяОперация, ОповещениеОЗавершении, ПараметрыОжидания);

	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Функция ПолучитьДанныеНастроекНаСервере()
	
	Возврат МашиночитаемыеДоверенности.СинхронизироватьСопоставленияКлассификатораОграниченийСОбъектамиБЭД(УникальныйИдентификатор);
	
КонецФункции

&НаКлиенте
Процедура ПолучитьДанныеНастроекПродолжение(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат <> Неопределено
		И Результат.Статус = "Выполнено" Тогда
		
		ПолучитьДанныеНастроекЗавершение(Результат.АдресРезультата);
	
	Иначе
		
		ОбщегоНазначенияКлиент.СообщитьПользователю(
			НСтр("ru = 'Ошибка синхронизации. Подробности см. в журнале регистрации.'"));
		
	КонецЕсли;
	
КонецПроцедуры 

&НаСервере
Процедура ПолучитьДанныеНастроекЗавершение(АдресРезультата);
	
	РезультатВыполненияУспех = ПолучитьИзВременногоХранилища(АдресРезультата);
	
	Если РезультатВыполненияУспех Тогда
		
		ОбщегоНазначения.СообщитьПользователю(НСтр("ru = 'Загрузка данных завершена успешно.'"));
		Элементы.Список.Обновить();
		
	Иначе 
		
		ОбщегоНазначения.СообщитьПользователю(
			НСтр("ru = 'Загрузка данных из сервиса настроек не выполнена. Обратитесь в техподдержку.'"));
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти
