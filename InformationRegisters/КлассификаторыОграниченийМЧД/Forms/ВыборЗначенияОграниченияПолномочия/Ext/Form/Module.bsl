// @strict-types

#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	КодОграничения = Параметры.КодОграничения;
		
	ОбновитьТаблицуЗначенийОграничений();
	
	ДоступнаОтметкаНесколькихЗначений = Параметры.ДоступнаОтметкаНесколькихЗначений;
		
	ОтмеченныеЭлементы = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(Параметры, "ОтмеченныеЭлементы", Новый Массив());
	
	Если ДоступнаОтметкаНесколькихЗначений Тогда 
		УстановитьПометкуСтрокТаблицаЗначенийОграничений(ОтмеченныеЭлементы);
	КонецЕсли;
	
	РежимВыделения = Новый Соответствие();
	РежимВыделения.Вставить(Ложь, РежимВыделенияТаблицы.Одиночный);
	РежимВыделения.Вставить(Истина, РежимВыделенияТаблицы.Множественный);
	
	Элементы.ТаблицаЗначенийОграничений.РежимВыделения = РежимВыделения[ДоступнаОтметкаНесколькихЗначений];
	
	Элементы.ТаблицаЗначенийОграниченийПоказыватьТолькоОтмеченные.Видимость = ДоступнаОтметкаНесколькихЗначений;
	Элементы.ТаблицаЗначенийОграниченийПометка.Видимость = ДоступнаОтметкаНесколькихЗначений;
 	
КонецПроцедуры

&НаКлиенте
Процедура ПриЗакрытии(ЗавершениеРаботы)
		
	Если Не ЗакрытиеФормыСВыбором Тогда
		ПараметрыОтбора = Новый Структура("Пометка", Истина);
		ПомеченныеСтроки = ТаблицаЗначенийОграничений.НайтиСтроки(ПараметрыОтбора);
		ОповеститьОВыборе(ПомеченныеСтроки);
	КонецЕсли;

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыТаблицаЗначенийОграничений

&НаКлиенте
Процедура ТаблицаЗначенийОграниченийВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	Если Не ДоступнаОтметкаНесколькихЗначений Тогда
		ВыделенныеСтроки = Новый Массив(); // Массив из ДанныеФормыЭлементКоллекции
			ВыделенныеСтроки.Добавить(ТаблицаЗначенийОграничений.НайтиПоИдентификатору(ВыбраннаяСтрока));
		ЗакрытиеФормыСВыбором = Истина;
		ОповеститьОВыборе(ВыделенныеСтроки);
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура Выбрать(Команда)
	
	Если Элементы.ТаблицаЗначенийОграничений.ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если ДоступнаОтметкаНесколькихЗначений Тогда
		ПараметрыОтбора = Новый Структура("Пометка", Истина);
		ПомеченныеСтроки = ТаблицаЗначенийОграничений.НайтиСтроки(ПараметрыОтбора);
	Иначе
		ПомеченныеСтроки = Новый Массив(); // Массив из ДанныеФормыЭлементКоллекции
		ВыделенныеСтроки = Элементы.ТаблицаЗначенийОграничений.ВыделенныеСтроки;
		Для Каждого ИдентификаторСтроки Из ВыделенныеСтроки Цикл
			ПомеченныеСтроки.Добавить(ТаблицаЗначенийОграничений.НайтиПоИдентификатору(ИдентификаторСтроки));
		КонецЦикла;
	КонецЕсли;
	
	ЗакрытиеФормыСВыбором = Истина;
	ОповеститьОВыборе(ПомеченныеСтроки);
		
КонецПроцедуры
	
&НаКлиенте
Процедура ПоказыватьТолькоОтмеченные(Команда)
	
	Элементы.ТаблицаЗначенийОграниченийПоказыватьТолькоОтмеченные.Пометка = 
		Не Элементы.ТаблицаЗначенийОграниченийПоказыватьТолькоОтмеченные.Пометка;
	
	Отбор = Новый ФиксированнаяСтруктура;
	
	Пометка = Элементы.ТаблицаЗначенийОграниченийПоказыватьТолькоОтмеченные.Пометка;
	Если Пометка Тогда 
		Отбор = Новый ФиксированнаяСтруктура("Пометка", Пометка);
		Элементы.ТаблицаЗначенийОграничений.ОтборСтрок = Отбор;
	КонецЕсли;
	
	Элементы.ТаблицаЗначенийОграничений.ОтборСтрок = Отбор;
		
КонецПроцедуры

&НаКлиенте
Асинх Процедура ОбновитьКлассификатор(Команда)
	
	ЗаголовокВопроса = НСтр("ru = 'Обновление классификаторов'");
	ТекстВопроса = НСтр("ru = 'Данные будут очищены и загружены заново. Хотите продолжить?'");
	
	Кнопки = Новый СписокЗначений; // СписокЗначений из КодВозвратаДиалога
	Кнопки.Добавить(КодВозвратаДиалога.Да);
	Кнопки.Добавить(КодВозвратаДиалога.Отмена);
	
	Ответ = Ждать ВопросАсинх(ТекстВопроса, Кнопки, , , ЗаголовокВопроса); // Обещание
	
	Если Ответ = КодВозвратаДиалога.Да Тогда 
		
		ДлительнаяОперация = ЗагрузитьКлассификаторыОграниченийМЧДНаСервере();
	
		ОповещениеОЗавершении = Новый ОписаниеОповещения("ПолучитьДанныеКлассификаторовПродолжение", ЭтотОбъект);
		ПараметрыОжидания = ДлительныеОперацииКлиент.ПараметрыОжидания(ЭтотОбъект);
		ПараметрыОжидания.ВыводитьОкноОжидания = Ложь;
	
		ДлительныеОперацииКлиент.ОжидатьЗавершение(ДлительнаяОперация, ОповещениеОЗавершении, ПараметрыОжидания);

	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере 
Процедура ОбновитьТаблицуЗначенийОграничений() 

	Таблица = РегистрыСведений.КлассификаторыОграниченийМЧД.КлассификаторЗначенийОграничений();
		
	ТаблицаПоКодуОграничения = Таблица.Скопировать(Новый Структура("КодОграничения", КодОграничения));
	ТаблицаПоКодуОграничения.Сортировать("Наименование");
	ТаблицаЗначенийОграничений.Загрузить(ТаблицаПоКодуОграничения);
	
КонецПроцедуры

&НаСервере
Функция ЗагрузитьКлассификаторыОграниченийМЧДНаСервере()
	
	АдресРезультата = ПоместитьВоВременноеХранилище(Неопределено, УникальныйИдентификатор);
	Возврат МашиночитаемыеДоверенности.ЗагрузитьКлассификаторыОграниченийМЧД(АдресРезультата);
	
КонецФункции

&НаКлиенте
Процедура ПолучитьДанныеКлассификаторовПродолжение(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат <> Неопределено
		И Результат.Статус = "Выполнено" Тогда
		
		ПолучитьДанныеКлассификаторовЗавершение();
			
	Иначе
		
		ОбщегоНазначенияКлиент.СообщитьПользователю(
			НСтр("ru = 'Ошибка обновления данных. Подробности см. в журнале регистрации.'"));
		
	КонецЕсли;
	
КонецПроцедуры 

&НаСервере
Процедура ПолучитьДанныеКлассификаторовЗавершение()
	
	РезультатВыполнения = ПолучитьИзВременногоХранилища(АдресРезультата);
	
	Если РезультатВыполнения <> Неопределено Тогда
		
		ОбщегоНазначения.СообщитьПользователю(НСтр("ru = 'Загрузка данных завершена успешно.'"));
		ОбновитьТаблицуЗначенийОграничений();
		
	Иначе 
		
		ОбщегоНазначения.СообщитьПользователю(
			НСтр("ru = 'Загрузка данных из сервиса настроек не выполнена. Обратитесь в техподдержку.'"));
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура УстановитьПометкуСтрокТаблицаЗначенийОграничений(ОтмеченныеСтроки)
	
	Для Каждого СтрокаСОтметкой Из ОтмеченныеСтроки Цикл
		ПараметрыОтбора = Новый Структура("Код", СтрокаСОтметкой);
		НайденныеСтроки = ТаблицаЗначенийОграничений.НайтиСтроки(ПараметрыОтбора);
		Если НайденныеСтроки.Количество() > 0 Тогда 
			НайденныеСтроки[0].Пометка = Истина;
		КонецЕсли;
	КонецЦикла;
		
КонецПроцедуры

#КонецОбласти

