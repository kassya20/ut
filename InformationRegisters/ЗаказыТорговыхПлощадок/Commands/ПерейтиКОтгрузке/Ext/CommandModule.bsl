// @strict-types

#Область ОбработчикиСобытий

&НаКлиенте
Процедура ОбработкаКоманды(ПараметрКоманды, ПараметрыВыполненияКоманды)

	ОчиститьСообщения();
	
	ПараметрыФормы = ПараметрыФормы(ПараметрыВыполненияКоманды.Источник);
	
	ОткрытьФорму("РегистрСведений.ЗаказыТорговыхПлощадок.Форма.ПодготовкаОтгрузки",
				  ПараметрыФормы,
				  ПараметрыВыполненияКоманды.Источник,
				  ПараметрыВыполненияКоманды.Уникальность,
				  ПараметрыВыполненияКоманды.Окно,
				  ПараметрыВыполненияКоманды.НавигационнаяСсылка);

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Функция ПараметрыФормы(ИсточникКоманды)
	
	ПараметрыФормы = ИнтеграцияСМаркетплейсамиКлиентСервер.НовыеПараметрыОткрытияПодготовкиОтгрузки();
	
	Если ИсточникКоманды.ИмяФормы = "РегистрСведений.ЗаказыТорговыхПлощадок.Форма.ФормаСпискаЗаказов" Тогда
		Форма = ИсточникКоманды; // см. РегистрСведений.ЗаказыТорговыхПлощадок.Форма.ФормаСпискаЗаказов
		ИмяОтбораПоСкладу = "ОтборСкладТорговойПлощадки";
		ИмяТаблицыФормы = "Список";
		ИмяИдентификатораСклада = "ИдентификаторСкладаТорговойПлощадки"; 
		ИмяДатыОтгрузки = "СрокОтгрузки";
		ИмяИдентификатораОтгрузки = "ИдентификаторОтгрузки"; 
		
	ИначеЕсли ИсточникКоманды.ИмяФормы = "РегистрСведений.ЗаказыТорговыхПлощадок.Форма.ПросмотрИЗагрузкаЗаказов" Тогда
		Форма = ИсточникКоманды; // см. РегистрСведений.ЗаказыТорговыхПлощадок.Форма.ПросмотрИЗагрузкаЗаказов
		ИмяОтбораПоСкладу = "ФильтрПоСкладам";
		ИмяТаблицыФормы = "ТаблицаЗаказов";
		ИмяИдентификатораСклада = "ИдентификаторСклада"; 
	Иначе
		Возврат ПараметрыФормы;
	КонецЕсли;
	
	ПараметрыФормы.УчетнаяЗапись = Форма.УчетнаяЗапись;
	
	ЭлементОтборПоСкладу = Форма.Элементы[ИмяОтбораПоСкладу]; // РасширениеПоляФормыДляПоляВвода
	ПараметрыФормы.СписокСкладов = ЭлементОтборПоСкладу.СписокВыбора;
	
	ПараметрыФормы.СписокМетодовДоставки = СписокМетодовДоставкиИзДанныхФормы(Форма);
	ПараметрыФормы.ИдентификаторСклада = ИдентификаторСкладаИзДанныхФормы(
		Форма,
		ИмяОтбораПоСкладу,
		ИмяТаблицыФормы,
		ИмяИдентификатораСклада);  
		
	Если ИсточникКоманды.ИмяФормы = "РегистрСведений.ЗаказыТорговыхПлощадок.Форма.ФормаСпискаЗаказов" Тогда 
		ПараметрыФормы.ДатаОтгрузки = ДатаОтгрузкиИзДанныхФормы(
			Форма,
			ИмяТаблицыФормы,
			ИмяДатыОтгрузки); 
		ПараметрыФормы.ИдентификаторОтгрузки = ИдентификаторОтгрузкиИзДанныхФормы(
			Форма,
			ИмяТаблицыФормы,
			ИмяИдентификатораОтгрузки); 
	КонецЕсли;
	
	Возврат ПараметрыФормы;

КонецФункции

&НаКлиенте
Функция ИдентификаторСкладаИзДанныхФормы(Форма, ИмяОтбораПоСкладу, ИмяТаблицыФормы, ИмяИдентификатораСклада)
	
	Результат = Форма[ИмяОтбораПоСкладу]; // Строка
	
	ТаблицаФормы = Форма.Элементы[ИмяТаблицыФормы];
	Если ТаблицаФормы.ВыделенныеСтроки.Количество() >= 1 Тогда
		ТекущаяСтрока = ТаблицаФормы.ТекущиеДанные;
		Результат = ТекущаяСтрока[ИмяИдентификатораСклада]; // Строка  
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции  

&НаКлиенте
Функция ДатаОтгрузкиИзДанныхФормы(Форма, ИмяТаблицыФормы, ИмяДатыОтгрузки)
		
	ТаблицаФормы = Форма.Элементы[ИмяТаблицыФормы];
	Если ТаблицаФормы.ВыделенныеСтроки.Количество() >= 1 Тогда
		ТекущаяСтрока = ТаблицаФормы.ТекущиеДанные;
		Результат = ТекущаяСтрока[ИмяДатыОтгрузки]; // Строка   		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

&НаКлиенте
Функция ИдентификаторОтгрузкиИзДанныхФормы(Форма, ИмяТаблицыФормы, ИмяИдентификатораОтгрузки)
		
	ТаблицаФормы = Форма.Элементы[ИмяТаблицыФормы];
	Если ТаблицаФормы.ВыделенныеСтроки.Количество() >= 1 Тогда
		ТекущаяСтрока = ТаблицаФормы.ТекущиеДанные;
		Результат = ТекущаяСтрока[ИмяИдентификатораОтгрузки]; // Строка
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции


// Параметры:
//  Форма - ФормаКлиентскогоПриложения
// 
// Возвращаемое значение:
//  Структура:
//   * Ключ - Строка
//   * Значение - см. ИнтеграцияСМаркетплейсамиСервер.НовыйМетодДоставкиСклада
//
&НаКлиенте
Функция СписокМетодовДоставкиИзДанныхФормы(Форма)
	//@skip-check property-return-type
	Возврат Форма.СписокМетодовДоставки;
КонецФункции

#КонецОбласти
