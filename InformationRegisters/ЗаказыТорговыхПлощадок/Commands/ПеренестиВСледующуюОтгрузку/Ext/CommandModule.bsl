// @strict-types

#Область ОбработчикиСобытий

&НаКлиенте
Процедура ОбработкаКоманды(ПараметрКоманды, ПараметрыВыполненияКоманды)
	
	ОчиститьСообщения();
	
	ОжидаемыеСвойства = Новый Структура;
	ОжидаемыеСвойства.Вставить(
		"УчетнаяЗапись",
		ПредопределенноеЗначение("Справочник.УчетныеЗаписиМаркетплейсов.ПустаяСсылка"));
	
	ЗаполнитьЗначенияСвойств(ОжидаемыеСвойства, ПараметрыВыполненияКоманды.Источник);
	
	Если Не ЗначениеЗаполнено(ОжидаемыеСвойства.УчетнаяЗапись) Тогда
		ОбщегоНазначенияКлиент.СообщитьПользователю(
			НСтр("ru = 'Не предусмотрен перенос заказов в следующую отгрузку из этого источника.'"));
		Возврат;
	КонецЕсли;
	
	ПараметрыЗадания = Новый Структура;
	ПараметрыЗадания.Вставить("УчетнаяЗапись", ОжидаемыеСвойства.УчетнаяЗапись);
	ПараметрыЗадания.Вставить("Форма", ПараметрыВыполненияКоманды.Источник);
	
	ПродолжитьВыполнениеКоманды(ПараметрыЗадания);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Процедура ПродолжитьВыполнениеКоманды(Параметры)
	
	Форма = Параметры.Форма;
	УчетнаяЗапись = Параметры.УчетнаяЗапись;
	
	КлючиВыделенныхСтрок = Форма.Элементы.Список.ВыделенныеСтроки;
	ДанныеДляПереноса = ДанныеДляПереносаВСледующуюОтгрузку(КлючиВыделенныхСтрок);
	
	Если ДанныеДляПереноса.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	Если ДанныеДляПереноса.Количество() > 1 Тогда
		ЗадатьВопросПользователю(Форма, УчетнаяЗапись, ДанныеДляПереноса);
	Иначе
		ПродолжитьПереносВСледующуюОтгрузкуПослеВопроса(Форма, УчетнаяЗапись, ДанныеДляПереноса);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Асинх Процедура ЗадатьВопросПользователю(Форма, УчетнаяЗапись, ДанныеДляПереноса)
	
	Ответ = Ждать ВопросАсинх(
		НСтр("ru = 'Выделенные заказы относятся к нескольким отгрузкам. Продолжить перенос заказов?'"),
		РежимДиалогаВопрос.ДаНет,
		60,
		КодВозвратаДиалога.Нет, ,
		КодВозвратаДиалога.Нет); // КодВозвратаДиалога
		
	Если Ответ <> КодВозвратаДиалога.Да Тогда
		Возврат;
	КонецЕсли;
	
	ПродолжитьПереносВСледующуюОтгрузкуПослеВопроса(Форма, УчетнаяЗапись, ДанныеДляПереноса);
	
КонецПроцедуры

&НаКлиенте
Процедура ПродолжитьПереносВСледующуюОтгрузкуПослеВопроса(Форма, УчетнаяЗапись, ДанныеДляПереноса)
	
	ВидМаркетплейса = ПредопределенноеЗначение("Перечисление.ВидыМаркетплейсов.ПустаяСсылка");
	
	ДлительнаяОперация = ЗапуститьПереносВСледующуюОтгрузку(
		ВидМаркетплейса,
		УчетнаяЗапись,
		Форма.УникальныйИдентификатор,
		ДанныеДляПереноса);
	
	ДополнительныеПараметры = ДополнительныеПараметрыПереносаВСледующуюОтгрузку();
	ДополнительныеПараметры.ВидМаркетплейса = ВидМаркетплейса;
	ДополнительныеПараметры.УчетнаяЗапись = УчетнаяЗапись;
	
	ОповещениеОЗавершении = Новый ОписаниеОповещения(
		"ПереносВСледующуюОтгрузкуЗавершение",
		ЭтотОбъект,
		ДополнительныеПараметры);
	
	ПараметрыОжидания = ДлительныеОперацииКлиент.ПараметрыОжидания(Форма);
	ДлительныеОперацииКлиент.ОжидатьЗавершение(ДлительнаяОперация, ОповещениеОЗавершении, ПараметрыОжидания);
	
КонецПроцедуры

&НаКлиенте
Функция ДанныеДляПереносаВСледующуюОтгрузку(ВыделенныеСтроки, Таблица = Неопределено)
	
	Результат = Новый Соответствие;
	Для Каждого ВыделеннаяСтрока Из ВыделенныеСтроки Цикл // РегистрСведенийКлючЗаписи.ЗаказыТорговыхПлощадок
		
		ДанныеСтроки = ИнтеграцияСМаркетплейсамиКлиент.ДанныеОтправленияИзВыделеннойСтрокиТаблицы(
			ВыделеннаяСтрока,
			Таблица);
		
		Если ДанныеСтроки = Неопределено Тогда
			Продолжить;
		ИначеЕсли ПустаяСтрока(ДанныеСтроки.ИдентификаторОтгрузки) Тогда
			Продолжить;
		КонецЕсли;
		
		ИдентификаторыЗаказов = Результат.Получить(ДанныеСтроки.ИдентификаторОтгрузки); // Массив из Строка
		
		Если ИдентификаторыЗаказов = Неопределено Тогда
			Результат.Вставить(ДанныеСтроки.ИдентификаторОтгрузки, Новый Массив);
			ИдентификаторыЗаказов = Результат.Получить(ДанныеСтроки.ИдентификаторОтгрузки);
		КонецЕсли;
		
		ИдентификаторыЗаказов.Добавить(ДанныеСтроки.НомерЗаказа);
	КонецЦикла;
	
	Если Результат.Количество() = 0 Тогда
		ТекстСообщения = НСтр("ru = 'Нет заказов, доступных для переноса в следующую отгрузку.'");
		ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

&НаСервере
Функция ЗапуститьПереносВСледующуюОтгрузку(ВидМаркетплейса, Знач УчетнаяЗапись, Знач УникальныйИдентификатор,
			Знач ДанныеДляПереноса)
	
	ВидМаркетплейса = ИнтеграцияСМаркетплейсамиПовтИсп.ВидМаркетплейсаУчетнойЗаписи(УчетнаяЗапись);
	
	ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияФункции(УникальныйИдентификатор);
	ПараметрыВыполнения.НаименованиеФоновогоЗадания = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
		НСтр("ru = '%1. Перенос заказов в следующую отгрузку.'"),
		ИнтеграцияСМаркетплейсамиКлиентСервер.ПредставлениеВидаТорговойПлощадки(ВидМаркетплейса));
	ПараметрыВыполнения.ОжидатьЗавершение = 0;
	ПараметрыВыполнения.ЗапуститьВФоне = Истина;
	
	ИмяМетода = "РегистрыСведений.ЗаказыТорговыхПлощадок.ПеренестиЗаказыВСледующуюОтгрузку";
	
	Возврат ДлительныеОперации.ВыполнитьФункцию(
		ПараметрыВыполнения,
		ИмяМетода,
		УчетнаяЗапись,
		ДанныеДляПереноса);
	
КонецФункции

// Возвращаемое значение:
//  Структура:
//   * ВидМаркетплейса - ПеречислениеСсылка.ВидыМаркетплейсов
//   * УчетнаяЗапись - СправочникСсылка.УчетныеЗаписиМаркетплейсов
//
&НаКлиенте
Функция ДополнительныеПараметрыПереносаВСледующуюОтгрузку()
	
	Результат = Новый Структура;
	
	Результат.Вставить("ВидМаркетплейса", ПредопределенноеЗначение("Перечисление.ВидыМаркетплейсов.ПустаяСсылка"));
	Результат.Вставить("УчетнаяЗапись", ПредопределенноеЗначение("Справочник.УчетныеЗаписиМаркетплейсов.ПустаяСсылка"));
	
	Возврат Результат;
	
КонецФункции

// Параметры:
//  Результат - см. ДлительныеОперации.ВыполнитьВФоне
//  ДополнительныеПараметры - см. ДополнительныеПараметрыПереносаВСледующуюОтгрузку
//
&НаКлиенте
Процедура ПереносВСледующуюОтгрузкуЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
		
	ИначеЕсли Результат.Статус = "Ошибка" Тогда
		СтандартныеПодсистемыКлиент.ВывестиИнформациюОбОшибке(Результат.ИнформацияОбОшибке);
		Возврат;
	КонецЕсли;
	
	РезультатПереноса = РезультатПереносаВСледующуюОтгрузку(Результат.АдресРезультата);
	
	Логотип = ИнтеграцияСМаркетплейсамиКлиентСервер.ЛоготипТорговойПлощадки(ДополнительныеПараметры.ВидМаркетплейса);
	ИнтеграцияСМаркетплейсамиКлиент.ВывестиСостояние(РезультатПереноса, Неопределено, Истина, Логотип);
	
	Оповестить("МП_ОбновлениеСведенийПоЗаказамИОтправлениям", ДополнительныеПараметры.УчетнаяЗапись);
	
КонецПроцедуры

// Параметры:
//  АдресРезультата - Строка
// 
// Возвращаемое значение:
//  См. ИнтеграцияСМаркетплейсамиСервер.НоваяОшибка
//
&НаСервере
Функция РезультатПереносаВСледующуюОтгрузку(АдресРезультата)
	
	Результат = ПолучитьИзВременногоХранилища(АдресРезультата);
	УдалитьИзВременногоХранилища(АдресРезультата);
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти
