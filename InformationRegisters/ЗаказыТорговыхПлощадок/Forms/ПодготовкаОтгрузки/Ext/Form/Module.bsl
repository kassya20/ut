&НаСервереБезКонтекста
Процедура ПодготовитьПечатьНакладнойАкта(ПечатныеДокументы, ИнформацияОбОтгрузке, ТранспортнаяНакладная, ПолучитьАкт)
	
	НаименованиеФайла = "";  
	ЭтоЯндексМаркет = ИнтеграцияСМаркетплейсамиКлиентСервер.ЭтоЯндексМаркет(ИнформацияОбОтгрузке.ВидМаркетплейса);
	ЭтоOzon = ИнтеграцияСМаркетплейсамиКлиентСервер.ЭтоOzon(ИнформацияОбОтгрузке.ВидМаркетплейса);
	Если ЭтоOzon Тогда
		НаименованиеФайла = НСтр("ru = 'Транспортная накладная или акт'");
		
	ИначеЕсли ЭтоЯндексМаркет Тогда
		Если ПолучитьАкт Тогда
			НаименованиеФайла = НСтр("ru = 'Акт приема-передачи'");
		Иначе
			НаименованиеФайла = НСтр("ru = 'Транспортная накладная'");
		КонецЕсли;
	КонецЕсли;
	
	Адрес = Новый УникальныйИдентификатор();
	
	ДанныеФайла = РегистрыСведений.ЗаказыТорговыхПлощадок.ПолучитьФайлНакладнойАкта(
		ИнформацияОбОтгрузке,
		ТранспортнаяНакладная,
		НаименованиеФайла,
		Адрес,
		ПолучитьАкт);
	
	ПечатныеДокументы.Вставить(НаименованиеФайла, ДанныеФайла);

КонецПроцедуры

