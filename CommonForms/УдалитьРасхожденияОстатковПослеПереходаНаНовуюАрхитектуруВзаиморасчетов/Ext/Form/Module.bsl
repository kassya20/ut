
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ХранилищеОтчета = Константы.УдалитьРасхожденияОстатковПослеПереходаНаНовуюАрхитектуруВзаиморасчетов.Получить();
	Отчет = ХранилищеОтчета.Получить();
	
	Смещать = ТипСмещенияТабличногоДокумента.ПоВертикали;
	КоличествоСтрок = 3;
	Пока КоличествоСтрок > 0 Цикл
		Область = Отчет.Область("R1");
		Отчет.УдалитьОбласть(Область, Смещать);
		КоличествоСтрок = КоличествоСтрок - 1;
	КонецЦикла;
	
	Отчет.ОтображатьСетку = Ложь;
	Отчет.ТолькоПросмотр = Истина;
	Отчет.ФиксацияСверху = 1;
	
	АдресОтчета = ПоместитьВоВременноеХранилище(Отчет, УникальныйИдентификатор);
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	Отказ = Истина;
	Отчет = ПолучитьИзВременногоХранилища(АдресОтчета);
	Отчет.Показать(НСтр("ru = 'Расхождения остатков после перехода на новую архитектуру взаиморасчетов'"));
	
КонецПроцедуры

#КонецОбласти
