#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	УстановитьУсловноеОформление();
	
	Если Параметры.Свойство("АвтоТест") Тогда // Возврат при получении формы для анализа.
		Возврат;
	КонецЕсли;
	
	ИнициализироватьСхемуКомпоновкиДанных();
	ИнициализироватьДанныеФормы();
	ЗаполнитьТаблицуДанныхНаСервере();
	
	ОбщегоНазначенияСобытияФормИСПереопределяемый.ПриСозданииНаСервере(ЭтотОбъект, Отказ, СтандартнаяОбработка);

КонецПроцедуры

&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	Если ИмяСобытия = "Изменение_ИсключенияДляНастройкиНоменклатурыПоТНВЭДиОКПД2ИС"
		И ОтборПоТНВЭДиОКПД2 Тогда
		ЗаполнитьТаблицуДанныхНаСервере();
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура НастройкиОтборПриИзменении(Элемент)
	
	ОтборПоНоменклатуре = ЕстьИспользуемыйЭлементОтбора(НастройкиОтбора.Настройки.Отбор.Элементы);
	
	ЗаполнитьТаблицуДанныхНаСервере();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыТаблицаДанных

&НаКлиенте
Процедура ТаблицаДанныхВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	Если Поле = Элементы.ТаблицаДанныхНоменклатура
		Или Поле = Элементы.ТаблицаДанныхПредставлениеGTIN
		Или Поле = Элементы.ТаблицаДанныхТНВЭД
		Или Поле = Элементы.ТаблицаДанныхОКПД2
		Или Поле = Элементы.ТаблицаДанныхПредставлениеКлючаТекущее Тогда
		СтандартнаяОбработка = Ложь;
		ТекущиеДанные = Элемент.ТекущиеДанные;
		ПоказатьЗначение(, ТекущиеДанные.Номенклатура);
	ИначеЕсли Поле = Элементы.ТаблицаДанныхПредставлениеКлюча Тогда
		Строки = Новый Массив;
		Строки.Добавить(ВыбраннаяСтрока);
		ОткрытьФормуНастройкиИнтеграцииСФГИС(Строки);
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура Записать(Команда)
	
	ОчиститьСообщения();
	ЗаписьДанных();
	Оповестить("НастройкаНоменклатурыПоТНВЭДиОКПД2");
	
КонецПроцедуры

&НаКлиенте
Процедура ДобавитьНоменклатуруВИсключения(Команда)
	
	Строки = Элементы.ТаблицаДанных.ВыделенныеСтроки;
	Если Строки.Количество() > 0 Тогда
		ДобавитьНоменклатуруВИсключенияСервер(Строки);
		Оповестить("НастройкаНоменклатурыПоТНВЭДиОКПД2");
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПоказатьИсключения(Команда)
	
	ОткрытьФорму("РегистрСведений.ИсключенияДляНастройкиНоменклатурыПоТНВЭДиОКПД2ИС.ФормаСписка");
	
КонецПроцедуры

&НаКлиенте
Процедура УстановитьПометку(Команда)
	
	ИзменитьПометкуВыделенныхСтрок(Истина);
	
КонецПроцедуры

&НаКлиенте
Процедура СнятьПометку(Команда)
	
	ИзменитьПометкуВыделенныхСтрок(Ложь);
	
КонецПроцедуры

&НаКлиенте
Процедура ЗапроситьДанныеИзГИСМТ(Команда)
	
	ЗапроситьДанныеИзГИСМТНаКлиенте(Элементы.ТаблицаДанных.ВыделенныеСтроки);
	
КонецПроцедуры

&НаКлиенте
Процедура НастроитьИнтеграциюСФГИС(Команда)
	
	ОткрытьФормуНастройкиИнтеграцииСФГИС(Элементы.ТаблицаДанных.ВыделенныеСтроки);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура УстановитьУсловноеОформление()
	
	УсловноеОформление.Элементы.Очистить();
	
	// ПредставлениеGTIN
	ЭлементУсловногоОформления = УсловноеОформление.Элементы.Добавить();
	
	ПолеЭлемента = ЭлементУсловногоОформления.Поля.Элементы.Добавить();
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(Элементы.ТаблицаДанныхПредставлениеGTIN.Имя);
	
	ОтборЭлемента = ЭлементУсловногоОформления.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ОтборЭлемента.ЛевоеЗначение  = Новый ПолеКомпоновкиДанных(Элементы.ТаблицаДанныхПредставлениеGTIN.ПутьКДанным);
	ОтборЭлемента.ВидСравнения   = ВидСравненияКомпоновкиДанных.Равно;
	ОтборЭлемента.ПравоеЗначение = "";
	
	ЭлементУсловногоОформления.Оформление.УстановитьЗначениеПараметра("Текст", НСтр("ru = 'не указан'"));
	ЭлементУсловногоОформления.Оформление.УстановитьЗначениеПараметра("ЦветТекста", ЦветаСтиля.ЦветТекстаНеТребуетВниманияГосИС);
	
	// ТНВЭД
	ЭлементУсловногоОформления = УсловноеОформление.Элементы.Добавить();
	
	ПолеЭлемента = ЭлементУсловногоОформления.Поля.Элементы.Добавить();
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(Элементы.ТаблицаДанныхТНВЭД.Имя);
	
	ОтборЭлемента = ЭлементУсловногоОформления.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ОтборЭлемента.ЛевоеЗначение  = Новый ПолеКомпоновкиДанных(Элементы.ТаблицаДанныхТНВЭД.ПутьКДанным);
	ОтборЭлемента.ВидСравнения   = ВидСравненияКомпоновкиДанных.Равно;
	ОтборЭлемента.ПравоеЗначение = Справочники.ТНВЭДПоВидамПродукцииИС.ПустаяСсылка();
	
	ЭлементУсловногоОформления.Оформление.УстановитьЗначениеПараметра("Текст", НСтр("ru = 'не указан'"));
	ЭлементУсловногоОформления.Оформление.УстановитьЗначениеПараметра("ЦветТекста", ЦветаСтиля.ЦветТекстаНеТребуетВниманияГосИС);
	
	// ОКПД2
	ЭлементУсловногоОформления = УсловноеОформление.Элементы.Добавить();
	
	ПолеЭлемента = ЭлементУсловногоОформления.Поля.Элементы.Добавить();
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(Элементы.ТаблицаДанныхОКПД2.Имя);
	
	ОтборЭлемента = ЭлементУсловногоОформления.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ОтборЭлемента.ЛевоеЗначение  = Новый ПолеКомпоновкиДанных(Элементы.ТаблицаДанныхОКПД2.ПутьКДанным);
	ОтборЭлемента.ВидСравнения   = ВидСравненияКомпоновкиДанных.Равно;
	ОтборЭлемента.ПравоеЗначение = Справочники.ОКПД2ПоВидамПродукцииИС.ПустаяСсылка();
	
	ЭлементУсловногоОформления.Оформление.УстановитьЗначениеПараметра("Текст", НСтр("ru = 'не указан'"));
	ЭлементУсловногоОформления.Оформление.УстановитьЗначениеПараметра("ЦветТекста", ЦветаСтиля.ЦветТекстаНеТребуетВниманияГосИС);
	
	// ПредставлениеКлючаТекущее
	ЭлементУсловногоОформления = УсловноеОформление.Элементы.Добавить();
	
	ПолеЭлемента = ЭлементУсловногоОформления.Поля.Элементы.Добавить();
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(Элементы.ТаблицаДанныхПредставлениеКлючаТекущее.Имя);
	
	ОтборЭлемента = ЭлементУсловногоОформления.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ОтборЭлемента.ЛевоеЗначение  = Новый ПолеКомпоновкиДанных(Элементы.ТаблицаДанныхПредставлениеКлючаТекущее.ПутьКДанным);
	ОтборЭлемента.ВидСравнения   = ВидСравненияКомпоновкиДанных.Равно;
	ОтборЭлемента.ПравоеЗначение = "";
	
	ЭлементУсловногоОформления.Оформление.УстановитьЗначениеПараметра("Текст", НСтр("ru = 'не используется'"));
	ЭлементУсловногоОформления.Оформление.УстановитьЗначениеПараметра("ЦветТекста", ЦветаСтиля.ЦветТекстаНеТребуетВниманияГосИС);
	
	// ПредставлениеКлюча
	ЭлементУсловногоОформления = УсловноеОформление.Элементы.Добавить();
	
	ПолеЭлемента = ЭлементУсловногоОформления.Поля.Элементы.Добавить();
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(Элементы.ТаблицаДанныхПредставлениеКлюча.Имя);
	
	ОтборЭлемента = ЭлементУсловногоОформления.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ОтборЭлемента.ЛевоеЗначение  = Новый ПолеКомпоновкиДанных(Элементы.ТаблицаДанныхПредставлениеКлюча.ПутьКДанным);
	ОтборЭлемента.ВидСравнения   = ВидСравненияКомпоновкиДанных.Равно;
	ОтборЭлемента.ПравоеЗначение = "";
	
	ОтборЭлемента = ЭлементУсловногоОформления.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ОтборЭлемента.ЛевоеЗначение  = Новый ПолеКомпоновкиДанных("ТаблицаДанных.ЗапроситьИзГИСМТ");
	ОтборЭлемента.ВидСравнения   = ВидСравненияКомпоновкиДанных.Равно;
	ОтборЭлемента.ПравоеЗначение = Истина;
	
	ЭлементУсловногоОформления.Оформление.УстановитьЗначениеПараметра("Текст", НСтр("ru = 'по данным ГИС МТ / вручную'"));
	ЭлементУсловногоОформления.Оформление.УстановитьЗначениеПараметра("ЦветТекста", ЦветаСтиля.ЦветТекстаНеТребуетВниманияГосИС);
	
	//
	ЭлементУсловногоОформления = УсловноеОформление.Элементы.Добавить();
	
	ПолеЭлемента = ЭлементУсловногоОформления.Поля.Элементы.Добавить();
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(Элементы.ТаблицаДанныхПредставлениеКлюча.Имя);
	
	ОтборЭлемента = ЭлементУсловногоОформления.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ОтборЭлемента.ЛевоеЗначение  = Новый ПолеКомпоновкиДанных(Элементы.ТаблицаДанныхПредставлениеКлюча.ПутьКДанным);
	ОтборЭлемента.ВидСравнения   = ВидСравненияКомпоновкиДанных.Равно;
	ОтборЭлемента.ПравоеЗначение = "";
	
	ОтборЭлемента = ЭлементУсловногоОформления.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ОтборЭлемента.ЛевоеЗначение  = Новый ПолеКомпоновкиДанных("ТаблицаДанных.ЗапроситьИзГИСМТ");
	ОтборЭлемента.ВидСравнения   = ВидСравненияКомпоновкиДанных.Равно;
	ОтборЭлемента.ПравоеЗначение = Ложь;
	
	ЭлементУсловногоОформления.Оформление.УстановитьЗначениеПараметра("Текст", НСтр("ru = 'вручную'"));
	ЭлементУсловногоОформления.Оформление.УстановитьЗначениеПараметра("ЦветТекста", ЦветаСтиля.ЦветТекстаНеТребуетВниманияГосИС);
	
	//
	ЭлементУсловногоОформления = УсловноеОформление.Элементы.Добавить();
	
	ПолеЭлемента = ЭлементУсловногоОформления.Поля.Элементы.Добавить();
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(Элементы.ТаблицаДанныхПредставлениеКлюча.Имя);
	
	ОтборГруппа1 = ЭлементУсловногоОформления.Отбор.Элементы.Добавить(Тип("ГруппаЭлементовОтбораКомпоновкиДанных"));
	ОтборГруппа1.ТипГруппы = ТипГруппыЭлементовОтбораКомпоновкиДанных.ГруппаИли;
	
	ОтборГруппа2 = ЭлементУсловногоОформления.Отбор.Элементы.Добавить(Тип("ГруппаЭлементовОтбораКомпоновкиДанных"));
	ОтборГруппа2.ТипГруппы = ТипГруппыЭлементовОтбораКомпоновкиДанных.ГруппаИ;
	
	Для Каждого Суффикс Из КонструкторИСОбщегоНазначенияКлиентСервер.СуффиксыВидовПродукции() Цикл
		
		ОтборЭлемента = ОтборГруппа1.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
		ОтборЭлемента.ЛевоеЗначение  = Новый ПолеКомпоновкиДанных("ТаблицаДанных.ВидПродукции"+Суффикс);
		ОтборЭлемента.ВидСравнения   = ВидСравненияКомпоновкиДанных.НеРавно;
		ОтборЭлемента.ПравоеЗначение = Справочники.ВидыПродукцииИС.ПустаяСсылка();
		
		ОтборЭлемента = ОтборГруппа2.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
		ОтборЭлемента.ЛевоеЗначение  = Новый ПолеКомпоновкиДанных("ТаблицаДанных.ВидПродукции"+Суффикс);
		ОтборЭлемента.ВидСравнения   = ВидСравненияКомпоновкиДанных.Равно;
		ОтборЭлемента.ПравоеЗначение = Новый ПолеКомпоновкиДанных("ТаблицаДанных.ТекущийВидПродукции"+Суффикс);
		
	КонецЦикла;
	
	ЭлементУсловногоОформления.Оформление.УстановитьЗначениеПараметра("Текст", НСтр("ru = 'не требуется'"));
	ЭлементУсловногоОформления.Оформление.УстановитьЗначениеПараметра("ЦветТекста", ЦветаСтиля.ЦветТекстаНеТребуетВниманияГосИС);
	
КонецПроцедуры

&НаСервере
Процедура ИнициализироватьДанныеФормы()
	
	ОтборПоТНВЭДиОКПД2 = Параметры.ОтборПоТНВЭДиОКПД2;
	
	Элементы.ГруппаИсключения.Видимость = ОтборПоТНВЭДиОКПД2;
	
	Если ЗначениеЗаполнено(Параметры.ОтборПоНоменклатуре) Тогда
		ОтборПоНоменклатуре = Истина;
		СписокНоменклатуры = Новый СписокЗначений;
		СписокНоменклатуры.ЗагрузитьЗначения(Параметры.ОтборПоНоменклатуре);
		ЭлементОтбора = НастройкиОтбора.Настройки.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
		ЭлементОтбора.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("Номенклатура");
		ЭлементОтбора.ВидСравнения = ВидСравненияКомпоновкиДанных.ВСписке;
		ЭлементОтбора.ПравоеЗначение = СписокНоменклатуры;
		ЭлементОтбора.Использование = Истина;
	КонецЕсли;
	
	АвтоЗаголовок = Ложь;
	Если ОтборПоТНВЭДиОКПД2 Тогда
		Заголовок = НСтр("ru = 'Настройка интеграции номенклатуры по ТН ВЭД и ОКПД2'");
	Иначе
		Заголовок = НСтр("ru = 'Настройка интеграции номенклатуры с ФГИС'");
	КонецЕсли;
	
	СуффиксыВидовПродукцииСПредставлением = КонструкторИСОбщегоНазначенияКлиентСервер.СуффиксыВидовПродукцииСПредставлением();
	СуффиксПодсистемыМаркировки = КонструкторИСОбщегоНазначенияКлиентСервер.СуффиксПодсистемыМаркировкиДляКлючаВидовПродукции();
	
	Для Каждого Суффикс Из СуффиксыВидовПродукцииСПредставлением Цикл
		Если ОбщегоНазначенияИС.ПодсистемаИспользуется(Суффикс.Значение) Тогда
			ВидыПродукцииПоИмениПодсистемы = КонструкторИСОбщегоНазначенияКлиентСервер.ВидыПродукцииПоИмениПодсистемы(Суффикс.Значение);
			ЭтотОбъект["ИспользуетсяПодсистема"+Суффикс.Значение] = Истина;
			Если Суффикс.Значение = СуффиксПодсистемыМаркировки Тогда
				ПредставлениеПодсистемыГИСМТ = Суффикс.Представление;
			Иначе
				ПодсистемыФГИС.Добавить(Суффикс.Значение, Суффикс.Представление, ВидыПродукцииПоИмениПодсистемы.Количество() = 1);
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	
	Заголовки = Новый Массив;
	Если ИспользуетсяПодсистемаГИСМТ Тогда
		Заголовки.Добавить(ПредставлениеПодсистемыГИСМТ);
	КонецЕсли;
	
	Если ПодсистемыФГИС.Количество() > 0 Тогда
		Заголовки.Добавить(НСтр("ru = 'Интеграция с ФГИС'"));
	КонецЕсли;
	
	Элементы.ГруппаИтеграцияГосИС.Заголовок = СтрСоединить(Заголовки, ", ");
	
	Если Не ИспользуетсяПодсистемаГИСМТ Тогда
		Элементы.ТаблицаДанныхПредставлениеGTIN.Видимость = Ложь;
		Элементы.ЗапроситьДанныеИзГИСМТ.Видимость = Ложь;
		Элементы.ТаблицаДанныхКонтекстноеМенюЗапроситьДанныеИзГИСМТ.Видимость = Ложь;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьТаблицуДанныхНаСервере()
	
	ТаблицаДанных.Очистить();
	
	Запрос = Новый Запрос;
	
	Если ОтборПоНоменклатуре Тогда
		ТаблицаНоменклатуры = НоменклатураОтбора();
		Запрос.УстановитьПараметр("ТаблицаНоменклатуры", ТаблицаНоменклатуры);
	Иначе
		ТаблицаНоменклатуры = Неопределено;
	КонецЕсли;
	
	Если Не ОтборПоТНВЭДиОКПД2
		И (Не ОтборПоНоменклатуре Или ТаблицаНоменклатуры.Количество() = 0) Тогда
		Возврат;
	КонецЕсли;
	
	Запрос.Текст = ИнтеграцияИС.ТекстЗапросаТНВЭДиОКПД2Номенклатуры(ОтборПоТНВЭДиОКПД2, ТаблицаНоменклатуры);
	
	ТекущаяНоменклатура = Неопределено;
	Строка = Неопределено;
	
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		Если Выборка.Номенклатура <> ТекущаяНоменклатура Тогда
			ТекущаяНоменклатура = Выборка.Номенклатура;
			Строка = ТаблицаДанных.Добавить();
			ЗаполнитьЗначенияСвойств(Строка, Выборка);
		КонецЕсли;
		Если Строка.ДоступныеВидыПродукцииГИСМТ.Количество() = 0
			Или Не Строка.ДоступныеВидыПродукцииГИСМТ[0].Пометка Тогда
			Если Выборка.ТНВЭДСоответствуетОКПД2 Тогда
				Строка.ДоступныеВидыПродукцииГИСМТ.Очистить();
			КонецЕсли;
			Если ЗначениеЗаполнено(Выборка.ВидПродукцииПоТНВЭД)
				И Строка.ДоступныеВидыПродукцииГИСМТ.НайтиПоЗначению(Выборка.ВидПродукцииПоТНВЭД) = Неопределено Тогда
				ДобавленныйЭлемент = Строка.ДоступныеВидыПродукцииГИСМТ.Добавить(Выборка.ВидПродукцииПоТНВЭД);
				ДобавленныйЭлемент.Пометка = Выборка.ТНВЭДСоответствуетОКПД2;
			КонецЕсли;
			Если ЗначениеЗаполнено(Выборка.ВидПродукцииПоОКПД2)
				И Строка.ДоступныеВидыПродукцииГИСМТ.НайтиПоЗначению(Выборка.ВидПродукцииПоОКПД2) = Неопределено Тогда
				ДобавленныйЭлемент = Строка.ДоступныеВидыПродукцииГИСМТ.Добавить(Выборка.ВидПродукцииПоОКПД2);
				ДобавленныйЭлемент.Пометка = Выборка.ТНВЭДСоответствуетОКПД2;
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	
	ДополнитьДанныеТаблицы();
	
	Если ОтборПоТНВЭДиОКПД2 Тогда
		ОбновитьЗаписьПроблем(ТаблицаДанных.Количество() > 0);
	КонецЕсли;
	
КонецПроцедуры
	
&НаСервере
Процедура ДополнитьДанныеТаблицы()
	
	ДанныеПоGTIN = ДанныеПоGTIN();
	КэшЗависимыхВидовПродукции = Новый Соответствие;
	
	Для Каждого Строка Из ТаблицаДанных Цикл
		
		МассивGTIN = ДанныеПоGTIN[Строка.Номенклатура];
		Если МассивGTIN <> Неопределено Тогда
			Строка.GTIN.ЗагрузитьЗначения(МассивGTIN);
			Строка.ПредставлениеGTIN = ПредставлениеМассиваДанных(МассивGTIN);
		КонецЕсли;
		
		ЗаполнитьДанныеВСтроке(Строка, КэшЗависимыхВидовПродукции);
		
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Функция ДанныеПоGTIN()
	
	Результат = Новый Соответствие;
	
	Если ИспользуетсяПодсистемаГИСМТ Тогда
		
		ТаблицаНоменклатуры = ТаблицаДанных.Выгрузить(, "Номенклатура");
		ТаблицаНоменклатуры.Колонки.Добавить("Характеристика", Метаданные.ОпределяемыеТипы.ХарактеристикаНоменклатуры.Тип);
		
		ПроверяемыеGTIN = Новый Массив;
		СоответствиеGTIN = Новый Соответствие;
		
		ШтрихкодированиеОбщегоНазначенияИС.ЗаполнитьПроверяемыеGTIN(
			ТаблицаНоменклатуры, ПроверяемыеGTIN, СоответствиеGTIN, Ложь, Ложь);
		
		Для Каждого КлючИЗначение Из СоответствиеGTIN Цикл
			Номенклатура = КлючИЗначение.Значение.Номенклатура;
			Если Результат[Номенклатура] = Неопределено Тогда
				Результат.Вставить(Номенклатура, Новый Массив);
			КонецЕсли;
			Результат[Номенклатура].Добавить(КлючИЗначение.Ключ);
		КонецЦикла;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

&НаСервере
Процедура ЗаполнитьДанныеВСтроке(Строка, КэшЗависимыхВидовПродукции)
	
	Если ИспользуетсяПодсистемаГИСМТ Тогда
		Если Строка.ДоступныеВидыПродукцииГИСМТ.Количество() = 1 Тогда
			Строка.ВидПродукцииГИСМТ = Строка.ДоступныеВидыПродукцииГИСМТ[0].Значение;
			ПриЗаполненииВидаПродукцииГИСМТ(Строка, КэшЗависимыхВидовПродукции);
			Если ЗначениеЗаполнено(Строка.ВидПродукцииГИСМТ)
				И Не ЗначениеЗаполнено(Строка.ТекущийКлючВидовПродукции) Тогда
				Строка.Пометка = Истина;
			КонецЕсли;
		КонецЕсли;
		Если Не ЗначениеЗаполнено(Строка.ВидПродукцииГИСМТ)
			И Строка.GTIN.Количество() > 0 Тогда
			Строка.ЗапроситьИзГИСМТ = Истина;
		КонецЕсли;
	КонецЕсли;
	
	Строка.ПредставлениеКлючаТекущее = ПредставлениеКлюча(ЭтотОбъект, Строка, "Текущий");
	Строка.ПредставлениеКлюча = ПредставлениеКлюча(ЭтотОбъект, Строка);
	
КонецПроцедуры

&НаСервере
Процедура ПриЗаполненииВидаПродукцииГИСМТ(Строка, КэшЗависимыхВидовПродукции, ПодлежитВетеринарномуКонтролю = Неопределено)
	
	ДанныеКэша = КэшЗависимыхВидовПродукции[Строка.ВидПродукцииГИСМТ];
	Если ДанныеКэша <> Неопределено Тогда
		ЗаполнитьЗначенияСвойств(Строка, ДанныеКэша);
		Возврат;
	КонецЕсли;
	
	ДанныеКэша = Новый Структура;
	
	СуффиксПодсистемыМаркировки = КонструкторИСОбщегоНазначенияКлиентСервер.СуффиксПодсистемыМаркировкиДляКлючаВидовПродукции();
	СуффиксПодсистемыВетИС = КонструкторИСОбщегоНазначенияКлиентСервер.СуффиксПодсистемыМеркурийДляКлючаВидовПродукции();
	
	ЗависимыеВидыПродукции = ИнтеграцияИСКлиентСервер.ЗависимыеВидыПродукции(Строка, СуффиксПодсистемыМаркировки)[СуффиксПодсистемыМаркировки];
	
	Если ЗависимыеВидыПродукции.Количество() > 0 Тогда
		
		ДоступныеПодсистемы = Новый Массив;
		
		Если ЗависимыеВидыПродукции <> Неопределено Тогда
			Для Каждого КлючИЗначение Из ЗависимыеВидыПродукции Цикл
				Если ПодсистемыФГИС.НайтиПоЗначению(КлючИЗначение.Ключ) <> Неопределено Тогда
					ДоступныеПодсистемы.Добавить(КлючИЗначение.Ключ);
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;
		
		Для Каждого ПодсистемаФГИС Из ПодсистемыФГИС Цикл
			Суффикс = ПодсистемаФГИС.Значение;
			ВидПродукцииИмяЭлемента = "ВидПродукции"+Суффикс;
			Если ДоступныеПодсистемы.Найти(Суффикс) <> Неопределено
				И ЗависимыеВидыПродукции[Суффикс] <> Неопределено Тогда
				Если ЗначениеЗаполнено(ЗависимыеВидыПродукции[Суффикс].Значение) Тогда
					Строка[ВидПродукцииИмяЭлемента] = ЗависимыеВидыПродукции[Суффикс].Значение;
				ИначеЕсли ЗависимыеВидыПродукции[Суффикс].Обязательный
					Или ИспользуетсяПодсистемаВЕТИС
						И ПодлежитВетеринарномуКонтролю <> Неопределено
						И Суффикс = СуффиксПодсистемыВетИС Тогда
					ВидыПродукцииПоИмениПодсистемы = КонструкторИСОбщегоНазначенияКлиентСервер.ВидыПродукцииПоИмениПодсистемы(Суффикс);
					Если ВидыПродукцииПоИмениПодсистемы.Количество() = 1 Тогда
						Строка[ВидПродукцииИмяЭлемента] = ВидыПродукцииПоИмениПодсистемы[0];
					КонецЕсли;
				КонецЕсли;
				Если ЗначениеЗаполнено(Строка[ВидПродукцииИмяЭлемента]) Тогда
					ДанныеКэша.Вставить(ВидПродукцииИмяЭлемента, Строка[ВидПродукцииИмяЭлемента]);
				КонецЕсли;
			КонецЕсли;
		КонецЦикла;
		
		Если ДоступныеПодсистемы.Количество() > 0
			И ДанныеКэша.Количество() = 0 Тогда
			Строка.ВидПродукцииГИСМТ = Неопределено;
			ДанныеКэша.Вставить("ВидПродукцииГИСМТ", Неопределено);
		КонецЕсли;
		
	КонецЕсли;
	
	Если ПодлежитВетеринарномуКонтролю = Неопределено Тогда
		КэшЗависимыхВидовПродукции.Вставить(Строка.ВидПродукцииГИСМТ, ДанныеКэша);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Функция ПредставлениеКлюча(Форма, ДанныеСтроки, Префикс = "")
	
	МассивПредставлений = Новый Массив;
	
	Если Форма.ИспользуетсяПодсистемаГИСМТ Тогда
		ИмяРеквизита = СтрШаблон("%1ВидПродукции%2",
			Префикс,
			КонструкторИСОбщегоНазначенияКлиентСервер.СуффиксПодсистемыМаркировкиДляКлючаВидовПродукции());
		Если ЗначениеЗаполнено(ДанныеСтроки[ИмяРеквизита]) Тогда
			МассивПредставлений.Добавить(Строка(ДанныеСтроки[ИмяРеквизита]));
		КонецЕсли;
	КонецЕсли;
	
	Для Каждого ДанныеПодсистемыФГИС Из Форма.ПодсистемыФГИС Цикл
		ИмяРеквизита = СтрШаблон("%1ВидПродукции%2", Префикс, ДанныеПодсистемыФГИС.Значение);
		Если ЗначениеЗаполнено(ДанныеСтроки[ИмяРеквизита]) Тогда
			Если ДанныеПодсистемыФГИС.Пометка Тогда
				МассивПредставлений.Добавить(ДанныеПодсистемыФГИС.Представление);
			Иначе
				МассивПредставлений.Добавить(СтрШаблон("%1 (%2)",
					ДанныеПодсистемыФГИС.Представление,
					Строка(ДанныеСтроки[ИмяРеквизита])));
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	
	Если МассивПредставлений.Количество() = 0 Тогда
		Представление = "";
	Иначе
		Представление = СтрСоединить(МассивПредставлений, ", ");
	КонецЕсли;
	
	Возврат Представление;
	
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Функция ПредставлениеМассиваДанных(МассивДанных, ДлинаПоля = 50)
	
	КоличествоДанных = МассивДанных.Количество();

	Если КоличествоДанных = 0 Тогда
		Возврат "";
	КонецЕсли;
	
	Разделитель            = ", ";
	ТекстОкончанияЭлемента = "...";
	ДлинаОкончанияЭлемента = СтрДлина(ТекстОкончанияЭлемента);
	ТекстОкончанияСтроки   = НСтр("ru = ' ( + еще %1 )'");
	ДлинаОкончанияСтроки   = СтрДлина(ТекстОкончанияСтроки);
	МаксимальнаяДлина      = ДлинаПоля - ДлинаОкончанияСтроки;
	Представление          = "";
	ПредставлениеДлина     = 0;
	КоличествоДобавлено    = 0;
	
	Для Каждого Элемент Из МассивДанных Цикл
		
		ТекущееПредставление = СокрЛП(Элемент);
		Если КоличествоДобавлено > 0 Тогда
			ТекущееПредставление = Разделитель + ТекущееПредставление;
		КонецЕсли;
			
		ПредставлениеДлина = ПредставлениеДлина + СтрДлина(ТекущееПредставление);
		
		Если КоличествоДанных = КоличествоДобавлено + 1 Тогда
			МаксимальнаяДлина = МаксимальнаяДлина + ДлинаОкончанияСтроки;
		КонецЕсли;
		
		Если ПредставлениеДлина > МаксимальнаяДлина Тогда
			
			Если КоличествоДобавлено = 0 Тогда
				Представление = Лев(ТекущееПредставление,
					МаксимальнаяДлина - ДлинаОкончанияЭлемента) + ТекстОкончанияЭлемента;
				КоличествоДобавлено = КоличествоДобавлено + 1;
			КонецЕсли;
			
			Если КоличествоДанных > 1 Тогда
				Представление = Представление + СтрШаблон(
					ТекстОкончанияСтроки, КоличествоДанных - КоличествоДобавлено);
			КонецЕсли;
		
			Прервать;
			
		КонецЕсли;
		
		Представление = Представление + ТекущееПредставление;
		
		КоличествоДобавлено = КоличествоДобавлено + 1;
		
	КонецЦикла;
	
	Возврат Представление;
	
КонецФункции

&НаСервере
Процедура ДобавитьНоменклатуруВИсключенияСервер(Строки)
	
	Для Каждого Строка Из Строки Цикл
		СтрокаТаблицы = ТаблицаДанных.НайтиПоИдентификатору(Строка);
		Запись = РегистрыСведений.ИсключенияДляНастройкиНоменклатурыПоТНВЭДиОКПД2ИС.СоздатьМенеджерЗаписи();
		Запись.Номенклатура = СтрокаТаблицы.Номенклатура;
		Запись.Записать();
		ТаблицаДанных.Удалить(СтрокаТаблицы);
	КонецЦикла;
	
	ОбновитьЗаписьПроблем(ТаблицаДанных.Количество() > 0);
	
КонецПроцедуры

&НаСервереБезКонтекста
Процедура ОбновитьЗаписьПроблем(ЕстьПроблема)
	
	Если Не ОбщегоНазначенияИС.ПодсистемаСуществует("ИСМП") Тогда
		Возврат;
	КонецЕсли;
	
	МодульИСМП = ОбщегоНазначения.ОбщийМодуль("ИнтеграцияИСМП");
	
	МодульИСМП.ОбновитьЗаписьПроблем(ЕстьПроблема, "НастройкаНоменклатурыПоТНВЭДиОКПД2");
	
КонецПроцедуры

&НаКлиенте
Процедура ИзменитьПометкуВыделенныхСтрок(Пометка)
	
	Строки = Элементы.ТаблицаДанных.ВыделенныеСтроки;
	
	Для Каждого Строка Из Строки Цикл
		ДанныеСтроки = ТаблицаДанных.НайтиПоИдентификатору(Строка);
		ДанныеСтроки.Пометка = Пометка;
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьФормуНастройкиИнтеграцииСФГИС(Строки)
	
	Если Строки.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	ПараметрыОткрытияФормы = Новый Структура;
	Если ОтборПоТНВЭДиОКПД2 Тогда
		ТекущиеДанныеКлюча = Новый Структура(СтрСоединить(КонструкторИСОбщегоНазначенияКлиентСервер.ИменаПолейКлючаВидовПродукции(), ","));
		ЗаполнитьЗначенияСвойств(ТекущиеДанныеКлюча, ТаблицаДанных.НайтиПоИдентификатору(Строки[0]));
		ПараметрыОткрытияФормы.Вставить("ТекущиеДанныеКлюча",          ТекущиеДанныеКлюча);
		ПараметрыОткрытияФормы.Вставить("ДоступныеВидыПродукцииГИСМТ", ДоступныеВидыПродукцииГИСМТ(Строки));
	КонецЕсли;
	
	ДополнительныеПараметры = Новый Структура;
	ДополнительныеПараметры.Вставить("Строки", Строки);
	
	ОткрытьФорму("ОбщаяФорма.НастройкаИнтеграцииИС",
		ПараметрыОткрытияФормы,,,,,
		Новый ОписаниеОповещения("НастройкаИнтеграцииСФГИСЗавершение", ЭтотОбъект, ДополнительныеПараметры),
		РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	
КонецПроцедуры

&НаКлиенте
Функция ДоступныеВидыПродукцииГИСМТ(Строки)
	
	Результат = Новый Массив;
	
	Для Каждого Строка Из Строки Цикл
		ДанныеСтроки = ТаблицаДанных.НайтиПоИдентификатору(Строка);
		Для Каждого ЭлементСписка Из ДанныеСтроки.ДоступныеВидыПродукцииГИСМТ Цикл
			Если ЗначениеЗаполнено(ЭлементСписка.Значение)
				И Результат.Найти(ЭлементСписка.Значение) = Неопределено Тогда
				Результат.Добавить(ЭлементСписка.Значение);
			КонецЕсли;
		КонецЦикла;
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

&НаКлиенте
Процедура НастройкаИнтеграцииСФГИСЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат <> Неопределено Тогда
		Для Каждого Строка Из ДополнительныеПараметры.Строки Цикл
			ДанныеСтроки = ТаблицаДанных.НайтиПоИдентификатору(Строка);
			ЗаполнитьЗначенияСвойств(ДанныеСтроки, Результат);
			ДанныеСтроки.ПредставлениеКлюча = ПредставлениеКлюча(ЭтотОбъект, ДанныеСтроки);
			ДанныеСтроки.Пометка = ЗначенияВидовПродукцииИзменились(ДанныеСтроки);
		КонецЦикла;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Функция ЗначенияВидовПродукцииИзменились(ДанныеСтроки)
	
	Для Каждого Суффикс Из КонструкторИСОбщегоНазначенияКлиентСервер.СуффиксыВидовПродукции() Цикл
		Если ДанныеСтроки["ВидПродукции"+Суффикс] <> ДанныеСтроки["ТекущийВидПродукции"+Суффикс] Тогда
			Возврат Истина;
		КонецЕсли;
	КонецЦикла;
	
	Возврат Ложь;
	
КонецФункции

&НаКлиенте
Процедура ЗапроситьДанныеИзГИСМТНаКлиенте(Строки)
	
	ОчиститьСообщения();
	
	ДанныеGTIN = Новый Соответствие;
	
	Для Каждого Строка Из Строки Цикл
		ДанныеСтроки = ТаблицаДанных.НайтиПоИдентификатору(Строка);
		Если ДанныеСтроки.GTIN.Количество() = 0 Тогда
			ОбщегоНазначенияКлиент.СообщитьПользователю(
				СтрШаблон(
					НСтр("ru = 'По номенклатуре ""%1"" запрос данных невозможен, т.к. не указан GTIN. Строка пропущена.'"),
					ДанныеСтроки.Номенклатура));
		ИначеЕсли ДанныеСтроки.ЗапроситьИзГИСМТ Тогда
			Для Каждого ЭлементСписка Из ДанныеСтроки.GTIN Цикл
				ДанныеGTIN.Вставить(ЭлементСписка.Значение, Строка);
			КонецЦикла;
		Иначе
			ОбщегоНазначенияКлиент.СообщитьПользователю(
				СтрШаблон(
					НСтр("ru = 'По номенклатуре ""%1"" запрос данных не требуется. Строка пропущена.'"),
					ДанныеСтроки.Номенклатура));
		КонецЕсли;
	КонецЦикла;
	
	Если ДанныеGTIN.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Организация) Тогда
		ЗапроситьДанныеИзГИСМТПоОрганизации(ДанныеGTIN);
	Иначе
		ДоступныеОрганизации = ДоступныеОрганизации();
		Если ДоступныеОрганизации.Количество() = 0 Тогда
			ПоказатьПредупреждение(,
				НСтр("ru = 'Отсутствуют организации по которым возможно обращение в ФГИС ""Честный знак""'"));
		ИначеЕсли ДоступныеОрганизации.Количество() = 1 Тогда
			Организация = ДоступныеОрганизации[0].Значение;
			ЗапроситьДанныеИзГИСМТПоОрганизации(ДанныеGTIN);
		Иначе
			ДополнительныеПараметры = Новый Структура;
			ДополнительныеПараметры.Вставить("ДанныеGTIN", ДанныеGTIN);
			ДоступныеОрганизации.ПоказатьВыборЭлемента(
				Новый ОписаниеОповещения(
					"ВыборОрганизацииЗавершение",
					ЭтотОбъект,
					ДополнительныеПараметры),
				НСтр("ru = 'Выберите организацию'"));
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ВыборОрганизацииЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат <> Неопределено Тогда
		Организация = Результат.Значение;
		ЗапроситьДанныеИзГИСМТПоОрганизации(ДополнительныеПараметры.ДанныеGTIN);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ЗапроситьДанныеИзГИСМТПоОрганизации(ДанныеGTIN)
	
	РезультатЗагрузки = ЗапроситьДанныеИзГИСМТНаСервере(ДанныеGTIN);
	
	Если РезультатЗагрузки.ТребуетсяОбновлениеКлючаСессии Тогда
		
		ДополнительныеПараметры = Новый Структура;
		ДополнительныеПараметры.Вставить("ДанныеGTIN", ДанныеGTIN);
		
		ПараметрыАвторизации = ИнтерфейсИСМПОбщегоНазначенияКлиент.ПараметрыЗапросаДанных();
		ПараметрыАвторизации.Организация           = Организация;
		ПараметрыАвторизации.ОповещениеОЗавершении = Новый ОписаниеОповещения(
			"ЗапроситьКлючСессииЗавершение",
			ЭтотОбъект,
			ДополнительныеПараметры);
		
		ИнтерфейсИСМПОбщегоНазначенияКлиент.ВыполнитьАвторизациюГИСМТ(ПараметрыАвторизации);
		
	ИначеЕсли ЗначениеЗаполнено(РезультатЗагрузки.ТекстОшибки) Тогда
		
		ОбщегоНазначенияКлиент.СообщитьПользователю(РезультатЗагрузки.ТекстОшибки);
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ЗапроситьКлючСессииЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	Если ИнтерфейсИСМПОбщегоНазначенияКлиент.АвторизацияГИСМТВыполненаСОшибкой(Результат) Тогда
		Возврат;
	КонецЕсли;
	
	РезультатЗапросаДанных = ЗапроситьДанныеИзГИСМТНаСервере(ДополнительныеПараметры.ДанныеGTIN);
	
	Если РезультатЗапросаДанных.ТребуетсяОбновлениеКлючаСессии Тогда
		ОбщегоНазначенияКлиент.СообщитьПользователю(НСтр("ru = 'Не удалось выполнить подключение к сервису'"));
	ИначеЕсли ЗначениеЗаполнено(РезультатЗапросаДанных.ТекстОшибки) Тогда
		ОбщегоНазначенияКлиент.СообщитьПользователю(РезультатЗапросаДанных.ТекстОшибки);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция ЗапроситьДанныеИзГИСМТНаСервере(ДанныеGTIN)
	
	ВозвращаемоеЗначение = Новый Структура;
	ВозвращаемоеЗначение.Вставить("ТребуетсяОбновлениеКлючаСессии", Ложь);
	ВозвращаемоеЗначение.Вставить("ТекстОшибки", "");
	
	МассивGTIN = Новый Массив;
	Для Каждого КлючИЗначение Из ДанныеGTIN Цикл
		МассивGTIN.Добавить(КлючИЗначение.Ключ);
	КонецЦикла;
	
	РезультатПроверки = ИнтерфейсИСМПОбщегоНазначения.ДанныеПродукцииПоШтрихкодуEAN(МассивGTIN);
	
	Если РезультатПроверки.ТребуетсяОбновлениеКлючаСессии Тогда
		ВозвращаемоеЗначение.ТребуетсяОбновлениеКлючаСессии = Истина;
		Возврат ВозвращаемоеЗначение;
	ИначеЕсли ЗначениеЗаполнено(РезультатПроверки.ТекстОшибки) Тогда
		ВозвращаемоеЗначение.ТекстОшибки = РезультатПроверки.ТекстОшибки;
		Возврат ВозвращаемоеЗначение;
	КонецЕсли;
	
	ОбработатьПолученныеДанныеИзГИСМТ(ДанныеGTIN, РезультатПроверки.ДанныеПродукцииПоШтрихкодуEAN);
	
	Возврат ВозвращаемоеЗначение;
	
КонецФункции

&НаСервере
Процедура ОбработатьПолученныеДанныеИзГИСМТ(ДанныеGTIN, ДанныеГИСМТ)
	
	КэшЗависимыхВидовПродукции = Новый Соответствие;
	
	Для Каждого ЭлементГИСМТ Из ДанныеГИСМТ Цикл
		
		ДанныеЭлементаGTIN = ДанныеGTIN[ЭлементГИСМТ.Ключ];
		Если ДанныеЭлементаGTIN = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		ДанныеСтроки = ТаблицаДанных.НайтиПоИдентификатору(ДанныеЭлементаGTIN);
		Если ДанныеСтроки.ЗапроситьИзГИСМТ Тогда
			
			ДанныеЭлементаГИСМТ = ЭлементГИСМТ.Значение;
			Если ЗначениеЗаполнено(ДанныеЭлементаГИСМТ.ВидПродукции) Тогда
				ДанныеСтроки.ВидПродукцииГИСМТ = ДанныеЭлементаГИСМТ.ВидПродукции;
				ПриЗаполненииВидаПродукцииГИСМТ(ДанныеСтроки, КэшЗависимыхВидовПродукции, ДанныеЭлементаГИСМТ.ПодлежитВетеринарномуКонтролю);
				ДанныеСтроки.ЗапроситьИзГИСМТ = Ложь;
				ДанныеСтроки.Пометка = ЗначенияВидовПродукцииИзменились(ДанныеСтроки);
				ДанныеСтроки.ПредставлениеКлюча = ПредставлениеКлюча(ЭтотОбъект, ДанныеСтроки);
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЦикла;
	
	Для Каждого ЭлементGTIN Из ДанныеGTIN Цикл
		ДанныеСтроки = ТаблицаДанных.НайтиПоИдентификатору(ЭлементGTIN.Значение);
		ДанныеСтроки.ЗапроситьИзГИСМТ = Ложь;
	КонецЦикла;
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ДоступныеОрганизации()
	
	Возврат ОбщегоНазначенияИС.ДоступныеОрганизации();
	
КонецФункции

#Область СхемаКомпоновкиДанных

&НаСервере
Процедура ИнициализироватьСхемуКомпоновкиДанных()
	
	СхемаКомпоновкиДанных = ПолучитьСхемуКомпоновкиДанныхОтбораНоменклатуры();
	
	АдресСхемыКомпоновкиДанных = ПоместитьВоВременноеХранилище(СхемаКомпоновкиДанных, Новый УникальныйИдентификатор);
	
	ИсточникНастроек = Новый ИсточникДоступныхНастроекКомпоновкиДанных(АдресСхемыКомпоновкиДанных);
	
	НастройкиОтбора.Инициализировать(ИсточникНастроек);
	
	Настройки = Новый ХранилищеЗначения(НастройкиОтбора.ПолучитьНастройки());
	НастройкиОтбора.ЗагрузитьНастройки(Настройки.Получить());
	
КонецПроцедуры

&НаСервере
Функция ПолучитьСхемуКомпоновкиДанныхОтбораНоменклатуры()
	
	СхемаКомпоновкиДанных = Новый СхемаКомпоновкиДанных;
	ИсточникДанных = СхемаКомпоновкиДанных.ИсточникиДанных.Добавить();
	ИсточникДанных.Имя = "ИсточникДанных";
	ИсточникДанных.ТипИсточникаДанных = "Local";
	
	НаборДанных = СхемаКомпоновкиДанных.НаборыДанных.Добавить(Тип("НаборДанныхЗапросСхемыКомпоновкиДанных"));
	НаборДанных.ИсточникДанных = "ИсточникДанных";
	НаборДанных.Имя = "НаборДанных";
	НаборДанных.АвтоЗаполнениеДоступныхПолей = Истина;
	НаборДанных.Запрос = ТекстЗапросаОтбораНоменклатуры();
	
	Возврат СхемаКомпоновкиДанных;
	
КонецФункции

&НаСервереБезКонтекста
Функция ТекстЗапросаОтбораНоменклатуры()
	
	МассивТипов = Новый Массив;
	Для Каждого Тип Из Метаданные.ОпределяемыеТипы.Номенклатура.Тип.Типы() Цикл
		ОбъектМетаданных = Метаданные.НайтиПоТипу(Тип);
		Если ОбъектМетаданных <> Неопределено
			И Метаданные.Справочники.Содержит(ОбъектМетаданных) Тогда
			МассивТипов.Добавить(ОбъектМетаданных.ПолноеИмя());
		КонецЕсли;
	КонецЦикла;
	
	Если МассивТипов.Количество() = 0 Тогда
		ТекстЗапроса =
		"ВЫБРАТЬ
		|	"""" КАК Номенклатура
		|{ГДЕ
		|	"""" КАК Номенклатура}";
	Иначе
		
		ИменаПолейКлюча = Новый Массив;
		Для Каждого ИмяПоляКлюча Из КонструкторИСОбщегоНазначенияКлиентСервер.ИменаПолейКлючаВидовПродукции() Цикл
			ИменаПолейКлюча.Добавить(СтрШаблон(
				"РегистрОписаниеНоменклатуры.КлючВидовПродукции.%1 КАК %1",
				ИмяПоляКлюча));
		КонецЦикла;
		УсловиеПоКлючуВидовПродукции = СтрСоединить(ИменаПолейКлюча, ",");
		
		ТекстЗапроса = "";
		Для Каждого Тип Из МассивТипов Цикл
			Если ТекстЗапроса <> "" Тогда
				ТекстЗапроса = ТекстЗапроса +
				"
				|
				|ОБЪЕДИНИТЬ ВСЕ
				|";
			КонецЕсли;
			ТекстЗапроса = ТекстЗапроса + СтрШаблон(
			"ВЫБРАТЬ
			|	СправочникНоменклатура.Ссылка КАК Номенклатура
			|ИЗ
			|	%1 КАК СправочникНоменклатура
			|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ОписаниеНоменклатурыИС КАК РегистрОписаниеНоменклатуры
			|		ПО СправочникНоменклатура.Ссылка = РегистрОписаниеНоменклатуры.Номенклатура
			|{ГДЕ
			|	СправочникНоменклатура.Ссылка.* КАК Номенклатура,
			|	%2}",
			Тип,
			УсловиеПоКлючуВидовПродукции);
		КонецЦикла;
		
	КонецЕсли;
	
	Возврат ТекстЗапроса;
	
КонецФункции

&НаСервере
Функция НоменклатураОтбора()
	
	СхемаКомпоновкиДанных = ПолучитьСхемуКомпоновкиДанныхОтбораНоменклатуры();
	
	ВыбранныеПоля = Новый Массив;
	ВыбранныеПоля.Добавить("Номенклатура");
	
	Компоновщик = Новый КомпоновщикНастроекКомпоновкиДанных;
	Компоновщик.Инициализировать(Новый ИсточникДоступныхНастроекКомпоновкиДанных(СхемаКомпоновкиДанных));
	Компоновщик.ЗагрузитьНастройки(СхемаКомпоновкиДанных.НастройкиПоУмолчанию);
	
	Структура = Компоновщик.Настройки.Структура.Добавить(Тип("ГруппировкаКомпоновкиДанных"));
	
	Для Каждого Поле Из ВыбранныеПоля Цикл
		ВыбранноеПоле = Структура.Выбор.Элементы.Добавить(Тип("ВыбранноеПолеКомпоновкиДанных"));
		ВыбранноеПоле.Поле = Новый ПолеКомпоновкиДанных(Поле);
	КонецЦикла;
	
	ДобавитьЭлементыОтбораКомпоновщика(Компоновщик.Настройки.Отбор.Элементы,
		НастройкиОтбора.Настройки.Отбор.Элементы);
	
	КомпоновщикМакета = Новый КомпоновщикМакетаКомпоновкиДанных;
	Макет = КомпоновщикМакета.Выполнить(СхемаКомпоновкиДанных, Компоновщик.ПолучитьНастройки(),,,
		Тип("ГенераторМакетаКомпоновкиДанныхДляКоллекцииЗначений"));
	
	ПроцессорКомпоновки = Новый ПроцессорКомпоновкиДанных;
	ПроцессорКомпоновки.Инициализировать(Макет);
	
	ПроцессорВывода = Новый ПроцессорВыводаРезультатаКомпоновкиДанныхВКоллекциюЗначений;
	
	Возврат ПроцессорВывода.Вывести(ПроцессорКомпоновки);
	
КонецФункции

&НаСервере
Процедура ДобавитьЭлементыОтбораКомпоновщика(ЭлементыПриемника, ЭлементыИсточника)
	
	Для Каждого ЭлементИсточника Из ЭлементыИсточника Цикл
		Если ТипЗнч(ЭлементИсточника) = Тип("ЭлементОтбораКомпоновкиДанных")
			И ЭлементИсточника.Использование Тогда
			ЭлементПриемника = ЭлементыПриемника.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
			ЗаполнитьЗначенияСвойств(ЭлементПриемника, ЭлементИсточника);
		ИначеЕсли ТипЗнч(ЭлементИсточника) = Тип("ГруппаЭлементовОтбораКомпоновкиДанных") Тогда
			ЭлементПриемника = ЭлементыПриемника.Добавить(Тип("ГруппаЭлементовОтбораКомпоновкиДанных"));
			ЗаполнитьЗначенияСвойств(ЭлементПриемника, ЭлементИсточника);
			ДобавитьЭлементыОтбораКомпоновщика(ЭлементПриемника.Элементы, ЭлементИсточника.Элементы);
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Функция ЕстьИспользуемыйЭлементОтбора(ЭлементыОтбора)
	
	Для Каждого ЭлементОтбора Из ЭлементыОтбора Цикл
		Если ЭлементОтбора.Использование Тогда
			Если ТипЗнч(ЭлементОтбора) = Тип("ГруппаЭлементовОтбораКомпоновкиДанных") Тогда
				Если ЕстьИспользуемыйЭлементОтбора(ЭлементОтбора.Элементы) Тогда
					Возврат Истина;
				КонецЕсли;
			Иначе
				Возврат Истина;
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	
	Возврат Ложь;
	
КонецФункции

#КонецОбласти

#Область ЗаписьДанных

&НаСервере
Процедура ЗаписьДанных()
	
	СтрокиДляЗаписи = Новый Массив;
	
	Для Каждого Строка Из ТаблицаДанных Цикл
		Если Строка.Пометка
			И ЗначенияВидовПродукцииИзменились(Строка) Тогда
			СтрокиДляЗаписи.Добавить(Строка);
		КонецЕсли;
	КонецЦикла;
	
	Если СтрокиДляЗаписи.Количество() = 0 Тогда
		ОбщегоНазначения.СообщитьПользователю(
			НСтр("ru = 'Отсутствуют данные для записи'"),,
			"ТаблицаДанных");
		Возврат;
	КонецЕсли;
	
	СуффиксыВидовПродукции = КонструкторИСОбщегоНазначенияКлиентСервер.СуффиксыВидовПродукции();
	
	Таблица = Новый ТаблицаЗначений;
	Таблица.Колонки.Добавить("Индекс", ОбщегоНазначения.ОписаниеТипаЧисло(6));
	Таблица.Колонки.Добавить("Номенклатура", Метаданные.ОпределяемыеТипы.Номенклатура.Тип);
	Для Каждого Суффикс Из СуффиксыВидовПродукции Цикл
		Таблица.Колонки.Добавить("ВидПродукции"+Суффикс, Новый ОписаниеТипов("СправочникСсылка.ВидыПродукцииИС"));
	КонецЦикла;
	
	Для Индекс = 0 По СтрокиДляЗаписи.ВГраница() Цикл
		Строка = Таблица.Добавить();
		ЗаполнитьЗначенияСвойств(Строка, СтрокиДляЗаписи[Индекс]);
		Строка.Индекс = Индекс;
	КонецЦикла;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Таблица", Таблица);
	Запрос.Текст = ТекстЗапросаЗаписиДанных();
	
	Блокировка = Новый БлокировкаДанных;
	ЭлементБлокировки = Блокировка.Добавить("РегистрСведений.ОписаниеНоменклатурыИС");
	ЭлементБлокировки.Режим = РежимБлокировкиДанных.Исключительный;
	
	ЭлементБлокировки.ИсточникДанных = Таблица;
	ЭлементБлокировки.ИспользоватьИзИсточникаДанных("Номенклатура", "Номенклатура");
	
	УстановитьПривилегированныйРежим(Истина);
	
	НачатьТранзакцию();
	
	Попытка
		
		Блокировка.Заблокировать();
		
		Выборка = Запрос.Выполнить().Выбрать();
		Пока Выборка.Следующий() Цикл
			Строка = СтрокиДляЗаписи[Выборка.Индекс];
			Запись = РегистрыСведений.ОписаниеНоменклатурыИС.СоздатьМенеджерЗаписи();
			Если ЗначениеЗаполнено(Выборка.Номенклатура) Тогда
				ЗаполнитьЗначенияСвойств(Запись, Выборка);
			Иначе
				Запись.Номенклатура = Строка.Номенклатура;
				Запись.ВариантИспользованияЕдиницыХранения = Перечисления.ВариантыИспользованияЕдиницыХраненияИС.ПотребительскаяУпаковка;
				Запись.КоличествоВПотребительскойУпаковке = 1;
			КонецЕсли;
			Если ЗначениеЗаполнено(Выборка.КлючВидовПродукцииНовый) Тогда
				Запись.КлючВидовПродукции = Выборка.КлючВидовПродукцииНовый;
			Иначе
				Запись.КлючВидовПродукции = КлючВидовПродукцииПоСтроке(Строка, СуффиксыВидовПродукции);
			КонецЕсли;
			Если ЗначениеЗаполнено(Запись.КлючВидовПродукции) Тогда
				Запись.Записать();
			Иначе
				Запись.Удалить();
			КонецЕсли;
		КонецЦикла;
		
		ЗафиксироватьТранзакцию();
		
	Исключение
		ОтменитьТранзакцию();
		ВызватьИсключение;
	КонецПопытки;
	
	УстановитьПривилегированныйРежим(Ложь);
	
	ЗаполнитьТаблицуДанныхНаСервере();
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ТекстЗапросаЗаписиДанных()
	
	ИменаПолейКлюча = КонструкторИСОбщегоНазначенияКлиентСервер.ИменаПолейКлючаВидовПродукции();
	ИменаПолейСоединенияТаблиц = Новый Массив;
	Для Каждого ИмяПоляКлюча Из ИменаПолейКлюча Цикл
		ИменаПолейСоединенияТаблиц.Добавить(СтрШаблон(
			"Таблица.%1 = КлючиВидовПродукции.%1",
			ИмяПоляКлюча));
	КонецЦикла;
	
	Возврат СтрШаблон(
	"ВЫБРАТЬ
	|	Таблица.Индекс,
	|	Таблица.Номенклатура,
	|	%1
	|ПОМЕСТИТЬ Таблица
	|ИЗ
	|	&Таблица КАК Таблица
	|;
	|ВЫБРАТЬ
	|	Таблица.Индекс КАК Индекс,
	|	КлючиВидовПродукции.Ссылка КАК КлючВидовПродукцииНовый,
	|	ОписаниеНоменклатуры.*
	|ИЗ
	|	Таблица КАК Таблица
	|	ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ОписаниеНоменклатурыИС КАК ОписаниеНоменклатуры
	|	ПО Таблица.Номенклатура = ОписаниеНоменклатуры.Номенклатура
	|	ЛЕВОЕ СОЕДИНЕНИЕ Справочник.КлючиВидовПродукцииИС КАК КлючиВидовПродукции
	|	ПО %2",
	СтрСоединить(ИменаПолейКлюча, ","),
	СтрСоединить(ИменаПолейСоединенияТаблиц, " И "));
	
КонецФункции

&НаСервереБезКонтекста
Функция КлючВидовПродукцииПоСтроке(Строка, СуффиксыВидовПродукции)
	
	ПоляКлюча = Справочники.КлючиВидовПродукцииИС.ПоляКлюча();
	
	Для Каждого Суффикс Из СуффиксыВидовПродукции Цикл
		Если ЗначениеЗаполнено(Строка["ВидПродукции"+Суффикс]) Тогда
			ПоляКлюча["ВидПродукции"+Суффикс] = Строка["ВидПродукции"+Суффикс];
		КонецЕсли;
	КонецЦикла;
	
	Возврат Справочники.КлючиВидовПродукцииИС.ПолучитьКлюч(ПоляКлюча);
	
КонецФункции

#КонецОбласти

#КонецОбласти
