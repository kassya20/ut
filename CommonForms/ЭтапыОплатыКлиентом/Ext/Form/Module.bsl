&НаКлиенте
Процедура СдвигПредоплатаПриИзменении(Элемент)
	
	ДанныеЭтапа = Новый Структура;
	ДанныеЭтапа.Вставить("ДатаПлатежа", Дата(1,1,1));
	ДанныеЭтапа.Вставить("Сдвиг", СдвигПредоплата);
	ДанныеЭтапа.Вставить("ВариантОтсчета", ВариантОтсчетаПредоплата);
	ДанныеЭтапа.Вставить("ВариантОплаты",  ПредопределенноеЗначение("Перечисление.ВариантыКонтроляОплатыКлиентом.ПредоплатаДоОтгрузки"));
	ДанныеЭтапа.Вставить("Формула",        Неопределено);
	
	ПараметрыЗаполненияДатыПлатежа = ЭтапыОплатыКлиентСервер.ПараметрыРасчетаДатыПлатежа();
	ПараметрыЗаполненияДатыПлатежа.ДатаЗаказа                     = ДатаЗаказа;
	ПараметрыЗаполненияДатыПлатежа.ДатаСогласования               = ДатаСогласования;
	ПараметрыЗаполненияДатыПлатежа.ДатаОтгрузки                   = ДатаОтгрузки;
	ПараметрыЗаполненияДатыПлатежа.ДатаПереходаПраваСобственности = ДатаПереходаПраваСобственности;
	ПараметрыЗаполненияДатыПлатежа.СрокПереходаПраваСобственности = СрокПереходаПраваСобственности;
	ПараметрыЗаполненияДатыПлатежа.Календарь                      = Календарь;
	
	ЭтапыОплатыКлиент.ЭтапыГрафикаОплатыСдвигВариантОтсчетаПриИзменении(
		ДанныеЭтапа,ПараметрыЗаполненияДатыПлатежа);
	
	ДатаПредоплата = ДанныеЭтапа.ДатаПлатежа;
	
КонецПроцедуры

