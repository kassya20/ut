// Со всех реквизитов снят флаг "ИзменяетСохраняемыеДанные", т.к. в противном случае отображается заголовок "*" при модифицированности
// За отслеживание изменений отвечает флаг "ПротоколИзменен", который взводится при отправке нового сообщения или редактировании последнего
// Т.к. форма может быть открыта при пустой таблице, текущее состояние хранится в "ДанныеПротокола" для отслеживания изменений

#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	РазрешитьРедактирование = Параметры.РазрешитьРедактирование;
	ДанныеПротокола = Параметры.ДанныеПротокола;
	ЗаполнитьЗначенияСвойств(ЭтотОбъект, ДанныеПротокола,, "Комментарий");
	ЗаполнитьПротокол();
	
	УправлениеФормой();
	
	Если ЗначениеЗаполнено(Протокол) Тогда
		ПоследняяСтрока = РаботаСПротоколомДокументаКлиентСервер.ПоследняяСтрокаПротокола(Протокол);
		Элементы.Протокол.ТекущаяСтрока = ПоследняяСтрока.ПолучитьИдентификатор();
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ОбработкаПроверкиЗаполненияНаСервере(Отказ, ПроверяемыеРеквизиты)
	
	НепроверяемыеРеквизиты = Новый Массив;
	
	Если ЭтоКонечныйСтатусДокумента Тогда
		
		НепроверяемыеРеквизиты.Добавить("Исполнитель");
		
	КонецЕсли;
	
	ОбщегоНазначения.УдалитьНепроверяемыеРеквизитыИзМассива(ПроверяемыеРеквизиты, НепроверяемыеРеквизиты);
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыПротокол

&НаКлиенте
Процедура ПротоколВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	ОткрытьФормуСтрокиПротокола(ВыбраннаяСтрока, СтандартнаяОбработка);
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура Отправить(Команда)
	ДобавитьСтрокуПротокола();
КонецПроцедуры

&НаКлиенте
Процедура ОК(Команда)
		
	ДобавитьСтрокуПротокола();
	
	ВозвращаемоеЗначение = Неопределено;
	Если ПротоколИзменен Тогда
		
		ВозвращаемоеЗначение = РаботаСПротоколомДокументаКлиент.ПротоколВМассив(Протокол);
		
	КонецЕсли;
	
	Закрыть(ВозвращаемоеЗначение);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

#Область ИнициализацияТаблицы

&НаСервере
Процедура ЗаполнитьПротокол()
	
	НачалоТекущегоДня = НачалоДня(ТекущаяДатаСеанса());
	
	Для Каждого СтрокаИсточник Из Параметры.Протокол Цикл
		
		СтрокаПриемник = Протокол.Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаПриемник, СтрокаИсточник);
		ЗаполнитьПредставлениеДанныхСтрокПротокола(СтрокаПриемник, НачалоТекущегоДня);
		
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти

#Область ДобавлениеСтрок

&НаКлиенте
Процедура ДобавитьСтрокуПротокола()
	
	ОчиститьСообщения();
	
	Если Не ПроверитьЗаполнение() Тогда
		Возврат;
	КонецЕсли;
	
	НовоеСостояние = РаботаСПротоколомДокументаКлиентСервер.ИзменяемыеСвойстваПротокола();
	ЗаполнитьЗначенияСвойств(НовоеСостояние, ДанныеПротокола); // Для свойств, которые не изменяются в форме
	ЗаполнитьЗначенияСвойств(НовоеСостояние, ЭтотОбъект);
	
	Если Не РаботаСПротоколомДокументаКлиентСервер.ИзменилисьСвойстваПротокола(НовоеСостояние, ДанныеПротокола, Истина) Тогда
		Возврат;
	КонецЕсли;
	
	СтрокаПротокола = РаботаСПротоколомДокументаКлиент.НоваяСтрокаПротокола(Протокол, НовоеСостояние);
	НачалоТекущегоДня = НачалоДня(ОбщегоНазначенияКлиент.ДатаСеанса());
	ЗаполнитьПредставлениеДанныхСтрокПротокола(СтрокаПротокола, НачалоТекущегоДня);
	Элементы.Протокол.ТекущаяСтрока = СтрокаПротокола.ПолучитьИдентификатор();
	
	Комментарий = Неопределено; // Комментарий сбрасывается, т.к. "сообщение" успешно отправлено	
	ПриИзмененииДанныхПротокола();
	
КонецПроцедуры

#КонецОбласти

#Область ОткрытиеСтрок

&НаКлиенте
Процедура ОткрытьФормуСтрокиПротокола(ВыбраннаяСтрока, СтандартнаяОбработка = Ложь)
	
	ТекущиеДанные = Протокол.НайтиПоИдентификатору(ВыбраннаяСтрока);
	
	ПараметрыОткрытия = РаботаСПротоколомДокументаКлиент.ПараметрыОткрытияСтрокиПротокола();
	ЗаполнитьЗначенияСвойств(ПараметрыОткрытия.ДанныеПротокола, ТекущиеДанные);
	
	ПараметрыОткрытия.ЭтоНоваяЗапись = Ложь; 
	ПараметрыОткрытия.АвторДокумента = АвторДокумента;
	
	ПараметрыОткрытия.РазрешитьРедактирование = РазрешитьРедактирование
		И ТекущиеДанные.Автор = ПользователиКлиент.ТекущийПользователь()
		И Протокол.Индекс(ТекущиеДанные) = Протокол.Индекс(РаботаСПротоколомДокументаКлиентСервер.ПоследняяСтрокаПротокола(Протокол));
		
	ОписаниеОповещения = Новый ОписаниеОповещения("Подключаемый_ПриИзмененииСтрокиПротокола", ЭтотОбъект);
	РаботаСПротоколомДокументаКлиент.ОткрытьСтрокуПротокола(ЭтотОбъект, ПараметрыОткрытия, ОписаниеОповещения);
	
КонецПроцедуры

&НаКлиенте
Процедура Подключаемый_ПриИзмененииСтрокиПротокола(НовоеСостояние, ДополнительныеПараметры = Неопределено) Экспорт
	
	Если НовоеСостояние = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ТекущиеДанные = Элементы.Протокол.ТекущиеДанные;
	
	Если Не РаботаСПротоколомДокументаКлиентСервер.ИзменилисьСвойстваПротокола(НовоеСостояние, ДанныеПротокола) Тогда
		Возврат;
	КонецЕсли;
	
	ЗаполнитьЗначенияСвойств(ТекущиеДанные, НовоеСостояние);
	ТекущиеДанные.Дата = ОбщегоНазначенияКлиент.ДатаСеанса(); // Обновляем дату изменения строки
	ПриИзмененииДанныхПротокола();
	
КонецПроцедуры

#КонецОбласти

#Область ТекущееСостояние

&НаКлиенте
Процедура ПриИзмененииДанныхПротокола()
	
	ПоследняяСтрока = РаботаСПротоколомДокументаКлиентСервер.ПоследняяСтрокаПротокола(Протокол);
	ЗаполнитьЗначенияСвойств(ДанныеПротокола, ПоследняяСтрока); // Новое текущее состояние для отслеживания изменений
	ПротоколИзменен = Истина;
	
КонецПроцедуры

#КонецОбласти

#Область ПредставлениеПротокола

&НаКлиентеНаСервереБезКонтекста
Процедура ЗаполнитьПредставлениеДанныхСтрокПротокола(СтрокаПротокола, НачалоТекущегоДня)
	
	ЗаполнитьПредставлениеДаты(СтрокаПротокола, НачалоТекущегоДня);
	ЗаполнитьПредставлениеПеренаправления(СтрокаПротокола);
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Процедура ЗаполнитьПредставлениеДаты(СтрокаПротокола, НачалоТекущегоДня)
		
	Если НачалоДня(СтрокаПротокола.Дата) = НачалоТекущегоДня Тогда
		// Для текущей даты отображается только время
		СтрокаПротокола.ПредставлениеДаты = Формат(СтрокаПротокола.Дата, "ДФ=HH:mm");
	Иначе // Отображаем дату без секунд. Более детально можно посмотреть при рассмотрении конкретной строки
		СтрокаПротокола.ПредставлениеДаты = СтрШаблон("%1 %2",
			Формат(СтрокаПротокола.Дата, "ДЛФ=D"),
			Формат(СтрокаПротокола.Дата, "ДФ=HH:mm"));
	КонецЕсли;
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Процедура ЗаполнитьПредставлениеПеренаправления(СтрокаПротокола)
		
	Если СтрокаПротокола.Исполнитель <> СтрокаПротокола.Автор И ЗначениеЗаполнено(СтрокаПротокола.Исполнитель) Тогда 
		СтрокаПротокола.ПредставлениеПеренаправления = СтрШаблон("%1 --> %2",
			СтрокаПротокола.Автор,
			СтрокаПротокола.Исполнитель);
	Иначе
		СтрокаПротокола.ПредставлениеПеренаправления = СтрШаблон("%1",
			СтрокаПротокола.Автор);
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область УправлениеФормой

&НаСервере
Процедура УправлениеФормой()
	
	Элементы.ГруппаРедактирование.Видимость = РазрешитьРедактирование;
	Элементы.ФормаОК.Видимость = РазрешитьРедактирование;
	Элементы.ФормаОК.КнопкаПоУмолчанию = РазрешитьРедактирование;
	Элементы.ФормаЗакрыть.КнопкаПоУмолчанию = Не РазрешитьРедактирование;
	
	ЭтоКонечныйСтатусДокумента = РаботаСПротоколомДокумента.ЭтоКонечныйСтатусДокумента(ДанныеПротокола.Статус);
	Элементы.Исполнитель.Видимость = Не ЭтоКонечныйСтатусДокумента;
	Элементы.ДекорацияИсполнитель.Видимость = ЭтоКонечныйСтатусДокумента;
	
КонецПроцедуры

#КонецОбласти

#КонецОбласти
