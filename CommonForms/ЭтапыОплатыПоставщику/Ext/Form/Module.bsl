&НаКлиенте
Процедура СдвигПредоплатаПриИзменении(Элемент)
	
	Структура = Новый Структура;
	Структура.Вставить("ДатаПлатежа",    Дата(1,1,1));
	Структура.Вставить("Сдвиг",          СдвигПредоплата);
	Структура.Вставить("ВариантОтсчета", ВариантОтсчетаПредоплата);
	Структура.Вставить("ВариантОплаты",  ПредопределенноеЗначение("Перечисление.ВариантыКонтроляОплатыПоставщику.ПредоплатаДоПоступления"));
	Структура.Вставить("Формула",        Неопределено);
	
	ПараметрыЗаполненияДатыПлатежа = ЭтапыОплатыКлиентСервер.ПараметрыРасчетаДатыПлатежа();
	ПараметрыЗаполненияДатыПлатежа.ДатаЗаказа                     = ДатаЗаказа;
	ПараметрыЗаполненияДатыПлатежа.ДатаСогласования               = ДатаСогласования;
	ПараметрыЗаполненияДатыПлатежа.ДатаОтгрузки                   = ДатаОтгрузки;
	ПараметрыЗаполненияДатыПлатежа.ДатаПереходаПраваСобственности = ДатаПереходаПраваСобственности;
	ПараметрыЗаполненияДатыПлатежа.СрокПереходаПраваСобственности = СрокПереходаПраваСобственности;
	ПараметрыЗаполненияДатыПлатежа.Календарь                      = Календарь;
	
	ЭтапыОплатыКлиент.ЭтапыГрафикаОплатыСдвигВариантОтсчетаПриИзменении(
		Структура,ПараметрыЗаполненияДатыПлатежа);
	
	ДатаПредоплата = Структура.ДатаПлатежа;
	
КонецПроцедуры

&НаКлиенте
Процедура ВариантОтсчетаКонтролируемыйПриИзменении(Элемент)
	
	Если ВариантОтсчетаПредоплата = ПредопределенноеЗначение("Перечисление.ВариантыОтсчетаДатыПлатежа.ФиксированнаяДата") Тогда
		СдвигПредоплата = 0;
	КонецЕсли;
	УстановитьДоступностьЭлементовПоВариантуОтсчета();
	
	Структура = Новый Структура;
	Структура.Вставить("ДатаПлатежа",    ДатаПредоплата);
	Структура.Вставить("Сдвиг",          СдвигПредоплата);
	Структура.Вставить("ВариантОтсчета", ВариантОтсчетаПредоплата);
	Структура.Вставить("ВариантОплаты",  ПредопределенноеЗначение("Перечисление.ВариантыКонтроляОплатыПоставщику.ПредоплатаДоПоступления"));
	Структура.Вставить("Формула",        Неопределено);
	
	ПараметрыЗаполненияДатыПлатежа = ЭтапыОплатыКлиентСервер.ПараметрыРасчетаДатыПлатежа();
	ПараметрыЗаполненияДатыПлатежа.ДатаЗаказа                     = ДатаЗаказа;
	ПараметрыЗаполненияДатыПлатежа.ДатаСогласования               = ДатаСогласования;
	ПараметрыЗаполненияДатыПлатежа.ДатаОтгрузки                   = ДатаОтгрузки;
	ПараметрыЗаполненияДатыПлатежа.ДатаПереходаПраваСобственности = ДатаПереходаПраваСобственности;
	ПараметрыЗаполненияДатыПлатежа.СрокПереходаПраваСобственности = СрокПереходаПраваСобственности;
	ПараметрыЗаполненияДатыПлатежа.Календарь                      = Календарь;
	
	ЭтапыОплатыКлиент.ЭтапыГрафикаОплатыСдвигВариантОтсчетаПриИзменении(
		Структура,ПараметрыЗаполненияДатыПлатежа);
	
	ДатаПредоплата = Структура.ДатаПлатежа;
	
КонецПроцедуры

&НаКлиенте
Процедура ДатаПредоплатаПриИзменении(Элемент)
	
	Структура = Новый Структура;
	Структура.Вставить("ДатаПлатежа",    ДатаПредоплата);
	Структура.Вставить("Сдвиг",          0);
	Структура.Вставить("ВариантОтсчета", ВариантОтсчетаПредоплата);
	Структура.Вставить("ВариантОплаты", ПредопределенноеЗначение("Перечисление.ВариантыКонтроляОплатыПоставщику.ПредоплатаДоПоступления"));
	Структура.Вставить("Формула",        Неопределено);
	
	ПараметрыЗаполненияСдвига = ЭтапыОплатыКлиентСервер.ПараметрыРасчетаДатыПлатежа();
	ПараметрыЗаполненияСдвига.ДатаЗаказа                     = ДатаЗаказа;
	ПараметрыЗаполненияСдвига.ДатаСогласования               = ДатаСогласования;
	ПараметрыЗаполненияСдвига.ДатаОтгрузки                   = ДатаОтгрузки;
	ПараметрыЗаполненияСдвига.ДатаПереходаПраваСобственности = ДатаПереходаПраваСобственности;
	ПараметрыЗаполненияСдвига.СрокПереходаПраваСобственности = СрокПереходаПраваСобственности;
	ПараметрыЗаполненияСдвига.Календарь                      = Календарь;
	
	ЭтапыОплатыКлиент.ЭтапыГрафикаОплатыДатаПлатежаПриИзменении(
		Структура,ПараметрыЗаполненияСдвига);
	
	СдвигПредоплата = Структура.Сдвиг;
	
КонецПроцедуры

&НаКлиенте
Процедура СдвигПостоплатаПриИзменении(Элемент)
	
	Структура = Новый Структура;
	Структура.Вставить("ДатаПлатежа",    Дата(1,1,1));
	Структура.Вставить("Сдвиг",          СдвигПостоплата);
	Структура.Вставить("ВариантОтсчета", ВариантОтсчетаПостоплата);
	Структура.Вставить("ВариантОплаты",  ПредопределенноеЗначение("Перечисление.ВариантыКонтроляОплатыПоставщику.КредитПослеПоступления"));
	Структура.Вставить("Формула",        Неопределено);
	
	ПараметрыЗаполненияДатыПлатежа = ЭтапыОплатыКлиентСервер.ПараметрыРасчетаДатыПлатежа();
	ПараметрыЗаполненияДатыПлатежа.ДатаЗаказа                     = ДатаЗаказа;
	ПараметрыЗаполненияДатыПлатежа.ДатаСогласования               = ДатаСогласования;
	ПараметрыЗаполненияДатыПлатежа.ДатаОтгрузки                   = ДатаОтгрузки;
	ПараметрыЗаполненияДатыПлатежа.ДатаПереходаПраваСобственности = ДатаПереходаПраваСобственности;
	ПараметрыЗаполненияДатыПлатежа.СрокПереходаПраваСобственности = СрокПереходаПраваСобственности;
	ПараметрыЗаполненияДатыПлатежа.Календарь                      = Календарь;
	
	ЭтапыОплатыКлиент.ЭтапыГрафикаОплатыСдвигВариантОтсчетаПриИзменении(
		Структура,ПараметрыЗаполненияДатыПлатежа);
	
