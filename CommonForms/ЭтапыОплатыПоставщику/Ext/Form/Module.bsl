&НаКлиенте
Процедура ЭтапыГрафикаОплатыСдвигПриИзменении(Элемент)
	
	ТекущиеДанные = Элементы.ЭтапыГрафикаОплаты.ТекущиеДанные;
	
	Если ЗначениеЗаполнено(ТекущиеДанные.Заказ) Тогда
		СтрокиЗаказа = ТабличнаяЧасть.НайтиСтроки(Новый Структура("Заказ", ТекущиеДанные.Заказ));
		Если СтрокиЗаказа.Количество() > 0 Тогда
			ДатаЗаказа = СтрокиЗаказа[0].ДатаЗаказа;
			ДатаСогласования = СтрокиЗаказа[0].ДатаСогласования;
		КонецЕсли;
	КонецЕсли;
	
	ПараметрыЗаполненияДатыПлатежа = ЭтапыОплатыКлиентСервер.ПараметрыРасчетаДатыПлатежа();
	ПараметрыЗаполненияДатыПлатежа.ДатаЗаказа                     = ДатаЗаказа;
	ПараметрыЗаполненияДатыПлатежа.ДатаСогласования               = ДатаСогласования;
	ПараметрыЗаполненияДатыПлатежа.ДатаОтгрузки                   = ДатаОтгрузки;
	ПараметрыЗаполненияДатыПлатежа.ДатаПоступления                = ДатаПоступления;
	ПараметрыЗаполненияДатыПлатежа.ДатаПереходаПраваСобственности = ДатаПереходаПраваСобственности;
	ПараметрыЗаполненияДатыПлатежа.СрокПереходаПраваСобственности = СрокПереходаПраваСобственности;
	ПараметрыЗаполненияДатыПлатежа.Календарь                      = Календарь;
	
	ЭтапыОплатыКлиент.ЭтапыГрафикаОплатыСдвигВариантОтсчетаПриИзменении(
		Элементы.ЭтапыГрафикаОплаты.ТекущиеДанные,ПараметрыЗаполненияДатыПлатежа);
	
	ЕстьРучныеИзмененияГрафикаОплат = Истина;
	
	СортироватьЭтапыОплаты();
	
КонецПроцедуры

&НаКлиенте
Процедура ЭтапыГрафикаОплатыВариантКонтроляПриИзменении(Элемент)
	
	ТекущиеДанные = Элементы.ЭтапыГрафикаОплаты.ТекущиеДанные;
	
	Если ЗначениеЗаполнено(ТекущиеДанные.Заказ) Тогда
		СтрокиЗаказа = ТабличнаяЧасть.НайтиСтроки(Новый Структура("Заказ", ТекущиеДанные.Заказ));
		Если СтрокиЗаказа.Количество() > 0 Тогда
			ДатаЗаказа = СтрокиЗаказа[0].ДатаЗаказа;
			ДатаСогласования = СтрокиЗаказа[0].ДатаСогласования;
		КонецЕсли;
	КонецЕсли;
	
	ПараметрыЗаполненияДатыПлатежа = ЭтапыОплатыКлиентСервер.ПараметрыРасчетаДатыПлатежа();
	ПараметрыЗаполненияДатыПлатежа.ДатаЗаказа                     = ДатаЗаказа;
	ПараметрыЗаполненияДатыПлатежа.ДатаСогласования               = ДатаСогласования;
	ПараметрыЗаполненияДатыПлатежа.ДатаОтгрузки                   = ДатаОтгрузки;
	ПараметрыЗаполненияДатыПлатежа.ДатаПоступления                = ДатаПоступления;
	ПараметрыЗаполненияДатыПлатежа.ДатаПереходаПраваСобственности = ДатаПереходаПраваСобственности;
	ПараметрыЗаполненияДатыПлатежа.СрокПереходаПраваСобственности = СрокПереходаПраваСобственности;
	ПараметрыЗаполненияДатыПлатежа.Календарь                      = Календарь;
	
	ЭтапыОплатыКлиент.ЭтапыГрафикаОплатыВариантКонтроляПриИзменении(
		ТекущиеДанные,ПараметрыЗаполненияДатыПлатежа);
	
	ЕстьРучныеИзмененияГрафикаОплат = Истина;
	
	СортироватьЭтапыОплаты();
	
КонецПроцедуры

&НаКлиенте
Процедура ЭтапыГрафикаОплатыВариантОтсчетаПриИзменении(Элемент)
	
	ТекущиеДанные = Элементы.ЭтапыГрафикаОплаты.ТекущиеДанные;
	
	Если ТекущиеДанные.ВариантОтсчета = ПредопределенноеЗначение("Перечисление.ВариантыОтсчетаДатыПлатежа.ФиксированнаяДата") Тогда
		ТекущиеДанные.Сдвиг = 0;
		ТекущиеДанные.ВариантОплаты = ПредопределенноеЗначение("Перечисление.ВариантыКонтроляОплатыПоставщику.КредитПослеПоступления");
	КонецЕсли;
	
	Если ТекущиеДанные.ВариантОтсчета = ПредопределенноеЗначение("Перечисление.ВариантыОтсчетаДатыПлатежа.Формула") Тогда
		ОбработкаВыбора = Новый ОписаниеОповещения("ЭтапыОплатыВариантОтсчетаПриИзмененииЗавершение",ЭтотОбъект);
		ОткрытьФорму("Справочник.ФормулыРасчетаДатыПлатежа.Форма.ФормаВыбора",
			Новый Структура("ТекущаяСтрока",ТекущиеДанные.Формула),
			ЭтотОбъект,,,,ОбработкаВыбора,РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	Иначе
		ТекущиеДанные.Формула = Неопределено;
		ВыполнитьРасчетДатыПлатежаПриИзмененииВариантаОтсчета();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ЭтапыОплатыВариантОтсчетаПриИзмененииЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	ТекущиеДанные = Элементы.ЭтапыГрафикаОплаты.ТекущиеДанные;
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ТекущиеДанные.Формула = Результат;
	
	ВыполнитьРасчетДатыПлатежаПриИзмененииВариантаОтсчета();
	
КонецПроцедуры

