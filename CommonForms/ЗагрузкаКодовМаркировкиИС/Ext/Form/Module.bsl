#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Заголовок               = Параметры.Заголовок;
	ИспользоватьКодУпаковки = Параметры.ИспользоватьКодУпаковки;
	
	ТабличныйДокумент.Область(, 1,, 4).ШиринаКолонки = 50;
	Колонка = 1;
	
	ТабличныйДокумент.Область(1,Колонка).Текст = ЗаголовокШтрихкод();
	Колонка = Колонка + 1;
	
	Если ИспользоватьКодУпаковки Тогда
		ТабличныйДокумент.Область(1,Колонка).Текст = ЗаголовокКодУпаковки();
		Колонка = Колонка + 1;
	КонецЕсли;
	
	ТабличныйДокумент.Область(1,Колонка).Текст = ЗаголовокКодМаркировки();
	Колонка = Колонка + 1;
	
	ТабличныйДокумент.Область(1,Колонка).Текст = ЗаголовокКоличество();
	Колонка = Колонка + 1;
	
	ОбщегоНазначенияСобытияФормИСПереопределяемый.ПриСозданииНаСервере(ЭтотОбъект, Отказ, СтандартнаяОбработка);
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура Готово(Команда)
	
	Если ЕстьКодыМаркировки() Тогда
		ОповеститьОВыборе(КодыМаркировкиИзТабличногоДокумента());
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ЗакрытьФорму(Команда)
	
	Закрыть(Неопределено);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиентеНаСервереБезКонтекста
Функция ЗаголовокКодУпаковки()
	
	Возврат НСтр("ru = 'Код упаковки'");
	
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Функция ЗаголовокШтрихкод()
	
	Возврат НСтр("ru = 'Штрихкод или код маркировки'");
	
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Функция ЗаголовокКодМаркировки()
	
	Возврат НСтр("ru = 'Код маркировки'");
	
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Функция ЗаголовокКоличество()
	
	Возврат НСтр("ru = 'Количество'");
	
КонецФункции

// Заполняет коды маркировки из табличного документа в массив структур для возврата вызвавшей форме
//   Наименования колонок возвращаемого значения соответствуют загрузке из ТСД БПО
//
// Возвращаемое значение:
//   Массив Из Структура - коды маркировки из табличного документа с полями:
//    * Штрихкод                          - Строка - Штрихкод или код маркировки (обязательный)
//    * ШтрихкодУпаковки                  - Строка - код упаковки (необязательный)
//    * Количество                        - Число  - количество
//    * ШтрихкодМаркиАлкогольнойПродукции - Строка - Код маркировки (при считывании одновременно со штрихкодом)
//
&НаКлиенте
Функция КодыМаркировкиИзТабличногоДокумента()
	
	Результат = Новый Массив;
	
	НомерКолонкиШтрихкод      = Неопределено;
	НомерКолонкиКодУпаковки   = Неопределено;
	НомерКолонкиКодМаркировки = Неопределено;
	НомерКолонкиКоличество    = Неопределено;
	
	Для Индекс = 1 По ТабличныйДокумент.ШиринаТаблицы Цикл
		Текст = ТабличныйДокумент.Область(1,Индекс).Текст;
		Если Текст = ЗаголовокШтрихкод() Тогда
			НомерКолонкиШтрихкод = Индекс;
		ИначеЕсли Текст = ЗаголовокКодУпаковки() Тогда
			НомерКолонкиКодУпаковки = Индекс;
		ИначеЕсли Текст = ЗаголовокКодМаркировки() Тогда
			НомерКолонкиКодМаркировки = Индекс;
		ИначеЕсли Текст = ЗаголовокКоличество() Тогда
			НомерКолонкиКоличество = Индекс;
		КонецЕсли;
	КонецЦикла;
	
	КолонкаКодУпаковкиИспользуется = ИспользоватьКодУпаковки И НомерКолонкиКодУпаковки <> Неопределено;
	КолонкаКодМаркировкиИспользуется = НомерКолонкиКодМаркировки <> Неопределено;
	КолонкаКоличествоИспользуется = НомерКолонкиКоличество <> Неопределено;
	
	Для Индекс = 2 По ТабличныйДокумент.ВысотаТаблицы Цикл
		
		Штрихкод = СокрЛП(ТабличныйДокумент.Область(Индекс, НомерКолонкиШтрихкод).Текст);
		КодМаркировки = "";
		Количество = 1;
		ШтрихкодУпаковки = "";
		
		Если Не ЗначениеЗаполнено(Штрихкод) Тогда
			Продолжить;
		КонецЕсли;
		
		СодержитНедопустимыеСимволы = Ложь;
		
		Если РазборКодаМаркировкиИССлужебныйКлиентСервер.НайденНедопустимыйСимволXML(Штрихкод) Тогда
			СодержитНедопустимыеСимволы = Истина;
		КонецЕсли;
		
		Если КолонкаКодМаркировкиИспользуется Тогда
			КодМаркировки = СокрЛП(ТабличныйДокумент.Область(Индекс, НомерКолонкиКодМаркировки).Текст);
			Если ЗначениеЗаполнено(КодМаркировки)
				И РазборКодаМаркировкиИССлужебныйКлиентСервер.НайденНедопустимыйСимволXML(КодМаркировки) Тогда
				СодержитНедопустимыеСимволы = Истина;
			КонецЕсли;
		КонецЕсли;
		
		Если КолонкаКоличествоИспользуется Тогда
			ЗначениеПоля = ТабличныйДокумент.Область(Индекс, НомерКолонкиКоличество).Текст;
			Если ЗначениеЗаполнено(ЗначениеПоля) Тогда
				//@skip-check empty-except-statement
				Попытка
					Количество = Число(СокрЛП(ЗначениеПоля));
				Исключение
				КонецПопытки;
			КонецЕсли;
		КонецЕсли;
		
		Если КолонкаКодУпаковкиИспользуется Тогда
			ШтрихкодУпаковки = СокрЛП(ТабличныйДокумент.Область(Индекс, НомерКолонкиКодУпаковки).Текст);
			Если ЗначениеЗаполнено(ШтрихкодУпаковки)
				И РазборКодаМаркировкиИССлужебныйКлиентСервер.НайденНедопустимыйСимволXML(ШтрихкодУпаковки) Тогда
				СодержитНедопустимыеСимволы = Истина;
			КонецЕсли;
		КонецЕсли;
		
		Если СодержитНедопустимыеСимволы Тогда
			Штрихкод = ШтрихкодированиеОбщегоНазначенияИСКлиентСервер.ШтрихкодВBase64(Штрихкод);
			ШтрихкодУпаковки = ШтрихкодированиеОбщегоНазначенияИСКлиентСервер.ШтрихкодВBase64(ШтрихкодУпаковки);
			КодМаркировки = ШтрихкодированиеОбщегоНазначенияИСКлиентСервер.ШтрихкодВBase64(КодМаркировки);
		КонецЕсли;
		
		ПоляСтроки = Новый Структура;
		ПоляСтроки.Вставить("Штрихкод",                          Штрихкод);
		ПоляСтроки.Вставить("Количество",                        Количество);
		ПоляСтроки.Вставить("ШтрихкодМаркиАлкогольнойПродукции", КодМаркировки);
		ПоляСтроки.Вставить("ШтрихкодУпаковки",                  ШтрихкодУпаковки);
		ПоляСтроки.Вставить("ФорматBase64",                      ФорматBase64 Или СодержитНедопустимыеСимволы);
		
		Результат.Добавить(ПоляСтроки);
	
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

// Проверяет наличие колонки "Штрихкод" и хотя бы 1 заполненного значения в ней
// 
// Возвращаемое значение:
//   Булево - коды маркировки в таблице есть
//
&НаКлиенте
Функция ЕстьКодыМаркировки()
	
	НомерКолонкиКодМаркировки = Неопределено;
	Для Индекс = 1 По ТабличныйДокумент.ШиринаТаблицы Цикл
		Если ТабличныйДокумент.Область(1,Индекс).Текст = ЗаголовокШтрихкод() Тогда
			НомерКолонкиКодМаркировки = Индекс;
		КонецЕсли;
	КонецЦикла;
	
	Если НомерКолонкиКодМаркировки = Неопределено Тогда
		ОбщегоНазначенияКлиент.СообщитьПользователю(
			СтрШаблон(НСтр("ru = 'Не найдена колонка с заголовком: %1'"), ЗаголовокШтрихкод()), , "ТабличныйДокумент");
		Возврат Ложь;
	КонецЕсли;
	
	Для Индекс = 2 По ТабличныйДокумент.ВысотаТаблицы Цикл
		Штрихкод = ТабличныйДокумент.Область(Индекс, НомерКолонкиКодМаркировки).Текст;
		Если ЗначениеЗаполнено(Штрихкод) Тогда
			Возврат Истина;
		КонецЕсли;
	КонецЦикла;
	
	ОбщегоНазначенияКлиент.СообщитьПользователю(
		СтрШаблон(НСтр("ru = 'Не заполнена колонка с заголовком: %1'"), ЗаголовокШтрихкод()), , "ТабличныйДокумент");
	Возврат Ложь;
	
КонецФункции

#КонецОбласти
