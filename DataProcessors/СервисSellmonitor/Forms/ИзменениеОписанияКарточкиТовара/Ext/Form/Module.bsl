#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)

	ЗаполнитьСпискиВыбора();
	
	Артикул = Параметры.Артикул;
	ЭтоНоваяКТ = Параметры.Новая;
	
	ИдентификаторМП = Параметры.ИдентификаторМП;
	Наименование = Параметры.НаименованиеМП;
	ИсходноеОписаниеНоменклатуры = Параметры.ОписаниеМП;
	ИдентификаторКатегорииМаркетплейса = Параметры.ИдентификаторКатегорииМаркетплейса;
	Если Параметры.Новая Тогда
		Элементы.СписокКТ.ПодсказкаВвода = НСтр("ru = 'Укажите карточку товара'");
	Иначе
		СписокКТ.Добавить(Параметры.ИдентификаторПубликации, Параметры.НаименованиеМП);
	КонецЕсли;

	СхемаКомпоновки = Обработки.СервисSellmonitor.ПолучитьМакет("ПодборКарточекТоваров_OZON");
	КомпоновщикНастроекПодбораКТ.Инициализировать(Новый ИсточникДоступныхНастроекКомпоновкиДанных(СхемаКомпоновки));
	КомпоновщикНастроекПодбораКТ.ЗагрузитьНастройки(СхемаКомпоновки.НастройкиПоУмолчанию);
	КомпоновщикНастроекПодбораКТ.Настройки.ПараметрыДанных.УстановитьЗначениеПараметра("УчетнаяЗаписьМаркетплейса", Параметры.УчетнаяЗапись);
	
	ЯзыкТекста = Элементы.ЯзыкТекста.СписокВыбора[0].Значение;
	СтрогостьВключенияКлючевыхСлов = Элементы.СтрогостьВключенияКлючевыхСлов.СписокВыбора[1].Значение;
	Тон = Элементы.Тон.СписокВыбора[0].Значение;
	КоличествоСимволов = 1500;
	
	Элементы.ГруппаОписаниеНовойНоменклатурыПодсказка.Видимость = Ложь;
	Элементы.ГруппаОписаниеСуществующейНоменклатурыПодсказка.Видимость = Ложь;
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	Если ИмяСобытия = "Маркетплейсы_ЗавершениеМенеджерДлительныхОпераций" Тогда
		Если Источник.ИдентификаторНазначения = УникальныйИдентификатор Тогда
			ОбработатьРезультатДлительныхОпераций(Параметр, Источник);
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры
#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура СписокКТНачалоВыбора(Элемент, ДанныеВыбора, ВыборДобавлением, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	ОчиститьСообщения();
	
	ПриЗавершенииОтбора = Новый ОписаниеОповещения("ПриЗавершенииНастройкиОтбораКТ", ЭтотОбъект);
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("ВидМаркетплейса", Параметры.ВидМаркетплейса);
	ПараметрыФормы.Вставить("УчетнаяЗапись", Параметры.УчетнаяЗапись);
	
	ОткрытьФорму("Обработка.СервисSellmonitor.Форма.ПодборКарточекТоваров", ПараметрыФормы, ЭтотОбъект,,,,ПриЗавершенииОтбора, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	
КонецПроцедуры

&НаКлиенте
Процедура СписокКТПриИзменении(Элемент)
	Элементы.СписокКТ.ПодсказкаВвода = ?(СписокКТ.Количество()=0, НСтр("ru = 'Укажите карточку товара'"), "");
КонецПроцедуры

&НаКлиенте
Процедура КоличествоСимволовОкончаниеВводаТекста(Элемент, Текст, ДанныеВыбора, ПараметрыПолученияДанных, СтандартнаяОбработка)
	
	ВведенноеЗначение = Число(Текст);
	
	Если ВведенноеЗначение < Элемент.МинимальноеЗначение Или ВведенноеЗначение > Элемент.МаксимальноеЗначение Тогда
		ТекстСообщения = НСтр("ru = 'Укажите значение от 500 до 3000'");
		ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения, , "КоличествоСимволов");
		СтандартнаяОбработка = Ложь;
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыКлючевыеСлова

&НаКлиенте
Процедура КлючевыеСловаПриНачалеРедактирования(Элемент, НоваяСтрока, Копирование)
	
	Если НоваяСтрока Тогда
		
		ТекущиеДанные = Элемент.ТекущиеДанные;
		
		Если ТекущиеДанные = Неопределено Тогда
			Возврат;
		КонецЕсли;
		
		ТекущиеДанные.Пометка = Истина;
		ТекущиеДанные.Кратность = 1;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура КлючевыеСловаПометкаПриИзменении(Элемент)
	
	ТекущиеДанные = Элементы.КлючевыеСлова.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если ТекущиеДанные.Пометка И ТекущиеДанные.Кратность = 0 Тогда
		ТекущиеДанные.Кратность = 1;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура КлючевыеСловаКратностьПриИзменении(Элемент)
	
	ТекущиеДанные = Элементы.КлючевыеСлова.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ТекущиеДанные.Пометка = ТекущиеДанные.Кратность <> 0;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура СкрытьПодсказку(Команда)
	
	ОчиститьСообщения();
	ИзменитьВидимостьПодсказки(Ложь);
	
КонецПроцедуры

&НаКлиенте
Процедура ПолучитьСтатистику(Команда)
	
	ПараметрыОперации = ИнтеграцияСМаркетплейсамиСИКлиентСервер.НовыеПараметрыМенеджераДлительныхОпераций();
	ПараметрыОперации.ОбработкаРезультатаНаСервере = Истина;
	
	ПараметрыОперации.Очередь.Добавить( , ИнтеграцияСМаркетплейсамиСИКлиентСервер.МетодПолучитьСтатистикуПоисковыхЗапросовSellmonitor());
	НачатьВыполнениеДлительныхОпераций(ПараметрыОперации);
	
КонецПроцедуры

&НаКлиенте
Процедура СгенерироватьИИ(Команда)
	
	ПараметрыОперации = ИнтеграцияСМаркетплейсамиСИКлиентСервер.НовыеПараметрыМенеджераДлительныхОпераций();
	ПараметрыОперации.ОбработкаРезультатаНаСервере = Истина;
	
	ПараметрыОперации.Очередь.Добавить( , ИнтеграцияСМаркетплейсамиСИКлиентСервер.МетодСгенерироватьОписаниеКарточкиТовараВSellmonitor());
	НачатьВыполнениеДлительныхОпераций(ПараметрыОперации);
	
КонецПроцедуры

&НаКлиенте
Процедура ПеренестиОписаниеВКарточкиТоваров(Команда)
	
	Если Не ЗначениеЗаполнено(СписокКТ) Тогда
		Закрыть(ОписаниеНоменклатуры);
		Возврат;
	КонецЕсли;
	
	ПараметрыОперации = ИнтеграцияСМаркетплейсамиСИКлиентСервер.НовыеПараметрыМенеджераДлительныхОпераций();
	ПараметрыОперации.ОбработкаРезультатаНаСервере = Ложь;
	
	ПараметыМетода = Новый Структура;
	ПараметыМетода.Вставить("ИсключитьОсновнуюКарточкуТовара", ТипЗнч(ВладелецФормы) <> Тип("Неопределено"));

	ПараметрыОперации.Очередь.Добавить(ПараметыМетода , ИнтеграцияСМаркетплейсамиСИКлиентСервер.МетодЗаполнитьОписаниеКарточекТоваров());
	НачатьВыполнениеДлительныхОпераций(ПараметрыОперации);
	
КонецПроцедуры

&НаКлиенте
Процедура ПоказатьПодсказку(Команда)
	
	ОчиститьСообщения();
	ИзменитьВидимостьПодсказки(Истина);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

#Область ДлительныеОперации

#Область ИнициализацияДлительныхОпераций

&НаКлиенте
Процедура НачатьВыполнениеДлительныхОпераций(ПараметрыОперации)
	
	ИнтернетПоддержкаПодключена = Ложь;
	ВыполнитьДлительныеОперации(ИнтернетПоддержкаПодключена, ПараметрыОперации);
	
	Если ИнтернетПоддержкаПодключена Тогда
		НачатьВыполнениеДлительныхОперацийПродолжение(Истина, ПараметрыОперации);
	Иначе
		Оповещение = Новый ОписаниеОповещения("НачатьВыполнениеДлительныхОперацийПродолжение", ЭтотОбъект, ПараметрыОперации);
		ИнтернетПоддержкаПользователейКлиент.ПодключитьИнтернетПоддержкуПользователей(Оповещение, ЭтотОбъект);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура НачатьВыполнениеДлительныхОперацийПродолжение(Результат, ПараметрыОперации) Экспорт
	
	ФоновоеЗадание = ПараметрыОперации.ФоновоеЗадание;
	
	Если Результат = Неопределено Тогда
		ТекстСообщения = НСтр("ru = 'Отсутствует подключение к Интернет-поддержке пользователей.'");
		ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения);
		Возврат;
	ИначеЕсли ТипЗнч(Результат) = Тип("Структура") Тогда
		// Повторный вызов метода после подключения к Интернет-поддержке.
		ВыполнитьДлительныеОперации(Ложь, ПараметрыОперации);
		ФоновоеЗадание = ПараметрыОперации.ФоновоеЗадание;
	КонецЕсли;
	
	Если ФоновоеЗадание = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если ФоновоеЗадание.Статус = "Выполняется" Тогда
		ОжидатьЗавершениеДлительныхОпераций(ПараметрыОперации);
	ИначеЕсли ФоновоеЗадание.Статус = "Выполнено" Тогда
		ОбработатьРезультатДлительныхОпераций(ФоновоеЗадание, ПараметрыОперации);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОжидатьЗавершениеДлительныхОпераций(ПараметрыОперации)
	
	Если Не ПараметрыОперации.ВыводитьОкноОжидания Тогда
		
		ТолькоПросмотр = Истина;
		
	КонецЕсли;
	
	ИнтеграцияСМаркетплейсамиСИКлиент.ОжидатьЗавершениеДлительныхОпераций(ЭтотОбъект, ПараметрыОперации);
	
КонецПроцедуры

&НаСервере
Процедура ВыполнитьДлительныеОперации(ИнтернетПоддержкаПодключена, ПараметрыОперации)

	Если Не ИнтеграцияСМаркетплейсамиСИ.ВозможенЗапускФоновогоЗадания(ЭтотОбъект, ПараметрыОперации,
		ИнтернетПоддержкаПодключена) Тогда
		Возврат;
	КонецЕсли;

	Отказ = Ложь;
	ЗаполнитьПараметрыДлительныхОпераций(ПараметрыОперации, Отказ);
	Если Отказ Тогда
		Возврат;
	КонецЕсли;

	ИнтеграцияСМаркетплейсамиСИ.ВыполнитьДлительныеОперации(ЭтотОбъект, ПараметрыОперации);

КонецПроцедуры

#КонецОбласти

#Область ПараметрыДлительныхОпераций

&НаСервере
Процедура ЗаполнитьПараметрыДлительныхОпераций(ПараметрыОперации, Отказ)
	
	Для Каждого Операция Из ПараметрыОперации.Очередь Цикл
		
		Если Операция.Представление = ИнтеграцияСМаркетплейсамиСИКлиентСервер.МетодСгенерироватьОписаниеКарточкиТовараВSellmonitor() Тогда
			ПараметрыЗапросаСгенерироватьОписаниеКарточкиТовараВSellmonitor(Операция.Значение);
		ИначеЕсли Операция.Представление = ИнтеграцияСМаркетплейсамиСИКлиентСервер.МетодПолучитьСтатистикуПоисковыхЗапросовSellmonitor() Тогда
			ПараметрыЗапросаПолучитьСтатистикуПоисковыхЗапросовSellmonitor(Операция.Значение);
		ИначеЕсли Операция.Представление = ИнтеграцияСМаркетплейсамиСИКлиентСервер.МетодЗаполнитьОписаниеКарточекТоваров() Тогда
			ПараметрыЗапросаЗаполнитьОписаниеКарточекТоваров(Операция.Значение);
		КонецЕсли;
		
	КонецЦикла;
	
	ПараметрыОперации.ВидМаркетплейса = Перечисления.ВидыМаркетплейсов.СервисАналитикиSellmonitor;
	
КонецПроцедуры

&НаСервере
Процедура ПараметрыЗапросаСгенерироватьОписаниеКарточкиТовараВSellmonitor(ПараметрыЗапроса)
	
	ВходящиеПараметры = ПараметрыЗапроса;
	
	ПараметрыЗапроса = ИнтеграцияСМаркетплейсамиСИ.НовыйПараметрыЗапросаСгенерироватьОписаниеКарточкиТовараВSellmonitor();
	ПараметрыЗапроса.УчетнаяЗапись = ИнтеграцияСSellmonitorСервер.ОсновнаяУчетнаяЗапись();
	ПараметрыЗапроса.ВидМаркетплейса = Перечисления.ВидыМаркетплейсов.СервисАналитикиSellmonitor;
	
	// Настройки для генерации описания
	НастройкиИИ = ПараметрыЗапроса.НастройкиИИ;
	НастройкиИИ.ВидМаркетплейса = Параметры.ВидМаркетплейса;
	НастройкиИИ.НаименованиеТовара = Наименование;
	
	Для Каждого СтрокаТаблицы Из КлючевыеСлова Цикл
		Если СтрокаТаблицы.Пометка И СтрокаТаблицы.Кратность > 0 Тогда
			НастройкиИИ.КлючевыеСлова.Вставить(СтрокаТаблицы.Слово, СтрокаТаблицы.Кратность);
		КонецЕсли;
	КонецЦикла;
	
	НастройкиИИ.Строгость = СтрогостьВключенияКлючевыхСлов;
	НастройкиИИ.Язык = ЯзыкТекста;
	НастройкиИИ.Длина = КоличествоСимволов;
	НастройкиИИ.ТекущееОписание = ИсходноеОписаниеНоменклатуры;
	НастройкиИИ.Тон = Тон;
	
	Если ВходящиеПараметры <> Неопределено Тогда
		ЗаполнитьЗначенияСвойств(ПараметрыЗапроса, ВходящиеПараметры);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ПараметрыЗапросаПолучитьСтатистикуПоисковыхЗапросовSellmonitor(ПараметрыЗапроса)
	
	ПараметрыЗапроса = ИнтеграцияСМаркетплейсамиСИ.НовыйПараметрыЗапросаПолучитьСтатистикуПоисковыхЗапросовSellmonitor();
	ПараметрыЗапроса.УчетнаяЗапись = ИнтеграцияСSellmonitorСервер.ОсновнаяУчетнаяЗапись();
	ПараметрыЗапроса.ВидМаркетплейса = Перечисления.ВидыМаркетплейсов.СервисАналитикиSellmonitor;

	ПараметрыЗапроса.НастройкиПоиска.ВидМаркетплейса = Параметры.ВидМаркетплейса;
	ПараметрыЗапроса.НастройкиПоиска.ИдентификаторКарточкиТовара = Артикул;
	
КонецПроцедуры

&НаСервере
Процедура ПараметрыЗапросаЗаполнитьОписаниеКарточекТоваров(ПараметрыЗапроса)
	
	ВходящиеПараметры = ПараметрыЗапроса;
	
	ПараметрыЗапроса = ИнтеграцияСМаркетплейсамиСИ.НовыйПараметрыЗапросаЗаполнитьОписаниеКарточекТоваров();
	ПараметрыЗапроса.УчетнаяЗапись = ИнтеграцияСSellmonitorСервер.ОсновнаяУчетнаяЗапись();
	ПараметрыЗапроса.ВидМаркетплейса = Перечисления.ВидыМаркетплейсов.СервисАналитикиSellmonitor;
	ПараметрыЗапроса.Аккаунт = Параметры.УчетнаяЗапись;
	ПараметрыЗапроса.ОписаниеКТ = ОписаниеНоменклатуры;
	
	Если ВходящиеПараметры <> Неопределено Тогда
		ИсключитьОсновнуюКарточкуТовара = ВходящиеПараметры.ИсключитьОсновнуюКарточкуТовара;
	Иначе
		ИсключитьОсновнуюКарточкуТовара = Ложь;
	КонецЕсли;
	
	Для Каждого КарточкаТовара Из СписокКТ Цикл
		Если Не ЗначениеЗаполнено(КарточкаТовара.Значение) Тогда
			Продолжить;
		ИначеЕсли ИсключитьОсновнуюКарточкуТовара И КарточкаТовара.Значение = Параметры.ИдентификаторПубликации Тогда
			Продолжить;
		КонецЕсли;
		
		ПараметрыЗапроса.ИдентификаторыПубликацииКТ.Добавить(КарточкаТовара.Значение);
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти

#Область РезультатыДлительныхОпераций

&НаКлиенте
Процедура ОбработатьРезультатДлительныхОпераций(Результат, ДополнительныеПараметры)
	
	Отказ = ТипЗнч(Результат) <> Тип("Структура");
	
	Если Отказ Или Результат.Статус <> "Выполнено" Тогда
		ПослеОбработкиРезультатаДлительныхОпераций(Результат, ДополнительныеПараметры, Истина);
		Возврат;
	КонецЕсли;
	
	Если ДополнительныеПараметры.ОбработкаРезультатаНаСервере Тогда
		РезультатМенеджера = ОбработатьРезультатМенеджераДлительныхОпераций(Результат.АдресРезультата);
	Иначе
		РезультатМенеджера = ПолучитьИзВременногоХранилища(Результат.АдресРезультата);
	КонецЕсли;
	
	Очередь = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(РезультатМенеджера, "Очередь", Новый СписокЗначений);
	
	Для Каждого Операция Из Очередь Цикл
		ИмяМетода = Операция.Представление;
		РезультатОперации = Операция.Значение;
		РезультатОбработки = Истина;
		
		Если ИмяМетода = ИнтеграцияСМаркетплейсамиСИКлиентСервер.МетодЗаполнитьОписаниеКарточекТоваров() Тогда
			ОбработатьРезультатЗаполнитьОписаниеКарточекТоваров(РезультатОперации, РезультатОбработки);
			
			Если РезультатОбработки Тогда
				Закрыть(ОписаниеНоменклатуры);
			КонецЕсли;
			
		КонецЕсли;
	КонецЦикла;
	
	ПослеОбработкиРезультатаДлительныхОпераций(Результат, ДополнительныеПараметры, Отказ);
	
КонецПроцедуры

// Обрабатывает результат менеджера длительных операций на сервере.
// 
// Параметры:
//  АдресРезультата - Строка - Адрес результата
// 
// Возвращаемое значение:
//  Произвольный - Результат обработки
&НаСервере
Функция ОбработатьРезультатМенеджераДлительныхОпераций(Знач АдресРезультата)
	
	РезультатМенеджера = ПолучитьИзВременногоХранилища(АдресРезультата);
	УдалитьИзВременногоХранилища(АдресРезультата);
	
	Очередь = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(РезультатМенеджера, "Очередь", Новый СписокЗначений);
	РезультатМенеджера.Вставить("КодСостояния", 200);
	
	Для Каждого Операция Из Очередь Цикл
		
		ИмяМетода = Операция.Представление;
		РезультатОперации = Операция.Значение;
		РезультатОбработки = Истина;
		
		Если ИмяМетода = ИнтеграцияСМаркетплейсамиСИКлиентСервер.МетодСгенерироватьОписаниеКарточкиТовараВSellmonitor() Тогда
			ОбработатьРезультатСгенерироватьОписаниеКарточкиТовараВSellmonitor(РезультатОперации, РезультатОбработки);
		ИначеЕсли ИмяМетода = ИнтеграцияСМаркетплейсамиСИКлиентСервер.МетодПолучитьСтатистикуПоисковыхЗапросовSellmonitor() Тогда
			ОбработатьРезультатПолучитьСтатистикуПоисковыхЗапросовSellmonitor(РезультатОперации, РезультатОбработки);
		КонецЕсли;
		
		Если РезультатОперации.КодСостояния <> 200 Тогда
			РезультатМенеджера.КодСостояния = РезультатОперации.КодСостояния;
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат РезультатМенеджера;
	
КонецФункции

&НаКлиенте
Процедура ПослеОбработкиРезультатаДлительныхОпераций(Результат, ДополнительныеПараметры, Отказ)
	
	ИнтеграцияСМаркетплейсамиСИКлиент.ПослеОбработкиРезультатаДлительныхОпераций(Результат, ДополнительныеПараметры);
	
КонецПроцедуры

&НаСервере
Процедура ОбработатьРезультатСгенерироватьОписаниеКарточкиТовараВSellmonitor(РезультатОперации, РезультатОбработки)
	
	Если РезультатОперации = Неопределено Тогда
		РезультатОбработки = Ложь;
		Возврат;
	КонецЕсли;
	
	Если РезультатОперации.КодСостояния <> 200 И РезультатОперации.Ошибки.Количество() > 0 Тогда
		Для Каждого Ошибка Из РезультатОперации.Ошибки Цикл
			ОбщегоНазначения.СообщитьПользователю(Ошибка);
		КонецЦикла;
		РезультатОбработки = Ложь;
		Возврат;
	КонецЕсли;
	
	ОписаниеНоменклатуры = РезультатОперации["Описание"];
	
КонецПроцедуры

&НаСервере
Процедура ОбработатьРезультатПолучитьСтатистикуПоисковыхЗапросовSellmonitor(РезультатОперации, РезультатОбработки)
	
	Если РезультатОперации = Неопределено Тогда
		РезультатОбработки = Ложь;
		Возврат;
	КонецЕсли;
	
	Если РезультатОперации.КодСостояния <> 200 И РезультатОперации.Ошибки.Количество() > 0 Тогда
		Для Каждого Ошибка Из РезультатОперации.Ошибки Цикл
			ОбщегоНазначения.СообщитьПользователю(Ошибка);
		КонецЦикла;
		РезультатОбработки = Ложь;
		Возврат;
	КонецЕсли;
	
	КлючевыеСловаСервиса = РезультатОперации.КлючевыеСлова;
	
	Для Каждого ОписаниеКС Из КлючевыеСловаСервиса Цикл
		СтруктураПоиска = Новый Структура("Слово", ОписаниеКС.Слово);
		НайденныеСтроки = КлючевыеСлова.НайтиСтроки(СтруктураПоиска);
		Если НайденныеСтроки.Количество() = 0 Тогда
			ТекущаяСтрока = КлючевыеСлова.Добавить();
			ТекущаяСтрока.Слово = ОписаниеКС.Слово;
		Иначе
			ТекущаяСтрока = НайденныеСтроки[0];
		КонецЕсли;
		
		ТекущаяСтрока.Частота = ОписаниеКС.Частота;
		
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработатьРезультатЗаполнитьОписаниеКарточекТоваров(РезультатОперации, РезультатОбработки)
	
	Если РезультатОперации = Неопределено Тогда
		РезультатОбработки = Ложь;
		Возврат;
	КонецЕсли;
	
	Если РезультатОперации.Ошибки.Количество() > 0 Тогда
		Для Каждого Ошибка Из РезультатОперации.Ошибки Цикл
			ОбщегоНазначенияКлиент.СообщитьПользователю(Ошибка);
		КонецЦикла;
		РезультатОбработки = Ложь;
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#КонецОбласти

&НаСервере
Процедура ЗаполнитьСпискиВыбора()
	
	СписокВыбора = Элементы.ЯзыкТекста.СписокВыбора;
	СписокВыбора.Добавить("ru", НСтр("ru = 'Русский'"));
	СписокВыбора.Добавить("en", НСтр("ru = 'Английский'"));
	
	СписокВыбора = Элементы.СтрогостьВключенияКлючевыхСлов.СписокВыбора;
	СписокВыбора.Добавить("strict", НСтр("ru = 'Строго'"));
	СписокВыбора.Добавить("medium", НСтр("ru = 'Средне'"));
	СписокВыбора.Добавить("loose", НСтр("ru = 'Свободно'"));
	
	СписокВыбора = Элементы.Тон.СписокВыбора;
	СписокВыбора.Добавить("professional", НСтр("ru = 'Профессиональный'"));
	СписокВыбора.Добавить("friendly", НСтр("ru = 'Дружелюбный'"));
	СписокВыбора.Добавить("luxury", НСтр("ru = 'Изысканный'"));
	
КонецПроцедуры

&НаКлиенте
Процедура ПриЗавершенииНастройкиОтбораКТ(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если ТипЗнч(Результат) = Тип("Соответствие") Тогда
		Для Каждого КлючЗначение Из Результат Цикл
			Если СписокКТ.НайтиПоЗначению(КлючЗначение.Ключ) = Неопределено Тогда
				СписокКТ.Добавить(КлючЗначение.Ключ, КлючЗначение.Значение);
			КонецЕсли;
		КонецЦикла;
	Иначе
		ПолучитьКарточкиТоваровПоФильтру(Результат, КомпоновщикНастроекПодбораКТ, СписокКТ);
	КонецЕсли;
	
	Элементы.СписокКТ.ПодсказкаВвода = ?(СписокКТ.Количество()=0, НСтр("ru = 'Укажите карточку товара'"), "");
	
КонецПроцедуры

&НаСервереБезКонтекста
Процедура ПолучитьКарточкиТоваровПоФильтру(НастройкиОтбор, КомпоновщикНастроекПодбораКТ, СписокКТ)
	
	СхемаКомпоновки = Обработки.СервисSellmonitor.ПолучитьМакет("ПодборКарточекТоваров_OZON");
	
	КомпоновщикНастроекПодбораКТ.Настройки.Отбор.Элементы.Очистить();

	Для Каждого ЭлементОтбораИсточник Из НастройкиОтбор.Отбор["Элементы"] Цикл
		ЭлементОтбораПриемник = КомпоновщикНастроекПодбораКТ.Настройки.Отбор.Элементы.Добавить(ТипЗнч(ЭлементОтбораИсточник));
		ЗаполнитьЗначенияСвойств(ЭлементОтбораПриемник, ЭлементОтбораИсточник);
	КонецЦикла;
	
	КомпоновщикМакета = Новый КомпоновщикМакетаКомпоновкиДанных;
	МакетКомпоновки = КомпоновщикМакета.Выполнить(СхемаКомпоновки, КомпоновщикНастроекПодбораКТ.ПолучитьНастройки(),,,Тип("ГенераторМакетаКомпоновкиДанныхДляКоллекцииЗначений"));
	
	ПроцессорКомпоновки = Новый ПроцессорКомпоновкиДанных;
	ПроцессорКомпоновки.Инициализировать(МакетКомпоновки);

	Данные = Новый ТаблицаЗначений;
	
	ПроцессорВывода = Новый ПроцессорВыводаРезультатаКомпоновкиДанныхВКоллекциюЗначений;
	ПроцессорВывода.УстановитьОбъект(Данные);
	ПроцессорВывода.Вывести(ПроцессорКомпоновки);
	
	Для Каждого СтрокаТаблицы Из Данные Цикл
		СписокКТ.Добавить(СтрокаТаблицы.ИдентификаторПубликации, СтрокаТаблицы.НаименованиеМП);
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура ИзменитьВидимостьПодсказки(ВидимостьПодсказки)
	
	Если ЭтоНоваяКТ Тогда
		ИмяГруппыПодсказки = "ГруппаОписаниеНовойНоменклатурыПодсказка";
	Иначе
		ИмяГруппыПодсказки = "ГруппаОписаниеСуществующейНоменклатурыПодсказка";
	КонецЕсли;

	Элементы[ИмяГруппыПодсказки].Видимость = ВидимостьПодсказки;
	
КонецПроцедуры

#КонецОбласти
