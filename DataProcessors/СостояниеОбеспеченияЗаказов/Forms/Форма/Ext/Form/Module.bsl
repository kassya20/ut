		Элемент.Оформление.УстановитьЗначениеПараметра("Текст", ТекстНеопределена);
		
	КонецЕсли;
	
	#КонецОбласти
	
	// Надпись "<не определено>" в поле "Контроль качества", если не установлен основной способ обеспечения, не заполнен календарь или не установлена дата следующей поставки по графику
	#Область ЭлементОформления
	
	Если Не АвторизованВнешнийПользователь Тогда
		
		Элемент = СписокУсловноеОформление.Элементы.Добавить();
		Элемент.Представление = НСтр("ru = 'Надпись ""<не определено>"" в поле ""Контроль качества"", если не установлен основной способ обеспечения, не заполнен календарь или не установлена дата следующей поставки по графику'");
		
