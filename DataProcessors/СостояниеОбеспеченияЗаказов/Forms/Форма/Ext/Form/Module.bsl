&НаСервере
Процедура УстановитьУсловноеОформлениеСписка(СписокУсловноеОформление, ПутиКДанным, ИменаПолей)
	
	ЗначенияНаСогласованииИлиНеОбеспечен = Новый СписокЗначений();
	ЗначенияНаСогласованииИлиНеОбеспечен.Добавить(Перечисления.СостоянияЗапаса.НаСогласованииПоставки);
	ЗначенияНаСогласованииИлиНеОбеспечен.Добавить(Перечисления.СостоянияЗапаса.НеОбеспечен);
	
	ЗначенияВНаличии = Новый СписокЗначений();
	ЗначенияВНаличии.Добавить(Перечисления.СостоянияЗапаса.ВНаличии);
	ЗначенияВНаличии.Добавить(Перечисления.СостоянияЗапаса.ВНаличииОжидаетсяРазблокировка);
	ЗначенияВНаличии.Добавить(Перечисления.СостоянияЗапаса.ВНаличииНеПодлежитРазблокировке);
	
	ЗначенияНеНаКонтроле = Новый СписокЗначений();
	ЗначенияНеНаКонтроле.Добавить(Перечисления.СостоянияЗапаса.ВНаличии);
	ЗначенияНеНаКонтроле.Добавить(Перечисления.СостоянияЗапаса.ОжидаетсяКПоступлению);
	ЗначенияНеНаКонтроле.Добавить(Перечисления.СостоянияЗапаса.НаСогласованииПоставки);
	ЗначенияНеНаКонтроле.Добавить(Перечисления.СостоянияЗапаса.НеОбеспечен);
	
	СписокУсловноеОформление.Элементы.Очистить();
	
	// Надпись "Не требуется" в поле "Контроль качества".
	#Область ЭлементОформления
	Элемент = СписокУсловноеОформление.Элементы.Добавить();
	Элемент.Представление = НСтр("ru = 'Надпись ""<не требуется>"" в поле ""Контроль качества""'");
	
	ПолеЭлемента = Элемент.Поля.Элементы.Добавить();
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(ИменаПолей.КонтрольКачества);
	
	ОтборЭлемента = Элемент.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ОтборЭлемента.ЛевоеЗначение = Новый ПолеКомпоновкиДанных(ПутиКДанным.КонтролироватьКачествоПоступившегоТовара);
	ОтборЭлемента.ВидСравнения = ВидСравненияКомпоновкиДанных.Равно;
	ОтборЭлемента.ПравоеЗначение = Ложь;
	
	ОтборЭлемента = Элемент.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ОтборЭлемента.ЛевоеЗначение = Новый ПолеКомпоновкиДанных(ПутиКДанным.СостояниеЗапаса);
	ОтборЭлемента.ВидСравнения = ВидСравненияКомпоновкиДанных.ВСписке;
	ОтборЭлемента.ПравоеЗначение = ЗначенияНеНаКонтроле;
	
	Элемент.Оформление.УстановитьЗначениеПараметра("Текст", НСтр("ru = '<не требуется>'"));
	
	#КонецОбласти
	
	// Надпись "Пройден" в поле "Контроль качества".
