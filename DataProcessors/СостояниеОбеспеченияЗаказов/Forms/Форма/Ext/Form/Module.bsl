		|		ЗНАЧЕНИЕ(Перечисление.ХарактеристикиПотребности.КОбеспечению) КАК ХарактеристикаПотребности
		|	
		|	ОБЪЕДИНИТЬ ВСЕ
		|	
		|	ВЫБРАТЬ
		|		ЗНАЧЕНИЕ(Перечисление.РаспределениеЗапасовСостояния.ОжидаетсяПоНеподтвержденномуЗаказу) КАК Состояние,
		|		ЗНАЧЕНИЕ(Перечисление.СостоянияЗапаса.НаСогласованииПоставки) КАК СостояниеЗапаса,
		|		ЗНАЧЕНИЕ(Перечисление.ХарактеристикиПотребности.РезервироватьПоМереПоступления) КАК ХарактеристикаПотребности
		|	
		|	ОБЪЕДИНИТЬ ВСЕ
		|	
		|	ВЫБРАТЬ
		|		ЗНАЧЕНИЕ(Перечисление.РаспределениеЗапасовСостояния.ОжидаетсяПоНеподтвержденномуЗаказу) КАК Состояние,
		|		ЗНАЧЕНИЕ(Перечисление.СостоянияЗапаса.НаСогласованииПоставки) КАК СостояниеЗапаса,
		|		ЗНАЧЕНИЕ(Перечисление.ХарактеристикиПотребности.РезервироватьПоМереПоступленияИзЗаблокированных) КАК ХарактеристикаПотребности
		|	
		|	ОБЪЕДИНИТЬ ВСЕ
		|	
		|	ВЫБРАТЬ
		|		ЗНАЧЕНИЕ(Перечисление.РаспределениеЗапасовСостояния.ОжидаетсяПоНеподтвержденномуЗаказу) КАК Состояние,
		|		ЗНАЧЕНИЕ(Перечисление.СостоянияЗапаса.НаСогласованииПоставки) КАК СостояниеЗапаса,
		|		ЗНАЧЕНИЕ(Перечисление.ХарактеристикиПотребности.ОтложитьРезервирование) КАК ХарактеристикаПотребности
		|	
		|	ОБЪЕДИНИТЬ ВСЕ
		|	
		|	ВЫБРАТЬ
		|		ЗНАЧЕНИЕ(Перечисление.РаспределениеЗапасовСостояния.ОжидаетсяПоНеподтвержденномуЗаказу) КАК Состояние,
		|		ЗНАЧЕНИЕ(Перечисление.СостоянияЗапаса.НаСогласованииПоставки) КАК СостояниеЗапаса,
		|		ЗНАЧЕНИЕ(Перечисление.ХарактеристикиПотребности.КОбеспечению) КАК ХарактеристикаПотребности
		|	
		|	ОБЪЕДИНИТЬ ВСЕ
		|	
		|	ВЫБРАТЬ
		|		ЗНАЧЕНИЕ(Перечисление.РаспределениеЗапасовСостояния.Обеспечить) КАК Состояние,
		|		ЗНАЧЕНИЕ(Перечисление.СостоянияЗапаса.НеОбеспечен) КАК СостояниеЗапаса,
		|		ЗНАЧЕНИЕ(Перечисление.ХарактеристикиПотребности.РезервироватьПоМереПоступления) КАК ХарактеристикаПотребности
		|	
		|	ОБЪЕДИНИТЬ ВСЕ
		|	
		|	ВЫБРАТЬ
		|		ЗНАЧЕНИЕ(Перечисление.РаспределениеЗапасовСостояния.Обеспечить) КАК Состояние,
		|		ЗНАЧЕНИЕ(Перечисление.СостоянияЗапаса.НеОбеспечен) КАК СостояниеЗапаса,
		|		ЗНАЧЕНИЕ(Перечисление.ХарактеристикиПотребности.РезервироватьПоМереПоступленияИзЗаблокированных) КАК ХарактеристикаПотребности
		|	
		|	ОБЪЕДИНИТЬ ВСЕ
		|	
		|	ВЫБРАТЬ
		|		ЗНАЧЕНИЕ(Перечисление.РаспределениеЗапасовСостояния.Обеспечить) КАК Состояние,
		|		ЗНАЧЕНИЕ(Перечисление.СостоянияЗапаса.НеОбеспечен) КАК СостояниеЗапаса,
		|		ЗНАЧЕНИЕ(Перечисление.ХарактеристикиПотребности.ОтложитьРезервирование) КАК ХарактеристикаПотребности
		|	
		|	ОБЪЕДИНИТЬ ВСЕ
		|	
		|	ВЫБРАТЬ
		|		ЗНАЧЕНИЕ(Перечисление.РаспределениеЗапасовСостояния.Обеспечить) КАК Состояние,
		|		ЗНАЧЕНИЕ(Перечисление.СостоянияЗапаса.НеОбеспечен) КАК СостояниеЗапаса,
		|		ЗНАЧЕНИЕ(Перечисление.ХарактеристикиПотребности.КОбеспечению) КАК ХарактеристикаПотребности
		|	
		|	ОБЪЕДИНИТЬ ВСЕ
		|	
		|	ВЫБРАТЬ
		|		ЗНАЧЕНИЕ(Перечисление.РаспределениеЗапасовСостояния.НеОбеспечивать) КАК Состояние,
		|		ЗНАЧЕНИЕ(Перечисление.СостоянияЗапаса.НеОбеспечен) КАК СостояниеЗапаса,
		|		ЗНАЧЕНИЕ(Перечисление.ХарактеристикиПотребности.НеОбеспечивать) КАК ХарактеристикаПотребности) КАК Набор
		|ГДЕ
		|	Набор.Состояние В(&ОтборСостояний)
		|ИНДЕКСИРОВАТЬ ПО
		|	СостояниеЗапаса, ХарактеристикаПотребности";
	
	Возврат ТекстЗапроса;
	
КонецФункции

&НаСервере
Функция ПараметрыЗапроса()
	
	ОтборСостояний = Новый Массив();
	
	Ожидается = Ложь;
	ОжидаетсяНеВСрок = Ложь;
	ОбеспеченКДатеДобавлен = Ложь;
	Для Каждого Элемент Из ОтобранныеСостояния Цикл
		
		Если Не Элемент.Пометка Тогда
			Продолжить;
		КонецЕсли;
		
		Если Элемент.Значение = Перечисления.РаспределениеЗапасовСостояния.ОбеспеченКДате Тогда
			
			Ожидается = Ожидается Или Элемент.Представление = НСтр("ru = 'Ожидается'");
			ОжидаетсяНеВСрок = ОжидаетсяНеВСрок Или Элемент.Представление = НСтр("ru = 'Ожидается не в срок'");
			
			Если ОбеспеченКДатеДобавлен Тогда
				Продолжить;
			КонецЕсли;
			ОбеспеченКДатеДобавлен = Истина;
			ОтборСостояний.Добавить(Перечисления.РаспределениеЗапасовСостояния.ОжидаетсяПоНеподтвержденномуЗаказу);
			
		КонецЕсли;
		ОтборСостояний.Добавить(Элемент.Значение);
		
	КонецЦикла;
	
	ПараметрыЗапроса = Новый Структура();
	ПараметрыЗапроса.Вставить("ОтборСостояний", ОтборСостояний);
	ПараметрыЗапроса.Вставить("Ожидается", Ожидается);
	ПараметрыЗапроса.Вставить("ОжидаетсяНеВСрок", ОжидаетсяНеВСрок);
	ПараметрыЗапроса.Вставить("ТекущийЗаказ", Параметры.Заказ);
	ПараметрыЗапроса.Вставить("НадписьЗаказ", НСтр("ru = 'Заказ'"));
	ПараметрыЗапроса.Вставить("НачалоЭтогоДня", НачалоДня(ТекущаяДатаСеанса()));
	ПараметрыЗапроса.Вставить("НадписьТекущийЗаказ", НСтр("ru = 'Текущий заказ'"));
	ПараметрыЗапроса.Вставить("ЗаказНаОтгрузку", Параметры.Заказ);
	ПараметрыЗапроса.Вставить("ЗаказыНаОтгрузку", Параметры.Заказы);
	
	Возврат ПараметрыЗапроса;
	
КонецФункции

&НаКлиенте
Процедура Подключаемый_СписокПриАктивизацииСтроки()
	
	ТекущиеДанные = Элементы.Список.ТекущиеДанные;
	Если ТекущиеДанные <> Неопределено Тогда
		
		Результат = СписокПриАктивизацииСтрокиНаСервере(
			?(ТекущиеДанные.Свойство("Номенклатура"), ТекущиеДанные.Номенклатура, Неопределено),
			?(ТекущиеДанные.Свойство("Характеристика"), ТекущиеДанные.Характеристика, Неопределено),
			?(ТекущиеДанные.Свойство("Склад"), ТекущиеДанные.Склад, Неопределено),
			?(ТекущиеДанные.Свойство("Назначение"), ТекущиеДанные.Назначение, Неопределено),
			?(ТекущиеДанные.Свойство("ЕдиницаИзмерения"), ТекущиеДанные.ЕдиницаИзмерения, Неопределено));
			
		ЗаполнитьЗначенияСвойств(ЭтотОбъект, Результат);
		Элементы.НадписьТовар.Заголовок = Результат.НадписьТовар;
		ЭтоРабота = ТекущиеДанные.Свойство("ТипНоменклатуры")
			И ТекущиеДанные.ТипНоменклатуры = ПредопределенноеЗначение("Перечисление.ТипыНоменклатуры.Работа");
		Элементы.СтраницыПодвалЗаголовокНаСкладе.ТекущаяСтраница = ?(ЭтоРабота,
			Элементы.СтраницаПодвалЗаголовокВПодразделении,
			Элементы.СтраницаПодвалЗаголовокНаСкладеВТомЧислеНаКонтролеКачества);
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция СписокПриАктивизацииСтрокиНаСервере(Номенклатура, Характеристика, Склад, Назначение, ЕдиницаИзмерения)
	
	ТекстыЗапросов = Новый Массив();
	ТекстыЗапросов.Добавить(
		"ВЫБРАТЬ
		|	Таблица.Наименование КАК Наименование
		|ИЗ
		|	Справочник.Номенклатура КАК Таблица
		|ГДЕ
		|	Таблица.Ссылка = &Номенклатура");
	ТекстыЗапросов.Добавить(
		"ВЫБРАТЬ
		|	Таблица.Наименование КАК Наименование
		|ИЗ
		|	Справочник.ХарактеристикиНоменклатуры КАК Таблица
		|ГДЕ
		|	Таблица.Ссылка = &Характеристика");
	ТекстыЗапросов.Добавить(
		"ВЫБРАТЬ
		|	Таблица.Наименование КАК Наименование
		|ИЗ
		|	Справочник.Склады КАК Таблица
		|ГДЕ
		|	Таблица.Ссылка = &Склад");
	ТекстыЗапросов.Добавить(
		"ВЫБРАТЬ
		|	Таблица.Наименование КАК Наименование
		|ИЗ
		|	Справочник.УпаковкиЕдиницыИзмерения КАК Таблица
		|ГДЕ
		|	Таблица.Ссылка = &ЕдиницаИзмерения");
	
	ТекстЗапроса =
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	Запасы.Номенклатура КАК Номенклатура,
		|	Запасы.Характеристика КАК Характеристика,
		|	Запасы.Склад КАК Склад,
		|	Запасы.Назначение КАК Назначение,
		|	Запасы.Заказ КАК Заказ,
		|	Запасы.ЗаблокированоВНаличииОстаток КАК ЗаблокированоВНаличииОстаток,
		|	Запасы.ЗаблокированоПоступитОстаток КАК ЗаблокированоПоступитОстаток,
		|	Запасы.КРазблокировкеОстаток КАК КРазблокировкеОстаток,
		|	Запасы.РезервироватьНаСкладеИзЗаблокированныхОстаток КАК РезервироватьНаСкладеИзЗаблокированныхОстаток,
		|	Запасы.РезервироватьПоМереПоступленияИзЗаблокированныхОстаток КАК РезервироватьПоМереПоступленияИзЗаблокированныхОстаток
		|ПОМЕСТИТЬ ЗапасыИПотребностиОстаткиКонтролируемыхПартий
		|ИЗ
		|	РегистрНакопления.ЗапасыИПотребности.Остатки(,
		|		Номенклатура = &Номенклатура
		|		И Характеристика = &Характеристика
		|		И Склад = &Склад) КАК Запасы
		|ИНДЕКСИРОВАТЬ ПО
		|	Номенклатура, Характеристика, Склад, Назначение
		|;
		|
		|/////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	Запасы.Номенклатура КАК Номенклатура,
		|	Запасы.Характеристика КАК Характеристика,
		|	Запасы.Склад КАК Склад,
		|	Запасы.Назначение КАК Назначение,
		|	Запасы.ВНаличииОстаток КАК ВНаличииОстаток,
		|	Запасы.ЗаблокированоВНаличииОстаток КАК ЗаблокированоВНаличииОстаток,
		|	Запасы.ЗаказаноОстаток КАК ЗаказаноОстаток,
		|	Запасы.ПоступитОстаток КАК ПоступитОстаток,
		|	Запасы.ЗаблокированоПоступитОстаток КАК ЗаблокированоПоступитОстаток,
		|	Запасы.РезервироватьНаСкладеОстаток КАК РезервироватьНаСкладеОстаток,
		|	Запасы.РезервироватьПоМереПоступленияОстаток КАК РезервироватьПоМереПоступленияОстаток,
		|	Запасы.ОтложитьРезервированиеОстаток КАК ОтложитьРезервированиеОстаток,
		|	Запасы.КОбеспечениюОстаток КАК КОбеспечениюОстаток,
		|	Запасы.НеОбеспечиватьОстаток КАК НеОбеспечиватьОстаток
		|ПОМЕСТИТЬ ЗапасыИПотребностиОстатки
		|ИЗ
		|	РегистрНакопления.ЗапасыИПотребности.Остатки(,
		|		Номенклатура = &Номенклатура
		|		И Характеристика = &Характеристика
		|		И Склад = &Склад) КАК Запасы
		|ИНДЕКСИРОВАТЬ ПО
		|	Номенклатура, Характеристика, Склад, Назначение
		|;
		|
		|/////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Расчет.Номенклатура КАК Номенклатура,
		|	Расчет.Характеристика КАК Характеристика,
		|	Расчет.Склад КАК Склад,
		|	СУММА(Расчет.КоличествоБезКонтроляРезервовДляДействияОтгрузить) КАК ИтогНаСкладеСПодтвержденнымКачеством,
		|	СУММА(Расчет.КоличествоВНаличии) КАК ИтогНаСкладе,
		|	СУММА(Расчет.КоличествоВНаличииИОжидается) КАК ИтогПоГрафику,
		|	СУММА(ВЫБОР
		|		КОГДА Расчет.Назначение В (ЗНАЧЕНИЕ(Справочник.Назначения.ПустаяСсылка), &Назначение)
		|			ТОГДА Расчет.КоличествоДляДействияОтгрузить
		|		ИНАЧЕ 0
		|	КОНЕЦ) КАК ИтогДоступноНаСкладеСПодтвержденнымКачеством,
		|	СУММА(ВЫБОР
		|		КОГДА Расчет.Назначение В (ЗНАЧЕНИЕ(Справочник.Назначения.ПустаяСсылка), &Назначение)
		|			ТОГДА Расчет.КоличествоНаСкладеДляДействияРезервироватьПоМереПоступления
		|		ИНАЧЕ 0
		|	КОНЕЦ) КАК ИтогДоступноНаСкладе,
		|	СУММА(ВЫБОР
		|		КОГДА Расчет.Назначение В (ЗНАЧЕНИЕ(Справочник.Назначения.ПустаяСсылка), &Назначение)
		|			ТОГДА Расчет.КоличествоДляДействияРезервироватьПоМереПоступления
		|		ИНАЧЕ 0
		|	КОНЕЦ) КАК ИтогДоступноПоГрафику
		|ИЗ
		|	РасчетОстатковДляУстановкиДействий КАК Расчет
		|СГРУППИРОВАТЬ ПО
		|	Расчет.Номенклатура,
		|	Расчет.Характеристика,
		|	Расчет.Склад";
	
	ИменаТаблиц = ОбеспечениеВДокументахСервер.НовыеИменаТаблицДляРасчетаОстатковДляУстановкиДействий();
	ИменаТаблиц.Остатки = "ЗапасыИПотребностиОстатки"; // @query-part-1
	ИменаТаблиц.ОстаткиКонтролируемыхПартий = "ЗапасыИПотребностиОстаткиКонтролируемыхПартий"; // @query-part-1
	ИменаТаблиц.Результат = "РасчетОстатковДляУстановкиДействий"; // @query-part-1
	ОбеспечениеВДокументахСервер.РасчетОстатковДляУстановкиДействий(ТекстЗапроса, ИменаТаблиц, Истина, Ложь);
	
	ТекстыЗапросов.Добавить(ТекстЗапроса);
	
	Запрос = Новый Запрос();
	Запрос.Текст = СтрСоединить(ТекстыЗапросов, ОбщегоНазначения.РазделительПакетаЗапросов());
	Запрос.УстановитьПараметр("Номенклатура",     Номенклатура);
	Запрос.УстановитьПараметр("Характеристика",   Характеристика);
	Запрос.УстановитьПараметр("Склад",            Склад);
	Запрос.УстановитьПараметр("Назначение",       Назначение);
	Запрос.УстановитьПараметр("ЕдиницаИзмерения", ЕдиницаИзмерения);
	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц();
	РезультатВыполнения = Запрос.ВыполнитьПакет();
	
	ЭлементыНадписи = Новый Массив();
	Выборка = РезультатВыполнения[0].Выбрать();
	Если Выборка.Следующий() Тогда
		ЭлементыНадписи.Добавить(Выборка.Наименование);
	КонецЕсли;
	Выборка = РезультатВыполнения[1].Выбрать();
	Если Выборка.Следующий() Тогда
		ЭлементыНадписи.Добавить(Выборка.Наименование);
	КонецЕсли;
	Выборка = РезультатВыполнения[2].Выбрать();
	Если Выборка.Следующий() Тогда
		ЭлементыНадписи.Добавить(Выборка.Наименование);
	КонецЕсли;
	
	Результат = Новый Структура();
	Результат.Вставить("НадписьТовар", НСтр("ru = 'Позиция заказа:'") + Символы.НПП + СтрСоединить(ЭлементыНадписи, ", "));
	Результат.Вставить("ИтогНаСкладеСПодтвержденнымКачеством", 0);
	Результат.Вставить("ИтогНаСкладе", 0);
	Результат.Вставить("ИтогПоГрафику", 0);
	Результат.Вставить("ИтогДоступноНаСкладеСПодтвержденнымКачеством", 0);
	Результат.Вставить("ИтогДоступноНаСкладе", 0);
	Результат.Вставить("ИтогДоступноПоГрафику", 0);
	Результат.Вставить("ИтогВРезервеНаСкладеСПодтвержденнымКачеством", 0);
	Результат.Вставить("ИтогВРезервеНаСкладе", 0);
	Результат.Вставить("ИтогВРезервеПоГрафику", 0);
	Результат.Вставить("ЕдиницаИзмерения", "");
	
	Выборка = РезультатВыполнения[3].Выбрать();
	Если Выборка.Следующий() Тогда
		Результат.Вставить("ЕдиницаИзмерения", Выборка.Наименование);
	КонецЕсли;
	
	Выборка = РезультатВыполнения[РезультатВыполнения.ВГраница()].Выбрать();
	Если Выборка.Следующий() Тогда
		
		ЗаполнитьЗначенияСвойств(Результат, Выборка);
		
		Результат.ИтогДоступноНаСкладеСПодтвержденнымКачеством = Макс(Результат.ИтогДоступноНаСкладеСПодтвержденнымКачеством, 0);
		Результат.ИтогДоступноНаСкладе = Макс(Результат.ИтогДоступноНаСкладе, 0);
		Результат.ИтогДоступноПоГрафику = Макс(Результат.ИтогДоступноПоГрафику, 0);
		
		Результат.ИтогНаСкладеСПодтвержденнымКачеством = Макс(Результат.ИтогНаСкладеСПодтвержденнымКачеством, 0);
		Результат.ИтогНаСкладе = Макс(Результат.ИтогНаСкладе, 0);
		Результат.ИтогПоГрафику = Макс(Результат.ИтогПоГрафику, 0);
		
		Результат.ИтогВРезервеНаСкладеСПодтвержденнымКачеством = Результат.ИтогНаСкладеСПодтвержденнымКачеством
			- Результат.ИтогДоступноНаСкладеСПодтвержденнымКачеством;
		Результат.ИтогВРезервеНаСкладе = Результат.ИтогНаСкладе
			- Результат.ИтогДоступноНаСкладе;
		Результат.ИтогВРезервеПоГрафику = Результат.ИтогПоГрафику
			- Результат.ИтогДоступноПоГрафику;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

&НаКлиенте
Процедура СписокВыборНаКлиенте(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	Если Элемент.ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	СтандартнаяОбработка = Ложь;
	Данные = Неопределено;
	
	Если СтрНайти(Поле.Имя, "ЗаказНаОтгрузку") > 0
			И Элемент.ТекущиеДанные.Свойство("ЗаказНаОтгрузку") Тогда
		
		Данные = Элемент.ТекущиеДанные.ЗаказНаОтгрузку;
		
	ИначеЕсли СтрНайти(Поле.Имя, "ЗаказНаПоступление") > 0
				И Элемент.ТекущиеДанные.Свойство("ЗаказНаПоступление") Тогда
		
		Данные = Элемент.ТекущиеДанные.ЗаказНаПоступление;
		Если Не ЗначениеЗаполнено(Данные) И Элемент.ТекущиеДанные.Свойство("СпособОбеспечения") Тогда
			Данные = Элемент.ТекущиеДанные.СпособОбеспечения;
		ИначеЕсли ЗначениеЗаполнено(Данные) И ТипЗнч(Данные) = Тип("СправочникСсылка.КонтролируемыеПартии") Тогда
			Данные = РеквизитПартия(Данные);
		КонецЕсли;
		
	ИначеЕсли СтрНайти(Поле.Имя, "СпособОбеспеченияНаименование") > 0
				И Элемент.ТекущиеДанные.Свойство("СпособОбеспечения") Тогда
		
		Данные = Элемент.ТекущиеДанные.СпособОбеспечения;
		Если Не ЗначениеЗаполнено(Данные) И Элемент.ТекущиеДанные.Свойство("ЗаказНаПоступление") Тогда
			Данные = Элемент.ТекущиеДанные.ЗаказНаПоступление;
		КонецЕсли;
		
	ИначеЕсли СтрНайти(Поле.Имя, "Номенклатура") > 0
				И Элемент.ТекущиеДанные.Свойство("Номенклатура") Тогда
		
		Данные = Элемент.ТекущиеДанные.Номенклатура;
		
	ИначеЕсли СтрНайти(Поле.Имя, "Характеристика") > 0
				И Элемент.ТекущиеДанные.Свойство("Характеристика") Тогда
		
		Данные = Элемент.ТекущиеДанные.Характеристика;
		
	ИначеЕсли СтрНайти(Поле.Имя, "Склад") > 0
				И Элемент.ТекущиеДанные.Свойство("Склад") Тогда
		
		Данные = Элемент.ТекущиеДанные.Склад;
		
	ИначеЕсли СтрНайти(Поле.Имя, "Назначение") > 0
				И Элемент.ТекущиеДанные.Свойство("ЗаказНазначения") Тогда
		
		Данные = Элемент.ТекущиеДанные.ЗаказНазначения;
		Если Не ЗначениеЗаполнено(Данные) И Элемент.ТекущиеДанные.Свойство("Назначение") Тогда
			Данные = Элемент.ТекущиеДанные.Назначение;
		КонецЕсли;
		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Данные) Тогда
		ПоказатьЗначение(, Данные);
	КонецЕсли;
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция РеквизитПартия(Данные)
	
	УстановитьПривилегированныйРежим(Истина);
	Партия = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Данные, "Партия");
	УстановитьПривилегированныйРежим(Ложь);
	Возврат Партия;
	
КонецФункции

&НаСервереБезКонтекста
Процедура ПриПолученииДанныхНаСервере(ИмяЭлемента, Настройки, Строки)
	
	Таблица = Новый ТаблицаЗначений();
	Таблица.Колонки.Добавить("Номенклатура", Новый ОписаниеТипов("СправочникСсылка.Номенклатура"));
	Таблица.Колонки.Добавить("Характеристика", Новый ОписаниеТипов("СправочникСсылка.ХарактеристикиНоменклатуры"));
	Таблица.Колонки.Добавить("Склад", Новый ОписаниеТипов("СправочникСсылка.Склады"));
	Таблица.Колонки.Добавить("Назначение", Новый ОписаниеТипов("СправочникСсылка.Назначения"));
	Таблица.Колонки.Добавить("ЗаказНаОтгрузку", Метаданные.ОпределяемыеТипы.ОжидаемаяОтгрузка.Тип);
	Таблица.Колонки.Добавить("СостояниеЗапаса", Новый ОписаниеТипов("ПеречислениеСсылка.СостоянияЗапаса"));
	Таблица.Колонки.Добавить("ХарактеристикаПотребности", Новый ОписаниеТипов("ПеречислениеСсылка.ХарактеристикиПотребности"));
	Таблица.Колонки.Добавить("Индекс", Новый ОписаниеТипов("Число"));
	Таблица.Колонки.Добавить("Действие", Новый ОписаниеТипов("ПеречислениеСсылка.ВариантыОбеспечения"));
	Таблица.Колонки.Добавить("КонтролироватьКачествоПоступившегоТовара", Новый ОписаниеТипов("Булево"));
	Таблица.Колонки.Добавить("КонтрольКачества", Новый ОписаниеТипов("Дата"));
	
	Индекс = 0;
	Ключи = Новый Массив();
	Для Каждого Строка Из Строки Цикл
		НоваяСтрока = Таблица.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, Строка.Значение.Данные);
		НоваяСтрока.Индекс = Индекс;
		Ключи.Добавить(Строка.Ключ);
		Индекс = Индекс + 1;
	КонецЦикла;
	
	Запрос = Новый Запрос();
	Запрос.УстановитьПараметр("Таблица", Таблица);
	Запрос.Текст = ТекстЗапросаПриПолученииДанныхНаСервере("СПИСОК");
	РезультатЗапроса = Запрос.ВыполнитьПакет();
	Выборка = РезультатЗапроса[РезультатЗапроса.ВГраница() - 1].Выбрать();
	
	ПараметрЦветТекста = Новый ПараметрКомпоновкиДанных("ЦветТекста");
	ЦветТекстаПоложительногоЗначения = ЦветаСтиля.ЦветТекстаПоложительногоЗначения;
	ГиперссылкаЦвет = ЦветаСтиля.ГиперссылкаЦвет;
	Пока Выборка.Следующий() Цикл
		
		Строка = Строки[Ключи[Выборка.Индекс]].Данные;
		ЗаполнитьЗначенияСвойств(Строка, Выборка, "МожноОтгрузитьИзДоступногоОстатка,МожноОтгрузитьИзНаличия");
		ОформлениеСостояния = Строки[Ключи[Выборка.Индекс]].Оформление.Получить("Состояние");
		Если ТипЗнч(ОформлениеСостояния) = Тип("ОформлениеЯчейкиДинамическогоСписка") Тогда
			
			Если Строка.МожноОтгрузитьИзДоступногоОстатка Тогда
				ОформлениеСостояния.УстановитьЗначениеПараметра(ПараметрЦветТекста, ЦветТекстаПоложительногоЗначения);
			ИначеЕсли Строка.МожноОтгрузитьИзНаличия Тогда
				ОформлениеСостояния.УстановитьЗначениеПараметра(ПараметрЦветТекста, ГиперссылкаЦвет);
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЦикла;
	
	Выборка = РезультатЗапроса[РезультатЗапроса.ВГраница()].Выбрать();
	Пока Выборка.Следующий() Цикл
		
		Строка = Строки[Ключи[Выборка.Индекс]].Данные;
		ЗаполнитьЗначенияСвойств(Строка, Выборка, "ДатаПоступления");
		
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура НаборОбновить(ПараметрыЗапроса, АдресТаблицыДвижений)
	
	Данные = ПолучитьИзВременногоХранилища(АдресТаблицыДвижений);
	МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	
	РаспределениеЗапасовДвижения.ДобавитьКолонкиРегистра(Данные.ТаблицаДвижений);
	РаспределениеЗапасов.СостояниеСУчетомОтраженияИзменений(
		ЗаказыРегистраторыДвижений.ВыгрузитьЗначения(),
		Данные.ТаблицаДвижений,
		МенеджерВременныхТаблиц,
		Данные.ТаблицаИмитацияРеестра);
		
	Запрос = Новый Запрос();
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	Запрос.Текст = ТекстЗапроса(Элементы.Набор.Имя);
	Запрос.УстановитьПараметр("ИсключаемыеЗаказы", Новый Массив());
	Запрос.УстановитьПараметр("ОтборСостояний", ПараметрыЗапроса.ОтборСостояний);
	Запрос.УстановитьПараметр("Ожидается", ПараметрыЗапроса.Ожидается);
	Запрос.УстановитьПараметр("ОжидаетсяНеВСрок", ПараметрыЗапроса.ОжидаетсяНеВСрок);
	Запрос.УстановитьПараметр("ТекущийЗаказ", ПараметрыЗапроса.ТекущийЗаказ);
	Запрос.УстановитьПараметр("НадписьЗаказ", ПараметрыЗапроса.НадписьЗаказ);
	Запрос.УстановитьПараметр("НачалоЭтогоДня", ПараметрыЗапроса.НачалоЭтогоДня);
	Запрос.УстановитьПараметр("ДоступныеТипыЗаказов", ДоступныеТипыЗаказов());
	Запрос.УстановитьПараметр("НачалоТекущегоДня", НачалоДня(ТекущаяДатаСеанса()));

	УстановитьПривилегированныйРежим(Истина);
	Таблица = Запрос.Выполнить().Выгрузить();
	
	Таблица.Колонки.Добавить("Индекс", Новый ОписаниеТипов("Число"));
	Для Индекс = 0 По Таблица.Количество() - 1 Цикл
		Таблица[Индекс].Индекс = Индекс;
	КонецЦикла;
	
	Запрос.УстановитьПараметр("Таблица", Таблица);
	Запрос.Текст = ТекстЗапросаПриПолученииДанныхНаСервере("ТАБЛИЦА");
	РезультатЗапроса = Запрос.ВыполнитьПакет();
	Выборка = РезультатЗапроса[РезультатЗапроса.ВГраница() - 1].Выбрать();
	
	Пока Выборка.Следующий() Цикл
		ЗаполнитьЗначенияСвойств(Таблица[Выборка.Индекс], Выборка, "МожноОтгрузитьИзДоступногоОстатка,МожноОтгрузитьИзНаличия");
	КонецЦикла;
	Выборка = РезультатЗапроса[РезультатЗапроса.ВГраница()].Выбрать();
	Пока Выборка.Следующий() Цикл
		ЗаполнитьЗначенияСвойств(Таблица[Выборка.Индекс], Выборка, "ДатаПоступления");
	КонецЦикла;
	
	Набор.Загрузить(Таблица);
	
	Запрос.Текст =
		"ВЫБРАТЬ
		|КОЛИЧЕСТВО(*) КАК ВсегоЗаписей
		|ИЗ
		|	ИмитацияОтражения КАК Таблица
		|ГДЕ
		|	Таблица.ХарактеристикаПотребности В(
		|		ЗНАЧЕНИЕ(Перечисление.ХарактеристикиПотребности.РезервироватьНаСкладе),
		|		ЗНАЧЕНИЕ(Перечисление.ХарактеристикиПотребности.РезервироватьНаСкладеИзЗаблокированных),
		|		ЗНАЧЕНИЕ(Перечисление.ХарактеристикиПотребности.РезервироватьПоМереПоступления),
		|		ЗНАЧЕНИЕ(Перечисление.ХарактеристикиПотребности.РезервироватьПоМереПоступленияИзЗаблокированных),
		|		ЗНАЧЕНИЕ(Перечисление.ХарактеристикиПотребности.ОтложитьРезервирование),
		|		ЗНАЧЕНИЕ(Перечисление.ХарактеристикиПотребности.КОбеспечению),
		|		ЗНАЧЕНИЕ(Перечисление.ХарактеристикиПотребности.НеОбеспечивать))
		|
		|;
		|///////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ ПЕРВЫЕ 1
		|	ИСТИНА КАК ЕстьОтгрузить
		|ИЗ
		|	НаборЗаписейЗапасыИПотребности КАК Таблица
		|ГДЕ
		|	Таблица.ОтгружаемыйЗаказ = &ТекущийЗаказ
		|		И Таблица.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход)
		|		И Таблица.ВНаличии > 0";
	ВсегоСтрокВСпискеБезОтборов = 0;
	РезультатЗапроса = Запрос.ВыполнитьПакет();
	
	Выборка = РезультатЗапроса[0].Выбрать();
	Если Выборка.Следующий() Тогда
		ВсегоСтрокВСпискеБезОтборов = Выборка.ВсегоЗаписей;
	КонецЕсли;
	
	Выборка = РезультатЗапроса[1].Выбрать();
	Если Выборка.Следующий() Тогда
		// Достаточно для понимания, что все строки нельзя выделить в списке.
		ВсегоСтрокВСпискеБезОтборов = ВсегоСтрокВСпискеБезОтборов + 1;
	КонецЕсли;
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ТекстЗапросаПриПолученииДанныхНаСервере(Источник)
	
	АвторизованВнешнийПользователь = ОбщегоНазначенияУТКлиентСервер.АвторизованВнешнийПользователь();
	
	Тексты = Новый Массив();
	Если Источник = "ТАБЛИЦА" Тогда
		
		ИмяРегистра = "ИмитацияОтражения"; // @query-part-1
		ИмяЗапасыИПотребностиИзменение = "ЗапасыИПотребностиИзменение"; // @query-part-1
		
	ИначеЕсли Источник = "СПИСОК" Тогда
		
		ИмяРегистра = "РегистрСведений.РаспределениеЗапасов"; // @query-part-1
		ИмяЗапасыИПотребностиИзменение = "";
		Тексты.Добавить(ОбеспечениеВДокументахСервер.ВременнаяТаблицаГодыГрафикаПредприятия());
		
	КонецЕсли;
	
	ТекстЗапроса =
		"ВЫБРАТЬ
		|	ВЫРАЗИТЬ(Таблица.Номенклатура КАК Справочник.Номенклатура) КАК Номенклатура,
		|	Таблица.Характеристика КАК Характеристика,
		|	Таблица.Склад КАК Склад,
		|	Таблица.Назначение КАК Назначение,
		|	Таблица.ЗаказНаОтгрузку КАК ЗаказНаОтгрузку,
		|	Таблица.СостояниеЗапаса КАК СостояниеЗапаса,
		|	Таблица.ХарактеристикаПотребности КАК ХарактеристикаПотребности,
		|	ВЫБОР
		|		КОГДА Таблица.ХарактеристикаПотребности В(
		|				ЗНАЧЕНИЕ(Перечисление.ХарактеристикиПотребности.РезервироватьНаСкладеИзЗаблокированных),
		|				ЗНАЧЕНИЕ(Перечисление.ХарактеристикиПотребности.РезервироватьПоМереПоступленияИзЗаблокированных))
		|			ТОГДА Таблица.ЗаказНаОтгрузку
		|		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.КонтролируемыеПартии.ПустаяСсылка)
		|	КОНЕЦ КАК КонтролируемаяПартия,
		|	Таблица.КонтролироватьКачествоПоступившегоТовара КАК КонтролироватьКачествоПоступившегоТовара,
		|	Таблица.КонтрольКачества КАК КонтрольКачества,
		|	Таблица.Индекс КАК Индекс
		|ПОМЕСТИТЬ Таблица
		|ИЗ
		|	&Таблица КАК Таблица
		|ГДЕ
		|	Таблица.Действие <> ЗНАЧЕНИЕ(Перечисление.ВариантыОбеспечения.НеТребуется)
		|ИНДЕКСИРОВАТЬ ПО
		|	Номенклатура, Характеристика, Склад, Назначение, ЗаказНаОтгрузку
		|;
		|
		|/////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ЕСТЬNULL(Таблица.Номенклатура.СрокКонтроляКачества, 0) КАК СрокКонтроляКачества,
		|	Таблица.КонтрольКачества КАК КонтрольКачества,
		|	Таблица.Индекс КАК Индекс
		|ПОМЕСТИТЬ ТаблицаДляРасчетаДатыПоступления
		|ИЗ
		|	Таблица КАК Таблица
		|ГДЕ
		|	Таблица.КонтролироватьКачествоПоступившегоТовара
		|	И Таблица.КонтрольКачества <> ДАТАВРЕМЯ(1, 1, 1)
		|	И ЕСТЬNULL(Таблица.Номенклатура.СрокКонтроляКачества, 0) > 0
		|	И Таблица.СостояниеЗапаса В(
		|		ЗНАЧЕНИЕ(Перечисление.СостоянияЗапаса.НеОбеспечен),
		|		ЗНАЧЕНИЕ(Перечисление.СостоянияЗапаса.НаСогласованииПоставки))
		|	И Таблица.ХарактеристикаПотребности <> ЗНАЧЕНИЕ(Перечисление.ХарактеристикиПотребности.НеОбеспечивать)
		|ИНДЕКСИРОВАТЬ ПО
		|	СрокКонтроляКачества, КонтрольКачества
		|;
		|
		|/////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	Таблица.СрокКонтроляКачества КАК СрокКонтроляКачества,
		|	Таблица.КонтрольКачества КАК КонтрольКачества
		|ПОМЕСТИТЬ ПараметрыПоиска
		|ИЗ
