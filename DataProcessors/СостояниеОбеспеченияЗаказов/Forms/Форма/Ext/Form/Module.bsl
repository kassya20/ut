		|ИНДЕКСИРОВАТЬ ПО
		|	СрокКонтроляКачества, КонтрольКачества";
		
	Подстановки = ОбеспечениеВДокументахСервер.ДобавитьКДатеПоКалендарюПредприятия(
		"Таблица.КонтрольКачества",
		"(-Таблица.СрокКонтроляКачества)");
	
	Если АвторизованВнешнийПользователь Тогда
		
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "ЛЕВОЕ СОЕДИНЕНИЕ РасчетДатыПоставкиПереопределяемый ПО ИСТИНА", "");
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "РасчетДатыПоставкиПереопределяемый.НайденнаяДата", "ДАТАВРЕМЯ(1, 1, 1)");
		
	Иначе
		
