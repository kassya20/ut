#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ПрограммныйИнтерфейс

#Область Команды

// Добавляет команду отчета в список команд.
// 
// Параметры:
//   КомандыОтчетов - см. ВариантыОтчетовПереопределяемый.ПередДобавлениемКомандОтчетов.КомандыОтчетов
//
// Возвращаемое значение:
//   СтрокаТаблицыЗначений - новая команда отчета.
Функция ДобавитьКомандуСостояниеОбеспеченияСпискаЗаказовКлиента(КомандыОтчетов) Экспорт
	
	Если ПравоДоступа("Просмотр", Метаданные.Обработки.СостояниеОбеспеченияЗаказов) Тогда
		
		КомандаОтчет = КомандыОтчетов.Добавить();
		
		КомандаОтчет.Менеджер = Метаданные.Обработки.СостояниеОбеспеченияЗаказов.ПолноеИмя();
		КомандаОтчет.Представление = НСтр("ru = 'Состояние обеспечения'");
		
		КомандаОтчет.МножественныйВыбор = Истина;
		КомандаОтчет.Важность = "Важное";
		КомандаОтчет.ИмяПараметраФормы = "Заказы";
		КомандаОтчет.ПараметрыФормы = Новый Структура("КонтекстИспользования", "СПИСОКЗАКАЗОВ");
		
		КомандаОтчет.ФункциональныеОпции = "ИспользоватьПострочнуюОтгрузкуВЗаказеКлиента";
		
		КомандаОтчет.ЕстьУсловияВидимости = Истина;
		ПодключаемыеКоманды.ДобавитьУсловиеВидимостиКоманды(КомандаОтчет,
			"ЭтоЗаказКакСчет",
			Ложь, 
			ВидСравненияКомпоновкиДанных.Равно);
		
		Возврат КомандаОтчет;
		
	КонецЕсли;
	
	Возврат Неопределено;
	
КонецФункции

#КонецОбласти

// Определяет параметры доступности номенклатуры для заказа. Используется в командах резервирования на складе.
// Параметры:
//  Номенклатура - СправочникСсылка.Номенклатура - номенклатура
//  Характеристика - СправочникСсылка.ХарактеристикиНоменклатуры - характеристика 
//  Назначение - СправочникСсылка.Назначения - назначение
//  Склад - СправочникСсылка.Склады - склад
//  ЗаказНаОтгрузку - ОпределяемыйТип.ОжидаемаяОтгрузка - заказ
// Возвращаемое значение:
//  Структура - структура с полями:
//   * ПотребностьПоЗаказу - Число - потребность в товаре на складе в заказе, кроме строк с действием "Не обеспечивать" и "Отгрузить"
//   * РезервПодЗаказом - Число - количество потребности обеспеченное действием "Резервировать на складе в заказе"
//   * Доступно - Число - количество доступное для отгрузки заказу, для строк с действиями "Резервировать по мере поступления" и "К обеспечению"
Функция ЧисловыеПараметрыРезервирования(Номенклатура, Характеристика, Назначение, Склад, ЗаказНаОтгрузку) Экспорт
	
	Запрос = Новый Запрос();
	Запрос.УстановитьПараметр("Номенклатура", Номенклатура);
	Запрос.УстановитьПараметр("Характеристика", Характеристика);
	Запрос.УстановитьПараметр("Склад", Склад);
	Запрос.УстановитьПараметр("Назначение", Назначение);
	Запрос.УстановитьПараметр("ЗаказНаОтгрузку", ЗаказНаОтгрузку);
	
	ТекстЗапроса =
		"ВЫБРАТЬ
		|	&Номенклатура КАК Номенклатура,
		|	&Характеристика КАК Характеристика,
		|	&Склад КАК Склад,
		|	&Назначение КАК Назначение,
		|	&ЗаказНаОтгрузку КАК ЗаказНаОтгрузку,
		|	ЗНАЧЕНИЕ(Справочник.КонтролируемыеПартии.ПустаяСсылка) КАК КонтролируемаяПартия
		|ПОМЕСТИТЬ Таблица
		|ИНДЕКСИРОВАТЬ ПО
		|	Номенклатура, Характеристика, Склад, Назначение, ЗаказНаОтгрузку
		|;
		|
		|/////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Запасы.Номенклатура КАК Номенклатура,
		|	Запасы.Характеристика КАК Характеристика,
		|	Запасы.Склад КАК Склад,
		|	Запасы.Назначение КАК Назначение,
		|	Запасы.Заказ КАК Заказ,
		|	Запасы.ЗаблокированоВНаличииОстаток КАК ЗаблокированоВНаличииОстаток,
		|	Запасы.ЗаблокированоПоступитОстаток КАК ЗаблокированоПоступитОстаток,
		|	Запасы.КРазблокировкеОстаток КАК КРазблокировкеОстаток,
		|	Запасы.РезервироватьНаСкладеИзЗаблокированныхОстаток КАК РезервироватьНаСкладеИзЗаблокированныхОстаток,
		|	Запасы.РезервироватьПоМереПоступленияИзЗаблокированныхОстаток КАК РезервироватьПоМереПоступленияИзЗаблокированныхОстаток,
		|	Запасы.РезервироватьНаСкладеОстаток КАК РезервироватьНаСкладеОстаток,
		|	Запасы.РезервироватьПоМереПоступленияОстаток КАК РезервироватьПоМереПоступленияОстаток,
		|	Запасы.ОтложитьРезервированиеОстаток КАК ОтложитьРезервированиеОстаток,
		|	Запасы.КОбеспечениюОстаток КАК КОбеспечениюОстаток,
		|	Запасы.НеОбеспечиватьОстаток КАК НеОбеспечиватьОстаток
		|ПОМЕСТИТЬ ЗапасыИПотребностиОстаткиКонтролируемыхПартий
		|ИЗ
		|	РегистрНакопления.ЗапасыИПотребности.Остатки(,
		|		(Номенклатура, Характеристика, Склад, Назначение, Заказ) В(
		|			ВЫБРАТЬ
		|				Фильтр.Номенклатура КАК Номенклатура,
		|				Фильтр.Характеристика КАК Характеристика,
		|				Фильтр.Склад КАК Склад,
		|				Фильтр.Назначение КАК Назначение,
		|				Фильтр.ЗаказНаОтгрузку КАК ЗаказНаОтгрузку
		|			ИЗ
		|				Таблица КАК Фильтр)) КАК Запасы
		|ИНДЕКСИРОВАТЬ ПО
		|	Номенклатура, Характеристика, Склад, Назначение
		|;
		|
		|////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Запасы.Номенклатура КАК Номенклатура,
		|	Запасы.Характеристика КАК Характеристика,
		|	Запасы.Склад КАК Склад,
		|	Запасы.Назначение КАК Назначение,
		|	Запасы.ВНаличииОстаток КАК ВНаличииОстаток,
		|	Запасы.ЗаблокированоВНаличииОстаток КАК ЗаблокированоВНаличииОстаток,
		|	Запасы.ЗаказаноОстаток КАК ЗаказаноОстаток,
		|	Запасы.ПоступитОстаток КАК ПоступитОстаток,
		|	Запасы.ЗаблокированоПоступитОстаток КАК ЗаблокированоПоступитОстаток,
		|	Запасы.РезервироватьНаСкладеОстаток КАК РезервироватьНаСкладеОстаток,
		|	Запасы.РезервироватьПоМереПоступленияОстаток КАК РезервироватьПоМереПоступленияОстаток,
		|	Запасы.ОтложитьРезервированиеОстаток КАК ОтложитьРезервированиеОстаток,
		|	Запасы.КОбеспечениюОстаток КАК КОбеспечениюОстаток,
		|	Запасы.НеОбеспечиватьОстаток КАК НеОбеспечиватьОстаток
		|ПОМЕСТИТЬ ЗапасыИПотребностиОстатки
		|ИЗ
		|	РегистрНакопления.ЗапасыИПотребности.Остатки(,
		|		(Номенклатура, Характеристика, Склад, Назначение) В(
		|			ВЫБРАТЬ
		|				Фильтр.Номенклатура КАК Номенклатура,
		|				Фильтр.Характеристика КАК Характеристика,
		|				Фильтр.Склад КАК Склад,
		|				Фильтр.Назначение КАК Назначение
		|			ИЗ
		|				Таблица КАК Фильтр)) КАК Запасы
		|ИНДЕКСИРОВАТЬ ПО
		|	Номенклатура, Характеристика, Склад, Назначение
		|;
		|
		|////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	РаспределениеЗапасов.Номенклатура КАК Номенклатура,
		|	РаспределениеЗапасов.Характеристика КАК Характеристика,
		|	РаспределениеЗапасов.Склад КАК Склад,
		|	РаспределениеЗапасов.Назначение КАК Назначение,
		|	РаспределениеЗапасов.СостояниеЗапаса КАК СостояниеЗапаса,
		|	РаспределениеЗапасов.ХарактеристикаПотребности КАК ХарактеристикаПотребности,
		|	РаспределениеЗапасов.ЗаказНаПоступление КАК ЗаказНаПоступление,
		|	РаспределениеЗапасов.ДатаПоступления КАК ДатаПоступления,
		|	РаспределениеЗапасов.ДатаДоступности КАК ДатаДоступности,
		|	РаспределениеЗапасов.ЗаказНаОтгрузку КАК ЗаказНаОтгрузку,
		|	РаспределениеЗапасов.ЖелаемаяДатаОтгрузки КАК ЖелаемаяДатаОтгрузки,
		|	РаспределениеЗапасов.Количество КАК Количество
		|ПОМЕСТИТЬ РаспределениеЗапасов
		|ИЗ
		|	РегистрСведений.РаспределениеЗапасов КАК РаспределениеЗапасов
		|ГДЕ
		|	ИСТИНА В(
		|		ВЫБРАТЬ ПЕРВЫЕ 1
		|			ИСТИНА КАК ЕстьЗаписи
		|		ИЗ
		|			Таблица КАК Фильтр
		|		ГДЕ
		|			Фильтр.Номенклатура = РаспределениеЗапасов.Номенклатура
		|			И Фильтр.Характеристика = РаспределениеЗапасов.Характеристика
		|			И Фильтр.Склад = РаспределениеЗапасов.Склад
		|			И Фильтр.Назначение = РаспределениеЗапасов.Назначение
		|			И Фильтр.ЗаказНаОтгрузку = РаспределениеЗапасов.ЗаказНаОтгрузку)
		|;
		|
		|/////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ЕСТЬNULL(Потребности.РезервироватьНаСкладе
		|				+ Потребности.РезервироватьПоМереПоступления
		|				+ Потребности.ОтложитьРезервирование
		|				+ Потребности.КОбеспечению, 0) КАК ПотребностьПоЗаказу,
		|	ЕСТЬNULL(Остатки.КоличествоДляДействияОтгрузить, 0) КАК Доступно,
		|	ЕСТЬNULL(Потребности.РезервироватьНаСкладе, 0) КАК РезервПодЗаказом
		|ИЗ
		|	Таблица КАК Таблица
		|		
		|		ЛЕВОЕ СОЕДИНЕНИЕ РасчетОстатковДляУстановкиДействий КАК Остатки
		|		ПО Остатки.ЗаказНаОтгрузку = Таблица.ЗаказНаОтгрузку
		|		И Остатки.Номенклатура = Таблица.Номенклатура
		|		И Остатки.Характеристика = Таблица.Характеристика
		|		И Остатки.Склад = Таблица.Склад
		|		И Остатки.Назначение = Таблица.Назначение
		|		И Остатки.КонтролируемаяПартия = Таблица.КонтролируемаяПартия
		|		
		|		ЛЕВОЕ СОЕДИНЕНИЕ Потребности КАК Потребности
		|		ПО Потребности.ЗаказНаОтгрузку = Таблица.ЗаказНаОтгрузку
		|		И Потребности.Номенклатура = Таблица.Номенклатура
		|		И Потребности.Характеристика = Таблица.Характеристика
		|		И Потребности.Склад = Таблица.Склад
		|		И Потребности.Назначение = Таблица.Назначение
		|		И Потребности.КонтролируемаяПартия = Таблица.КонтролируемаяПартия";
	
	ИменаТаблиц = ОбеспечениеВДокументахСервер.НовыеИменаТаблицДляРасчетаОстатковДляУстановкиДействий();
	ИменаТаблиц.Остатки = "ЗапасыИПотребностиОстатки"; // @query-part-1
	ИменаТаблиц.ОстаткиКонтролируемыхПартий = "ЗапасыИПотребностиОстаткиКонтролируемыхПартий"; // @query-part-1
	ИменаТаблиц.Аналитики = "Таблица"; // @query-part-1
	ИменаТаблиц.ЗапасыИПотребностиИзменение = ""; // @query-part-1
	ИменаТаблиц.РаспределениеЗапасов = "РаспределениеЗапасов"; // @query-part-1
	ИменаТаблиц.Результат = "РасчетОстатковДляУстановкиДействий"; // @query-part-1
	ИменаТаблиц.Потребности = "Потребности"; // @query-part-1
	ОбеспечениеВДокументахСервер.РасчетОстатковДляУстановкиДействий(ТекстЗапроса, ИменаТаблиц, Истина);
	
	Запрос.Текст = ТекстЗапроса;
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Показатели = Новый Структура("ПотребностьПоЗаказу,РезервПодЗаказом,Доступно", 0, 0, 0);
	Если Выборка.Следующий() Тогда
		
		Показатели.ПотребностьПоЗаказу = Выборка.ПотребностьПоЗаказу;
		Показатели.РезервПодЗаказом = Выборка.РезервПодЗаказом;
		Показатели.Доступно = Выборка.Доступно;
		Показатели.Доступно = Макс(0, Мин(Показатели.Доступно, Показатели.ПотребностьПоЗаказу));
		
	КонецЕсли;
	Возврат Показатели;
	
КонецФункции

#КонецОбласти

#КонецЕсли
