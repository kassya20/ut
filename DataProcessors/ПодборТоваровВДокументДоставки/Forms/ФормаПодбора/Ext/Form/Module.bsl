		|				{(Получатель).* КАК КонечныйПолучательОбороты}) КАК ДоставкаОбороты
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТСодержимоеДокумента КАК ВТСодержимоеДокумента
		|		ПО ДоставкаОбороты.Распоряжение = ВТСодержимоеДокумента.Распоряжение
		|			И ДоставкаОбороты.КодСтроки = ВТСодержимоеДокумента.КодСтроки
		|			И ДоставкаОбороты.ДокументПланирования = ВТСодержимоеДокумента.ДокументПланирования
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.Доставка КАК ДоставкаКонечноеПлечо
		|		ПО ДоставкаОбороты.Распоряжение = ДоставкаКонечноеПлечо.Распоряжение
		|			И ДоставкаОбороты.КодСтроки = ДоставкаКонечноеПлечо.КодСтроки
		|			И ДоставкаОбороты.ДокументПланирования = ДоставкаКонечноеПлечо.ДокументПланирования
		|			И (ДоставкаКонечноеПлечо.ЭтоКонечноеПлечо)
		|			И (ДоставкаКонечноеПлечо.УровеньОперации В (&ПредыдущиеУровниОпераций))
		|			И НЕ 1 В
		|				(ВЫБРАТЬ ПЕРВЫЕ 1
		|					1
		|				ИЗ
		|					РегистрСведений.ИсправленияДокументов КАК ИсправленияДокументов
		|				ГДЕ
		|					ИсправленияДокументов.ИсправляемыйДокумент = ДоставкаКонечноеПлечо.Регистратор
		|					ИЛИ ИсправленияДокументов.ПредыдущееИсправление = ДоставкаКонечноеПлечо.Регистратор)
		|{ГДЕ
		|	ДоставкаКонечноеПлечо.Получатель КАК КонечныйПолучательКонечноеПлечо,
		|	(ВЫБОР
		|			КОГДА ЕСТЬNULL(ДоставкаКонечноеПлечо.Плечо, 1) > 1
		|				ТОГДА ЕСТЬNULL(ДоставкаКонечноеПлечо.Получатель, НЕОПРЕДЕЛЕНО)
		|			ИНАЧЕ НЕОПРЕДЕЛЕНО
		|		КОНЕЦ).* КАК КонечныйПолучатель,
		|	(ВЫБОР
		|			КОГДА ЕСТЬNULL(ДоставкаКонечноеПлечо.Плечо, 1) > 1
		|				ТОГДА ЕСТЬNULL(ДоставкаКонечноеПлечо.ТочкаПолучателя, ЗНАЧЕНИЕ(Справочник.ТочкиДоставки.ПустаяСсылка))
		|			ИНАЧЕ ЗНАЧЕНИЕ(Справочник.ТочкиДоставки.ПустаяСсылка)
		|		КОНЕЦ).* КАК ТочкаКонечногоПолучателя,
		|	(ВЫБОР
		|			КОГДА ЕСТЬNULL(ДоставкаКонечноеПлечо.Плечо, 1) > 1
		|				ТОГДА ЕСТЬNULL(ДоставкаКонечноеПлечо.ЗонаПолучателя, ЗНАЧЕНИЕ(Справочник.ЗоныДоставки.ПустаяСсылка))
		|			ИНАЧЕ ЗНАЧЕНИЕ(Справочник.ЗоныДоставки.ПустаяСсылка)
		|		КОНЕЦ).* КАК ЗонаКонечногоПолучателя}
		|
		|СГРУППИРОВАТЬ ПО
		|	ДоставкаОбороты.ДатаОтгрузки,
		|	ДоставкаОбороты.СпособДоставки,
		|	ДоставкаОбороты.Отправитель,
		|	ДоставкаОбороты.Получатель,
		|	ДоставкаОбороты.ТочкаПолучателя,
		|	ДоставкаОбороты.ЗонаПолучателя,
		|	ВЫБОР
		|		КОГДА ЕСТЬNULL(ДоставкаКонечноеПлечо.Плечо, 1) > 1
		|			ТОГДА ЕСТЬNULL(ДоставкаКонечноеПлечо.Получатель, НЕОПРЕДЕЛЕНО)
		|		ИНАЧЕ НЕОПРЕДЕЛЕНО
		|	КОНЕЦ,
		|	ВЫБОР
		|		КОГДА ЕСТЬNULL(ДоставкаКонечноеПлечо.Плечо, 1) > 1
		|			ТОГДА ЕСТЬNULL(ДоставкаКонечноеПлечо.ТочкаПолучателя, ЗНАЧЕНИЕ(Справочник.ТочкиДоставки.ПустаяСсылка))
		|		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.ТочкиДоставки.ПустаяСсылка)
		|	КОНЕЦ,
		|	ВЫБОР
		|		КОГДА ЕСТЬNULL(ДоставкаКонечноеПлечо.Плечо, 1) > 1
		|			ТОГДА ЕСТЬNULL(ДоставкаКонечноеПлечо.ЗонаПолучателя, ЗНАЧЕНИЕ(Справочник.ЗоныДоставки.ПустаяСсылка))
		|		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.ЗоныДоставки.ПустаяСсылка)
		|	КОНЕЦ,
		|	ДоставкаОбороты.Распоряжение,
		|	ДоставкаОбороты.ТипДоставки
		|
		|ИМЕЮЩИЕ
		|	СУММА(ДоставкаОбороты.КРейсуОборот) - СУММА(ДоставкаОбороты.ВРейсеОборот) + СУММА(ДоставкаОбороты.ОтмененоОборот) - СУММА(ЕСТЬNULL(ВТСодержимоеДокумента.Количество, 0)) > 0";
		
		ОбщегоНазначенияКлиентСервер.УстановитьПараметрДинамическогоСписка(
			СписокПоДокументам, "ДокументДоставки", Объект.ДокументДоставки);
		
	Иначе
		
		ТекстЗапросаПоДокументам =
		"ВЫБРАТЬ
		|	ДоставкаОбороты.ДатаОтгрузки КАК ДатаОтгрузки,
		|	ДоставкаОбороты.СпособДоставки КАК СпособДоставки,
		|	ДоставкаОбороты.Отправитель КАК Отправитель,
		|	ДоставкаОбороты.Получатель КАК Получатель,
		|	ДоставкаОбороты.ТочкаПолучателя КАК ТочкаПолучателя,
		|	ДоставкаОбороты.ЗонаПолучателя КАК ЗонаПолучателя,
		|	ВЫБОР
		|		КОГДА ЕСТЬNULL(ДоставкаКонечноеПлечо.Плечо, 1) > 1
		|			ТОГДА ЕСТЬNULL(ДоставкаКонечноеПлечо.Получатель, НЕОПРЕДЕЛЕНО)
		|		ИНАЧЕ НЕОПРЕДЕЛЕНО
		|	КОНЕЦ КАК КонечныйПолучатель,
		|	ВЫБОР
		|		КОГДА ЕСТЬNULL(ДоставкаКонечноеПлечо.Плечо, 1) > 1
		|			ТОГДА ЕСТЬNULL(ДоставкаКонечноеПлечо.ТочкаПолучателя, ЗНАЧЕНИЕ(Справочник.ТочкиДоставки.ПустаяСсылка))
		|		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.ТочкиДоставки.ПустаяСсылка)
		|	КОНЕЦ КАК ТочкаКонечногоПолучателя,
		|	ВЫБОР
		|		КОГДА ЕСТЬNULL(ДоставкаКонечноеПлечо.Плечо, 1) > 1
		|			ТОГДА ЕСТЬNULL(ДоставкаКонечноеПлечо.ЗонаПолучателя, ЗНАЧЕНИЕ(Справочник.ЗоныДоставки.ПустаяСсылка))
		|		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.ЗоныДоставки.ПустаяСсылка)
		|	КОНЕЦ КАК ЗонаКонечногоПолучателя,
		|	ДоставкаОбороты.Распоряжение КАК Распоряжение,
		|	ДоставкаОбороты.ТипДоставки КАК ТипДоставки,
		|	СУММА((ДоставкаОбороты.КРейсуОборот - ДоставкаОбороты.ВРейсеОборот + ДоставкаОбороты.ОтмененоОборот) * &ВыражениеВесУпаковки) КАК Вес,
		|	СУММА((ДоставкаОбороты.КРейсуОборот - ДоставкаОбороты.ВРейсеОборот + ДоставкаОбороты.ОтмененоОборот) * &ВыражениеОбъемУпаковки) КАК Объем,
		|	-1 КАК ИндексКартинки,
		|	NULL КАК Детализация,
		|	ЛОЖЬ КАК ЕстьОтличияВПараметрахДоставки,
		|	NULL КАК ВариантыПараметровДоставки
		|{ВЫБРАТЬ
		|	ДатаОтгрузки,
		|	СпособДоставки.*,
		|	Отправитель.*,
		|	Получатель.*,
		|	ТочкаПолучателя.*,
		|	ЗонаПолучателя.*,
		|	КонечныйПолучатель.*,
		|	ТочкаКонечногоПолучателя.*,
		|	ЗонаКонечногоПолучателя.*,
		|	Распоряжение.*,
		|	ТипДоставки,
		|	Вес,
		|	Объем,
		|	ИндексКартинки,
		|	Детализация,
		|	ЕстьОтличияВПараметрахДоставки,
		|	ВариантыПараметровДоставки}
		|ИЗ
		|	РегистрНакопления.Доставка.Обороты(
		|			,
		|			,
		|			,
		|			&ОтборПоПараметрам
		|				{&ОтборКомпоновкой}
		|				{(Получатель).* КАК КонечныйПолучательОбороты}) КАК ДоставкаОбороты
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.Доставка КАК ДоставкаКонечноеПлечо
		|		ПО ДоставкаОбороты.Распоряжение = ДоставкаКонечноеПлечо.Распоряжение
		|			И ДоставкаОбороты.КодСтроки = ДоставкаКонечноеПлечо.КодСтроки
		|			И ДоставкаОбороты.ДокументПланирования = ДоставкаКонечноеПлечо.ДокументПланирования
		|			И (ДоставкаКонечноеПлечо.ЭтоКонечноеПлечо)
		|			И (ДоставкаКонечноеПлечо.УровеньОперации В (&ПредыдущиеУровниОпераций))
		|			И НЕ 1 В
		|				(ВЫБРАТЬ ПЕРВЫЕ 1
		|					1
		|				ИЗ
		|					РегистрСведений.ИсправленияДокументов КАК ИсправленияДокументов
		|				ГДЕ
		|					ИсправленияДокументов.ИсправляемыйДокумент = ДоставкаКонечноеПлечо.Регистратор
		|					ИЛИ ИсправленияДокументов.ПредыдущееИсправление = ДоставкаКонечноеПлечо.Регистратор)
		|ГДЕ
		|	ДоставкаОбороты.КРейсуОборот - ДоставкаОбороты.ВРейсеОборот + ДоставкаОбороты.ОтмененоОборот > 0
		|{ГДЕ
		|	ДоставкаКонечноеПлечо.Получатель КАК КонечныйПолучательКонечноеПлечо,
		|	(ВЫБОР
		|			КОГДА ЕСТЬNULL(ДоставкаКонечноеПлечо.Плечо, 1) > 1
		|				ТОГДА ЕСТЬNULL(ДоставкаКонечноеПлечо.Получатель, НЕОПРЕДЕЛЕНО)
		|			ИНАЧЕ НЕОПРЕДЕЛЕНО
		|		КОНЕЦ).* КАК КонечныйПолучатель,
		|	(ВЫБОР
		|			КОГДА ЕСТЬNULL(ДоставкаКонечноеПлечо.Плечо, 1) > 1
		|				ТОГДА ЕСТЬNULL(ДоставкаКонечноеПлечо.ТочкаПолучателя, ЗНАЧЕНИЕ(Справочник.ТочкиДоставки.ПустаяСсылка))
		|			ИНАЧЕ ЗНАЧЕНИЕ(Справочник.ТочкиДоставки.ПустаяСсылка)
		|		КОНЕЦ).* КАК ТочкаКонечногоПолучателя,
		|	(ВЫБОР
		|			КОГДА ЕСТЬNULL(ДоставкаКонечноеПлечо.Плечо, 1) > 1
		|				ТОГДА ЕСТЬNULL(ДоставкаКонечноеПлечо.ЗонаПолучателя, ЗНАЧЕНИЕ(Справочник.ЗоныДоставки.ПустаяСсылка))
		|			ИНАЧЕ ЗНАЧЕНИЕ(Справочник.ЗоныДоставки.ПустаяСсылка)
		|		КОНЕЦ).* КАК ЗонаКонечногоПолучателя}
		|
		|СГРУППИРОВАТЬ ПО
		|	ДоставкаОбороты.ДатаОтгрузки,
		|	ДоставкаОбороты.СпособДоставки,
		|	ДоставкаОбороты.Отправитель,
		|	ДоставкаОбороты.Получатель,
		|	ДоставкаОбороты.ТочкаПолучателя,
		|	ДоставкаОбороты.ЗонаПолучателя,
		|	ДоставкаОбороты.ТипДоставки,
		|	ДоставкаОбороты.Распоряжение,
		|	ВЫБОР
		|		КОГДА ЕСТЬNULL(ДоставкаКонечноеПлечо.Плечо, 1) > 1
		|			ТОГДА ЕСТЬNULL(ДоставкаКонечноеПлечо.Получатель, НЕОПРЕДЕЛЕНО)
		|		ИНАЧЕ НЕОПРЕДЕЛЕНО
		|	КОНЕЦ,
		|	ВЫБОР
		|		КОГДА ЕСТЬNULL(ДоставкаКонечноеПлечо.Плечо, 1) > 1
		|			ТОГДА ЕСТЬNULL(ДоставкаКонечноеПлечо.ТочкаПолучателя, ЗНАЧЕНИЕ(Справочник.ТочкиДоставки.ПустаяСсылка))
		|		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.ТочкиДоставки.ПустаяСсылка)
		|	КОНЕЦ,
		|	ВЫБОР
		|		КОГДА ЕСТЬNULL(ДоставкаКонечноеПлечо.Плечо, 1) > 1
		|			ТОГДА ЕСТЬNULL(ДоставкаКонечноеПлечо.ЗонаПолучателя, ЗНАЧЕНИЕ(Справочник.ЗоныДоставки.ПустаяСсылка))
		|		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.ЗоныДоставки.ПустаяСсылка)
		|	КОНЕЦ";
		
	КонецЕсли;
	
	ПодставитьОтборОборотовДоставкиПоПараметрамВЗапрос(ТекстЗапросаПоДокументам);
	ПодставитьОтборОборотовДоставкиКомпоновкойВЗапрос(ТекстЗапросаПоДокументам);
	
	ВыражениеВесУпаковки = Справочники.УпаковкиЕдиницыИзмерения.ТекстЗапросаВесУпаковки(
		"ДоставкаОбороты.Номенклатура.ЕдиницаИзмерения", "ДоставкаОбороты.Номенклатура", Ложь);
	ТекстЗапросаПоДокументам = СтрЗаменить(ТекстЗапросаПоДокументам, "&ВыражениеВесУпаковки", ВыражениеВесУпаковки);
	
	ВыражениеОбъемУпаковки = Справочники.УпаковкиЕдиницыИзмерения.ТекстЗапросаОбъемУпаковки(
		"ДоставкаОбороты.Номенклатура.ЕдиницаИзмерения", "ДоставкаОбороты.Номенклатура", Ложь);
	ТекстЗапросаПоДокументам = СтрЗаменить(ТекстЗапросаПоДокументам, "&ВыражениеОбъемУпаковки", ВыражениеОбъемУпаковки);
	
	СвойстваСписка = ОбщегоНазначения.СтруктураСвойствДинамическогоСписка();
	СвойстваСписка.ТекстЗапроса = ТекстЗапросаПоДокументам;
	СвойстваСписка.ОсновнаяТаблица = "РегистрНакопления.Доставка.Обороты";
	СвойстваСписка.ДинамическоеСчитываниеДанных = Истина;
	ОбщегоНазначения.УстановитьСвойстваДинамическогоСписка(Элементы.СписокПоДокументам, СвойстваСписка);
	
КонецПроцедуры

&НаСервереБезКонтекста
Процедура ПодставитьОтборОборотовДоставкиПоПараметрамВЗапрос(ТекстЗапроса)
	
	УсловияОтбора =
	"Плечо = 1
	|И Организация = &Организация
	|И Отправитель = &Склад";
	
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&ОтборПоПараметрам", УсловияОтбора);
	
КонецПроцедуры

&НаСервереБезКонтекста
Процедура ПодставитьОтборОборотовДоставкиКомпоновкойВЗапрос(ТекстЗапроса)
	
	УсловияОтбора =
	"(Перевозчик).* КАК Перевозчик,
	|(ДатаОтгрузки) КАК ДатаОтгрузки,
	|(ДатаОтгрузки >= &ДатаОтгрузкиС),
	|(ДатаОтгрузки <= &ДатаОтгрузкиПо),
	|(Получатель).* КАК Получатель,
	|(ЗонаПолучателя).* КАК ЗонаПолучателя,
	|(ТочкаПолучателя).* КАК ТочкаПолучателя,
	|(ТипДоставки) КАК ТипДоставки,
	|(СпособДоставки) КАК СпособДоставки,
	|(Распоряжение).* КАК Распоряжение,
	|(Номенклатура).*, (Характеристика).*, (Серия).*";
	
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&ОтборКомпоновкой", УсловияОтбора);
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ОтборДетальныхОстатков(ЭтоСписокПоТоварам, ВыводитьКонечногоПолучателя)
	
	ОтборДетальныхОстатков = Новый Структура;
	ОтборДетальныхОстатков.Вставить("Распоряжение", Неопределено);
	ОтборДетальныхОстатков.Вставить("Отправитель", Справочники.Склады.ПустаяСсылка());
	ОтборДетальныхОстатков.Вставить("СпособДоставки", Перечисления.СпособыДоставки25.ПустаяСсылка());
	ОтборДетальныхОстатков.Вставить("Получатель", Справочники.Партнеры.ПустаяСсылка());
	ОтборДетальныхОстатков.Вставить("ТочкаПолучателя", Справочники.ТочкиДоставки.ПустаяСсылка());
	ОтборДетальныхОстатков.Вставить("ЗонаПолучателя", Справочники.ЗоныДоставки.ПустаяСсылка());
	ОтборДетальныхОстатков.Вставить("ДатаОтгрузки", '00010101');
	
	Если ЭтоСписокПоТоварам Тогда
		
		ОтборДетальныхОстатков.Вставить("Номенклатура", Справочники.Номенклатура.ПустаяСсылка());
		ОтборДетальныхОстатков.Вставить("Характеристика", Справочники.ХарактеристикиНоменклатуры.ПустаяСсылка());
		ОтборДетальныхОстатков.Вставить("Серия", Справочники.СерииНоменклатуры.ПустаяСсылка());
		ОтборДетальныхОстатков.Вставить("Упаковка", Справочники.УпаковкиЕдиницыИзмерения.ПустаяСсылка());
		
	КонецЕсли;
	
	Если ВыводитьКонечногоПолучателя Тогда
		
		ОтборДетальныхОстатков.Вставить("КонечныйПолучатель", Справочники.Партнеры.ПустаяСсылка());
		ОтборДетальныхОстатков.Вставить("ТочкаКонечногоПолучателя", Справочники.ТочкиДоставки.ПустаяСсылка());
		ОтборДетальныхОстатков.Вставить("ЗонаКонечногоПолучателя", Справочники.ЗоныДоставки.ПустаяСсылка());
		
	КонецЕсли;
	
	Возврат ОтборДетальныхОстатков;
	
КонецФункции

&НаСервереБезКонтекста
Функция ЗонаДоставкиПоТочке(Знач ТочкаДоставки)
	
	РеквизитыТочки = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ТочкаДоставки, "ЗонаДоставки");
	Возврат РеквизитыТочки.ЗонаДоставки;
	
КонецФункции

// Параметры:
//  ДанныеСтроки - См. ДанныеСтрокиСпискаДоставить
//  ВыбранныеПараметрыДоставки - ДанныеФормыСтруктура, Структура - Выбранные параметры доставки
//
&НаСервере
Процедура ДобавитьСтрокиВПодобраноСервер(Знач ДанныеСтроки, Знач ВыбранныеПараметрыДоставки)
	
	ОтборСтрокПодобраноБезПараметров = Новый Структура;
	ОтборСтрокПодобраноБезПараметров.Вставить("Распоряжение", ДанныеСтроки.Распоряжение);
	ОтборСтрокПодобраноБезПараметров.Вставить("ДокументПланирования", Неопределено);
	ОтборСтрокПодобраноБезПараметров.Вставить("КодСтроки", 0);
	
	ОтборСтрокПодобраноСПараметрами = Новый Структура;
	ОтборСтрокПодобраноСПараметрами.Вставить("Распоряжение", ДанныеСтроки.Распоряжение);
	ОтборСтрокПодобраноСПараметрами.Вставить("ДокументПланирования", Неопределено);
	ОтборСтрокПодобраноСПараметрами.Вставить("КодСтроки", 0);
	ОтборСтрокПодобраноСПараметрами.Вставить("ДоставкаДо", ВыбранныеПараметрыДоставки.Получатель);
	ОтборСтрокПодобраноСПараметрами.Вставить("ТочкаДоставки", ВыбранныеПараметрыДоставки.ТочкаПолучателя);
	ОтборСтрокПодобраноСПараметрами.Вставить("ЗонаДоставки", ВыбранныеПараметрыДоставки.ЗонаПолучателя);
	
	ДетализацияСтроки = ДанныеСтроки.Детализация.Получить();
	ИзмененныеСтроки = Новый Массив; // Массив Из ДанныеФормыЭлементКоллекции
	
	Для Каждого ВариантДетализации Из ДетализацияСтроки Цикл
		
		ЗаполнитьЗначенияСвойств(ОтборСтрокПодобраноБезПараметров, ВариантДетализации);
		ЗаполнитьЗначенияСвойств(ОтборСтрокПодобраноСПараметрами, ВариантДетализации);
		
		ПодобраноВсегоПоКоду = Подобрано.Выгрузить(ОтборСтрокПодобраноБезПараметров, "Количество");
		КоличествоПодобрано = ПодобраноВсегоПоКоду.Итог("Количество");
		ОстатокНаВариантДетализации = Макс(ВариантДетализации.Остаток - КоличествоПодобрано, 0);
		Если ОстатокНаВариантДетализации <= 0 Тогда
			Продолжить;
		КонецЕсли;
		
		СтрокиПодобраноПоПараметрам = Подобрано.НайтиСтроки(ОтборСтрокПодобраноСПараметрами);
		Если СтрокиПодобраноПоПараметрам.Количество() > 0 Тогда
			
			СтрокаПодобрано = СтрокиПодобраноПоПараметрам[0];
			
		Иначе
			
			СтрокаПодобрано = Подобрано.Добавить();
			ЗаполнитьЗначенияСвойств(СтрокаПодобрано, ДанныеСтроки);
			ЗаполнитьЗначенияСвойств(СтрокаПодобрано, ВариантДетализации);
			ЗаполнитьЗначенияСвойств(СтрокаПодобрано, ОтборСтрокПодобраноСПараметрами);
			
		КонецЕсли;
		
		СтрокаПодобрано.Количество = СтрокаПодобрано.Количество + ОстатокНаВариантДетализации;
		ИзмененныеСтроки.Добавить(СтрокаПодобрано);
		
	КонецЦикла;
	
	ОбновитьПодобраноВСпискеДоставить();
	
	ЗаполнитьСлужебныеРеквизитыНоменклатурыПодобрано(ИзмененныеСтроки);
	
	Для Каждого СтрокаПодобрано Из ИзмененныеСтроки Цикл
		ПересчитатьВесОбъемВОбщихЕдиницах(СтрокаПодобрано);
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьПодобраноВСпискеДоставить()
	
	ДопСвойства = ДопСвойстваНастроекСписка(СписокПоТоварам.КомпоновщикНастроек.Настройки);
	АдресТаблицыПодобрано = ДопСвойства.АдресТаблицыПодобрано;
	ТаблицаПодобрано = Подобрано.Выгрузить();
	ПоместитьВоВременноеХранилище(ТаблицаПодобрано, АдресТаблицыПодобрано);
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьСлужебныеРеквизитыНоменклатурыПодобрано(ИзмененныеСтроки)
	
	СтруктураДействий = Новый Структура;
	ЗаполнитьПризнакТипНоменклатуры = Новый Структура("Номенклатура", "ТипНоменклатуры");
	СтруктураДействий.Вставить("ЗаполнитьПризнакТипНоменклатуры", ЗаполнитьПризнакТипНоменклатуры);
	СтруктураДействий.Вставить("ПроверитьХарактеристикуПоВладельцу", Неопределено);
	СтруктураДействий.Вставить("ПроверитьЗаполнитьУпаковкуПоВладельцу", Неопределено);
	
	СтруктураДействий.Вставить("ЗаполнитьВесУпаковки",
		Новый Структура("Номенклатура, Упаковка", "ВесУпаковки", Неопределено));
	СтруктураДействий.Вставить("ЗаполнитьОбъемУпаковки",
		Новый Структура("Номенклатура, Упаковка", "ОбъемУпаковки", Неопределено));
	СтруктураДействий.Вставить("ЗаполнитьЕдиницуИзмеренияВеса",
		Новый Структура("Номенклатура, Упаковка", "ЕдиницаИзмеренияВеса", Неопределено));
	СтруктураДействий.Вставить("ЗаполнитьЕдиницуИзмеренияОбъема",
		Новый Структура("Номенклатура, Упаковка", "ЕдиницаИзмеренияОбъема", Неопределено));
	
	КэшированныеЗначения = ПакетнаяОбработкаТабличнойЧастиКлиентСервер.ПолучитьСтруктуруКэшируемыеЗначения();
	ПакетнаяОбработкаТабличнойЧастиСервер.ОбработатьСтрокиТЧ(
		ИзмененныеСтроки, СтруктураДействий, Подобрано, КэшированныеЗначения);
	
	Для Каждого СтрокаПодобрано Из ИзмененныеСтроки Цикл
		ЗаполнитьВесНеттоЕдиницы(СтрокаПодобрано);
	КонецЦикла;
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Процедура ЗаполнитьВесНеттоЕдиницы(СтрокаПодобрано)
	
	ПустаяУпаковка = ПредопределенноеЗначение("Справочник.УпаковкиЕдиницыИзмерения.ПустаяСсылка");
	ДанныеНоменклатуры = КоэффициентыВесОбъем(СтрокаПодобрано.Номенклатура, ПустаяУпаковка);
	СтрокаПодобрано.ВесНеттоЕдиницы = ДанныеНоменклатуры.ВесНетто; // Число
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция КоэффициентыВесОбъем(Знач Номенклатура, Знач Упаковка)
	
	Возврат Справочники.УпаковкиЕдиницыИзмерения.КоэффициентВесОбъемПрочиеРеквизитыУпаковки(Упаковка, Номенклатура,, Ложь);
	
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Процедура ПересчитатьВесОбъемВОбщихЕдиницах(СтрокаПодобрано)
	
	// объем в кубических метрах
	СтрокаПодобрано.Объем = СтрокаПодобрано.Количество * СтрокаПодобрано.ОбъемУпаковки;
	
	// вес брутто в кг
	СтрокаПодобрано.Вес = СтрокаПодобрано.Количество * СтрокаПодобрано.ВесУпаковки;
	
КонецПроцедуры

&НаСервере
Функция ПараметрыФормыВыбораПараметровДоставки(Знач ИмяЭлемента, Знач ВыбраннаяСтрока, Знач ДанныеСтроки)
	
	Результат = Новый Структура;
	
	ЭтоСписокПоТоварам = (ИмяЭлемента = Элементы.СписокПоТоварам.Имя);
	Результат.Вставить("ДляСпискаПоТоварам", ЭтоСписокПоТоварам);
	
	ТаблицаВариантов = ВариантыПараметровДоставкиПоСтроке(ДанныеСтроки);
	
	ТаблицаВариантов.Колонки.Добавить("Номенклатура", Новый ОписаниеТипов("СправочникСсылка.Номенклатура"));
	ТаблицаВариантов.Колонки.Добавить("Характеристика", Новый ОписаниеТипов("СправочникСсылка.ХарактеристикиНоменклатуры"));
	ТаблицаВариантов.Колонки.Добавить("Серия", Новый ОписаниеТипов("СправочникСсылка.СерииНоменклатуры"));
	ТаблицаВариантов.Колонки.Добавить("Распоряжение", Метаданные.ОпределяемыеТипы.РаспоряжениеНаДоставку25.Тип);
	ТаблицаВариантов.Колонки.Добавить("ПлановыеПараметры", Новый ОписаниеТипов("Булево"));
	
	ЕстьПлановыеПараметры = Ложь;
	
	ВыводитьКонечногоПолучателя =
		(ТипЗнч(Объект.ДокументДоставки) = Тип("ДокументСсылка.Рейс")
			И Объект.СпособДоставкиДокумента = Перечисления.СпособыДоставки25.СиламиПеревозчика);
	
	ИспользоватьДанныеКонечногоПолучателя =
		(ВыводитьКонечногоПолучателя
			И ЗначениеЗаполнено(ДанныеСтроки.КонечныйПолучатель)
			И ЗначениеЗаполнено(ДанныеСтроки.ТочкаКонечногоПолучателя)
			И ЗначениеЗаполнено(ДанныеСтроки.ЗонаКонечногоПолучателя));
	
	Если ИспользоватьДанныеКонечногоПолучателя Тогда
		
		ПлановыйПолучатель = ДанныеСтроки.КонечныйПолучатель;
		ПлановаяТочкаПолучателя = ДанныеСтроки.ТочкаКонечногоПолучателя;
		ПлановаяЗонаПолучателя = ДанныеСтроки.ЗонаКонечногоПолучателя;
		
	Иначе
		
		ПлановыйПолучатель = ДанныеСтроки.Получатель;
		ПлановаяТочкаПолучателя = ДанныеСтроки.ТочкаПолучателя;
		ПлановаяЗонаПолучателя = ДанныеСтроки.ЗонаПолучателя;
		
	КонецЕсли;
	
	Для Каждого СтрокаВариантов Из ТаблицаВариантов Цикл
		
		ЗаполнитьЗначенияСвойств(СтрокаВариантов, ДанныеСтроки);
		
		Если СтрокаВариантов.СодержимоеТочкаПолучателя = ПлановаяТочкаПолучателя
		   И СтрокаВариантов.СодержимоеЗонаПолучателя = ПлановаяЗонаПолучателя Тогда
			
			СтрокаВариантов.ПлановыеПараметры = Истина;
			ЕстьПлановыеПараметры = Истина;
			
		КонецЕсли;
		
	КонецЦикла;
	
	ТаблицаВариантов.Колонки.СодержимоеТочкаПолучателя.Имя = "ТочкаДоставки";
	ТаблицаВариантов.Колонки.СодержимоеЗонаПолучателя.Имя = "ЗонаДоставки";
	ТаблицаВариантов.Колонки.СодержимоеПолучатель.Имя = "ДоставкаДо";
	
	Если НЕ ЕстьПлановыеПараметры Тогда
		
		СтрокаПлановыхПараметров = ТаблицаВариантов.Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаПлановыхПараметров, ДанныеСтроки);
		СтрокаПлановыхПараметров.ДоставкаДо = ПлановыйПолучатель;
		СтрокаПлановыхПараметров.ТочкаДоставки = ПлановаяТочкаПолучателя;
		СтрокаПлановыхПараметров.ЗонаДоставки = ПлановаяЗонаПолучателя;
		СтрокаПлановыхПараметров.ПлановыеПараметры = Истина;
		
	КонецЕсли;
	
	ТаблицаВариантов.Сортировать("ПлановыеПараметры Убыв");
	
	АдресТаблицыВариантов = ПоместитьВоВременноеХранилище(ТаблицаВариантов);
	Результат.Вставить("АдресТаблицыВариантов", АдресТаблицыВариантов);
	
	Результат.Вставить("ВыбраннаяСтрока", ВыбраннаяСтрока);
	
	Возврат Результат;
	
КонецФункции

// Параметры:
//  ВыбранныеПараметры - КодВозвратаДиалога, Неопределено, Структура - Выбранные параметры:
//  * ВыбраннаяСтрока - Число
//  * Получатель - СправочникСсылка.Партнеры
//  * ТочкаПолучателя - СправочникСсылка.ТочкиДоставки
//  * ЗонаПолучателя - СправочникСсылка.ЗоныДоставки
//  ДополнительныеПараметры - Строка - Имя элемента списка
//
&НаКлиенте
Процедура СписокДоставитьВыборЗавершение(ВыбранныеПараметры, ДополнительныеПараметры) Экспорт
	
	Если ТипЗнч(ВыбранныеПараметры) = Тип("Структура") Тогда
		
		ИмяЭлемента = ДополнительныеПараметры;
		ДанныеСтроки = Элементы[ИмяЭлемента].ДанныеСтроки(ВыбранныеПараметры.ВыбраннаяСтрока); // См. ДанныеСтрокиСпискаДоставить
		ДобавитьСтрокиВПодобраноСервер(ДанныеСтроки, ВыбранныеПараметры);
		
		Элементы.СписокПоТоварам.Обновить();
		Элементы.СписокПоДокументам.Обновить();
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ПоместитьПодобранныеТоварыВХранилище()
	
	ТаблицаПодобрано = Подобрано.Выгрузить();
	
	КолонкиАнализа = "Распоряжение, ДокументПланирования, КодСтроки";
	ТаблицаСвернутаяПодобрано = ТаблицаПодобрано.Скопировать(, КолонкиАнализа);
	ТаблицаСвернутаяПодобрано.Свернуть(КолонкиАнализа);
	
	Запрос = Новый Запрос;
	ТекстЗапроса =
	"ВЫБРАТЬ
	|	ВтВнешниеДанные.Распоряжение КАК Распоряжение,
	|	ВтВнешниеДанные.ДокументПланирования КАК ДокументПланирования,
	|	ВтВнешниеДанные.КодСтроки КАК КодСтроки
	|ПОМЕСТИТЬ ВтДанныеСодержимое
	|ИЗ
	|	&ВнешниеДанные КАК ВтВнешниеДанные
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВтВнешниеДанные.Распоряжение КАК Распоряжение,
	|	ВтВнешниеДанные.ДокументПланирования КАК ДокументПланирования,
	|	ВтВнешниеДанные.КодСтроки КАК КодСтроки,
	|	ЕСТЬNULL(ДоставкаКонечноеПлечо.Получатель, НЕОПРЕДЕЛЕНО) КАК Получатель,
	|	ЕСТЬNULL(ДоставкаКонечноеПлечо.ТочкаПолучателя, ЗНАЧЕНИЕ(Справочник.ТочкиДоставки.ПустаяСсылка)) КАК ТочкаПолучателя,
	|	ЕСТЬNULL(ДоставкаКонечноеПлечо.ЗонаПолучателя, ЗНАЧЕНИЕ(Справочник.ЗоныДоставки.ПустаяСсылка)) КАК ЗонаПолучателя
	|ИЗ
	|	ВтДанныеСодержимое КАК ВтВнешниеДанные
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.Доставка КАК ДоставкаКонечноеПлечо
	|		ПО ВтВнешниеДанные.Распоряжение = ДоставкаКонечноеПлечо.Распоряжение
	|			И ВтВнешниеДанные.КодСтроки = ДоставкаКонечноеПлечо.КодСтроки
	|			И ВтВнешниеДанные.ДокументПланирования = ДоставкаКонечноеПлечо.ДокументПланирования
	|			И (ДоставкаКонечноеПлечо.ЭтоКонечноеПлечо)
	|			И (ДоставкаКонечноеПлечо.УровеньОперации В (&ПредыдущиеУровниОпераций))";
	Запрос.Текст = ТекстЗапроса;
	Запрос.УстановитьПараметр("ВнешниеДанные", ТаблицаСвернутаяПодобрано);
	Запрос.УстановитьПараметр("ПредыдущиеУровниОпераций", ПредыдущиеУровниОпераций);
	ДанныеДоставкиПлан = Запрос.Выполнить().Выгрузить();
	
	ТипКонечныйПункт = Новый ОписаниеТипов("СправочникСсылка.Партнеры, СправочникСсылка.Склады");
	ТипТочкаДоставки = Новый ОписаниеТипов("СправочникСсылка.ТочкиДоставки");
	ТипЗонаДоставки = Новый ОписаниеТипов("СправочникСсылка.ЗоныДоставки");
	
	ТаблицаПодобрано.Колонки.Добавить("КонечныйПункт", ТипКонечныйПункт);
	ТаблицаПодобрано.Колонки.Добавить("КонечнаяТочкаДоставки", ТипТочкаДоставки);
	ТаблицаПодобрано.Колонки.Добавить("КонечнаяЗонаДоставки", ТипЗонаДоставки);
	
	СтруктураПоиска = Новый Структура;
	СтруктураПоиска.Вставить("Распоряжение");
	СтруктураПоиска.Вставить("ДокументПланирования");
	СтруктураПоиска.Вставить("КодСтроки");
	
	Для каждого СтрокаТоваров Из ТаблицаПодобрано Цикл
		
		Если Объект.ЗафиксироватьПараметрыДоставки Тогда
			
			СтрокаТоваров.ТочкаДоставки = Объект.ТочкаДоставкиФиксированная;
			СтрокаТоваров.ЗонаДоставки = Объект.ЗонаДоставкиФиксированная;
			
		КонецЕсли;
		
		ЗаполнитьЗначенияСвойств(СтруктураПоиска, СтрокаТоваров);
		СтрокиДанных = ДанныеДоставкиПлан.НайтиСтроки(СтруктураПоиска);
		Если СтрокиДанных.Количество() > 0 Тогда
			
			СтрокаДанных = СтрокиДанных[0];
			
			Если СтрокаТоваров.ДоставкаДо <> СтрокаДанных.Получатель Тогда
				
				СтрокаТоваров.КонечныйПункт = СтрокаДанных.Получатель;
				СтрокаТоваров.КонечнаяТочкаДоставки = СтрокаДанных.ТочкаПолучателя;
				СтрокаТоваров.КонечнаяЗонаДоставки = СтрокаДанных.ЗонаПолучателя;
				
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЦикла;
	
	АдресПодобранныхТоваров = ПоместитьВоВременноеХранилище(ТаблицаПодобрано, УникальныйИдентификатор);
	
КонецПроцедуры

// Параметры:
//  РезультатВопроса - КодВозвратаДиалога
//  ДополнительныеПараметры - Неопределено
// 
&НаКлиенте
Процедура ПередЗакрытиемЗавершение(РезультатВопроса, ДополнительныеПараметры) Экспорт
	
	Если РезультатВопроса = КодВозвратаДиалога.Да Тогда
		
		ПеренестиВДокумент = Истина;
		ВыполняетсяЗакрытие = Истина;
		ПоместитьПодобранныеТоварыВХранилище();
		Закрыть(КодВозвратаДиалога.OK);
		ВыполняетсяЗакрытие = Ложь;
		
	ИначеЕсли РезультатВопроса = КодВозвратаДиалога.Нет Тогда
		
		ВыполняетсяЗакрытие = Истина;
		Закрыть();
		ВыполняетсяЗакрытие = Ложь;
		
	КонецЕсли;
	
КонецПроцедуры

// Параметры:
//  Строки - СтрокиДинамическогоСписка - 
//  ДокументДоставки - ДокументСсылка.Рейс - 
//  УчитыватьКоличествоВДокументе - Булево - 
//  ЭтоСписокПоТоварам - Булево -
//  ТекстЗапроса - Строка
// 
// Возвращаемое значение:
//  Структура - Детальные данные порции строк:
// * ПараметрыДоставкиСодержимогоПорции - ТаблицаЗначений
// * ФлагиПорции - ТаблицаЗначений:
//   ** ЕстьВСодержимом - Булево
//   ** ЕстьОтличияВПараметрахДоставки - Булево
// * ДетальныеОстаткиПорции - ТаблицаЗначений -
//
&НаСервереБезКонтекста
Функция ДетальныеДанныеПорцииСтрок(Строки, ДокументДоставки, УчитыватьКоличествоВДокументе, ЭтоСписокПоТоварам, ТекстЗапроса, ПредыдущиеУровниОпераций)
	
	РаспоряженияПорцииСтрок = Новый Массив; // Массив Из ОпределяемыйТип.РаспоряжениеНаДоставку25
	НоменклатураПорцииСтрок = Новый Массив; // Массив Из СправочникСсылка.Номенклатура
	
	Для Каждого СтрокаСписка Из Строки Цикл
		
		ДанныеСтрокиСписка = ДанныеСтрокиСпискаДоставить(СтрокаСписка);
		
		Если РаспоряженияПорцииСтрок.Найти(ДанныеСтрокиСписка.Распоряжение) = Неопределено Тогда
			РаспоряженияПорцииСтрок.Добавить(ДанныеСтрокиСписка.Распоряжение);
		КонецЕсли;
		
		Если ЭтоСписокПоТоварам Тогда
			
			Если НоменклатураПорцииСтрок.Найти(ДанныеСтрокиСписка.Номенклатура) = Неопределено Тогда
				НоменклатураПорцииСтрок.Добавить(ДанныеСтрокиСписка.Номенклатура);
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЦикла;
	
	Запрос = Новый Запрос;
	Запрос.Текст = ТекстЗапроса;
	Запрос.УстановитьПараметр("РаспоряженияПорцииСтрок", РаспоряженияПорцииСтрок);
	Если ЭтоСписокПоТоварам Тогда
		Запрос.УстановитьПараметр("НоменклатураПорцииСтрок", НоменклатураПорцииСтрок);
	КонецЕсли;
	Запрос.УстановитьПараметр("ДокументДоставки", ДокументДоставки);
	Запрос.УстановитьПараметр("УчитыватьКоличествоВДокументе", УчитыватьКоличествоВДокументе);
	Запрос.УстановитьПараметр("ПредыдущиеУровниОпераций", ПредыдущиеУровниОпераций);
	
	РезультатЗапроса = Запрос.ВыполнитьПакет();
	ПараметрыДоставкиСодержимогоПорции = РезультатЗапроса[РезультатЗапроса.ВГраница() - 2].Выгрузить();
	ФлагиПорции = РезультатЗапроса[РезультатЗапроса.ВГраница() - 1].Выгрузить();
	ДетальныеОстаткиПорции = РезультатЗапроса[РезультатЗапроса.ВГраница()].Выгрузить();
	
	Результат = Новый Структура;
	Результат.Вставить("ПараметрыДоставкиСодержимогоПорции", ПараметрыДоставкиСодержимогоПорции);
	Результат.Вставить("ФлагиПорции", ФлагиПорции);
	Результат.Вставить("ДетальныеОстаткиПорции", ДетальныеОстаткиПорции);
	
	Возврат Результат;
	
КонецФункции

&НаСервере
Функция ТекстЗапросаДетальныеДанныеПорцииСтрок(ЭтоСписокПоТоварам, УчитыватьКоличествоВДокументе)
	
	ПакетЗапросов = Новый Массив; // Массив Из Строка
	
	Если ТипЗнч(Объект.ДокументДоставки) = Тип("ДокументСсылка.ЗаказНаДоставку") Тогда
		
		ТекстЗапросаВТСодержимоеДокумента =
		"ВЫБРАТЬ
		|	ЗаказНаДоставкуТовары.Распоряжение КАК Распоряжение,
		|	ЗаказНаДоставкуТовары.КодСтрокиДоставки КАК КодСтроки,
		|	НЕОПРЕДЕЛЕНО КАК ДокументПланирования,
		|	ЗаказНаДоставку.ТочкаДоставкиПолучателя КАК ТочкаПолучателя,
		|	ЗаказНаДоставку.ЗонаДоставки КАК ЗонаПолучателя,
		|	ЗаказНаДоставку.Получатель КАК Получатель,
		|	ЗаказНаДоставкуТовары.Количество КАК Количество
		|ПОМЕСТИТЬ ВТСодержимоеДокумента
		|ИЗ
		|	Документ.ЗаказНаДоставку.Товары КАК ЗаказНаДоставкуТовары
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЗаказНаДоставку КАК ЗаказНаДоставку
		|		ПО (ЗаказНаДоставкуТовары.Ссылка = &ДокументДоставки)
		|			И (ЗаказНаДоставку.Ссылка = &ДокументДоставки)";
		
	Иначе
		
		ТекстЗапросаВТСодержимоеДокумента =
		"ВЫБРАТЬ
		|	РейсСодержимое.Распоряжение КАК Распоряжение,
		|	РейсСодержимое.КодСтроки КАК КодСтроки,
		|	РейсСодержимое.ДокументПланирования КАК ДокументПланирования,
		|	РейсМаршрут.ТочкаДоставки КАК ТочкаПолучателя,
		|	РейсМаршрут.ЗонаДоставки КАК ЗонаПолучателя,
		|	РейсМаршрут.Пункт КАК Получатель,
		|	РейсСодержимое.Количество КАК Количество
		|ПОМЕСТИТЬ ВТСодержимоеДокумента
		|ИЗ
		|	Документ.Рейс.Содержимое КАК РейсСодержимое
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.Рейс.Маршрут КАК РейсМаршрут
		|		ПО (РейсСодержимое.Ссылка = &ДокументДоставки)
		|			И (РейсМаршрут.Ссылка = &ДокументДоставки)
		|			И РейсСодержимое.КлючСвязи = РейсМаршрут.КлючСвязи
		|ГДЕ
		|	НЕ РейсСодержимое.Отменено";
		
	КонецЕсли;
	
	ПакетЗапросов.Добавить(ТекстЗапросаВТСодержимоеДокумента);
	
	ТекстЗапросаВТСодержимоеДокументаСвернуто =
	"ВЫБРАТЬ
	|	ВТСодержимоеДокумента.Распоряжение КАК Распоряжение,
	|	ВТСодержимоеДокумента.КодСтроки КАК КодСтроки,
	|	ВТСодержимоеДокумента.ДокументПланирования КАК ДокументПланирования,
	|	СУММА(ВТСодержимоеДокумента.Количество) КАК Количество
	|ПОМЕСТИТЬ ВТСодержимоеДокументаСвернуто
	|ИЗ
	|	ВТСодержимоеДокумента КАК ВТСодержимоеДокумента
	|
	|СГРУППИРОВАТЬ ПО
	|	ВТСодержимоеДокумента.Распоряжение,
	|	ВТСодержимоеДокумента.КодСтроки,
	|	ВТСодержимоеДокумента.ДокументПланирования";
	
	ПакетЗапросов.Добавить(ТекстЗапросаВТСодержимоеДокументаСвернуто);
	
	ТекстЗапросаВТОстатки =
	"ВЫБРАТЬ
	|	ДоставкаОбороты.Распоряжение КАК Распоряжение,
	|	&ВыражениеДокументПланирования КАК ДокументПланирования,
	|	ДоставкаОбороты.КодСтроки КАК КодСтроки,
	|	ДоставкаОбороты.Номенклатура КАК Номенклатура,
	|	ДоставкаОбороты.Характеристика КАК Характеристика,
	|	ДоставкаОбороты.Серия КАК Серия,
	|	ДоставкаОбороты.ДатаОтгрузки КАК ДатаОтгрузки,
	|	ДоставкаОбороты.СпособДоставки КАК СпособДоставки,
	|	ДоставкаОбороты.Отправитель КАК Отправитель,
	|	ДоставкаОбороты.Получатель КАК Получатель,
	|	ДоставкаОбороты.ТочкаПолучателя КАК ТочкаПолучателя,
	|	ДоставкаОбороты.ЗонаПолучателя КАК ЗонаПолучателя,
	|	ЗНАЧЕНИЕ(Справочник.УпаковкиЕдиницыИзмерения.ПустаяСсылка) КАК Упаковка,
	|	&ВыражениеКонечныйПолучатель КАК КонечныйПолучатель,
	|	&ВыражениеТочкаКонечногоПолучателя КАК ТочкаКонечногоПолучателя,
	|	&ВыражениеЗонаКонечногоПолучателя КАК ЗонаКонечногоПолучателя,
	|	&ВыражениеОстаток КАК Остаток
	|ПОМЕСТИТЬ ВТОстатки
	|ИЗ
	|	РегистрНакопления.Доставка.Обороты(
	|			,
	|			,
	|			,
	|			Плечо = 1
	|				И Распоряжение В (&РаспоряженияПорцииСтрок)
	|				И &УсловиеПоТоварам) КАК ДоставкаОбороты
	|		ЛЕВОЕ СОЕДИНЕНИЕ &ДоставкаКонечноеПлечо КАК ДоставкаКонечноеПлечо ПО ИСТИНА
	|ГДЕ
	|	&ВыражениеОстаток > 0";
	
	Если ТипЗнч(Объект.ДокументДоставки) = Тип("ДокументСсылка.ЗаказНаДоставку") Тогда
		
		ВыражениеОстаток = "ДоставкаОбороты.КДоставкеОборот - ДоставкаОбороты.КРейсуОборот";
		ВыражениеДокументПланирования = "НЕОПРЕДЕЛЕНО";
		
	Иначе
		
		ВыражениеОстаток = "ДоставкаОбороты.КРейсуОборот - ДоставкаОбороты.ВРейсеОборот + ДоставкаОбороты.ОтмененоОборот";
		ВыражениеДокументПланирования = "ДоставкаОбороты.ДокументПланирования";
		
	КонецЕсли;
	
	ТекстЗапросаВТОстатки = СтрЗаменить(ТекстЗапросаВТОстатки, "&ВыражениеОстаток", ВыражениеОстаток);
	ТекстЗапросаВТОстатки = СтрЗаменить(ТекстЗапросаВТОстатки, "&ВыражениеДокументПланирования", ВыражениеДокументПланирования);
	
	Если ЭтоСписокПоТоварам Тогда
		УсловиеПоТоварам = "Номенклатура В (&НоменклатураПорцииСтрок)";
	Иначе
		УсловиеПоТоварам = "ИСТИНА";
	КонецЕсли;
	
	ТекстЗапросаВТОстатки = СтрЗаменить(ТекстЗапросаВТОстатки, "&УсловиеПоТоварам", УсловиеПоТоварам);
	
	Если ТипЗнч(Объект.ДокументДоставки) = Тип("ДокументСсылка.Рейс")
	   И Объект.СпособДоставкиДокумента = Перечисления.СпособыДоставки25.СиламиПеревозчика Тогда
		
		ВыражениеКонечныйПолучатель = "ВЫБОР
		|		КОГДА ЕСТЬNULL(ДоставкаКонечноеПлечо.Плечо, 1) > 1
		|			ТОГДА ЕСТЬNULL(ДоставкаКонечноеПлечо.Получатель, ЗНАЧЕНИЕ(Справочник.Партнеры.ПустаяСсылка))
		|		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.Партнеры.ПустаяСсылка)
		|	КОНЕЦ";
		
		ВыражениеТочкаКонечногоПолучателя = "ВЫБОР
		|		КОГДА ЕСТЬNULL(ДоставкаКонечноеПлечо.Плечо, 1) > 1
		|			ТОГДА ЕСТЬNULL(ДоставкаКонечноеПлечо.ТочкаПолучателя, ЗНАЧЕНИЕ(Справочник.ТочкиДоставки.ПустаяСсылка))
		|		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.ТочкиДоставки.ПустаяСсылка)
		|	КОНЕЦ";
		
		ВыражениеЗонаКонечногоПолучателя = "ВЫБОР
		|		КОГДА ЕСТЬNULL(ДоставкаКонечноеПлечо.Плечо, 1) > 1
		|			ТОГДА ЕСТЬNULL(ДоставкаКонечноеПлечо.ЗонаПолучателя, ЗНАЧЕНИЕ(Справочник.ЗоныДоставки.ПустаяСсылка))
		|		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.ЗоныДоставки.ПустаяСсылка)
		|	КОНЕЦ";
		
		СоединениеКонечноеПлечо =
		"		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.Доставка КАК ДоставкаКонечноеПлечо
		|		ПО ДоставкаОбороты.Распоряжение = ДоставкаКонечноеПлечо.Распоряжение
		|			И ДоставкаОбороты.КодСтроки = ДоставкаКонечноеПлечо.КодСтроки
		|			И ДоставкаОбороты.ДокументПланирования = ДоставкаКонечноеПлечо.ДокументПланирования
		|			И (ДоставкаКонечноеПлечо.ЭтоКонечноеПлечо)
		|			И (ДоставкаКонечноеПлечо.УровеньОперации В (&ПредыдущиеУровниОпераций))";
		
	Иначе
		
		ВыражениеКонечныйПолучатель = "ЗНАЧЕНИЕ(Справочник.Партнеры.ПустаяСсылка)";
		ВыражениеТочкаКонечногоПолучателя = "ЗНАЧЕНИЕ(Справочник.ТочкиДоставки.ПустаяСсылка)";
		ВыражениеЗонаКонечногоПолучателя = "ЗНАЧЕНИЕ(Справочник.ЗоныДоставки.ПустаяСсылка)";
		СоединениеКонечноеПлечо = "";
		
	КонецЕсли;
	
	ТекстЗапросаВТОстатки = СтрЗаменить(ТекстЗапросаВТОстатки, "&ВыражениеКонечныйПолучатель", ВыражениеКонечныйПолучатель);
	ТекстЗапросаВТОстатки = СтрЗаменить(ТекстЗапросаВТОстатки, "&ВыражениеТочкаКонечногоПолучателя", ВыражениеТочкаКонечногоПолучателя);
	ТекстЗапросаВТОстатки = СтрЗаменить(ТекстЗапросаВТОстатки, "&ВыражениеЗонаКонечногоПолучателя", ВыражениеЗонаКонечногоПолучателя);
	ТекстЗапросаВТОстатки = СтрЗаменить(
		ТекстЗапросаВТОстатки,
		"ЛЕВОЕ СОЕДИНЕНИЕ &ДоставкаКонечноеПлечо КАК ДоставкаКонечноеПлечо ПО ИСТИНА",
		СоединениеКонечноеПлечо);
	
	ПакетЗапросов.Добавить(ТекстЗапросаВТОстатки);
	
	ТекстЗапросаПараметрыДоставки =
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ВТОстатки.Распоряжение КАК Распоряжение,
	|	&ПоляТовара,
	|	ВТОстатки.ДатаОтгрузки КАК ДатаОтгрузки,
	|	ВТОстатки.СпособДоставки КАК СпособДоставки,
	|	ВТОстатки.Отправитель КАК Отправитель,
	|	ВТОстатки.Получатель КАК Получатель,
	|	ВТОстатки.ТочкаПолучателя КАК ТочкаПолучателя,
	|	ВТОстатки.ЗонаПолучателя КАК ЗонаПолучателя,
	|	ВТОстатки.КонечныйПолучатель КАК КонечныйПолучатель,
	|	ВТОстатки.ТочкаКонечногоПолучателя КАК ТочкаКонечногоПолучателя,
	|	ВТОстатки.ЗонаКонечногоПолучателя КАК ЗонаКонечногоПолучателя,
	|	ВТСодержимоеДокумента.ТочкаПолучателя КАК СодержимоеТочкаПолучателя,
	|	ВТСодержимоеДокумента.ЗонаПолучателя КАК СодержимоеЗонаПолучателя,
	|	ВТСодержимоеДокумента.Получатель КАК СодержимоеПолучатель
	|ИЗ
	|	ВТОстатки КАК ВТОстатки
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТСодержимоеДокумента КАК ВТСодержимоеДокумента
	|		ПО ВТОстатки.Распоряжение = ВТСодержимоеДокумента.Распоряжение
	|			И &УсловиеСвязиПоДокументуПланирования
	|			И ВТОстатки.КодСтроки = ВТСодержимоеДокумента.КодСтроки";
	
	Если ЭтоСписокПоТоварам Тогда
		
		ПоляТовара =
		"ВТОстатки.Номенклатура КАК Номенклатура,
		|	ВТОстатки.Характеристика КАК Характеристика,
		|	ВТОстатки.Серия КАК Серия,
		|	ВТОстатки.Упаковка КАК Упаковка";
		
	Иначе
		
		ПоляТовара = "NULL";
		
	КонецЕсли;
	
	Если ТипЗнч(Объект.ДокументДоставки) = Тип("ДокументСсылка.ЗаказНаДоставку") Тогда
		УсловиеСвязиПоДокументуПланирования = "ИСТИНА";
	Иначе
		УсловиеСвязиПоДокументуПланирования = "ВТОстатки.ДокументПланирования = ВТСодержимоеДокумента.ДокументПланирования";
	КонецЕсли;
	
	ТекстЗапросаПараметрыДоставки = СтрЗаменить(
		ТекстЗапросаПараметрыДоставки, "&УсловиеСвязиПоДокументуПланирования", УсловиеСвязиПоДокументуПланирования);
	ТекстЗапросаПараметрыДоставки = СтрЗаменить(ТекстЗапросаПараметрыДоставки, "&ПоляТовара", ПоляТовара);
	
	ПакетЗапросов.Добавить(ТекстЗапросаПараметрыДоставки);
	
	ТекстЗапросаФлаги =
	"ВЫБРАТЬ
	|	Остатки.Распоряжение КАК Распоряжение,
	|	&ПоляТовараВнешние,
	|	Остатки.ДатаОтгрузки КАК ДатаОтгрузки,
	|	Остатки.СпособДоставки КАК СпособДоставки,
	|	Остатки.Отправитель КАК Отправитель,
	|	Остатки.Получатель КАК Получатель,
	|	Остатки.ТочкаПолучателя КАК ТочкаПолучателя,
	|	Остатки.ЗонаПолучателя КАК ЗонаПолучателя,
	|	Остатки.КонечныйПолучатель КАК КонечныйПолучатель,
	|	Остатки.ТочкаКонечногоПолучателя КАК ТочкаКонечногоПолучателя,
	|	Остатки.ЗонаКонечногоПолучателя КАК ЗонаКонечногоПолучателя,
	|	МАКСИМУМ(Остатки.ЕстьВСодержимом) КАК ЕстьВСодержимом,
	|	МАКСИМУМ(Остатки.ЕстьОтличияВПараметрахДоставки) КАК ЕстьОтличияВПараметрахДоставки
	|ИЗ
	|	(ВЫБРАТЬ
	|		ВТОстатки.Распоряжение КАК Распоряжение,
	|		&ПоляТовараВнутренние,
	|		ВТОстатки.ДатаОтгрузки КАК ДатаОтгрузки,
	|		ВТОстатки.СпособДоставки КАК СпособДоставки,
	|		ВТОстатки.Отправитель КАК Отправитель,
	|		ВТОстатки.Получатель КАК Получатель,
	|		ВТОстатки.ТочкаПолучателя КАК ТочкаПолучателя,
	|		ВТОстатки.ЗонаПолучателя КАК ЗонаПолучателя,
	|		ВТОстатки.КонечныйПолучатель КАК КонечныйПолучатель,
	|		ВТОстатки.ТочкаКонечногоПолучателя КАК ТочкаКонечногоПолучателя,
	|		ВТОстатки.ЗонаКонечногоПолучателя КАК ЗонаКонечногоПолучателя,
	|		ВЫБОР
	|			КОГДА ВТСодержимоеДокумента.КодСтроки ЕСТЬ NULL
	|				ТОГДА ЛОЖЬ
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ КАК ЕстьВСодержимом,
	|		ВЫБОР
	|			КОГДА ВТСодержимоеДокумента.ТочкаПолучателя ЕСТЬ NULL
	|				ТОГДА ЛОЖЬ
	|			КОГДА ВТОстатки.ТочкаКонечногоПолучателя = ЕСТЬNULL(ВТСодержимоеДокумента.ТочкаПолучателя, ЗНАЧЕНИЕ(Справочник.ТочкиДоставки.ПустаяСсылка))
	|					И ВТОстатки.ЗонаКонечногоПолучателя = ЕСТЬNULL(ВТСодержимоеДокумента.ЗонаПолучателя, ЗНАЧЕНИЕ(Справочник.ЗоныДоставки.ПустаяСсылка))
	|				ТОГДА ЛОЖЬ
	|			КОГДА ВТОстатки.ТочкаПолучателя = ЕСТЬNULL(ВТСодержимоеДокумента.ТочкаПолучателя, ЗНАЧЕНИЕ(Справочник.ТочкиДоставки.ПустаяСсылка))
	|					И ВТОстатки.ЗонаПолучателя = ЕСТЬNULL(ВТСодержимоеДокумента.ЗонаПолучателя, ЗНАЧЕНИЕ(Справочник.ЗоныДоставки.ПустаяСсылка))
	|				ТОГДА ЛОЖЬ
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ КАК ЕстьОтличияВПараметрахДоставки
	|	ИЗ
	|		ВТОстатки КАК ВТОстатки
	|			ЛЕВОЕ СОЕДИНЕНИЕ ВТСодержимоеДокумента КАК ВТСодержимоеДокумента
	|			ПО ВТОстатки.Распоряжение = ВТСодержимоеДокумента.Распоряжение
	|				И &УсловиеСвязиПоДокументуПланирования
	|				И ВТОстатки.КодСтроки = ВТСодержимоеДокумента.КодСтроки) КАК Остатки
	|
	|СГРУППИРОВАТЬ ПО
	|	Остатки.ДатаОтгрузки,
	|	&ПоляГруппировкиПоТовару,
	|	Остатки.СпособДоставки,
	|	Остатки.Распоряжение,
	|	Остатки.Отправитель,
	|	Остатки.Получатель,
	|	Остатки.ТочкаПолучателя,
	|	Остатки.ЗонаПолучателя,
	|	Остатки.КонечныйПолучатель,
	|	Остатки.ТочкаКонечногоПолучателя,
	|	Остатки.ЗонаКонечногоПолучателя";
	
	Если ЭтоСписокПоТоварам Тогда
		
		ПоляТовараВнешние =
		"Остатки.Номенклатура КАК Номенклатура,
		|	Остатки.Характеристика КАК Характеристика,
		|	Остатки.Серия КАК Серия,
		|	Остатки.Упаковка КАК Упаковка";
		
		ПоляТовараВнутренние =
		"ВТОстатки.Номенклатура КАК Номенклатура,
		|		ВТОстатки.Характеристика КАК Характеристика,
		|		ВТОстатки.Серия КАК Серия,
		|		ВТОстатки.Упаковка КАК Упаковка";
		
		ПоляГруппировкиПоТовару =
		"Остатки.Номенклатура,
		|	Остатки.Характеристика,
		|	Остатки.Серия,
		|	Остатки.Упаковка";
		
	Иначе
		
		ПоляТовараВнешние = "NULL";
		ПоляТовараВнутренние = "NULL";
		ПоляГруппировкиПоТовару = "NULL";
		
	КонецЕсли;
	
	Если ТипЗнч(Объект.ДокументДоставки) = Тип("ДокументСсылка.ЗаказНаДоставку") Тогда
		УсловиеСвязиПоДокументуПланирования = "ИСТИНА";
	Иначе
		УсловиеСвязиПоДокументуПланирования = "ВТОстатки.ДокументПланирования = ВТСодержимоеДокумента.ДокументПланирования";
	КонецЕсли;
	
	ТекстЗапросаФлаги = СтрЗаменить(
		ТекстЗапросаФлаги, "&УсловиеСвязиПоДокументуПланирования", УсловиеСвязиПоДокументуПланирования);
	ТекстЗапросаФлаги = СтрЗаменить(ТекстЗапросаФлаги, "&ПоляТовараВнешние", ПоляТовараВнешние);
	ТекстЗапросаФлаги = СтрЗаменить(ТекстЗапросаФлаги, "&ПоляТовараВнутренние", ПоляТовараВнутренние);
	ТекстЗапросаФлаги = СтрЗаменить(ТекстЗапросаФлаги, "&ПоляГруппировкиПоТовару", ПоляГруппировкиПоТовару);
	
	ПакетЗапросов.Добавить(ТекстЗапросаФлаги);
	
	Если УчитыватьКоличествоВДокументе Тогда
		
		ТекстЗапросаДетальныеОстатки =
		"ВЫБРАТЬ
		|	ВТОстатки.Распоряжение КАК Распоряжение,
		|	&ДокументПланирования КАК ДокументПланирования,
		|	ВТОстатки.КодСтроки КАК КодСтроки,
		|	ВТОстатки.Номенклатура КАК Номенклатура,
		|	ВТОстатки.Характеристика КАК Характеристика,
		|	ВТОстатки.Серия КАК Серия,
		|	ВТОстатки.Упаковка КАК Упаковка,
		|	ВТОстатки.ДатаОтгрузки КАК ДатаОтгрузки,
		|	ВТОстатки.СпособДоставки КАК СпособДоставки,
		|	ВТОстатки.Отправитель КАК Отправитель,
		|	ВТОстатки.Получатель КАК Получатель,
		|	ВТОстатки.ТочкаПолучателя КАК ТочкаПолучателя,
		|	ВТОстатки.ЗонаПолучателя КАК ЗонаПолучателя,
		|	ВТОстатки.КонечныйПолучатель КАК КонечныйПолучатель,
		|	ВТОстатки.ТочкаКонечногоПолучателя КАК ТочкаКонечногоПолучателя,
		|	ВТОстатки.ЗонаКонечногоПолучателя КАК ЗонаКонечногоПолучателя,
		|	СУММА(ВТОстатки.Остаток - ЕСТЬNULL(ВТСодержимоеДокументаСвернуто.Количество, 0)) КАК Остаток
		|ИЗ
		|	ВТОстатки КАК ВТОстатки
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТСодержимоеДокументаСвернуто КАК ВТСодержимоеДокументаСвернуто
		|		ПО ВТОстатки.Распоряжение = ВТСодержимоеДокументаСвернуто.Распоряжение
		|			И ВТОстатки.КодСтроки = ВТСодержимоеДокументаСвернуто.КодСтроки
		|			И &УсловиеСвязиПоДокументуПланирования
		|
		|СГРУППИРОВАТЬ ПО
		|	ВТОстатки.Распоряжение,
		|	&ДокументПланирования,
		|	ВТОстатки.КодСтроки,
		|	ВТОстатки.Номенклатура,
		|	ВТОстатки.Характеристика,
		|	ВТОстатки.Серия,
		|	ВТОстатки.Упаковка,
		|	ВТОстатки.ДатаОтгрузки,
		|	ВТОстатки.СпособДоставки,
		|	ВТОстатки.Отправитель,
		|	ВТОстатки.Получатель,
		|	ВТОстатки.ТочкаПолучателя,
		|	ВТОстатки.ЗонаПолучателя,
		|	ВТОстатки.КонечныйПолучатель,
		|	ВТОстатки.ТочкаКонечногоПолучателя,
		|	ВТОстатки.ЗонаКонечногоПолучателя";
		
	Иначе
		
		ТекстЗапросаДетальныеОстатки =
		"ВЫБРАТЬ
		|	ВТОстатки.Распоряжение КАК Распоряжение,
		|	&ДокументПланирования КАК ДокументПланирования,
		|	ВТОстатки.КодСтроки КАК КодСтроки,
		|	ВТОстатки.Номенклатура КАК Номенклатура,
		|	ВТОстатки.Характеристика КАК Характеристика,
		|	ВТОстатки.Серия КАК Серия,
		|	ВТОстатки.Упаковка КАК Упаковка,
		|	ВТОстатки.ДатаОтгрузки КАК ДатаОтгрузки,
		|	ВТОстатки.СпособДоставки КАК СпособДоставки,
		|	ВТОстатки.Отправитель КАК Отправитель,
		|	ВТОстатки.Получатель КАК Получатель,
		|	ВТОстатки.ТочкаПолучателя КАК ТочкаПолучателя,
		|	ВТОстатки.ЗонаПолучателя КАК ЗонаПолучателя,
		|	ВТОстатки.КонечныйПолучатель КАК КонечныйПолучатель,
		|	ВТОстатки.ТочкаКонечногоПолучателя КАК ТочкаКонечногоПолучателя,
		|	ВТОстатки.ЗонаКонечногоПолучателя КАК ЗонаКонечногоПолучателя,
		|	СУММА(ВТОстатки.Остаток) КАК Остаток
		|ИЗ
		|	ВТОстатки КАК ВТОстатки
		|
		|СГРУППИРОВАТЬ ПО
		|	ВТОстатки.Распоряжение,
		|	&ДокументПланирования,
		|	ВТОстатки.КодСтроки,
		|	ВТОстатки.Номенклатура,
		|	ВТОстатки.Характеристика,
		|	ВТОстатки.Серия,
		|	ВТОстатки.Упаковка,
		|	ВТОстатки.ДатаОтгрузки,
		|	ВТОстатки.СпособДоставки,
		|	ВТОстатки.Отправитель,
		|	ВТОстатки.Получатель,
		|	ВТОстатки.ТочкаПолучателя,
		|	ВТОстатки.ЗонаПолучателя,
		|	ВТОстатки.КонечныйПолучатель,
		|	ВТОстатки.ТочкаКонечногоПолучателя,
		|	ВТОстатки.ЗонаКонечногоПолучателя";
		
	КонецЕсли;
	
	Если ТипЗнч(Объект.ДокументДоставки) = Тип("ДокументСсылка.ЗаказНаДоставку") Тогда
		
		ВыражениеДокументПланирования = "НЕОПРЕДЕЛЕНО";
		УсловиеСвязиПоДокументуПланирования = "ИСТИНА";
		
	Иначе
		
		ВыражениеДокументПланирования = "ВТОстатки.ДокументПланирования";
		УсловиеСвязиПоДокументуПланирования = "ВТОстатки.ДокументПланирования = ВТСодержимоеДокументаСвернуто.ДокументПланирования";
		
	КонецЕсли;
	
	ТекстЗапросаДетальныеОстатки = СтрЗаменить(
		ТекстЗапросаДетальныеОстатки, "&ДокументПланирования", ВыражениеДокументПланирования);
	ТекстЗапросаДетальныеОстатки = СтрЗаменить(
		ТекстЗапросаДетальныеОстатки, "&УсловиеСвязиПоДокументуПланирования", УсловиеСвязиПоДокументуПланирования);
	
	ПакетЗапросов.Добавить(ТекстЗапросаДетальныеОстатки);
	
	ТекстЗапроса = СтрСоединить(ПакетЗапросов, ОбщегоНазначения.РазделительПакетаЗапросов());
	
	Возврат ТекстЗапроса;
	
КонецФункции

// Параметры:
//  СтрокаСписка - СтрокаДинамическогоСписка
// 
// Возвращаемое значение:
//  ДанныеФормыСтруктура - Данные строки:
//  * Номенклатура - СправочникСсылка.Номенклатура
//  * Подобрано - Число
//  * Остаток - Число
//  * ЕстьОтличияВПараметрахДоставки - Булево
//  * ИндексКартинки - Число
//  * Детализация - ХранилищеЗначения
//  * ВариантыПараметровДоставки - ХранилищеЗначения
//  * Распоряжение - ОпределяемыйТип.РаспоряжениеНаДоставку25
//  * ТипДоставки - ПеречислениеСсылка.ТипыДоставки
//  * Получатель - СправочникСсылка.Партнеры
//  * ТочкаПолучателя - СправочникСсылка.ТочкиДоставки
//  * ЗонаПолучателя - СправочникСсылка.ЗоныДоставки
//  * КонечныйПолучатель - СправочникСсылка.Партнеры
//  * ТочкаКонечногоПолучателя - СправочникСсылка.ТочкиДоставки
//  * ЗонаКонечногоПолучателя - СправочникСсылка.ЗоныДоставки
//
&НаСервереБезКонтекста
Функция ДанныеСтрокиСпискаДоставить(СтрокаСписка)
	
	ДанныеСтрокиСписка = СтрокаСписка.Значение.Данные;
	Возврат ДанныеСтрокиСписка;
	
КонецФункции

// Параметры:
//  Настройки - НастройкиКомпоновкиДанных
// 
// Возвращаемое значение:
//  Структура:
//    * УчитыватьКоличествоВДокументе - Булево
//    * ДокументДоставки - ДокументСсылка.Рейс
//    * АдресТаблицыПодобрано - Строка
//    * ТекстЗапросаДетальныеДанныеПорцииСтрок - Строка
//    * ВыводитьКартинкуЕстьОтличияВПараметрахДоставки - Булево
//    * ПредыдущиеУровниОпераций - СписокЗначений Из Число
//    * ВыводитьКонечногоПолучателя - Булево
//  
&НаКлиентеНаСервереБезКонтекста
Функция ДопСвойстваНастроекСписка(Настройки)
	
	Возврат Настройки.ДополнительныеСвойства;
	
КонецФункции

// Параметры:
//  ДанныеСтроки - ДанныеФормыСтруктура
// 
// Возвращаемое значение:
//  ТаблицаЗначений - Варианты параметров доставки по строке:
// * Номенклатура - СправочникСсылка.Номенклатура
// * Характеристика - СправочникСсылка.ХарактеристикиНоменклатуры
// * Серия - СправочникСсылка.СерииНоменклатуры
// * Распоряжение - ОпределяемыйТип.РаспоряжениеНаДоставку25
// * ПлановыеПараметры - Булево
// * СодержимоеПолучатель - СправочникСсылка.Партнеры
// * СодержимоеТочкаПолучателя - СправочникСсылка.ТочкиДоставки
// * СодержимоеЗонаПолучателя - СправочникСсылка.ЗоныДоставки
//
&НаСервереБезКонтекста
Функция ВариантыПараметровДоставкиПоСтроке(ДанныеСтроки)
	
	Результат = ДанныеСтроки.ВариантыПараметровДоставки.Получить(); // ТаблицаЗначений
	Возврат Результат;
	
КонецФункции

// Параметры:
//  ДопСвойства - См. ДопСвойстваНастроекСписка
// 
// Возвращаемое значение:
//  ТаблицаЗначений:
//  * Количество - Число
//
&НаСервереБезКонтекста
Функция ТаблицаПодобрано(ДопСвойства)
	
	АдресТаблицыПодобрано = ДопСвойства.АдресТаблицыПодобрано;
	ТаблицаПодобрано = ПолучитьИзВременногоХранилища(АдресТаблицыПодобрано); // ТаблицаЗначений
	Возврат ТаблицаПодобрано;
	
КонецФункции

&НаСервереБезКонтекста
Процедура СписокПриПолученииДанныхНаСервере(ИмяЭлемента, Настройки, Строки)
	
	ЭтоСписокПоТоварам = (ИмяЭлемента = "СписокПоТоварам");
	
	ДопСвойства = ДопСвойстваНастроекСписка(Настройки);
	УчитыватьКоличествоВДокументе = ДопСвойства.УчитыватьКоличествоВДокументе;
	ДокументДоставки = ДопСвойства.ДокументДоставки;
	ТекстЗапроса = ДопСвойства.ТекстЗапросаДетальныеДанныеПорцииСтрок;
	ПредыдущиеУровниОпераций = ДопСвойства.ПредыдущиеУровниОпераций;
	ВыводитьКонечногоПолучателя = ДопСвойства.ВыводитьКонечногоПолучателя;
	
	ДетальныеДанные = ДетальныеДанныеПорцииСтрок(
		Строки, ДокументДоставки, УчитыватьКоличествоВДокументе, ЭтоСписокПоТоварам, ТекстЗапроса, ПредыдущиеУровниОпераций);
	
	ОтборДетальныхОстатков = ОтборДетальныхОстатков(ЭтоСписокПоТоварам, ВыводитьКонечногоПолучателя);
	КолонкиДетальныхОстатков = "ДокументПланирования,КодСтроки,Остаток";
	Если НЕ ЭтоСписокПоТоварам Тогда
		КолонкиДетальныхОстатков = КолонкиДетальныхОстатков + ",Номенклатура,Характеристика,Серия";
	КонецЕсли;
	
	КолонкиПараметровДоставки = "СодержимоеТочкаПолучателя,СодержимоеЗонаПолучателя,СодержимоеПолучатель";
	
	Если ЭтоСписокПоТоварам Тогда
		ТаблицаПодобрано = ТаблицаПодобрано(ДопСвойства);
	КонецЕсли;
	
	Для Каждого СтрокаСписка Из Строки Цикл
		
		ДанныеСтрокиСписка = ДанныеСтрокиСпискаДоставить(СтрокаСписка);
		ЗаполнитьЗначенияСвойств(ОтборДетальныхОстатков, ДанныеСтрокиСписка);
		
		ЕстьВСодержимом = Ложь;
		СтрокиФлагов = ДетальныеДанные.ФлагиПорции.НайтиСтроки(ОтборДетальныхОстатков);
		Если СтрокиФлагов.Количество() > 0 Тогда
			
			ЕстьВСодержимом = СтрокиФлагов[0].ЕстьВСодержимом;
			ДанныеСтрокиСписка.ЕстьОтличияВПараметрахДоставки = СтрокиФлагов[0].ЕстьОтличияВПараметрахДоставки;
			
		КонецЕсли;
		
		Если ДанныеСтрокиСписка.ЕстьОтличияВПараметрахДоставки
		   И ДопСвойства.ВыводитьКартинкуЕстьОтличияВПараметрахДоставки Тогда
			ДанныеСтрокиСписка.ИндексКартинки = 0;
		ИначеЕсли ЕстьВСодержимом Тогда
			ДанныеСтрокиСписка.ИндексКартинки = 1;
		Иначе
			ДанныеСтрокиСписка.ИндексКартинки = -1;
		КонецЕсли;
		
		ДетализацияСтроки = ДетальныеДанные.ДетальныеОстаткиПорции.Скопировать(ОтборДетальныхОстатков, КолонкиДетальныхОстатков);
		ДанныеСтрокиСписка.Детализация = Новый ХранилищеЗначения(ДетализацияСтроки);
		
		ВариантыПараметровДоставки = ДетальныеДанные.ПараметрыДоставкиСодержимогоПорции.Скопировать(
			ОтборДетальныхОстатков, КолонкиПараметровДоставки);
		ВариантыПараметровДоставки.Свернуть(КолонкиПараметровДоставки);
		ДанныеСтрокиСписка.ВариантыПараметровДоставки = Новый ХранилищеЗначения(ВариантыПараметровДоставки);
		
		Если ЭтоСписокПоТоварам Тогда
			
			ЗаполнитьПодобраноВСтрокеСписка(ТаблицаПодобрано, ДанныеСтрокиСписка, ДетализацияСтроки);
			
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

&НаСервереБезКонтекста
Процедура ЗаполнитьПодобраноВСтрокеСписка(ТаблицаПодобрано, ДанныеСтрокиСписка, ДетализацияСтроки)
	
	ОтборСтрокПодобрано = Новый Структура;
	ОтборСтрокПодобрано.Вставить("Распоряжение", Неопределено);
	ОтборСтрокПодобрано.Вставить("ДокументПланирования", Неопределено);
	ОтборСтрокПодобрано.Вставить("КодСтроки", 0);
	
	ЗаполнитьЗначенияСвойств(ОтборСтрокПодобрано, ДанныеСтрокиСписка);
	
	Для Каждого ВариантДетализации Из ДетализацияСтроки Цикл
		
		ЗаполнитьЗначенияСвойств(ОтборСтрокПодобрано, ВариантДетализации);
		СтрокиПодобрано = ТаблицаПодобрано.НайтиСтроки(ОтборСтрокПодобрано);
		
		Для Каждого СтрокаПодобрано Из СтрокиПодобрано Цикл
			
			ДанныеСтрокиСписка.Подобрано = ДанныеСтрокиСписка.Подобрано + СтрокаПодобрано.Количество;
			
		КонецЦикла;
		
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ИнициализироватьДополнительныеСвойстваСписков()
	
	ТаблицаПодобрано = Подобрано.Выгрузить();
	АдресТаблицыПодобрано = ПоместитьВоВременноеХранилище(ТаблицаПодобрано, УникальныйИдентификатор);
	
	ВыводитьКартинкуЕстьОтличияВПараметрахДоставки = (ТипЗнч(Объект.ДокументДоставки) = Тип("ДокументСсылка.Рейс"));
	
	ВыводитьКонечногоПолучателя = (ТипЗнч(Объект.ДокументДоставки) = Тип("ДокументСсылка.Рейс")
		И Объект.СпособДоставкиДокумента = Перечисления.СпособыДоставки25.СиламиПеревозчика);
	
	Списки = Новый Массив; // Массив Из ДинамическийСписок
	Списки.Добавить(СписокПоТоварам);
	Списки.Добавить(СписокПоДокументам);
	
	Для Каждого СписокОстатков Из Списки Цикл
		
		ЭтоСписокПоТоварам = (СписокОстатков = СписокПоТоварам);
		
		ДопСвойства = СписокОстатков.КомпоновщикНастроек.Настройки.ДополнительныеСвойства;
		ДопСвойства.Вставить("УчитыватьКоличествоВДокументе", Объект.УчитыватьКоличествоВДокументе);
		ДопСвойства.Вставить("ДокументДоставки", Объект.ДокументДоставки);
		ДопСвойства.Вставить("АдресТаблицыПодобрано", АдресТаблицыПодобрано);
		ДопСвойства.Вставить("ВыводитьКартинкуЕстьОтличияВПараметрахДоставки", ВыводитьКартинкуЕстьОтличияВПараметрахДоставки);
		ДопСвойства.Вставить("ПредыдущиеУровниОпераций", ПредыдущиеУровниОпераций);
		ДопСвойства.Вставить("ВыводитьКонечногоПолучателя", ВыводитьКонечногоПолучателя);
		
		ТекстЗапроса = ТекстЗапросаДетальныеДанныеПорцииСтрок(ЭтоСписокПоТоварам, Объект.УчитыватьКоличествоВДокументе);
		ДопСвойства.Вставить("ТекстЗапросаДетальныеДанныеПорцииСтрок", ТекстЗапроса);
		
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ИнициализироватьОтборыСписков()
	
	Если ТипЗнч(Объект.ДокументДоставки) = Тип("ДокументСсылка.Рейс")
		И Не Объект.ЗафиксироватьПараметрыДоставки Тогда
		
		ПолеОтбораКонечныйПолучатель = "КонечныйПолучательКонечноеПлечо";
		
	Иначе
		
		ПолеОтбораКонечныйПолучатель = "КонечныйПолучательОбороты";
		
	КонецЕсли;
	
	ПодходящиеСпособыДоставки = Новый СписокЗначений; // СписокЗначений Из ПеречислениеСсылка.СпособыДоставки25
	Если ЗначениеЗаполнено(Объект.СпособДоставки) Тогда
		
		ПодходящиеСпособыДоставки.Добавить(Объект.СпособДоставки);
		
		Если Не Объект.ПараметрыДоставкиСоответствуютРейсу Тогда
			ПодходящиеСпособыДоставки.Добавить(Перечисления.СпособыДоставки25.ОпределяетСлужбаДоставки);
		КонецЕсли;
		
	КонецЕсли;
	
	Списки = Новый Массив; // Массив Из ДинамическийСписок
	Списки.Добавить(СписокПоТоварам);
	Списки.Добавить(СписокПоДокументам);
	
	Для Каждого СписокОстатков Из Списки Цикл
		
		ОбщегоНазначенияКлиентСервер.УстановитьПараметрДинамическогоСписка(
			СписокОстатков, "Организация", Объект.Организация);
		ОбщегоНазначенияКлиентСервер.УстановитьПараметрДинамическогоСписка(
			СписокОстатков, "Склад", Объект.Склад);
		ОбщегоНазначенияКлиентСервер.УстановитьПараметрДинамическогоСписка(
			СписокОстатков, "ДатаОтгрузкиПо", Объект.ДатаОтгрузки, ЗначениеЗаполнено(Объект.ДатаОтгрузки));
		ОбщегоНазначенияКлиентСервер.УстановитьПараметрДинамическогоСписка(
			СписокОстатков, "ПредыдущиеУровниОпераций", ПредыдущиеУровниОпераций);
		
		Если Объект.ПараметрыДоставкиСоответствуютРейсу Тогда
			
			ОбщегоНазначенияКлиентСервер.УстановитьПараметрДинамическогоСписка(
				СписокОстатков, "ДатаОтгрузкиС", Объект.ДатаОтгрузки, ЗначениеЗаполнено(Объект.ДатаОтгрузки));
			
		КонецЕсли;
		
		ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(
			СписокОстатков, "Перевозчик", Объект.Перевозчик,,, ЗначениеЗаполнено(Объект.Перевозчик));
		ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(
			СписокОстатков, ПолеОтбораКонечныйПолучатель, Объект.Получатель,,, ЗначениеЗаполнено(Объект.Получатель));
		ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(
			СписокОстатков, "ТипДоставки", Объект.ТипДоставки,,, ЗначениеЗаполнено(Объект.ТипДоставки));
		
		ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(
			СписокОстатков,
			"СпособДоставки",
			ПодходящиеСпособыДоставки,
			ВидСравненияКомпоновкиДанных.ВСписке,
			,
			ЗначениеЗаполнено(Объект.СпособДоставки));
		
	КонецЦикла;
	
	НастройкаСписковПоЗонеДоставки();
	
КонецПроцедуры

&НаСервере
Процедура НастройкаСписковПоЗонеДоставки()
	
	ЕстьОтборПоЗоне = ЗначениеЗаполнено(Объект.ЗонаДоставки);
	
	ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(
		СписокПоТоварам, "ЗонаПолучателя", Объект.ЗонаДоставки,,, ЕстьОтборПоЗоне);
	
	ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(
		СписокПоДокументам, "ЗонаПолучателя", Объект.ЗонаДоставки,,, ЕстьОтборПоЗоне);
	
	ИменаПолей = Новый Массив; // Массив из Строка
	ИменаПолей.Добавить("СписокПоДокументамЗонаПолучателя");
	ИменаПолей.Добавить("СписокПоТоварамЗонаПолучателя");
	ОбщегоНазначенияУТКлиентСервер.УстановитьСвойствоЭлементовФормы(
		Элементы, ИменаПолей, "Видимость", Не ЕстьОтборПоЗоне);
	
КонецПроцедуры

// Возвращаемое значение:
//  Массив Из Строка - Имена полей отбора, недоступных для редактирования
//
&НаСервере
Функция ИменаФиксированныхПолейОтбора()
	
	Возврат Параметры.ФиксированныеПоляОтбора.ВыгрузитьЗначения();
	
КонецФункции

&НаКлиенте
Процедура СписокДоставитьВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	ЭтоСписокПоТоварам = (Элемент = Элементы.СписокПоТоварам);
	ДанныеСтроки = Элемент.ДанныеСтроки(ВыбраннаяСтрока); // См. ДанныеСтрокиСпискаДоставить
	
	Если ЭтоСписокПоТоварам
	   И (ДанныеСтроки.Остаток - ДанныеСтроки.Подобрано) <= 0 Тогда
		Возврат;
	КонецЕсли;
	
	Если ДанныеСтроки.ЕстьОтличияВПараметрахДоставки
	   И НЕ Объект.ЗафиксироватьПараметрыДоставки Тогда
		
		ПараметрыФормы = ПараметрыФормыВыбораПараметровДоставки(Элемент.Имя, ВыбраннаяСтрока, ДанныеСтроки);
		Оповещение = Новый ОписаниеОповещения("СписокДоставитьВыборЗавершение", ЭтотОбъект, Элемент.Имя);
		
		ОткрытьФорму("Обработка.ПодборТоваровВДокументДоставки.Форма.ФормаВыбораПараметров",
			ПараметрыФормы,
			ЭтотОбъект,
			УникальныйИдентификатор,
			,
			,
			Оповещение,
			РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
		
	Иначе
		
		ВыбранныеПараметры = Новый Структура;
		
		ВыводитьКонечногоПолучателя = ТипЗнч(Объект.ДокументДоставки) = Тип("ДокументСсылка.Рейс")
			И Объект.СпособДоставкиДокумента = ПредопределенноеЗначение("Перечисление.СпособыДоставки25.СиламиПеревозчика");
		
		ДанныеКонечногоПолучателяЗаполнены = ВыводитьКонечногоПолучателя
			И ЗначениеЗаполнено(ДанныеСтроки.КонечныйПолучатель)
			И ЗначениеЗаполнено(ДанныеСтроки.ТочкаКонечногоПолучателя)
			И ЗначениеЗаполнено(ДанныеСтроки.ЗонаКонечногоПолучателя);
		
		Если НЕ Объект.ЗафиксироватьПараметрыДоставки
		   И ВыводитьКонечногоПолучателя
		   И ДанныеКонечногоПолучателяЗаполнены Тогда
			
			ВыбранныеПараметры.Вставить("Получатель", ДанныеСтроки.КонечныйПолучатель);
			ВыбранныеПараметры.Вставить("ТочкаПолучателя", ДанныеСтроки.ТочкаКонечногоПолучателя);
			ВыбранныеПараметры.Вставить("ЗонаПолучателя", ДанныеСтроки.ЗонаКонечногоПолучателя);
			
		Иначе
			
			ВыбранныеПараметры.Вставить("Получатель", ДанныеСтроки.Получатель);
			ВыбранныеПараметры.Вставить("ТочкаПолучателя", ДанныеСтроки.ТочкаПолучателя);
			ВыбранныеПараметры.Вставить("ЗонаПолучателя", ДанныеСтроки.ЗонаПолучателя);
			
		КонецЕсли;
		
		ДобавитьСтрокиВПодобраноСервер(ДанныеСтроки, ВыбранныеПараметры);
		Элементы.СписокПоТоварам.Обновить();
		Элементы.СписокПоДокументам.Обновить();
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура НастроитьВидимостьДоступностьПолей()
	
	ТипДокументаДоставки = ТипЗнч(Объект.ДокументДоставки);
	
	ИменаПолейТолькоПросмотр = Новый Массив; // Массив Из Строка
	ИменаНевидимыхПолей = Новый Массив; // Массив Из Строка
	
	ФиксированныеПоляОтбора = ИменаФиксированныхПолейОтбора();
	ОбщегоНазначенияКлиентСервер.ДополнитьМассив(ИменаПолейТолькоПросмотр, ФиксированныеПоляОтбора);
	
	Если Объект.ЗафиксироватьПараметрыДоставки Тогда
		
		ИменаПолейТолькоПросмотр.Добавить(Элементы.ПодобраноТочкаДоставки.Имя);
		ИменаПолейТолькоПросмотр.Добавить(Элементы.ПодобраноЗонаДоставки.Имя);
		
	КонецЕсли;
		
	Если НЕ Объект.ЗафиксироватьПараметрыДоставки Тогда
		
		ИменаНевидимыхПолей.Добавить(Элементы.ТочкаДоставкиФиксированнаяПоДокументам.Имя);
		ИменаНевидимыхПолей.Добавить(Элементы.ТочкаДоставкиФиксированнаяПоТоварам.Имя);
		ИменаНевидимыхПолей.Добавить(Элементы.ЗонаДоставкиФиксированнаяПоДокументам.Имя);
		ИменаНевидимыхПолей.Добавить(Элементы.ЗонаДоставкиФиксированнаяПоТоварам.Имя);
		
	КонецЕсли;
	
	Если ТипДокументаДоставки = Тип("ДокументСсылка.ЗаказНаДоставку") Тогда
		
		ИменаНевидимыхПолей.Добавить(Элементы.СтраницаПоДокументам.Имя);
		ИменаНевидимыхПолей.Добавить(Элементы.ПодобраноДокументПланирования.Имя);
		ИменаНевидимыхПолей.Добавить(Элементы.ЗонаДоставки.Имя);
		ИменаНевидимыхПолей.Добавить(Элементы.Получатель.Имя);
		ИменаНевидимыхПолей.Добавить(Элементы.Перевозчик.Имя);
		ИменаНевидимыхПолей.Добавить(Элементы.ПараметрыДоставкиСоответствуютРейсу.Имя);
		ИменаНевидимыхПолей.Добавить(Элементы.СпособДоставки.Имя);
		
		Элементы.ГруппаСтраницы.ОтображениеСтраниц = ОтображениеСтраницФормы.Нет;
		
	Иначе
		
		ИменаНевидимыхПолей.Добавить(Элементы.СписокПоТоварамПеревозчик.Имя);
		
	КонецЕсли;
	
	Если НЕ (ТипДокументаДоставки = Тип("ДокументСсылка.Рейс")
				И Объект.СпособДоставкиДокумента = Перечисления.СпособыДоставки25.СиламиПеревозчика) Тогда
		
		ИменаНевидимыхПолей.Добавить(Элементы.СписокПоДокументамКонечныйПолучатель.Имя);
		ИменаНевидимыхПолей.Добавить(Элементы.СписокПоДокументамТочкаКонечногоПолучателя.Имя);
		ИменаНевидимыхПолей.Добавить(Элементы.СписокПоДокументамЗонаКонечногоПолучателя.Имя);
		ИменаНевидимыхПолей.Добавить(Элементы.СписокПоТоварамКонечныйПолучатель.Имя);
		ИменаНевидимыхПолей.Добавить(Элементы.СписокПоТоварамТочкаКонечногоПолучателя.Имя);
		ИменаНевидимыхПолей.Добавить(Элементы.СписокПоТоварамЗонаКонечногоПолучателя.Имя);
		
		СписокПоДокументам.УстановитьОбязательноеИспользование("КонечныйПолучатель", Ложь);
		СписокПоДокументам.УстановитьОбязательноеИспользование("ТочкаКонечногоПолучателя", Ложь);
		СписокПоДокументам.УстановитьОбязательноеИспользование("ЗонаКонечногоПолучателя", Ложь);
		
		СписокПоТоварам.УстановитьОбязательноеИспользование("КонечныйПолучатель", Ложь);
		СписокПоТоварам.УстановитьОбязательноеИспользование("ТочкаКонечногоПолучателя", Ложь);
		СписокПоТоварам.УстановитьОбязательноеИспользование("ЗонаКонечногоПолучателя", Ложь);
		
	КонецЕсли;
	
	ОбщегоНазначенияУТКлиентСервер.УстановитьСвойствоЭлементовФормы(
		Элементы, ИменаНевидимыхПолей, "Видимость", Ложь);
	ОбщегоНазначенияУТКлиентСервер.УстановитьСвойствоЭлементовФормы(
		Элементы, ИменаПолейТолькоПросмотр, "ТолькоПросмотр", Истина);
	
КонецПроцедуры

&НаСервере
Процедура УстановитьЗаголовкиПолей()
	
	Если ТипЗнч(Объект.ДокументДоставки) = Тип("ДокументСсылка.ЗаказНаДоставку") Тогда
		
		ЗаголовокТочкиФиксированной = НСтр("ru = 'Точка доставки'");
		ЗаголовокЗоныФиксированной = НСтр("ru = 'Зона доставки'");
		
	Иначе
		
		ЗаголовокТочкиФиксированной = НСтр("ru = 'Точка доставки пункта'");
		ЗаголовокЗоныФиксированной = НСтр("ru = 'Зона доставки пункта'");
		
	КонецЕсли;
	
	Если Объект.ПараметрыДоставкиСоответствуютРейсу Тогда
		
		ЗаголовокДатыОтгрузки = НСтр("ru = 'Дата отгрузки'");
		
	Иначе
		
		ЗаголовокДатыОтгрузки = НСтр("ru = 'Дата отгрузки по'");
		
	КонецЕсли;
	
	Элементы.ТочкаДоставкиФиксированнаяПоТоварам.Заголовок = ЗаголовокТочкиФиксированной;
	Элементы.ТочкаДоставкиФиксированнаяПоДокументам.Заголовок = ЗаголовокТочкиФиксированной;
	
	Элементы.ЗонаДоставкиФиксированнаяПоТоварам.Заголовок = ЗаголовокЗоныФиксированной;
	Элементы.ЗонаДоставкиФиксированнаяПоДокументам.Заголовок = ЗаголовокЗоныФиксированной;
	
	Элементы.ДатаОтгрузки.Заголовок = ЗаголовокДатыОтгрузки;
	
КонецПроцедуры

&НаСервере
Процедура НастроитьДоступностьПолейОтбора()
	
	Элементы.СпособДоставки.ТолькоПросмотр = (Объект.ПараметрыДоставкиСоответствуютРейсу И ЗначениеЗаполнено(Объект.СпособДоставкиДокумента));
	Элементы.ДатаОтгрузки.ТолькоПросмотр = (Объект.ПараметрыДоставкиСоответствуютРейсу И ЗначениеЗаполнено(Объект.ДатаОтгрузкиДокумента));
	Элементы.Перевозчик.ТолькоПросмотр = (Объект.ПараметрыДоставкиСоответствуютРейсу И ЗначениеЗаполнено(Объект.ПеревозчикДокумента));
	
КонецПроцедуры

&НаСервере
Процедура ПараметрыДоставкиСоответствуютРейсуПриИзмененииНаСервере()
	
	Если Объект.ПараметрыДоставкиСоответствуютРейсу Тогда
		
		Если ЗначениеЗаполнено(Объект.СпособДоставкиДокумента) Тогда
			Объект.СпособДоставки = Объект.СпособДоставкиДокумента;
		КонецЕсли;
		
		Если ЗначениеЗаполнено(Объект.ДатаОтгрузкиДокумента) Тогда
			Объект.ДатаОтгрузки = Объект.ДатаОтгрузкиДокумента;
		КонецЕсли;
		
		Если ЗначениеЗаполнено(Объект.ПеревозчикДокумента) Тогда
			Объект.Перевозчик = Объект.ПеревозчикДокумента;
		КонецЕсли;
		
	КонецЕсли;
	
	ПодходящиеСпособыДоставки = Новый СписокЗначений; // СписокЗначений Из ПеречислениеСсылка.СпособыДоставки25
	Если ЗначениеЗаполнено(Объект.СпособДоставки) Тогда
		
		ПодходящиеСпособыДоставки.Добавить(Объект.СпособДоставки);
		
		Если НЕ Объект.ПараметрыДоставкиСоответствуютРейсу Тогда
			ПодходящиеСпособыДоставки.Добавить(Перечисления.СпособыДоставки25.ОпределяетСлужбаДоставки);
		КонецЕсли;
		
	КонецЕсли;
	
	ИспользоватьОтборПоДатеОтгрузкеС = (Объект.ПараметрыДоставкиСоответствуютРейсу И ЗначениеЗаполнено(Объект.ДатаОтгрузки));
	
	Списки = Новый Массив; // Массив Из ДинамическийСписок
	Списки.Добавить(СписокПоТоварам);
	Списки.Добавить(СписокПоДокументам);
	
	Для Каждого Список Из Списки Цикл
		
		ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(
			Список,
			"СпособДоставки",
			ПодходящиеСпособыДоставки,
			ВидСравненияКомпоновкиДанных.ВСписке,
			,
			ЗначениеЗаполнено(Объект.СпособДоставки));
		
		ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(
			Список, "Перевозчик", Объект.Перевозчик,,, ЗначениеЗаполнено(Объект.Перевозчик));
		
		ОбщегоНазначенияКлиентСервер.УстановитьПараметрДинамическогоСписка(
			Список, "ДатаОтгрузкиС", Объект.ДатаОтгрузки, ИспользоватьОтборПоДатеОтгрузкеС);
		
	КонецЦикла;
	
	НастроитьДоступностьПолейОтбора();
	УстановитьЗаголовкиПолей();
	
КонецПроцедуры

&НаКлиенте
Процедура ПриИзмененииПеревозчика()
	
	ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(
		СписокПоТоварам, "Перевозчик", Объект.Перевозчик,,, ЗначениеЗаполнено(Объект.Перевозчик));
	
	ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(
		СписокПоДокументам, "Перевозчик", Объект.Перевозчик,,, ЗначениеЗаполнено(Объект.Перевозчик));
	
КонецПроцедуры

&НаКлиенте
Процедура СписокПоДокументамОбновитьДопПараметры()
	
	Если Элементы.СписокПоДокументам.ТекущаяСтрока = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ДанныеСтроки = Элементы.СписокПоДокументам.ТекущиеДанные; // См. ДанныеСтрокиСпискаДоставить
	ОбновитьДопПараметрыНаСервере(Элементы.СписокПоДокументам.Имя, ДанныеСтроки);
	
КонецПроцедуры

&НаКлиенте
Процедура СписокПоТоварамОбновитьДопПараметры()
	
	Если Элементы.СписокПоТоварам.ТекущаяСтрока = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ДанныеСтроки = Элементы.СписокПоТоварам.ТекущиеДанные; // См. ДанныеСтрокиСпискаДоставить
	ОбновитьДопПараметрыНаСервере(Элементы.СписокПоТоварам.Имя, ДанныеСтроки);
	
КонецПроцедуры

// Параметры:
//  ИмяЭлемента - Строка - 
//  ДанныеСтроки - См. ДанныеСтрокиСпискаДоставить
//
&НаСервере
Процедура ОбновитьДопПараметрыНаСервере(Знач ИмяЭлемента, Знач ДанныеСтроки)
	
	Если ИмяЭлемента = Элементы.СписокПоДокументам.Имя Тогда
		
		ЭтоСписокПоТоварам = Ложь;
		ПрефиксПолей = "СведенияПоДокументам";
		
	Иначе
		
		ЭтоСписокПоТоварам = Истина;
		ПрефиксПолей = "СведенияПоТоварам";
		
	КонецЕсли;
	
	ВыводитьКонечногоПолучателя = (ТипЗнч(Объект.ДокументДоставки) = Тип("ДокументСсылка.Рейс")
		И Объект.СпособДоставкиДокумента = Перечисления.СпособыДоставки25.СиламиПеревозчика);
	ОтборПараметров = ОтборДетальныхОстатков(ЭтоСписокПоТоварам, ВыводитьКонечногоПолучателя);
	ЗаполнитьЗначенияСвойств(ОтборПараметров, ДанныеСтроки);
	
	Если ТипЗнч(Объект.ДокументДоставки) = Тип("ДокументСсылка.ЗаказНаДоставку") Тогда
		
		Распоряжение = ДанныеСтроки.Распоряжение;
		
		Если ТипЗнч(Распоряжение) = Тип("ДокументСсылка.ЗаказКлиента") Тогда
			
			СпособУказанияДоставки = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Распоряжение, "СпособУказанияДоставки");
			Если СпособУказанияДоставки = Перечисления.СпособыУказанияДоставки.НаВесьДокумент Тогда
				
				ДопПараметры = ДоставкаТоваров.ДополнительныеПараметрыИзШапкиДокумента(Распоряжение);
				
			Иначе
				
				ДокументыДоставки = ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(Распоряжение);
				ДопПараметры = ДоставкаТоваров.СовпадающиеДополнительныеПараметрыИзСтрокДокументов(
					ДокументыДоставки, ОтборПараметров, ЭтоСписокПоТоварам);
				
			КонецЕсли;
			
		Иначе
			
			ДопПараметры = ДоставкаТоваров.ДополнительныеПараметрыИзШапкиДокумента(Распоряжение);
			
		КонецЕсли;
		
	Иначе // Подбор в рейс
		
		ДетализацияСтроки = ДанныеСтроки.Детализация.Получить();
		ДокументыДоставки = ОбщегоНазначенияУТ.УникальныеЗначенияИзКолонкиТаблицы(ДетализацияСтроки, "ДокументПланирования");
		
		Если ДокументыДоставки.Количество() = 1
		   И ТипЗнч(ДокументыДоставки[0]) = Тип("ДокументСсылка.ЗаказКлиента") Тогда
			
			ДокументДоставки = ДокументыДоставки[0]; // ДокументСсылка.ЗаказКлиента
			СпособУказанияДоставки = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДокументДоставки, "СпособУказанияДоставки");
			Если СпособУказанияДоставки = Перечисления.СпособыУказанияДоставки.НаВесьДокумент Тогда
				
				ДопПараметры = ДоставкаТоваров.ДополнительныеПараметрыИзШапкиДокумента(ДокументДоставки);
				
			Иначе
				
				ДопПараметры = ДоставкаТоваров.СовпадающиеДополнительныеПараметрыИзСтрокДокументов(
					ДокументыДоставки, ОтборПараметров, ЭтоСписокПоТоварам);
				
			КонецЕсли;
			
		ИначеЕсли ДокументыДоставки.Количество() = 1 Тогда
			
			ДопПараметры = ДоставкаТоваров.ДополнительныеПараметрыИзШапкиДокумента(ДокументыДоставки[0]);
			
		Иначе
			
			ДопПараметры = ДоставкаТоваров.СовпадающиеДополнительныеПараметрыИзСтрокДокументов(
				ДокументыДоставки, ОтборПараметров, ЭтоСписокПоТоварам);
			
		КонецЕсли;
		
	КонецЕсли;
	
	Для Каждого ЭлементДопПараметров Из ДопПараметры Цикл
		
		Если ЭлементДопПараметров.Ключ = "Совпадают" Тогда
			Продолжить;
		КонецЕсли;
		ИмяПоля = ПрефиксПолей + ЭлементДопПараметров.Ключ;
		ОбщегоНазначенияКлиентСервер.УстановитьРеквизитФормыПоПути(ЭтотОбъект, ИмяПоля, ЭлементДопПараметров.Значение);
		
	КонецЦикла;
	
	ЭлементыДопПараметров = Новый Массив; // Массив Из Строка
	
	Если ЭтоСписокПоТоварам Тогда
		
		НадписьОтличаютсяСведения = Элементы.НадписьОтличаютсяСведенияПоТоварам;
		
		ЭлементыДопПараметров.Добавить(Элементы.СведенияПоТоварамВремяДоставкиС.Имя);
		ЭлементыДопПараметров.Добавить(Элементы.СведенияПоТоварамВремяДоставкиПо.Имя);
		ЭлементыДопПараметров.Добавить(Элементы.СведенияПоТоварамДополнительнаяИнформацияПоДоставке.Имя);
		ЭлементыДопПараметров.Добавить(Элементы.СведенияПоТоварамОсобыеУсловияПеревозки.Имя);
		ЭлементыДопПараметров.Добавить(Элементы.СведенияПоТоварамОсобыеУсловияПеревозкиОписание.Имя);
		
	Иначе
		
		НадписьОтличаютсяСведения = Элементы.НадписьОтличаютсяСведенияПоДокументам;
		
		ЭлементыДопПараметров.Добавить(Элементы.СведенияПоДокументамВремяДоставкиС.Имя);
		ЭлементыДопПараметров.Добавить(Элементы.СведенияПоДокументамВремяДоставкиПо.Имя);
		ЭлементыДопПараметров.Добавить(Элементы.СведенияПоДокументамДополнительнаяИнформацияПоДоставке.Имя);
		ЭлементыДопПараметров.Добавить(Элементы.СведенияПоДокументамОсобыеУсловияПеревозки.Имя);
		ЭлементыДопПараметров.Добавить(Элементы.СведенияПоДокументамОсобыеУсловияПеревозкиОписание.Имя);
		
	КонецЕсли;
	
	Если ДопПараметры.Совпадают Тогда
		
		ОбщегоНазначенияУТКлиентСервер.УстановитьСвойствоЭлементовФормы(Элементы, ЭлементыДопПараметров, "Видимость", Истина);
		НадписьОтличаютсяСведения.Видимость = Ложь;
		
	Иначе
		
		ОбщегоНазначенияУТКлиентСервер.УстановитьСвойствоЭлементовФормы(Элементы, ЭлементыДопПараметров, "Видимость", Ложь);
		НадписьОтличаютсяСведения.Видимость = Истина;
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти
