// @strict-types

#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	МодифицируемыеПоля = Новый Массив; // Массив Из Строка
	МодифицируемыеПоля.Добавить("Остаток");
	МодифицируемыеПоля.Добавить("Подобрано");
	МодифицируемыеПоля.Добавить("ИндексКартинки");
	СписокПоТоварам.УстановитьОграниченияИспользованияВОтборе(МодифицируемыеПоля);
	СписокПоТоварам.УстановитьОграниченияИспользованияВГруппировке(МодифицируемыеПоля);
	СписокПоТоварам.УстановитьОграниченияИспользованияВПорядке(МодифицируемыеПоля);
	
	МодифицируемыеПоля.Очистить();
	МодифицируемыеПоля.Добавить("Остаток");
	СписокПоДокументам.УстановитьОграниченияИспользованияВОтборе(МодифицируемыеПоля);
	СписокПоДокументам.УстановитьОграниченияИспользованияВГруппировке(МодифицируемыеПоля);
	СписокПоДокументам.УстановитьОграниченияИспользованияВПорядке(МодифицируемыеПоля);
	
	Объект.Организация = Параметры.Организация;
	Объект.Склад = Параметры.Склад;
	Объект.СпособДоставки = Параметры.СпособДоставки;
	Объект.СпособДоставкиДокумента = Параметры.СпособДоставки;
	Объект.Перевозчик = Параметры.Перевозчик;
	Объект.ПеревозчикДокумента = Параметры.Перевозчик;
	Объект.ДатаОтгрузки = Параметры.ДатаОтгрузки;
	Объект.ДатаОтгрузкиДокумента = Параметры.ДатаОтгрузки;
	Объект.УчитыватьКоличествоВДокументе = Параметры.УчитыватьКоличествоВДокументе;
	Объект.ДокументДоставки = Параметры.ДокументДоставки;
	Объект.ПараметрыДоставкиСоответствуютРейсу = (ТипЗнч(Объект.ДокументДоставки) = Тип("ДокументСсылка.Рейс"));
	Объект.Получатель = Параметры.Получатель;
	Объект.ТочкаДоставки = Параметры.ТочкаДоставки;
	Объект.ЗонаДоставки = Параметры.ЗонаДоставки;
	Объект.ТочкаДоставкиФиксированная = Параметры.ТочкаДоставкиФиксированная;
	Объект.ЗонаДоставкиФиксированная = Параметры.ЗонаДоставкиФиксированная;
	Объект.ЗафиксироватьПараметрыДоставки = Параметры.ЗафиксироватьПараметрыДоставки;
	Объект.ТипДоставки = Параметры.ТипДоставки;
	
	НастроитьВидимостьДоступностьПолей();
	НастроитьДоступностьПолейОтбора();
	УстановитьЗаголовкиПолей();
	
	УточнитьЗапросСпискаПоТоварам();
	УточнитьЗапросСпискаПоДокументам();
	
	ИнициализироватьОтборыСписков();
	ИнициализироватьДополнительныеСвойстваСписков();
	
	УстановитьУсловноеОформление();
	
КонецПроцедуры

&НаКлиенте
Процедура ПередЗакрытием(Отказ, ЗавершениеРаботы, ТекстПредупреждения, СтандартнаяОбработка)
	
	Если ЗавершениеРаботы
	   И Подобрано.Количество() > 0 Тогда
		
		Отказ = Истина;
		ТекстПредупреждения = НСтр("ru = 'Данные были изменены. Все изменения будут потеряны.'");
		Возврат;
		
	КонецЕсли;
	
	Если НЕ ВыполняетсяЗакрытие
	   И НЕ ПеренестиВДокумент
	   И Подобрано.Количество() > 0 Тогда
		
		Отказ = Истина;
		ТекстВопроса = НСтр("ru = 'Подобранные товары не перенесены в документ. Перенести?'");
		Оповещение = Новый ОписаниеОповещения("ПередЗакрытиемЗавершение", ЭтотОбъект);
		ПоказатьВопрос(Оповещение, ТекстВопроса, РежимДиалогаВопрос.ДаНетОтмена);
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПриЗакрытии(ЗавершениеРаботы)
	
	Если ЗавершениеРаботы Тогда
		Возврат;
	КонецЕсли;
	
	Если ПеренестиВДокумент Тогда
		
		Результат = Новый Структура("АдресПодобранныхТоваров", АдресПодобранныхТоваров);
		ОповеститьОВыборе(Результат);
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура СпособДоставкиПриИзменении(Элемент)
	
	ПодходящиеСпособыДоставки = Новый СписокЗначений; // СписокЗначений Из ПеречислениеСсылка.СпособыДоставки25
	Если ЗначениеЗаполнено(Объект.СпособДоставки) Тогда
		
		ПодходящиеСпособыДоставки.Добавить(Объект.СпособДоставки);
		
		Если НЕ Объект.ПараметрыДоставкиСоответствуютРейсу Тогда
			ПодходящиеСпособыДоставки.Добавить(ПредопределенноеЗначение("Перечисление.СпособыДоставки25.ОпределяетСлужбаДоставки"));
		КонецЕсли;
		
	КонецЕсли;
	
	ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(
		СписокПоТоварам,
		"СпособДоставки",
		ПодходящиеСпособыДоставки,
		ВидСравненияКомпоновкиДанных.ВСписке,
		,
		ЗначениеЗаполнено(Объект.СпособДоставки));
	
	ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(
		СписокПоДокументам,
		"СпособДоставки",
		ПодходящиеСпособыДоставки,
		ВидСравненияКомпоновкиДанных.ВСписке,
		,
		ЗначениеЗаполнено(Объект.СпособДоставки));
	
	Если Объект.СпособДоставки <> ПредопределенноеЗначение("Перечисление.СпособыДоставки25.СиламиПеревозчика")
	   И ЗначениеЗаполнено(Объект.Перевозчик) Тогда
		
		Объект.Перевозчик = ПредопределенноеЗначение("Справочник.Партнеры.ПустаяСсылка");
		ПриИзмененииПеревозчика();
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ДатаОтгрузкиПриИзменении(Элемент)
	
	Списки = Новый Массив; // Массив Из ДинамическийСписок
	Списки.Добавить(СписокПоТоварам);
	Списки.Добавить(СписокПоДокументам);
	
	Для Каждого Список Из Списки Цикл
		
		ОбщегоНазначенияКлиентСервер.УстановитьПараметрДинамическогоСписка(
			Список, "ДатаОтгрузкиПо", Объект.ДатаОтгрузки, ЗначениеЗаполнено(Объект.ДатаОтгрузки));
		
		Если Объект.ПараметрыДоставкиСоответствуютРейсу Тогда
			
			ОбщегоНазначенияКлиентСервер.УстановитьПараметрДинамическогоСписка(
				Список, "ДатаОтгрузкиС", Объект.ДатаОтгрузки, ЗначениеЗаполнено(Объект.ДатаОтгрузки));
			
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура ПеревозчикПриИзменении(Элемент)
	
	ПриИзмененииПеревозчика();
	
КонецПроцедуры

&НаКлиенте
Процедура ЗонаДоставкиПриИзменении(Элемент)
	
	НастройкаСписковПоЗонеДоставки();
	
КонецПроцедуры

&НаКлиенте
Процедура ПолучательПриИзменении(Элемент)
	
	Если ТипЗнч(Объект.ДокументДоставки) = Тип("ДокументСсылка.Рейс")
		И Не Объект.ЗафиксироватьПараметрыДоставки Тогда
		
		ИмяПоляОтбора = "КонечныйПолучательКонечноеПлечо";
		
	Иначе
		
		ИмяПоляОтбора = "КонечныйПолучательОбороты";
		
	КонецЕсли;
	
	ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(
		СписокПоТоварам, ИмяПоляОтбора, Объект.Получатель,,, ЗначениеЗаполнено(Объект.Получатель));
	
	ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(
		СписокПоДокументам, ИмяПоляОтбора, Объект.Получатель,,, ЗначениеЗаполнено(Объект.Получатель));
	
КонецПроцедуры

&НаКлиенте
Процедура ПараметрыДоставкиСоответствуютРейсуПриИзменении(Элемент)
	
	ПараметрыДоставкиСоответствуютРейсуПриИзмененииНаСервере();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыСписокПоТоварам

&НаСервереБезКонтекста
Процедура СписокПоТоварамПриПолученииДанныхНаСервере(ИмяЭлемента, Настройки, Строки)
	
	СписокПриПолученииДанныхНаСервере(ИмяЭлемента, Настройки, Строки);
	
КонецПроцедуры

&НаКлиенте
Процедура СписокПоТоварамВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	СписокДоставитьВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка);
	
КонецПроцедуры

&НаКлиенте
Процедура СписокПоТоварамПриАктивизацииСтроки(Элемент)
	
	ОтключитьОбработчикОжидания("СписокПоТоварамОбновитьДопПараметры");
	ПодключитьОбработчикОжидания("СписокПоТоварамОбновитьДопПараметры", 0.1, Истина);
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыСписокПоДокументам

&НаСервереБезКонтекста
Процедура СписокПоДокументамПриПолученииДанныхНаСервере(ИмяЭлемента, Настройки, Строки)
	
	СписокПриПолученииДанныхНаСервере(ИмяЭлемента, Настройки, Строки);
	
КонецПроцедуры

&НаКлиенте
Процедура СписокПоДокументамВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	СписокДоставитьВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка);
	
КонецПроцедуры

&НаКлиенте
Процедура СписокПоДокументамПриАктивизацииСтроки(Элемент)
	
	ОтключитьОбработчикОжидания("СписокПоДокументамОбновитьДопПараметры");
	ПодключитьОбработчикОжидания("СписокПоДокументамОбновитьДопПараметры", 0.1, Истина);
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыПодобрано

&НаКлиенте
Процедура ПодобраноТочкаДоставкиПриИзменении(Элемент)
	
	ТекущиеДанные = Элементы.Подобрано.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ТекущиеДанные.ТочкаДоставки) Тогда
		ТекущиеДанные.ЗонаДоставки = ЗонаДоставкиПоТочке(ТекущиеДанные.ТочкаДоставки);
	Иначе
		ТекущиеДанные.ЗонаДоставки = Неопределено;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПодобраноПриИзменении(Элемент)
	
	ОбновитьПодобраноВСпискеДоставить();
	Элементы.СписокПоТоварам.Обновить();
	
КонецПроцедуры

&НаКлиенте
Процедура ПодобраноКоличествоПриИзменении(Элемент)
	
	ТекущаяСтрока = Элементы.Подобрано.ТекущиеДанные;
	ПересчитатьВесОбъемВОбщихЕдиницах(ТекущаяСтрока);
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура ПеренестиВДокумент(Команда)
	
	ПеренестиВДокумент = Истина;
	ПоместитьПодобранныеТоварыВХранилище();
	Закрыть(КодВозвратаДиалога.OK);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура УстановитьУсловноеОформление()
	
	УсловноеОформление.Элементы.Очистить();
	
	ПараметрыОформленияЕдиниц = НоменклатураСервер.НовыеПараметрыУсловногоОформленияЕдиницИзмерения();
	ПараметрыОформленияЕдиниц.ИмяПоляЕдиницаИзмерения = "СписокПоТоварамНоменклатураЕдиницаИзмерения";
	ПараметрыОформленияЕдиниц.ПутьКПолюУпаковка = "СписокПоТоварам.Упаковка";
	НоменклатураСервер.УстановитьУсловноеОформлениеЕдиницИзмерения(ЭтотОбъект, ПараметрыОформленияЕдиниц);
	
	ПараметрыОформленияЕдиниц = НоменклатураСервер.НовыеПараметрыУсловногоОформленияЕдиницИзмерения();
	ПараметрыОформленияЕдиниц.ИмяПоляЕдиницаИзмерения = "ПодобраноНоменклатураЕдиницаИзмерения";
	ПараметрыОформленияЕдиниц.ПутьКПолюУпаковка = "Подобрано.Упаковка";
	НоменклатураСервер.УстановитьУсловноеОформлениеЕдиницИзмерения(ЭтотОбъект, ПараметрыОформленияЕдиниц);
	
	УстановитьУсловноеОформлениеНезаполненныйПеревозчик();
	
	Если ТипЗнч(Объект.ДокументДоставки) = Тип("ДокументСсылка.Рейс")
	   И Объект.СпособДоставкиДокумента = Перечисления.СпособыДоставки25.СиламиПеревозчика Тогда
		
		УстановитьУсловноеОформлениеПолейКонечногоПолучателя();
		
	КонецЕсли;
	
	УстановитьУсловноеОформлениеВесОбъемНеИспользуются();
	
КонецПроцедуры

&НаСервере
Процедура УстановитьУсловноеОформлениеНезаполненныйПеревозчик()
	
	Элемент = УсловноеОформление.Элементы.Добавить();
	
	ПолеЭлемента = Элемент.Поля.Элементы.Добавить();
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(Элементы.СписокПоТоварамПеревозчик.Имя);
	
	ОтборЭлемента = Элемент.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ОтборЭлемента.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("СписокПоТоварам.Перевозчик");
	ОтборЭлемента.ВидСравнения = ВидСравненияКомпоновкиДанных.НеЗаполнено;
	
	Элемент.Оформление.УстановитьЗначениеПараметра("ЦветТекста", ЦветаСтиля.ЦветТекстаОтмененнойСтрокиДокумента);
	Элемент.Оформление.УстановитьЗначениеПараметра("Текст", НСтр("ru = '<неприменимо>'"));
	
КонецПроцедуры

&НаСервере
Процедура УстановитьУсловноеОформлениеПолейКонечногоПолучателя()
	
	Элемент = УсловноеОформление.Элементы.Добавить();
	
	ПолеЭлемента = Элемент.Поля.Элементы.Добавить();
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(Элементы.СписокПоТоварамКонечныйПолучатель.Имя);
	ПолеЭлемента = Элемент.Поля.Элементы.Добавить();
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(Элементы.СписокПоТоварамТочкаКонечногоПолучателя.Имя);
	ПолеЭлемента = Элемент.Поля.Элементы.Добавить();
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(Элементы.СписокПоТоварамЗонаКонечногоПолучателя.Имя);
	
	ОтборЭлемента = Элемент.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ОтборЭлемента.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("СписокПоТоварам.КонечныйПолучатель");
	ОтборЭлемента.ВидСравнения = ВидСравненияКомпоновкиДанных.НеЗаполнено;
	
	ОтборЭлемента = Элемент.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ОтборЭлемента.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("СписокПоТоварам.ТочкаКонечногоПолучателя");
	ОтборЭлемента.ВидСравнения = ВидСравненияКомпоновкиДанных.НеЗаполнено;
	
	ОтборЭлемента = Элемент.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ОтборЭлемента.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("СписокПоТоварам.ЗонаКонечногоПолучателя");
	ОтборЭлемента.ВидСравнения = ВидСравненияКомпоновкиДанных.НеЗаполнено;
	
	Элемент.Оформление.УстановитьЗначениеПараметра("ЦветТекста", ЦветаСтиля.ЦветТекстаОтмененнойСтрокиДокумента);
	Элемент.Оформление.УстановитьЗначениеПараметра("Текст", НСтр("ru = '<неприменимо>'"));
	
	Элемент = УсловноеОформление.Элементы.Добавить();
	
	ПолеЭлемента = Элемент.Поля.Элементы.Добавить();
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(Элементы.СписокПоДокументамКонечныйПолучатель.Имя);
	ПолеЭлемента = Элемент.Поля.Элементы.Добавить();
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(Элементы.СписокПоДокументамТочкаКонечногоПолучателя.Имя);
	ПолеЭлемента = Элемент.Поля.Элементы.Добавить();
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(Элементы.СписокПоДокументамЗонаКонечногоПолучателя.Имя);
	
