&НаСервере
Процедура УточнитьЗапросСпискаПоТоварам()
	
	Если ТипЗнч(Объект.ДокументДоставки) = Тип("ДокументСсылка.ЗаказНаДоставку") Тогда
		
		ПредыдущиеУровниОпераций.Добавить(10);
		УточнитьЗапросСпискаПоТоварамДляЗаказаНаДоставку();
		
	ИначеЕсли ТипЗнч(Объект.ДокументДоставки) = Тип("ДокументСсылка.Рейс") Тогда
		
		ПредыдущиеУровниОпераций.Добавить(15);
		ПредыдущиеУровниОпераций.Добавить(20);
		УточнитьЗапросСпискаПоТоварамДляРейса();
		
	Иначе
		
		ТекстИсключения = НСтр("ru = 'В форму подбора товаров доставки передан неизвестный документ для работы'");
		ВызватьИсключение ТекстИсключения;
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура УточнитьЗапросСпискаПоТоварамДляРейса()
	
	Если Объект.УчитыватьКоличествоВДокументе Тогда
		
		ТекстЗапросаПоТоварам =
		"ВЫБРАТЬ
		|	РейсСодержимое.Распоряжение КАК Распоряжение,
		|	РейсСодержимое.ДокументПланирования КАК ДокументПланирования,
		|	РейсСодержимое.КодСтроки КАК КодСтроки,
		|	СУММА(РейсСодержимое.Количество) КАК Количество
		|ПОМЕСТИТЬ ВТСодержимоеДокумента
		|ИЗ
		|	Документ.Рейс.Содержимое КАК РейсСодержимое
		|ГДЕ
		|	РейсСодержимое.Ссылка = &ДокументДоставки
		|	И НЕ РейсСодержимое.Отменено
		|
		|СГРУППИРОВАТЬ ПО
		|	РейсСодержимое.Распоряжение,
		|	РейсСодержимое.ДокументПланирования,
		|	РейсСодержимое.КодСтроки
		|
		|ИНДЕКСИРОВАТЬ ПО
		|	Распоряжение,
		|	ДокументПланирования,
		|	КодСтроки
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ДоставкаОбороты.ДатаОтгрузки КАК ДатаОтгрузки,
		|	ДоставкаОбороты.СпособДоставки КАК СпособДоставки,
		|	ДоставкаОбороты.Отправитель КАК Отправитель,
		|	ДоставкаОбороты.Получатель КАК Получатель,
		|	ДоставкаОбороты.ТочкаПолучателя КАК ТочкаПолучателя,
		|	ДоставкаОбороты.ЗонаПолучателя КАК ЗонаПолучателя,
		|	ДоставкаОбороты.Распоряжение КАК Распоряжение,
		|	ДоставкаОбороты.ТипДоставки КАК ТипДоставки,
		|	ДоставкаОбороты.Номенклатура КАК Номенклатура,
		|	ДоставкаОбороты.Характеристика КАК Характеристика,
		|	ДоставкаОбороты.Серия КАК Серия,
		|	ЗНАЧЕНИЕ(Справочник.УпаковкиЕдиницыИзмерения.ПустаяСсылка) КАК Упаковка,
		|	ВЫБОР
		|		КОГДА ЕСТЬNULL(ДоставкаКонечноеПлечо.Плечо, 1) > 1
		|			ТОГДА ЕСТЬNULL(ДоставкаКонечноеПлечо.Получатель, НЕОПРЕДЕЛЕНО)
		|		ИНАЧЕ НЕОПРЕДЕЛЕНО
		|	КОНЕЦ КАК КонечныйПолучатель,
		|	ВЫБОР
		|		КОГДА ЕСТЬNULL(ДоставкаКонечноеПлечо.Плечо, 1) > 1
		|			ТОГДА ЕСТЬNULL(ДоставкаКонечноеПлечо.ТочкаПолучателя, ЗНАЧЕНИЕ(Справочник.ТочкиДоставки.ПустаяСсылка))
		|		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.ТочкиДоставки.ПустаяСсылка)
		|	КОНЕЦ КАК ТочкаКонечногоПолучателя,
		|	ВЫБОР
		|		КОГДА ЕСТЬNULL(ДоставкаКонечноеПлечо.Плечо, 1) > 1
		|			ТОГДА ЕСТЬNULL(ДоставкаКонечноеПлечо.ЗонаПолучателя, ЗНАЧЕНИЕ(Справочник.ЗоныДоставки.ПустаяСсылка))
		|		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.ЗоныДоставки.ПустаяСсылка)
		|	КОНЕЦ КАК ЗонаКонечногоПолучателя,
		|	СУММА(ДоставкаОбороты.КРейсуОборот - ДоставкаОбороты.ВРейсеОборот + ДоставкаОбороты.ОтмененоОборот - ЕСТЬNULL(ВТСодержимоеДокумента.Количество, 0)) КАК Остаток,
		|	0 КАК Подобрано,
		|	СУММА((ДоставкаОбороты.КРейсуОборот - ДоставкаОбороты.ВРейсеОборот + ДоставкаОбороты.ОтмененоОборот - ЕСТЬNULL(ВТСодержимоеДокумента.Количество, 0)) * &ВыражениеВесУпаковки) КАК Вес,
		|	СУММА((ДоставкаОбороты.КРейсуОборот - ДоставкаОбороты.ВРейсеОборот + ДоставкаОбороты.ОтмененоОборот - ЕСТЬNULL(ВТСодержимоеДокумента.Количество, 0)) * &ВыражениеОбъемУпаковки) КАК Объем,
		|	-1 КАК ИндексКартинки,
		|	NULL КАК Детализация,
		|	ЛОЖЬ КАК ЕстьОтличияВПараметрахДоставки,
		|	NULL КАК ВариантыПараметровДоставки
		|{ВЫБРАТЬ
		|	ДатаОтгрузки,
		|	СпособДоставки.*,
		|	Отправитель.*,
		|	Получатель.*,
		|	ТочкаПолучателя.*,
		|	ЗонаПолучателя.*,
		|	КонечныйПолучатель.*,
		|	ТочкаКонечногоПолучателя.*,
		|	ЗонаКонечногоПолучателя.*,
		|	Распоряжение.*,
		|	ТипДоставки,
		|	Номенклатура.*,
		|	Характеристика.*,
		|	Серия.*,
		|	Упаковка.*,
		|	Остаток,
		|	Подобрано,
		|	Вес,
		|	Объем,
		|	ИндексКартинки,
		|	Детализация,
		|	ЕстьОтличияВПараметрахДоставки,
		|	ВариантыПараметровДоставки}
		|ИЗ
		|	РегистрНакопления.Доставка.Обороты(
		|			,
		|			,
		|			,
		|			&ОтборПоПараметрам
		|				{&ОтборКомпоновкой}
		|				{(Получатель).* КАК КонечныйПолучательОбороты}) КАК ДоставкаОбороты
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТСодержимоеДокумента КАК ВТСодержимоеДокумента
		|		ПО ДоставкаОбороты.Распоряжение = ВТСодержимоеДокумента.Распоряжение
		|			И ДоставкаОбороты.ДокументПланирования = ВТСодержимоеДокумента.ДокументПланирования
		|			И ДоставкаОбороты.КодСтроки = ВТСодержимоеДокумента.КодСтроки
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.Доставка КАК ДоставкаКонечноеПлечо
		|		ПО ДоставкаОбороты.Распоряжение = ДоставкаКонечноеПлечо.Распоряжение
		|			И ДоставкаОбороты.КодСтроки = ДоставкаКонечноеПлечо.КодСтроки
		|			И ДоставкаОбороты.ДокументПланирования = ДоставкаКонечноеПлечо.ДокументПланирования
		|			И (ДоставкаКонечноеПлечо.ЭтоКонечноеПлечо)
		|			И (ДоставкаКонечноеПлечо.УровеньОперации В (&ПредыдущиеУровниОпераций))
		|			И НЕ 1 В
		|				(ВЫБРАТЬ ПЕРВЫЕ 1
		|					1
		|				ИЗ
		|					РегистрСведений.ИсправленияДокументов КАК ИсправленияДокументов
		|				ГДЕ
		|					ИсправленияДокументов.ИсправляемыйДокумент = ДоставкаКонечноеПлечо.Регистратор
		|					ИЛИ ИсправленияДокументов.ПредыдущееИсправление = ДоставкаКонечноеПлечо.Регистратор)
		|ГДЕ
		|	ДоставкаОбороты.КРейсуОборот - ДоставкаОбороты.ВРейсеОборот + ДоставкаОбороты.ОтмененоОборот - ЕСТЬNULL(ВТСодержимоеДокумента.Количество, 0) > 0
		|{ГДЕ
		|	ДоставкаКонечноеПлечо.Получатель КАК КонечныйПолучательКонечноеПлечо,
		|	(ВЫБОР
		|			КОГДА ЕСТЬNULL(ДоставкаКонечноеПлечо.Плечо, 1) > 1
		|				ТОГДА ЕСТЬNULL(ДоставкаКонечноеПлечо.Получатель, НЕОПРЕДЕЛЕНО)
		|			ИНАЧЕ НЕОПРЕДЕЛЕНО
		|		КОНЕЦ).* КАК КонечныйПолучатель,
		|	(ВЫБОР
		|			КОГДА ЕСТЬNULL(ДоставкаКонечноеПлечо.Плечо, 1) > 1
		|				ТОГДА ЕСТЬNULL(ДоставкаКонечноеПлечо.ТочкаПолучателя, ЗНАЧЕНИЕ(Справочник.ТочкиДоставки.ПустаяСсылка))
		|			ИНАЧЕ ЗНАЧЕНИЕ(Справочник.ТочкиДоставки.ПустаяСсылка)
		|		КОНЕЦ).* КАК ТочкаКонечногоПолучателя,
		|	(ВЫБОР
		|			КОГДА ЕСТЬNULL(ДоставкаКонечноеПлечо.Плечо, 1) > 1
		|				ТОГДА ЕСТЬNULL(ДоставкаКонечноеПлечо.ЗонаПолучателя, ЗНАЧЕНИЕ(Справочник.ЗоныДоставки.ПустаяСсылка))
		|			ИНАЧЕ ЗНАЧЕНИЕ(Справочник.ЗоныДоставки.ПустаяСсылка)
		|		КОНЕЦ).* КАК ЗонаКонечногоПолучателя}
		|
		|СГРУППИРОВАТЬ ПО
		|	ДоставкаОбороты.ДатаОтгрузки,
		|	ДоставкаОбороты.СпособДоставки,
		|	ДоставкаОбороты.Отправитель,
		|	ДоставкаОбороты.Получатель,
		|	ДоставкаОбороты.ТочкаПолучателя,
		|	ДоставкаОбороты.ЗонаПолучателя,
		|	ВЫБОР
		|		КОГДА ЕСТЬNULL(ДоставкаКонечноеПлечо.Плечо, 1) > 1
		|			ТОГДА ЕСТЬNULL(ДоставкаКонечноеПлечо.Получатель, НЕОПРЕДЕЛЕНО)
		|		ИНАЧЕ НЕОПРЕДЕЛЕНО
