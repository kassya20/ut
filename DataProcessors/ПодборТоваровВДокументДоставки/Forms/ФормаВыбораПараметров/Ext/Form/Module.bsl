// @strict-types

#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ВыбраннаяСтрока = Параметры.ВыбраннаяСтрока;
	
	ТаблицаВариантов = ПолучитьИзВременногоХранилища(Параметры.АдресТаблицыВариантов); // ТаблицаЗначений
	ВариантыПараметров.Загрузить(ТаблицаВариантов);
	УдалитьИзВременногоХранилища(Параметры.АдресТаблицыВариантов);
	
	ИменаЭлементов = Новый Массив; // Массив Из Строка
	ИменаЭлементов.Добавить(Элементы.ВариантыПараметровНоменклатура.Имя);
	ИменаЭлементов.Добавить(Элементы.ВариантыПараметровХарактеристика.Имя);
	ИменаЭлементов.Добавить(Элементы.ВариантыПараметровСерия.Имя);
	
	ОбщегоНазначенияУТКлиентСервер.УстановитьСвойствоЭлементовФормы(
		Элементы,
		ИменаЭлементов,
		"Видимость",
		Параметры.ДляСпискаПоТоварам);
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыВариантыПараметров

&НаКлиенте
Процедура ВариантыПараметровВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	ВыбратьПараметрыИЗакрыть();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура ПодобратьСтроку(Команда)
	
	ВыбратьПараметрыИЗакрыть();
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Процедура ВыбратьПараметрыИЗакрыть()
	
	СтрокаПараметров = Элементы.ВариантыПараметров.ТекущиеДанные;
	Если СтрокаПараметров = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Результат = Новый Структура;
	Результат.Вставить("ВыбраннаяСтрока", ВыбраннаяСтрока);
	
	Результат.Вставить("Получатель", СтрокаПараметров.ДоставкаДо);
	Результат.Вставить("ТочкаПолучателя", СтрокаПараметров.ТочкаДоставки);
	Результат.Вставить("ЗонаПолучателя", СтрокаПараметров.ЗонаДоставки);
	
	Закрыть(Результат);
	
КонецПроцедуры

#КонецОбласти
