		<query>ВЫБРАТЬ РАЗЛИЧНЫЕ
	ЧекиККМ.Ссылка КАК ЧекСсылка,
	ЧекиККМ.Ссылка.Дата КАК Дата,
	ЧекиККМ.Ссылка.Организация КАК Организация,
	ЧекиККМ.Ссылка.Склад КАК Склад,
	ЧекиККМ.Ссылка.НомерЧекаККМ КАК НомерЧекаККМ,
	ЧекиККМ.ИдентификаторКорзины КАК ИдентификаторКорзины,
	ЛОЖЬ КАК ЭтоВозврат
ПОМЕСТИТЬ ВтДанныеПоЧекам
ИЗ
	Документ.ЧекККМ.ОплатаПлатежнымиКартами КАК ЧекиККМ
ГДЕ
	ЧекиККМ.Ссылка.Проведен
	И ЧекиККМ.Ссылка.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыЧековККМ.Пробит)
	И ЧекиККМ.ВидОплаты = ЗНАЧЕНИЕ(Перечисление.ТипыПлатежнойСистемыККТ.СертификатНСПК)
	И ЧекиККМ.Сумма &gt; 0
{ГДЕ
	(ЧекиККМ.Ссылка.Дата &gt;= &amp;ДатаНачала),
	(ЧекиККМ.Ссылка.Дата &lt;= &amp;ДатаОкончания),
	ЧекиККМ.Ссылка.Товары.Номенклатура КАК Номенклатура}

ОБЪЕДИНИТЬ ВСЕ

ВЫБРАТЬ РАЗЛИЧНЫЕ
	ЧекиККМ.Ссылка,
	ЧекиККМ.Ссылка.Дата,
	ЧекиККМ.Ссылка.Организация,
	ЧекиККМ.Ссылка.Склад,
	ЧекиККМ.Ссылка.НомерЧекаККМ,
	ЧекиККМ.ИдентификаторКорзины,
	ИСТИНА
ИЗ
	Документ.ЧекККМВозврат.ОплатаПлатежнымиКартами КАК ЧекиККМ
ГДЕ
	ЧекиККМ.Ссылка.Проведен
	И ЧекиККМ.Ссылка.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыЧековККМ.Пробит)
	И ЧекиККМ.ВидОплаты = ЗНАЧЕНИЕ(Перечисление.ТипыПлатежнойСистемыККТ.СертификатНСПК)
	И ЧекиККМ.Сумма &gt; 0
{ГДЕ
	(ЧекиККМ.Ссылка.Дата &gt;= &amp;ДатаНачала),
	(ЧекиККМ.Ссылка.Дата &lt;= &amp;ДатаОкончания),
	ЧекиККМ.Ссылка.Товары.Номенклатура КАК Номенклатура}

ИНДЕКСИРОВАТЬ ПО
	ЧекСсылка,
	ИдентификаторКорзины
;

ВЫБРАТЬ
	Товары.Ссылка КАК ЧекСсылка,
	Чеки.ИдентификаторКорзины КАК ИдентификаторКорзины,	
	Товары.Номенклатура КАК Номенклатура,
	Товары.Номенклатура.Код КАК КодНоменклатуры,
	Товары.Номенклатура.КодТРУ КАК КодТРУ,
	Товары.Характеристика КАК Характеристика,
	Товары.Упаковка КАК Упаковка,
	СУММА(Товары.Количество) КАК Количество,
	Товары.Цена КАК Цена,
	СУММА(Товары.Сумма) КАК Сумма,
	Товары.СтавкаНДС КАК СтавкаНДС,
	СУММА(Товары.СуммаНДС) КАК СуммаНДС
ПОМЕСТИТЬ ВтДанныеПоТоварымПозициямЧеков
ИЗ
	Документ.ЧекККМ.Товары КАК Товары
	ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВтДанныеПоЧекам КАК Чеки
	ПО Чеки.ЧекСсылка = Товары.Ссылка
	
СГРУППИРОВАТЬ ПО
	Товары.Ссылка,
	Чеки.ИдентификаторКорзины,
	Товары.Номенклатура,
	Товары.Номенклатура.Код,
	Товары.Номенклатура.КодТРУ,
	Товары.Характеристика,
	Товары.Упаковка,
	Товары.Цена,
	Товары.СтавкаНДС

ОБЪЕДИНИТЬ ВСЕ

ВЫБРАТЬ
	Товары.Ссылка,
	Чеки.ИдентификаторКорзины КАК ИдентификаторКорзины,	
	Товары.Номенклатура,
	Товары.Номенклатура.Код,
	Товары.Номенклатура.КодТРУ,
	Товары.Характеристика,
	Товары.Упаковка,
	СУММА(Товары.Количество),
	Товары.Цена,
	СУММА(Товары.Сумма),
	Товары.СтавкаНДС,
	СУММА(Товары.СуммаНДС)
ИЗ
	Документ.ЧекККМВозврат.Товары КАК Товары
	ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВтДанныеПоЧекам КАК Чеки
	ПО Чеки.ЧекСсылка = Товары.Ссылка

СГРУППИРОВАТЬ ПО
	Товары.Ссылка,
	Чеки.ИдентификаторКорзины,
	Товары.Номенклатура,
	Товары.Номенклатура.Код,
	Товары.Номенклатура.КодТРУ,
	Товары.Характеристика,
	Товары.Упаковка,
	Товары.Цена,
	Товары.СтавкаНДС

ИНДЕКСИРОВАТЬ ПО
	ЧекСсылка,
	КодТРУ	
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	ВтДанныеПоЧекам.ЧекСсылка КАК ЧекСсылка,
	ВтДанныеПоЧекам.Дата КАК Дата,
	ВтДанныеПоЧекам.Организация КАК Организация,
	ВтДанныеПоЧекам.Склад КАК Склад,
	ВтДанныеПоЧекам.НомерЧекаККМ КАК НомерЧекаККМ,
	ВтДанныеПоЧекам.ИдентификаторКорзины КАК ИдентификаторКорзины,
	ВтДанныеПоЧекам.ЭтоВозврат КАК ЭтоВозврат,
	ВтЗагруженныеДанныеПоЧекам.НомерЭлектронногоСертификата КАК НомерЭлектронногоСертификатаНСПК,
	ВтЗагруженныеДанныеПоЧекам.КодТРУ КАК КодТРУНСПК,
	ВтЗагруженныеДанныеПоЧекам.КодНоменклатуры КАК КодНоменклатурыНСПК,
	ВтЗагруженныеДанныеПоЧекам.Количество КАК КоличествоНСПК,
	ВтЗагруженныеДанныеПоЧекам.Цена КАК ЦенаНСПК,
	ТоварныеПозиции.Номенклатура КАК Номенклатура,
	ТоварныеПозиции.КодНоменклатуры КАК КодНоменклатуры,
	ТоварныеПозиции.Характеристика КАК Характеристика,
	ТоварныеПозиции.Упаковка КАК Упаковка,
	ТоварныеПозиции.Количество КАК Количество,
	ТоварныеПозиции.Сумма КАК Сумма,
	ТоварныеПозиции.СтавкаНДС КАК СтавкаНДС,
	ТоварныеПозиции.СуммаНДС КАК СуммаНДС	
ИЗ
	ВтДанныеПоЧекам КАК ВтДанныеПоЧекам
		ЛЕВОЕ СОЕДИНЕНИЕ ВтЗагруженныеДанныеПоЧекам КАК ВтЗагруженныеДанныеПоЧекам
		ПО ВтДанныеПоЧекам.ЧекСсылка = ВтЗагруженныеДанныеПоЧекам.ЧекСсылка
			И ВтДанныеПоЧекам.ИдентификаторКорзины = ВтЗагруженныеДанныеПоЧекам.ИдентификаторКорзины
		ЛЕВОЕ СОЕДИНЕНИЕ ВтДанныеПоТоварымПозициямЧеков КАК ТоварныеПозиции
		ПО ВтЗагруженныеДанныеПоЧекам.ЧекСсылка = ТоварныеПозиции.ЧекСсылка
		И ВтЗагруженныеДанныеПоЧекам.ИдентификаторКорзины = ТоварныеПозиции.ИдентификаторКорзины		
		И ВтЗагруженныеДанныеПоЧекам.КодТРУ = ТоварныеПозиции.КодТРУ
		И ВтЗагруженныеДанныеПоЧекам.Цена = ТоварныеПозиции.Цена</query>
	</dataSet>
	<totalField>
		<dataPath>Сумма</dataPath>
		<expression>Сумма(Сумма)</expression>
	</totalField>
