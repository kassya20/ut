Процедура Подключаемый_ВыполнитьПереопределяемуюКоманду(Команда)
	
	СобытияФормКлиент.ВыполнитьПереопределяемуюКоманду(ЭтаФорма, Команда);
	
КонецПроцедуры

&НаКлиенте
Процедура СписокДокументовОбновить(Команда)
	
	// НастройкиДинамическихСписков
	ОбновитьДанныеСпискаДокументовСЗамеромВремени("СписокДокументов");
	// Конец НастройкиДинамическихСписков
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Процедура СоздатьОперациюСЭлектроннымБилетом(ТипОперации)
	
	ТекущиеДанные = Элементы.СписокДокументов.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ОписаниеОперации = Новый Структура;
	ОписаниеОперации.Вставить("ТипОперации", ТипОперации);
	ОписаниеОперации.Вставить("ЭтоПолныйВозврат", Ложь);
	
	ДанныеДляСозданияОперацииБилета = Новый Структура;
	ДанныеДляСозданияОперацииБилета.Вставить("ДанныеЭлектронногоБилета");
	ДанныеДляСозданияОперацииБилета.Вставить("ОписаниеОперации", ОписаниеОперации);
	ДанныеДляСозданияОперацииБилета.Вставить("ЭтоРазделениеБилета", Ложь);
	
	ПараметрыОснования = Новый Структура();
	ПараметрыОснования.Вставить("ЭлектронныйБилет", ТекущиеДанные.Ссылка);
	ПараметрыОснования.Вставить("ДанныеДляСозданияОперацииБилета", ДанныеДляСозданияОперацииБилета);
	
	ОткрытьФорму("Документ.ОперацияСЭлектроннымБилетом.Форма.ФормаОперацииЭлектронногоБилета", Новый Структура("Основание", ПараметрыОснования));
	
КонецПроцедуры

&НаСервере
Процедура УстановитьУсловноеОформление()
	
	СтандартныеПодсистемыСервер.УстановитьУсловноеОформлениеПоляДата(ЭтотОбъект, "СписокДокументов.Дата", Элементы.Дата.Имя);
	
КонецПроцедуры

&НаСервере
Процедура УстановитьОтборДинамическихСписков()
	
	ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(
		СписокДокументов,
		"Организация",
		Организация,
		ВидСравненияКомпоновкиДанных.Равно,,
		ЗначениеЗаполнено(Организация));
		
	ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(
		СписокДокументов,
		"Сотрудник",
		Сотрудник,
		ВидСравненияКомпоновкиДанных.Равно,,
		ЗначениеЗаполнено(Сотрудник));
		
	УстановитьОтборПоПериоду();
	
	// НастройкиДинамическихСписков
	РаботаСЖурналамиДокументов.УстановитьВидимостьГруппыНастройкиОбновленияПоУмолчанию(ЭтотОбъект, "СписокДокументов");
	// Конец НастройкиДинамическихСписков
	
КонецПроцедуры

&НаСервере
Процедура УстановитьОтборПоПериоду()
	
	СписокДокументов.Параметры.УстановитьЗначениеПараметра("НачалоПериода", Период.ДатаНачала);
	СписокДокументов.Параметры.УстановитьЗначениеПараметра("КонецПериода", Период.ДатаОкончания);
	// НастройкиДинамическихСписков
	РаботаСЖурналамиДокументов.УстановитьВидимостьГруппыНастройкиОбновленияПоУмолчанию(ЭтотОбъект, "СписокДокументов");
	// Конец НастройкиДинамическихСписков
	
КонецПроцедуры

&НаСервере
Процедура УстановитьВидимостьДоступность()
	
	Если Не ПолучитьФункциональнуюОпцию("ИспользоватьНесколькоОрганизаций") Тогда
		Элементы.ОрганизацияОтбор.Видимость = Ложь;
	КонецЕсли;
	
	Элементы.Подразделение.Видимость = ПолучитьФункциональнуюОпцию("ИспользоватьПодразделения");
	
	//++ Локализация
	Элементы.СписокПолучитьДанныеБронирования.Видимость = Истина;
	Элементы.СписокОформитьКомандировку.Видимость = Истина;
	//-- Локализация
	
КонецПроцедуры

&НаСервере
Процедура НастроитьКнопкиУправленияДокументами()
	
	ВидимостьКомандРедактирования = ПравоДоступа("Добавление", Метаданные.Документы.ОперацияСЭлектроннымБилетом);
	
	Если Не ВидимостьКомандРедактирования Тогда
		
		КомандыРедактирования = Новый Массив;
		КомандыРедактирования.Добавить(Элементы.СписокСоздатьБилет);
		КомандыРедактирования.Добавить(Элементы.СписокСоздатьДоплату);
		КомандыРедактирования.Добавить(Элементы.СписокСоздатьВозврат);
		
		//++ Локализация
		КомандыРедактирования.Добавить(Элементы.СписокСоздатьБронирование);
		//-- Локализация
		
		КомандыРедактирования.Добавить(Элементы.СписокСкопировать);
		КомандыРедактирования.Добавить(Элементы.СписокУстановитьСнятьПометкуУдаления);
		КомандыРедактирования.Добавить(Элементы.СписокПровести);
		КомандыРедактирования.Добавить(Элементы.СписокОтменаПроведения);
		КомандыРедактирования.Добавить(Элементы.СписокКонтекстноеМенюСкопировать);
		КомандыРедактирования.Добавить(Элементы.СписокКонтекстноеМенюУстановитьПометкуУдаления);
		КомандыРедактирования.Добавить(Элементы.СписокКонтекстноеМенюПровести);
		КомандыРедактирования.Добавить(Элементы.СписокКонтекстноеМенюОтменаПроведения);
		
		Для каждого КомандаРедактирования Из КомандыРедактирования Цикл
			КомандаРедактирования.Видимость = Ложь;
		КонецЦикла;
	КонецЕсли;
	
	//++ Локализация


	//-- Локализация
	
КонецПроцедуры

#Область НастройкиДинамическихСписков

&НаСервере
Процедура ИнициироватьНастройкиДинамическихСписков()
	
	ПараметрыСписковДокументов = Новый Массив;
	
	СтруктураПараметровСписка = РаботаСЖурналамиДокументов.СтруктураФормированияНаФормеГруппыПользовательскихНастроекДинамическогоСписка();
	СтруктураПараметровСписка.ИмяСписка = "СписокДокументов";
	СтруктураПараметровСписка.ГруппаРазмещенияНастройки = Элементы.ГруппаНастройкиСпискаДокументов;
	СтруктураПараметровСписка.ИмяРеквизитаРежимАвтообновления = "СписокДокументовРежимАвтообновления";
	СтруктураПараметровСписка.ИмяКомандыОбновленияСписка = Команды.СписокДокументовОбновить.Имя;
	ПараметрыСписковДокументов.Добавить(СтруктураПараметровСписка);
	
	РаботаСЖурналамиДокументов.ИнициироватьНастройкиДинамическихСписков(ЭтотОбъект, ПараметрыСписковДокументов);

КонецПроцедуры

&НаКлиенте
Процедура ОтображениеГруппыПользовательскихОтборовИНастроек(ИмяСписка)
	
	ДлительноеОбновление = РаботаСЖурналамиДокументовКлиент.ВремяОбновленияСпискаПревышаетДопутимое(ЭтотОбъект,
		ИмяСписка);
		
	Если ДлительноеОбновление Тогда
		РаботаСЖурналамиДокументовКлиент.УстановитьЗначениеНастройкиСпискаДокументов(ЭтотОбъект, ИмяСписка,
			"ПровереныНастройкиКомпоновкиДанных", Истина);
		СтруктураНастроекКомпоновкиДанных = ПолучитьИсполняемыеНастройкиКомпоновкиДанных(ИмяСписка);
		РаботаСЖурналамиДокументовКлиент.УстановитьЗначениеНастройкиСпискаДокументов(ЭтотОбъект, ИмяСписка,
			"НастройкиКомпоновкиДанных", СтруктураНастроекКомпоновкиДанных.НастройкиКомпоновкиДанных);
		РаботаСЖурналамиДокументовКлиент.УстановитьЗначениеНастройкиСпискаДокументов(ЭтотОбъект, ИмяСписка,
			"СтруктураПользовательскихНастроек", СтруктураНастроекКомпоновкиДанных.СтруктураПользовательскихНастроек);
	Иначе
		РаботаСЖурналамиДокументовКлиент.УстановитьЗначениеНастройкиСпискаДокументов(ЭтотОбъект, ИмяСписка,
			"ПровереныНастройкиКомпоновкиДанных", Ложь);
		РаботаСЖурналамиДокументовКлиент.УстановитьЗначениеНастройкиСпискаДокументов(ЭтотОбъект, ИмяСписка,
			"НастройкиКомпоновкиДанных", Новый НастройкиКомпоновкиДанных);
		РаботаСЖурналамиДокументовКлиент.УстановитьЗначениеНастройкиСпискаДокументов(ЭтотОбъект, ИмяСписка,
			"СтруктураПользовательскихНастроек", Новый Структура);
	КонецЕсли;

	РаботаСЖурналамиДокументовКлиент.ДокументыОтображениеГруппыПользовательскихОтборовИНастроек(ЭтотОбъект, ИмяСписка);
	
КонецПроцедуры

&НаСервере
Функция ПолучитьИсполняемыеНастройкиКомпоновкиДанных(ИмяСписка)
	
	ИмяЭлемента = РаботаСЖурналамиДокументов.ЗначениеНастройкиСпискаДокументов(ЭтотОбъект, ИмяСписка,
		"ИмяЭлементаСписка");
	ЭлементФормыСписок = Элементы[ИмяЭлемента];
	НастройкиКомпоновкиДанных = ЭлементФормыСписок.ПолучитьИсполняемыеНастройкиКомпоновкиДанных();

	СтруктураВозврата = Новый Структура;
	СтруктураВозврата.Вставить("НастройкиКомпоновкиДанных", НастройкиКомпоновкиДанных);

	СписокПолейСоставногоТипа = РаботаСЖурналамиДокументов.ЗначениеНастройкиСпискаДокументов(ЭтотОбъект,
		ИмяСписка, "СписокПолейСоставногоТипа");

	СтруктураПользовательскихНастроек = РаботаСЖурналамиДокументов.ПроверитьПользовательскиеНастройкиДинамическогоСписка(
		НастройкиКомпоновкиДанных, СписокПолейСоставногоТипа);

	СтруктураВозврата.Вставить("СтруктураПользовательскихНастроек", СтруктураПользовательскихНастроек);
	
	Возврат СтруктураВозврата;
	
КонецФункции

&НаКлиенте
Процедура УстановитьПараметрыОбновленияСписковДокументов(ДанныеУстарели, ДлительностьОбновления = Неопределено)
	
	ИмяНастройки = "СписокДокументовКэшНастроек";
	ИмяСписка = "";
	Для Каждого НастройкаСписокДокументов Из ЭтотОбъект[ИмяНастройки] Цикл
		ИмяСписка = НастройкаСписокДокументов.Ключ;
		РаботаСЖурналамиДокументовКлиент.УстановитьПараметрыОбновленияСпискаДокументов(ЭтотОбъект, ИмяСписка, ДанныеУстарели,
			ДлительностьОбновления);
		ОтображениеГруппыПользовательскихОтборовИНастроек(ИмяСписка);
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьДанныеСпискаДокументовСЗамеромВремени(ИмяСписка, УчитыватьПараметрАвтообновления = Ложь)

	Если Не УчитыватьПараметрАвтообновления Тогда

		ТребуетсяОбновлениеСписка = Истина;

	Иначе

		ТребуетсяОбновлениеСписка = РаботаСЖурналамиДокументовКлиент.ЗначениеНастройкиАвтообновленияСпискаДокументов(
			ЭтотОбъект, ИмяСписка);

		Если Не ТребуетсяОбновлениеСписка Тогда
			РаботаСЖурналамиДокументовКлиент.УстановитьПризнакОтображенияНеактуальныхДанныхВСписке(ЭтотОбъект, ИмяСписка);
		КонецЕсли;

	КонецЕсли;

	Если ТребуетсяОбновлениеСписка Тогда

		РаботаСЖурналамиДокументовКлиент.ОбновитьДанныеСпискаДокументовСЗамеромВремени(ЭтотОбъект, ИмяСписка);
		ОтображениеГруппыПользовательскихОтборовИНастроек(ИмяСписка);

	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ОбновитьСписокДокументовСобытиеОбработкаОповещения(ИмяСписка, Параметр = Неопределено)
	
	РаботаСЖурналамиДокументовКлиент.ОбновитьСписокДокументовСобытиеОбработкаОповещения(ЭтотОбъект, ИмяСписка, Параметр);
	ОтображениеГруппыПользовательскихОтборовИНастроек(ИмяСписка);

КонецПроцедуры

// Обработка события элемента формы.
// 
// Параметры:
//  Элемент - ПолеФормы
//@skip-check module-unused-method
&НаКлиенте
Процедура СписокДокументовОбработкаСобытияЭлементаФормы(Элемент)

	ДействиеСписка = РаботаСЖурналамиДокументовКлиент.ИмяСпискаДокументовПоИмениЭлементаФормы(ЭтотОбъект, Элемент.Имя);
	
	Если ДействиеСписка.ИмяСписка = "" Тогда
		Возврат;
	КонецЕсли;
	
	ИмяСписка = ДействиеСписка.ИмяСписка;
	Действие = ДействиеСписка.Действие;
	
	Если Действие = "Отборы" Или Действие = "Порядок" Или Действие = "УсловноеОформление" Тогда
		РаботаСЖурналамиДокументовКлиент.УстановитьЗначениеНастройкиСпискаДокументов(ЭтотОбъект, ИмяСписка,
			"ПровереныНастройкиКомпоновкиДанных", Истина);
		СтруктураНастроекКомпоновкиДанных = ПолучитьИсполняемыеНастройкиКомпоновкиДанных(ИмяСписка);
		РаботаСЖурналамиДокументовКлиент.УстановитьЗначениеНастройкиСпискаДокументов(ЭтотОбъект, ИмяСписка,
			"НастройкиКомпоновкиДанных", СтруктураНастроекКомпоновкиДанных.НастройкиКомпоновкиДанных);
		РаботаСЖурналамиДокументовКлиент.УстановитьЗначениеНастройкиСпискаДокументов(ЭтотОбъект, ИмяСписка,
			"СтруктураПользовательскихНастроек", СтруктураНастроекКомпоновкиДанных.СтруктураПользовательскихНастроек);
	КонецЕсли;
	
	Если Действие = "Отборы" Тогда
		РаботаСЖурналамиДокументовКлиент.ИсправитьПользовательскиеОтборыВСпискеДокументов(ЭтотОбъект, ИмяСписка);
	ИначеЕсли Действие = "Порядок" Тогда
		РаботаСЖурналамиДокументовКлиент.ИсправитьНастройкиСортировкиВСпискеДокументов(ЭтотОбъект, ИмяСписка);
	ИначеЕсли Действие = "УсловноеОформление" Тогда
		РаботаСЖурналамиДокументовКлиент.ИсправитьНастройкиУсловногоОформленияВСпискеДокументов(ЭтотОбъект, ИмяСписка);
	ИначеЕсли Действие = "Обновление" Тогда
		ОбновитьДанныеСпискаДокументовСЗамеромВремени(ИмяСписка);
	ИначеЕсли Действие = "УскорениеОбновленияСписка" Тогда
		РаботаСЖурналамиДокументовКлиент.СохранитьНастройкуПроизводительныйРежимОбновленияСписка(ЭтотОбъект, ИмяСписка);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПоказатьВыборВариантаОтбораДокументов()
	
	СписокВариантовОтбора = СписокВариантовОтбора();
	ОписаниеОповещенияОВыбореВарианта = Новый ОписаниеОповещения("ПриВыбореВариантаОтбораДокументов", ЭтотОбъект);
	СписокВариантовОтбора.ПоказатьВыборЭлемента(
		ОписаниеОповещенияОВыбореВарианта,
		НСтр("ru = 'Варианты отбора документов'"),
		СписокВариантовОтбора.НайтиПоЗначению(ТекущийВариантОтбораДокументов));
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Функция ВариантОтбораДокументовПоУмолчанию()
	Возврат "ВсеДокументы";
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Функция СписокВариантовОтбора()
	
	СписокВариантовОтбора = Новый СписокЗначений;
	СписокВариантовОтбора.Добавить(ВариантОтбораДокументовПоУмолчанию(), НСтр("ru = 'Все документы журнала'"));
	СписокВариантовОтбора.Добавить("ЭлектронныеБилеты", НСтр("ru = 'Электронные билеты'"));
	СписокВариантовОтбора.Добавить("ЭлектронныеБилетыИОперации", НСтр("ru = 'Электронные билеты и операции'"));
	
	//++ Локализация
	СписокВариантовОтбора.Добавить("ЭлектронныеБилетыИБронирования", НСтр("ru = 'Электронные билеты и бронирования'"));
	//-- Локализация
	
	Возврат СписокВариантовОтбора;
	
КонецФункции

&НаКлиенте
Процедура ПриВыбореВариантаОтбораДокументов(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если Результат.Значение = ТекущийВариантОтбораДокументов Тогда
		Возврат;
	КонецЕсли;
	
	ПрименитьВариантОтбораДокументов(Результат.Значение);
	
КонецПроцедуры

&НаСервере
Процедура ПрименитьВариантОтбораДокументов(ВариантОтбораДокументов)
	
	// Фиксация текущего варианта
	ТекущийВариантОтбораДокументов = ВариантОтбораДокументов;
	
	// Перерисовка кнопок создания
	ВидимостьКомандРедактирования = ПравоДоступа("Добавление", Метаданные.Документы.ОперацияСЭлектроннымБилетом);
	
	Элементы.СписокСоздатьБилет.Видимость = ВидимостьКомандРедактирования;
	Элементы.СписокСоздатьДоплату.Видимость = ВидимостьКомандРедактирования;
	Элементы.СписокСоздатьВозврат.Видимость = ВидимостьКомандРедактирования;
	
	//++ Локализация
	Элементы.СписокСоздатьБронирование.Видимость = ВидимостьКомандРедактирования;
	//-- Локализация
	
	СписокТиповДокументов = Новый СписокЗначений;
	СписокТиповДокументов.Добавить(1);
	
	Если ТекущийВариантОтбораДокументов = "ЭлектронныеБилеты" Тогда
		
		Элементы.СписокСоздатьДоплату.Видимость = Ложь;
		Элементы.СписокСоздатьВозврат.Видимость = Ложь;
		
		//++ Локализация
		Элементы.СписокСоздатьБронирование.Видимость = Ложь;
		//-- Локализация
		
	ИначеЕсли ТекущийВариантОтбораДокументов = "ЭлектронныеБилетыИОперации" Тогда
		
		//++ Локализация
		Элементы.СписокСоздатьБронирование.Видимость = Ложь;
		//-- Локализация
		
		СписокТиповДокументов.Добавить(2);
		СписокТиповДокументов.Добавить(3);
		
	//++ Локализация
	ИначеЕсли ТекущийВариантОтбораДокументов = "ЭлектронныеБилетыИБронирования" Тогда
		
		Элементы.СписокСоздатьДоплату.Видимость = Ложь;
		Элементы.СписокСоздатьВозврат.Видимость = Ложь;
		СписокТиповДокументов.Добавить(4);
	//-- Локализация
		
	Иначе
		
		СписокТиповДокументов.Добавить(2);
		СписокТиповДокументов.Добавить(3);
		СписокТиповДокументов.Добавить(4);
		
	КонецЕсли;
	
	// Отбор динамического списка
	ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(
		СписокДокументов,
		"ИдентификаторТипаДокумента",
		СписокТиповДокументов,
		ВидСравненияКомпоновкиДанных.ВСписке,,
		Истина);
	
	// Формирование гиперссылки
	МассивСтрокНадписи = Новый Массив;
	МассивСтрокНадписи.Добавить(СтрШаблон(НСтр("ru = 'Показаны %1'"),
		НРег(СписокВариантовОтбора().НайтиПоЗначению(ТекущийВариантОтбораДокументов).Представление)));
	МассивСтрокНадписи.Добавить("  ");
	МассивСтрокНадписи.Добавить(Новый ФорматированнаяСтрока(НСтр("ru = 'Настроить'"),,,,"НастроитьОтбор"));
	//
	Элементы.ИнформационнаяНадписьОтбор.Заголовок = Новый ФорматированнаяСтрока(МассивСтрокНадписи);
	
КонецПроцедуры

Процедура УстановитьТекстЗапросаСпискуДокументов()
	
	МассивТекстов = Новый Массив;
	ТекстЗапроса =
	"ВЫБРАТЬ
	|	ВЫРАЗИТЬ(РеестрДокументовПереопределяемый.Ссылка КАК Документ.ОперацияСЭлектроннымБилетом) КАК Ссылка,
	|	ВЫБОР
	|		КОГДА ДанныеДокументаПереопределяемый.ТипОперации = ЗНАЧЕНИЕ(Перечисление.ТипыОперацийСБилетами.Доплата)
	|			ТОГДА &ТипДокументаДоплата
	|		КОГДА ДанныеДокументаПереопределяемый.ТипОперации = ЗНАЧЕНИЕ(Перечисление.ТипыОперацийСБилетами.Возврат)
	|			ТОГДА &ТипДокументаВозврат
	|		ИНАЧЕ &ТипДокументаЭлектронныйБилет
	|	КОНЕЦ КАК ТипДокумента,
	|	ВЫБОР
	|		КОГДА ДанныеДокументаПереопределяемый.ТипОперации = ЗНАЧЕНИЕ(Перечисление.ТипыОперацийСБилетами.Доплата)
	|			ТОГДА 2
	|		КОГДА ДанныеДокументаПереопределяемый.ТипОперации = ЗНАЧЕНИЕ(Перечисление.ТипыОперацийСБилетами.Возврат)
	|			ТОГДА 3
	|		ИНАЧЕ 1
	|	КОНЕЦ КАК ИдентификаторТипаДокумента,
	|	ДанныеДокументаПереопределяемый.ТипОперации = ЗНАЧЕНИЕ(Перечисление.ТипыОперацийСБилетами.ПустаяСсылка) КАК ЭтоЭлектронныйБилет,
	|	РеестрДокументовПереопределяемый.ДатаДокументаИБ КАК Дата,
	|	ВЫБОР
	|		КОГДА СведенияОбЭлектронномБилетеПереопределяемый.Ссылка Есть NULL
	|			ТОГДА РеестрДокументовПереопределяемый.НомерПервичногоДокумента
	|		ИНАЧЕ ДанныеДокументаПереопределяемый.НомерБилета
	|	КОНЕЦ КАК Номер,
	|	РеестрДокументовПереопределяемый.ПометкаУдаления КАК ПометкаУдаления,
	|	РеестрДокументовПереопределяемый.Проведен КАК Проведен,
	|	РеестрДокументовПереопределяемый.Организация КАК Организация,
	|	ВЫРАЗИТЬ(РеестрДокументовПереопределяемый.МестоХранения.Ключ КАК Справочник.ФизическиеЛица) КАК Сотрудник,
	|	ВЫБОР
	|		КОГДА ДанныеДокументаПереопределяемый.ТипОперации = ЗНАЧЕНИЕ(Перечисление.ТипыОперацийСБилетами.ПустаяСсылка)
	|			ТОГДА ДанныеДокументаПереопределяемый.ФИОПассажира
	|		ИНАЧЕ СведенияОбЭлектронномБилетеПереопределяемый.ФИОПассажира
	|	КОНЕЦ КАК ФИОПассажира,
	|	РеестрДокументовПереопределяемый.Партнер КАК Партнер,
	|	РеестрДокументовПереопределяемый.Контрагент КАК Контрагент,
	|	РеестрДокументовПереопределяемый.Подразделение КАК Подразделение,
	|	РеестрДокументовПереопределяемый.Ответственный КАК Ответственный,
	|	РеестрДокументовПереопределяемый.Комментарий КАК Комментарий,
	|	РеестрДокументовПереопределяемый.ХозяйственнаяОперация КАК ХозяйственнаяОперация,
	|	ТИПЗНАЧЕНИЯ(РеестрДокументовПереопределяемый.Ссылка) КАК Тип,
	|	РеестрДокументовПереопределяемый.Сумма КАК Сумма,
	|	РеестрДокументовПереопределяемый.Валюта КАК Валюта,
	|	ДанныеДокументаПереопределяемый.ТипУслуги КАК ТипУслуги,
	|	ДанныеДокументаПереопределяемый.ДатаОтправления КАК ДатаБрони,
	|	ДанныеДокументаПереопределяемый.ДеталиПоездки КАК ДеталиПоездки,
	|	ВЫБОР
	|		КОГДА ДанныеДокументаПереопределяемый.ТипОперации
	|			В (ЗНАЧЕНИЕ(Перечисление.ТипыОперацийСБилетами.Доплата), ЗНАЧЕНИЕ(Перечисление.ТипыОперацийСБилетами.Возврат))
	|			ТОГДА НЕОПРЕДЕЛЕНО
	|		ИНАЧЕ ДанныеДокументаПереопределяемый.Состояние КОНЕЦ КАК Состояние,
	|	ДанныеДокументаПереопределяемый.ДокументОснование КАК Заявка,
	|	ДанныеДокументаПереопределяемый.ДатаОтправления КАК ДатаОтправления,
	|	ДанныеДокументаПереопределяемый.ДатаПрибытия КАК ДатаПрибытия,
	|	ВЫБОР
	|		КОГДА РеестрДокументовПереопределяемый.Проведен
	|			ТОГДА 0
	|		КОГДА РеестрДокументовПереопределяемый.ПометкаУдаления
	|			ТОГДА 1
	|		ИНАЧЕ 2
	|	КОНЕЦ КАК НестандартнаяКартинка,
	|	&СтатусПроверки КАК СтатусПроверки,
	|	&ИндикаторПроверки КАК ИндикаторПроверки,
	|	РеестрДокументовПереопределяемый.ТипСсылки КАК ТипСсылки,
	|	РеестрДокументовПереопределяемый.ИдентификаторЗаписи КАК ИдентификаторЗаписи
	|ИЗ
	|	РегистрСведений.РеестрДокументов КАК РеестрДокументовПереопределяемый
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ОперацияСЭлектроннымБилетом КАК ДанныеДокументаПереопределяемый
	|		ПО (ДанныеДокументаПереопределяемый.Ссылка = РеестрДокументовПереопределяемый.Ссылка)
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ОперацияСЭлектроннымБилетом КАК СведенияОбЭлектронномБилетеПереопределяемый
	|		ПО ДанныеДокументаПереопределяемый.ЭлектронныйБилет = СведенияОбЭлектронномБилетеПереопределяемый.Ссылка
	|ГДЕ
	|	РеестрДокументовПереопределяемый.ТипСсылки В(&ИдОбъектаОперацияСЭлектроннымБилетом)
	|	И Не ДанныеДокументаПереопределяемый.УдалитьТипБронирования = ЗНАЧЕНИЕ(Перечисление.УдалитьТипыБронирования.Бронирование)
	|{ГДЕ
	|	(ВЫРАЗИТЬ(РеестрДокументовПереопределяемый.Ссылка КАК Документ.ОперацияСЭлектроннымБилетом)).* КАК Ссылка,
	|	РеестрДокументовПереопределяемый.Организация.* КАК Организация,
	|	РеестрДокументовПереопределяемый.ДатаДокументаИБ КАК Дата,
	|	РеестрДокументовПереопределяемый.НомерПервичногоДокумента КАК Номер,
	|	РеестрДокументовПереопределяемый.ТипСсылки КАК ТипСсылки,
	|	РеестрДокументовПереопределяемый.ХозяйственнаяОперация КАК ХозяйственнаяОперация,
	|	(ВЫРАЗИТЬ(РеестрДокументовПереопределяемый.МестоХранения.Ключ КАК Справочник.ФизическиеЛица)).* КАК Сотрудник,
	|	РеестрДокументовПереопределяемый.Партнер.* КАК Партнер,
	|	РеестрДокументовПереопределяемый.Контрагент.* КАК Контрагент,
	|	РеестрДокументовПереопределяемый.Валюта.* КАК Валюта,
	|	РеестрДокументовПереопределяемый.Подразделение.* КАК Подразделение,
	|	РеестрДокументовПереопределяемый.Ответственный.* КАК Ответственный,
	|	РеестрДокументовПереопределяемый.Дополнительно КАК НазначениеПлатежа,
	|	РеестрДокументовПереопределяемый.Комментарий КАК Комментарий,
	|	РеестрДокументовПереопределяемый.Проведен КАК Проведен,
	|	РеестрДокументовПереопределяемый.ПометкаУдаления КАК ПометкаУдаления,
	|	(РеестрДокументовПереопределяемый.ДатаОтраженияВУчете МЕЖДУ &НачалоПериода И &КонецПериода
	|			ИЛИ &КонецПериода = ДАТАВРЕМЯ(1, 1, 1)
	|				И РеестрДокументовПереопределяемый.ДатаОтраженияВУчете >= &НачалоПериода
	|				И НЕ РеестрДокументовПереопределяемый.ДополнительнаяЗапись)}";
	
	МассивТекстов.Добавить(ТекстЗапроса);
	
	//++ Локализация
	
	ТекстЗапроса =
	"ВЫБРАТЬ
	|	ВЫРАЗИТЬ(РеестрДокументовПереопределяемый.Ссылка КАК Документ.БронированиеSmartway) КАК Ссылка,
	|	&ТипДокументаБронирование КАК ТипДокумента,
	|	4 КАК ИдентификаторТипаДокумента,
	|	ЛОЖЬ КАК ЭтоЭлектронныйБилет,
	|	РеестрДокументовПереопределяемый.ДатаДокументаИБ КАК Дата,
	|	РеестрДокументовПереопределяемый.НомерПервичногоДокумента КАК Номер,
	|	РеестрДокументовПереопределяемый.ПометкаУдаления КАК ПометкаУдаления,
	|	РеестрДокументовПереопределяемый.Проведен КАК Проведен,
	|	РеестрДокументовПереопределяемый.Организация КАК Организация,
	|	ВЫРАЗИТЬ(РеестрДокументовПереопределяемый.МестоХранения.Ключ КАК Справочник.ФизическиеЛица) КАК Сотрудник,
	|	НЕОПРЕДЕЛЕНО КАК ФИОПассажира,
	|	РеестрДокументовПереопределяемый.Партнер КАК Партнер,
	|	РеестрДокументовПереопределяемый.Контрагент КАК Контрагент,
	|	РеестрДокументовПереопределяемый.Подразделение КАК Подразделение,
	|	РеестрДокументовПереопределяемый.Ответственный КАК Ответственный,
	|	РеестрДокументовПереопределяемый.Комментарий КАК Комментарий,
	|	РеестрДокументовПереопределяемый.ХозяйственнаяОперация КАК ХозяйственнаяОперация,
	|	ТИПЗНАЧЕНИЯ(РеестрДокументовПереопределяемый.Ссылка) КАК Тип,
	|	РеестрДокументовПереопределяемый.Сумма КАК Сумма,
	|	РеестрДокументовПереопределяемый.Валюта КАК Валюта,
	|	ДанныеДокументаПереопределяемый.ТипУслуги КАК ТипУслуги,
	|	ДанныеДокументаПереопределяемый.ДатаНачала КАК ДатаБрони,
	|	ДанныеДокументаПереопределяемый.ДеталиБронирования КАК ДеталиПоездки,
	|	ДанныеДокументаПереопределяемый.Состояние КАК Состояние,
	|	ДанныеДокументаПереопределяемый.ДокументОснование КАК Заявка,
	|	ДанныеДокументаПереопределяемый.ДатаНачала КАК ДатаОтправления,
	|	ДанныеДокументаПереопределяемый.ДатаОкончания КАК ДатаПрибытия,
	|	ВЫБОР
	|		КОГДА РеестрДокументовПереопределяемый.Проведен
	|			ТОГДА 0
	|		КОГДА РеестрДокументовПереопределяемый.ПометкаУдаления
	|			ТОГДА 1
	|		ИНАЧЕ 2
	|	КОНЕЦ КАК НестандартнаяКартинка,
	|	&СтатусПроверки КАК СтатусПроверки,
	|	&ИндикаторПроверки КАК ИндикаторПроверки,
	|	РеестрДокументовПереопределяемый.ТипСсылки КАК ТипСсылки,
	|	РеестрДокументовПереопределяемый.ИдентификаторЗаписи КАК ИдентификаторЗаписи
	|ИЗ
	|	РегистрСведений.РеестрДокументов КАК РеестрДокументовПереопределяемый
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.БронированиеSmartway КАК ДанныеДокументаПереопределяемый
	|		ПО (ДанныеДокументаПереопределяемый.Ссылка = РеестрДокументовПереопределяемый.Ссылка)
	|ГДЕ
	|	РеестрДокументовПереопределяемый.ТипСсылки В(&ИдОбъектаБронирование)
	|{ГДЕ
	|	(ВЫРАЗИТЬ(РеестрДокументовПереопределяемый.Ссылка КАК Документ.ОперацияСЭлектроннымБилетом)).* КАК Ссылка,
	|	РеестрДокументовПереопределяемый.Организация.* КАК Организация,
	|	РеестрДокументовПереопределяемый.ДатаДокументаИБ КАК Дата,
	|	РеестрДокументовПереопределяемый.НомерПервичногоДокумента КАК Номер,
	|	РеестрДокументовПереопределяемый.ТипСсылки КАК ТипСсылки,
	|	РеестрДокументовПереопределяемый.ХозяйственнаяОперация КАК ХозяйственнаяОперация,
	|	(ВЫРАЗИТЬ(РеестрДокументовПереопределяемый.МестоХранения.Ключ КАК Справочник.ФизическиеЛица)).* КАК Сотрудник,
	|	РеестрДокументовПереопределяемый.Партнер.* КАК Партнер,
	|	РеестрДокументовПереопределяемый.Контрагент.* КАК Контрагент,
	|	РеестрДокументовПереопределяемый.Валюта.* КАК Валюта,
	|	РеестрДокументовПереопределяемый.Подразделение.* КАК Подразделение,
	|	РеестрДокументовПереопределяемый.Ответственный.* КАК Ответственный,
	|	РеестрДокументовПереопределяемый.Дополнительно КАК НазначениеПлатежа,
	|	РеестрДокументовПереопределяемый.Комментарий КАК Комментарий,
	|	РеестрДокументовПереопределяемый.Проведен КАК Проведен,
	|	РеестрДокументовПереопределяемый.ПометкаУдаления КАК ПометкаУдаления,
	|	(РеестрДокументовПереопределяемый.ДатаОтраженияВУчете МЕЖДУ &НачалоПериода И &КонецПериода
	|			ИЛИ &КонецПериода = ДАТАВРЕМЯ(1, 1, 1)
	|				И РеестрДокументовПереопределяемый.ДатаОтраженияВУчете >= &НачалоПериода
	|				И НЕ РеестрДокументовПереопределяемый.ДополнительнаяЗапись)}";
	
	МассивТекстов.Добавить(ТекстЗапроса);
	//-- Локализация
	
	СписокДокументов.ТекстЗапроса = СтрСоединить(МассивТекстов, ОбщегоНазначенияУТ.РазделительЗапросовВОбъединении());
	
КонецПроцедуры

