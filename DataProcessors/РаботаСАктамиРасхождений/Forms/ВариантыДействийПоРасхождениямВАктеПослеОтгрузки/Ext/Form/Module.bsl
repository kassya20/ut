	Элементы.ОтгрузитьСейчасДекорация.Заголовок = НСтр("ru = 'Недопоставленный товар отгружается со склада, документы не переоформляются, реализация оформляется без учета расхождений'");
	
	// Не признавать
	Если Элементы.НедостачаНеПризнана.СписокВыбора.Количество() > 0 Тогда
		Элементы.НедостачаНеПризнана.СписокВыбора[0].Представление = НСтр("ru = 'Не признавать и не учитывать расхождения в реализации'");
	КонецЕсли;
	
	Элементы.НедостачаНеПризнанаДекорация.Заголовок = НСтр("ru = 'Расхождения не признаются, документы не переоформляются, реализация оформляется без учета расхождений'");
	
	// Излишки
	
	Элементы.ДекорацияИзлишкиСогласованы.Заголовок   = НСтр("ru = 'Излишки при отгрузке согласованы с клиентом'");
	Элементы.ДекорацияИзлишкиНеСогласованы.Заголовок = НСтр("ru = 'Излишки при отгрузке не согласованы с клиентом'");
	
	Если СпособОтраженияРасхождений = ПредопределенноеЗначение("Перечисление.СпособыОтраженияРасхожденийАктПриемкиКлиента.ОформлениеКорректировкиКакИсправлениеПервичныхДокументов") Тогда
		
		// Оформить
		Если ДействиеСТоваромИзлишки = ПредопределенноеЗначение("Перечисление.ВариантыДействийПоТоварамВАктеПослеОтгрузки.ОприходоватьВПуть") Тогда
			Элементы.ПокупкаПерепоставленногоДекорация.Заголовок = НСтр("ru = 'Исправление отгрузки товаров клиенту не оформляется'");
		Иначе
			Элементы.ПокупкаПерепоставленногоДекорация.Заголовок = НСтр("ru = 'На перепоставленный товар оформляется исправление отгрузки товаров клиенту'");
		КонецЕсли;
		
		// Оформить и вернуть
		Если ДействиеСТоваромИзлишки = ПредопределенноеЗначение("Перечисление.ВариантыДействийПоТоварамВАктеПослеОтгрузки.ОприходоватьВПуть") Тогда
			Элементы.ВозвратПерепоставленногоДекорация.Заголовок = НСтр("ru = 'Оформляется поступление товаров от клиента для возврата перепоставленного товара'");
		Иначе
			Элементы.ВозвратПерепоставленногоДекорация.Заголовок = НСтр("ru = 'На перепоставленный товар оформляется исправление отгрузки товаров клиенту с последующим оформлением поступления товаров от клиента для возврата перепоставленного товара'");
		КонецЕсли;
		
	Иначе // Перечисления.СпособыОтраженияРасхожденийАктПриемкиКлиента.ИсправлениеПервичныхДокументов
		
		// Оформить
		Если ДействиеСТоваромИзлишки = ПредопределенноеЗначение("Перечисление.ВариантыДействийПоТоварамВАктеПослеОтгрузки.ОприходоватьВПуть") Тогда
			Элементы.ПокупкаПерепоставленногоДекорация.Заголовок = НСтр("ru = 'Отгрузка товаров клиенту не изменяется'");
		Иначе
			Элементы.ПокупкаПерепоставленногоДекорация.Заголовок = НСтр("ru = 'Отгрузка товаров клиенту увеличивается на перепоставленный товар'");
		КонецЕсли;
		
		// Оформить и вернуть
		Если ДействиеСТоваромИзлишки = ПредопределенноеЗначение("Перечисление.ВариантыДействийПоТоварамВАктеПослеОтгрузки.ОприходоватьВПуть") Тогда
			Элементы.ВозвратПерепоставленногоДекорация.Заголовок = НСтр("ru = 'Оформляется поступление товаров от клиента для возврата перепоставленного товара'");
		Иначе
			Элементы.ВозвратПерепоставленногоДекорация.Заголовок = НСтр("ru = 'Отгрузка товаров клиенту увеличивается на перепоставленный товар с последующим оформлением возврата перепоставленного товара'");
		КонецЕсли;
		
	КонецЕсли;
	
	// Вернуть без оформления
	Элементы.ОприходоватьСейчасДекорация.Заголовок = НСтр("ru = 'Перепоставленный товар возвращается на склад, документы не переоформляются, реализация оформляется без учета расхождений'");

	// Не признавать
	Элементы.ПерепоставленноеДаритсяДекорация.Заголовок = НСтр("ru = 'Перепоставленный товар не возвращается на склад, документы не переоформляются'");

	Если Элементы.ПерепоставленноеДарится.СписокВыбора.Количество() > 0 Тогда
		Элементы.ПерепоставленноеДарится.СписокВыбора[0].Представление = НСтр("ru = 'Не признавать и не учитывать расхождения в реализации'");
	КонецЕсли;

КонецПроцедуры

