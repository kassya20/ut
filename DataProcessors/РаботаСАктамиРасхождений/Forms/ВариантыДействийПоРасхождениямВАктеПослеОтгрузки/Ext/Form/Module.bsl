		КонецЕсли;
		Элементы.ТребуетсяДопоставкаДекорация.Заголовок = ТекстЗаголовка;
	Иначе
		Элементы.ДопоставкаНеТребуетсяДекорация.Заголовок
			= НСтр("ru = 'Отгрузка товаров поклажедателю уменьшается на недопоставленный товар'");
		Элементы.ТребуетсяДопоставкаДекорация.Заголовок
			= НСтр("ru = 'Отгрузка товаров поклажедателю уменьшается на недопоставленный товар с последующим оформлением новой отгрузки недопоставленного товара'");
	КонецЕсли;
	
	Элементы.НедостачаНеПризнанаДекорация.Заголовок = НСтр("ru = 'Недопоставленный товар не отгружается со склада, документы не переоформляются'");
	Элементы.ОтгрузитьСейчасДекорация.Заголовок = НСтр("ru = 'Недопоставленный товар отгружается со склада, документы не переоформляются'");
	
	// Излишки
	Элементы.ДекорацияИзлишкиСогласованы.Заголовок   = НСтр("ru = 'Излишки при отгрузке с ответственного хранения согласованы с поставщиком'");
	Элементы.ДекорацияИзлишкиНеСогласованы.Заголовок = НСтр("ru = 'Излишки при отгрузке с ответственного хранения не согласованы с поставщиком'");
	
	// Действие с товаром
	Элементы.ОприходоватьВПутьДействиеСТоваромИзлишки.Видимость = Ложь;
	Элементы.ОприходоватьВПутьДействиеСТоваромИзлишкиДекорация.Видимость = Ложь;
	
	// Действие с документом
	Если СпособОтраженияРасхождений = ПредопределенноеЗначение("Перечисление.СпособыОтраженияРасхожденийАктПриемкиКлиента.ОформлениеКорректировкиКакИсправлениеПервичныхДокументов") Тогда
		Если ОтгрузкаПринципалу Тогда
			ТекстЗаголовка
				= НСтр("ru = 'На перепоставленный товар оформляется отгрузка принципалу (исправление)'");
		Иначе
			ТекстЗаголовка
				= НСтр("ru = 'На перепоставленный товар оформляется отгрузка поклажедателю (исправление)'");
		КонецЕсли;
		Элементы.ПокупкаПерепоставленногоДекорация.Заголовок = ТекстЗаголовка;
		Если ОтгрузкаПринципалу Тогда
			ТекстЗаголовка
				= НСтр("ru = 'На перепоставленный товар оформляется отгрузка принципалу (исправление) с последующим оформлением поступления перепоставленного товара'");
		Иначе
			ТекстЗаголовка
				= НСтр("ru = 'На перепоставленный товар оформляется отгрузка поклажедателю (исправление) с последующим оформлением поступления перепоставленного товара'");
		КонецЕсли;
		Элементы.ВозвратПерепоставленногоДекорация.Заголовок = ТекстЗаголовка;
	Иначе
		Элементы.ПокупкаПерепоставленногоДекорация.Заголовок
			= НСтр("ru = 'Отгрузка товаров поклажедателю увеличивается на перепоставленный товар'");
		Элементы.ВозвратПерепоставленногоДекорация.Заголовок
			= НСтр("ru = 'Отгрузка товаров поклажедателю увеличивается на перепоставленный товар с последующим оформлением поступления перепоставленного товара'");
	КонецЕсли;
	
	Элементы.ПерепоставленноеДаритсяДекорация.Заголовок = НСтр("ru = 'Перепоставленный товар не возвращается на склад, документы не переоформляются'");
	Элементы.ОприходоватьСейчасДекорация.Заголовок = НСтр("ru = 'Перепоставленный товар возвращается на склад, документы не переоформляются'");
	
КонецПроцедуры


&НаКлиенте
Процедура УстановитьДоступностьДействий()
	
	// Недостачи
	
	Если ДействиеСТоваромНедостачи = ПредопределенноеЗначение("Перечисление.ВариантыДействийПоТоварамВАктеПослеОтгрузки.Списать") Тогда
		
		Элементы.ДопоставкаНеТребуется.Доступность = Истина;
		Элементы.ТребуетсяДопоставка.Доступность = Истина;
		Элементы.ОтгрузитьСейчас.Доступность = Истина;
		Элементы.НедостачаНеПризнана.Доступность = Ложь;
		
		Если ДействиеСДокументомНедостачи = ПредопределенноеЗначение("Перечисление.ВариантыДействийПоРасхождениямВАктеПослеОтгрузки.НедостачаНеПризнана") Тогда
			ДействиеСДокументомНедостачи = ПредопределенноеЗначение("Перечисление.ВариантыДействийПоРасхождениямВАктеПослеОтгрузки.ДопоставкаНеТребуется");
		КонецЕсли;
		
	ИначеЕсли ДействиеСТоваромНедостачи = ПредопределенноеЗначение("Перечисление.ВариантыДействийПоТоварамВАктеПослеОтгрузки.СписатьИзПути") Тогда
		
		Элементы.ДопоставкаНеТребуется.Доступность = Истина;
		Элементы.ТребуетсяДопоставка.Доступность = Истина;
		Элементы.ОтгрузитьСейчас.Доступность = Ложь;
		Элементы.НедостачаНеПризнана.Доступность = Ложь;
		
		Если ДействиеСДокументомНедостачи = ПредопределенноеЗначение("Перечисление.ВариантыДействийПоРасхождениямВАктеПослеОтгрузки.НедостачаНеПризнана")
			Или ДействиеСДокументомНедостачи = ПредопределенноеЗначение("Перечисление.ВариантыДействийПоРасхождениямВАктеПослеОтгрузки.ОтгрузитьСейчас") Тогда
			ДействиеСДокументомНедостачи = ПредопределенноеЗначение("Перечисление.ВариантыДействийПоРасхождениямВАктеПослеОтгрузки.ДопоставкаНеТребуется");
		КонецЕсли;
		
	ИначеЕсли ДействиеСТоваромНедостачи = ПредопределенноеЗначение("Перечисление.ВариантыДействийПоТоварамВАктеПослеОтгрузки.УчестьПриИнвентаризации") Тогда
		
		Элементы.ДопоставкаНеТребуется.Доступность = Истина;
		Элементы.ТребуетсяДопоставка.Доступность = Истина;
		Элементы.ОтгрузитьСейчас.Доступность = Истина;
		Элементы.НедостачаНеПризнана.Доступность = Истина;
		
	ИначеЕсли ДействиеСТоваромНедостачи = ПредопределенноеЗначение("Перечисление.ВариантыДействийПоТоварамВАктеПослеОтгрузки.Вернуть") Тогда
		
		Элементы.ДопоставкаНеТребуется.Доступность = Истина;
		Элементы.ТребуетсяДопоставка.Доступность = Истина;
		Элементы.ОтгрузитьСейчас.Доступность = Ложь;
		Элементы.НедостачаНеПризнана.Доступность = Ложь;
		
		Если ДействиеСДокументомНедостачи = ПредопределенноеЗначение("Перечисление.ВариантыДействийПоРасхождениямВАктеПослеОтгрузки.НедостачаНеПризнана")
			Или ДействиеСДокументомНедостачи = ПредопределенноеЗначение("Перечисление.ВариантыДействийПоРасхождениямВАктеПослеОтгрузки.ОтгрузитьСейчас") Тогда
			ДействиеСДокументомНедостачи = ПредопределенноеЗначение("Перечисление.ВариантыДействийПоРасхождениямВАктеПослеОтгрузки.ДопоставкаНеТребуется");
		КонецЕсли;
		
	ИначеЕсли ДействиеСТоваромНедостачи = ПредопределенноеЗначение("Перечисление.ВариантыДействийПоТоварамВАктеПослеОтгрузки.Ожидать") Тогда
		
		Элементы.ДопоставкаНеТребуется.Доступность = Ложь;
		Элементы.ТребуетсяДопоставка.Доступность = Ложь;
		Элементы.ОтгрузитьСейчас.Доступность = Ложь;
		Элементы.НедостачаНеПризнана.Доступность = Истина;
		
		Если ДействиеСДокументомНедостачи = ПредопределенноеЗначение("Перечисление.ВариантыДействийПоРасхождениямВАктеПослеОтгрузки.ДопоставкаНеТребуется")
			Или ДействиеСДокументомНедостачи = ПредопределенноеЗначение("Перечисление.ВариантыДействийПоРасхождениямВАктеПослеОтгрузки.ТребуетсяДопоставка")
			Или ДействиеСДокументомНедостачи = ПредопределенноеЗначение("Перечисление.ВариантыДействийПоРасхождениямВАктеПослеОтгрузки.ОтгрузитьСейчас") Тогда
			ДействиеСДокументомНедостачи = ПредопределенноеЗначение("Перечисление.ВариантыДействийПоРасхождениямВАктеПослеОтгрузки.НедостачаНеПризнана");
		КонецЕсли;
		
	КонецЕсли;
	
	// Излишки
	
	Если ДействиеСТоваромИзлишки = ПредопределенноеЗначение("Перечисление.ВариантыДействийПоТоварамВАктеПослеОтгрузки.ОприходоватьВПуть") Тогда
		
		Элементы.ПокупкаПерепоставленного.Доступность = Истина;
		Элементы.ВозвратПерепоставленного.Доступность = Истина;
		Элементы.ОприходоватьСейчас.Доступность = Ложь;
		Элементы.ПерепоставленноеДарится.Доступность = Ложь;
		
		Если ДействиеСДокументомИзлишки = ПредопределенноеЗначение("Перечисление.ВариантыДействийПоРасхождениямВАктеПослеОтгрузки.ОприходоватьСейчас")
			Или ДействиеСДокументомИзлишки = ПредопределенноеЗначение("Перечисление.ВариантыДействийПоРасхождениямВАктеПослеОтгрузки.ПерепоставленноеДарится") Тогда
			ДействиеСДокументомИзлишки = ПредопределенноеЗначение("Перечисление.ВариантыДействийПоРасхождениямВАктеПослеОтгрузки.ПокупкаПерепоставленного");
		КонецЕсли;
		
	ИначеЕсли ДействиеСТоваромИзлишки = ПредопределенноеЗначение("Перечисление.ВариантыДействийПоТоварамВАктеПослеОтгрузки.УчестьПриИнвентаризации") Тогда
		
		Элементы.ПокупкаПерепоставленного.Доступность = Истина;
		Элементы.ВозвратПерепоставленного.Доступность = Истина;
		Элементы.ОприходоватьСейчас.Доступность = Истина;
		Элементы.ПерепоставленноеДарится.Доступность = Истина;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПередЗакрытиемЗавершение(РезультатВопроса, ДополнительныеПараметры) Экспорт
	
	Ответ = РезультатВопроса;
	Если Ответ = КодВозвратаДиалога.Да Тогда
		ВыполняетсяЗакрытие = Истина;
		Закрыть();
	КонецЕсли;
	
КонецПроцедуры

