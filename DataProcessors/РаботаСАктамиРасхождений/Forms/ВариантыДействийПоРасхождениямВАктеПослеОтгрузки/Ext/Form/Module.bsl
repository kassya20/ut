
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	РасхожденияСервер.УправлениеСтраницамиВыборДействия(ЭтотОбъект, Параметры);
	
	ИспользоватьЗаявкиНаВозврат = ПолучитьФункциональнуюОпцию("ИспользоватьЗаявкиНаВозвратТоваровОтКлиентов");
	ИспользоватьЗаказыКлиентов = ПолучитьФункциональнуюОпцию("ИспользоватьЗаказыКлиентов");
	ИспользоватьЗаказыНаПеремещение = ПолучитьФункциональнуюОпцию("ИспользоватьЗаказыНаПеремещение");
	ИспользоватьОтгрузкуБезПереходаПраваСобственности2_5 = ПолучитьФункциональнуюОпцию("ИспользоватьОтгрузкуБезПереходаПраваСобственности2_5");
	КоличествоУпаковокРасхождения = Параметры.КоличествоУпаковокРасхождения;
	ГрупповоеИзменение = Параметры.ГрупповоеИзменение;
	ЭтоПереходПраваСобственности = (Параметры.ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.ПереходПраваСобственности);
	ЭтоРеализацияРеглУчет = (Параметры.ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.РеализацияКлиентуРеглУчет);
	ТипАкта = Параметры.ТипАкта;
	ОтгрузкаПринципалу = Параметры.ОтгрузкаПринципалу;
	СпособОтраженияРасхождений = Параметры.СпособОтраженияРасхождений;
	СтрокаПоЗаказу = Параметры.СтрокаПоЗаказу;
	Договор = Параметры.Договор;
	ЕстьТара = Параметры.ЕстьТара;
	
	Если ОтгрузкаПринципалу
		Или Не ГрупповоеИзменение
			И КоличествоУпаковокРасхождения >= 0
			И (Параметры.ТипНоменклатуры = Перечисления.ТипыНоменклатуры.Работа
				Или Параметры.ТипНоменклатуры = Перечисления.ТипыНоменклатуры.Услуга) Тогда
		Если ДействиеСДокументомИзлишки = Перечисления.ВариантыДействийПоРасхождениямВАктеПослеОтгрузки.ВозвратПерепоставленного Тогда
			ДействиеСДокументомИзлишки = Перечисления.ВариантыДействийПоРасхождениямВАктеПослеОтгрузки.ПустаяСсылка();
		КонецЕсли;
		Элементы.ВозвратПерепоставленного.Доступность = Ложь;
	КонецЕсли;
	
	Если Не ГрупповоеИзменение Тогда
		Если КоличествоУпаковокРасхождения >= 0 Тогда
			
			Элементы.Страницы.ТекущаяСтраница = Элементы.Излишки;
			
			ДействиеСТоваромИзлишки = ?(
				ЗначениеЗаполнено(Параметры.ВыбранноеДействиеСТоваром),
				Параметры.ВыбранноеДействиеСТоваром,
				Перечисления.ВариантыДействийПоТоварамВАктеПослеОтгрузки.УчестьПриИнвентаризации);
			
			ДействиеСДокументомИзлишки = ?(
				ЗначениеЗаполнено(Параметры.ВыбранноеДействиеСДокументом),
				Параметры.ВыбранноеДействиеСДокументом,
				Перечисления.ВариантыДействийПоРасхождениямВАктеПослеОтгрузки.ПокупкаПерепоставленного);
			
		Иначе
			
			Элементы.Страницы.ТекущаяСтраница = Элементы.Недостачи;
			
			ДействиеСТоваромНедостачи = ?(
				ЗначениеЗаполнено(Параметры.ВыбранноеДействиеСТоваром),
				Параметры.ВыбранноеДействиеСТоваром,
				Перечисления.ВариантыДействийПоТоварамВАктеПослеОтгрузки.УчестьПриИнвентаризации);
			
			ДействиеСДокументомНедостачи = ?(
				ЗначениеЗаполнено(Параметры.ВыбранноеДействиеСДокументом),
				Параметры.ВыбранноеДействиеСДокументом,
				Перечисления.ВариантыДействийПоРасхождениямВАктеПослеОтгрузки.ДопоставкаНеТребуется);
			
		КонецЕсли;
	Иначе
		
		Если Параметры.ЕстьИзлишки Тогда
			
			Если Не ЗначениеЗаполнено(ДействиеСТоваромИзлишки) Тогда
				ДействиеСТоваромИзлишки = Перечисления.ВариантыДействийПоТоварамВАктеПослеОтгрузки.УчестьПриИнвентаризации;
			КонецЕсли;
			
			Если Не ЗначениеЗаполнено(ДействиеСДокументомИзлишки) Тогда
				ДействиеСДокументомИзлишки = Перечисления.ВариантыДействийПоРасхождениямВАктеПослеОтгрузки.ПокупкаПерепоставленного;
			КонецЕсли;
			
		КонецЕсли;
		
		Если Параметры.ЕстьНедостачи Тогда
			
			Если Не ЗначениеЗаполнено(ДействиеСТоваромНедостачи) Тогда
				ДействиеСТоваромНедостачи = Перечисления.ВариантыДействийПоТоварамВАктеПослеОтгрузки.УчестьПриИнвентаризации;
			КонецЕсли;
			
			Если Не ЗначениеЗаполнено(ДействиеСДокументомНедостачи) Тогда
				ДействиеСДокументомНедостачи = Перечисления.ВариантыДействийПоРасхождениямВАктеПослеОтгрузки.ДопоставкаНеТребуется;
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЕсли;
	
	Если ГрупповоеИзменение Тогда
		Заголовок = НСтр("ru='Как отработать расхождения'");
	Иначе
		Если КоличествоУпаковокРасхождения >= 0 Тогда
			Элементы.Недостачи.Видимость = Ложь;
			Заголовок = НСтр("ru='Как отработать излишек'");
		Иначе
			Элементы.Излишки.Видимость = Ложь;
			Заголовок = НСтр("ru='Как отработать недостачу'");
		КонецЕсли;
	КонецЕсли;
	
	Элементы.КартинкаПояснения.Видимость = Параметры.ПоказыватьПояснение;
	Элементы.Пояснение.Видимость = Параметры.ПоказыватьПояснение;
	
КонецПроцедуры

&НаКлиенте
Процедура ПередЗакрытием(Отказ, ЗавершениеРаботы, ТекстПредупреждения, СтандартнаяОбработка)
	
	Если Не ВыполняетсяЗакрытие И Модифицированность И НЕ ЗавершениеРаботы Тогда
		
		Отказ = Истина;
		Оповещение = Новый ОписаниеОповещения("ПередЗакрытиемЗавершение", ЭтотОбъект);
		ПоказатьВопрос(
			Оповещение,
			НСтр("ru='Выполненные изменения будут утеряны. Все равно закрыть?'"),
			РежимДиалогаВопрос.ДаНет);
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	СформироватьЗаголовки();
	УстановитьДоступностьДействий();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура СписатьДействиеСТоваромНедостачиПриИзменении(Элемент)
	
	Если РасхожденияКлиентСервер.ТипОснованияОтгрузкаТоваровКлиенту(ТипАкта) Тогда
		СформироватьЗаголовки();
	КонецЕсли;
	
	УстановитьДоступностьДействий();
	
КонецПроцедуры

&НаКлиенте
Процедура СписатьИзПутиДействиеСТоваромНедостачиПриИзменении(Элемент)
	
	Если РасхожденияКлиентСервер.ТипОснованияОтгрузкаТоваровКлиенту(ТипАкта) Тогда
		СформироватьЗаголовки();
	КонецЕсли;
	
	УстановитьДоступностьДействий();
	
КонецПроцедуры

&НаКлиенте
Процедура УчестьПриИнвентаризацииДействиеСТоваромНедостачиПриИзменении(Элемент)
	
	Если РасхожденияКлиентСервер.ТипОснованияОтгрузкаТоваровКлиенту(ТипАкта) Тогда
		СформироватьЗаголовки();
	КонецЕсли;
	
	УстановитьДоступностьДействий();
	
КонецПроцедуры

&НаКлиенте
Процедура ВернутьДействиеСТоваромНедостачиПриИзменении(Элемент)
	
	Если РасхожденияКлиентСервер.ТипОснованияОтгрузкаТоваровКлиенту(ТипАкта) Тогда
		СформироватьЗаголовки();
	КонецЕсли;
	
	УстановитьДоступностьДействий();
	
КонецПроцедуры

&НаКлиенте
Процедура ОжидатьДействиеСТоваромНедостачиПриИзменении(Элемент)
	
	Если РасхожденияКлиентСервер.ТипОснованияОтгрузкаТоваровКлиенту(ТипАкта) Тогда
		СформироватьЗаголовки();
	КонецЕсли;
	
	УстановитьДоступностьДействий();
	
КонецПроцедуры

&НаКлиенте
Процедура ОприходоватьВПутьДействиеСТоваромИзлишкиПриИзменении(Элемент)
	
	Если РасхожденияКлиентСервер.ТипОснованияОтгрузкаТоваровКлиенту(ТипАкта) Тогда
		СформироватьЗаголовки();
	КонецЕсли;
	
	УстановитьДоступностьДействий();
	
КонецПроцедуры

&НаКлиенте
Процедура УчестьПриИнвентаризацииДействиеСТоваромИзлишкиПриИзменении(Элемент)
	УстановитьДоступностьДействий();
	
	Если РасхожденияКлиентСервер.ТипОснованияОтгрузкаТоваровКлиенту(ТипАкта) Тогда
		СформироватьЗаголовки();
	КонецЕсли;
	
	УстановитьДоступностьДействий();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура ОК(Команда)
	
	ВыполняетсяЗакрытие = Истина;
	
	Если ГрупповоеИзменение Тогда
		ПараметрыЗакрытия = Новый Структура();
		ПараметрыЗакрытия.Вставить("ДействиеСДокументомИзлишки", ДействиеСДокументомИзлишки);
		ПараметрыЗакрытия.Вставить("ДействиеСДокументомНедостачи", ДействиеСДокументомНедостачи);
		ПараметрыЗакрытия.Вставить("ДействиеСТоваромИзлишки", ДействиеСТоваромИзлишки);
		ПараметрыЗакрытия.Вставить("ДействиеСТоваромНедостачи", ДействиеСТоваромНедостачи);
		Закрыть(ПараметрыЗакрытия);
	ИначеЕсли КоличествоУпаковокРасхождения > 0 Тогда
		ПараметрыЗакрытия = Новый Структура();
		ПараметрыЗакрытия.Вставить("ДействиеСДокументом", ДействиеСДокументомИзлишки);
		ПараметрыЗакрытия.Вставить("ДействиеСТоваром", ДействиеСТоваромИзлишки);
		Закрыть(ПараметрыЗакрытия);
	ИначеЕсли КоличествоУпаковокРасхождения < 0 Тогда
		ПараметрыЗакрытия = Новый Структура();
		ПараметрыЗакрытия.Вставить("ДействиеСДокументом", ДействиеСДокументомНедостачи);
		ПараметрыЗакрытия.Вставить("ДействиеСТоваром", ДействиеСТоваромНедостачи);
		Закрыть(ПараметрыЗакрытия);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура Отмена(Команда)
	
	ВыполняетсяЗакрытие = Истина;
	Закрыть(Неопределено);

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Процедура СформироватьЗаголовки()
	
	Если РасхожденияКлиентСервер.ТипОснованияРеализацияТоваровУслуг(ТипАкта) Тогда
		
		СформироватьЗаголовкиАктРеализация();
	
	ИначеЕсли РасхожденияКлиентСервер.ТипОснованияОтгрузкаТоваровКлиенту(ТипАкта) Тогда
		
		СформироватьЗаголовкиАктОтгрузкаТоваровКлиенту();
		
	ИначеЕсли РасхожденияКлиентСервер.ТипОснованияВозвратПоставщику(ТипАкта) Тогда
		
		СформироватьЗаголовкиАктВозврат();
		
	ИначеЕсли ТипАкта = "Перемещение" Тогда
		
		СформироватьЗаголовкиАктПеремещение();
		
	ИначеЕсли РасхожденияКлиентСервер.ТипОснованияПередачаТоваровХранителю(ТипАкта)
		Или РасхожденияКлиентСервер.ТипОснованияПередачаНаКомиссию(ТипАкта) Тогда
		
		СформироватьЗаголовкиАктПередача();
		
	ИначеЕсли РасхожденияКлиентСервер.ТипОснованияОтгрузкаТоваровСХранения(ТипАкта) Тогда
		
		СформироватьЗаголовкиАктОтветственноеХранение();
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура СформироватьЗаголовкиАктРеализация()
	
	// 1. Недостачи
	Элементы.ДекорацияНедостачиСогласованы.Заголовок   = НСтр("ru = 'Недостачи при реализации согласованы с клиентом'");
	Элементы.ДекорацияНедостачиНеСогласованы.Заголовок = НСтр("ru = 'Недостачи при реализации не согласованы с клиентом'");
	
	// 1.1. Корректировка (исправление)
	Если СпособОтраженияРасхождений = ПредопределенноеЗначение("Перечисление.СпособыОтраженияРасхожденийАктПриемкиКлиента.ОформлениеКорректировкиКакИсправлениеПервичныхДокументов") Тогда
		
		// Действие с товаром
		Элементы.СписатьИзПутиДействиеСТоваромНедостачи.Видимость = Ложь;
		Элементы.СписатьИзПутиДействиеСТоваромНедостачиДекорация.Видимость = Ложь;
		
		Элементы.ВернутьДействиеСТоваромНедостачи.Видимость =
			ИспользоватьОтгрузкуБезПереходаПраваСобственности2_5 И ЗначениеЗаполнено(Договор) И Не ЕстьТара;
		Элементы.ВернутьДействиеСТоваромНедостачиДекорация.Видимость =
			ИспользоватьОтгрузкуБезПереходаПраваСобственности2_5 И ЗначениеЗаполнено(Договор) И Не ЕстьТара;
		
		Элементы.ОжидатьДействиеСТоваромНедостачи.Видимость = Ложь;
		Элементы.ОжидатьДействиеСТоваромНедостачиДекорация.Видимость = Ложь;
		
		Элементы.УчестьПриИнвентаризацииДействиеСТоваромНедостачиДекорация.Заголовок = НСтр("ru = 'Расхождения учитываются при инвентаризации'");
		
		Элементы.ВернутьДействиеСТоваромНедостачиДекорация.Заголовок = НСтр("ru = 'Оформляется корректировка реализации для возврата товаров ""в путь""'");
		
		// Действие с документом
		
		// Оформить
		Элементы.ДопоставкаНеТребуетсяДекорация.Заголовок = НСтр("ru = 'На недопоставленный товар оформляется корректировка реализации (исправление)'");
		
		// Оформить и допоставить
		Если ЭтоПереходПраваСобственности Тогда
			Элементы.ТребуетсяДопоставкаДекорация.Заголовок = НСтр("ru = 'На недопоставленный товар оформляется корректировка реализации (исправление) с последующим оформлением новой отгрузки товаров клиенту недопоставленного товара'");
		Иначе
			Элементы.ТребуетсяДопоставкаДекорация.Заголовок = НСтр("ru = 'На недопоставленный товар оформляется корректировка реализации (исправление) с последующим оформлением реализации недопоставленного товара'");
		КонецЕсли;
		
	// 1.2. Корректировка (по согласованию сторон)
	ИначеЕсли СпособОтраженияРасхождений = ПредопределенноеЗначение("Перечисление.СпособыОтраженияРасхожденийАктПриемкиКлиента.ОформлениеКорректировкиПоСогласованию") Тогда
	
		// Действие с товаром
		Элементы.СписатьИзПутиДействиеСТоваромНедостачи.Видимость = Ложь;
		Элементы.СписатьИзПутиДействиеСТоваромНедостачиДекорация.Видимость = Ложь;
		
		Элементы.ВернутьДействиеСТоваромНедостачи.Видимость =
			ИспользоватьОтгрузкуБезПереходаПраваСобственности2_5 И ЗначениеЗаполнено(Договор) И Не ЕстьТара;
		Элементы.ВернутьДействиеСТоваромНедостачиДекорация.Видимость =
			ИспользоватьОтгрузкуБезПереходаПраваСобственности2_5 И ЗначениеЗаполнено(Договор) И Не ЕстьТара;
		
		Элементы.ОжидатьДействиеСТоваромНедостачи.Видимость = Ложь;
		Элементы.ОжидатьДействиеСТоваромНедостачиДекорация.Видимость = Ложь;
		
		Элементы.УчестьПриИнвентаризацииДействиеСТоваромНедостачиДекорация.Заголовок = НСтр("ru = 'Расхождения учитываются при инвентаризации'");
		
		Элементы.ВернутьДействиеСТоваромНедостачиДекорация.Заголовок = НСтр("ru = 'Оформляется корректировка реализации для возврата товаров ""в путь""'");
		
		// Действие с документом
		
		// Оформить
		Элементы.ДопоставкаНеТребуетсяДекорация.Заголовок = НСтр("ru = 'На недопоставленный товар оформляется корректировка реализации (по согласованию сторон)'");
		
		// Оформить и допоставить
		Если ЭтоПереходПраваСобственности Тогда
			Элементы.ТребуетсяДопоставкаДекорация.Заголовок = НСтр("ru = 'На недопоставленный товар оформляется корректировка реализации (по согласованию сторон) с последующим оформлением отгрузки товаров клиенту недопоставленного товара'");
		Иначе
			Элементы.ТребуетсяДопоставкаДекорация.Заголовок = НСтр("ru = 'На недопоставленный товар оформляется корректировка реализации (по согласованию сторон) с последующим оформлением реализации недопоставленного товара'");
		КонецЕсли;
		
	// 1.3.
	ИначеЕсли СпособОтраженияРасхождений = ПредопределенноеЗначение("Перечисление.СпособыОтраженияРасхожденийАктПриемкиКлиента.ОформлениеКорректировокКакНовыеПервичныеДокументы") Тогда
		
