// Проверяет и возвращает признак необходимости указания серий при планировании отбора.
//
//	Параметры:
//		РасходныйОрдер - ДокументСсылка.РасходныйОрдерНаТовары - ссылка на расходный ордер.
//		Склад - СправочникСсылка.Склады - ссылка на склад, указанный в расходном ордере.
//		
//	Возвращаемое значение:
//		Булево - Истина, если требуется указание серий при планировании отбора.
//
Функция ПроверитьСтатусУказанияСерийПриПланированииОтбора(РасходныйОрдер, Склад) Экспорт
	
#Если Не МобильныйАвтономныйСервер Тогда
	Помещение = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(РасходныйОрдер, "Помещение");
#Иначе
	Помещение = МобильноеРабочееМестоКладовщика.ЗначениеРеквизитаОбъекта(РасходныйОрдер, "Помещение");
#КонецЕсли
	
	СтруктураПараметров = Новый Структура("Склад, Помещение", Склад, Помещение);
	ИспользоватьАдресноеХранение = ПолучитьФункциональнуюОпцию("ИспользоватьАдресноеХранение", СтруктураПараметров);
	
	Если Не ИспользоватьАдресноеХранение Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	РасходныйОрдерНаТоварыОтгружаемыеТовары.Номенклатура КАК Номенклатура
		|ИЗ
		|	Документ.РасходныйОрдерНаТовары.ОтгружаемыеТовары КАК РасходныйОрдерНаТоварыОтгружаемыеТовары
		|ГДЕ
		|	РасходныйОрдерНаТоварыОтгружаемыеТовары.СтатусУказанияСерий В(&Статусы)
		|	И РасходныйОрдерНаТоварыОтгружаемыеТовары.Ссылка = &Ссылка";
	
	Статусы = Новый Массив;
	Статусы.Добавить(27);
	Статусы.Добавить(7);
	Статусы.Добавить(5);

	Запрос.УстановитьПараметр("Статусы", Статусы);
	Запрос.УстановитьПараметр("Ссылка", РасходныйОрдер);
	
	РезультатЗапроса = Запрос.Выполнить().Выбрать();   
	
	Если РезультатЗапроса.Следующий() Тогда
		Возврат Истина;
	КонецЕсли;
	
	Возврат Ложь;
	
КонецФункции

// Производит поиск объекта (документа,ячейки или номенклатуры) по штрихкоду и возвращает данные об объекте.
//
//	Параметры:
//		Штрихкод - Строка - отсканированный штрихкод.
//		Склад - СправочникСсылка.Склады - ссылка на склад, указанный в отборах. Может быть пустым.
//		Помещение - СправочникСсылка.СкладскиеПомещения - ссылка на помещение, указанное в отборах. Может быть пустым.
//		
//	Возвращаемое значение:
//		Структура - Структура данных найденного объекта:
//			* ВидОбъекта - Строка, Неопределено - текстовое описание найденного объекта: Номенклатура, Ячейка или Документ.
//			* ТекстОшибки - Строка - текст ошибки при поиске документа.
//			* Товары - Массив из Структура: см. ДанныеТоваровПоШК().
//			* ДанныеЯчейки - Структура: см. ДанныеЯчейкиПоШК().
//			* ДанныеДокумента - Структура: см. ДанныеДокументаПоШК().
//
Функция ДанныеПоОбщемуШтрихкоду(Штрихкод, Склад, Помещение) Экспорт
		
	ДанныеОбъекта = Новый Структура();
	ДанныеОбъекта.Вставить("ВидОбъекта", Неопределено);
	ДанныеОбъекта.Вставить("ТекстОшибки", "");
	ДанныеОбъекта.Вставить("Товары", Новый Массив);
	ДанныеОбъекта.Вставить("ДанныеЯчейки", Новый Структура);
	ДанныеОбъекта.Вставить("ДанныеДокумента", Новый Структура);
	
	ТоварыПоШК = ДанныеТоваровПоШК(Штрихкод);
	
	Если ЗначениеЗаполнено(ТоварыПоШК) Тогда 
		ДанныеОбъекта.ВидОбъекта = "Номенклатура";
		ДанныеОбъекта.Товары = ТоварыПоШК;
		Возврат ДанныеОбъекта;
	КонецЕсли;
	
	ДанныеЯчейки = ДанныеЯчейкиПоШК(Склад, Помещение, Штрихкод);
	
	Если ЗначениеЗаполнено(ДанныеЯчейки.Ячейка) Тогда
		ДанныеОбъекта.ВидОбъекта = "Ячейка";
		ДанныеОбъекта.ДанныеЯчейки = ДанныеЯчейки;
		Возврат ДанныеОбъекта;
	КонецЕсли;
		
	ДанныеДокумента = ДанныеДокументаПоШК(Штрихкод, Склад);
	
	Если ЗначениеЗаполнено(ДанныеДокумента.Ссылки) Тогда
		ДанныеОбъекта.ВидОбъекта = "Документ"; 
		ДанныеОбъекта.ДанныеДокумента = ДанныеДокумента;
		Возврат ДанныеОбъекта;
	КонецЕсли;
		
	ДанныеОбъекта.ТекстОшибки = НСтр("ru = 'Штрихкод ячейки, товара или документа не распознан.
		|Возможно неверно указан склад.'");
	
	Возврат ДанныеОбъекта;
	
КонецФункции

// Производит поиск документа (распоряжения или складского) по штрихкоду и возвращает данные о документу.
//
//	Параметры:
//		Штрихкод - Строка - отсканированный штрихкод.
//		Склад - СправочникСсылка.Склады - ссылка на склад, указанный в отборах. Может быть пустым.
//		КонтекстРаспоряжения - Строка - строкое описание контекста поиска распоряжения.
//		
//	Возвращаемое значение:
//		Структура - Структура со свойствами:
//			* ЭтоРаспоряжение - Булево - признак того, что найденый документ является распоряжением.
//			* Ссылки - Массив Из Структура - массив из ссылок на найденный документ(-ы).
//			* Распоряжение - Неопределено - ссылка на распоряжение, если найденны ордера.
//			* Направление - Строка - строкое описание направления найденного документа.
//			* Режим - Строка - строкое описание режима поиска документа.
//			* Штрихкод - Строка - штрихкод отсканированного документа.
//			* ТекстОшибки - Строка - текст ошибки поиска документа.
//
Функция ДанныеДокументаПоШК(Штрихкод, Склад, КонтекстРаспоряжения = "") Экспорт
	
	РезультатПоиска = РезультатПоискаДокументаПоШК();
	РезультатПоиска.Режим = "ПоискДокумента";
	РезультатПоиска.Штрихкод = Штрихкод;
	
	МассивДокументов = Новый Массив;
	МассивДокументов.Добавить(Тип("ДокументСсылка.РасходныйОрдерНаТовары"));
	МассивДокументов.Добавить(Тип("ДокументСсылка.ПриходныйОрдерНаТовары"));
	МассивДокументов.Добавить(Тип("ДокументСсылка.ОтборРазмещениеТоваров"));
    МассивДокументов.Добавить(Тип("ДокументСсылка.ПересчетТоваров")); 
		
	МассивПустыхСсылок = Новый Массив;
	МассивПустыхСсылок.Добавить(Документы.РасходныйОрдерНаТовары.ПустаяСсылка());
	МассивПустыхСсылок.Добавить(Документы.ПриходныйОрдерНаТовары.ПустаяСсылка());
	МассивПустыхСсылок.Добавить(Документы.ОтборРазмещениеТоваров.ПустаяСсылка());
	МассивПустыхСсылок.Добавить(Документы.ПересчетТоваров.ПустаяСсылка()); 
	
	МассивТиповОтгрузки = Метаданные.ОпределяемыеТипы.РаспоряжениеНаОтгрузку.Тип.Типы();
	Для Каждого Тип Из МассивТиповОтгрузки Цикл		
		ИмяДокумента = Метаданные.НайтиПоТипу(Тип).ПолноеИмя();
		ПустаяСсылка = ПредопределенноеЗначение(ИмяДокумента + ".ПустаяСсылка");
		МассивПустыхСсылок.Добавить(ПустаяСсылка);		
	КонецЦикла; 
	
	МассивТиповПриемки = Метаданные.ОпределяемыеТипы.РаспоряжениеНаПоступление.Тип.Типы();
	Для Каждого Тип Из МассивТиповПриемки Цикл		
		ИмяДокумента = Метаданные.НайтиПоТипу(Тип).ПолноеИмя();
		ПустаяСсылка = ПредопределенноеЗначение(ИмяДокумента + ".ПустаяСсылка");
		МассивПустыхСсылок.Добавить(ПустаяСсылка);		
	КонецЦикла;
	
#Если Не МобильныйАвтономныйСервер Тогда	
	Ссылки = ШтрихкодированиеПечатныхФорм.ПолучитьСсылкуПоШтрихкодуТабличногоДокумента(Штрихкод, МассивПустыхСсылок); 
#Иначе	
	Ссылки = МобильноеРабочееМестоКладовщика.ПолучитьСсылкуПоШтрихкодуТабличногоДокумента(Штрихкод, МассивПустыхСсылок); 
#КонецЕсли
	
	// Документ по штрихкоду в ИБ не найден
	Если Не ЗначениеЗаполнено(Ссылки) Тогда
		Возврат РезультатПоиска;
	КонецЕсли;	
	
	СсылкаНаДокумент = Ссылки[0]; 
				
	ЭтоРаспоряжение = МассивДокументов.Найти(ТипЗнч(СсылкаНаДокумент)) = Неопределено;

	// Общий поиск, без контекста распоряжения
	Если Не ЗначениеЗаполнено(КонтекстРаспоряжения) И Не ЭтоРаспоряжение Тогда 
				
		Если ТипЗнч(СсылкаНаДокумент) = Тип("ДокументСсылка.ОтборРазмещениеТоваров") Тогда	
#Если Не МобильныйАвтономныйСервер Тогда	
			ВидОперации = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(СсылкаНаДокумент, "ВидОперации"); 
#Иначе	
			ВидОперации = МобильноеРабочееМестоКладовщика.ЗначениеРеквизитаОбъекта(СсылкаНаДокумент, "ВидОперации");
#КонецЕсли
			Если ВидОперации = Перечисления.ВидыОперацийОтбораРазмещенияТоваров.Отбор Тогда
				РезультатПоиска.Направление = "Отгрузка";
			ИначеЕсли ВидОперации = Перечисления.ВидыОперацийОтбораРазмещенияТоваров.Размещение Тогда
				РезультатПоиска.Направление = "Приемка";
			Иначе
				РезультатПоиска.Направление = "Перемещение";
			КонецЕсли;
		Иначе
			ПроверитьСтатусПересчетаТоваров(СсылкаНаДокумент, РезультатПоиска);
		КонецЕсли;
		
		// Найден документ складской операции
		РезультатПоиска.ЭтоРаспоряжение = ЭтоРаспоряжение;
		РезультатПоиска.Ссылки.Добавить(СсылкаНаДокумент);
		Возврат РезультатПоиска;
		
	ИначеЕсли ЗначениеЗаполнено(КонтекстРаспоряжения) И Не ЭтоРаспоряжение Тогда 
		// Контексный поиск распоряжения, а найден документ складской операции
		Возврат РезультатПоиска;
	ИначеЕсли ЗначениеЗаполнено(КонтекстРаспоряжения) Тогда
		РезультатПоиска.Режим = "ВыборДокумента";
	КонецЕсли;
		
	ЭтоОтгрузка = МассивТиповОтгрузки.Найти(ТипЗнч(СсылкаНаДокумент)) <> Неопределено;
	ЭтоПриемка = МассивТиповПриемки.Найти(ТипЗнч(СсылкаНаДокумент)) <> Неопределено;
	
	// Контексный поиск распоряжения, а найдено распоряжение не по контексту и не двухсторонний документ
	Если Не (ЭтоОтгрузка И ЭтоПриемка)
		И ((ЭтоОтгрузка И КонтекстРаспоряжения = "Приемка")
		Или (ЭтоПриемка И КонтекстРаспоряжения = "Отгрузка")) Тогда
		 Возврат РезультатПоиска;
	КонецЕсли;
	 
	// Найден документ не складской операции и не распоряжение
	Если Не ЭтоОтгрузка И Не ЭтоПриемка Тогда
		Возврат РезультатПоиска;
	КонецЕсли;
		
	Если Не ЗначениеЗаполнено(КонтекстРаспоряжения) И Не (ЭтоОтгрузка И ЭтоПриемка) Тогда
		
		ОрдераПоРаспоряжениям = ОрдераПоРаспоряжениям(СсылкаНаДокумент, Справочники.Склады.ПустаяСсылка(), ЭтоОтгрузка, 
			ЭтоПриемка);
		Если ОрдераПоРаспоряжениям.СсылкиНаОрдера.Количество() Тогда  
			
			РезультатПоиска.Направление = ОрдераПоРаспоряжениям.НаправлениеОрдеров;
			РезультатПоиска.Распоряжение = СсылкаНаДокумент;
			РезультатПоиска.ЭтоРаспоряжение = Ложь;
			РезультатПоиска.Ссылки = ОрдераПоРаспоряжениям.СсылкиНаОрдера;
			Возврат РезультатПоиска;
		КонецЕсли;
		
	КонецЕсли;
	
#Если Не МобильныйАвтономныйСервер Тогда	
	// Общий поиск, без контекста распоряжения или контекст поиска приемки - проверка настроек договора закупки
	Если Не ЗначениеЗаполнено(КонтекстРаспоряжения) Или КонтекстРаспоряжения = "Приемка" Тогда
		
		МассивПоДоговоруЗакупки = Новый Массив;
		МассивПоДоговоруЗакупки.Добавить(Тип("ДокументСсылка.ЗаказПоставщику"));
		МассивПоДоговоруЗакупки.Добавить(Тип("ДокументСсылка.ПриемкаТоваровНаХранение"));
		МассивПоДоговоруЗакупки.Добавить(Тип("ДокументСсылка.ПриобретениеТоваровУслуг"));
		
		Индекс = МассивПоДоговоруЗакупки.Найти(ТипЗнч(СсылкаНаДокумент));
		Если Индекс <> Неопределено Тогда 
			Договор = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(СсылкаНаДокумент, "Договор");
			Если ЗначениеЗаполнено(Договор) Тогда
				ПриемкаТоваров = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Договор, "ВариантПриемкиТоваров"); 
				Если ЗначениеЗаполнено(ПриемкаТоваров) 
					И (ПриемкаТоваров = Перечисления.ВариантыПриемкиТоваров.ПоДоговорамПослеЗаказовИлиНакладных 
					Или ПриемкаТоваров = Перечисления.ВариантыПриемкиТоваров.ПоДоговорамПослеНакладных) Тогда
					
					// Поиск договора среди распоряжений
					ЗапросРаспоряжения = ЗапросРаспоряженияНаПриемку(Склад, ТекущаяДатаСеанса(), "Все", Ложь);
					ЗапросРаспоряжения.Текст = СтрЗаменить(ЗапросРаспоряжения.Текст, "ГДЕ &УсловиеПоРаспоряжениям", 
						"ГДЕ
						|	ТоварыКПоступлениюОстаткиНаДату.ДокументПоступления В (&СсылкиРаспоряжений)");	
					ЗапросРаспоряжения.УстановитьПараметр("СсылкиРаспоряжений", Договор); 
						
					ТаблицаРаспоряжений = ЗапросРаспоряжения.Выполнить().Выгрузить();
					Если ТаблицаРаспоряжений.Количество() Тогда
						РезультатПоиска.Ссылки = ОбщегоНазначения.ТаблицаЗначенийВМассив(ТаблицаРаспоряжений);
						РезультатПоиска.Направление = "Приемка";
					КонецЕсли;
					
					Возврат РезультатПоиска; 
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	// Для поиска распоряжения и ордеров по нему, необходимо указание склада
	Если Не ЗначениеЗаполнено(Склад) Тогда
		Возврат РезультатПоиска;
	КонецЕсли;
	
	ДокументыОтгрузки = Новый Массив;
	ДокументыПриемки = Новый Массив;
	
	Если ЭтоОтгрузка Тогда
		ДокументыОтгрузки.Добавить(СсылкаНаДокумент);
	КонецЕсли;
	
	 Если ЭтоПриемка Тогда
		ДокументыПриемки.Добавить(СсылкаНаДокумент);
	КонецЕсли;
	
	// Ордера не найдены, распоряжение - не договор, если это документ заказа - поиск накладных
	МассивДокументовЗаказов = МассивДокументовЗаказов();
	
	Индекс = МассивДокументовЗаказов.Найти(ТипЗнч(СсылкаНаДокумент));
	ЭтоДокументЗаказа = Индекс <> Неопределено;
	Если ЭтоДокументЗаказа Тогда
		
		ПодчиненныеДокументы = ПодчиненныеДокументы(СсылкаНаДокумент, МассивТиповОтгрузки, МассивТиповПриемки,
			ЭтоОтгрузка, ЭтоПриемка);
			
		ОбщегоНазначенияКлиентСервер.ДополнитьМассив(ДокументыОтгрузки, ПодчиненныеДокументы.ДокументыОтгрузки);
		ОбщегоНазначенияКлиентСервер.ДополнитьМассив(ДокументыПриемки, ПодчиненныеДокументы.ДокументыПриемки);
	Иначе
		// Документ - не заказ. Определение родительских документов, 
		// которые могут быть распоряжениями-заказами/основаниями
		РодительскиеДокументы = РодительскиеДокументы(СсылкаНаДокумент, МассивТиповОтгрузки, МассивТиповПриемки,
			ЭтоОтгрузка, ЭтоПриемка);
		
		ОбщегоНазначенияКлиентСервер.ДополнитьМассив(ДокументыОтгрузки, РодительскиеДокументы.ДокументыОтгрузки);
		ОбщегоНазначенияКлиентСервер.ДополнитьМассив(ДокументыПриемки, РодительскиеДокументы.ДокументыПриемки);
	КонецЕсли;
		
	МассивРаспоряжений = Новый Массив;
	
	ДатаОтгрузкиПриемки = ТекущаяДатаСеанса();
	
	// Опеределение распоряжения/распоряжений отгрузки
	Если ЭтоОтгрузка И (Не ЗначениеЗаполнено(КонтекстРаспоряжения) Или КонтекстРаспоряжения = "Отгрузка") Тогда 
		
		ЗапросРаспоряжения = ЗапросРаспоряженияНаОтгрузку(Склад);
		
		ЗапросРаспоряжения.УстановитьПараметр("Склад", 	Склад);
		ЗапросРаспоряжения.УстановитьПараметр("ДатаОтгрузки", ДатаОтгрузкиПриемки);
		ОформлятьСначалаНакладные = Константы.ПорядокОформленияНакладныхРасходныхОрдеров.Получить() 
			= Перечисления.ПорядокОформленияНакладныхРасходныхОрдеров.СначалаНакладные;
		ЗапросРаспоряжения.УстановитьПараметр("ОформлятьСначалаНакладные", ОформлятьСначалаНакладные);
		ЗапросРаспоряжения.УстановитьПараметр("ОтображениеДеталейОтгрузка", Ложь);
		
		Состояния = Новый Массив; 
		Для Каждого Значение Из Перечисления.СостоянияОтбораТоваров Цикл 
			Состояния.Добавить(Значение);
		КонецЦикла;
		ЗапросРаспоряжения.УстановитьПараметр("Состояния", Состояния);
		
		ЗапросРаспоряжения.Текст = СтрЗаменить(ЗапросРаспоряжения.Текст, "&УсловиеПоРаспоряжениям", "И РаспоряженияКОтгрузке.ДокументОтгрузки В (&СсылкиРаспоряжений)");	
		ЗапросРаспоряжения.УстановитьПараметр("СсылкиРаспоряжений", ДокументыОтгрузки);
		
		ТаблицаРаспоряжений = ЗапросРаспоряжения.Выполнить().Выгрузить(); 
		Если ТаблицаРаспоряжений.Количество() Тогда
			МассивРаспоряжений = ОбщегоНазначения.ТаблицаЗначенийВМассив(ТаблицаРаспоряжений);
			ЭтоОтгрузка = Истина;
			ЭтоПриемка = Ложь;
		КонецЕсли;
	КонецЕсли;
	
	// Опеределение распоряжения/распоряжений приемки
	Если ЭтоПриемка И (Не ЗначениеЗаполнено(КонтекстРаспоряжения) Или КонтекстРаспоряжения = "Приемка") Тогда
		
		ЗапросРаспоряжения = ЗапросРаспоряженияНаПриемку(Склад, ДатаОтгрузкиПриемки, "Все", Ложь);
		
		ЗапросРаспоряжения.Текст = СтрЗаменить(ЗапросРаспоряжения.Текст, "ГДЕ &УсловиеПоРаспоряжениям", 
			"ГДЕ
			|	ТоварыКПоступлениюОстаткиНаДату.ДокументПоступления В (&СсылкиРаспоряжений)");	
		ЗапросРаспоряжения.УстановитьПараметр("СсылкиРаспоряжений", ДокументыПриемки); 
		
		ТаблицаРаспоряжений = ЗапросРаспоряжения.Выполнить().Выгрузить();
		
		Если ТаблицаРаспоряжений.Количество() Тогда
			МассивРаспоряжений = ОбщегоНазначения.ТаблицаЗначенийВМассив(ТаблицаРаспоряжений);
			ЭтоОтгрузка = Ложь;
			ЭтоПриемка = Истина;
		КонецЕсли;	
	КонецЕсли;
			
	Распоряжение = СсылкаНаДокумент;
	
	// Итоговое определение направления
	Если ЭтоОтгрузка И ЭтоПриемка Тогда
		РезультатПоиска.Направление = "Двухстороний";
	ИначеЕсли ЭтоОтгрузка Тогда
		РезультатПоиска.Направление = "Отгрузка";
	ИначеЕсли ЭтоПриемка Тогда
		РезультатПоиска.Направление = "Приемка";
	КонецЕсли;

	Если МассивРаспоряжений.Количество() = 1 Тогда
		// Найдено одно распоряжение, возможем поиск ордеров
		Распоряжение = МассивРаспоряжений[0].Распоряжение;
	ИначеЕсли МассивРаспоряжений.Количество() > 1 Тогда 
		// Найдено несколько распоряжений
		РезультатПоиска.Ссылки = МассивРаспоряжений;
		Возврат РезультатПоиска;
	КонецЕсли;
	
	// Общий поиск, без контекста распоряжения - поиск ордеров
	Если Не ЗначениеЗаполнено(КонтекстРаспоряжения) Тогда  
		// Распоряжение может быть с двумя направлением ордеров
		ОрдераПоРаспоряжениям = ОрдераПоРаспоряжениям(Распоряжение, Склад, ЭтоОтгрузка, ЭтоПриемка);
		Если ОрдераПоРаспоряжениям.СсылкиНаОрдера.Количество() Тогда  
			
			РезультатПоиска.Направление = ОрдераПоРаспоряжениям.НаправлениеОрдеров;
			РезультатПоиска.Распоряжение = Распоряжение;
			РезультатПоиска.ЭтоРаспоряжение = Ложь;
			РезультатПоиска.Ссылки = ОрдераПоРаспоряжениям.СсылкиНаОрдера;
			Возврат РезультатПоиска;
		КонецЕсли;
	КонецЕсли;
	
	// Ничего не найдено
	РезультатПоиска.Ссылки = МассивРаспоряжений; 

#Иначе 
	
	ОрдераПоРаспоряжениям = ОрдераПоРаспоряжениям(СсылкаНаДокумент, Склад, ЭтоОтгрузка, ЭтоПриемка);
	Если ОрдераПоРаспоряжениям.СсылкиНаОрдера.Количество() Тогда  
			
		РезультатПоиска.Направление = ОрдераПоРаспоряжениям.НаправлениеОрдеров;
		РезультатПоиска.Распоряжение = СсылкаНаДокумент;
		РезультатПоиска.ЭтоРаспоряжение = Ложь;
		РезультатПоиска.Ссылки = ОрдераПоРаспоряжениям.СсылкиНаОрдера;
		Возврат РезультатПоиска;
	КонецЕсли;
	
#КонецЕсли
	Возврат РезультатПоиска;
		
КонецФункции  

// Производит поиск складского документа (ордера, отбора, пересчета и т.д.) по штрихкоду и возвращает данные о документе.
//
//	Параметры:
//		Штрихкод - Строка - отсканированный штрихкод.
//		ВидДокумента - Строка - строковое обозначения документа для поискаю.
//		
//	Возвращаемое значение:
//		Структура - Структура со свойствами:
//			* ЭтоРаспоряжение - Булево - признак того, что найденый документ является распоряжением.
//			* Ссылки - Массив Из ДокументСсылка - массив из ссылок на найденный документ(-ы).
//			* Распоряжение - Неопределено - ссылка на распоряжение, если найденны ордера.
//			* Направление - Строка - строкое описание направления найденного документа.
//			* Режим - Строка - строкое описание режима поиска документа.
//			* Штрихкод - Строка - штрихкод отсканированного документа.
//			* ТекстОшибки - Строка - текст ошибки поиска документа.
//
Функция ДанныеСкладскогоДокументаПоШК(Штрихкод, ВидДокумента) Экспорт
	
	РезультатПоиска = РезультатПоискаДокументаПоШК();
	РезультатПоиска.ЭтоРаспоряжение = Ложь;
	РезультатПоиска.Штрихкод = Штрихкод;

	МассивДокументов = Новый Массив;
	МассивДокументов.Добавить(Тип("ДокументСсылка.РасходныйОрдерНаТовары"));
	МассивДокументов.Добавить(Тип("ДокументСсылка.ПриходныйОрдерНаТовары"));
	МассивДокументов.Добавить(Тип("ДокументСсылка.ОтборРазмещениеТоваров"));
	МассивДокументов.Добавить(Тип("ДокументСсылка.ПересчетТоваров")); 
		
	МассивПустыхСсылок = Новый Массив;
	МассивПустыхСсылок.Добавить(Документы.РасходныйОрдерНаТовары.ПустаяСсылка());
	МассивПустыхСсылок.Добавить(Документы.ПриходныйОрдерНаТовары.ПустаяСсылка());
	МассивПустыхСсылок.Добавить(Документы.ОтборРазмещениеТоваров.ПустаяСсылка());
	МассивПустыхСсылок.Добавить(Документы.ПересчетТоваров.ПустаяСсылка()); 
		
#Если Не МобильныйАвтономныйСервер Тогда	
	Ссылки = ШтрихкодированиеПечатныхФорм.ПолучитьСсылкуПоШтрихкодуТабличногоДокумента(Штрихкод, МассивПустыхСсылок); 
#Иначе	
	Ссылки = МобильноеРабочееМестоКладовщика.ПолучитьСсылкуПоШтрихкодуТабличногоДокумента(Штрихкод, МассивПустыхСсылок); 
#КонецЕсли
	
	// Документ по штрихкоду в ИБ не найден
	Если Не ЗначениеЗаполнено(Ссылки) Тогда
		Возврат РезультатПоиска;
	КонецЕсли;	
	
	СсылкаНаДокумент = Ссылки[0];
	
	// Контекстный поиск на документы
	Если (ВидДокумента = "РасходныйОрдер" 
		И ТипЗнч(СсылкаНаДокумент) = Тип("ДокументСсылка.РасходныйОрдерНаТовары"))
		Или (ВидДокумента = "ПриходныйОрдер"  
		И ТипЗнч(СсылкаНаДокумент) = Тип("ДокументСсылка.ПриходныйОрдерНаТовары"))
		Или (ВидДокумента = "ПересчетТоваров"  
		И ТипЗнч(СсылкаНаДокумент) = Тип("ДокументСсылка.ПересчетТоваров")) Тогда 
		
		ПроверитьСтатусПересчетаТоваров(СсылкаНаДокумент, РезультатПоиска);
		
		РезультатПоиска.Ссылки = Ссылки;
		Возврат РезультатПоиска;
		
	ИначеЕсли (ВидДокумента = "ЗаданиеНаОтбор" Или ВидДокумента = "ЗаданиеНаРазмещение"
		Или ВидДокумента = "ЗаданиеНаПеремещение")
		И ТипЗнч(СсылкаНаДокумент) = Тип("ДокументСсылка.ОтборРазмещениеТоваров") Тогда
		
#Если Не МобильныйАвтономныйСервер Тогда	
		ВидОперации = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(СсылкаНаДокумент, "ВидОперации"); 
#Иначе	
		ВидОперации = МобильноеРабочееМестоКладовщика.ЗначениеРеквизитаОбъекта(СсылкаНаДокумент, "ВидОперации");
#КонецЕсли
		
		Если (ВидДокумента = "ЗаданиеНаОтбор" 
			И ВидОперации = Перечисления.ВидыОперацийОтбораРазмещенияТоваров.Отбор)
			Или (ВидДокумента = "ЗаданиеНаРазмещение" 
			И ВидОперации = Перечисления.ВидыОперацийОтбораРазмещенияТоваров.Размещение) 
			Или (ВидДокумента = "ЗаданиеНаПеремещение" 
			И ВидОперации = Перечисления.ВидыОперацийОтбораРазмещенияТоваров.Перемещение) Тогда
			
			РезультатПоиска.Ссылки = Ссылки;
			Возврат РезультатПоиска;
		КонецЕсли;
	КонецЕсли;
		
	Возврат РезультатПоиска;	
	
КонецФункции 

// Производит поиск заданий на отбор/размещений товаров по данным ордеров и возвращает данные о документах.
//
//	Параметры:
//		ДанныеПоиска - Структура - описанные параметров для поиска документа:
//		* Ссылка - ДокументСсылка.РасходныйОрдерНаТовары, Неопределено - ссылка на расходный ордер, если ищут отбор.
//		* Направление - Строка - строковое описание направления документа.
//		
//	Возвращаемое значение:
//		Структура - Структура со свойствами:
//			* ЭтоРаспоряжение - Булево - признак того, что найденый документ является распоряжением.
//			* Ссылки - Массив Из ДокументСсылка - массив из ссылок на найденный документ(-ы).
//			* Распоряжение - Неопределено - ссылка на распоряжение, если найденны ордера.
//			* Направление - Строка - строкое описание направления найденного документа.
//			* Режим - Строка - строкое описание режима поиска документа.
//			* Штрихкод - Строка - штрихкод отсканированного документа.
//			* ТекстОшибки - Строка - текст ошибки поиска документа.
//
Функция ДанныеЗаданийПоОрдеру(ДанныеПоиска) Экспорт
	
	РезультатПоиска = РезультатПоискаДокументаПоШК();
	РезультатПоиска.ЭтоРаспоряжение = Ложь;
	РезультатПоиска.Режим = "ВыборДокумента";
	РезультатПоиска.Направление = ДанныеПоиска.Направление;

	Запрос = Новый Запрос;
	
	Если ДанныеПоиска.Направление = "Приемка" Тогда 
		
		Запрос.Текст =
			"ВЫБРАТЬ РАЗРЕШЕННЫЕ 
			|	ОтборРазмещениеТоваров.Ссылка КАК Ссылка,
			|	ОтборРазмещениеТоваров.Номер КАК Номер,
			|	ОтборРазмещениеТоваров.Дата КАК Дата,
			|	ОтборРазмещениеТоваров.Статус КАК Статус,
			|	ВЫБОР
			|		КОГДА ОтборРазмещениеТоваров.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыОтборовРазмещенийТоваров.Подготовлено)
			|			ТОГДА 0
			|		КОГДА ОтборРазмещениеТоваров.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыОтборовРазмещенийТоваров.ВРаботе)
			|			ТОГДА 1
			|		ИНАЧЕ 2
			|	КОНЕЦ КАК СтатусЗадания,
			|	ОтборРазмещениеТоваров.Исполнитель КАК Исполнитель,
			|	СТРОКА(""Исполнитель"") КАК ИсполнительЗаголовок
			|ИЗ
			|	Документ.ОтборРазмещениеТоваров КАК ОтборРазмещениеТоваров
			|ГДЕ
			|	ОтборРазмещениеТоваров.Ссылка.Проведен
			|	И ОтборРазмещениеТоваров.Склад = &Склад
			|	И ОтборРазмещениеТоваров.Помещение = &Помещение
			|	И ОтборРазмещениеТоваров.ЗонаПриемки = &ЗонаПриемки
			|	И ОтборРазмещениеТоваров.Дата >= &Дата
			|	И ОтборРазмещениеТоваров.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийОтбораРазмещенияТоваров.Размещение)";
		
		Запрос.УстановитьПараметр("Склад", ДанныеПоиска.Склад);
		Запрос.УстановитьПараметр("Помещение", ДанныеПоиска.Помещение);
		Запрос.УстановитьПараметр("ЗонаПриемки", ДанныеПоиска.ЗонаПриемки);
		Запрос.УстановитьПараметр("Дата", ДанныеПоиска.ДатаОрдера);

	Иначе 
		
		Запрос.Текст =
			"ВЫБРАТЬ
			|	ОтборРазмещениеТоваров.Ссылка КАК Ссылка,
			|	ОтборРазмещениеТоваров.Номер КАК Номер,
			|	ОтборРазмещениеТоваров.Дата КАК Дата,
			|	ОтборРазмещениеТоваров.Статус КАК Статус,
			|	ВЫБОР
			|		КОГДА ОтборРазмещениеТоваров.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыОтборовРазмещенийТоваров.Подготовлено)
			|			ТОГДА 0
			|		КОГДА ОтборРазмещениеТоваров.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыОтборовРазмещенийТоваров.ВРаботе)
			|			ТОГДА 1
			|		ИНАЧЕ 2
			|	КОНЕЦ КАК СтатусЗадания,
			|	ОтборРазмещениеТоваров.Исполнитель КАК Исполнитель,
			|	СТРОКА(""Исполнитель"") КАК ИсполнительЗаголовок
			|ИЗ
			|	Документ.ОтборРазмещениеТоваров КАК ОтборРазмещениеТоваров
			|ГДЕ   
			|	ОтборРазмещениеТоваров.Ссылка.Проведен
			|	И ОтборРазмещениеТоваров.Распоряжение = &Ссылка";
		
		Запрос.УстановитьПараметр("Ссылка", ДанныеПоиска.Ссылка);
		
	КонецЕсли;
	
	РезультатЗапроса = Запрос.Выполнить().Выгрузить();
	
#Если Не МобильныйАвтономныйСервер Тогда	
	ЗаданияНаОтборРазмещения = ОбщегоНазначения.ТаблицаЗначенийВМассив(РезультатЗапроса); 
#Иначе	
	ЗаданияНаОтборРазмещения = МобильноеРабочееМестоКладовщика.ТаблицаЗначенийВМассив(РезультатЗапроса); 
#КонецЕсли 				

	РезультатПоиска.Ссылки = ЗаданияНаОтборРазмещения;
	Возврат РезультатПоиска;
	
КонецФункции

// Возвращает ссылку на Расходный/Приходный ордер(-а) на товары по переданному распоряжению(-ям).
//
//	Параметры:
//		РаспоряженияНаОтгрузкуПоступление - ОпределяемыйТип.РаспоряжениеНаПоступление - ссылка на распоряжение приемки;
//			- ОпределяемыйТип.РаспоряжениеНаОтгрузку - ссылка на распоряжение отгрузки;
//			- Массив Из ОпределяемыйТип.РаспоряжениеНаПоступление, ОпределяемыйТип.РаспоряжениеНаОтгрузку - массив ссылок на распоряжения.
//		Склад - СправочникСсылка.Склады - ссылка на склад, указанный в отборах. Может быть пустым.
//		ЭтоОтгрузка - Булево - признак поиска расходных ордеров. Не исключает значение Истина у ЭтоПриемка;
//		ЭтоПриемка - Булево - признак поиска приходных ордеров. Не исключает значение Истина у ЭтоОтгрузка;
//		
//	Возвращаемое значение:
//		Структура - структура с результатами поиска ордеров:
//			* СсылкиНаОрдера - Массив Из ДокументСсылка.РасходныйОрдерНаТовары, ДокументСсылка.ПриходныйОрдерНаТовары 
//				- массив из ссылов на ордера по распоряжению.
//			* НаправлениеОрдеров - Строка - строковое описание направления документа.
//
Функция ОрдераПоРаспоряжениям(РаспоряженияНаОтгрузкуПоступление, Склад, ЭтоОтгрузка = Ложь, ЭтоПриемка = Ложь) Экспорт
	
	СтруктураОрдеров = Новый Структура();
	СтруктураОрдеров.Вставить("СсылкиНаОрдера", Новый Массив);
	СтруктураОрдеров.Вставить("НаправлениеОрдеров", "");
	
	Если ТипЗнч(РаспоряженияНаОтгрузкуПоступление) <> Тип("Массив") Тогда
		Распоряжения = МобильноеРабочееМестоКладовщикаКлиентСервер.ЗначениеВМассиве(РаспоряженияНаОтгрузкуПоступление);
	Иначе
		Распоряжения = РаспоряженияНаОтгрузкуПоступление;
	КонецЕсли;
	
	ЭтоОрдерОтгрузка = Ложь;
	ЭтоОрдерПриемка = Ложь;
	
	МассивОрдеров = Новый Массив;
	
	Запрос = Новый Запрос;
	Если ЭтоОтгрузка Тогда
		Запрос.Текст = 
			"ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
			|	ТоварыПоРаспоряжениям.Ссылка КАК Ссылка
			|ИЗ
			|	Документ.РасходныйОрдерНаТовары.ТоварыПоРаспоряжениям КАК ТоварыПоРаспоряжениям
			|ГДЕ
			|	ТоварыПоРаспоряжениям.Распоряжение В(&Распоряжение)
			|	И ТоварыПоРаспоряжениям.Ссылка.Проведен
			|	И (ТоварыПоРаспоряжениям.Ссылка.Склад = &Склад
			|		ИЛИ &Склад = ЗНАЧЕНИЕ(Справочник.Склады.ПустаяСсылка))";
			
		Запрос.УстановитьПараметр("Распоряжение", Распоряжения);
		Запрос.УстановитьПараметр("Склад", Склад);
		
		РасходныеОрдера =  Запрос.Выполнить().Выгрузить();
		
		Если РасходныеОрдера.Количество() Тогда
			МассивОрдеров = РасходныеОрдера.ВыгрузитьКолонку("Ссылка");
			ЭтоОрдерОтгрузка = Истина;
		КонецЕсли;
	КонецЕсли;
	
	Если ЭтоПриемка Тогда
		Запрос.Текст =
			"ВЫБРАТЬ РАЗРЕШЕННЫЕ
			|	ПриходныйОрдерНаТовары.Ссылка КАК Ссылка
			|ИЗ
			|	Документ.ПриходныйОрдерНаТовары КАК ПриходныйОрдерНаТовары
			|ГДЕ
			|	ПриходныйОрдерНаТовары.Распоряжение В(&Распоряжение)
			|	И ПриходныйОрдерНаТовары.Ссылка.Проведен
			|	И (ПриходныйОрдерНаТовары.Склад = &Склад 
			|		ИЛИ &Склад = ЗНАЧЕНИЕ(Справочник.Склады.ПустаяСсылка))"; 
		
		Запрос.УстановитьПараметр("Распоряжение", Распоряжения);
		Запрос.УстановитьПараметр("Склад", Склад);

		ПриходныеОрдера = Запрос.Выполнить().Выгрузить(); 
		
		Если ПриходныеОрдера.Количество() Тогда
			МассивПриходныхОрдеров = ПриходныеОрдера.ВыгрузитьКолонку("Ссылка");
			МобильноеРабочееМестоКладовщика.ДополнитьМассив(МассивОрдеров, МассивПриходныхОрдеров);
			ЭтоОрдерПриемка = Истина;
		КонецЕсли;
	КонецЕсли;
	
	Если ЭтоОрдерОтгрузка И ЭтоОрдерПриемка  Тогда
		СтруктураОрдеров.НаправлениеОрдеров = "Двухстороний"; 
	ИначеЕсли ЭтоОрдерОтгрузка Тогда
		СтруктураОрдеров.НаправлениеОрдеров = "Отгрузка";
	ИначеЕсли ЭтоОрдерПриемка Тогда
		СтруктураОрдеров.НаправлениеОрдеров = "Приемка";
	КонецЕсли; 
	
	СтруктураОрдеров.СсылкиНаОрдера = МассивОрдеров;
	
	Возврат СтруктураОрдеров;
		
КонецФункции
	
// Возвращает структуру, которая затем обрабатывается функциями поиска документа по штрихкоду.
//
//	Возвращаемое значение:
//		Структура - Структура со свойствами:
//			* ЭтоРаспоряжение - Булево - признак того, что найденый документ является распоряжением.
//			* Ссылки - Массив Из ДокументСсылка - массив из ссылок на найденный документ(-ы).
//			* Распоряжение - Неопределено - ссылка на распоряжение, если найденны ордера.
//			* Направление - Строка - строкое описание направления найденного документа.
//			* Режим - Строка - строкое описание режима поиска документа.
//			* Штрихкод - Строка - штрихкод отсканированного документа.
//			* ТекстОшибки - Строка - текст ошибки поиска документа.
//
Функция РезультатПоискаДокументаПоШК() Экспорт
	
	СтруктураДокумента = Новый Структура;
	СтруктураДокумента.Вставить("ЭтоРаспоряжение", Истина);
	СтруктураДокумента.Вставить("Ссылки", Новый Массив);
	СтруктураДокумента.Вставить("Распоряжение", Неопределено);
	СтруктураДокумента.Вставить("Направление", "");
	СтруктураДокумента.Вставить("Режим", "");
	СтруктураДокумента.Вставить("Штрихкод", "");
	СтруктураДокумента.Вставить("ТекстОшибки", "");
	
	Возврат СтруктураДокумента;

КонецФункции

// Возвращает структуру, которая затем обрабатывается процедурами создания Задания на размещение товаров.
//
//	Возвращаемое значение:
//		Структура - Структура со свойствами:
//			* Склад - СправочникСсылка.Склады - склад создаваемого документа.
//			* Помещение - СправочникСсылка.СкладскиеПомещения - помещение создаваемого документа.
//			* Исполнитель - СправочникСсылка.Пользователи - пользователь, ответственный за Задание на размещение товаров.
//			* ЗонаПриемки - СправочникСсылка.СкладскиеЯчейки - зона приемки создаваемого документа.
//			* ТаблицаНоменклатуры - ТаблицаЗначений.
//			* ОграничиватьПоОбъему - Булево - признак ограчения создаваемого размещения по объему.
//			* ОграничиватьПоВесу - Булево - признак ограчения создаваемого размещения по весу.
//			* ОграничениеПоОбъему - Число - числовое ограничение по объему.
//			* ОграничениеПоВесу - Число - числовое ограничение по весу.
//			* ПоВсейНоменклатуре - Булево - признак создания задания по всей номенклатуре.
//
Функция ПараметрыСозданияРазмещенияТоваров() Экспорт
	
	ПараметрыРазмещения = Новый Структура;
	ПараметрыРазмещения.Вставить("Склад", Справочники.Склады.ПустаяСсылка());
	ПараметрыРазмещения.Вставить("Помещение", Справочники.СкладскиеПомещения.ПустаяСсылка()); 
	ПараметрыРазмещения.Вставить("Исполнитель", Справочники.Пользователи.ПустаяСсылка());
	ПараметрыРазмещения.Вставить("ЗонаПриемки", Справочники.СкладскиеЯчейки.ПустаяСсылка());
	ПараметрыРазмещения.Вставить("ТаблицаНоменклатуры", Новый ТаблицаЗначений);
	ПараметрыРазмещения.Вставить("ОграничиватьПоОбъему", Ложь);
	ПараметрыРазмещения.Вставить("ОграничиватьПоВесу", Ложь);
	ПараметрыРазмещения.Вставить("ОграничениеПоОбъему", 0);
	ПараметрыРазмещения.Вставить("ОграничениеПоВесу", 0);
	ПараметрыРазмещения.Вставить("ПоВсейНоменклатуре", Ложь);
	
	Возврат ПараметрыРазмещения;

КонецФункции

Функция СвойстваСклада(Склад) Экспорт
	
	СвойстваСклада = Новый Структура;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	Склады.ИспользоватьАдресноеХранение КАК ИспользоватьАдресноеХранение,
		|	Склады.ИспользоватьОрдернуюСхемуПриПоступлении КАК ИспользоватьОрдернуюСхемуПриПоступлении,
		|	Склады.ИспользоватьСкладскиеПомещения КАК ИспользоватьСкладскиеПомещения,
		|	Склады.ИспользоватьСтатусыРасходныхОрдеров КАК ИспользоватьСтатусыРасходныхОрдеров,
		|	Склады.ДатаНачалаИспользованияСкладскихПомещений КАК ДатаНачалаИспользованияСкладскихПомещений
		|ИЗ
		|	Справочник.Склады КАК Склады
		|ГДЕ
		|	Склады.Ссылка = &Склад";
	
	Запрос.УстановитьПараметр("Склад", Склад);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		СвойстваСклада.Вставить("ИспользоватьАдресноеХранение", ВыборкаДетальныеЗаписи.ИспользоватьАдресноеХранение);
		СвойстваСклада.Вставить("ИспользоватьОрдернуюСхемуПриПоступлении", ВыборкаДетальныеЗаписи.ИспользоватьОрдернуюСхемуПриПоступлении);
		СвойстваСклада.Вставить("ИспользоватьСкладскиеПомещения", ВыборкаДетальныеЗаписи.ИспользоватьСкладскиеПомещения);
		СвойстваСклада.Вставить("ИспользоватьСтатусыРасходныхОрдеров", ВыборкаДетальныеЗаписи.ИспользоватьСтатусыРасходныхОрдеров); 
		СвойстваСклада.Вставить("ДатаНачалаИспользованияСкладскихПомещений", ВыборкаДетальныеЗаписи.ДатаНачалаИспользованияСкладскихПомещений);
	КонецЦикла;
	
	Возврат СвойстваСклада;
	
КонецФункции

// Возвращает массив с данными о найденной номенклатуре по штрихкоду.
//
//	Параметры:
//		Штрихкод - Строка - штрихкод отсканированной номенклатуры.
//		
//	Возвращаемое значение:
//		Массив Из Структура - массив с результатами поиска товара:
//			* Номенклатура -  СправочникСсылка.Номенклатура -ссылка на найденную номенклатуру;
//			* Характеристика - СправочникСсылка.ХарактеристикиНоменклатуры -ссылка на характеристику номенклатуры;
//			* Серия - СправочникСсылка.СерииНоменклатуры -ссылка на серию номенклатуры;
//			* Количество - Число - количество номенклатуры по умолчанию. Всегда 1.
//			* ШтрихкодУпаковки - Строка - штрихкоды упаковок номенклатуры;
//			* Упаковка - СправочникСсылка.УпаковкиЕдиницыИзмерения -ссылка на упаковку номенклатуры;
//
Функция ДанныеТоваровПоШК(Штрихкод) Экспорт

	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ШтрихкодыНоменклатуры.Номенклатура КАК Номенклатура,
	|	ШтрихкодыНоменклатуры.Характеристика КАК Характеристика,
	|	ШтрихкодыНоменклатуры.Серия	КАК Серия,
	|	1 КАК Количество, 
	|	СТРОКА("""") КАК ШтрихкодУпаковки,
	|	ВЫБОР
	|		КОГДА ШтрихкодыНоменклатуры.Упаковка = ЗНАЧЕНИЕ(Справочник.УпаковкиЕдиницыИзмерения.ПустаяСсылка)
	|			ТОГДА ШтрихкодыНоменклатуры.Номенклатура.ЕдиницаИзмерения
	|		ИНАЧЕ ШтрихкодыНоменклатуры.Упаковка
	|	КОНЕЦ КАК Упаковка
	|ИЗ
	|	РегистрСведений.ШтрихкодыНоменклатуры КАК ШтрихкодыНоменклатуры
	|ГДЕ
	|	ШтрихкодыНоменклатуры.Штрихкод = &Штрихкод";
	
	Запрос.УстановитьПараметр("Штрихкод", Штрихкод);
	
	РезультатЗапроса = Запрос.Выполнить().Выгрузить(); 
	
	Если РезультатЗапроса.Количество() Тогда
#Если Не МобильныйАвтономныйСервер Тогда
		Возврат ОбщегоНазначения.ТаблицаЗначенийВМассив(РезультатЗапроса); 
#Иначе
		Возврат МобильноеРабочееМестоКладовщика.ТаблицаЗначенийВМассив(РезультатЗапроса); 
#КонецЕсли 	
	КонецЕсли;
	
	Если Не ПолучитьФункциональнуюОпцию("ИспользоватьСерииНоменклатурыСклад") Тогда
#Если Не МобильныйАвтономныйСервер Тогда
		Возврат ОбщегоНазначения.ТаблицаЗначенийВМассив(РезультатЗапроса); 
#Иначе
		Возврат МобильноеРабочееМестоКладовщика.ТаблицаЗначенийВМассив(РезультатЗапроса); 
#КонецЕсли 	
	КонецЕсли;
	
#Если Не МобильныйАвтономныйСервер Тогда
	ИнформацияОСерии = ШтрихкодированиеНоменклатурыСервер.ИнформацияОСерииИзШтрихкода(Штрихкод, Истина, Истина, Ложь);
	
	Если ИнформацияОСерии.ЕстьОшибка Тогда
		Возврат ОбщегоНазначения.ТаблицаЗначенийВМассив(РезультатЗапроса);
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ДвиженияСерийТоваров.Номенклатура КАК Номенклатура,
	|	ДвиженияСерийТоваров.Характеристика	КАК Характеристика,
	|	ДвиженияСерийТоваров.Номенклатура.ЕдиницаИзмерения КАК Упаковка,
	|	1 КАК Количество, 
	|	СТРОКА("""") КАК ШтрихкодУпаковки,
	|	ДвиженияСерийТоваров.Серия КАК Серия
	|ИЗ
	|	РегистрНакопления.ДвиженияСерийТоваров КАК ДвиженияСерийТоваров
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.СерииНоменклатуры КАК СерииНоменклатуры
	|		ПО ДвиженияСерийТоваров.Серия = СерииНоменклатуры.Ссылка
 	|		И СерииНоменклатуры.Номер = &НомерСерии
	|		И СерииНоменклатуры.ГоденДо = &ГоденДо";

	Запрос.УстановитьПараметр("НомерСерии", ИнформацияОСерии.Номер);
	Запрос.УстановитьПараметр("ГоденДо", ИнформацияОСерии.ГоденДо);
	
	УстановитьПривилегированныйРежим(Истина);
	РезультатЗапроса = Запрос.Выполнить().Выгрузить();
	УстановитьПривилегированныйРежим(Ложь);
	
	Возврат ОбщегоНазначения.ТаблицаЗначенийВМассив(РезультатЗапроса);
#Иначе
	Возврат МобильноеРабочееМестоКладовщика.ТаблицаЗначенийВМассив(РезультатЗапроса); 
#КонецЕсли 	
	
КонецФункции

// Возвращает массив с данными о найденной номенклатуре по штрихкоду.
//
//	Параметры:
//		Штрихкод - Строка - штрихкод отсканированной серии.
//		ВладелецСерий - СправочникСсылка.ВидыНоменклатуры - ссылка на вид номенклатуры.
//		
//	Возвращаемое значение:
//		Структура - Структура со свойствами:
//			* ГоденДо - Дата - срок годности серии.
//			* ДатаПроизводства - Дата - дата производства серии.
//			* Количество - Число - количество найденной серии.
//			* Номер - Число - номер серии в справочнике.
//			* Серия - СправочникСсылка.СерииНоменклатуры - ссылка на серию номенклатуры.
//
Функция ПолучитьПараметрыСерииПоШК(Штрихкод, ВладелецСерий) Экспорт 

#Если Не МобильныйАвтономныйСервер Тогда
		НастройкиИспользованияСерий = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ВладелецСерий, "ИспользоватьНомерСерии, ИспользоватьСрокГодностиСерии");
#Иначе
		НастройкиИспользованияСерий = МобильноеРабочееМестоКладовщика.ЗначенияРеквизитовОбъекта(ВладелецСерий, "ИспользоватьНомерСерии, ИспользоватьСрокГодностиСерии");
#КонецЕсли
	
	ПараметрыСерии = ПараметрыСерии();
#Если Не МобильныйАвтономныйСервер Тогда
	ИнформацияОСерии = ШтрихкодированиеНоменклатурыСервер.ИнформацияОСерииИзШтрихкода(Штрихкод, 
		НастройкиИспользованияСерий.ИспользоватьНомерСерии, НастройкиИспользованияСерий.ИспользоватьСрокГодностиСерии);
#Иначе
	ИнформацияОСерии = МобильноеРабочееМестоКладовщика.ИнформацияОСерииИзШтрихкода(Штрихкод, 
		НастройкиИспользованияСерий.ИспользоватьНомерСерии, НастройкиИспользованияСерий.ИспользоватьСрокГодностиСерии);
#КонецЕсли
		
	Если ИнформацияОСерии.ЕстьОшибка Тогда
		Возврат ПараметрыСерии;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ЕСТЬNULL(СерииНоменклатуры.Ссылка, ЗНАЧЕНИЕ(Справочник.СерииНоменклатуры.ПустаяСсылка)) КАК Серия,
	|	ЕСТЬNULL(СерииНоменклатуры.ГоденДо, &ГоденДо) КАК ГоденДо,
	|	ЕСТЬNULL(СерииНоменклатуры.ДатаПроизводства, ДАТАВРЕМЯ(1, 1, 1, 0, 0, 0)) КАК ДатаПроизводства
	|ИЗ
	|	Справочник.СерииНоменклатуры КАК СерииНоменклатуры
	|ГДЕ
	|	СерииНоменклатуры.Номер = &НомерСерии
	|	И СерииНоменклатуры.ГоденДо = &ГоденДо
	|	И СерииНоменклатуры.ВидНоменклатуры = &ВидНоменклатуры";
	
	Запрос.УстановитьПараметр("НомерСерии", ИнформацияОСерии.Номер);
	Запрос.УстановитьПараметр("ГоденДо", ИнформацияОСерии.ГоденДо);
	Запрос.УстановитьПараметр("ВидНоменклатуры", ВладелецСерий);

	РезультатЗапроса = Запрос.Выполнить();
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
		
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		ЗаполнитьЗначенияСвойств(ПараметрыСерии, ВыборкаДетальныеЗаписи);
	КонецЦикла;
	
	Возврат ПараметрыСерии;

КонецФункции

Функция ПолучитьВидНоменклатуры(Номенклатура) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	Номенклатура.ВидНоменклатуры КАК ВидНоменклатуры
		|ИЗ
		|	Справочник.Номенклатура КАК Номенклатура
		|ГДЕ
		|	Номенклатура.Ссылка = &Ссылка";
	
	Запрос.УстановитьПараметр("Ссылка", Номенклатура);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		Возврат ВыборкаДетальныеЗаписи.ВидНоменклатуры;
	КонецЦикла;
	
	Возврат Справочники.ВидыНоменклатуры.ПустаяСсылка();
	
КонецФункции

Функция ПолучитьРеквизитСправочника(Ссылка, ИмяРеквизита) Экспорт
	
	Возврат Ссылка[ИмяРеквизита];
	
КонецФункции

// Возвращает структуру с данными о найденной ячейке по штрихкоду.
//
//	Параметры:
//		Склад - СправочникСсылка.Склады - ссылка на склад ячейки.
//		Помещение - СправочникСсылка.СкладскиеПомещения - ссылка на помещение ячейки.
//		Штрихкод - Строка - штрихкод отсканированной ячейки.
//
//	Возвращаемое значение:
//		Структура - структура с данными ячейки:
//			* Штрихкод - Строка - штрихкод отсканированной ячейки.
//			* Ячейка - СправочникСсылка.СкладскиеЯчейки -ссылка на найденную ячейку.
//			* КодВозврата - Число - числовое обозначение результата поиска.
//			* ТипЯчейки - ПеречислениеСсылка.ТипыСкладскихЯчеек -тип ячейки.
//			* КодЯчейки - Строка - строковый код ячейки в справочнике.
//			* ШтрихкодЯчейки - Строка - штрихкод отсканированной ячейки.
//
Функция ДанныеЯчейкиПоШК(Склад, Помещение, Штрихкод) Экспорт
	
	СтруктураЯчейки = НайтиЯчейкуПоКоду(Склад, Помещение, Штрихкод);
	
	Если ЗначениеЗаполнено(СтруктураЯчейки.Ячейка) Тогда
		СтруктураЯчейки.Вставить("Штрихкод", Штрихкод);
		Возврат СтруктураЯчейки;
	КонецЕсли;
	
#Если Не МобильныйАвтономныйСервер Тогда
	СтруктураЯчейки = РабочееМестоРаботникаСкладаПрограммныйИнтерфейс.НайтиЯчейкуПоШтрихкоду(Склад,
	Помещение, Штрихкод, Истина);
#Иначе
	СтруктураЯчейки = МобильноеРабочееМестоКладовщика.НайтиЯчейкуПоШтрихкоду(Склад,
	Помещение, Штрихкод, Истина);
#КонецЕсли
	
	Если СтруктураЯчейки.КодВозврата = 0 Тогда
		СтруктураЯчейки.Вставить("Ячейка", Справочники.СкладскиеЯчейки.ПустаяСсылка());
	Иначе
#Если Не МобильныйАвтономныйСервер Тогда
		ЯчейкаСкладПомещение = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(СтруктураЯчейки.Ячейка, "Владелец, Помещение");
#Иначе
		ЯчейкаСкладПомещение = МобильноеРабочееМестоКладовщика.ЗначенияРеквизитовОбъекта(СтруктураЯчейки.Ячейка, "Владелец, Помещение");
#КонецЕсли
		Если Не (Склад = ЯчейкаСкладПомещение.Владелец И Помещение = ЯчейкаСкладПомещение.Помещение) Тогда 
			СтруктураЯчейки.Вставить("Ячейка", Справочники.СкладскиеЯчейки.ПустаяСсылка());
		КонецЕсли;
	КонецЕсли;
	
	СтруктураЯчейки.Вставить("Штрихкод", Штрихкод);
	
	Возврат СтруктураЯчейки;
	
КонецФункции

