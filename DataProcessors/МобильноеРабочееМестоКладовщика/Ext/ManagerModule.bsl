Функция НайтиЯчейкуПоКоду(Склад, Помещение, Штрихкод)
	
	СтруктураЯчейки = Новый Структура;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	СкладскиеЯчейки.Ссылка КАК Ячейка
		|ИЗ
		|	Справочник.СкладскиеЯчейки КАК СкладскиеЯчейки
		|ГДЕ
		|	СкладскиеЯчейки.Код = &Код
		|	И СкладскиеЯчейки.Владелец = &Склад
		|	И СкладскиеЯчейки.Помещение = &Помещение";
	
	Запрос.УстановитьПараметр("Код", Штрихкод);
	Запрос.УстановитьПараметр("Помещение", Помещение);
	Запрос.УстановитьПараметр("Склад", Склад);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Если РезультатЗапроса.Пустой() Тогда
		
		СтруктураЯчейки.Вставить("Ячейка", Справочники.СкладскиеЯчейки.ПустаяСсылка());
		Возврат СтруктураЯчейки;
		
	КонецЕсли;
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		
		СтруктураЯчейки.Вставить("Ячейка", ВыборкаДетальныеЗаписи.Ячейка);
		Возврат СтруктураЯчейки;
		
	КонецЦикла;
	
КонецФункции

#Если Не МобильныйАвтономныйСервер Тогда
Функция РазбитьСтрокиПоОграничениям(РазмещениеТоваровВЯчейках, МаксимальныйОбъем, МаксимальныйВес)

	ТаблицаРезультата = РазмещениеТоваровВЯчейках.СкопироватьКолонки();
	СтрокиСПересчетомКоличества = Новый Массив;

	Для Каждого ОписаниеРазмещения Из РазмещениеТоваровВЯчейках Цикл

		ОсталосьРазместить = ОписаниеРазмещения.КоличествоУпаковок;

		МаксимальноеКоличествоПоОбъему = МаксимальноеКоличествоПоОграничению(
			ОписаниеРазмещения.ОбъемУпаковки,
			МаксимальныйОбъем,
			ОсталосьРазместить);

		МаксимальноеКоличествоПоВесу = МаксимальноеКоличествоПоОграничению(
			ОписаниеРазмещения.ВесУпаковки,
			МаксимальныйВес,
			ОсталосьРазместить);

		МаксимальноеКоличествоРазмещения = Мин(МаксимальноеКоличествоПоОбъему, МаксимальноеКоличествоПоВесу);
		ПересчитыватьКоличество = МаксимальноеКоличествоРазмещения < ОсталосьРазместить;
		
		Пока ОсталосьРазместить <> 0 Цикл

			СтрокаРазмещения = ТаблицаРезультата.Добавить();
			ЗаполнитьЗначенияСвойств(СтрокаРазмещения, ОписаниеРазмещения);

			Если ОсталосьРазместить > МаксимальноеКоличествоРазмещения Тогда
				РазмещаемоеКоличествоУпаковок = МаксимальноеКоличествоРазмещения;
			Иначе
				РазмещаемоеКоличествоУпаковок = ОсталосьРазместить;
			КонецЕсли;

			СтрокаРазмещения.КоличествоУпаковок = РазмещаемоеКоличествоУпаковок;

			ОсталосьРазместить = ОсталосьРазместить - РазмещаемоеКоличествоУпаковок;
			
			Если ПересчитыватьКоличество Тогда
				СтрокиСПересчетомКоличества.Добавить(СтрокаРазмещения);
			КонецЕсли;
			
		КонецЦикла;

	КонецЦикла;

	СтруктураДействий = Новый Структура;
	СтруктураДействий.Вставить("ПересчитатьКоличествоЕдиниц");
	ПакетнаяОбработкаТабличнойЧастиСервер.ОбработатьСтрокиТЧ(СтрокиСПересчетомКоличества, СтруктураДействий,
		ТаблицаРезультата);

	Возврат ТаблицаРезультата;

КонецФункции  

Функция МаксимальноеКоличествоПоОграничению(Значение, Ограничение, ЗначениеПоУмолчанию)
	
	Если Значение = 0 Тогда
		Возврат ЗначениеПоУмолчанию;
	КонецЕсли;
	
	Возврат Цел(Ограничение / Значение);
	
КонецФункции

Процедура ЗаписатьДокумент(ДокументОбъект, Объем, Вес, ОшибкаПроверки) 
	
	Попытка
		ПараметрыУказанияСерий = НоменклатураСервер.ПараметрыУказанияСерий(ДокументОбъект, Документы.ОтборРазмещениеТоваров);
		НоменклатураСервер.ЗаполнитьСтатусыУказанияСерий(ДокументОбъект,ПараметрыУказанияСерий.Размещение);
		ДокументОбъект.Записать(РежимЗаписиДокумента.Проведение);
		
	Исключение
		ОшибкаПроверки = ИнформацияОбОшибке().Описание;
	КонецПопытки; 
	
КонецПроцедуры
