// Создает новый документ Расходный ордер на товары.
//
//	Параметры:
//		СтруктураЗаполнения - Структура - см. СтруктураЗаполненияРасходногоОрдера().
//		
//	Возвращаемое значение:
//		Структура - структура со следующими ключами:
//		*Ссылка - ДокументСсылка.РасходныйОрдерНаТовары, Неопределено- ссылка на Расходный ордер на товары.
//		*ЕстьОшибка - Булево - признак ошибки.
//
Функция НовыйРасходныйОрдер(СтруктураЗаполнения) Экспорт
	
	Получатели = Новый Соответствие;
	РаспоряжениеНаОтгрузку = СтруктураЗаполнения.РаспоряженияНаОтгрузку[0];
	
	СтруктураПараметровСозданияРасходныхОрдеров = СкладыСервер.ПараметрыПереоформленияРасходныхОрдеров();
	СтруктураПараметровСозданияРасходныхОрдеров.Склад = СтруктураЗаполнения.Склад;
	СтруктураПараметровСозданияРасходныхОрдеров.Помещение = СтруктураЗаполнения.Помещение;
	
	СтруктураПараметровСозданияРасходныхОрдеров.ЗонаОтгрузки = Справочники.СкладскиеЯчейки.ЗонаОтгрузкиПоУмолчанию(
		СтруктураЗаполнения.Склад, СтруктураЗаполнения.Помещение);
	
	МассивРаспоряжений = Новый Массив;
	Получатели.Вставить(СтруктураЗаполнения.Получатель, МассивРаспоряжений);
	МассивРаспоряжений.Добавить(РаспоряжениеНаОтгрузку);
	
	Если Получатели.Количество() > 0 Тогда
		
		СтруктураПараметровСозданияРасходныхОрдеров.ЗаданиеНаПеревозку = Неопределено;
		
		Для Каждого Получатель Из Получатели Цикл
			СтруктураПараметровСозданияРасходныхОрдеров.Получатель = Получатель.Ключ;
			СтруктураПараметровСозданияРасходныхОрдеров.РаспоряженияНаОтгрузку = Получатель.Значение;
			СтруктураВыполнения = СкладыСервер.ПереоформитьРасходныеОрдера(СтруктураПараметровСозданияРасходныхОрдеров);
		КонецЦикла;
	Иначе
		СтруктураВыполнения = Новый Структура("ЕстьОшибка", Ложь);
	КонецЕсли;
	
	Ссылка = СсылкаНаРасходныйОрдер(РаспоряжениеНаОтгрузку);
	СтруктураВыполнения.Вставить("Ссылка", Ссылка);
	СтруктураВыполнения.Вставить("ТребуетсяУказаниеСерии", Ложь);
	СтруктураВыполнения.Удалить("ОформленныеОрдера");
	Если Не ЗначениеЗаполнено(Ссылка) Тогда
		Возврат СтруктураВыполнения;
	КонецЕсли;

	ДокументОбъект = Ссылка.ПолучитьОбъект();
	Если ДокументОбъект.Статус = Перечисления.СтатусыРасходныхОрдеров.Подготовлен 
		Или ДокументОбъект.Статус = Перечисления.СтатусыРасходныхОрдеров.КОтбору Тогда
			
		ТребуетсяУказаниеСерии = ПроверитьСтатусУказанияСерийПриПланированииОтбора(Ссылка, СтруктураЗаполнения.Склад);
		Если ТребуетсяУказаниеСерии Тогда
			СтруктураВыполнения.Вставить("ТребуетсяУказаниеСерии", Истина);
		КонецЕсли;
		
		ДокументОбъект.Статус = Перечисления.СтатусыРасходныхОрдеров.КОтбору;
		ДокументОбъект.Записать(РежимЗаписиДокумента.Проведение);
	КонецЕсли;
	
	Возврат СтруктураВыполнения;
	
КонецФункции 

// Возвращает ссылку на Расходный ордер на товары по переданному распоряжению.
//
//	Параметры:
//		РаспоряжениеНаОтгрузку - ОпределяемыйТип.РаспоряжениеНаОтгрузку - ссылка на распоряжение.
//		
//	Возвращаемое значение:
//		ДокументСсылка.РасходныйОрдерНаТовары - ссылка на Расходный ордер на товары.
//
Функция СсылкаНаРасходныйОрдер(РаспоряжениеНаОтгрузку) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
		|	ТоварыПоРаспоряжениям.Ссылка КАК Ссылка
		|ИЗ
		|	Документ.РасходныйОрдерНаТовары.ТоварыПоРаспоряжениям КАК ТоварыПоРаспоряжениям
		|ГДЕ
		|	ТоварыПоРаспоряжениям.Распоряжение = &Распоряжение
		|	И ТоварыПоРаспоряжениям.Ссылка.Проведен
		|
		|УПОРЯДОЧИТЬ ПО
		|	ТоварыПоРаспоряжениям.Ссылка.Ссылка УБЫВ";
	
	Запрос.УстановитьПараметр("Распоряжение", РаспоряжениеНаОтгрузку);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Если ВыборкаДетальныеЗаписи.Следующий() Тогда
		Возврат ВыборкаДетальныеЗаписи.Ссылка;
	КонецЕсли;
	
	Возврат Неопределено;
	
КонецФункции

// Создает новый документ Задание на отбор товаров.
//
//	Параметры:
//		РасходныйОрдер - ДокументСсылка.РасходныйОрдерНаТовары - ссылка на расходный ордер,
//			по которому необходимо создать отбор.
//		
//	Возвращаемое значение:
//		ДокументСсылка.ОтборРазмещениеТоваров - ссылка на созданный документ Отбор, размещение товаров.
//
Функция НовыйОтборТоваров(РасходныйОрдер) Экспорт
	
	ОтборОбъект = Документы.ОтборРазмещениеТоваров.СоздатьДокумент();
	ОтборОбъект.Заполнить(РасходныйОрдер);
	ОтборОбъект.Дата = ТекущаяДатаСеанса();
	ОтборОбъект.Исполнитель = Пользователи.ТекущийПользователь();
	
	УсловиеОтбораСтрок = Новый Структура;
	УсловиеОтбораСтрок.Вставить("Ячейка", Справочники.СкладскиеЯчейки.ПустаяСсылка());
	НайденныеСтроки = ОтборОбъект.ТоварыОтбор.НайтиСтроки(УсловиеОтбораСтрок);
	Для Каждого СтрокаУдалить Из НайденныеСтроки Цикл
		ОтборОбъект.ТоварыОтбор.Удалить(СтрокаУдалить);
	КонецЦикла;
		
	Если ОтборОбъект.ТоварыОтбор.Количество() > 0 Тогда
		Попытка
			ОтборОбъект.Записать(РежимЗаписиДокумента.Проведение);
			Возврат ОтборОбъект.Ссылка;
		Исключение
			Возврат Документы.ОтборРазмещениеТоваров.ПустаяСсылка();
		КонецПопытки;
	Иначе
		Возврат Документы.ОтборРазмещениеТоваров.ПустаяСсылка();
	КонецЕсли;
	
КонецФункции

// Создает новый документ Задание на размещенение товаров.
//
//	Параметры:
//		ПараметрыРазмещенияТоваров - Структура - см. ПараметрыСозданияРазмещенияТоваров().
//		
//	Возвращаемое значение:
//		ДокументСсылка.ОтборРазмещениеТоваров - ссылка на созданный документ Отбор, размещение товаров.
//
Функция НовоеРазмещениеТоваров(ПараметрыРазмещенияТоваров) Экспорт
	
	СтруктураВозврата = Новый Структура("Ссылка, ТекстОшибкиПроверки", Неопределено, "");
	
	Менеджер = Новый МенеджерВременныхТаблиц;
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = Менеджер;
	
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Таблица.Номенклатура КАК Номенклатура,
	|	Таблица.Характеристика КАК Характеристика,
	|	Таблица.Назначение КАК Назначение,
	|	Таблица.Серия КАК Серия,
	|	Таблица.КоличествоУпаковок КАК КоличествоУпаковок,
	|	Таблица.Упаковка КАК Упаковка
	|ПОМЕСТИТЬ ТаблицаНоменклатурыДляЗапроса
	|ИЗ
	|	&ТаблицаНоменклатуры КАК Таблица
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТоварыВЯчейкахОстатки.Номенклатура КАК Номенклатура,
	|	ТоварыВЯчейкахОстатки.Характеристика КАК Характеристика,
	|	ТоварыВЯчейкахОстатки.Назначение КАК Назначение,
	|	ТоварыВЯчейкахОстатки.Серия,
	|	ТоварыВЯчейкахОстатки.Упаковка КАК Упаковка,
	|	ВЫБОР
	|		КОГДА ТоварыВЯчейкахОстатки.Номенклатура.ЕдиницаИзмерения.ТипИзмеряемойВеличины = ЗНАЧЕНИЕ(Перечисление.ТипыИзмеряемыхВеличин.КоличествоШтук)
	|			ТОГДА ВЫРАЗИТЬ(ТоварыВЯчейкахОстатки.ВНаличииОстаток - ТоварыВЯчейкахОстатки.КОтборуОстаток - 0.5 КАК ЧИСЛО(15, 0))
	|		ИНАЧЕ ТоварыВЯчейкахОстатки.ВНаличииОстаток - ТоварыВЯчейкахОстатки.КОтборуОстаток
	|	КОНЕЦ КАК КоличествоУпаковок
	|ПОМЕСТИТЬ ТоварыВЯчейкахОстаткиНоменклатуры
	|ИЗ
	|	РегистрНакопления.ТоварыВЯчейках.Остатки(
	|			,
	|			(&ПоВсейНоменклатуре
	|				ИЛИ (Номенклатура, Характеристика, Серия, Назначение, Упаковка) В
	|					(ВЫБРАТЬ
	|						Таблица.Номенклатура КАК Номенклатура,
	|						Таблица.Характеристика КАК Характеристика,
	|						Таблица.Серия КАК Серия,
	|				        Таблица.Назначение КАК Назначение,
	|				        Таблица.Упаковка КАК Упаковка
	|					ИЗ
	|						ТаблицаНоменклатурыДляЗапроса КАК Таблица))
	|				И Ячейка = &ЗоныПриемки) КАК ТоварыВЯчейкахОстатки
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ВидыНоменклатуры.ПолитикиУчетаСерий КАК ПолитикиУчетСерий
	|		ПО ТоварыВЯчейкахОстатки.Номенклатура.ВидНоменклатуры = ПолитикиУчетСерий.Ссылка
	|			И (ПолитикиУчетСерий.Склад = &Склад)
	|ГДЕ
	|	ТоварыВЯчейкахОстатки.ВНаличииОстаток - ТоварыВЯчейкахОстатки.КОтборуОстаток > 0
	|; 
	|////////////////////////////////////////////////////////////////////////////////
	|
	|ВЫБРАТЬ
	|	ВложенныйЗапрос.Номенклатура КАК Номенклатура,
	|	ВложенныйЗапрос.Характеристика КАК Характеристика,
	|	ВложенныйЗапрос.Назначение КАК Назначение,
	|	ВложенныйЗапрос.Серия,
	|	ВложенныйЗапрос.Упаковка КАК Упаковка,
	|	МИНИМУМ(ВложенныйЗапрос.КоличествоУпаковок) КАК КоличествоУпаковок
	|ПОМЕСТИТЬ ТаблицаНоменклатуры
	|ИЗ
	|	(ВЫБРАТЬ
	|		ТаблицаНоменклатуры.Номенклатура КАК Номенклатура,
	|		ТаблицаНоменклатуры.Характеристика КАК Характеристика,
	|		ТаблицаНоменклатуры.Назначение КАК Назначение,
	|		ТаблицаНоменклатуры.Серия КАК Серия,
	| 		ТаблицаНоменклатуры.Упаковка КАК Упаковка,
	|		ТаблицаНоменклатуры.КоличествоУпаковок КАК КоличествоУпаковок
	|	ИЗ
	|		ТаблицаНоменклатурыДляЗапроса КАК  ТаблицаНоменклатуры
	|
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ
	|		ТоварыВЯчейкахОстатки.Номенклатура,
	|		ТоварыВЯчейкахОстатки.Характеристика,
	|		ТоварыВЯчейкахОстатки.Назначение,
	|		ТоварыВЯчейкахОстатки.Серия,
	|		ТоварыВЯчейкахОстатки.Упаковка,
	|		ТоварыВЯчейкахОстатки.КоличествоУпаковок 
	|	ИЗ
	|		ТоварыВЯчейкахОстаткиНоменклатуры КАК  ТоварыВЯчейкахОстатки) КАК ВложенныйЗапрос 
	|
	|СГРУППИРОВАТЬ ПО 
	|	ВложенныйЗапрос.Серия,
	|	ВложенныйЗапрос.Номенклатура,
	|	ВложенныйЗапрос.Характеристика,
	|	ВложенныйЗапрос.Упаковка,
	|	ВложенныйЗапрос.Назначение
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ ТаблицаНоменклатурыДляЗапроса";

	Запрос.УстановитьПараметр("ЗоныПриемки", ПараметрыРазмещенияТоваров.ЗонаПриемки);
	Запрос.УстановитьПараметр("Склад", ПараметрыРазмещенияТоваров.Склад);
	Запрос.УстановитьПараметр("ТаблицаНоменклатуры", ПараметрыРазмещенияТоваров.ТаблицаНоменклатуры);
	Запрос.УстановитьПараметр("ПоВсейНоменклатуре", ПараметрыРазмещенияТоваров.ПоВсейНоменклатуре);
	
	Результаты = Запрос.ВыполнитьПакет(); 
	
	Выборка = Результаты[2].Выбрать();
	Выборка.Следующий();
	
	Если Выборка.Количество = 0 Тогда
		ТекстСообщения = НСтр("ru = 'Задания на размещение не сформированы: все товары или уже размещены, или по ним уже есть задания на размещение.'");
		СтруктураВозврата.ТекстОшибкиПроверки = ТекстСообщения;
		Возврат СтруктураВозврата;
	КонецЕсли;
	
	ОшибкаПроверки = Ложь;
	
	РезультатРазмещения = СкладыСервер.РазместитьТоварВЯчейках(Менеджер, ПараметрыРазмещенияТоваров.Склад, ПараметрыРазмещенияТоваров.Помещение,
		Справочники.РабочиеУчастки.ПустаяСсылка(), ПараметрыРазмещенияТоваров.ЗонаПриемки, ОшибкаПроверки, Ложь);
	
	Если ОшибкаПроверки Тогда
		Возврат СтруктураВозврата;
	КонецЕсли;
	
	Если РезультатРазмещения.ТаблицаРезультатов.Количество() = 0 Тогда
		ТекстСообщения = НСтр("ru = 'Задания на размещение не сформированы: не удалось разместить номенклатуру согласно правилам размещения.'");
		СтруктураВозврата.ТекстОшибкиПроверки = ТекстСообщения;
		Возврат СтруктураВозврата;
	КонецЕсли;
	
	ТаблицаРабочихУчастков = Новый ТаблицаЗначений;
	ТаблицаРабочихУчастков.Колонки.Добавить("РабочийУчасток", Новый ОписаниеТипов("СправочникСсылка.РабочиеУчастки"));
	НоваяСтрока = ТаблицаРабочихУчастков.Добавить();
	НоваяСтрока.РабочийУчасток = Справочники.РабочиеУчастки.ПустаяСсылка();
	
	НевозможныйНабор = 9999999999;

	МаксимальныйОбъем = ?(ПараметрыРазмещенияТоваров.ОграничиватьПоОбъему, ПараметрыРазмещенияТоваров.ОграничениеПоОбъему, НевозможныйНабор);
	МаксимальныйВес = ?(ПараметрыРазмещенияТоваров.ОграничиватьПоВесу, ПараметрыРазмещенияТоваров.ОграничениеПоВесу, НевозможныйНабор);

	ТаблицаРезультата = РазбитьСтрокиПоОграничениям(РезультатРазмещения.ТаблицаРезультатов, МаксимальныйОбъем,
		МаксимальныйВес);

	Для Каждого СтрокаРабочийУчасток Из ТаблицаРабочихУчастков Цикл
		
		// Разбиение по весу и объему. Соглашения:
		//	- в одну ячейку идет один человек (т.е. строка результата размещения не разбивается)
		//  - если вес (объем) одной строки больше, чем ограничения - создается отдельный документ,
		//		вес (объем) которого будет больше, чем максимальный
		//	- разбиение по весу (объему) не оптимально, т.к. более приоритетно сохранения порядка обхода
		//			(лучше пусть будет больше заданий, но каждое можно быстрее обойти).
		
		ОбъемДокумента    = 0;
		ВесДокумента	  = 0;
		
		ТекущийДокумент =  Документы.ОтборРазмещениеТоваров.СоздатьДокумент();
		ТекущийДокумент.Дата 				= ТекущаяДатаСеанса();
		ТекущийДокумент.Статус 				= Перечисления.СтатусыОтборовРазмещенийТоваров.Подготовлено;
		ТекущийДокумент.ВидОперации 		= Перечисления.ВидыОперацийОтбораРазмещенияТоваров.Размещение;
		ТекущийДокумент.Склад 				= ПараметрыРазмещенияТоваров.Склад;
		ТекущийДокумент.Помещение 			= ПараметрыРазмещенияТоваров.Помещение;
		ТекущийДокумент.ЗонаПриемки		 	= ПараметрыРазмещенияТоваров.ЗонаПриемки;
		ТекущийДокумент.Ответственный 		= Пользователи.ТекущийПользователь();		
		ТекущийДокумент.РабочийУчасток 		= СтрокаРабочийУчасток.РабочийУчасток;		
		ТекущийДокумент.Исполнитель         = ПараметрыРазмещенияТоваров.Исполнитель;
		
		ТаблицаЗаполнения = ТаблицаРезультата.СкопироватьКолонки();
		
		КоличествоОбработано = 0;
		
		Для Каждого СтрТабл Из ТаблицаРезультата Цикл

			Если (ОбъемДокумента + СтрТабл.ОбъемУпаковки * СтрТабл.КоличествоУпаковок) > МаксимальныйОбъем
				Или (ВесДокумента + СтрТабл.ВесУпаковки * СтрТабл.КоличествоУпаковок) > МаксимальныйВес Тогда

				СкладыСервер.ДополнитьМногооборотнойТаройТаблицуРазмещения(ТаблицаЗаполнения);
				ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(ТаблицаЗаполнения, ТекущийДокумент.ТоварыРазмещение);
				
				ЗаписатьДокумент(ТекущийДокумент, ОбъемДокумента, ВесДокумента, СтруктураВозврата.ОшибкаПроверки); 			
				
				ОбъемДокумента    = 0;
				ВесДокумента	  = 0; 
				
				ТекущийДокумент = Документы.ОтборРазмещениеТоваров.СоздатьДокумент();
				ТекущийДокумент.Дата 				= ТекущаяДатаСеанса();
				ТекущийДокумент.Статус 				= Перечисления.СтатусыОтборовРазмещенийТоваров.Подготовлено;
				ТекущийДокумент.ВидОперации 		= Перечисления.ВидыОперацийОтбораРазмещенияТоваров.Размещение;
				ТекущийДокумент.Склад 				= ПараметрыРазмещенияТоваров.Склад;
				ТекущийДокумент.Помещение 			= ПараметрыРазмещенияТоваров.Помещение;
				ТекущийДокумент.ЗонаПриемки		 	= ПараметрыРазмещенияТоваров.ЗонаПриемки;
				ТекущийДокумент.Ответственный 		= Пользователи.ТекущийПользователь();		
				ТекущийДокумент.РабочийУчасток 		= СтрокаРабочийУчасток.РабочийУчасток;		
				ТекущийДокумент.Исполнитель         = ПараметрыРазмещенияТоваров.Исполнитель;

				ТаблицаЗаполнения.Очистить();

			КонецЕсли;

			НоваяСтрока = ТаблицаЗаполнения.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрТабл);

			ОбъемДокумента    = ОбъемДокумента + СтрТабл.ОбъемУпаковки * СтрТабл.КоличествоУпаковок;
			ВесДокумента	  = ВесДокумента + СтрТабл.ВесУпаковки * СтрТабл.КоличествоУпаковок;
			КоличествоОбработано = КоличествоОбработано + 1;

		КонецЦикла;
		
		Если ТаблицаЗаполнения.Количество() > 0 Тогда
			
			СкладыСервер.ДополнитьМногооборотнойТаройТаблицуРазмещения(ТаблицаЗаполнения);
			ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(ТаблицаЗаполнения, ТекущийДокумент.ТоварыРазмещение);
			
			ОшибкаПроверки = "";
			ЗаписатьДокумент(ТекущийДокумент, ОбъемДокумента, ВесДокумента, ОшибкаПроверки);
			
			ШаблонОшибки = ?(ЗначениеЗаполнено(СтруктураВозврата.ТекстОшибкиПроверки), НСтр("ru = '
				|%1'"),  НСтр("ru = '%1'")); 
			
			СтруктураВозврата.ТекстОшибкиПроверки = СтруктураВозврата.ТекстОшибкиПроверки + СтрШаблон(ШаблонОшибки, 
				ОшибкаПроверки);
			
		КонецЕсли;
		
	КонецЦикла;
	
	СтруктураВозврата.Ссылка = ТекущийДокумент.Ссылка;
	
	Возврат СтруктураВозврата;
		
КонецФункции

#КонецЕсли

// Устанавливает переданный статус расходного ордера.
//
//	Параметры:
//		Ссылка - ДокументСсылка.РасходныйОрдерНаТовары - ссылка на расходный ордер.
//		Статус - ПеречислениеСсылка.СтатусыРасходныхОрдеров - статус расходного ордера, который необходимо установить.
//		Блокировать - Булево - признак необходимости блокировки расходного ордера перед записью. Истина по умолчанию.
//		
//	Возвращаемое значение:
//		Булево - Истина, если статус расходного ордера успешно установлен.
//
Функция УстановитьСтатусОрдера(Ссылка, Статус, Блокировать = Истина) Экспорт
	
	ШаблонОшибкиЗаблокировать = НСтр("ru='Не удалось заблокировать %1. %2'");
	ШаблонОшибкиЗаписать      = НСтр("ru='Не удалось записать %1. %2'");

	Если Блокировать Тогда
		// Захват объекта для редактирования
		Попытка
			ЗаблокироватьДанныеДляРедактирования(Ссылка);
		Исключение
			ТекстОшибки = СтрШаблон(ШаблонОшибкиЗаблокировать, Ссылка,
				ОбработкаОшибок.КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));
				
			ОбщегоНазначения.СообщитьПользователю(ТекстОшибки, Ссылка);
			Возврат Ложь;
		КонецПопытки;
	КонецЕсли;
	
	НачатьТранзакцию();
	Попытка
	
		ДокументОбъект = Ссылка.ПолучитьОбъект();
		
		ДокументОбъект.Статус = Статус;
#Если Не МобильныйАвтономныйСервер Тогда
		Пользователь = Пользователи.ТекущийПользователь();
#Иначе
		Пользователь = МобильноеРабочееМестоКладовщика.ТекущийПользователь();
#КонецЕсли

		Если Статус = Перечисления.СтатусыРасходныхОрдеров.КОтбору Тогда 
			ДокументОбъект.Ответственный = Пользователь;
		ИначеЕсли Статус = Перечисления.СтатусыРасходныхОрдеров.ВПроцессеПроверки Тогда
			ДокументОбъект.Контролер = Пользователь; 
		ИначеЕсли Статус = Перечисления.СтатусыРасходныхОрдеров.КОтгрузке 
			Или Статус = Перечисления.СтатусыРасходныхОрдеров.Отгружен Тогда
			ДокументОбъект.Отгрузил = Пользователь;
		ИначеЕсли Статус = Перечисления.СтатусыРасходныхОрдеров.КПроверке Тогда
			ДокументОбъект.Контролер = Неопределено;
		ИначеЕсли Статус = Перечисления.СтатусыРасходныхОрдеров.Проверен Тогда
			ДокументОбъект.Отгрузил = Неопределено;
		КонецЕсли;
		
#Если Не МобильныйАвтономныйСервер Тогда
		ЗаписьСПроведением = Истина;
#Иначе	
		ЗаписьСПроведением = Ложь;
#КонецЕсли

		Если ЗаписьСПроведением Тогда
			ДокументОбъект.Записать(РежимЗаписиДокумента.Проведение);
		Иначе
			ДокументОбъект.Записать(РежимЗаписиДокумента.Запись);
		КонецЕсли;

		ЗафиксироватьТранзакцию();
	Исключение 
		ОтменитьТранзакцию();
		
		ТекстОшибки = СтрШаблон(ШаблонОшибкиЗаписать, Ссылка, 
			ОбработкаОшибок.КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));
			
		ОбщегоНазначения.СообщитьПользователю(ТекстОшибки, Ссылка);
		Возврат Ложь;
	КонецПопытки;
	
	Возврат Истина;
	
КонецФункции

