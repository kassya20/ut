Процедура ПроверитьСтатусПересчетаТоваров(СсылкаНаДокумент, СтруктураДокумента)
	
	Если ТипЗнч(СсылкаНаДокумент) = Тип("ДокументСсылка.ПересчетТоваров") Тогда 
#Если Не МобильныйАвтономныйСервер Тогда	
		Статус = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(СсылкаНаДокумент, "Статус");
#Иначе	
		Статус = МобильноеРабочееМестоКладовщика.ЗначениеРеквизитаОбъекта(СсылкаНаДокумент, "Статус"); 
#КонецЕсли
		Если Не Статус = Перечисления.СтатусыПересчетовТоваров.ВнесениеРезультатов Тогда
			ТекстОшибки = СтрШаблон(НСтр("ru = 'Пересчет товаров имеет статус ""%1"". Внесение результатов невозможно.'"),
				Статус);
			СтруктураДокумента.ТекстОшибки = ТекстОшибки;
		КонецЕсли;
	КонецЕсли;

КонецПроцедуры

Функция РодительскиеДокументы(СсылкаНаДокумент, МассивТиповОтгрузки, МассивТиповПриемки, ЭтоОтгрузка, ЭтоПриемка)
	
	ДокументыОтгрузки = Новый Массив;
	ДокументыПриемки = Новый Массив;
	
	ПредставлениеТипа = ОбщегоНазначения.СтроковоеПредставлениеТипа(ТипЗнч(СсылкаНаДокумент));
	СписокРеквизитов = МобильноеРабочееМестоКладовщикаПовтИсп.СвязанныеРеквизиты(ПредставлениеТипа);
	
	Для Каждого Реквизит Из СписокРеквизитов.СвязанныеРеквизитыШапки Цикл
		
		ЗначениеРеквизита = СсылкаНаДокумент[Реквизит.Имя];
		
		ТипРеквизита = ТипЗнч(ЗначениеРеквизита);

		Если Не ЗначениеЗаполнено(ЗначениеРеквизита) Или ЗначениеРеквизита = СсылкаНаДокумент Тогда
			Продолжить;
		КонецЕсли;
		
		ЭтоДокументОтгрузки = МассивТиповОтгрузки.Найти(ТипРеквизита) <> Неопределено;
		ЭтоДокументПриемки = МассивТиповПриемки.Найти(ТипРеквизита) <> Неопределено;

		Если (ЭтоОтгрузка И ЭтоДокументОтгрузки) 
			И ДокументыОтгрузки.Найти(ЗначениеРеквизита) = Неопределено Тогда
			ДокументыОтгрузки.Добавить(ЗначениеРеквизита);
		КонецЕсли;
		
		Если (ЭтоПриемка И ЭтоДокументПриемки)
			И ДокументыПриемки.Найти(ЗначениеРеквизита) = Неопределено Тогда
			ДокументыПриемки.Добавить(ЗначениеРеквизита);
		КонецЕсли;
	КонецЦикла; 
	
	МетаданныеОбъекта = СсылкаНаДокумент.Метаданные(); 
	
	Для Каждого ТабличнаяЧасть Из МетаданныеОбъекта.ТабличныеЧасти Цикл // ОбъектМетаданныхТабличнаяЧасть
		
		ИменаРеквизитов = СписокРеквизитов[ТабличнаяЧасть.Имя];
		СодержимоеТЧ = СсылкаНаДокумент[ТабличнаяЧасть.Имя].Выгрузить(); // ТаблицаЗначений
		
		СодержимоеТЧ.Свернуть(ИменаРеквизитов);
		Для Каждого КолонкаТЧ Из СодержимоеТЧ.Колонки Цикл
			Для Каждого СтрокаТЧ Из СодержимоеТЧ Цикл
			
				ЗначениеРеквизита = СтрокаТЧ[КолонкаТЧ.Имя];
				ТипРеквизита = ТипЗнч(ЗначениеРеквизита);
				МетаданныеРеквизита = МетаданныеТипаРеквизита(ТипРеквизита);
					
				Если МетаданныеРеквизита = Неопределено Тогда
					Продолжить;
				КонецЕсли;
				
				Если Не ЗначениеЗаполнено(ЗначениеРеквизита) Или ЗначениеРеквизита = СсылкаНаДокумент Тогда
					Продолжить;
				КонецЕсли;
				
				ЭтоДокументОтгрузки = МассивТиповОтгрузки.Найти(ТипРеквизита) <> Неопределено;
				ЭтоДокументПриемки = МассивТиповПриемки.Найти(ТипРеквизита) <> Неопределено;

				Если (ЭтоОтгрузка И ЭтоДокументОтгрузки) 
					И ДокументыОтгрузки.Найти(ЗначениеРеквизита) = Неопределено Тогда
					ДокументыОтгрузки.Добавить(ЗначениеРеквизита);
				КонецЕсли;
				
				Если (ЭтоПриемка И ЭтоДокументПриемки)
					И ДокументыПриемки.Найти(ЗначениеРеквизита) = Неопределено Тогда
					ДокументыПриемки.Добавить(ЗначениеРеквизита);
				КонецЕсли;
			КонецЦикла;
		КонецЦикла;
	КонецЦикла;
   
	РодительскиеДокументы = Новый Структура;
	РодительскиеДокументы.Вставить("ДокументыОтгрузки", ДокументыОтгрузки);
	РодительскиеДокументы.Вставить("ДокументыПриемки", ДокументыПриемки);
	
	Возврат РодительскиеДокументы;
	
КонецФункции

Функция ПодчиненныеДокументы(СсылкаНаДокумент, МассивТиповОтгрузки, МассивТиповПриемки, ЭтоОтгрузка, ЭтоПриемка)
	
	ДокументыОтгрузки = Новый Массив;
	ДокументыПриемки = Новый Массив;
	
	ПредставлениеТипа = ОбщегоНазначения.СтроковоеПредставлениеТипа(ТипЗнч(СсылкаНаДокумент));
	ТекстЗапроса = МобильноеРабочееМестоКладовщикаПовтИсп.ТекстЗапросаСвязанныхДокументов(ПредставлениеТипа); 
	
	ПодчиненныеДокументы = Новый Структура;
	ПодчиненныеДокументы.Вставить("ДокументыОтгрузки", ДокументыОтгрузки);
	ПодчиненныеДокументы.Вставить("ДокументыПриемки", ДокументыПриемки);

	Если ТекстЗапроса = Неопределено Тогда 
		Возврат ПодчиненныеДокументы;
	КонецЕсли;
		
	Запрос = Новый Запрос;
	Запрос.Текст = ТекстЗапроса;
	Запрос.УстановитьПараметр("СсылкаНаДокумент", СсылкаНаДокумент);
	
	ТаблицаСвязанных = Запрос.Выполнить().Выгрузить();
	Если ТаблицаСвязанных = Неопределено Тогда
		Возврат ПодчиненныеДокументы;
	КонецЕсли;
	
	Для Каждого СтрокаТаблицы Из ТаблицаСвязанных Цикл

		ТекущаяСсылка = СтрокаТаблицы.Ссылка; // ДокументСсылка
		
		Если ТекущаяСсылка = СсылкаНаДокумент Тогда
			Продолжить;
		КонецЕсли;
		
		ТипДокумента = ТипЗнч(ТекущаяСсылка);
		
		ЭтоДокументОтгрузки = МассивТиповОтгрузки.Найти(ТипДокумента) <> Неопределено;
		ЭтоДокументПриемки = МассивТиповПриемки.Найти(ТипДокумента) <> Неопределено;

		Если (ЭтоОтгрузка И ЭтоДокументОтгрузки) 
			И ДокументыОтгрузки.Найти(ТекущаяСсылка) = Неопределено Тогда
			ДокументыОтгрузки.Добавить(ТекущаяСсылка);
		КонецЕсли;
		
		Если (ЭтоПриемка И ЭтоДокументПриемки)
			И ДокументыПриемки.Найти(ТекущаяСсылка) = Неопределено Тогда
			ДокументыПриемки.Добавить(ТекущаяСсылка);
		КонецЕсли;
		
	КонецЦикла;
	
	ПодчиненныеДокументы.ДокументыОтгрузки = ДокументыОтгрузки;
	ПодчиненныеДокументы.ДокументыПриемки = ДокументыПриемки;

	Возврат ПодчиненныеДокументы;

КонецФункции

Функция МетаданныеТипаРеквизита(ТипРеквизита)
		
	Результат = Неопределено; 
	
	МетаданныеРеквизита = Метаданные.НайтиПоТипу(ТипРеквизита);
		
	Если МетаданныеРеквизита = Неопределено Тогда
		Возврат Результат;
	КонецЕсли;

	Если Не ОбщегоНазначения.ОбъектМетаданныхДоступенПоФункциональнымОпциям(МетаданныеРеквизита) 
		Или Не ПравоДоступа("Чтение", МетаданныеРеквизита) 
		Или Не ОбщегоНазначения.ЭтоДокумент(МетаданныеРеквизита) Тогда
		Возврат Результат;
	КонецЕсли;
			
	Результат = МетаданныеРеквизита;
	Возврат Результат;

КонецФункции

