// Формирует список пользователей, доступных для выбора.
//
//	Параметры:
//		ИсключаемыеПользователи - СписокЗначений - список пользователей, которых нужно изключить из списка выбора.
//		
//	Возвращаемое значение:
//		Булево - Массив - список выбора пользователей.
//
Функция ПолучитьСписокПользователей(ИсключаемыеПользователи = Неопределено) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	Пользователи.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.Пользователи КАК Пользователи
		|ГДЕ
		|	НЕ Пользователи.Служебный";
	
	Если ЗначениеЗаполнено(ИсключаемыеПользователи) Тогда
		Запрос.Текст = Запрос.Текст + "
		|	И НЕ (Пользователи.Ссылка В(&Список))";
		Запрос.УстановитьПараметр("Список", ИсключаемыеПользователи);
	КонецЕсли;
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Возврат РезультатЗапроса.Выгрузить().ВыгрузитьКолонку("Ссылка");

КонецФункции

