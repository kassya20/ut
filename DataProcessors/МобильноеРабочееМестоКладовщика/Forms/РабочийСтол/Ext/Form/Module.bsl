КонецПроцедуры

&НаСервере
Процедура КомандаОбновитьФормуСервер(КодУзла)
	
	ОбновитьСчетчикиСервер();
	ПолучитьРеквизитыАвтономногоУзла(КодУзла);
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьСчетчикиСервер()
	
	Если Элементы.Разделы.ТекущаяСтраница = Элементы.РазделПриемка Тогда
		СчетчикиРазделПриемка();
	ИначеЕсли Элементы.Разделы.ТекущаяСтраница = Элементы.РазделОтгрузка Тогда
		СчетчикиРазделОтгрузка();
	ИначеЕсли Элементы.Разделы.ТекущаяСтраница = Элементы.РазделПрочиеОперации Тогда
		СчетчикиРазделПрочиеОперации();
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура СформироватьПредставленияОтборов()

	СформироватьПредставлениеОтбораСклад();
	СформироватьПредставлениеОтбораПомещение();
	
КонецПроцедуры

&НаСервере
Процедура СформироватьПредставлениеОтбораСклад()
	
	ИспользоватьСкладскиеПомещения = Ложь;
	ИспользоватьСтатусыРасходныхОрдеров = Ложь;
		
	ПредставленияОтборов = "";
	Если ЗначениеЗаполнено(Склад) Тогда
		ПредставленияОтборов = Склад;
		Элементы.КомандаОтборыОткрыть.ЦветТекста = WebЦвета.Черный;
		Элементы.КомандаОтборыОчистить.Видимость = Истина;
		Элементы.РамкаОтборыОткрыть.Картинка = БиблиотекаКартинок.РамкаМенюЧерная;
		
		СвойстваСклада = Обработки.МобильноеРабочееМестоКладовщика.СвойстваСклада(Склад);
		Если ЗначениеЗаполнено(СвойстваСклада) Тогда
			ИспользоватьАдресноеХранение = СвойстваСклада.ИспользоватьАдресноеХранение;
			ИспользоватьСкладскиеПомещения = СвойстваСклада.ИспользоватьСкладскиеПомещения;
			ИспользоватьСтатусыРасходныхОрдеров = СвойстваСклада.ИспользоватьСтатусыРасходныхОрдеров;
		КонецЕсли;
	Иначе
		ПредставленияОтборов = НСтр("ru = 'Выбрать склад'");

		Элементы.КомандаОтборыОткрыть.ЦветТекста = WebЦвета.ТемноСерый;
		Элементы.КомандаОтборыОчистить.Видимость = Ложь;
		Элементы.РамкаОтборыОткрыть.Картинка = БиблиотекаКартинок.РамкаМенюСерая;  
	КонецЕсли;
			
	Элементы.ГруппаКомандаОтборыОткрыть2.Видимость    = ИспользоватьСкладскиеПомещения;
	Элементы.КомандаОтборыОчиститьПомещение.Видимость = ИспользоватьСкладскиеПомещения;
	
	Элементы.КомандаОтборыОткрыть.Заголовок = ПредставленияОтборов;
	
КонецПроцедуры

&НаСервере
Процедура СформироватьПредставлениеОтбораПомещение()
	
	ПредставленияОтборов = "";
	Если ЗначениеЗаполнено(Помещение) Тогда
		ПредставленияОтборов = Помещение;
		Элементы.КомандаОтборыОткрытьПомещение.ЦветТекста = WebЦвета.Черный;
		Элементы.КомандаОтборыОчиститьПомещение.Видимость = Истина;
		Элементы.РамкаОтборыОткрыть2.Картинка = БиблиотекаКартинок.РамкаМенюЧерная; 

		ИспользоватьАдресноеХранение = Помещение["ИспользоватьАдресноеХранение"];
	Иначе
		ПредставленияОтборов = НСтр("ru = 'Выбрать помещение'");

		Элементы.КомандаОтборыОткрытьПомещение.ЦветТекста = WebЦвета.ТемноСерый;
		Элементы.КомандаОтборыОчиститьПомещение.Видимость = Ложь;
		Элементы.РамкаОтборыОткрыть2.Картинка = БиблиотекаКартинок.РамкаМенюСерая;
	КонецЕсли;
	
	Элементы.КомандаОтборыОткрытьПомещение.Заголовок = ПредставленияОтборов;
	
КонецПроцедуры

&НаКлиенте
Процедура ПерейтиВРаздел(ЭлементМеню)
	
	// Изменение иконки меню
	Элементы.ПриемкаМеню.Картинка        = БиблиотекаКартинок.МРМКладовщикаПриемка;
	Элементы.ОтгрузкаМеню.Картинка       = БиблиотекаКартинок.МРМКладовщикаОтгрузкаСерая;
	Элементы.ПрочиеОперацииМеню.Картинка = БиблиотекаКартинок.МРМКладовщикаПрочиеОперации;
	Элементы.СканированиеМеню.Картинка   = БиблиотекаКартинок.МРМКладовщикаСканирование;
	Элементы.НастройкиМеню.Картинка      = БиблиотекаКартинок.МРМКладовщикаНастройки;
	
	// Подсветка меню
	Белый  = WebЦвета.Белый;
	Желтый = WebЦвета.СветлоЗолотистый;
	
	Элементы.ПриемкаМеню.ЦветФона        = Белый;
	Элементы.ОтгрузкаМеню.ЦветФона       = Белый;
	Элементы.ПрочиеОперацииМеню.ЦветФона = Белый;
	Элементы.СканированиеМеню.ЦветФона   = Белый;
	Элементы.НастройкиМеню.ЦветФона      = Белый;
	
	Элементы.ГруппаПриемкаМеню.ЦветФона        = Белый;
	Элементы.ГруппаОтгрузкаМеню.ЦветФона       = Белый;
	Элементы.ГруппаПрочиеОперацииМеню.ЦветФона = Белый;
	Элементы.ГруппаСканированиеМеню.ЦветФона   = Белый;
	Элементы.ГруппаНастройкиМеню.ЦветФона      = Белый;
	
	Если ЭлементМеню = Элементы.ПриемкаМеню Тогда
		Элементы.Разделы.ТекущаяСтраница    = Элементы.РазделПриемка;
		ЭлементМеню.Картинка     = БиблиотекаКартинок.МРМКладовщикаПриемкаАктивная;
		Элементы.ГруппаПриемкаМеню.ЦветФона = Желтый;
		Элементы.ПриемкаМеню.ЦветФона       = Желтый;
	ИначеЕсли ЭлементМеню = Элементы.ОтгрузкаМеню Тогда
		Элементы.Разделы.ТекущаяСтраница     = Элементы.РазделОтгрузка;
		ЭлементМеню.Картинка     = БиблиотекаКартинок.МРМКладовщикаОтгрузкаАктивная;
		Элементы.ГруппаОтгрузкаМеню.ЦветФона = Желтый;
		Элементы.ОтгрузкаМеню.ЦветФона       = Желтый;
		
		Элементы.ГруппаОрдераОтбор.Видимость  = Истина;
		Элементы.ГруппаОтборИзЯчеек.Видимость = Истина;
		Элементы.ГруппаОрдераПроверка.Видимость = Истина;
		
		Если ЗначениеЗаполнено(Склад) И Не ИспользоватьСтатусыРасходныхОрдеров Тогда			
			Элементы.ГруппаОрдераОтбор.Видимость    = Ложь;
			Элементы.ГруппаОтборИзЯчеек.Видимость   = Ложь;
			Элементы.ГруппаОрдераПроверка.Видимость = Ложь;
		ИначеЕсли ИспользоватьСкладскиеПомещения И Не ЗначениеЗаполнено(Помещение) Тогда	
			Элементы.ГруппаОрдераОтбор.Видимость  = Истина;
			Элементы.ГруппаОтборИзЯчеек.Видимость = Истина;
		ИначеЕсли Не ЗначениеЗаполнено(Склад) Тогда
			Элементы.ГруппаОрдераОтбор.Видимость  = Истина;
			Элементы.ГруппаОтборИзЯчеек.Видимость = Истина;
			Элементы.ГруппаОрдераПроверка.Видимость = Истина;
		Иначе
			Элементы.ГруппаОрдераОтбор.Видимость  = Не ИспользоватьАдресноеХранение 
				Или РежимФормированияРасходныхОрдеровАвтоматически;
			Элементы.ГруппаОтборИзЯчеек.Видимость = ИспользоватьАдресноеХранение;
		КонецЕсли;

	ИначеЕсли ЭлементМеню = Элементы.ПрочиеОперацииМеню Тогда
		Элементы.Разделы.ТекущаяСтраница           = Элементы.РазделПрочиеОперации;
		ЭлементМеню.Картинка     = БиблиотекаКартинок.МРМКладовщикаПрочиеОперацииАктивная;
		Элементы.ГруппаПрочиеОперацииМеню.ЦветФона = Желтый;
		Элементы.ПрочиеОперацииМеню.ЦветФона       = Желтый;
	ИначеЕсли ЭлементМеню = Элементы.СканированиеМеню Тогда
		Элементы.Разделы.ТекущаяСтраница   = Элементы.РазделСканирование;
		ЭлементМеню.Картинка     = БиблиотекаКартинок.МРМКладовщикаСканированиеАктивная;
		Элементы.ГруппаСканированиеМеню.ЦветФона = Желтый;
		Элементы.СканированиеМеню.ЦветФона       = Желтый;
	ИначеЕсли ЭлементМеню = Элементы.НастройкиМеню Тогда
		Элементы.Разделы.ТекущаяСтраница      = Элементы.РазделНастройки;
		ЭлементМеню.Картинка     = БиблиотекаКартинок.МРМКладовщикаНастройкиАктивная;
		Элементы.ГруппаНастройкиМеню.ЦветФона = Желтый;
		Элементы.НастройкиМеню.ЦветФона       = Желтый;
	КонецЕсли;
	
	ОбновитьФормуСервер();
	
КонецПроцедуры

&НаСервере
Процедура УстановитьУсловноеОформление()
	
	Элементы.ТекущийПользователь.Заголовок = Исполнитель;
	Элементы.ГруппаРаспоряженияОтгрузка.Видимость = Не РежимФормированияРасходныхОрдеровАвтоматически;  
	
	ПорядокРаботыПриВыполненииЗаданияВМРМК = Константы.ПорядокРаботыПриВыполненииЗаданияВМРМК.Получить(); 
	
	Если ПорядокРаботыПриВыполненииЗаданияВМРМК = 
		Перечисления.ПорядокРаботыПриВыполненииЗаданияВМРМК.ОпределяетсяКладовщиком Тогда 
		
		Элементы.ГруппаПорядокСканирования.Видимость = Истина;
		Если Не ЗначениеЗаполнено(ПорядокСканирования) Тогда
			ПорядокСканирования = "СначалаСканированиеЯчейки";
		КонецЕсли;
		
	ИначеЕсли ПорядокРаботыПриВыполненииЗаданияВМРМК = 
		Перечисления.ПорядокРаботыПриВыполненииЗаданияВМРМК.СначалаСканированиеЯчейки 
		Или Не ЗначениеЗаполнено(ПорядокРаботыПриВыполненииЗаданияВМРМК) Тогда
		
		Элементы.ГруппаПорядокСканирования.Видимость = Ложь;
		ПорядокСканирования = "СначалаСканированиеЯчейки";
		
	ИначеЕсли ПорядокРаботыПриВыполненииЗаданияВМРМК = 
		Перечисления.ПорядокРаботыПриВыполненииЗаданияВМРМК.СначалаСканированиеТовара Тогда
		
		Элементы.ГруппаПорядокСканирования.Видимость = Ложь;
		ПорядокСканирования = "СначалаСканированиеТовара";
		
	КонецЕсли;	
	
КонецПроцедуры

&НаКлиенте
Процедура ПослеЗакрытияВопроса(Результат, Параметры) Экспорт
	
	Если Результат <> КодВозвратаДиалога.Да Тогда
		Возврат;
	КонецЕсли;

	// МеханизмВнешнегоОборудования
	Если ИспользуемыйСерверФормы = ИспользуемыйСервер.Основной Тогда
#Если МобильныйКлиент Тогда
		
		Выполнить("МенеджерОборудованияКлиент.НачатьОтключениеОборудованиеПриЗакрытииФормы(Неопределено, ЭтотОбъект)");
		
#Иначе
		
		МенеджерОборудованияКлиент.НачатьОтключениеОборудованиеПриЗакрытииФормы(Неопределено, ЭтотОбъект);
		
#КонецЕсли
	КонецЕсли;
	// Конец МеханизмВнешнегоОборудования
	
	ЗакрытиеРазрешено = Истина;
	Закрыть();
	ЗавершитьРаботуСистемы(Истина);
	
КонецПроцедуры

&НаСервере
Процедура СчетчикиРазделПриемка()
	
	МассивИсполнителей = Новый Массив;
	МассивИсполнителей.Добавить(Исполнитель);
	МассивИсполнителей.Добавить(Справочники.Пользователи.ПустаяСсылка());

	// Распоряжения на приемку
#Если НЕ МобильныйАвтономныйСервер Тогда
	СостояниеПоступления = Перечисления.СостоянияПоступленияТоваров.ОжидаетсяПриемка;
	Запрос = Обработки.МобильноеРабочееМестоКладовщика.ЗапросРаспоряженияНаПриемку(Склад, ТекущаяДатаСеанса(), СостояниеПоступления);
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "ГДЕ &УсловиеПоРаспоряжениям", "");
	Таблица = Запрос.Выполнить().Выгрузить();
	Элементы.РаспоряженияПриемка1.Заголовок = Таблица.Количество();
#Иначе
	Элементы.РаспоряженияПриемка1.Заголовок = 0;
#КонецЕсли
	
	// Приходные ордера
	Запрос = Обработки.МобильноеРабочееМестоКладовщика.СписокПриходныхОрдеров();
	Запрос.УстановитьПараметр("Склад", Склад);
	
	Если ЗначениеЗаполнено(Помещение) Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "И &УсловиеПомещение", "И ПриходныйОрдерНаТовары.Помещение = &Помещение");
		Запрос.УстановитьПараметр("Помещение", Помещение);
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "И &УсловиеПомещение", "");
	КонецЕсли;
	
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "И &УсловиеИсполнитель", "И ПриходныйОрдерНаТовары.Исполнитель В(&Исполнитель)");
	Запрос.УстановитьПараметр("Исполнитель", МассивИсполнителей);
	
	Статусы = Новый Массив();
	Статусы.Добавить(Перечисления.СтатусыПриходныхОрдеров.КПоступлению);
	Статусы.Добавить(Перечисления.СтатусыПриходныхОрдеров.ВРаботе);
	Запрос.УстановитьПараметр("Статусы", Статусы);
	
	Таблица = Запрос.Выполнить().Выгрузить();
	Элементы.Приемка1.Заголовок = Таблица.Количество();
	
	// Товары к размещению по ячейкам
#Если НЕ МобильныйАвтономныйСервер Тогда
	Запрос = Обработки.МобильноеРабочееМестоКладовщика.ТоварыКРазмещениюПоЯчейкам();
	Запрос.УстановитьПараметр("ЗонаПриемки", ЗонаПриемки);
	Таблица = Запрос.Выполнить().Выгрузить();
	Элементы.Размещение1.Заголовок = Таблица.Количество();
#Иначе
	Элементы.Размещение1.Заголовок = 0;
#КонецЕсли
	
	// Список заданий на размещение
	Запрос = Обработки.МобильноеРабочееМестоКладовщика.СписокЗаданийНаРазмещение();
	
	Запрос.УстановитьПараметр("ЗонаПриемки", ЗонаПриемки);
	
	Запрос.УстановитьПараметр("Склад", Склад);
	
	Если ЗначениеЗаполнено(Помещение) Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "И &УсловиеПомещение", "И ДокументОтборРазмещениеТоваров.Помещение = &Помещение");
		Запрос.УстановитьПараметр("Помещение", Помещение);
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "И &УсловиеПомещение", "");
	КонецЕсли;
	
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "И &УсловиеИсполнитель", "И ДокументОтборРазмещениеТоваров.Исполнитель В(&Исполнитель)");
	Запрос.УстановитьПараметр("Исполнитель", МассивИсполнителей);
	
	Статусы = Новый Массив();
	Статусы.Добавить(Перечисления.СтатусыОтборовРазмещенийТоваров.Подготовлено);
	Статусы.Добавить(Перечисления.СтатусыОтборовРазмещенийТоваров.ВРаботе);
	Запрос.УстановитьПараметр("Статусы", Статусы);
	
	Таблица = Запрос.Выполнить().Выгрузить();
	Элементы.Размещение3.Заголовок = Таблица.Количество();

КонецПроцедуры

&НаСервере
Процедура СчетчикиРазделОтгрузка()
	
	МассивИсполнителей = Новый Массив;
	МассивИсполнителей.Добавить(Исполнитель);
	МассивИсполнителей.Добавить(Справочники.Пользователи.ПустаяСсылка());

	// Распоряжения на отгрузку
	#Если Не МобильныйАвтономныйСервер Тогда
	Запрос = Обработки.МобильноеРабочееМестоКладовщика.ЗапросРаспоряженияНаОтгрузку(Склад);
	
	ДатаОтгрузки = ТекущаяДатаСеанса();
	
	Запрос.УстановитьПараметр("Склад", Склад);
	Запрос.УстановитьПараметр("ЗаданиеНаПеревозку", Документы.ЗаданиеНаПеревозку.ПустаяСсылка());
	Запрос.УстановитьПараметр("ДатаОтгрузки", ?(ЗначениеЗаполнено(ДатаОтгрузки), КонецДня(ДатаОтгрузки) + 1, ДатаОтгрузки));
	ОформлятьСначалаНакладные = Константы.ПорядокОформленияНакладныхРасходныхОрдеров.Получить() = Перечисления.ПорядокОформленияНакладныхРасходныхОрдеров.СначалаНакладные;
	Запрос.УстановитьПараметр("ОформлятьСначалаНакладные", ОформлятьСначалаНакладные);
	Запрос.УстановитьПараметр("ОтображениеДеталейОтгрузка", Ложь);
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеПоРаспоряжениям", "");
	
	Состояния = Новый Массив;
	Состояния.Добавить(Перечисления.СостоянияОтбораТоваров.ОжидаетсяОтбор);
	Запрос.УстановитьПараметр("Состояния", Состояния);
	
	УстановитьПривилегированныйРежим(Истина);
	Таблица = Запрос.Выполнить().Выгрузить();
	УстановитьПривилегированныйРежим(Ложь);
	Элементы.РаспоряженияОтгрузкаСчетчик.Заголовок = Таблица.Количество();
#Иначе
	Элементы.РаспоряженияОтгрузкаСчетчик.Заголовок = 0;
#КонецЕсли
		
	// Расходные ордера
	Запрос = Обработки.МобильноеРабочееМестоКладовщика.ЗапросСписокРасходныхОрдеров();
	
	//
	ТекстЗапроса = "
		|	И РасходныйОрдерНаТовары.Статус = &Статус";

	Если ЗначениеЗаполнено(Помещение) Тогда
		ТекстЗапроса = ТекстЗапроса + "
			|	И РасходныйОрдерНаТовары.Помещение = &Помещение";
	КонецЕсли;

	Запрос.Текст = Запрос.Текст + ТекстЗапроса;
	
	Запрос.УстановитьПараметр("Склад", Склад);
	Запрос.УстановитьПараметр("Помещение", Помещение);
	Запрос.УстановитьПараметр("ОтветственныйЗаголовок", НСтр("ru = 'Исполнитель'"));
	
	Если РежимФормированияРасходныхОрдеровАвтоматически Тогда
		Запрос.УстановитьПараметр("Статус", Перечисления.СтатусыРасходныхОрдеров.Подготовлен);
	Иначе
		Запрос.УстановитьПараметр("Статус", Перечисления.СтатусыРасходныхОрдеров.КОтбору);
	КонецЕсли;
	Таблица = Запрос.Выполнить().Выгрузить();
	Элементы.ОрдераКОтборуСчетчик.Заголовок = Таблица.Количество();		
		
	Если ЗначениеЗаполнено(Склад) И Не ИспользоватьСтатусыРасходныхОрдеров Тогда 
		Запрос.УстановитьПараметр("Статус", Перечисления.СтатусыРасходныхОрдеров.Отгружен);
	Иначе
		Запрос.УстановитьПараметр("Статус", Перечисления.СтатусыРасходныхОрдеров.Проверен);
	КонецЕсли;
	Таблица = Запрос.Выполнить().Выгрузить();
	Элементы.ОрдераКОтгрузкеСчетчик.Заголовок = Таблица.Количество();
	
	ПроверкаТолькоСвоихОрдеров = Обработки.МобильноеРабочееМестоКладовщика.ЕстьПравоНаПроверкуСвоихОрдеров()
		И Не Обработки.МобильноеРабочееМестоКладовщика.ЕстьПравоНаПроверкуЧужихОрдеров();
	ПроверкаТолькоЧужихОрдеров = Обработки.МобильноеРабочееМестоКладовщика.ЕстьПравоНаПроверкуЧужихОрдеров()
		И Не Обработки.МобильноеРабочееМестоКладовщика.ЕстьПравоНаПроверкуСвоихОрдеров();
		
	Если ПроверкаТолькоЧужихОрдеров Тогда
		Запрос.Текст = Запрос.Текст + "
		|	И РасходныйОрдерНаТовары.Ответственный <> &Ответственный";
			Запрос.УстановитьПараметр("Ответственный", Исполнитель);
	КонецЕсли;
	Если ПроверкаТолькоСвоихОрдеров Тогда
		Запрос.Текст = Запрос.Текст + "
		|	И РасходныйОрдерНаТовары.Ответственный = &Ответственный";
		Запрос.УстановитьПараметр("Ответственный", Исполнитель);
	КонецЕсли;
	
	Запрос.УстановитьПараметр("Статус", Перечисления.СтатусыРасходныхОрдеров.КПроверке);
	Таблица = Запрос.Выполнить().Выгрузить();
	Элементы.ОрдераКПроверкеСчетчик.Заголовок = Таблица.Количество();
	
	// Список заданий на отбор
	Запрос = Обработки.МобильноеРабочееМестоКладовщика.ЗапросСписокЗаданийНаОтбор();

	ТекстЗапроса = " 
		|	И РасходныйОрдерНаТовары.Статус = &Статус";
	
	ТекстЗапроса = ТекстЗапроса + "
		|	И ДокументОтборРазмещениеТоваров.Исполнитель В (&Исполнитель)";

	Если ЗначениеЗаполнено(Помещение) Тогда
		ТекстЗапроса = ТекстЗапроса + "
			|	И ДокументОтборРазмещениеТоваров.Помещение = &Помещение";
	КонецЕсли;
	
	Запрос.УстановитьПараметр("Склад", Склад); 
	Запрос.УстановитьПараметр("ЗонаОтгрузки", ЗонаОтгрузки);
	Запрос.УстановитьПараметр("Помещение", Помещение);
	Запрос.УстановитьПараметр("ИсполнительЗаголовок", НСтр("ru = 'Исполнитель'"));
	Запрос.УстановитьПараметр("Исполнитель", МассивИсполнителей);
		
	Статусы = Новый Массив();
	Статусы.Добавить(Перечисления.СтатусыОтборовРазмещенийТоваров.Подготовлено);
	Статусы.Добавить(Перечисления.СтатусыОтборовРазмещенийТоваров.ВРаботе);
	Запрос.УстановитьПараметр("Статусы", Статусы);
	
	Таблица = Запрос.Выполнить().Выгрузить();
	Элементы.ОтборИзЯчеекСчетчик.Заголовок = Таблица.Количество();

КонецПроцедуры

&НаСервере
Процедура СчетчикиРазделПрочиеОперации()
	
	// Список заданий на перемещение
	Запрос = Обработки.МобильноеРабочееМестоКладовщика.СписокЗаданийНаПеремещение();
	
	МассивИсполнителей = Новый Массив;
	МассивИсполнителей.Добавить(Исполнитель);
	МассивИсполнителей.Добавить(Справочники.Пользователи.ПустаяСсылка());
	
	Запрос.УстановитьПараметр("Склад", Склад);
	
	Если ЗначениеЗаполнено(Помещение) Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "И &УсловиеПомещение", "И ДокументОтборРазмещениеТоваров.Помещение = &Помещение");
		Запрос.УстановитьПараметр("Помещение", Помещение);
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "И &УсловиеПомещение", "");
	КонецЕсли;
	
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "И &УсловиеИсполнитель", "И ДокументОтборРазмещениеТоваров.Исполнитель В (&Исполнитель)");
	Запрос.УстановитьПараметр("Исполнитель", МассивИсполнителей);
	
	Статусы = Новый Массив();
	Статусы.Добавить(Перечисления.СтатусыОтборовРазмещенийТоваров.Подготовлено);
	Статусы.Добавить(Перечисления.СтатусыОтборовРазмещенийТоваров.ВРаботе);
	Запрос.УстановитьПараметр("Статусы", Статусы);
	
	Таблица = Запрос.Выполнить().Выгрузить();
	Элементы.Перемещение1.Заголовок = Таблица.Количество();
	
	// Список пересчетов
	Запрос = Обработки.МобильноеРабочееМестоКладовщика.СписокПересчетов();

	Запрос.УстановитьПараметр("Склад", Склад);
	
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "И &УсловиеИсполнитель", "И ПересчетТоваров.Исполнитель В (&Исполнитель)");
	Запрос.УстановитьПараметр("Исполнитель", МассивИсполнителей);
	
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "И &УсловиеСтатус", "И ДокументОтборРазмещениеТоваров.Статус = &Статус");
	Запрос.УстановитьПараметр("Статус", Перечисления.СтатусыПересчетовТоваров.ВнесениеРезультатов);
	
	Если ЗначениеЗаполнено(Помещение) Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "И &УсловиеПомещение", "И ПересчетТоваров.Помещение = &Помещение");
		Запрос.УстановитьПараметр("Помещение", Помещение);
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "И &УсловиеПомещение", "");
	КонецЕсли;
	
	Таблица = Запрос.Выполнить().Выгрузить();
	Элементы.Пересчет1.Заголовок = Таблица.Количество();
	
	// Список блокировок
	Запрос = Обработки.МобильноеРабочееМестоКладовщика.СписокБлокировок();
	
	Если НЕ Помещение.Пустая() Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "И &УсловиеПомещение", "И БлокировкиСкладскихЯчеек.Ячейка.Помещение = &Помещение");
		Запрос.УстановитьПараметр("Помещение", Помещение);
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "И &УсловиеПомещение", "");
	КонецЕсли;

	Запрос.УстановитьПараметр("Склад", Склад);
	
	Таблица = Запрос.Выполнить().Выгрузить();
	Элементы.БлокировкаЯчеек1.Заголовок = Таблица.Количество();
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ПолучитьСтруктуруЗаполненияОрдера()
	
	Возврат Обработки.МобильноеРабочееМестоКладовщика.СтруктураЗаполненияПриходногоОрдера();
	
КонецФункции

&НаКлиенте
Процедура ПослеЗакрытияВопросаВключитьОбменДанными(Результат, Параметры) Экспорт
	
#Если МобильныйКлиент Тогда
	Если Результат = "Включить" Или Результат = "НеВыключать" Тогда
		ВключитьОбменДанными = Истина;
	Иначе
		ВключитьОбменДанными = Ложь;
	КонецЕсли;
	
	ВключитьОбменДаннымиПриИзмененииНаСервере();
	
	Если Результат = "Включить" Тогда
		ОбменМобильныеКлиент.ВключитьОбмен();
	КонецЕсли;
	
	Если Результат = "Выключить" Тогда
		ОбменМобильныеКлиент.ОтключитьОбмен();
	КонецЕсли;
	
	Элементы.ДатаНачалаВыгрузкиДокументов.Доступность = Не ВключитьОбменДанными;
#КонецЕсли
	
КонецПроцедуры

&НаСервере
Процедура ВключитьОбменДаннымиПриИзмененииНаСервере()
	
	НачатьТранзакцию();	
	Попытка
		Блокировка = Новый БлокировкаДанных;
		ЭлементБлокировки = Блокировка.Добавить("ПланОбмена.Мобильные"); 
		ЭлементБлокировки.УстановитьЗначение("Ссылка", АвтономныйУзел);
		ЭлементБлокировки.Режим = РежимБлокировкиДанных.Исключительный;
		Блокировка.Заблокировать();
		
		Узел = АвтономныйУзел.ПолучитьОбъект();
		Узел.ВключитьОбменДанными = ВключитьОбменДанными;
		Узел.Записать();
		
		ЗафиксироватьТранзакцию();
	Исключение
		ОтменитьТранзакцию();
	КонецПопытки;
	
КонецПроцедуры

&НаСервере
Процедура ДатаНачалаВыгрузкиДокументовПриИзмененииНаСервере(Результат = НеОпределено)
	
	Если Результат = "НеОчищать" Тогда
		ДатаНачалаВыгрузкиДокументов = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(АвтономныйУзел, "ДатаНачалаВыгрузкиДокументов");
	Иначе
		НачатьТранзакцию();
		Попытка
			
			Блокировка = Новый БлокировкаДанных;
			ЭлементБлокировки = Блокировка.Добавить("ПланОбмена.Мобильные");
			ЭлементБлокировки.УстановитьЗначение("Ссылка", АвтономныйУзел);
			ЭлементБлокировки.Режим = РежимБлокировкиДанных.Исключительный;
			Блокировка.Заблокировать();
			
			Узел = АвтономныйУзел.ПолучитьОбъект();
			Узел.ДатаНачалаВыгрузкиДокументов = ДатаНачалаВыгрузкиДокументов;
			Узел.Записать();
			
			ЗафиксироватьТранзакцию();
		Исключение
			ОтменитьТранзакцию();
		КонецПопытки;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПослеЗакрытияВопросаДатаНачалаВыгрузкиДокументов(Результат, Параметры) Экспорт
	ДатаНачалаВыгрузкиДокументовПриИзмененииНаСервере(Результат);
	Элементы.ДатаНачалаВыгрузкиДокументов.Подсказка = СтрШаблон(НСтр("ru = 'В автономный режим будут выгружаться только те документы, дата которых больше или равна %1.'"), Формат(ДатаНачалаВыгрузкиДокументов, НСтр("ru='ДЛФ=Д'")));
КонецПроцедуры

&НаСервере
Процедура ПолучитьРеквизитыАвтономногоУзла(Код)
	
#Если МобильныйАвтономныйСервер Тогда
	Элементы.РаботаВАвтономномРежиме.Видимость = Ложь;
#Иначе
	Если Не ЗначениеЗаполнено(Код) Тогда
		Элементы.РаботаВАвтономномРежиме.Видимость = Ложь;
	ИначеЕсли Не ОбменМобильныеВызовПК.АвтономныйРежимДоступен() Тогда
		Элементы.РаботаВАвтономномРежиме.Видимость = Истина;
		Элементы.ДатаНачалаВыгрузкиДокументов.Доступность = Ложь;
		Элементы.ВключитьОбменДанными.Доступность = Ложь;
		Элементы.ДатаНачалаВыгрузкиДокументов.Подсказка = НСтр("ru = 'В автономный режим будут выгружаться только те документы, дата которых больше или равна этой.'");
		Элементы.ЗаголовокРаботаВАвтономномРежиме.Подсказка = НСтр("ru = 'Чтобы включить доступность опции необходимо подключить текущему пользователю роль ""Использование автономного режима"".'");
	Иначе
		Элементы.РаботаВАвтономномРежиме.Видимость = Истина;
		Элементы.ДатаНачалаВыгрузкиДокументов.Доступность = Истина;
		Элементы.ВключитьОбменДанными.Доступность = Истина;
		
		АвтономныйУзел = ПланыОбмена.Мобильные.НайтиПоКоду(Код);
		РеквизитыАвтономногоУзла = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(АвтономныйУзел, "ВключитьОбменДанными, ДатаНачалаВыгрузкиДокументов");
		ВключитьОбменДанными = РеквизитыАвтономногоУзла.ВключитьОбменДанными;
		
		Если Не ЗначениеЗаполнено(РеквизитыАвтономногоУзла.ДатаНачалаВыгрузкиДокументов) Тогда
			ДатаНачалаВыгрузкиДокументов = НачалоДня(ТекущаяДатаСеанса());
			
			НачатьТранзакцию();
			Попытка
				Блокировка = Новый БлокировкаДанных;
				ЭлементБлокировки = Блокировка.Добавить("ПланОбмена.Мобильные");
				ЭлементБлокировки.УстановитьЗначение("Ссылка", АвтономныйУзел);
				ЭлементБлокировки.Режим = РежимБлокировкиДанных.Исключительный;
				Блокировка.Заблокировать();
				
				Узел = АвтономныйУзел.ПолучитьОбъект();
				Узел.ДатаНачалаВыгрузкиДокументов = ДатаНачалаВыгрузкиДокументов;
				Узел.Записать();
				
				ЗафиксироватьТранзакцию();
			Исключение
				ОтменитьТранзакцию();
			КонецПопытки;
		Иначе
			ДатаНачалаВыгрузкиДокументов = РеквизитыАвтономногоУзла.ДатаНачалаВыгрузкиДокументов;
		КонецЕсли;
		
		Элементы.ДатаНачалаВыгрузкиДокументов.Подсказка = СтрШаблон(НСтр("ru = 'В автономный режим будут выгружаться только те документы, дата которых больше или равна %1.'"), Формат(ДатаНачалаВыгрузкиДокументов, НСтр("ru='ДЛФ=Д'")));
		Элементы.ЗаголовокРаботаВАвтономномРежиме.Подсказка = НСтр("ru = 'Приложение имеет возможность работать в автономном режиме. При наличии подключения к основному серверу приложение будет копировать необходимые данные в локальную базу, а после потери соединения переключится в автономный режим и продолжит работу с данными.'");
		Элементы.ДатаНачалаВыгрузкиДокументов.Доступность = Не ВключитьОбменДанными;
		
	КонецЕсли;
#КонецЕсли

КонецПроцедуры

#КонецОбласти
