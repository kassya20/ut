&НаКлиенте
Процедура ОбработатьШтрихкод(ДанныеШтрихкода)
			
	ТекстОшибки = "";
		
	ШтрихкодыВалидны = МобильноеРабочееМестоКладовщикаКлиент.ШтрихкодыВалидны(ДанныеШтрихкода); 
		
	Если Не ШтрихкодыВалидны Тогда
		Возврат;
	КонецЕсли;
	
	Состояние(НСтр("ru = 'Выполняется поиск объекта по штрихкоду...'")); 
			
	ДанныеПоШтрихкоду = ДанныеПоОбщемуШтрихкоду(ДанныеШтрихкода.Штрихкод);
		
	Если ДанныеПоШтрихкоду.ВидОбъекта = "Номенклатура" 
		И ИспользуемыйСерверФормы = ИспользуемыйСервер.Основной Тогда 
			
		РезультатСканированияТовара(ДанныеПоШтрихкоду.Товары);
			
	ИначеЕсли ДанныеПоШтрихкоду.ВидОбъекта = "Ячейка"
		И ИспользуемыйСерверФормы = ИспользуемыйСервер.Основной Тогда
			
		РезультатСканированияЯчейки(ДанныеПоШтрихкоду.ДанныеЯчейки); 
			
	ИначеЕсли ДанныеПоШтрихкоду.ВидОбъекта = "Документ" Тогда 
			
		Если ЗначениеЗаполнено(ДанныеПоШтрихкоду.ДанныеДокумента.ТекстОшибки) Тогда
			Состояние(ДанныеПоШтрихкоду.ДанныеДокумента.ТекстОшибки);
			Возврат;
		КонецЕсли;
		
		РезультатСканированияДокумента(ДанныеПоШтрихкоду.ДанныеДокумента);
			
	ИначеЕсли ДанныеПоШтрихкоду.ВидОбъекта = Неопределено Тогда

		ТекстОшибки = ДанныеПоШтрихкоду.ТекстОшибки;
		
		Состояние(ТекстОшибки);
			
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция ДанныеПоОбщемуШтрихкоду(Знач Штрихкод)
	
	Возврат Обработки.МобильноеРабочееМестоКладовщика.ДанныеПоОбщемуШтрихкоду(Штрихкод, Склад, Помещение);

КонецФункции

&НаКлиенте
Процедура РезультатСканированияДокумента(Результат = Неопределено, ДополнительныеПараметры = Неопределено) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;

	Описание = Новый ОписаниеОповещения("ОбновитьФормуСервер", ЭтотОбъект);

	Если Результат.Ссылки.Количество() > 1 Тогда 
		
		Описание = Новый ОписаниеОповещения("РезультатСканированияДокумента", ЭтотОбъект);

		ПараметрыФормы = Новый Структура;
		ПараметрыФормы.Вставить("РезультатСканирования", Результат);
		ПараметрыФормы.Вставить("Склад", Склад); 
		ПараметрыФормы.Вставить("Помещение", Помещение);
		
		ОткрытьФорму(
			"Обработка.МобильноеРабочееМестоКладовщика.Форма.ФормаВыбораСканирование", ПараметрыФормы,
			ЭтотОбъект,,,,Описание, РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
		
	ИначеЕсли Результат.ЭтоРаспоряжение Тогда
		
		Распоряжение =  Результат.Ссылки[0];
		
		ПараметрыФормы = Новый Структура;

		Если Результат.Направление = "Отгрузка" Тогда  
			СтруктураЗаполнения = Новый Структура;
			СтруктураЗаполнения.Вставить("Склад", Склад);
			СтруктураЗаполнения.Вставить("Помещение", Помещение);
			СтруктураЗаполнения.Вставить("Распоряжение", Распоряжение.Распоряжение); 
			СтруктураЗаполнения.Вставить("Получатель", Распоряжение.Получатель);
			ПараметрыФормы.Вставить("ТипДокумента", 2);
		Иначе
			СтруктураЗаполнения = ПолучитьСтруктуруЗаполненияОрдера();
	
			ЗаполнитьЗначенияСвойств(СтруктураЗаполнения, Распоряжение);
			СтруктураЗаполнения.Склад           = Склад;
			СтруктураЗаполнения.Помещение       = Помещение;
		
			СтруктураЗаполнения.Вставить("Отправитель", Распоряжение.Отправитель);
			ПараметрыФормы.Вставить("ТипДокумента", 1);
		КонецЕсли;
		
		ПараметрыФормы.Вставить("СтруктураЗаполнения", СтруктураЗаполнения);
		ПараметрыФормы.Вставить("ПоказыватьФотоТоваров", ПоказыватьФотоТоваров);
		ПараметрыФормы.Вставить("НазваниеДокумента", Распоряжение.ТипДокумента);
		ПараметрыФормы.Вставить("Номер", Распоряжение.Номер);
		ПараметрыФормы.Вставить("Штрихкод", Результат.Штрихкод);
		ПараметрыФормы.Вставить("ПорядокСканирования", ПорядокСканирования);

		ОткрытьФорму(
			"Обработка.МобильноеРабочееМестоКладовщика.Форма.Товары", ПараметрыФормы,
			ЭтотОбъект,,,,Описание, РежимОткрытияОкнаФормы.Независимый);
		
	Иначе
			
		Документ = Результат.Ссылки[0];
		Тип = ТипЗнч(Документ);
		
		ПараметрыФормы = Новый Структура;
		ПараметрыФормы.Вставить("Ссылка", Документ);
		ПараметрыФормы.Вставить("ПоказыватьФотоТоваров", ПоказыватьФотоТоваров);
		ПараметрыФормы.Вставить("Штрихкод", Результат.Штрихкод);
		ПараметрыФормы.Вставить("ПорядокСканирования", ПорядокСканирования);
		
		Если Тип = Тип("ДокументСсылка.РасходныйОрдерНаТовары") Тогда 
				
			ИмяОткрываемойФормы = "Обработка.МобильноеРабочееМестоКладовщика.Форма.РасходныйОрдер"
			
		ИначеЕсли Тип = Тип("ДокументСсылка.ПриходныйОрдерНаТовары") Тогда 
			
			ПараметрыФормы.Вставить("Исполнитель", Исполнитель);
			ИмяОткрываемойФормы = "Обработка.МобильноеРабочееМестоКладовщика.Форма.ПриходныйОрдер"
			
		ИначеЕсли Тип = Тип("ДокументСсылка.ОтборРазмещениеТоваров") Тогда
			
			Если Результат.Направление = "Отгрузка" Тогда
				ПараметрыФормы.Вставить("Бесшовный", Ложь);
				ИмяОткрываемойФормы = "Обработка.МобильноеРабочееМестоКладовщика.Форма.Отбор";
			ИначеЕсли Результат.Направление = "Приемка" Тогда 
				ИмяОткрываемойФормы = "Обработка.МобильноеРабочееМестоКладовщика.Форма.РазмещениеПоЯчейкам";
			Иначе
				ИмяОткрываемойФормы = "Обработка.МобильноеРабочееМестоКладовщика.Форма.ЗаданиеНаПеремещениеТоваров";
			КонецЕсли;
			
		ИначеЕсли Тип = Тип("ДокументСсылка.ПересчетТоваров") Тогда 
			
			ИмяОткрываемойФормы = "Обработка.МобильноеРабочееМестоКладовщика.Форма.ПересчетТоваров"
			
		КонецЕсли; 
		
		ОткрытьФорму(ИмяОткрываемойФормы, ПараметрыФормы, ЭтотОбъект,,,,Описание, РежимОткрытияОкнаФормы.Независимый);

	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура РезультатСканированияТовара(Результат = Неопределено, ДополнительныеПараметры = Неопределено) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если Результат.Количество() > 1 Тогда 
		
		Описание = Новый ОписаниеОповещения("РезультатСканированияТовара", ЭтотОбъект);
		
		ЗначенияЗаполнения = Новый Структура;
		ЗначенияЗаполнения.Вставить("Товары", Результат);
		ЗначенияЗаполнения.Вставить("Режим", "ВыборНоменклатуры");
		ЗначенияЗаполнения.Вставить("Штрихкод", "");
		
		ПараметрыФормы = Новый Структура;
		ПараметрыФормы.Вставить("РезультатСканирования", ЗначенияЗаполнения);
		
		ОткрытьФорму(
			"Обработка.МобильноеРабочееМестоКладовщика.Форма.ФормаВыбораСканирование", ПараметрыФормы,
			ЭтотОбъект,,,,Описание, РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
		
	Иначе
		
		ДанныеТовара = Результат[0];
	
		ПараметрыФормы = Новый Структура;
		ПараметрыФормы.Вставить("Номенклатура", ДанныеТовара.Номенклатура);
		ПараметрыФормы.Вставить("Характеристика", ДанныеТовара.Характеристика);
		ПараметрыФормы.Вставить("Упаковка", ДанныеТовара.Упаковка);
		ПараметрыФормы.Вставить("Серия", ДанныеТовара.Серия);
		ПараметрыФормы.Вставить("Склад", Склад);
		ПараметрыФормы.Вставить("Помещение", Помещение);
		ПараметрыФормы.Вставить("ПоказыватьФотоТоваров", ПоказыватьФотоТоваров);
		
		ОткрытьФорму(
		"Обработка.МобильноеРабочееМестоКладовщика.Форма.ПоискПоТовару",ПараметрыФормы,
			ЭтотОбъект,,,,,
			РежимОткрытияОкнаФормы.Независимый);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура РезультатСканированияЯчейки(Результат = Неопределено, ДополнительныеПараметры = Неопределено) Экспорт
	
