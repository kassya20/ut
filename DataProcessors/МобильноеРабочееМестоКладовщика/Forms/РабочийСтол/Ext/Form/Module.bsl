#Область ОписаниеПеременных

&НаКлиенте
Перем ЗакрытиеРазрешено;

#КонецОбласти


#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	УИДПользователяИБ = ПользователиИнформационнойБазы.ТекущийПользователь().УникальныйИдентификатор;
	Исполнитель = Справочники.Пользователи.НайтиПоРеквизиту("ИдентификаторПользователяИБ", Новый УникальныйИдентификатор(УИДПользователяИБ));
	
	ТипСкладскойЯчейкиПриемка  = Перечисления.ТипыСкладскихЯчеек.Приемка;
	ТипСкладскойЯчейкиОтгрузка = Перечисления.ТипыСкладскихЯчеек.Отгрузка;
	
	РежимФормированияРасходныхОрдеровАвтоматически = (Константы.РежимФормированияРасходныхОрдеров.Получить() 
		= Перечисления.РежимыФормированияРасходныхОрдеров.Автоматически);
		
	УстановитьУсловноеОформление();
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
#Если МобильныйКлиент Тогда
	ПолучитьРеквизитыАвтономногоУзла(ОбменМобильныеАвтономныйКлиент.ТекущийУзел());
#Иначе
	Элементы.РаботаВАвтономномРежиме.Видимость = Ложь;
#КонецЕсли
	
	ИспользоватьПодключаемоеОборудование = Истина;
	ПодключитьОбработчикОжидания("МеханизмВнешнегоОборудования", 5, Истина);
	
	СформироватьПредставленияОтборов();
	ПерейтиВРаздел(Элементы.ПриемкаМеню);
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаВыбора(ВыбранноеЗначение, ИсточникВыбора)
	
	Если ВРег(ИсточникВыбора.ИмяФормы) = ВРег("Справочник.Склады.Форма.ФормаВыбораМРМ") Тогда
		
		Склад        = ВыбранноеЗначение;
		Помещение    = Неопределено;
		ЗонаПриемки  = Неопределено;
		ЗонаОтгрузки = Неопределено;		
		СформироватьПредставленияОтборов();
		
	КонецЕсли;
	
	Если ВРег(ИсточникВыбора.ИмяФормы) = ВРег("Справочник.СкладскиеПомещения.Форма.ФормаВыбораМРМ") Тогда
		
		Помещение    = ВыбранноеЗначение;
		ЗонаПриемки  = Неопределено;
		ЗонаОтгрузки = Неопределено;
		СформироватьПредставлениеОтбораПомещение();
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПередЗакрытием(Отказ, ЗавершениеРаботы, ТекстПредупреждения, СтандартнаяОбработка)

#Если МобильныйКлиент Тогда
		Если ЗакрытиеРазрешено = Неопределено Тогда
			Если ЗавершениеРаботы Тогда
				ТекстПредупреждения = НСтр("ru = 'Закрыть приложение?'");
				Отказ = Истина;
			Иначе
				Режим = РежимДиалогаВопрос.ДаНет;
				Оповещение = Новый ОписаниеОповещения("ПослеЗакрытияВопроса", ЭтотОбъект, Параметры);
				ПоказатьВопрос(Оповещение, НСтр("ru = 'Закрыть приложение?'"), Режим, 0);
				Отказ = Истина;
			КонецЕсли;
		КонецЕсли;
#КонецЕсли

КонецПроцедуры

&НаКлиенте
Процедура ПриИзмененииДоступностиОсновногоСервера(СтандартнаяОбработка)
	
#Если МобильныйКлиент Тогда
	ПереоткрытьСДругогоСервера();
#КонецЕсли
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	Если ИспользуемыйСерверФормы = ИспользуемыйСервер.Основной Тогда
		// ПодключаемоеОборудование
		Если Источник = "ПодключаемоеОборудование" И ВводДоступен() Тогда 
			
			ЕстьНеобработанноеСобытие = МобильноеРабочееМестоКладовщикаКлиент.ЕстьНеобработанноеСобытие();
			
			Если ИмяСобытия = "ScanData" И ЕстьНеобработанноеСобытие Тогда
				
				Данные = МобильноеРабочееМестоКладовщикаКлиент.ПреобразоватьДанныеСоСканераВСтруктуру(Параметр);
				
				ОбработатьШтрихкод(Данные);
			
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;

КонецПроцедуры 

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура ВключитьОбменДаннымиПриИзменении(Элемент)
	
	Если ВключитьОбменДанными = Истина Тогда
		СписокЗначений = Новый СписокЗначений;
		СписокЗначений.Добавить("Включить", НСтр("ru = 'Включить'"));
		СписокЗначений.Добавить("НеВключать", НСтр("ru = 'Не включать'"));
		
		Оповещение = Новый ОписаниеОповещения("ПослеЗакрытияВопросаВключитьОбменДанными", ЭтотОбъект);
		ПоказатьВопрос(Оповещение, НСтр("ru = 'После включения синхронизации начнется обмен данными, который может занять длительное время. Включить синхронизацию?'"), СписокЗначений, 0);
	Иначе
		СписокЗначений = Новый СписокЗначений;
		СписокЗначений.Добавить("Выключить", НСтр("ru = 'Выключить'"));
		СписокЗначений.Добавить("НеВыключать", НСтр("ru = 'Не выключать'"));
		
		Оповещение = Новый ОписаниеОповещения("ПослеЗакрытияВопросаВключитьОбменДанными", ЭтотОбъект);
		ПоказатьВопрос(Оповещение, НСтр("ru = 'После выключения синхронизации обмен больше не будет выполняться, и данные в автономном режиме могут стать неактуальными. Выключить синхронизацию?'"), СписокЗначений, 0);
	
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ДатаНачалаВыгрузкиДокументовПриИзменении(Элемент)
	
	Если Не ЗначениеЗаполнено(ДатаНачалаВыгрузкиДокументов) Тогда
		СписокЗначений = Новый СписокЗначений;
		СписокЗначений.Добавить("Очистить", НСтр("ru = 'Очистить'"));
		СписокЗначений.Добавить("НеОчищать", НСтр("ru = 'Не очищать'"));
		
		Оповещение = Новый ОписаниеОповещения("ПослеЗакрытияВопросаДатаНачалаВыгрузкиДокументов", ЭтотОбъект);
		ПоказатьВопрос(Оповещение, НСтр("ru = 'Если оставить дату незаполненной, то в автономную конфигурацию будут выгружаться документы за весь период, что может занять продолжительное время. Очистить дату?'"), СписокЗначений, 0);
	Иначе
		ДатаНачалаВыгрузкиДокументовПриИзмененииНаСервере();
		Элементы.ДатаНачалаВыгрузкиДокументов.Подсказка = СтрШаблон(НСтр("ru = 'В автономный режим будут выгружаться только те документы, дата которых больше или равна %1.'"), Формат(ДатаНачалаВыгрузкиДокументов, НСтр("ru='ДЛФ=Д'")));
	КонецЕсли;
	
КонецПроцедуры

