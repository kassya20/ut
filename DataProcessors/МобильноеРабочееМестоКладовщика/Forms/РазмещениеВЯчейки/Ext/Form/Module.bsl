#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Ячейка                = Параметры.Ячейка;
	Склад                 = Параметры.Склад;
	Помещение             = Параметры.Помещение;
	ТипОперации           = Параметры.ТипОперации;
	Организация           = Параметры.Организация;
	ПоказыватьФотоТоваров = Параметры.ПоказыватьФотоТоваров;
	ШтрихкодДокумента     = Параметры.ШтрихкодДокумента;
	ШтрихкодЯчейки        = Параметры.ШтрихкодЯчейки;
	ПорядокСканирования   = Параметры.ПорядокСканирования;
	
	Если Параметры.Свойство("Режим") Тогда
		Режим = Параметры.Режим;
	КонецЕсли;
	
	Если Параметры.Свойство("Ссылка") Тогда
		Ссылка = Параметры.Ссылка;
	КонецЕсли;
	
	Если Параметры.Свойство("ПечататьКоличествоПоУчету") Тогда
		ПечататьКоличествоПоУчету = Параметры.ПечататьКоличествоПоУчету;
	КонецЕсли;
	
	Если Параметры.Свойство("РаспоряжениеНаОтбор") Тогда
		РаспоряжениеНаОтбор = Параметры.РаспоряжениеНаОтбор;
	КонецЕсли;
	
	Если Параметры.Свойство("Товары") Тогда
		
		ТоварыВЯчейке = Параметры.Товары;
		
		Для Каждого Строка Из ТоварыВЯчейке Цикл
			
			НоваяСтрока = Товары.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, Строка);
			Если ТипОперации = 1 Тогда
				НоваяСтрока.ЗаголовокФакт = НСтр("ru = 'Размещено'");
			ИначеЕсли ТипОперации = 2 Тогда
				НоваяСтрока.ЗаголовокФакт = НСтр("ru = 'Отобрано'");
			КонецЕсли;
			НоваяСтрока.Ячейка = Ячейка;
			
		КонецЦикла;
		
	КонецЕсли;
	
	Если ТипОперации = 3 Тогда
		
		Если Режим = "РедактированиеПеремещение" Тогда
			НоваяСтрока = Товары.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, Параметры);
		КонецЕсли;
		
		Если Параметры.Свойство("ЯчейкаЗамена") Тогда
			ЯчейкаЗамена = Параметры.ЯчейкаЗамена;
		КонецЕсли;
		
	КонецЕсли;
	
	УстановитьУсловноеОформление();
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	Если ИспользуемыйСерверФормы = ИспользуемыйСервер.Основной Тогда
		// ПодключаемоеОборудование
		Если Источник = "ПодключаемоеОборудование" И ВводДоступен() Тогда 
			
			ЕстьНеобработанноеСобытие = МобильноеРабочееМестоКладовщикаКлиент.ЕстьНеобработанноеСобытие();
			
			Если ИмяСобытия = "ScanData" И ЕстьНеобработанноеСобытие Тогда
				
				Данные = МобильноеРабочееМестоКладовщикаКлиент.ПреобразоватьДанныеСоСканераВСтруктуру(Параметр);
				
				ОбработатьШтрихкод(Данные);

			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура ТоварыВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	Описание = Новый ОписаниеОповещения("ОбновитьФорму", ЭтотОбъект);
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("Номенклатура", Элемент.ТекущиеДанные.Номенклатура);
	ПараметрыФормы.Вставить("Характеристика", Элемент.ТекущиеДанные.Характеристика);
	ПараметрыФормы.Вставить("Серия", Элемент.ТекущиеДанные.Серия);
	ПараметрыФормы.Вставить("Назначение", Элемент.ТекущиеДанные.Назначение);
	ПараметрыФормы.Вставить("Упаковка", Элемент.ТекущиеДанные.Упаковка);
	ПараметрыФормы.Вставить("Количество", Элемент.ТекущиеДанные.КоличествоУпаковок);
	Если ТипОперации = 1 Тогда
		ПараметрыФормы.Вставить("Режим", "РедактированиеРазмещениеПоЯчейкам");
	ИначеЕсли ТипОперации = 2 Тогда
		ПараметрыФормы.Вставить("Режим", "РедактированиеОтборИзЯчейкиОтгрузка"); 
	ИначеЕсли ТипОперации = 3 И Режим <> "РедактированиеПеремещение" Тогда
		ПараметрыФормы.Вставить("Режим", "Перемещение");
	ИначеЕсли ТипОперации = 4 Тогда
		ПараметрыФормы.Вставить("Режим", "РедактированиеПересчет");
		ПараметрыФормы.Вставить("Количество", Элемент.ТекущиеДанные.КоличествоУпаковокРазмещено);
	Иначе
		ПараметрыФормы.Вставить("Режим", "Просмотр");
	КонецЕсли;
	ПараметрыФормы.Вставить("НомерСтроки", Товары.Индекс(Элементы.Товары.ТекущиеДанные));
	ПараметрыФормы.Вставить("Склад", Склад);
	ПараметрыФормы.Вставить("Помещение", Помещение);
	Если Элемент.ТекущиеДанные.ЯчейкаЗамена.Пустая() Тогда
		ПараметрыФормы.Вставить("Ячейка", Элемент.ТекущиеДанные.Ячейка);
	Иначе
		ПараметрыФормы.Вставить("Ячейка", Элемент.ТекущиеДанные.ЯчейкаЗамена);
	КонецЕсли;
	ПараметрыФормы.Вставить("ПоказыватьФотоТоваров", ПоказыватьФотоТоваров);
	ПараметрыФормы.Вставить("Артикул", Элемент.ТекущиеДанные.Артикул);
	ПараметрыФормы.Вставить("ДокументИсточник", Ссылка);
	ПараметрыФормы.Вставить("ШтрихкодДокумента", ШтрихкодДокумента);
	ПараметрыФормы.Вставить("ПорядокСканирования", ПорядокСканирования);

	ОткрытьФорму(
	"Обработка.МобильноеРабочееМестоКладовщика.Форма.КарточкаТовара",ПараметрыФормы,
	ЭтотОбъект,,,,Описание,
	РежимОткрытияОкнаФормы.Независимый);
	
КонецПроцедуры

&НаКлиенте
Процедура Подтвердить(Команда)
		
	ЗакрытьФорму();
	
КонецПроцедуры

&НаКлиенте
Процедура ЗакрытьФорму(ДанныеСледующейЯчейки = Неопределено)
	
	Если ТипОперации = 3 И Не ЗначениеЗаполнено(ЯчейкаЗамена) Тогда
		ТекстОшибки = НСтр("ru = 'Укажите ячейку для размещения'");
		Состояние(ТекстОшибки);
		Возврат;
	КонецЕсли;

	МассивРазмещений = Новый Массив;
	
	Для Каждого Строка Из Товары Цикл
		
		Структура = СтруктураТоваров();
		
		ЗаполнитьЗначенияСвойств(Структура, Строка);
		
		Структура.Вставить("КоличествоУпаковок", Строка.КоличествоУпаковокРазмещено);
		
		МассивРазмещений.Добавить(Структура);
		
	КонецЦикла;
	
	РезультатСборки = Новый Структура;
	РезультатСборки.Вставить("Ячейка", Ячейка);
	РезультатСборки.Вставить("МассивРазмещений", МассивРазмещений);
	РезультатСборки.Вставить("Режим", Режим);
	РезультатСборки.Вставить("ШтрихкодыУпаковок", ШтрихкодыУпаковок);
	РезультатСборки.Вставить("ДанныеСледующейЯчейки", ДанныеСледующейЯчейки);
	
	Закрыть(РезультатСборки);
	
КонецПроцедуры

&НаКлиенте
Процедура Блокировать(Команда)
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("Ячейка", Ячейка);
	
	ОткрытьФорму(
	"Обработка.МобильноеРабочееМестоКладовщика.Форма.БлокировкаЯчейки",ПараметрыФормы,
	ЭтотОбъект,,,,,
	РежимОткрытияОкнаФормы.Независимый);
	
КонецПроцедуры

&НаКлиенте
Процедура Сканировать(Команда)
	
	СписокЗначений = Новый СписокЗначений;
	СписокЗначений.Добавить("Ячейка", НСтр("ru = 'Ячейку'"));
	СписокЗначений.Добавить("Товар", НСтр("ru = 'Товар'"));
	СписокЗначений.Добавить("Отмена", НСтр("ru = 'Отмена'"));
	
	Оповещение = Новый ОписаниеОповещения("ПослеЗакрытияВопросаВыбор", ЭтотОбъект);
	ПоказатьВопрос(Оповещение, НСтр("ru = 'Сканировать'"), СписокЗначений, 0);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура УстановитьУсловноеОформление()
	
	Если ТипОперации = 1 Тогда
		ОбновитьПодсказку();
		Элементы.Подтвердить.Заголовок = НСтр("ru = 'Закончить размещение'");
		Заголовок = НСтр("ru = 'Размещение в ячейку'");
	ИначеЕсли ТипОперации = 2 Тогда
		ОбновитьПодсказку();
		Элементы.Подтвердить.Заголовок = НСтр("ru = 'Закончить отбор'");
		Заголовок             = НСтр("ru = 'Отбор из ячейки'");
	ИначеЕсли ТипОперации = 3 Тогда
		ОбновитьПодсказку();
		Элементы.Подтвердить.Заголовок             = НСтр("ru = 'Переместить'");
		Заголовок                         = НСтр("ru = 'Перемещение'");
		Элементы.ЯчейкаЗамена.Видимость            = Истина;
		Элементы.ГруппаПодсказка.Видимость         = Ложь;
		Элементы.ТоварыЗаголовокФакт.Видимость     = Ложь;
		Элементы.ТоварыУпаковкаРазмещено.Видимость = Истина;
		Элементы.Ячейка.Заголовок                  = НСтр("ru = 'Ячейка отбор'");
		Элементы.ЯчейкаЗамена.Заголовок            = НСтр("ru = 'Ячейка размещение'");
	ИначеЕсли ТипОперации = 4 Тогда
		ОбновитьПодсказку();
		Элементы.Подтвердить.Заголовок = НСтр("ru = 'Закончить пересчет'");
		Заголовок             = НСтр("ru = 'Пересчет в ячейке'");
	КонецЕсли;
	
	Если ТипОперации = 4 И Не ПечататьКоличествоПоУчету Тогда
		Элементы.ТоварыКоличествоУпаковокРазмещено.ЦветТекста = ЦветаСтиля.ЦветТекстаПроблема;
		Элементы.ТоварыКоличествоУпаковок.Видимость = Ложь;
	Иначе
		ЭлементУсловногоОформления = УсловноеОформление.Элементы.Добавить();
		ОформляемоеПоле = ЭлементУсловногоОформления.Поля.Элементы.Добавить();
		ОформляемоеПоле.Поле = Новый ПолеКомпоновкиДанных("ТоварыКоличествоУпаковокРазмещено");
		
		ЭлементОтбора = ЭлементУсловногоОформления.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
		ЭлементОтбора.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("Товары.КоличествоУпаковок");
		ЭлементОтбора.ВидСравнения = ВидСравненияКомпоновкиДанных.НеРавно;
		ЭлементОтбора.ПравоеЗначение = Новый ПолеКомпоновкиДанных("Товары.КоличествоУпаковокРазмещено");
		
		ЭлементУсловногоОформления.Оформление.УстановитьЗначениеПараметра("ЦветТекста", ЦветаСтиля.ЦветТекстаПроблема);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Функция СтруктураТоваров()
	
	Структура = Новый Структура;
	Структура.Вставить("Номенклатура","");
	Структура.Вставить("Характеристика","");
	Структура.Вставить("Серия","");
	Структура.Вставить("Назначение","");
	Структура.Вставить("Упаковка","");
	Структура.Вставить("УпаковкаРазмещено","");
	Структура.Вставить("КоличествоУпаковок","");
	Структура.Вставить("КоличествоУпаковокРазмещено","");
	Структура.Вставить("Ячейка","");
	Структура.Вставить("ЯчейкаЗамена","");
	Структура.Вставить("НомерСтроки","");
	
	Возврат Структура;
	
КонецФункции

&НаСервере
Процедура ОбновитьПодсказку()
	
	Если ТипОперации = 1 Тогда
		Элементы.ЗаголовокПодсказка1.Заголовок = НСтр("ru = 'Размещено строк'");
	ИначеЕсли ТипОперации = 4 Тогда
		Элементы.ЗаголовокПодсказка1.Заголовок = НСтр("ru = 'Пересчитано'");
	Иначе
		Элементы.ЗаголовокПодсказка1.Заголовок = НСтр("ru = 'Отобрано строк'");
	КонецЕсли;
	
	План = Товары.Количество();
	ОтработаноСтрокБезОшибок = 0;
	Для Каждого Строка Из Товары Цикл
		Если Строка.КоличествоУпаковок = Строка.КоличествоУпаковокРазмещено Тогда
			ОтработаноСтрокБезОшибок = ОтработаноСтрокБезОшибок + 1;
		КонецЕсли;
	КонецЦикла;
		
	Элементы.ЗаголовокПодсказкаФакт.Заголовок = ОтработаноСтрокБезОшибок;
	Элементы.ЗаголовокПодсказкаПлан.Заголовок = План;
	Элементы.ЗаголовокПодсказкаРазница.Заголовок = План - ОтработаноСтрокБезОшибок;

КонецПроцедуры

&НаКлиенте
Процедура ОбновитьФорму(Результат = Неопределено, ДополнительныеПараметры = Неопределено) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ПодтвердитьКоличество(Результат);
	Если ЗначениеЗаполнено(Результат.ДанныеСледующегоТовара) Тогда
		РезультатСканированияТовара(Результат.ДанныеСледующегоТовара);
	ИначеЕсли ЗначениеЗаполнено(Результат.ДанныеСледующейЯчейки) Тогда
		РезультатСканированияЯчейки(Результат.ДанныеСледующейЯчейки);	
	КонецЕсли;
		
	Если Результат.ЗакрытьКарточку И Открыта() Тогда
		ЗакрытьФорму();
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ПодтвердитьКоличество(Результат = Неопределено, ДополнительныеПараметры = Неопределено)
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	СтруктураПоиска = Новый Структура;
	СтруктураПоиска.Вставить("Номенклатура", Результат.Номенклатура);
	СтруктураПоиска.Вставить("Характеристика", Результат.Характеристика);
	СтруктураПоиска.Вставить("Упаковка", Результат.Упаковка);
	СтруктураПоиска.Вставить("Серия", Результат.Серия); 
	СтруктураПоиска.Вставить("Назначение", Результат.Назначение);

	Если Результат.Режим = "РедактированиеРазмещениеПоЯчейкам"
		ИЛИ Результат.Режим = "РедактированиеОтборИзЯчейкиОтгрузка" Тогда
			
		Литерал = "НомерСтроки";
		НомерСтроки = Результат[Литерал];
		
		СерииПриОтгрузке = СерииНоменклатурыПриОтгрузке(Результат.Номенклатура);
		
		Если Результат.Режим = "РедактированиеОтборИзЯчейкиОтгрузка"
			И Не ЗначениеЗаполнено(Товары[НомерСтроки].Серия) 
			И СерииПриОтгрузке.УказыватьПоФактуОтбора 
			И СерииПриОтгрузке.УчитыватьОстаткиСерий Тогда 
			СтруктураПоиска.Вставить("Серия", Справочники.СерииНоменклатуры.ПустаяСсылка());
			РезультатПоиска = Товары.НайтиСтроки(СтруктураПоиска);
			Если РезультатПоиска.Количество() > 0 Тогда  
				ВычитаемоеЗначение = Мин(РезультатПоиска[0].КоличествоУпаковок, Результат.КоличествоУпаковок);
				РезультатПоиска[0].КоличествоУпаковок = РезультатПоиска[0].КоличествоУпаковок - ВычитаемоеЗначение; 
				НоваяСтрока = Товары.Добавить();
				ЗаполнитьЗначенияСвойств(НоваяСтрока, Результат,,"КоличествоУпаковок");
				НоваяСтрока.КоличествоУпаковок = ВычитаемоеЗначение;
				НоваяСтрока.КоличествоУпаковокРазмещено = Результат.КоличествоУпаковок;

				Если РезультатПоиска[0].КоличествоУпаковок <= 0 Тогда
					Товары.Удалить(РезультатПоиска[0])
				КонецЕсли;
			ОбновитьПодсказку();
			Возврат;
			КонецЕсли;
		КонецЕсли;

		Товары[НомерСтроки].КоличествоУпаковокРазмещено = Результат.КоличествоУпаковок;
		Если Товары[НомерСтроки].Ячейка <> Результат.Ячейка Тогда
			Товары[НомерСтроки].ЯчейкаЗамена = Результат.Ячейка;
		КонецЕсли;
		Товары[НомерСтроки].Серия = Результат.Серия;
		
	Иначе
		
		РезультатПоиска = Товары.НайтиСтроки(СтруктураПоиска);
		Если РезультатПоиска.Количество() > 0 Тогда
			Если Результат.Режим = "РедактированиеПересчет" Тогда
				РезультатПоиска[0].КоличествоУпаковокРазмещено = Результат.КоличествоУпаковок;
			Иначе
				РезультатПоиска[0].КоличествоУпаковокРазмещено = РезультатПоиска[0].КоличествоУпаковокРазмещено + Результат.КоличествоУпаковок;
			КонецЕсли;
			РезультатПоиска[0].Серия = Результат.Серия;
		ИначеЕсли Результат.КоличествоУпаковок > 0 Тогда
			
			Если Результат.Режим = "ОтборИзЯчейкиОтгрузка" Тогда
				СтруктураПоиска.Вставить("Серия", Справочники.СерииНоменклатуры.ПустаяСсылка());
				РезультатПоиска = Товары.НайтиСтроки(СтруктураПоиска);
				Если РезультатПоиска.Количество() > 0 Тогда  
					ВычитаемоеЗначение = Мин(РезультатПоиска[0].КоличествоУпаковок, Результат.КоличествоУпаковок);
					РезультатПоиска[0].КоличествоУпаковок = РезультатПоиска[0].КоличествоУпаковок - ВычитаемоеЗначение; 
					НоваяСтрока = Товары.Добавить();
					ЗаполнитьЗначенияСвойств(НоваяСтрока, Результат,,"КоличествоУпаковок");
					НоваяСтрока.КоличествоУпаковок = ВычитаемоеЗначение;
					НоваяСтрока.КоличествоУпаковокРазмещено = Результат.КоличествоУпаковок;

					Если РезультатПоиска[0].КоличествоУпаковок <= 0 Тогда
						Товары.Удалить(РезультатПоиска[0])
					КонецЕсли; 
				ОбновитьПодсказку();
				Возврат;
				КонецЕсли;
			КонецЕсли;
					
			НоваяСтрока = Товары.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, Результат,,"КоличествоУпаковок");
			НоваяСтрока.КоличествоУпаковокРазмещено = Результат.КоличествоУпаковок;
			
			Если Результат.Режим = "Перемещение" Тогда
				НоваяСтрока.Ячейка             = Ячейка;
				НоваяСтрока.ЯчейкаЗамена       = ЯчейкаЗамена;
				НоваяСтрока.КоличествоУпаковок = НоваяСтрока.КоличествоУпаковокРазмещено;
				НоваяСтрока.УпаковкаРазмещено  = НоваяСтрока.Упаковка;
			ИначеЕсли Результат.Режим = "РазмещениеВЯчейку" Тогда
				НоваяСтрока.ЗаголовокФакт = НСтр("ru = 'Размещено'");
			ИначеЕсли Результат.Режим = "ОтборИзЯчейкиОтгрузка" Тогда
				НоваяСтрока.ЗаголовокФакт = НСтр("ru = 'Отобрано'");
			КонецЕсли;
		КонецЕсли;
		
	КонецЕсли;
	
	Для Каждого СтрокаКодМаркировки Из Результат.ШтрихкодыУпаковок Цикл
			
		НоваяСтрока = ШтрихкодыУпаковок.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаКодМаркировки);
			
	КонецЦикла;
		
	ОбновитьПодсказку();
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработатьШтрихкод(ДанныеШтрихкода)
		
	ШтрихкодыВалидны = МобильноеРабочееМестоКладовщикаКлиент.ШтрихкодыВалидны(ДанныеШтрихкода);
	
	Если Не ШтрихкодыВалидны Тогда
		Возврат;
	КонецЕсли;
	
	Штрихкод = ДанныеШтрихкода.Штрихкод;
	
	Если ШтрихкодДокумента = Штрихкод Тогда 
		ЗакрытьФорму();
		Возврат;
	КонецЕсли;
	
	Если ШтрихкодЯчейки = Штрихкод Тогда
		ЗакрытьФорму();
		Возврат;
	КонецЕсли;

	ДанныеЯчейки = ДанныеЯчейкиПоШК(Штрихкод); 
		
	Если ЗначениеЗаполнено(ДанныеЯчейки.Ячейка) Тогда  
		РезультатСканированияЯчейки(ДанныеЯчейки);
		Возврат;
	КонецЕсли;

	ДанныеТоваров = ДанныеТоваровПоШК(ДанныеШтрихкода.Штрихкод);
			
	Если ЗначениеЗаполнено(ДанныеТоваров) Тогда	
		РезультатСканированияТовара(ДанныеТоваров);
		Возврат;
	КонецЕсли;
	
	Состояние(НСтр("ru = 'Номенклатура или ячейка по штрихкоду не найдена'"));
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ДанныеТоваровПоШК(Штрихкод)
	
	Возврат Обработки.МобильноеРабочееМестоКладовщика.ДанныеТоваровПоШК(Штрихкод);
	
КонецФункции

&НаСервере
Функция ДанныеЯчейкиПоШК(Знач Штрихкод) 
	
	Возврат Обработки.МобильноеРабочееМестоКладовщика.ДанныеЯчейкиПоШК(Склад, Помещение, Штрихкод);
	
КонецФункции

&НаКлиенте
Процедура ПослеЗакрытияВопросаВыбор(Результат, Параметры) Экспорт
	
	Если Результат = Неопределено 
		Или Результат = "Отмена" Тогда
		Возврат;
	КонецЕсли;
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("Склад", Склад);
	ПараметрыФормы.Вставить("Помещение", Помещение);
	ПараметрыФормы.Вставить("ДокументСсылка", Ссылка);
		
	Если Результат = "Ячейка" Тогда
		
		Описание = Новый ОписаниеОповещения("РезультатСканированияЯчейки", ЭтотОбъект);
		ПараметрыФормы.Вставить("ТипПоиска", "ПоискЯчейки");
		
	ИначеЕсли Результат = "Товар" Тогда
		
		Описание = Новый ОписаниеОповещения("РезультатСканированияТовара", ЭтотОбъект);
		ПараметрыФормы.Вставить("ТипПоиска", "ПоискНоменклатуры");
		ПараметрыФормы.Вставить("Организация", Организация);
		
	КонецЕсли;
	
	Если ИспользуемыйСерверФормы = ИспользуемыйСервер.Основной Тогда
		ОткрытьФорму(
		"Обработка.МобильноеРабочееМестоКладовщика.Форма.СканированиеШтрихкода",ПараметрыФормы,
		ЭтотОбъект,,,,Описание,
		РежимОткрытияОкнаФормы.Независимый);
	Иначе
		ОткрытьФорму(
		"Обработка.МобильноеРабочееМестоКладовщика.Форма.СканированиеШтрихкодаАвтономныйРежим",ПараметрыФормы,
		ЭтотОбъект,,,,Описание,
		РежимОткрытияОкнаФормы.Независимый);
	КонецЕсли;
			
КонецПроцедуры

&НаКлиенте
Процедура РезультатСканированияТовара(Результат = Неопределено, ДополнительныеПараметры = Неопределено) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если Результат.Количество() > 1 Тогда 
		
		Описание = Новый ОписаниеОповещения("РезультатСканированияТовара", ЭтотОбъект);
		
		ЗначенияЗаполнения = Новый Структура;
		ЗначенияЗаполнения.Вставить("Товары", Результат);
		ЗначенияЗаполнения.Вставить("Режим", "ВыборНоменклатуры");
		ЗначенияЗаполнения.Вставить("Штрихкод", "");
		
		ПараметрыФормы = Новый Структура;
		ПараметрыФормы.Вставить("РезультатСканирования", ЗначенияЗаполнения);
	
		ОткрытьФорму(
			"Обработка.МобильноеРабочееМестоКладовщика.Форма.ФормаВыбораСканирование", ПараметрыФормы,
			ЭтотОбъект,,,,Описание, РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
		
	Иначе
		
		ДанныеТовара = Результат[0];
		
		СтруктураПоиска = Новый Структура;
		СтруктураПоиска.Вставить("Номенклатура",   ДанныеТовара.Номенклатура);
		СтруктураПоиска.Вставить("Характеристика", ДанныеТовара.Характеристика);
		СтруктураПоиска.Вставить("Упаковка",       ДанныеТовара.Упаковка);
		
		Описание = Новый ОписаниеОповещения("ОбновитьФорму", ЭтотОбъект);
		
		ПараметрыФормы = Новый Структура;
			
		РезультатПоиска = Товары.НайтиСтроки(СтруктураПоиска);
		
		Если Не ТипОперации = 3 Или Режим = "РедактированиеПеремещение" Тогда
			
			Если РезультатПоиска.Количество() > 0 Тогда
						
				ПараметрыФормы.Вставить("Номенклатура",   РезультатПоиска[0].Номенклатура);
				ПараметрыФормы.Вставить("Характеристика", РезультатПоиска[0].Характеристика);
				ПараметрыФормы.Вставить("Серия",          РезультатПоиска[0].Серия);
				ПараметрыФормы.Вставить("Назначение",     РезультатПоиска[0].Назначение);
				ПараметрыФормы.Вставить("Упаковка",       РезультатПоиска[0].Упаковка);
				ПараметрыФормы.Вставить("НомерСтроки",    Товары.Индекс(Элементы.Товары.ТекущиеДанные));
						
				Если ТипОперации = 1 Тогда
					ПараметрыФормы.Вставить("Режим", "РазмещениеВЯчейку");
				ИначеЕсли ТипОперации = 2 Тогда
					ПараметрыФормы.Вставить("Режим", "ОтборИзЯчейкиОтгрузка");
					ПараметрыФормы.Вставить("РаспоряжениеНаОтбор", РаспоряжениеНаОтбор);
				ИначеЕсли ТипОперации = 4 Тогда
					ПараметрыФормы.Вставить("Режим", "Пересчет");
				Иначе
					ПараметрыФормы.Вставить("Режим", "Просмотр");
				КонецЕсли;
				
				Если РезультатПоиска[0].ЯчейкаЗамена.Пустая() Тогда
					ПараметрыФормы.Вставить("Ячейка", РезультатПоиска[0].Ячейка);
				Иначе
					ПараметрыФормы.Вставить("Ячейка", РезультатПоиска[0].ЯчейкаЗамена);
				КонецЕсли;
			
			Иначе
				
				Если ТипОперации = 1 Тогда
					ТекстОперации = НСтр("ru = 'размещение'");
				ИначеЕсли ТипОперации = 2 Тогда
					ТекстОперации = НСтр("ru = 'отбор'");	
				ИначеЕсли ТипОперации = 3 Тогда	
					ТекстОперации = НСтр("ru = 'перемещение'");	
				Иначе
					ТекстОперации = НСтр("ru = 'пересчет'");
				КонецЕсли;
				
				ТекстОшибки = СтрШаблон(НСтр("ru = 'Не требуется %1 номенклатуры %2 в упаковке %3'"), ТекстОперации, 
					ДанныеТовара.Номенклатура, ДанныеТовара.Упаковка);
					
				Состояние(ТекстОшибки); 
				Возврат;
				
			КонецЕсли;
			
		Иначе
			
			ПараметрыФормы.Вставить("Номенклатура", ДанныеТовара.Номенклатура);
			ПараметрыФормы.Вставить("Характеристика", ДанныеТовара.Характеристика);
			ПараметрыФормы.Вставить("Упаковка",       ДанныеТовара.Упаковка);
			ПараметрыФормы.Вставить("Серия", ДанныеТовара.Серия);
			Если ТипОперации = 3 Тогда
				ПараметрыФормы.Вставить("Режим", "Перемещение");
			Иначе
				ПараметрыФормы.Вставить("Режим", "Просмотр");
			КонецЕсли;
			ПараметрыФормы.Вставить("НомерСтроки", 0);
			
			Если ЯчейкаЗамена.Пустая() Тогда
				ПараметрыФормы.Вставить("Ячейка", Ячейка);
			Иначе
				ПараметрыФормы.Вставить("Ячейка", ЯчейкаЗамена);
			КонецЕсли;

		КонецЕсли;
			
		ПараметрыФормы.Вставить("Склад", Склад);
		ПараметрыФормы.Вставить("Помещение", Помещение); 
		ПараметрыФормы.Вставить("Количество", ДанныеТовара.Количество);
		ПараметрыФормы.Вставить("ПоказыватьФотоТоваров", ПоказыватьФотоТоваров);
		ПараметрыФормы.Вставить("Источник", Ссылка);
		ПараметрыФормы.Вставить("ШтрихкодДокумента", ШтрихкодДокумента);
		ПараметрыФормы.Вставить("ШтрихкодУпаковки", ДанныеТовара.ШтрихкодУпаковки);
		ПараметрыФормы.Вставить("ПорядокСканирования", ПорядокСканирования);
		
		ОткрытьФорму(
			"Обработка.МобильноеРабочееМестоКладовщика.Форма.КарточкаТовара",ПараметрыФормы,
			ЭтотОбъект,,,,Описание,
			РежимОткрытияОкнаФормы.Независимый);
			
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура РезультатСканированияЯчейки(Результат = Неопределено, ДополнительныеПараметры = Неопределено) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если Результат.Ячейка = Ячейка
		Или Результат.Ячейка = ЯчейкаЗамена Тогда
		ЗакрытьФорму();
	ИначеЕсли ТипОперации = 3 И Не ЗначениеЗаполнено(ЯчейкаЗамена) Тогда	
		УстановитьЯчейку(Результат.Ячейка);
	Иначе
		ЗакрытьФорму(Результат);
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура УстановитьЯчейку(Результат) 
		
	ЯчейкаЗамена = Результат;
	
	Для Каждого Строка Из Товары Цикл
		Строка.ЯчейкаЗамена = ЯчейкаЗамена;
	КонецЦикла;
	
КонецПроцедуры 

&НаСервере
Функция СерииНоменклатурыПриОтгрузке(Знач Номенклатура)
	
	ВидНоменклатуры =  МобильноеРабочееМестоКладовщика.ЗначениеРеквизитаОбъекта(Номенклатура, "ВидНоменклатуры");
	ПолитикаУчетаСерий = Обработки.МобильноеРабочееМестоКладовщика.ПолитикаУчетаСерий(ВидНоменклатуры, Склад);
	Если ЗначениеЗаполнено(ПолитикаУчетаСерий) Тогда
		СерииПриОтгрузке = МобильноеРабочееМестоКладовщика.ЗначенияРеквизитовОбъекта(ПолитикаУчетаСерий, "УказыватьПоФактуОтбора,
		|	УчитыватьОстаткиСерий");
	Иначе
		СерииПриОтгрузке = Новый Структура("УказыватьПоФактуОтбора,
		|	УчитыватьОстаткиСерий", Ложь, Ложь);
	КонецЕсли;
	
	Возврат СерииПриОтгрузке;
	
КонецФункции
#КонецОбласти