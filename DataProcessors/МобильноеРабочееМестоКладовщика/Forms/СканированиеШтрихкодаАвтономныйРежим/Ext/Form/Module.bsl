
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ТипПоиска = Параметры.ТипПоиска;
	Контекст = Параметры.Контекст;
	
	Если ЗначениеЗаполнено(Параметры.Склад) Тогда
		Склад = Параметры.Склад;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Параметры.Помещение) Тогда
		Помещение = Параметры.Помещение;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Параметры.ДокументСсылка) Тогда
		Ссылка = Параметры.ДокументСсылка;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Параметры.ШтрихкодыУпаковок) Тогда
		ШтрихкодыУпаковок.Загрузить(Параметры.ШтрихкодыУпаковок.Выгрузить());
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Параметры.Организация) Тогда
		Организация = Параметры.Организация;
	КонецЕсли;
	
	УстановитьЗаголовок();
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
#Если МобильныйКлиент Тогда
	ТекущийЭлемент = Элементы.Штрихкод;
	НачатьРедактированиеЭлемента();
#КонецЕсли
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	// ПодключаемоеОборудование
	Если Источник = "ПодключаемоеОборудование" И ВводДоступен() Тогда
		
		Если ИмяСобытия = "ScanData" И МобильноеРабочееМестоКладовщикаКлиент.ЕстьНеобработанноеСобытие() Тогда

			ОбработатьШтрихкод(МобильноеРабочееМестоКладовщикаКлиент.ПреобразоватьДанныеСоСканераВСтруктуру(Параметр));
			
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура ШтрихкодОкончаниеВводаТекста(Элемент, Текст, ДанныеВыбора, ПараметрыПолученияДанных, СтандартнаяОбработка)
	
	ДанныеШтрихкода = Новый Структура("Штрихкод", Текст);
	ДанныеШтрихкода.Вставить("Количество", 1);
	
	ОбработатьШтрихкод(ДанныеШтрихкода);
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура НайтиПоШтрихкоду(Команда)
	
	ДанныеШтрихкода = Новый Структура("Штрихкод", Штрихкод);
	ДанныеШтрихкода.Вставить("Количество", 1);
	
	ОбработатьШтрихкод(ДанныеШтрихкода);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура УстановитьЗаголовок()
	
	Если ТипПоиска = "ПоискЯчейки" Тогда
		Элементы.Заголовок.Заголовок = НСтр("ru = 'Отсканируйте штрихкод ячейки'");
	ИначеЕсли ТипПоиска = "ПоискНоменклатуры" Тогда
		Элементы.Заголовок.Заголовок = НСтр("ru = 'Отсканируйте штрихкод номенклатуры'"); 
	ИначеЕсли ТипПоиска = "ПоискДокумента" Тогда
		Элементы.Заголовок.Заголовок = НСтр("ru = 'Отсканируйте штрихкод документа'");
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция ДанныеЯчейкиПоШК(Знач Штрихкод)
	
	Возврат Обработки.МобильноеРабочееМестоКладовщика.ДанныеЯчейкиПоШК(Склад, Помещение, Штрихкод);
	
КонецФункции

&НаСервереБезКонтекста
Функция ДанныеТоваровПоШК(Штрихкод)
	
	Возврат Обработки.МобильноеРабочееМестоКладовщика.ДанныеТоваровПоШК(Штрихкод);
	
КонецФункции

&НаСервере
Функция ДанныеДокументаПоШК(Знач Штрихкод)
			
	Возврат Обработки.МобильноеРабочееМестоКладовщика.ДанныеСкладскогоДокументаПоШК(Штрихкод, Контекст); 

КонецФункции

&НаКлиенте
Процедура ОбработатьШтрихкод(ДанныеШтрихкода)

	Если ТипПоиска = "ПоискЯчейки" Тогда
		
		ДанныеЯчейки = ДанныеЯчейкиПоШК(ДанныеШтрихкода.Штрихкод);
		
		Если ЗначениеЗаполнено(ДанныеЯчейки.Ячейка) Тогда
			Закрыть(ДанныеЯчейки);
			Возврат;
		КонецЕсли;

		Состояние(НСтр("ru = 'Ячейка по штрихкоду не найдена'"));
	
	ИначеЕсли ТипПоиска = "ПоискНоменклатуры" Тогда
		
		Если МобильноеРабочееМестоКладовщикаКлиент.ШтрихкодыВалидны(ДанныеШтрихкода) Тогда

			ДанныеТоваров = ДанныеТоваровПоШК(ДанныеШтрихкода.Штрихкод);
				
			Если ЗначениеЗаполнено(ДанныеТоваров) Тогда
				Закрыть(ДанныеТоваров);
				Возврат;
			Иначе
				Состояние(НСтр("ru = 'Номенклатура по штрихкоду не найдена'"));
			КонецЕсли;
		КонецЕсли;
		
	ИначеЕсли ТипПоиска = "ПоискДокумента" Тогда 
		
		ДанныеДокумента = ДанныеДокументаПоШК(ДанныеШтрихкода.Штрихкод);
	
		Если ЗначениеЗаполнено(ДанныеДокумента.Ссылки) Тогда
			Если ЗначениеЗаполнено(ДанныеДокумента.ТекстОшибки) Тогда
				Состояние(ДанныеДокумента.ТекстОшибки);	
				Возврат;
			Иначе
				Закрыть(ДанныеДокумента);
				Возврат;
			КонецЕсли;
		КонецЕсли;
		
		Состояние(НСтр("ru = 'Документ по штрихкоду не найден'"));
	КонецЕсли;
	
КонецПроцедуры

#Если МобильныйКлиент Тогда

&НаКлиенте
Процедура СканированиеШтрихКодов(Команда)
	
	Если СредстваМультимедиа.ПоддерживаетсяСканированиеШтрихКодов() Тогда
		
		ОбработчикСканирования = Новый ОписаниеОповещения("ОбработкаСканирования", ЭтотОбъект);
		
		СредстваМультимедиа.ПоказатьСканированиеШтрихКодов(НСтр("ru = 'Наведите камеру на штрихкод'"),
			ОбработчикСканирования,
			,
			ТипШтрихКода.Линейный);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаСканирования(ШтрихкодКамера, Результат, Сообщение, ДополнительныеПараметры) Экспорт

	Если Результат Тогда
		
		СредстваМультимедиа.ВоспроизвестиЗвуковоеОповещение(ЗвуковоеОповещение.ПоУмолчанию,Истина);
		СредстваМультимедиа.ЗакрытьСканированиеШтрихКодов();
		
		ДанныеШтрихкода = Новый Структура("Штрихкод", ШтрихкодКамера);
		ДанныеШтрихкода.Вставить("Количество", 1);
		
		ОбработатьШтрихкод(ДанныеШтрихкода);
		
	Иначе
		
		Сообщение = НСтр("ru = 'Ошибка обработки штрихкода'");
		
	КонецЕсли;
КонецПроцедуры

#КонецЕсли

#КонецОбласти