			Элементы.ВыбратьЯчейку.Заголовок = Ячейка;
		КонецЕсли;
		
		Элементы.ГруппаСерия.Видимость = Истина;
		ИспользоватьСерии = Истина;
		
	КонецЕсли;
	
	Элементы.Количество.Шрифт = Новый Шрифт(, 16, Истина, , , );
	
	Если Не ИспользоватьСерии Тогда
		Элементы.Серия.Доступность = Ложь;
		Элементы.СоздатьСерию.Видимость = Ложь;
	Иначе
#Если МобильныйАвтономныйСервер Тогда
		Элементы.Серия.КнопкаСоздания = Ложь;
		Элементы.СоздатьСерию.Видимость = Ложь;
#КонецЕсли
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработатьШтрихкод(ДанныеШтрихкода)
		
	ШтрихкодыВалидны = МобильноеРабочееМестоКладовщикаКлиент.ШтрихкодыВалидны(ДанныеШтрихкода); 
	
	Если Не ШтрихкодыВалидны Тогда
		Возврат;
	КонецЕсли;
	
	Штрихкод = ДанныеШтрихкода.Штрихкод;
	
	Если ШтрихкодДокумента = Штрихкод Тогда
		Если Элементы.ВыбратьЯчейку.Видимость Тогда
			Если ПорядокСканирования = "СначалаСканированиеЯчейки" Тогда
				ЗакрытьКарточкуТовара(,,Истина);
			ИначеЕсли Ячейка.Пустая() Тогда
				Состояние(НСтр("ru = 'Укажите ячейку'"));
			Иначе
				ЗакрытьКарточкуТовара();
			КонецЕсли;
		Иначе
			ЗакрытьКарточкуТовара();
		КонецЕсли;
		Возврат;	
	КонецЕсли;
	
	Если ИспользоватьСерии Тогда
		
		ПараметрыСерии = ПолучитьПараметрыСерииНаСервере(Штрихкод);
				
		Если ЗначениеЗаполнено(ПараметрыСерии.Серия) Тогда
			Серия = ПараметрыСерии.Серия;
			КоличествоУпаковок = КоличествоУпаковок + 1;
			Возврат;
		КонецЕсли;
	КонецЕсли;
	
	ДанныеТоваров = ДанныеТоваровПоШК(Штрихкод);
	
	Если ЗначениеЗаполнено(ДанныеТоваров) Тогда
		Если ДанныеТоваров.Количество() > 1 Тогда
			ЗакрытьКарточкуТовара(ДанныеТоваров);
		ИначеЕсли ДанныеТоваров[0].Номенклатура = Номенклатура
			И ДанныеТоваров[0].Характеристика = Характеристика
			И ДанныеТоваров[0].Упаковка = Упаковка
			И (ДанныеТоваров[0].Серия = Серия Или Не ИспользоватьСерии) Тогда
			
			КоличествоУпаковок = КоличествоУпаковок + ДанныеТоваров[0].Количество;
		Иначе
			ЗакрытьКарточкуТовара(ДанныеТоваров);
		КонецЕсли;
		Возврат;
	КонецЕсли;
	
	Если Элементы.ВыбратьЯчейку.Видимость Тогда 
		
		ДанныеЯчейки = ДанныеЯчейкиПоШК(Штрихкод); 
		Если ЗначениеЗаполнено(ДанныеЯчейки.Ячейка) Тогда
			Если ДанныеЯчейки.Ячейка = Ячейка Тогда
				ЗакрытьКарточкуТовара(); 
			ИначеЕсли Режим = "Перемещение" Тогда 
				ЗакрытьКарточкуТовара(,ДанныеЯчейки, Истина);
			Иначе
				ЗакрытьКарточкуТовара(,ДанныеЯчейки);
			КонецЕсли;
		
			Возврат;
		КонецЕсли;
		
		Состояние(НСтр("ru = 'Номенклатура или ячейка по штрихкоду не найдена'"));
		Возврат;
		
	КонецЕсли;
	
	Состояние(НСтр("ru = 'Номенклатура по штрихкоду не найдена'"));

КонецПроцедуры

&НаСервере
Процедура ЗагрузитьФотоТовара()

#Если НЕ МобильныйАвтономныйСервер Тогда
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	НоменклатураПрисоединенныеФайлы.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.НоменклатураПрисоединенныеФайлы КАК НоменклатураПрисоединенныеФайлы
		|ГДЕ
		|	НоменклатураПрисоединенныеФайлы.ВладелецФайла = &ВладелецФайла
		|	И НЕ НоменклатураПрисоединенныеФайлы.ПометкаУдаления";
	
	Запрос.УстановитьПараметр("ВладелецФайла", Номенклатура);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Сч = 1;
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		
		Если Сч > 3 Тогда
			Продолжить;
		КонецЕсли;
		
		СсылкаНаДДФ = РаботаСФайлами.ДанныеФайла(ВыборкаДетальныеЗаписи.Ссылка, УникальныйИдентификатор).СсылкаНаДвоичныеДанныеФайла;
		ЭтотОбъект["ФотоТовара" + Сч] = СсылкаНаДДФ;
		
		Сч = Сч + 1;
		
	КонецЦикла;	
#КонецЕсли
КонецПроцедуры

&НаСервере
Функция ЕдиницаИзмеренияНоменклатуры()
	
	Возврат Обработки.МобильноеРабочееМестоКладовщика.ПолучитьРеквизитСправочника(Номенклатура, "ЕдиницаИзмерения");
	
КонецФункции

&НаКлиенте
Процедура РезультатЗаменыЯчейки(Результат = Неопределено, ДополнительныеПараметры = Неопределено) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Ячейка = Результат;
	Элементы.ВыбратьЯчейку.Заголовок = Ячейка;
	
	Если Режим = "РазмещениеВЯчейку" Или Режим = "РедактированиеРазмещениеПоЯчейкам" 
		Или Режим = "Перемещение" Или Режим = "ОтборИзЯчейки" Или Режим = "РедактированиеОтборИзЯчейки" 
		Или Режим = "ОтборИзЯчейкиОтгрузка" Или Режим = "РедактированиеОтборИзЯчейкиОтгрузка" Тогда
		
		Назначение = Неопределено;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПослеЗакрытияВопросаФото(Результат, Параметры) Экспорт
	
	Если Результат = "ВыбратьФото" Тогда
		
#Если МобильныйКлиент Тогда
		Выполнить("РаботаСФайламиКлиент.ДобавитьФайлы(Номенклатура, УникальныйИдентификатор, , Неопределено)");
#Иначе
		РаботаСФайламиКлиент.ДобавитьФайлы(Номенклатура, УникальныйИдентификатор, , Неопределено);
#КонецЕсли
		ЗагрузитьФотоТовара();
		УстановитьУсловноеОформление();
		
	ИначеЕсли Результат = "СделатьФото" Тогда
		
#Если МобильныйКлиент Тогда
		ДвоичныеДанные = ПолучитьДанныеФотоСнимка();
		ПрисоединитьФайл(ДвоичныеДанные);
		ЗагрузитьФотоТовара();
		УстановитьУсловноеОформление();
#Иначе
		Состояние(НСтр("ru = 'Данное устройство не поддерживает фотоснимок'"));
#КонецЕсли
		
	Иначе
		Возврат;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ИзменитьШтрихкодыУпаковок(Результат, Параметры) Экспорт
	
	ИзменитьШтрихкодыУпаковокНаСервере(Результат);
	
КонецПроцедуры

&НаСервере
Процедура ИзменитьШтрихкодыУпаковокНаСервере(Результат)
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ШтрихкодыУпаковок.Очистить();
	ШтрихкодыУпаковок.Загрузить(Результат.Выгрузить());
	
КонецПроцедуры

&НаКлиенте
Функция ПолучитьДанныеФотоСнимка()
	
	Данные = Неопределено;
	
#Если МобильныйКлиент Тогда 
		
	Если СредстваМультимедиа.ПоддерживаетсяФотоснимок() Тогда
			
		Данные = СредстваМультимедиа.СделатьФотоснимок();
			
		Возврат Данные.ПолучитьДвоичныеДанные();
			
	Иначе
		Состояние(НСтр("ru = 'Данное устройство не поддерживает фотоснимок'"));
	КонецЕсли;
		
#КонецЕсли
	
	Возврат Данные;
	
КонецФункции

&НаСервере
Процедура ПрисоединитьФайл(ДвоичныеДанные)

#Если НЕ МобильныйАвтономныйСервер Тогда
	
	ВременноеХранилище                = ПоместитьВоВременноеХранилище(ДвоичныеДанные);
	ПараметрыФайла                    = РаботаСФайлами.ПараметрыДобавленияФайла();
	ПараметрыФайла.Автор              = Пользователи.ТекущийПользователь();
	ПараметрыФайла.ИмяБезРасширения   = Строка(Номенклатура);
	ПараметрыФайла.РасширениеБезТочки = "jpg";
	ПараметрыФайла.ВладелецФайлов = Номенклатура;
	РаботаСФайлами.ДобавитьФайл(ПараметрыФайла, ВременноеХранилище);
	
#КонецЕсли

КонецПроцедуры

