&НаСервере
Процедура ЗаполнитьСвязиПараметровВыбораНазначения()
	
	СвязиПараметровВыбора = Новый Массив();
	ПараметрыВыбора = Новый Массив();
	
	Если Режим = "Отгрузка" ИЛИ Режим = "РедактированиеОтгрузка" 
		ИЛИ Режим = "ПересчетОтгрузка" ИЛИ Режим = "РедактированиеПересчетОтгрузка" 
		ИЛИ Режим = "Пересчет" ИЛИ Режим = "РедактированиеПересчет" Тогда
		
		СвязиПараметровВыбора.Добавить(Новый СвязьПараметраВыбора("Номенклатура", "Номенклатура", РежимИзмененияСвязанногоЗначения.Очищать));
		СвязиПараметровВыбора.Добавить(Новый СвязьПараметраВыбора("Характеристика", "Характеристика", РежимИзмененияСвязанногоЗначения.Очищать));
		СвязиПараметровВыбора.Добавить(Новый СвязьПараметраВыбора("Склад", "Склад", РежимИзмененияСвязанногоЗначения.НеИзменять));
		СвязиПараметровВыбора.Добавить(Новый СвязьПараметраВыбора("Источник", "ДокументИсточник", РежимИзмененияСвязанногоЗначения.Очищать));
		
		ПараметрыВыбора.Добавить(Новый ПараметрВыбора("Отбор.ДвиженияПоСкладскимРегистрам", Истина));
		
	ИначеЕсли Режим = "Приемка" ИЛИ Режим = "РедактированиеПриемка" Тогда
		
		СвязиПараметровВыбора.Добавить(Новый СвязьПараметраВыбора("Номенклатура", "Номенклатура", РежимИзмененияСвязанногоЗначения.Очищать));
		СвязиПараметровВыбора.Добавить(Новый СвязьПараметраВыбора("Характеристика", "Характеристика", РежимИзмененияСвязанногоЗначения.Очищать));
		СвязиПараметровВыбора.Добавить(Новый СвязьПараметраВыбора("Склад", "Склад", РежимИзмененияСвязанногоЗначения.НеИзменять));
		СвязиПараметровВыбора.Добавить(Новый СвязьПараметраВыбора("Источник", "ДокументИсточник", РежимИзмененияСвязанногоЗначения.НеИзменять));
		СвязиПараметровВыбора.Добавить(Новый СвязьПараметраВыбора("Распоряжение", "РаспоряжениеНаПоступление", РежимИзмененияСвязанногоЗначения.НеИзменять));
		СвязиПараметровВыбора.Добавить(Новый СвязьПараметраВыбора("ВидОперации", "СкладскаяОперация", РежимИзмененияСвязанногоЗначения.НеИзменять));
		
		ПараметрыВыбора.Добавить(Новый ПараметрВыбора("ТолькоСкладскиеНазначения", Истина));
		ВариантыВыбора = Новый Массив;
		ВариантыВыбора.Добавить(0);
		ВариантыВыбора.Добавить(5);
		ПараметрыВыбора.Добавить(Новый ПараметрВыбора("ВариантыВыбора", Новый ФиксированныйМассив(ВариантыВыбора)));
		
	ИначеЕсли Режим = "РазмещениеВЯчейку" ИЛИ Режим = "РедактированиеРазмещениеПоЯчейкам" Тогда
		
		ВидОперации = Перечисления.ВидыОперацийОтбораРазмещенияТоваров.Размещение;
		
		СвязиПараметровВыбора.Добавить(Новый СвязьПараметраВыбора("Номенклатура", "Номенклатура", РежимИзмененияСвязанногоЗначения.Очищать));
		СвязиПараметровВыбора.Добавить(Новый СвязьПараметраВыбора("Характеристика", "Характеристика", РежимИзмененияСвязанногоЗначения.Очищать));
		СвязиПараметровВыбора.Добавить(Новый СвязьПараметраВыбора("Склад", "Склад", РежимИзмененияСвязанногоЗначения.НеИзменять));
		СвязиПараметровВыбора.Добавить(Новый СвязьПараметраВыбора("Источник", "ДокументИсточник", РежимИзмененияСвязанногоЗначения.Очищать));
		СвязиПараметровВыбора.Добавить(Новый СвязьПараметраВыбора("Ячейка", "Ячейка", РежимИзмененияСвязанногоЗначения.НеИзменять));
		СвязиПараметровВыбора.Добавить(Новый СвязьПараметраВыбора("ВидОперации", "ВидОперации", РежимИзмененияСвязанногоЗначения.НеИзменять));
		
		ПараметрыВыбора.Добавить(Новый ПараметрВыбора("Отбор.ДвиженияПоСкладскимРегистрам", Истина));
		
	ИначеЕсли Режим = "Перемещение" Тогда
		
