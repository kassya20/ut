		ПараметрыВыбора.Добавить(Новый ПараметрВыбора("Отбор.ДвиженияПоСкладскимРегистрам", Истина));
		
	ИначеЕсли Режим = "ОтборИзЯчейки" ИЛИ Режим = "РедактированиеОтборИзЯчейки" 
		ИЛИ Режим = "ОтборИзЯчейкиОтгрузка" ИЛИ Режим = "РедактированиеОтборИзЯчейкиОтгрузка" Тогда
		
		ВидОперации = Перечисления.ВидыОперацийОтбораРазмещенияТоваров.Отбор;
		
		СвязиПараметровВыбора.Добавить(Новый СвязьПараметраВыбора("Номенклатура", "Номенклатура", РежимИзмененияСвязанногоЗначения.Очищать));
		СвязиПараметровВыбора.Добавить(Новый СвязьПараметраВыбора("Характеристика", "Характеристика", РежимИзмененияСвязанногоЗначения.Очищать));
		СвязиПараметровВыбора.Добавить(Новый СвязьПараметраВыбора("Склад", "Склад", РежимИзмененияСвязанногоЗначения.НеИзменять));
		СвязиПараметровВыбора.Добавить(Новый СвязьПараметраВыбора("Источник", "ДокументИсточник", РежимИзмененияСвязанногоЗначения.Очищать));
		СвязиПараметровВыбора.Добавить(Новый СвязьПараметраВыбора("Ячейка", "Ячейка", РежимИзмененияСвязанногоЗначения.НеИзменять));
		СвязиПараметровВыбора.Добавить(Новый СвязьПараметраВыбора("ВидОперации", "ВидОперации", РежимИзмененияСвязанногоЗначения.НеИзменять));
		СвязиПараметровВыбора.Добавить(Новый СвязьПараметраВыбора("Распоряжение", "РаспоряжениеНаОтбор", РежимИзмененияСвязанногоЗначения.НеИзменять));
		
		ПараметрыВыбора.Добавить(Новый ПараметрВыбора("Отбор.ДвиженияПоСкладскимРегистрам", Истина));
		ПараметрыВыбора.Добавить(Новый ПараметрВыбора("РежимВыбораНазначений", "ОстаткиВЯчейке"));
		
	КонецЕсли;
	
	Элементы.Назначение.СвязиПараметровВыбора = Новый ФиксированныйМассив(СвязиПараметровВыбора);
	Элементы.Назначение.ПараметрыВыбора = Новый ФиксированныйМассив(ПараметрыВыбора);
	
КонецПроцедуры

&НаКлиенте
Процедура ХарактеристикаНачалоВыбора(Элемент, ДанныеВыбора, ВыборДобавлением, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	ПараметрыФормы = Новый Структура();
	ПараметрыФормы.Вставить("Номенклатура", Номенклатура);
	
	ВыборХарактеристики = Новый ОписаниеОповещения("ВыборХарактеристики", ЭтотОбъект);
	Если ИспользуемыйСерверФормы = ИспользуемыйСервер.Основной Тогда
		ОткрытьФорму("Справочник.ХарактеристикиНоменклатуры.Форма.ФормаВыбора", ПараметрыФормы, ЭтотОбъект,,,, ВыборХарактеристики);
	Иначе
		ОткрытьФорму("Справочник.ХарактеристикиНоменклатуры.Форма.ФормаВыбораАвтономныйРежим", ПараметрыФормы, ЭтотОбъект,,,, ВыборХарактеристики);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ВыборХарактеристики(Результат = Неопределено, ДополнительныеПараметры = Неопределено) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Характеристика = Результат;
	
КонецПроцедуры

#КонецОбласти