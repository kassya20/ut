&НаКлиенте
Процедура ОтменитьЗаданиеНаРазмещение(Команда)
	
	СписокЗначений = Новый СписокЗначений;
	СписокЗначений.Добавить("Завершить", НСтр("ru = 'Пометить документ на удаление'"));
	СписокЗначений.Добавить("Продолжить", НСтр("ru = 'Продолжить размещение'"));
	
	Оповещение = Новый ОписаниеОповещения("ПослеЗакрытияВопросаОтменитьЗаданиеНаРазмещение", ЭтотОбъект);
	ПоказатьВопрос(Оповещение, НСтр("ru = 'Для отмены размещения необходимо пометить на удаление документ размещения. Вернуться к редактированию будет невозможно. Пометить на удаление?'"), СписокЗначений, 0);
	
КонецПроцедуры

&НаКлиенте
Процедура ПослеЗакрытияВопросаОтменитьЗаданиеНаРазмещение(Результат, Параметры) Экспорт
	
	Если Результат = "Завершить" Тогда
		
		РазмещениеОтменено = ОтменитьЗаданиеНаРазмещениеНаСервере();
		
		Если РазмещениеОтменено Тогда
			Если Элементы.ГруппаСтраницы.ТекущаяСтраница = Элементы["СтраницаИнформация"] Тогда
				Закрыть();
			КонецЕсли;
			Закрыть();
		КонецЕсли;
		
	Иначе
		Возврат;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция ОтменитьЗаданиеНаРазмещениеНаСервере()
	
#Если МобильныйАвтономныйСервер Тогда
	Возврат Ложь;
#Иначе
	Попытка
		ДокументОбъект = Ссылка.ПолучитьОбъект();
		ДокументОбъект.УстановитьПометкуУдаления(Истина);
		
		ОбеспечениеВДокументахСервер.ПроверитьЗапуститьФоновоеЗаданиеРаспределенияЗапасов();
	Исключение
		ОбщегоНазначения.СообщитьПользователю(НСтр("ru = 'Не удалось отменить задание на размещение.'"));
		
		Возврат Ложь;
	КонецПопытки;
	
	Возврат Истина;
#КонецЕсли
		
КонецФункции

