#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Если Параметры.Свойство("СтруктураЗаполнения") Тогда
		
		СтруктураЗаполнения = Параметры.СтруктураЗаполнения;
		
		РаспоряжениеНаПоступление = СтруктураЗаполнения.Распоряжение;
		КонтролируемаяПартия = СтруктураЗаполнения.КонтролируемаяПартия;
		Если Не СоздатьПриходныйОрдер(СтруктураЗаполнения) Тогда
			Отказ = Истина;
			Возврат;
		КонецЕсли;
		
	Иначе
		Ссылка = Параметры.Ссылка;
#Если Не МобильныйАвтономныйСервер Тогда
		ЗаполнямыеРеквизиты = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Ссылка,
			"Распоряжение,КонтролируемаяПартия");
		РаспоряжениеНаПоступление = ЗаполнямыеРеквизиты.Распоряжение;
		КонтролируемаяПартия = ЗаполнямыеРеквизиты.КонтролируемаяПартия;
#Иначе
		РаспоряжениеНаПоступление = Параметры.Ссылка.Распоряжение;
#КонецЕсли

	КонецЕсли;
	
	ПоказыватьФотоТоваров = Параметры.ПоказыватьФотоТоваров;
	Штрихкод = Параметры.Штрихкод;
	ПорядокСканирования = Параметры.ПорядокСканирования;

	ЗаполнитьФорму();
	
	//++ Локализация
	
	ИспользоватьУчетМаркируемойПродукции = Константы.ВестиУчетМаркируемойПродукцииИСМП.Получить();

#Если Не МобильныйАвтономныйСервер Тогда
	ПроверкаИПодборПродукцииИСПереопределяемый.ПриОпределенииОрганизации(Ссылка, Организация);

	ЕстьМаркируемаяПродукция = Ложь;
	ВидыПродукцииИСМП = ОбщегоНазначенияИСМПКлиентСерверПовтИсп.УчитываемыеВидыМаркируемойПродукции();
	ПроверкаИПодборПродукцииИСМПУТ.ЕстьМаркируемаяПродукцияВКоллекции(ТоварыКПоступлению, ВидыПродукцииИСМП, ЕстьМаркируемаяПродукция);
	Если НЕ ЕстьМаркируемаяПродукция Тогда
		ПроверкаИПодборПродукцииИСМПУТ.ЕстьМаркируемаяПродукцияВКоллекции(ТоварыПринято, ВидыПродукцииИСМП, ЕстьМаркируемаяПродукция);
	КонецЕсли;
#Иначе
	ЕстьМаркируемаяПродукция = Ложь;
#КонецЕсли

	//-- Локализация

	УстановитьУсловноеОформление();
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	ОформитьМеню("КПоступлению");
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	Если ИспользуемыйСерверФормы = ИспользуемыйСервер.Основной Тогда
		// ПодключаемоеОборудование
		Если Источник = "ПодключаемоеОборудование" И ВводДоступен() Тогда

			ЕстьНеобработанноеСобытие = МобильноеРабочееМестоКладовщикаКлиент.ЕстьНеобработанноеСобытие();

			Если ИмяСобытия = "ScanData" И ЕстьНеобработанноеСобытие Тогда

				Данные = МобильноеРабочееМестоКладовщикаКлиент.ПреобразоватьДанныеСоСканераВСтруктуру(Параметр);

				ОбработатьШтрихкод(Данные);

			КонецЕсли;
		КонецЕсли;
	КонецЕсли;

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура ПерейтиВРазделКПриемке(Команда)
	ОформитьМеню("КПоступлению");
КонецПроцедуры

&НаКлиенте
Процедура ПерейтиВРазделПринято(Команда)
	ОформитьМеню("Принято");
КонецПроцедуры

&НаКлиенте
Процедура ТоварыВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	Описание = Новый ОписаниеОповещения("ОбновитьФорму", ЭтотОбъект);
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("Номенклатура", Элемент.ТекущиеДанные.Номенклатура);
	ПараметрыФормы.Вставить("Характеристика", Элемент.ТекущиеДанные.Характеристика);
	ПараметрыФормы.Вставить("Серия", Элемент.ТекущиеДанные.Серия);
	ПараметрыФормы.Вставить("Назначение", Элемент.ТекущиеДанные.Назначение);
	ПараметрыФормы.Вставить("Упаковка", Элемент.ТекущиеДанные.Упаковка);
	ПараметрыФормы.Вставить("Количество", Элемент.ТекущиеДанные.КоличествоУпаковок);
	ПараметрыФормы.Вставить("Режим", "Приемка");
	ПараметрыФормы.Вставить("НомерСтроки", Элемент.ТекущаяСтрока);
	ПараметрыФормы.Вставить("Склад", Склад);
	ПараметрыФормы.Вставить("Помещение", Помещение);
	ПараметрыФормы.Вставить("ПоказыватьФотоТоваров", ПоказыватьФотоТоваров);
	ПараметрыФормы.Вставить("Артикул", Элемент.ТекущиеДанные.Артикул);
	ПараметрыФормы.Вставить("ДокументИсточник", Ссылка);
	ПараметрыФормы.Вставить("РаспоряжениеНаПоступление", РаспоряжениеНаПоступление);
	ПараметрыФормы.Вставить("СкладскаяОперация", СкладскаяОперация);
	ПараметрыФормы.Вставить("ШтрихкодДокумента", Штрихкод);
	ПараметрыФормы.Вставить("ПорядокСканирования", ПорядокСканирования);

	ОткрытьФорму(
	"Обработка.МобильноеРабочееМестоКладовщика.Форма.КарточкаТовара",ПараметрыФормы,
	ЭтотОбъект,,,,Описание,
	РежимОткрытияОкнаФормы.Независимый);
	
КонецПроцедуры

&НаКлиенте
Процедура ТоварыПринятоВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	Описание = Новый ОписаниеОповещения("ОбновитьФорму", ЭтотОбъект);
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("Номенклатура", Элемент.ТекущиеДанные.Номенклатура);
	ПараметрыФормы.Вставить("Характеристика", Элемент.ТекущиеДанные.Характеристика);
	ПараметрыФормы.Вставить("Серия", Элемент.ТекущиеДанные.Серия);
	ПараметрыФормы.Вставить("Назначение", Элемент.ТекущиеДанные.Назначение);
	ПараметрыФормы.Вставить("Упаковка", Элемент.ТекущиеДанные.Упаковка);
	ПараметрыФормы.Вставить("Количество", Элемент.ТекущиеДанные.КоличествоУпаковок);
	ПараметрыФормы.Вставить("Режим", "РедактированиеПриемка");
	ПараметрыФормы.Вставить("НомерСтроки", ТоварыПринято.Индекс(Элементы.ТоварыПринято.ТекущиеДанные));
	ПараметрыФормы.Вставить("Склад", Склад);
	ПараметрыФормы.Вставить("Помещение", Помещение);
	ПараметрыФормы.Вставить("ПоказыватьФотоТоваров", ПоказыватьФотоТоваров);
	ПараметрыФормы.Вставить("Артикул", Элемент.ТекущиеДанные.Артикул);
	ПараметрыФормы.Вставить("ПорядокСканирования", ПорядокСканирования);
	ПараметрыФормы.Вставить("ДокументИсточник", Ссылка);
	ПараметрыФормы.Вставить("РаспоряжениеНаПоступление", РаспоряжениеНаПоступление);
	ПараметрыФормы.Вставить("СкладскаяОперация", СкладскаяОперация);

	ОткрытьФорму(
	"Обработка.МобильноеРабочееМестоКладовщика.Форма.КарточкаТовара",ПараметрыФормы,
	ЭтотОбъект,,,,Описание,
	РежимОткрытияОкнаФормы.Независимый);

КонецПроцедуры

&НаКлиенте
Процедура ЗакончитьПриемку(Команда)
	
	Если Не ИспользоватьСтатусыПриходныхОрдеров И ТоварыПринято.Количество() = 0 Тогда   		
		Состояние(НСтр("ru = 'Не возможно закончить приемку, пока не принято ни одного товара.'"));	
		Возврат;
	КонецЕсли;
	
	СписокЗначений = Новый СписокЗначений;
	СписокЗначений.Добавить("Завершить", НСтр("ru = 'Завершить'"));
	СписокЗначений.Добавить("Продолжить", НСтр("ru = 'Продолжить'"));
	
	Оповещение = Новый ОписаниеОповещения("ПослеЗакрытияВопроса", ЭтотОбъект);
	ПоказатьВопрос(Оповещение, НСтр("ru = 'Завершить приемку?'"), СписокЗначений, 0);
	
КонецПроцедуры

&НаКлиенте
Процедура ПомещениеПриИзменении(Элемент)

	ОбновитьЗонуПриемкиАдресноеХранение();

КонецПроцедуры

&НаКлиенте
Процедура СобратьВсе(Команда)
	Оповещение = Новый ОписаниеОповещения("ПослеЗакрытияВопросаСобратьВсе", ЭтотОбъект);
	ПоказатьВопрос(Оповещение, НСтр("ru = 'Вкладка Принято будет очищена, продолжить?'"),РежимДиалогаВопрос.ДаНет,0);
КонецПроцедуры

&НаКлиенте
Процедура Сканировать(Команда)

	Описание = Новый ОписаниеОповещения("РезультатСканированияТовара", ЭтотОбъект);
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("ТипПоиска", "ПоискНоменклатуры");
	ПараметрыФормы.Вставить("Склад", Склад);
	ПараметрыФормы.Вставить("Помещение", Помещение);
	ПараметрыФормы.Вставить("ДокументСсылка", Ссылка);
	ПараметрыФормы.Вставить("ШтрихкодыУпаковок", ШтрихкодыУпаковок);
	ПараметрыФормы.Вставить("Организация", Организация);
	
	Если ИспользуемыйСерверФормы = ИспользуемыйСервер.Основной Тогда
		ОткрытьФорму(
			"Обработка.МобильноеРабочееМестоКладовщика.Форма.СканированиеШтрихкода", ПараметрыФормы,
			ЭтотОбъект,,,, Описание,
			РежимОткрытияОкнаФормы.Независимый);
		Иначе
			ОткрытьФорму(
			"Обработка.МобильноеРабочееМестоКладовщика.Форма.СканированиеШтрихкодаАвтономныйРежим", ПараметрыФормы,
			ЭтотОбъект,,,, Описание,
			РежимОткрытияОкнаФормы.Независимый);
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ОтменитьПриемку(Команда)
	
	ИндексСтроки = ТоварыПринято.Индекс(Элементы.ТоварыПринято.ТекущиеДанные);
	Если ИндексСтроки >= 0 Тогда
		ТоварыПринято.Удалить(ИндексСтроки);
	КонецЕсли;
	
	СформироватьЗаголовкиКомандМеню();
	
КонецПроцедуры

&НаКлиенте
Процедура КодыМаркировки(Команда)
	Описание = Новый ОписаниеОповещения("ИзменитьШтрихкодыУпаковок", ЭтотОбъект);
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("ШтрихкодыУпаковок", ШтрихкодыУпаковок);
	
	ОткрытьФорму(
	"Обработка.МобильноеРабочееМестоКладовщика.Форма.СписокКодовМаркировки",ПараметрыФормы,
	ЭтотОбъект,,,,Описание,
	РежимОткрытияОкнаФормы.Независимый);
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура УстановитьУсловноеОформление()
	
	Элементы.Помещение.Видимость      = ИспользоватьСкладскиеПомещения;
	Элементы.ЗонаПриемки.Видимость    = ИспользоватьАдресноеХранение;
	Элементы.КодыМаркировки.Видимость = ИспользоватьУчетМаркируемойПродукции И ЕстьМаркируемаяПродукция;
	Элементы.ИнформацияОбОтправителе.Видимость   = (ТипЗнч(Отправитель) = Тип("СправочникСсылка.Партнеры") Или ТипЗнч(Отправитель) = Тип("СправочникСсылка.ФизическиеЛица"));
	
#Если МобильныйАвтономныйСервер Тогда
	Элементы.СобратьВсе.Видимость = Ложь;
	Элементы.ФормаОтменитьПриемкуОрдера.Видимость = Ложь;
#Иначе
	Статус = МобильноеРабочееМестоКладовщика.ЗначениеРеквизитаОбъекта(Ссылка, "Статус");
	Если Статус = Перечисления.СтатусыПриходныхОрдеров.КПоступлению И ПравоДоступа("ИнтерактивнаяПометкаУдаления", Метаданные.Документы.ПриходныйОрдерНаТовары) Тогда
		Элементы.ФормаОтменитьПриемкуОрдера.Видимость = Истина;
	Иначе
		Элементы.ФормаОтменитьПриемкуОрдера.Видимость = Ложь;
	КонецЕсли;
#КонецЕсли
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработатьШтрихкод(ДанныеШтрихкода)

	ШтрихкодыВалидны = МобильноеРабочееМестоКладовщикаКлиент.ШтрихкодыВалидны(ДанныеШтрихкода);

	Если Не ШтрихкодыВалидны Тогда
		Возврат;
	КонецЕсли;

	Если Штрихкод = ДанныеШтрихкода.Штрихкод Тогда
		Если Статус = ПредопределенноеЗначение("Перечисление.СтатусыПриходныхОрдеров.Принят")
			И ИспользоватьАдресноеХранение Тогда

			ЗаданияНаРазмещение = ДанныеЗаданийПоОрдеру();
			РезультатСканированияДокумента(ЗаданияНаРазмещение);

		ИначеЕсли ИспользоватьАдресноеХранение Тогда
			ЗакончитьПриемкуНаКлиенте(Ложь);
		Иначе
			ЗакончитьПриемкуНаКлиенте(Истина);
		КонецЕсли;
		Возврат;
	КонецЕсли;

	ДанныеТоваров = ДанныеТоваровПоШК(ДанныеШтрихкода.Штрихкод);

	Если ЗначениеЗаполнено(ДанныеТоваров) Тогда
		РезультатСканированияТовара(ДанныеТоваров);
		Возврат;
	КонецЕсли;

	Состояние(НСтр("ru = 'Номенклатура по штрихкоду не найдена'"));

КонецПроцедуры

&НаСервере
Функция ДанныеЗаданийПоОрдеру()

	СтруктураПоиска = Новый Структура();
	СтруктураПоиска.Вставить("Склад", Склад);
	СтруктураПоиска.Вставить("Помещение", Помещение);
	СтруктураПоиска.Вставить("ЗонаПриемки", ЗонаПриемки);
	СтруктураПоиска.Вставить("ДатаОрдера", Дата);
	СтруктураПоиска.Вставить("Направление", "Приемка");

	Возврат Обработки.МобильноеРабочееМестоКладовщика.ДанныеЗаданийПоОрдеру(СтруктураПоиска);

КонецФункции

&НаКлиенте
Процедура РезультатСканированияДокумента(Результат = Неопределено, ДополнительныеПараметры = Неопределено) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;

	Описание = Новый ОписаниеОповещения("ЗакрытьФорму", ЭтотОбъект);

	Если ЗначениеЗаполнено(Результат.Ссылки) И ЗначениеЗаполнено(Результат.Режим) Тогда

		Описание = Новый ОписаниеОповещения("РезультатСканированияДокумента", ЭтотОбъект);

		ПараметрыФормы = Новый Структура;
		ПараметрыФормы.Вставить("РезультатСканирования", Результат);
		ПараметрыФормы.Вставить("Склад", Склад);
		ПараметрыФормы.Вставить("Помещение", Помещение);

		ОткрытьФорму(
			"Обработка.МобильноеРабочееМестоКладовщика.Форма.ФормаВыбораСканирование", ПараметрыФормы,
			ЭтотОбъект,,,, Описание, РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);

	ИначеЕсли ЗначениеЗаполнено(Результат.Ссылки) И Не ЗначениеЗаполнено(Результат.Режим) Тогда

		ПараметрыФормы = Новый Структура;
		ПараметрыФормы.Вставить("Ссылка", Результат.Ссылки[0]);
		ПараметрыФормы.Вставить("ПоказыватьФотоТоваров", ПоказыватьФотоТоваров);
		ПараметрыФормы.Вставить("Штрихкод", Штрихкод);
		ПараметрыФормы.Вставить("ПорядокСканирования", ПорядокСканирования);

		ОткрытьФорму(
			"Обработка.МобильноеРабочееМестоКладовщика.Форма.РазмещениеПоЯчейкам", ПараметрыФормы,
			ЭтотОбъект,,,, Описание, РежимОткрытияОкнаФормы.Независимый);

	Иначе

		СтруктураНовогоРазмещения = НовоеРазмещениеТоваров();

		Если ЗначениеЗаполнено(СтруктураНовогоРазмещения.ТекстОшибкиПроверки) Тогда
			Состояние(СтруктураНовогоРазмещения.ТекстОшибкиПроверки);
		КонецЕсли;

		Если Не ЗначениеЗаполнено(СтруктураНовогоРазмещения.Ссылка) Тогда
			Возврат;
		КонецЕсли;

		ПараметрыФормы = Новый Структура;
		ПараметрыФормы.Вставить("Ссылка", СтруктураНовогоРазмещения.Ссылка);
		ПараметрыФормы.Вставить("ПоказыватьФотоТоваров", ПоказыватьФотоТоваров);
		ПараметрыФормы.Вставить("Штрикход", Штрихкод);
		ПараметрыФормы.Вставить("ПорядокСканирования", ПорядокСканирования);

		ОткрытьФорму(
			"Обработка.МобильноеРабочееМестоКладовщика.Форма.РазмещениеПоЯчейкам", ПараметрыФормы,
			ЭтотОбъект,,,, Описание, РежимОткрытияОкнаФормы.Независимый);

	КонецЕсли;

КонецПроцедуры

&НаСервере
Функция НовоеРазмещениеТоваров()

	ПараметрыРазмещения = Обработки.МобильноеРабочееМестоКладовщика.ПараметрыСозданияРазмещенияТоваров();
	ПараметрыРазмещения.Склад = Склад;
	ПараметрыРазмещения.Помещение = Помещение;
	ПараметрыРазмещения.Исполнитель = Исполнитель;
	ПараметрыРазмещения.ЗонаПриемки = ЗонаПриемки;
	ПараметрыРазмещения.ТаблицаНоменклатуры =  ТоварыПринято.Выгрузить();

	СтруктураНовогоРазмещения = Обработки.МобильноеРабочееМестоКладовщика.НовоеРазмещениеТоваров(ПараметрыРазмещения);

	Возврат СтруктураНовогоРазмещения;

КонецФункции

&НаКлиенте
Процедура РезультатСканированияТовара(Результат = Неопределено, ДополнительныеПараметры = Неопределено) Экспорт

	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;

	Если Результат.Количество() > 1 Тогда

		Описание = Новый ОписаниеОповещения("РезультатСканированияТовара", ЭтотОбъект);

		ЗначенияЗаполнения = Новый Структура;
		ЗначенияЗаполнения.Вставить("Товары", Результат);
		ЗначенияЗаполнения.Вставить("Режим", "ВыборНоменклатуры");
		ЗначенияЗаполнения.Вставить("Штрихкод", "");

		ПараметрыФормы = Новый Структура;
		ПараметрыФормы.Вставить("РезультатСканирования", ЗначенияЗаполнения);

		ОткрытьФорму(
			"Обработка.МобильноеРабочееМестоКладовщика.Форма.ФормаВыбораСканирование", ПараметрыФормы,
			ЭтотОбъект,,,,Описание, РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);

	Иначе

		ДанныеТовара = Результат[0];

		Описание = Новый ОписаниеОповещения("ОбновитьФорму", ЭтотОбъект);

		ПараметрыФормы = Новый Структура;
		ПараметрыФормы.Вставить("Номенклатура", ДанныеТовара.Номенклатура);
		ПараметрыФормы.Вставить("Характеристика", ДанныеТовара.Характеристика);
		ПараметрыФормы.Вставить("Серия", ДанныеТовара.Серия);
		ПараметрыФормы.Вставить("Упаковка", ДанныеТовара.Упаковка);
		ПараметрыФормы.Вставить("Количество", ДанныеТовара.Количество);
		ПараметрыФормы.Вставить("Режим", "Приемка");
		ПараметрыФормы.Вставить("НомерСтроки", 0);
		ПараметрыФормы.Вставить("Склад", Склад);
		ПараметрыФормы.Вставить("Помещение", Помещение);
		ПараметрыФормы.Вставить("ШтрихкодУпаковки", ДанныеТовара.ШтрихкодУпаковки);
		ПараметрыФормы.Вставить("ПоказыватьФотоТоваров", ПоказыватьФотоТоваров);
		ПараметрыФормы.Вставить("ШтрихкодДокумента", Штрихкод);
		ПараметрыФормы.Вставить("ПорядокСканирования", ПорядокСканирования);
		ПараметрыФормы.Вставить("Источник", Ссылка);
		ПараметрыФормы.Вставить("РаспоряжениеНаПоступление", РаспоряжениеНаПоступление);
		ПараметрыФормы.Вставить("СкладскаяОперация", СкладскаяОперация);

		ОткрытьФорму(
		"Обработка.МобильноеРабочееМестоКладовщика.Форма.КарточкаТовара",ПараметрыФормы,
		ЭтотОбъект,,,,Описание,
		РежимОткрытияОкнаФормы.Независимый);

	КонецЕсли;

КонецПроцедуры

&НаСервере
Функция СоздатьПриходныйОрдер(СтруктураЗаполнения)
	
#Если Не МобильныйАвтономныйСервер Тогда

	НовыйОрдер = Документы.ПриходныйОрдерНаТовары.СоздатьДокумент();
	
	НовыйОрдер.Заполнить(СтруктураЗаполнения);
	НовыйОрдер.Дата = ТекущаяДатаСеанса();
	НовыйОрдер.Исполнитель = МобильноеРабочееМестоКладовщика.ТекущийПользователь();
	
	ПараметрыУказанияСерий = Документы.ПриходныйОрдерНаТовары.ПараметрыУказанияСерий(НовыйОрдер);
	МобильноеРабочееМестоКладовщика.ЗаполнитьСтатусыУказанияСерий(НовыйОрдер, ПараметрыУказанияСерий);
	СтруктураДействий = Новый Структура();
	КонтрольКачестваКэш = КонтрольКачества.КэшДанныхМеханизма(НовыйОрдер);
	СтруктураДействий.Вставить("ЗаполнитьПроконтролироватьКачествоДатаПодтвержденияКачества", КонтрольКачестваКэш);
	СтруктураДействий.Вставить("ЗаполнитьПодлежитРазблокировкеДатаПодтвержденияКачества", КонтрольКачестваКэш);
	ПакетнаяОбработкаТабличнойЧастиСервер.ОбработатьТЧ(НовыйОрдер.Товары, СтруктураДействий);
	
	Если НовыйОрдер.Товары.Количество() = 0 Тогда
		Возврат Ложь;
	КонецЕсли;
		
	НовыйОрдер.Записать(РежимЗаписиДокумента.Запись);
	
	Склад       = НовыйОрдер.Склад;
	Помещение   = НовыйОрдер.Помещение;
	Исполнитель = НовыйОрдер.Исполнитель;
	
	Ссылка = НовыйОрдер.Ссылка;
	
	Возврат Истина;

#Иначе

	Возврат Ложь;

#КонецЕсли
	
КонецФункции

&НаКлиенте
Процедура ОформитьМеню(ИмяВкладки)
	
	ПоказатьМеню();
	
	Элементы.РамкаКПоступлению.Картинка = БиблиотекаКартинок.РамкаМенюБелая;
	Элементы.КомандаКПоступлению.ЦветТекста = WebЦвета.ТемноСерый;
	
	Элементы.РамкаПринято.Картинка = БиблиотекаКартинок.РамкаМенюБелая;
	Элементы.КомандаПринято.ЦветТекста = WebЦвета.ТемноСерый;
	
	Если ИмяВкладки = "КПоступлению" Тогда
		Элементы.РамкаКПоступлению.Картинка = БиблиотекаКартинок.РамкаМенюЧерная;
		Элементы.КомандаКПоступлению.ЦветТекста = WebЦвета.Черный;
		Элементы.ГруппаСтраницы.ТекущаяСтраница = Элементы.СтраницаКПоступлению;
	ИначеЕсли ИмяВкладки = "Принято" Тогда
		Элементы.РамкаПринято.Картинка = БиблиотекаКартинок.РамкаМенюЧерная;
		Элементы.КомандаПринято.ЦветТекста = WebЦвета.Черный;
		Элементы.ГруппаСтраницы.ТекущаяСтраница = Элементы.СтраницаПринято;
	КонецЕсли;
	
	СформироватьЗаголовкиКомандМеню();
	
КонецПроцедуры

&НаСервере
Процедура СформироватьЗаголовкиКомандМеню()
	Элементы.КомандаКПоступлению.Заголовок = СтрШаблон(НСтр("ru = 'К приемке (%1)'"), ТоварыКПоступлению.Количество());
	Элементы.КомандаПринято.Заголовок = СтрШаблон(НСтр("ru = 'Принято (%1)'"), ТоварыПринято.Количество());
КонецПроцедуры

