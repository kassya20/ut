#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Режим = Параметры.Режим;
		
	Если Режим = "Проверка" Тогда		
		Элементы.ДекорацияНадписьПроверка.Видимость = Истина;
		Элементы.ГруппаКнопкиПроверка.Видимость = Истина;
	Иначе
		Элементы.ДекорацияНадписьОтбор.Видимость = Истина;
		Элементы.ГруппаКнопкиОтбор.Видимость = Истина;
	КонецЕсли;
		
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	Если ИспользуемыйСерверФормы = ИспользуемыйСервер.Основной Тогда
		// ПодключаемоеОборудование
		Если Источник = "ПодключаемоеОборудование" И ВводДоступен() Тогда 
			
			ЕстьНеобработанноеСобытие = МобильноеРабочееМестоКладовщикаКлиент.ЕстьНеобработанноеСобытие();
			
			Если ИмяСобытия = "ScanData" И ЕстьНеобработанноеСобытие Тогда
				
				Если Режим = "Проверка" Тогда
					Закрыть("Отобрать");
				Иначе
					Закрыть("НеОтгружать");
				КонецЕсли;
				
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти 


