&НаКлиенте
Процедура ФайлыПоказыватьУдаленные(Команда)
	
	ФайлыПоказыватьУдаленные = Не ФайлыПоказыватьУдаленные;
	Элементы.ФайлыПоказыватьУдаленные.Пометка = ФайлыПоказыватьУдаленные;
	
	ОбзорЗаполнен = Ложь;
	ВыводитьОкноОжидания = Истина;
	
	НачатьОбновлениеФормы(Элементы.СтраницаОбзор, ВыводитьОкноОжидания);
	
КонецПроцедуры

&НаКлиенте
Процедура ФайлыРедактировать(Команда)
	
	ОткрытьТекущийФайлВДеревеФайловДляРедактирования();
	
КонецПроцедуры

&НаКлиенте
Процедура ФайлыСохранитьВместеСЭП(Команда)
	
	ТекущиеДанные = Элементы.ДеревоФайлов.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Или ТекущиеДанные.Тип <> "DMFile" Тогда
		Возврат;
	КонецЕсли;
	
	ИнтеграцияС1СДокументооборотБазоваяФункциональностьКлиент.НачатьСохранениеВместеСЭП(
		ТекущиеДанные.ID,
		ТекущиеДанные.Расширение,
		ТекущиеДанные.Наименование,
		ТекущиеДанные.Размер * 1024,
		ТекущиеДанные.ДатаМодификации,
		УникальныйИдентификатор);
	
КонецПроцедуры

&НаКлиенте
Процедура ФайлыСохранитьИзменения(Команда)
	
	ТекущиеДанные = Элементы.ДеревоФайлов.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Или ТекущиеДанные.Тип <> "DMFile" Тогда
		Возврат;
	КонецЕсли;
	
	ИнтеграцияС1СДокументооборотБазоваяФункциональностьКлиент.СохранитьИзмененияРедактируемогоФайла(
		ТекущиеДанные.ID,
		ТекущиеДанные.Наименование,
		ТекущиеДанные.Расширение,
		УникальныйИдентификатор,,
		ОбъектДОID);
	
КонецПроцедуры

&НаКлиенте
Процедура ФайлыСохранитьКак(Команда)
	
	ТекущиеДанные = Элементы.ДеревоФайлов.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ВыделенныеФайлы = Новый Массив;
	
	Если Элементы.ДеревоФайлов.ВыделенныеСтроки.Количество() > 1 Тогда
		Для Каждого ВыбраннаяСтрока Из Элементы.ДеревоФайлов.ВыделенныеСтроки Цикл
			ДанныеСтроки = Элементы.ДеревоФайлов.ДанныеСтроки(ВыбраннаяСтрока);
			Если ИнтеграцияС1СДокументооборот3Клиент.ОбъектМожноСохранитьНаДиск(ДанныеСтроки.Тип) Тогда
				ВыделенныеФайлы.Добавить(ДанныеФайлаДляСохранения(ДанныеСтроки));
			КонецЕсли;
		КонецЦикла;
	Иначе
		Если ИнтеграцияС1СДокументооборот3Клиент.ОбъектМожноСохранитьНаДиск(ТекущиеДанные.Тип) Тогда
			ВыделенныеФайлы.Добавить(ДанныеФайлаДляСохранения(ТекущиеДанные));
		КонецЕсли;
	КонецЕсли;
	
	Если ВыделенныеФайлы.Количество() = 0 Тогда
		ПоказатьПредупреждение(, НСтр("ru = 'Выберите файл.'"));
		Возврат;
	КонецЕсли;
	
	ПараметрыСохранения = Новый Структура;
	ПараметрыСохранения.Вставить("ОставшиесяФайлы", Новый Массив);
	ПараметрыСохранения.Вставить("ИспользоватьВизуализациюШтампаЭП", Истина);
	Для Индекс = 0 По ВыделенныеФайлы.ВГраница() Цикл
		Если Индекс = 0 Тогда
			ПараметрыСохранения.Вставить("ТекущийФайл", ВыделенныеФайлы[Индекс]);
		Иначе
			ПараметрыСохранения.ОставшиесяФайлы.Добавить(ВыделенныеФайлы[Индекс]);
		КонецЕсли;
	КонецЦикла;
	ПараметрыСохранения.Вставить("УникальныйИдентификаторФормы", УникальныйИдентификатор);
	ПараметрыСохранения.Вставить("ОписаниеОповещения", Неопределено);
	
	ИнтеграцияС1СДокументооборотБазоваяФункциональностьКлиент.СохранитьФайлыКакНачало(ПараметрыСохранения);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

#Область Клиент

&НаКлиенте
Процедура ВосстановитьПоложениеВСпискеФайлов()
	
	// Раскроем дерево.
	Для Каждого СтрокаКРаскрытию Из СтрокиКРаскрытию Цикл
		Строка = ИнтеграцияС1СДокументооборот3Клиент.СтрокаДереваФайловПоID(
			ДеревоФайлов,
			ИспользоватьРолиФайлов,
			СтрокаКРаскрытию);
		Если Строка <> Неопределено Тогда
			Элементы.ДеревоФайлов.Развернуть(Строка.ПолучитьИдентификатор(), Истина);
		КонецЕсли;
	КонецЦикла;
	
	ТекущаяСтрокаУстановлена = Ложь;
	
	// Если передан идентификатор текущей строки - установим текущую строку на него.
	Если ЗначениеЗаполнено(ТекущийИдентификаторСтроки) Тогда
		Строка = ИнтеграцияС1СДокументооборот3Клиент.СтрокаДереваФайловПоID(
			ДеревоФайлов,
			ИспользоватьРолиФайлов,
			ТекущийИдентификаторСтроки,
			ТекущийТипСтроки);
		Если Строка <> Неопределено Тогда
			Элементы.ДеревоФайлов.ТекущаяСтрока = Строка.ПолучитьИдентификатор();
			ТекущаяСтрокаУстановлена = Истина;
		КонецЕсли;
	КонецЕсли;
	
	// Если идентификатор текущей строки не передан - установим текущей строку самого документа.
	Если Не ТекущаяСтрокаУстановлена И ДеревоФайлов.ПолучитьЭлементы().Количество() > 0 Тогда
		Элементы.ДеревоФайлов.ТекущаяСтрока = ДеревоФайлов.ПолучитьЭлементы()[0].ПолучитьИдентификатор();
		ТекущаяСтрокаУстановлена = Истина;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Функция ДанныеФайлаДляСохранения(СтрокаДереваФайлов)
	
	Если СтрокаДереваФайлов.Тип = "DMIncomingElectronicDocument"
			Или СтрокаДереваФайлов.Тип = "DMOutgoingElectronicDocument" Тогда
		Расширение = "xml";
	Иначе
		Расширение = СтрокаДереваФайлов.Расширение;
	КонецЕсли;
	
	ДанныеФайла = ИнтеграцияС1СДокументооборотБазоваяФункциональностьКлиентСервер.ДанныеФайла(
		СтрокаДереваФайлов.Наименование,
		СтрокаДереваФайлов.ID,
		СтрокаДереваФайлов.Тип,
		Расширение,
		СтрокаДереваФайлов.РольФайлаID);
	
	Если СтрокаДереваФайлов.Тип = "DMIncomingElectronicDocument"
			Или СтрокаДереваФайлов.Тип = "DMOutgoingElectronicDocument" Тогда
		ДанныеФайла.СсылкаНаДвоичныеДанныеФайла =
			ИнтеграцияС1СДокументооборот3ВызовСервера.ПолучитьФайлДокументаЭДОИПоместитьВХранилище(
				СтрокаДереваФайлов.ID,
				СтрокаДереваФайлов.Тип,
				УникальныйИдентификатор,
				Расширение);
	КонецЕсли;
	
	Возврат ДанныеФайла;
	
КонецФункции

&НаКлиенте
Процедура ДекорацияОбъектВыбратьНажатиеПослеВыбораТипа(Результат, ДополнительныеПараметры) Экспорт
	
	Если ТипЗнч(Результат) <> Тип("Строка") Или Результат = "" Тогда
		Возврат;
	КонецЕсли;
	
	ВидДокументаОтбор = Новый Структура("Значение, ЗначениеID",
		ВидДокументаИзПравил,
		ВидДокументаИзПравилID);
	Отбор = ИнтеграцияС1СДокументооборотБазоваяФункциональностьКлиент.ОтборПриВыбореСвязанногоОбъекта(
		ВнешнийОбъект,
		Результат,
		ВидДокументаОтбор);
	ИнтеграцияС1СДокументооборот3Клиент.ВыбратьЗначениеИзСписка(
		Результат,
		"ОбъектДО",
		ЭтотОбъект,
		Отбор);
	
КонецПроцедуры

&НаКлиенте
Процедура ДеревоФайловОткрытьКарточку()
	
	ТекущиеДанные = Элементы.ДеревоФайлов.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Или ТекущиеДанные.Тип <> "DMFile" Тогда
		Возврат;
	КонецЕсли;
	
	ДополнительныеПараметры = Новый Структура("РазрешеноРедактирование", СостояниеРазрешаетРедактированиеФайла);
	ИнтеграцияС1СДокументооборотБазоваяФункциональностьКлиент.ОткрытьОбъект(
		ТекущиеДанные.Тип,
		ТекущиеДанные.ID,
		ЭтотОбъект,
		ДополнительныеПараметры);
	
КонецПроцедуры

&НаКлиенте
Процедура ДобавлениеФайла(Результат, Параметры) Экспорт
	
	Если Не ЗначениеЗаполнено(Результат) Тогда
		Возврат;
	КонецЕсли;
	
	Если Результат = 1 Тогда
		СоздатьФайлСДиска();
	ИначеЕсли Результат = 2 Тогда
		// Создание файла по шаблону.
		Оповещение = Новый ОписаниеОповещения("ДобавлениеФайлаЗавершение", ЭтотОбъект);
		ОткрытьФорму(
			"Обработка.ИнтеграцияС1СДокументооборотБазоваяФункциональность.Форма.ВыборФайла",,
			ЭтотОбъект,,,,
			Оповещение,
			РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ДобавлениеФайлаЗавершение(Результат, Параметры) Экспорт
	
	Если Не ЗначениеЗаполнено(Результат) Тогда
		Возврат;
	КонецЕсли;
	
	Если ИспользоватьРолиФайлов Тогда
		РольФайлаID = ИнтеграцияС1СДокументооборот3Клиент.ТекущаяРольФайла(
			ДеревоФайлов,
			Элементы.ДеревоФайлов.ТекущаяСтрока);
	Иначе
		РольФайлаID = "";
	КонецЕсли;
	
	ДополнительныеПараметры = Новый Структура;
	ДополнительныеПараметры.Вставить("Владелец", ОбъектДО);
	ДополнительныеПараметры.Вставить("ВладелецID", ОбъектДОID);
	ДополнительныеПараметры.Вставить("ВладелецТип", ОбъектДОТип);
	ДополнительныеПараметры.Вставить("ВладелецФайла", ВнешнийОбъект);
	ДополнительныеПараметры.Вставить("ШаблонID", Результат.РеквизитID);
	ДополнительныеПараметры.Вставить("РольФайлаID", РольФайлаID);
	ДополнительныеПараметры.Вставить("РазрешеноРедактирование", СостояниеРазрешаетРедактированиеФайла);
	
	ИнтеграцияС1СДокументооборотБазоваяФункциональностьКлиент.ОткрытьОбъект(
		"DMFile",
		"",
		ЭтотОбъект,
		ДополнительныеПараметры);
	
КонецПроцедуры

&НаКлиенте
Функция ЗадачаПоID(ДействиеЗадачиID, ДействиеЗадачиТип, СтрокиДереваОбработки)
	
	Для Каждого Строка Из СтрокиДереваОбработки Цикл
		
		ЗадачаПоID = ЗадачаПоID(ДействиеЗадачиID, ДействиеЗадачиТип, Строка.ПолучитьЭлементы());
		Если ЗадачаПоID <> Неопределено Тогда
			Возврат ЗадачаПоID;
		КонецЕсли;
		
		Если Строка.ДействиеЗадачиID = ДействиеЗадачиID И Строка.ДействиеЗадачиТип = ДействиеЗадачиТип Тогда
			Возврат Строка;
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Неопределено;
	
КонецФункции

&НаКлиенте
Функция ЗаполненныеСвойстваФайла(ТекущиеДанные)
	
	СвойстваФайла = ИнтеграцияС1СДокументооборотБазоваяФункциональностьКлиентСервер.СвойстваФайла();
	
	ИдентификаторФайла = ТекущиеДанные.ID;
	ТаблицаПодписей = ИнтеграцияС1СДокументооборотБазоваяФункциональностьКлиентСервер.ТаблицаПодписей(
		ДеревоПодписей,,
		ИдентификаторФайла);
	ДанныеПодписейФайла = ИнтеграцияС1СДокументооборотБазоваяФункциональностьКлиент.ДанныеПодписей(ТаблицаПодписей);
	
	СвойстваФайла.ИдентификаторФайла = ТекущиеДанные.ID;
	СвойстваФайла.ИмяФайла = ТекущиеДанные.Наименование;
	СвойстваФайла.ОписаниеФайла = ТекущиеДанные.Описание;
	СвойстваФайла.Редактируется = ТекущиеДанные.Редактируется;
	СвойстваФайла.Зашифрован = ТекущиеДанные.Зашифрован;
	СвойстваФайла.ДанныеПодписейФайла = ДанныеПодписейФайла;
	СвойстваФайла.УникальныйИдентификаторФормы = УникальныйИдентификатор;
	СвойстваФайла.ВладелецФайла = ОбъектДОID;
	
	Возврат СвойстваФайла;
	
КонецФункции

&НаКлиенте
Процедура НачатьДобавлениеФайла()
	
	ОписаниеОповещения = Новый ОписаниеОповещения("ДобавлениеФайла", ЭтотОбъект);
	ОткрытьФорму(
		"Обработка.ИнтеграцияС1СДокументооборотБазоваяФункциональность.Форма.СозданиеНовогоФайла",,,,,,
		ОписаниеОповещения,
		РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьДекорацииОбъектаДО(ПриОткрытии = Ложь)
	
	ОбъектДОЗаполнен = ЗначениеЗаполнено(ОбъектДОID);
	НавигационнаяСсылкаЗаполнена = ЗначениеЗаполнено(ОбъектДОНавигационнаяСсылка);
	
	Элементы.ДекорацияОбъектСоздать.Видимость = Не ОбъектДОЗаполнен;
	Элементы.ДекорацияОбъектИли.Видимость = Не ОбъектДОЗаполнен;
	Элементы.ДекорацияОбъектВыбрать.Видимость = Не ОбъектДОЗаполнен;
	
	Элементы.ДекорацияОбъект.Видимость = ОбъектДОЗаполнен;
	Элементы.ДекорацияОбъект.Заголовок = ОбъектДО;
	Элементы.КопироватьНавигационнуюСсылкуВБуферОбмена.Видимость = НавигационнаяСсылкаЗаполнена;
	Элементы.КопироватьНавигационнуюСсылкуВБуферОбменаКонтекст.Видимость = НавигационнаяСсылкаЗаполнена;
	Элементы.ДекорацияОбъектОчистить.Видимость = ОбъектДОЗаполнен;
	
	Если ОбъектДОЗаполнен Тогда
		Элементы.ГруппаСтраницыСвязанныйОбъект.ТекущаяСтраница = Элементы.ГруппаСтраницаЕстьСвязанныйОбъект;
	Иначе
		Элементы.ГруппаСтраницыСвязанныйОбъект.ТекущаяСтраница = Элементы.ГруппаСтраницаНетСвязанногоОбъекта;
	КонецЕсли;
	
	Элементы.ПредставлениеHTMLФайловИДокумента.Доступность = ОбъектДОЗаполнен;
	Элементы.Действия.Доступность = ОбъектДОЗаполнен;
	
	Элементы.ГруппаКнопкиЗапуска.Видимость = ОбъектДОЗаполнен
		И ОбработкаЗаполнена
		И Элементы.ГруппаКнопкиЗапуска.Видимость;
	Элементы.ГруппаИнформацияОПрерыванииОбработки.Видимость = ОбъектДОЗаполнен
		И ОбработкаЗаполнена
		И Элементы.ГруппаИнформацияОПрерыванииОбработки.Видимость;
	
	Если ОбъектДОЗаполнен Тогда
		ТипДерева = ИнтеграцияС1СДокументооборот3Клиент.ТипДерева();
		ТипДерева.ЭтоДеревоОбработки = Истина;
		ИнтеграцияС1СДокументооборот3Клиент.РазвернутьДерево(
			ТипДерева,
			Действия.ПолучитьЭлементы(),
			Элементы.Действия,
			СостояниеДереваОбработки);
	КонецЕсли;
	
	Если ДоступенОбзор Тогда
		Элементы.ГруппаСтраницыПолученияДанныхОбзор.ТекущаяСтраница = Элементы.СтраницаДанныеПолученыОбзор;
		Элементы.Оригинал.Видимость = (ОбъектДОТип = "DMDocument");
		Элементы.Оригинал.ТолькоПросмотр = (СостояниеРазрешаетДобавлениеСканКопии И Не СостояниеРазрешаетДобавлениеФайла);
		Если ПриОткрытии Тогда
			СтрокиКРаскрытию = Новый Массив;
			Если ИспользоватьРолиФайлов Тогда
				Для Каждого Строка Из ДеревоФайлов.ПолучитьЭлементы() Цикл
					Если ЗначениеЗаполнено(Строка.ID) И Строка.РольОбязательная Тогда
						СтрокиКРаскрытию.Добавить(Строка.ID);
					КонецЕсли;
				КонецЦикла;
			КонецЕсли;
		КонецЕсли;
		Если Элементы.ГруппаСтраницы.ТекущаяСтраница = Элементы.СтраницаОбзор
				Или Элементы.ГруппаСтраницы.ТекущаяСтраница = Элементы.СтраницаЭП Тогда
			ВосстановитьПоложениеВСпискеФайлов();
		КонецЕсли;
	Иначе
		Элементы.ГруппаСтраницыПолученияДанныхОбзор.ТекущаяСтраница = Элементы.СтраницаОбзорНедоступен;
	КонецЕсли;
	Если ДоступенПросмотрОбработки Тогда
		Элементы.ГруппаСтраницыПолученияДанныхОбработка.ТекущаяСтраница = Элементы.СтраницаДанныеПолученыОбработка;
	Иначе
		Элементы.ГруппаСтраницыПолученияДанныхОбработка.ТекущаяСтраница = Элементы.СтраницаОбработкаНедоступна;
	КонецЕсли;
	Если ДоступноДеревоСвязей Тогда
		Элементы.ГруппаСтраницыПолученияДанныхСвязи.ТекущаяСтраница = Элементы.СтраницаДанныеПолученыСвязи;
		Если ДеревоСвязейЗаполнено И Не ДеревоСвязейРазвернуто Тогда
			ИнтеграцияС1СДокументооборот3Клиент.РазвернутьУровеньДереваСвязей(
				ДеревоСвязейРазворачиваемаяСтрока,
				ДеревоСвязей,
				Элементы.ДеревоСвязей);
			ДеревоСвязейРазвернуто = Истина;
			ДеревоСвязейРазворачиваемаяСтрока = 0;
		КонецЕсли;
	Иначе
		Элементы.ГруппаСтраницыПолученияДанныхСвязи.ТекущаяСтраница = Элементы.СтраницаСвязиНедоступны;
	КонецЕсли;
	Если ДоступноДеревоПодписей Тогда
		Элементы.ГруппаСтраницыПолученияДанныхПодписи.ТекущаяСтраница = Элементы.СтраницаДанныеПолученыПодписи;
		СтрокиДерева = ДеревоПодписей.ПолучитьЭлементы();
		Для Каждого СтрокаДерева Из СтрокиДерева Цикл
			ИдентификаторСтроки = СтрокаДерева.ПолучитьИдентификатор();
			Элементы.ДеревоПодписей.Развернуть(ИдентификаторСтроки);
		КонецЦикла;
	Иначе
		Элементы.ГруппаСтраницыПолученияДанныхПодписи.ТекущаяСтраница = Элементы.СтраницаПодписиНедоступны;
	КонецЕсли;
	
	Модифицированность = Ложь;
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьОбзор(ИдентификаторФайла = Неопределено, ВыводитьОкноОжидания = Истина)
	
	ОбзорЗаполнен = Ложь;
	
	ТекущийИдентификаторСтроки = Неопределено;
	ТекущийТипСтроки = Неопределено;
	Если ИдентификаторФайла <> Неопределено Тогда
		ТекущийИдентификаторСтроки = ИдентификаторФайла;
		ТекущийТипСтроки = "DMFile";
	ИначеЕсли Элементы.ДеревоФайлов.ТекущиеДанные <> Неопределено Тогда
		ТекущийИдентификаторСтроки = Элементы.ДеревоФайлов.ТекущиеДанные.ID;
		ТекущийТипСтроки = Элементы.ДеревоФайлов.ТекущиеДанные.Тип;
	КонецЕсли;
	СтрокиКРаскрытию = Новый Массив;
	Если ИспользоватьРолиФайлов Тогда
		Для Каждого Строка Из ДеревоФайлов.ПолучитьЭлементы() Цикл
			Если Элементы.ДеревоФайлов.Развернут(Строка.ПолучитьИдентификатор()) Тогда
				СтрокиКРаскрытию.Добавить(Строка.ID);
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
	НачатьОбновлениеФормы(Элементы.СтраницаОбзор, ВыводитьОкноОжидания);
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьОбработку(ВыводитьОкноОжидания = Истина)
	
	ОбработкаЗаполнена = Ложь;
	НачатьОбновлениеФормы(Элементы.СтраницаОбработка, ВыводитьОкноОжидания);
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьПредпросмотрСвязи(ОбновитьДанные = Ложь, ИгнорироватьМаксРазмер = Ложь)
	
	Если Не ПредварительныйПросмотрСвязей Тогда
		Возврат;
	КонецЕсли;
	
	ПредставлениеСвязиHTML = ИнтеграцияС1СДокументооборотБазоваяФункциональностьКлиентСервер.СообщениеОЗагрузке();
	Элементы.СтраницыПросмотраСвязи.ТекущаяСтраница = Элементы.СтраницаГруппаHTMLСвязи;
	Элементы.ГруппаПредпросмотрУрезан.Видимость = Ложь;
	
	ДеревоСвязейТекущиеДанные = ИнтеграцияС1СДокументооборот3Клиент.ДеревоСвязейТекущиеДанныеДляПросмотра(
		Элементы.ДеревоСвязей);
	Если ДеревоСвязейТекущиеДанные = Неопределено Тогда
		ПредставлениеСвязиHTML = ИнтеграцияС1СДокументооборотБазоваяФункциональностьКлиентСервер.СообщениеОбОтсутствииПредпросмотра(
			ЗаголовокСообщенияВОбластиПредпросмотра);
		Возврат;
	КонецЕсли;
	Если ДеревоСвязейТекущиеДанные.ОжиданиеПредпросмотра Тогда
		Возврат;
	КонецЕсли;
	
	// Получение НДПС документа совмещено с получением предпросмотра для оптимизации.
	// Получим НДПС в одном пакетном запросе вместе с предпросмотром, за один вызов сервиса ДО.
	// Заранее, при получении списка задач, получить НДПС всех предметов нельзя, т.к. это
	// существенно замедлит обновление списка.
	ОбъектДляПолученияНДПС = Неопределено;
	СтрокаДокумента = ИнтеграцияС1СДокументооборот3КлиентСервер.СтрокаДокументаВДеревеСвязей(
		ДеревоСвязейТекущиеДанные);
	Если СтрокаДокумента <> Неопределено Тогда
		ОбъектДляПолученияНДПС =
			ИнтеграцияС1СДокументооборотБазоваяФункциональностьКлиентСервер.ДанныеСсылочногоОбъектаДО(
				СтрокаДокумента.СвязанныйОбъектID,
				СтрокаДокумента.СвязанныйОбъектТип);
	КонецЕсли;
	
	ВернутьДвоичныеДанные = ПоказыватьPDFСредствами1С
		И (НРег(ДеревоСвязейТекущиеДанные.РасширениеФайла) = "pdf")
		И Не ДеревоСвязейТекущиеДанные.Зашифрован;
	ЕстьФайлПредпросмотра = ЭтоАдресВременногоХранилища(ДеревоСвязейТекущиеДанные.АдресВХранилищеФайлаПредпросмотра)
		И Не ДеревоСвязейТекущиеДанные.Зашифрован;
	
	Если (ДеревоСвязейТекущиеДанные.СвязанныйОбъектТип = "DMFile"
				Или ИнтеграцияС1СДокументооборот3КлиентПовтИсп.ЭтоИзвестныйОбъектОбзора(ДеревоСвязейТекущиеДанные.СвязанныйОбъектТип))
			И (ОбновитьДанные
				Или (ВернутьДвоичныеДанные И Не ЕстьФайлПредпросмотра)
				Или (Не ЗначениеЗаполнено(ДеревоСвязейТекущиеДанные.ПредставлениеHTML) И Не ЕстьФайлПредпросмотра)) Тогда
		
		ДеревоСвязейТекущиеДанные.ОжиданиеПредпросмотра = Истина;
		ДлительнаяОперация = ИнтеграцияС1СДокументооборот3ВызовСервера.ПолучитьHTMLПредпросмотрОбъектаАсинхронно(
			УникальныйИдентификатор,
			ДеревоСвязейТекущиеДанные.СвязанныйОбъектID,
			ДеревоСвязейТекущиеДанные.СвязанныйОбъектТип,
			ИгнорироватьМаксРазмер,
			ОбъектДляПолученияНДПС,
			ВернутьДвоичныеДанные);
		
		ОповещениеОЗавершении = Новый ОписаниеОповещения(
			"ОбновитьПредпросмотрСвязиЗавершение",
			ЭтотОбъект,
			ДеревоСвязейТекущиеДанные);
		
		ИнтеграцияС1СДокументооборотБазоваяФункциональностьКлиент.ВыполнитьЗапросАсинхронно(
			ЭтотОбъект,
			ДлительнаяОперация,
			ОповещениеОЗавершении,
			Ложь,,
			Ложь);
		
		Возврат;
		
	КонецЕсли;
	
	Если Не ДеревоСвязейТекущиеДанные.РедактируетсяТекущимПользователем
			И ДеревоСвязейТекущиеДанные.ПредпросмотрУрезан Тогда
		Элементы.ГруппаПредпросмотрУрезан.Видимость = Истина;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ДеревоСвязейТекущиеДанные.ПредставлениеHTML) Тогда
		ПредставлениеСвязиHTML = ДеревоСвязейТекущиеДанные.ПредставлениеHTML;
	ИначеЕсли ЕстьФайлПредпросмотра Тогда
		Если ДеревоСвязейТекущиеДанные.РедактируетсяТекущимПользователем Тогда
			ПредставлениеСвязиHTML = ИнтеграцияС1СДокументооборотБазоваяФункциональностьКлиентСервер.СообщениеОРедактировании(
				ЗаголовокСообщенияВОбластиПредпросмотра);
		Иначе
			ДокументPDF = ИнтеграцияС1СДокументооборотБазоваяФункциональностьВызовСервера.ПолучитьДокументPDF(
				ДеревоСвязейТекущиеДанные.АдресВХранилищеФайлаПредпросмотра);
			Если ДокументPDF = Неопределено Тогда
				ПредставлениеСвязиHTML = ИнтеграцияС1СДокументооборотБазоваяФункциональностьКлиентСервер.СообщениеОбОтсутствииПредпросмотра(
					ЗаголовокСообщенияВОбластиПредпросмотра);
			Иначе
				ЭтотОбъект["ДокументPDFСвязиРеквизит"] = ДокументPDF;
				Элементы.СтраницыПросмотраСвязи.ТекущаяСтраница = Элементы.СтраницаГруппаPDFСвязи;
				Элементы["ДокументPDFСвязиПоле"].НомерТекущейСтраницы = 1;
			КонецЕсли;
		КонецЕсли;
	Иначе
		ПредставлениеСвязиHTML = ИнтеграцияС1СДокументооборотБазоваяФункциональностьКлиентСервер.СообщениеОбОтсутствииПредпросмотра(
			ЗаголовокСообщенияВОбластиПредпросмотра);
	КонецЕсли;
	
КонецПроцедуры

// Вызывается после получения предпросмотра объекта ДО.
//
// Параметры:
//   Результат - см. ДлительныеОперации.ОперацияВыполнена
//   ПараметрыОповещения - см. ИнтеграцияС1СДокументооборотБазоваяФункциональностьКлиентСервер.ДанныеФайла
//
&НаКлиенте
Процедура ОбновитьПредпросмотрСвязиЗавершение(Результат, ПараметрыОповещения) Экспорт
	
	HTMLПредпросмотрОбъекта =
		ИнтеграцияС1СДокументооборотБазоваяФункциональностьКлиентСервер.ПараметрыОповещенияПолученHTMLПредпросмотрОбъекта();
	
	Если Результат <> Неопределено И Результат.Статус = "Ошибка" Тогда
		СообщениеHTML =
			ИнтеграцияС1СДокументооборотБазоваяФункциональностьКлиентСервер.СообщениеВПредпросмотр(
				Результат.КраткоеПредставлениеОшибки,
				ЗаголовокСообщенияВОбластиПредпросмотра);
		HTMLПредпросмотрОбъекта.ID = ПараметрыОповещения.СвязанныйОбъектID;
		HTMLПредпросмотрОбъекта.Тип = ПараметрыОповещения.СвязанныйОбъектТип;
		HTMLПредпросмотрОбъекта.Расширение = ПараметрыОповещения.РасширениеФайла;
		HTMLПредпросмотрОбъекта.ПредставлениеHTML = СообщениеHTML;
		Оповестить("ПолученHTMLПредпросмотрОбъекта", HTMLПредпросмотрОбъекта, ЭтотОбъект);
	КонецЕсли;
	
	ОбработатьФорму = Ложь;
	Если ИнтеграцияС1СДокументооборотБазоваяФункциональностьКлиент.ОперацияВыполнена(Результат, ОбработатьФорму) Тогда
		ИнтеграцияС1СДокументооборотБазоваяФункциональностьКлиентСервер.ДополнитьНДПС(HTMLПредпросмотрОбъекта);
		ЗаполнитьЗначенияСвойств(HTMLПредпросмотрОбъекта, Результат.РезультатДлительнойОперации);
		HTMLПредпросмотрОбъекта.ID = ПараметрыОповещения.СвязанныйОбъектID;
		HTMLПредпросмотрОбъекта.Тип = ПараметрыОповещения.СвязанныйОбъектТип;
		HTMLПредпросмотрОбъекта.Расширение = ПараметрыОповещения.РасширениеФайла;
		Если ПустаяСтрока(HTMLПредпросмотрОбъекта.ПредставлениеHTML) Тогда
			HTMLПредпросмотрОбъекта.ПредставлениеHTML =
				ИнтеграцияС1СДокументооборотБазоваяФункциональностьКлиентСервер.СообщениеОбОтсутствииПредпросмотра(
					ЗаголовокСообщенияВОбластиПредпросмотра);
		КонецЕсли;
		Оповестить("ПолученHTMLПредпросмотрОбъекта", HTMLПредпросмотрОбъекта, ЭтотОбъект);
	ИначеЕсли ОбработатьФорму Тогда
		ОбработатьФормуСогласноВерсииСервиса();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьПредпросмотрСвязиОбработчикОжидания()
	
	ОбновитьПредпросмотрСвязи();
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьПредпросмотрФайла(ОбновитьДанные = Ложь, ИгнорироватьМаксРазмер = Ложь)
	
	ПредставлениеHTML = ИнтеграцияС1СДокументооборотБазоваяФункциональностьКлиентСервер.СообщениеОЗагрузке();
	Элементы.СтраницыПросмотраОбзор.ТекущаяСтраница = Элементы.СтраницаГруппаHTMLОбзор;
	Элементы.ГруппаПредпросмотрУрезанОбзор.Видимость = Ложь;
	
	ТекущиеДанные = Элементы.ДеревоФайлов.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		ПредставлениеHTML = ИнтеграцияС1СДокументооборотБазоваяФункциональностьКлиентСервер.СообщениеОбОтсутствииПредпросмотра(
			ЗаголовокСообщенияВОбластиПредпросмотра);
		Возврат;
	КонецЕсли;
	Если ТекущиеДанные.ОжиданиеПредпросмотра Тогда
		Возврат;
	КонецЕсли;
	
	Если ТекущиеДанные.Тип = "DMDocument" Или ТекущиеДанные.Тип = "DMFileRole" Тогда
		ПредставлениеHTML = ДеревоФайлов.ПолучитьЭлементы()[0].ПредставлениеHTML;
		Возврат;
	КонецЕсли;
	
	// Получение НДПС документа совмещено с получением предпросмотра для оптимизации.
	// Получим НДПС в одном пакетном запросе вместе с предпросмотром, за один вызов сервиса ДО.
	// Заранее, при получении списка задач, получить НДПС всех предметов нельзя, т.к. это
	// существенно замедлит обновление списка.
	ОбъектДляПолученияНДПС =
		ИнтеграцияС1СДокументооборотБазоваяФункциональностьКлиентСервер.ДанныеСсылочногоОбъектаДО(
			ОбъектДОID,
			ОбъектДОТип);
	
	ВернутьДвоичныеДанные = ПоказыватьPDFСредствами1С
		И (НРег(ТекущиеДанные.Расширение) = "pdf")
		И Не ТекущиеДанные.Зашифрован;
	ЕстьФайлПредпросмотра = ЭтоАдресВременногоХранилища(ТекущиеДанные.АдресВХранилищеФайлаПредпросмотра)
		И Не ТекущиеДанные.Зашифрован;
	
	Если (ТекущиеДанные.Тип = "DMFile"
				Или ИнтеграцияС1СДокументооборот3КлиентПовтИсп.ЭтоИзвестныйОбъектОбзора(ТекущиеДанные.Тип))
			И (ОбновитьДанные
				Или (ВернутьДвоичныеДанные И Не ЕстьФайлПредпросмотра)
				Или (Не ЗначениеЗаполнено(ТекущиеДанные.ПредставлениеHTML) И Не ЕстьФайлПредпросмотра)) Тогда
		
		ТекущиеДанные.ОжиданиеПредпросмотра = Истина;
		ДлительнаяОперация = ИнтеграцияС1СДокументооборот3ВызовСервера.ПолучитьHTMLПредпросмотрОбъектаАсинхронно(
			УникальныйИдентификатор,
			ТекущиеДанные.ID,
			ТекущиеДанные.Тип,
			ИгнорироватьМаксРазмер,
			ОбъектДляПолученияНДПС,
			ВернутьДвоичныеДанные);
		
		ОповещениеОЗавершении = Новый ОписаниеОповещения(
			"ОбновитьПредпросмотрФайлаЗавершение",
			ЭтотОбъект,
			ТекущиеДанные);
		
		ИнтеграцияС1СДокументооборотБазоваяФункциональностьКлиент.ВыполнитьЗапросАсинхронно(
			ЭтотОбъект,
			ДлительнаяОперация,
			ОповещениеОЗавершении,
			Ложь,,
			Ложь);
		
		Возврат;
		
	КонецЕсли;
	
	Если Не ТекущиеДанные.РедактируетсяТекущимПользователем И ТекущиеДанные.ПредпросмотрУрезан Тогда
		Элементы.ГруппаПредпросмотрУрезанОбзор.Видимость = Истина;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ТекущиеДанные.ПредставлениеHTML) Тогда
		ПредставлениеHTML = ТекущиеДанные.ПредставлениеHTML;
	ИначеЕсли ЕстьФайлПредпросмотра Тогда
		Если ТекущиеДанные.РедактируетсяТекущимПользователем Тогда
			ПредставлениеHTML = ИнтеграцияС1СДокументооборотБазоваяФункциональностьКлиентСервер.СообщениеОРедактировании(
				ЗаголовокСообщенияВОбластиПредпросмотра);
		Иначе
			ДокументPDF = ИнтеграцияС1СДокументооборотБазоваяФункциональностьВызовСервера.ПолучитьДокументPDF(
				ТекущиеДанные.АдресВХранилищеФайлаПредпросмотра);
			Если ДокументPDF = Неопределено Тогда
				ПредставлениеHTML = ИнтеграцияС1СДокументооборотБазоваяФункциональностьКлиентСервер.СообщениеОбОтсутствииПредпросмотра(
					ЗаголовокСообщенияВОбластиПредпросмотра);
			Иначе
				ЭтотОбъект["ДокументPDFОбзорРеквизит"] = ДокументPDF;
				Элементы.СтраницыПросмотраОбзор.ТекущаяСтраница = Элементы.СтраницаГруппаPDFОбзор;
				Элементы["ДокументPDFОбзорПоле"].НомерТекущейСтраницы = 1;
			КонецЕсли;
		КонецЕсли;
	Иначе
		ПредставлениеHTML = ИнтеграцияС1СДокументооборотБазоваяФункциональностьКлиентСервер.СообщениеОбОтсутствииПредпросмотра(
			ЗаголовокСообщенияВОбластиПредпросмотра);
	КонецЕсли;
	
КонецПроцедуры

// Вызывается после получения предпросмотра объекта ДО.
//
// Параметры:
//   Результат - см. ДлительныеОперации.ОперацияВыполнена
//   ПараметрыОповещения - см. ИнтеграцияС1СДокументооборотБазоваяФункциональностьКлиентСервер.ДанныеФайла
//
&НаКлиенте
Процедура ОбновитьПредпросмотрФайлаЗавершение(Результат, ПараметрыОповещения) Экспорт
	
	HTMLПредпросмотрОбъекта =
		ИнтеграцияС1СДокументооборотБазоваяФункциональностьКлиентСервер.ПараметрыОповещенияПолученHTMLПредпросмотрОбъекта();
	
	Если Результат <> Неопределено И Результат.Статус = "Ошибка" Тогда
		СообщениеHTML =
			ИнтеграцияС1СДокументооборотБазоваяФункциональностьКлиентСервер.СообщениеВПредпросмотр(
				Результат.КраткоеПредставлениеОшибки,
				ЗаголовокСообщенияВОбластиПредпросмотра);
		HTMLПредпросмотрОбъекта.ID = ПараметрыОповещения.ID;
		HTMLПредпросмотрОбъекта.Тип = ПараметрыОповещения.Тип;
		HTMLПредпросмотрОбъекта.Расширение = ПараметрыОповещения.Расширение;
		HTMLПредпросмотрОбъекта.ПредставлениеHTML = СообщениеHTML;
		Оповестить("ПолученHTMLПредпросмотрОбъекта", HTMLПредпросмотрОбъекта, ЭтотОбъект);
	КонецЕсли;
	
	ОбработатьФорму = Ложь;
	Если ИнтеграцияС1СДокументооборотБазоваяФункциональностьКлиент.ОперацияВыполнена(Результат, ОбработатьФорму) Тогда
		ИнтеграцияС1СДокументооборотБазоваяФункциональностьКлиентСервер.ДополнитьНДПС(HTMLПредпросмотрОбъекта);
		ЗаполнитьЗначенияСвойств(HTMLПредпросмотрОбъекта, Результат.РезультатДлительнойОперации);
		HTMLПредпросмотрОбъекта.ID = ПараметрыОповещения.ID;
		HTMLПредпросмотрОбъекта.Тип = ПараметрыОповещения.Тип;
		HTMLПредпросмотрОбъекта.Расширение = ПараметрыОповещения.Расширение;
		Если ПустаяСтрока(HTMLПредпросмотрОбъекта.ПредставлениеHTML) Тогда
			HTMLПредпросмотрОбъекта.ПредставлениеHTML =
				ИнтеграцияС1СДокументооборотБазоваяФункциональностьКлиентСервер.СообщениеОбОтсутствииПредпросмотра(
					ЗаголовокСообщенияВОбластиПредпросмотра);
		КонецЕсли;
		Оповестить("ПолученHTMLПредпросмотрОбъекта", HTMLПредпросмотрОбъекта, ЭтотОбъект);
	ИначеЕсли ОбработатьФорму Тогда
		ОбработатьФормуСогласноВерсииСервиса();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьПредпросмотрФайлаОбработчикОжидания()
	
	ОбновитьПредпросмотрФайла();
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьСвязи(ВыводитьОкноОжидания)
	
	ДеревоСвязейРазвернуто = Ложь;
	ДеревоСвязейЗаполнено = Ложь;
	Если ДеревоСвязейРазворачиваемаяСтрока = 0 Тогда
		ПредставлениеСвязиHTML =
			ИнтеграцияС1СДокументооборотБазоваяФункциональностьКлиентСервер.СообщениеОбОтсутствииПредпросмотра(
				ЗаголовокСообщенияВОбластиПредпросмотра);
		ПрочитаноСвязей = 0;
		ВсегоСвязей = 0;
	КонецЕсли;
	НачатьОбновлениеФормы(Элементы.СтраницаСвязи, ВыводитьОкноОжидания);
	
КонецПроцедуры

&НаКлиенте
Функция ОбработатьДвойнойКликНаУчастникаДействия(ТекущиеДанные)
	
	Если ТекущиеДанные = Неопределено Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Если Не ТекущиеДанные.ЭтоУчастник Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Если ТекущиеДанные.Состояние <> "Performing" И ТекущиеДанные.Состояние <> "Completed" Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Если ИнтеграцияС1СДокументооборот3КлиентСервер.ЭтоДействиеОзнакомления(ТекущиеДанные.ДействиеТип)Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ТекущиеДанные.ДействиеЗадачиID) И ЗначениеЗаполнено(ТекущиеДанные.ДействиеЗадачиТип) Тогда
		ПараметрыФормы = Новый Структура(
			"ОсновнойПредмет, ОсновнойПредметID, ОсновнойПредметТип", ОбъектДО, ОбъектДОID, ОбъектДОТип);
		ИнтеграцияС1СДокументооборотБазоваяФункциональностьКлиент.ОткрытьОбъект(
			ТекущиеДанные.ДействиеЗадачиТип,
			ТекущиеДанные.ДействиеЗадачиID,
			ЭтотОбъект,
			ПараметрыФормы);
		Возврат Истина;
	КонецЕсли;
	
	Возврат Ложь;
	
КонецФункции

&НаКлиенте
Процедура ОбработатьСобытиеЗаписиФайлаОбзор(Параметр, Источник)
	
	Если ОбъектДОID = ""
			Или Параметр.ВладелецФайла <> ОбъектДОID
			Или Параметр.ДействиеНадФайлом.ПодписаниеДокументаСФайлами
			Или (Параметр.ДействиеНадФайлом.УдалениеЭПФайла
				И УникальныйИдентификатор = Параметр.УникальныйИдентификаторФормы)
			Или (Параметр.ДействиеНадФайлом.УдалениеФайла
				И УникальныйИдентификатор = Параметр.УникальныйИдентификаторФормы) Тогда
		Возврат;
	КонецЕсли;
	
	НужноОбновление = Истина;
	Если Параметр.ДействиеНадФайлом.РедактированиеФайла Тогда
		Строка = ИнтеграцияС1СДокументооборот3Клиент.СтрокаДереваФайловПоID(
			ДеревоФайлов,
			ИспользоватьРолиФайлов,
			Параметр.ИдентификаторФайла,
			"DMFile");
		Если Строка = Неопределено Тогда
			НужноОбновление = Ложь;
		Иначе
			НужноОбновление = Не Строка.Редактируется;
		КонецЕсли;
	КонецЕсли;
	Если НужноОбновление Тогда
		Если Параметр.УникальныйИдентификаторФормы = Неопределено Тогда
			ВыводитьОкноОжидания = (Источник = ЭтотОбъект);
		Иначе
			ВыводитьОкноОжидания = (УникальныйИдентификатор = Параметр.УникальныйИдентификаторФормы);
		КонецЕсли;
		ОбновитьОбзор(Параметр.ИдентификаторФайла, ВыводитьОкноОжидания);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработатьСобытиеЗаписиФайлаСвязи(Параметр, Источник)
	
	СтрокаВладельца = ИнтеграцияС1СДокументооборот3КлиентСервер.СвязьПоID(
		ДеревоСвязей.ПолучитьЭлементы(),
		Параметр.ВладелецФайла);
	Если СтрокаВладельца <> Неопределено Тогда
		Если Параметр.УникальныйИдентификаторФормы = Неопределено Тогда
			ВыводитьОкноОжидания = (Источник = ЭтотОбъект);
		Иначе
			ВыводитьОкноОжидания = (УникальныйИдентификатор = Параметр.УникальныйИдентификаторФормы);
		КонецЕсли;
		ОбновитьСвязи(ВыводитьОкноОжидания);
	КонецЕсли;
	
КонецПроцедуры

// Обработчик события "ПолученHTMLПредпросмотрОбъекта".
//
// Параметры:
//   Параметр - см. ИнтеграцияС1СДокументооборотБазоваяФункциональностьКлиентСервер.ПараметрыОповещенияПолученHTMLПредпросмотрОбъекта
//   Источник - Произвольный - источник события.
//
&НаКлиенте
Процедура ОбработатьСобытиеПолученияHTMLПредпросмотраОбзор(Параметр, Источник)
	
	Строка = ИнтеграцияС1СДокументооборот3Клиент.СтрокаДереваФайловПоID(
		ДеревоФайлов,
		ИспользоватьРолиФайлов,
		Параметр.ID,
		Параметр.Тип);
	Если Строка <> Неопределено Тогда
		Строка.ОжиданиеПредпросмотра = Ложь;
		Если ТипЗнч(Параметр.ДвоичныеДанные) = Тип("ДвоичныеДанные") И НРег(Параметр.Расширение) = "pdf" Тогда
			Строка.ПредставлениеHTML = "";
			Строка.ПредпросмотрУрезан = Ложь;
			Строка.АдресВХранилищеФайлаПредпросмотра = ПоместитьВоВременноеХранилище(
				Параметр.ДвоичныеДанные,
				УникальныйИдентификатор);
		Иначе
			Строка.ПредставлениеHTML = Параметр.ПредставлениеHTML;
			Строка.ПредпросмотрУрезан = Параметр.ПредпросмотрУрезан;
		КонецЕсли;
		ОбновитьПредпросмотрФайла();
	КонецЕсли;
	
КонецПроцедуры

// Обработчик события "ПолученHTMLПредпросмотрОбъекта".
//
// Параметры:
//   Параметр - см. ИнтеграцияС1СДокументооборотБазоваяФункциональностьКлиентСервер.ПараметрыОповещенияПолученHTMLПредпросмотрОбъекта
//   Источник - Произвольный - источник события.
//
&НаКлиенте
Процедура ОбработатьСобытиеПолученияHTMLПредпросмотраСвязи(Параметр, Источник)
	
	Строка = ИнтеграцияС1СДокументооборот3КлиентСервер.СвязьПоID(
		ДеревоСвязей.ПолучитьЭлементы(),
		Параметр.ID,
		Параметр.Тип);
	Если Строка <> Неопределено Тогда
		Строка.ОжиданиеПредпросмотра = Ложь;
		Если ТипЗнч(Параметр.ДвоичныеДанные) = Тип("ДвоичныеДанные") И НРег(Параметр.Расширение) = "pdf" Тогда
			Строка.ПредставлениеHTML = "";
			Строка.ПредпросмотрУрезан = Ложь;
			Строка.АдресВХранилищеФайлаПредпросмотра = ПоместитьВоВременноеХранилище(
				Параметр.ДвоичныеДанные,
				УникальныйИдентификатор);
		Иначе
			Строка.ПредставлениеHTML = Параметр.ПредставлениеHTML;
			Строка.ПредпросмотрУрезан = Параметр.ПредпросмотрУрезан;
		КонецЕсли;
		ОбновитьПредпросмотрСвязи();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьТекущийФайлВДеревеСвязейДляРедактирования(ДеревоСвязейТекущиеДанные)
	
	Если ДеревоСвязейТекущиеДанные = Неопределено Или ДеревоСвязейТекущиеДанные.СвязанныйОбъектТип <> "DMFile" Тогда
		Возврат;
	КонецЕсли;
	
	ВладелецID = Неопределено;
	СтрокаДокумента = ИнтеграцияС1СДокументооборот3КлиентСервер.СтрокаДокументаВДеревеСвязей(ДеревоСвязейТекущиеДанные);
	Если СтрокаДокумента <> Неопределено Тогда
		ВладелецID = СтрокаДокумента.СвязанныйОбъектID;
	КонецЕсли;
	
	ИнтеграцияС1СДокументооборотБазоваяФункциональностьКлиент.ОткрытьФайл(
		ДеревоСвязейТекущиеДанные.СвязанныйОбъектID,
		ДеревоСвязейТекущиеДанные.СвязанныйОбъект,
		ДеревоСвязейТекущиеДанные.РасширениеФайла,
		УникальныйИдентификатор,
		Ложь,,
		ВладелецID);
	
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьТекущийФайлВДеревеСвязейНаЧтение(ДеревоСвязейТекущиеДанные)
	
	Если ДеревоСвязейТекущиеДанные = Неопределено Или ДеревоСвязейТекущиеДанные.СвязанныйОбъектТип <> "DMFile" Тогда
		Возврат;
	КонецЕсли;
	
	ИнтеграцияС1СДокументооборотБазоваяФункциональностьКлиент.ОткрытьФайл(
		ДеревоСвязейТекущиеДанные.СвязанныйОбъектID,
		ДеревоСвязейТекущиеДанные.СвязанныйОбъект,
		ДеревоСвязейТекущиеДанные.РасширениеФайла,
		УникальныйИдентификатор);
	
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьТекущийФайлВДеревеФайловДляРедактирования()
	
	ТекущиеДанные = Элементы.ДеревоФайлов.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Или ТекущиеДанные.Тип <> "DMFile" Тогда
		Возврат;
	КонецЕсли;
	
	ИнтеграцияС1СДокументооборотБазоваяФункциональностьКлиент.ОткрытьФайл(
		ТекущиеДанные.ID,
		ТекущиеДанные.Наименование,
		ТекущиеДанные.Расширение,
		УникальныйИдентификатор,
		Ложь,,
		ОбъектДОID);
	
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьТекущийФайлВДеревеФайловНаЧтение()
	
	ТекущиеДанные = Элементы.ДеревоФайлов.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Или ТекущиеДанные.Тип = "DMDocument" Тогда
		Возврат;
	КонецЕсли;
	
	ОбъектДОНаПросмотр = ИнтеграцияС1СДокументооборотБазоваяФункциональностьКлиентСервер.ДанныеСсылочногоОбъектаДО(
		ТекущиеДанные.ID,
		ТекущиеДанные.Тип,
		ТекущиеДанные.Наименование,,
		ТекущиеДанные.НавигационнаяСсылка);
	ИнтеграцияС1СДокументооборот3Клиент.ОткрытьОбъектНаПросмотр(
		Неопределено,
		ОбъектДОНаПросмотр,
		ТекущиеДанные.Расширение,
		УникальныйИдентификатор);
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Функция ПараметрыДействияСОбработкой()
	
	ПараметрыДействияСОбработкой = Новый Структура;
	ПараметрыДействияСОбработкой.Вставить("ПричинаПрерывания", "");
	ПараметрыДействияСОбработкой.Вставить("ТребуетсяОбновлениеДанных", Истина);
	ПараметрыДействияСОбработкой.Вставить("ТребуемоеИнтерактивноеДействие",
		ИнтеграцияС1СДокументооборот3КлиентСервер.ТребуемоеИнтерактивноеДействие());
	
	Возврат ПараметрыДействияСОбработкой;
	
КонецФункции

// Конструктор структуры параметров для начала создания файла.
//
// Возвращаемое значение:
//   см. ИнтеграцияС1СДокументооборотБазоваяФункциональностьКлиент.ПараметрыНачалаСозданияФайла
//
&НаКлиенте
Функция ПараметрыНачалаСозданияФайла()
	
	ПараметрыНачалаСоздания =
		ИнтеграцияС1СДокументооборотБазоваяФункциональностьКлиент.ПараметрыНачалаСозданияФайла();
	ПараметрыНачалаСоздания.ЯвляетсяСканКопией =
		(СостояниеРазрешаетДобавлениеСканКопии И Не СостояниеРазрешаетДобавлениеФайла);
	ПараметрыНачалаСоздания.ВладелецID = ОбъектДОID;
	ПараметрыНачалаСоздания.ВладелецТип = ОбъектДОТип;
	ПараметрыНачалаСоздания.УникальныйИдентификаторФормы = УникальныйИдентификатор;
	ПараметрыНачалаСоздания.ВладелецПредставление = Строка(ВнешнийОбъект);
	ПараметрыНачалаСоздания.Владелец = ВнешнийОбъект;
	
	Возврат ПараметрыНачалаСоздания;
	
КонецФункции

&НаКлиенте
Процедура ПодписатьДокументЗавершение(Результат, ПараметрыОповещения) Экспорт
	
	ИсходныеПодписи = ИнтеграцияС1СДокументооборотБазоваяФункциональностьКлиент.МассивПодписей(ДеревоПодписей);
	ДобавитьПодписи(ПараметрыОповещения.ДобавленныеПодписиОбъектов);
	НовоеКоличествоЭП = 0;
	Для Каждого Элемент Из ПараметрыОповещения.ДобавленныеПодписиОбъектов Цикл
		НовоеКоличествоЭП = НовоеКоличествоЭП + Элемент.Значение.МассивПодписей.Количество();
	КонецЦикла;
	
	Если ИсходныеПодписи.Количество() <> НовоеКоличествоЭП Тогда
		ИнтеграцияС1СДокументооборотБазоваяФункциональностьКлиент.ИнформироватьОПодписании(
			ОбъектДО,
			ПараметрыОповещения.ДобавленныеПодписиОбъектов,
			ОбъектДОID,
			УникальныйИдентификатор);
		ОбновитьОбзор();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПослеУдаленияФайлов(Результат, ПараметрыОповещения) Экспорт
	
	Если ЗначениеЗаполнено(Результат) Тогда
		ВыводитьОкноОжидания = Истина;
		ОбзорЗаполнен = Ложь;
		НачатьОбновлениеФормы(Элементы.СтраницаОбзор, ВыводитьОкноОжидания);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПриПодключении()
	
	Если ОбработатьФормуСогласноВерсииСервиса() Тогда
		НачатьПолучениеДанныхСвязанногоОбъектаДО(Элементы.ГруппаСтраницы.ТекущаяСтраница, Истина);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПроверитьОшибкиПриОбновленииФормы(Результат, НужноОбработатьФорму)
	
	Если Результат <> Неопределено Тогда
		Если Результат.Статус = "Ошибка" И ИнициализацияВыполнена = Ложь Тогда
			ПоказатьОшибкуПриОбновлении(Результат.КраткоеПредставлениеОшибки);
		ИначеЕсли Элементы.ГруппаСтраницыПодключения.ТекущаяСтраница = Элементы.СтраницаОшибкаПриОбновлении Тогда
			ТекстОшибкиПриОбновлении = "";
			НужноОбработатьФорму = Истина;
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

// Проверяет подключение к ДО, выводя окно авторизации, если необходимо, и изменяя форму согласно результату.
//
&НаКлиенте
Процедура ПроверитьПодключение()
	
	ОписаниеОповещения = Новый ОписаниеОповещения("ПроверитьПодключениеЗавершение", ЭтотОбъект);
	ИнтеграцияС1СДокументооборотБазоваяФункциональностьКлиент.ПроверитьПодключение(
		ОписаниеОповещения,
		ЭтотОбъект,,
		Ложь,
		Истина);
	
КонецПроцедуры

// Вызывается после проверки подключения к ДО и изменяет форму согласно результату.
//
&НаКлиенте
Процедура ПроверитьПодключениеЗавершение(Результат, Параметры) Экспорт
	
	Если Результат = Истина Тогда
		ПриПодключении();
	Иначе // Не удалось подключиться к ДО.
		ОбработатьФормуСогласноВерсииСервиса();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПроверитьПодписьЗавершение(ТаблицаПодписей, ПараметрыОповещения) Экспорт
	
	ИнтеграцияС1СДокументооборотБазоваяФункциональностьКлиент.УстановитьСтатусПодписей(ДеревоПодписей, ТаблицаПодписей);
	
КонецПроцедуры

&НаКлиенте
Процедура ПродолжитьПрерываниеОбработкиПослеВводаПричиныПрерывания(ПараметрыПрерывания,
		ДополнительныеПараметры) Экспорт
	
	Если ПараметрыПрерывания = Неопределено Или ПараметрыПрерывания = КодВозвратаДиалога.Отмена Тогда
		Возврат;
	КонецЕсли;
	
	ТипОперации = ИнтеграцияС1СДокументооборот3КлиентСервер.ТипОперацииСОбработкой();
	ТипОперации.Прервать = Истина;
	ПараметрыДействияСОбработкой = ПараметрыДействияСОбработкой();
	ПараметрыДействияСОбработкой.ПричинаПрерывания = ПараметрыПрерывания.ПричинаПрерывания;
	ДействиеСОбработкой(ТипОперации, ПараметрыДействияСОбработкой);
	
КонецПроцедуры

&НаКлиенте
Асинх Процедура СоздатьФайлСДиска()
	
	НеобходимоДобавитьСканКопию =
		Ждать ИнтеграцияС1СДокументооборотБазоваяФункциональностьКлиент.НеобходимоДобавитьСканКопиюАсинх(
			СостояниеРазрешаетДобавлениеСканКопии,
			СостояниеРазрешаетДобавлениеФайла);
	
	Если НеобходимоДобавитьСканКопию = КодВозвратаДиалога.Да Тогда
		ПараметрыНачалаСоздания = ПараметрыНачалаСозданияФайла();
		Если ИспользоватьРолиФайлов Тогда
			ПараметрыНачалаСоздания.ТекущийФайл.РольФайлаID = ИнтеграцияС1СДокументооборот3Клиент.ТекущаяРольФайла(
				ДеревоФайлов,
				Элементы.ДеревоФайлов.ТекущаяСтрока);
		КонецЕсли;
		ИнтеграцияС1СДокументооборотБазоваяФункциональностьКлиент.СоздатьФайлСДиска(ПараметрыНачалаСоздания);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура УбратьДоступностьКомандСпискаФайлов()
	
	Элементы.ФайлыОткрытьФайл.Доступность = Ложь;
	Элементы.ФайлыОткрытьФайлКонтекст.Доступность = Ложь;
	
	Элементы.ФайлыРедактировать.Доступность = Ложь;
	Элементы.ФайлыРедактироватьКонтекст.Доступность = Ложь;
	
	Элементы.ФайлыЗакончитьРедактирование.Доступность = Ложь;
	Элементы.ФайлыЗакончитьРедактированиеКонтекст.Доступность = Ложь;
	
	Элементы.ФайлыОсвободить.Доступность = Ложь;
	Элементы.ФайлыОсвободитьКонтекст.Доступность = Ложь;
	
	Элементы.ФайлыОбновитьИзФайлаНаДиске.Доступность = Ложь;
	Элементы.ФайлыОбновитьИзФайлаНаДискеКонтекст.Доступность = Ложь;
	
	Элементы.ФайлыНапечатать.Доступность = Ложь;
	Элементы.ФайлыНапечататьКонтекст.Доступность = Ложь;
	
	Элементы.ФайлыИзменить.Доступность = Ложь;
	Элементы.ФайлыИзменитьКонтекст.Доступность = Ложь;
	
	Элементы.ФайлыУдалить.Доступность = Ложь;
	Элементы.ФайлыУдалитьКонтекст.Доступность = Ложь;
	
	Элементы.ФайлыВыбратьРольФайлаКонтекст.Доступность = Ложь;
	
	Элементы.ФайлыСохранитьИзменения.Доступность = Ложь;
	Элементы.ФайлыСохранитьИзмененияКонтекст.Доступность = Ложь;
	
	Элементы.ГруппаЭПИШифрование.Доступность = Ложь;
	Элементы.ГруппаЭПИШифрованиеКонтекст.Доступность = Ложь;
	
	Элементы.ФайлыПодписатьФайл.Доступность = Ложь;
	Элементы.ФайлыПодписатьФайлКонтекст.Доступность = Ложь;
	
	Элементы.ФайлыДобавитьЭПИзФайла.Доступность = Ложь;
	Элементы.ФайлыДобавитьЭПИзФайлаКонтекст.Доступность = Ложь;
	
	Элементы.ФайлыСохранитьВместеСЭП.Доступность = Ложь;
	Элементы.ФайлыСохранитьВместеСЭПКонтекст.Доступность = Ложь;
	
КонецПроцедуры

&НаКлиенте
Процедура УдалитьПодписьЗавершение(Результат, ПараметрыОповещения) Экспорт
	
	Если Результат <> Истина Тогда
		Возврат;
	КонецЕсли;
	
	ОбновитьОбзор();
	
КонецПроцедуры

&НаКлиенте
Процедура УдалитьСвязь()
	
	ОчиститьДанныеОбъектаДО();
	ОбновитьВидимостьСтраниц(ОбъектДОТип);
	ОбновитьДекорацииОбъектаДО();
	
КонецПроцедуры

&НаКлиенте
Процедура УстановитьДоступностьКомандСпискаФайлов()
	
	ТекущиеДанные = Элементы.ДеревоФайлов.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Или ТекущиеДанные.Тип <> "DMFile" Тогда
		
		Элементы.ФайлыОбновитьПредпросмотр.Видимость = Ложь;
		Элементы.ПредставлениеHTMLДокументаКонтекстноеМенюОбновитьОбзор.Видимость = Истина;
		
		УбратьДоступностьКомандСпискаФайлов();
		
		ОбъектМожноСохранитьНаДиск = (ТекущиеДанные = Неопределено)
			Или ИнтеграцияС1СДокументооборот3Клиент.ОбъектМожноСохранитьНаДиск(ТекущиеДанные.Тип);
		Элементы.ФайлыСохранитьКак.Доступность = ОбъектМожноСохранитьНаДиск;
		Элементы.ФайлыСохранитьКакКонтекст.Доступность = ОбъектМожноСохранитьНаДиск;
		
	Иначе
		
		Элементы.ФайлыОбновитьПредпросмотр.Видимость = Истина;
		Элементы.ПредставлениеHTMLДокументаКонтекстноеМенюОбновитьОбзор.Видимость = Ложь;
		
		Редактируется = ТекущиеДанные.Редактируется;
		РедактируетсяТекущимПользователем = ТекущиеДанные.РедактируетсяТекущимПользователем;
		ЕстьПодписи = ТекущиеДанные.ПодписанЭП;
		Зашифрован = ТекущиеДанные.Зашифрован;
		
		РедактируетсяДругимПользователем =
			Редактируется
			И Не РедактируетсяТекущимПользователем;
		МожноЗахватить =
			СостояниеРазрешаетРедактированиеФайла
			И Не РедактируетсяДругимПользователем
			И Не Зашифрован
			И Не ЕстьПодписи;
		МожноОтпустить =
			СостояниеРазрешаетРедактированиеФайла
			И РедактируетсяТекущимПользователем
			И Не Зашифрован
			И Не ЕстьПодписи;
		
		Элементы.ФайлыОткрытьФайл.Доступность = Не Зашифрован;
		Элементы.ФайлыОткрытьФайлКонтекст.Доступность = Не Зашифрован;
		
		Элементы.ФайлыРедактировать.Доступность = МожноЗахватить;
		Элементы.ФайлыРедактироватьКонтекст.Доступность = МожноЗахватить;
		
		Элементы.ФайлыЗакончитьРедактирование.Доступность = МожноОтпустить;
		Элементы.ФайлыЗакончитьРедактированиеКонтекст.Доступность = МожноОтпустить;
		
		Элементы.ФайлыОсвободить.Доступность = МожноОтпустить;
		Элементы.ФайлыОсвободитьКонтекст.Доступность = МожноОтпустить;
		
		Элементы.ФайлыОбновитьИзФайлаНаДиске.Доступность = МожноЗахватить;
		Элементы.ФайлыОбновитьИзФайлаНаДискеКонтекст.Доступность = МожноЗахватить;
		
		Элементы.ФайлыНапечатать.Доступность = Не Зашифрован;
		Элементы.ФайлыНапечататьКонтекст.Доступность = Не Зашифрован;
		
		Элементы.ФайлыИзменить.Доступность = Истина;
		Элементы.ФайлыИзменитьКонтекст.Доступность = Истина;
		
		Элементы.ФайлыУдалить.Доступность = СостояниеРазрешаетУдалениеФайла И Не Редактируется И Не ПодписанЭП;
		Элементы.ФайлыУдалитьКонтекст.Доступность = СостояниеРазрешаетУдалениеФайла И Не Редактируется И Не ПодписанЭП;
		
		Элементы.ФайлыСохранитьКак.Доступность = Не Зашифрован;
		Элементы.ФайлыСохранитьКакКонтекст.Доступность = Не Зашифрован;
		
		Элементы.ФайлыВыбратьРольФайлаКонтекст.Доступность = СостояниеРазрешаетДобавлениеФайла;
		
		Элементы.ФайлыСохранитьИзменения.Доступность = МожноОтпустить;
		Элементы.ФайлыСохранитьИзмененияКонтекст.Доступность = МожноОтпустить;
		
		Элементы.ГруппаЭПИШифрование.Доступность = СостояниеРазрешаетИзменениеЭП;
		Элементы.ГруппаЭПИШифрованиеКонтекст.Доступность = СостояниеРазрешаетИзменениеЭП;
		
		Элементы.ФайлыПодписатьФайл.Доступность = Не Редактируется И Не Зашифрован;
		Элементы.ФайлыПодписатьФайлКонтекст.Доступность = Не Редактируется И Не Зашифрован;
		
		Элементы.ФайлыДобавитьЭПИзФайла.Доступность = Не Редактируется И Не Зашифрован;
		Элементы.ФайлыДобавитьЭПИзФайлаКонтекст.Доступность = Не Редактируется И Не Зашифрован;
		
		Элементы.ФайлыСохранитьВместеСЭП.Доступность = ЕстьПодписи;
		Элементы.ФайлыСохранитьВместеСЭПКонтекст.Доступность = ЕстьПодписи;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура УстановитьДоступностьКомандСпискаЭП()
	
	ЕстьПодписи = (ДеревоПодписей.ПолучитьЭлементы().Количество() > 0);
	ЭтоПодпись = ИнтеграцияС1СДокументооборотБазоваяФункциональностьКлиент.ЭтоПодпись(
		Элементы.ДеревоПодписей.ТекущиеДанные);
	
	Элементы.ДеревоПодписейОткрыть.Доступность = ЕстьПодписи;
	Элементы.ДеревоПодписейОткрытьКонтекст.Доступность = ЕстьПодписи;
	
	Элементы.ДеревоПодписейПроверить.Доступность = ЕстьПодписи;
	Элементы.ДеревоПодписейПроверитьКонтекст.Доступность = ЕстьПодписи;
	
	Элементы.ДеревоПодписейПроверитьВсе.Доступность = ЕстьПодписи;
	Элементы.ДеревоПодписейПроверитьВсеКонтекст.Доступность = ЕстьПодписи;
	
	Элементы.ДеревоПодписейСохранить.Доступность = ЭтоПодпись;
	Элементы.ДеревоПодписейСохранитьКонтекст.Доступность = ЭтоПодпись;
	
	Элементы.ДеревоПодписейУдалить.Доступность = ЕстьПодписи;
	Элементы.ДеревоПодписейУдалитьКонтекст.Доступность = ЕстьПодписи;
	
КонецПроцедуры

#КонецОбласти

#Область Сервер

&НаСервере
Процедура ДобавитьПодписи(ДобавленныеПодписиОбъектов)
	
	ИнтеграцияС1СДокументооборотБазоваяФункциональность.ПодписатьДокумент(ДобавленныеПодписиОбъектов, ДеревоПодписей);
	
КонецПроцедуры

&НаСервере
Процедура ИзменитьПризнакЯвляетсяОригиналом(ИзменяемыйФайл)
	
	Прокси = ИнтеграцияС1СДокументооборотБазоваяФункциональностьПовтИсп.ПолучитьПрокси();
	
	ФайлXDTO = ИнтеграцияС1СДокументооборотБазоваяФункциональность.СоздатьОбъект(Прокси, ИзменяемыйФайл.Тип);
	ФайлXDTO.name = ИзменяемыйФайл.Наименование;
	ФайлXDTO.objectID = ИнтеграцияС1СДокументооборотБазоваяФункциональность.СоздатьObjectID(
		Прокси,
		ИзменяемыйФайл.ID,
		ИзменяемыйФайл.Тип);
	ФайлXDTO.scannedOriginal = ИзменяемыйФайл.ЯвляетсяОригиналом;
	
	ИнтеграцияС1СДокументооборотБазоваяФункциональность.ЗаписатьОбъект(Прокси, ФайлXDTO);
	
КонецПроцедуры

&НаСервере
Функция КолонкиДляПолученияОбъектаДО(ТипОбъектаДО, ТекущаяСтраницаИмя, ПолучатьФайлы = Ложь)
	
	Колонки = Новый Массив;
	Колонки.Добавить("name");
	Если ТипОбъектаДО = "DMDocument" Тогда
		Колонки.Добавить("documentType");
	ИначеЕсли ТипОбъектаДО = "DMMeeting" Тогда
		Колонки.Добавить("type");
	КонецЕсли;
	
	Если ДоступенОбзор И (ТекущаяСтраницаИмя = "СтраницаОбзор" Или ТекущаяСтраницаИмя = "СтраницаЭП") Тогда
		Колонки.Добавить("files");
		Если ПоказыватьPDFСредствами1С Тогда
			Колонки.Добавить("binaryData");
		КонецЕсли;
		Колонки.Добавить("htmlView");
		Если ИнтеграцияС1СДокументооборот3.ЭтоДокументДО3(ТипОбъектаДО) Тогда
			Колонки.Добавить("documentType");
			Колонки.Добавить("enabledProperties");
		КонецЕсли;
		Если ФайлыПоказыватьУдаленные Тогда
			Колонки.Добавить("ignoreDeletionMark");
		КонецЕсли;
		// Добавим поля для получения группы состояний и документов ЭДО.
		Если ДоступноПолучениеДанныхФормы Тогда
			Колонки.Добавить("form");
			Колонки.Добавить("EDIDocuments");
		КонецЕсли;
		ПолучатьФайлы = Истина;
		
		Если ИспользоватьЭлектронныеПодписиДО Тогда
			Колонки.Добавить("comment");
			Колонки.Добавить("keyPropertiesValue");
			Колонки.Добавить("signatures");
			Колонки.Добавить("signatureStatus");
			Колонки.Добавить("signatureStatusDescription");
		КонецЕсли;
	КонецЕсли;
	
	Возврат Колонки;
	
КонецФункции

// Вызывается при получении и изменении данных о связанном объекте, при удалении связи, при изменении
// настроек интеграции. Определяет доступность функционала и изменяет видимость соответствующих страниц формы.
//
&НаСервере
Процедура ОбновитьВидимостьСтраниц(Знач ТипОбъектаДО)
	
	Элементы.СтраницаОбзор.Видимость = Истина;
	ДоступенОбзор = Истина;
	Если ИнтеграцияС1СДокументооборот3.ЭтоИзвестныйОбъектОбзора(ТипОбъектаДО) Тогда
		Если Не ИнтеграцияС1СДокументооборотБазоваяФункциональностьПовтИсп.ДоступенФункционалВерсииСервиса("3.0.9.18") Тогда
			ДоступенОбзор = Ложь;
			Элементы.ДекорацияОписаниеОбзорНедоступен.Заголовок = НСтр(
				"ru = 'Просмотр обзора не поддерживается в данной версии 1С:Документооборота.
				|Требуется 1С:Документооборот версии 3.0.9 или выше.'");
		КонецЕсли;
	Иначе
		Элементы.СтраницаОбзор.Видимость = Ложь;
		ДоступенОбзор = Ложь;
		Элементы.ДекорацияОписаниеОбзорНедоступен.Заголовок = НСтр(
			"ru = 'Интегрированный объект не поддерживает просмотр обзора.'");
	КонецЕсли;
	
	Элементы.СтраницаОбработка.Видимость = Истина;
	ДоступенПросмотрОбработки = Истина;
	Если ИспользоватьОбработкуОбъектов1СДокументооборота Тогда
		Если ИнтеграцияС1СДокументооборот3.ОбъектДОПоддерживаетОбработку(ТипОбъектаДО) Тогда
			Если Не ИнтеграцияС1СДокументооборотБазоваяФункциональностьПовтИсп.ДоступенФункционалВерсииСервиса("3.0.12.22") Тогда
				ДоступенПросмотрОбработки = Ложь;
				Элементы.ДекорацияОписаниеОбработкаНедоступна.Заголовок = НСтр(
					"ru = 'Просмотр обработки не поддерживается в данной версии 1С:Документооборота.
					|Требуется 1С:Документооборот версии 3.0.12 или выше.'");
			КонецЕсли;
		Иначе
			Элементы.СтраницаОбработка.Видимость = Ложь;
			ДоступенПросмотрОбработки = Ложь;
			Элементы.ДекорацияОписаниеОбработкаНедоступна.Заголовок = НСтр(
				"ru = 'Интегрированный объект не поддерживает функционал обработки.'");
		КонецЕсли;
	Иначе
		Элементы.СтраницаОбработка.Видимость = Ложь;
		ДоступенПросмотрОбработки = Ложь;
		Элементы.ДекорацияОписаниеОбработкаНедоступна.Заголовок = НСтр(
			"ru = 'Функционал обработки выключен в настройках интеграции.'");
	КонецЕсли;
	
	Элементы.СтраницаСвязи.Видимость = Истина;
	ДоступноДеревоСвязей = Истина;
	Если ИнтеграцияС1СДокументооборот3.ЭтоДокументДО3(ТипОбъектаДО) Или ТипОбъектаДО = "DMMeeting" Тогда
		Если Не ИнтеграцияС1СДокументооборотБазоваяФункциональностьПовтИсп.ДоступенФункционалВерсииСервиса("3.0.17.36") Тогда
			ДоступноДеревоСвязей = Ложь;
			Элементы.ДекорацияОписаниеСвязиНедоступны.Заголовок = НСтр(
				"ru = 'Просмотр дерева связей не поддерживается в данной версии 1С:Документооборота.
				|Требуется 1С:Документооборот версии 3.0.17 или выше.'");
		КонецЕсли;
	Иначе
		Элементы.СтраницаСвязи.Видимость = Ложь;
		ДоступноДеревоСвязей = Ложь;
		Элементы.ДекорацияОписаниеСвязиНедоступны.Заголовок = НСтр(
			"ru = 'Интегрированный объект не поддерживает функционал связей.'");
	КонецЕсли;
	
	Элементы.СтраницаЭП.Видимость = Истина;
	ДоступноДеревоПодписей = Истина;
	Если ИспользоватьЭлектронныеПодписиДО И ИнтеграцияС1СДокументооборот3.ЭтоИзвестныйОбъектОбзора(ТипОбъектаДО) Тогда
		Если Не ИнтеграцияС1СДокументооборотБазоваяФункциональностьПовтИсп.ДоступенФункционалВерсииСервиса("3.0.9.18") Тогда
			ДоступноДеревоПодписей = Ложь;
			Элементы.ДекорацияОписаниеПодписиНедоступны.Заголовок = НСтр(
				"ru = 'Просмотр электронных подписей не поддерживается в данной версии 1С:Документооборота.
				|Требуется 1С:Документооборот версии 3.0.9 или выше.'");
		КонецЕсли;
	Иначе
		Элементы.СтраницаЭП.Видимость = Ложь;
		ДоступноДеревоПодписей = Ложь;
		Элементы.ДекорацияОписаниеПодписиНедоступны.Заголовок = НСтр(
			"ru = 'Использование электронных подписей выключено.'");
	КонецЕсли;
	
	ДоступенПросмотрДействий =
		ИнтеграцияС1СДокументооборотБазоваяФункциональностьПовтИсп.ДоступенФункционалВерсииСервиса("3.0.13.29");
	ДоступноСозданиеСвязей = ИнтеграцияС1СДокументооборот3.ДоступноСозданиеСвязей();
	ДоступноПолучениеДанныхФормы =
		ИнтеграцияС1СДокументооборотБазоваяФункциональностьПовтИсп.ДоступенФункционалВерсииСервиса("3.0.20.19");
	
	Элементы.ПодписатьДокумент.Видимость = ИспользоватьЭлектронныеПодписиДО
		И ИспользоватьЭлектронныеПодписиИС
		И ИнтеграцияС1СДокументооборот3.ЭтоДокументДО3(ТипОбъектаДО);
	Элементы.ПодписатьДокументКонтекст.Видимость = ИспользоватьЭлектронныеПодписиДО
		И ИспользоватьЭлектронныеПодписиИС
		И ИнтеграцияС1СДокументооборот3.ЭтоДокументДО3(ТипОбъектаДО);
	
	Если Не ДоступноСозданиеСвязей Тогда
		Элементы.ДеревоСвязейДобавить.Видимость = Ложь;
		Элементы.ДеревоСвязейКонтекстноеМенюДобавить.Видимость = Ложь;
		Элементы.ДеревоСвязейКонтекстноеМенюУдалить.Видимость = Ложь;
	КонецЕсли;
	
	ДоступныеЗакладки = Новый Массив;
	Если Элементы.СтраницаОбзор.Видимость Тогда
		ДоступныеЗакладки.Добавить("СтраницаОбзор");
	КонецЕсли;
	Если Элементы.СтраницаОбработка.Видимость Тогда
		ДоступныеЗакладки.Добавить("СтраницаОбработка");
	КонецЕсли;
	Если Элементы.СтраницаСвязи.Видимость Тогда
		ДоступныеЗакладки.Добавить("СтраницаСвязи");
	КонецЕсли;
	Если Элементы.СтраницаЭП.Видимость Тогда
		ДоступныеЗакладки.Добавить("СтраницаЭП");
	КонецЕсли;
	
	// Сохраненная закладка может быть неактуальной.
	Если ЗначениеЗаполнено(ТекущаяЗакладка) И ДоступныеЗакладки.Найти(ТекущаяЗакладка) = Неопределено Тогда
		ТекущаяЗакладка = "";
	КонецЕсли;
	Если ТекущаяЗакладка = "" И ДоступныеЗакладки.Количество() > 0 Тогда
		ТекущаяЗакладка = ДоступныеЗакладки[0];
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ТекущаяЗакладка) И Элементы.ГруппаСтраницы.ТекущаяСтраница <> Элементы[ТекущаяЗакладка] Тогда
		Элементы.ГруппаСтраницы.ТекущаяСтраница = Элементы[ТекущаяЗакладка];
	КонецЕсли;
	
	Если ДоступныеЗакладки.Количество() > 1 Тогда
		Элементы.ГруппаСтраницы.ОтображениеСтраниц = ОтображениеСтраницФормы.ЗакладкиСверху;
	Иначе
		Элементы.ГруппаСтраницы.ОтображениеСтраниц = ОтображениеСтраницФормы.Нет;
	КонецЕсли;
	
КонецПроцедуры

// Вызывается при открытии формы, при изменении правил интеграции, при получении и изменении данных о
// связанном объекте. Заполняет декорацию заголовка связанного объекта, а также информацию о недоступности
// правил интеграции.
//
&НаСервере
Процедура ОбновитьЗаголовокСвязанногоОбъекта()
	
	Если ЗначениеЗаполнено(ОбъектДОТип) Тогда
		
		ПредставлениеТипаОбъектаДО = ИнтеграцияС1СДокументооборот3КлиентСервер.ПредставлениеТипаОбъектаXDTO(ОбъектДОТип);
		Элементы.ДекорацияОбъектЗаголовок.Заголовок = СтрШаблон("%1:", ПредставлениеТипаОбъектаДО);
		
	Иначе
		
		Если ЗначениеЗаполнено(ПредставлениеСоздаваемогоОбъекта) Тогда
			Элементы.ДекорацияОбъектЗаголовок.Заголовок = СтрШаблон("%1:", ПредставлениеСоздаваемогоОбъекта);
			
		ИначеЕсли ЗначениеЗаполнено(ТипСоздаваемогоОбъекта) Тогда
			Элементы.ДекорацияОбъектЗаголовок.Заголовок = СтрШаблон("%1:",
				ИнтеграцияС1СДокументооборот3КлиентСервер.ПредставлениеТипаОбъектаXDTO(ТипСоздаваемогоОбъекта));
			
		Иначе
			// Нет подходящих правил.
			Элементы.ДекорацияОбъектЗаголовок.Заголовок = НСтр("ru = 'Соответствие в 1С:Документообороте:'");
			
		КонецЕсли;
		
	КонецЕсли;
	
	Если Элементы.ГруппаИнфо.Видимость Тогда
		
		Если КоличествоПодходящихПравилИнтеграции = 0 Тогда
			
			ПолноеИмяПотребителяПоЧастям = СтрРазделить(ПолноеИмяПотребителя, ".");
			Если ПолноеИмяПотребителяПоЧастям[0] = "Документ" Тогда
				ПредставлениеТипаОбъектаИС = НСтр("ru = 'документа'");
			ИначеЕсли ПолноеИмяПотребителяПоЧастям[0] = "Справочник" Тогда
				ПредставлениеТипаОбъектаИС = НСтр("ru = 'справочника'");
			Иначе
				ПредставлениеТипаОбъектаИС = НСтр("ru = 'объекта'");
			КонецЕсли;
			Если ЗначениеЗаполнено(ВнешнийОбъект) Тогда
				ПредставлениеОбъектаИС = Строка(ВнешнийОбъект);
			Иначе
				ПредставлениеОбъектаИС = ИмяПотребителя;
			КонецЕсли;
			
			Если ЗначениеЗаполнено(ОбъектДОТип) Тогда
				// Связанный объект уже есть.
				Попытка
					ПредставлениеТипаОбъектаДО = НРег(ПолучитьСклоненияСтроки(
						ПредставлениеТипаОбъектаДО,
						"Л=ru_RU",
						"ПД=Родительный")[0]);
				Исключение
					ПредставлениеТипаОбъектаДО = НСтр("ru = 'объекта'");
				КонецПопытки;
				Инфо = СтрШаблон(НСтр(
					"ru = 'Не настроено правило интеграции для заполнения %1 1С:Документооборота ""%2"" из %3 ""%4"".'"),
					ПредставлениеТипаОбъектаДО,
					ОбъектДО,
					ПредставлениеТипаОбъектаИС,
					ПредставлениеОбъектаИС);
			Иначе
				// Связанный объект еще не создан.
				Инфо = СтрШаблон(НСтр(
					"ru = 'Не настроено правило интеграции для создания объекта 1С:Документооборота из %1 ""%2"".'"),
					ПредставлениеТипаОбъектаИС,
					ПредставлениеОбъектаИС);
			КонецЕсли;
			
			Команда = "ФормаЭлемента";
			
		Иначе
			
			Инфо = СтрШаблон(НСтр(
				"ru = 'Настроено заполнение разных типов объектов 1С:Документооборота из ""%1"".
				|Измените правила или удалите лишние.'"),
				ИмяПотребителя);
			Команда = "ФормаСписка";
			
		КонецЕсли;
		
		Если ПравоДоступа("Добавление", Метаданные.Справочники.ПравилаИнтеграцииС1СДокументооборотом3) Тогда
			Инфо = СтроковыеФункции.ФорматированнаяСтрока(
				СтрШаблон("%1 <a href = ""%2||%3"">%4.</a>",
					Инфо,
					Команда,
					ПолноеИмяПотребителя,
					НСтр("ru = 'Настроить'")));
		КонецЕсли;
		
		Элементы.ДекорацияИнфо.Заголовок = Инфо;
		
	КонецЕсли;
	
КонецПроцедуры

// Вызывается при открытии формы и при изменении правил интеграции. Заполняет представление объекта,
// который можно создать через правила интеграции.
//
&НаСервере
Процедура ОбновитьПредставлениеСоздаваемогоОбъекта()
	
	ТипСоздаваемогоОбъекта = "";
	ПредставлениеСоздаваемогоОбъекта = "";
	ВидДокументаИзПравил = "";
	ВидДокументаИзПравилID = "";
	
	// Получим тип и представление создаваемого объекта, если они однозначны.
	ПодходящиеПравилаИнтеграции = ИнтеграцияС1СДокументооборот3ВызовСервера.ПодходящиеПравилаИнтеграцииОбъекта(
		ВнешнийОбъект);
	КоличествоПодходящихПравилИнтеграции = ПодходящиеПравилаИнтеграции.Количество();
	РеквизитыПравил = ОбщегоНазначения.ЗначенияРеквизитовОбъектов(
		ПодходящиеПравилаИнтеграции,
		"ТипОбъектаДО, ПредставлениеОбъектаДО, ВидДокументаДО, ВидДокументаДОID");
	Для Каждого Правило Из ПодходящиеПравилаИнтеграции Цикл
		Если Не ЗначениеЗаполнено(ТипСоздаваемогоОбъекта) Тогда
			ТипСоздаваемогоОбъекта = РеквизитыПравил[Правило].ТипОбъектаДО;
		ИначеЕсли ТипСоздаваемогоОбъекта <> РеквизитыПравил[Правило].ТипОбъектаДО Тогда
			ТипСоздаваемогоОбъекта = "";
			Прервать;
		КонецЕсли;
	КонецЦикла;
	Для Каждого Правило Из ПодходящиеПравилаИнтеграции Цикл
		Если Не ЗначениеЗаполнено(ПредставлениеСоздаваемогоОбъекта) Тогда
			ПредставлениеСоздаваемогоОбъекта = РеквизитыПравил[Правило].ПредставлениеОбъектаДО;
		ИначеЕсли ПредставлениеСоздаваемогоОбъекта <> РеквизитыПравил[Правило].ПредставлениеОбъектаДО Тогда
			ПредставлениеСоздаваемогоОбъекта = "";
			Прервать;
		КонецЕсли;
	КонецЦикла;
	Для Каждого Правило Из ПодходящиеПравилаИнтеграции Цикл
		Если Не ЗначениеЗаполнено(ВидДокументаИзПравилID) Тогда
			ВидДокументаИзПравил = РеквизитыПравил[Правило].ВидДокументаДО;
			ВидДокументаИзПравилID = РеквизитыПравил[Правило].ВидДокументаДОID;
		ИначеЕсли ВидДокументаИзПравилID <> РеквизитыПравил[Правило].ВидДокументаДОID Тогда
			ВидДокументаИзПравил = "";
			ВидДокументаИзПравилID = "";
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
	Элементы.ГруппаИнфо.Видимость = Не ЗначениеЗаполнено(ПредставлениеСоздаваемогоОбъекта)
		И Не ЗначениеЗаполнено(ТипСоздаваемогоОбъекта);
	ОбновитьЗаголовокСвязанногоОбъекта();
	
КонецПроцедуры

// Изменяет форму согласно доступности сервиса ДО и номеру его версии.
//
&НаСервере
Функция ОбработатьФормуСогласноВерсииСервиса()
	
	ВерсияСервиса = ИнтеграцияС1СДокументооборотБазоваяФункциональность.ВерсияСервиса();
	
	ФормаОбработанаУспешно = Истина;
	
	Если Не ИнтеграцияС1СДокументооборотБазоваяФункциональностьКлиентСервер.СервисДоступен(ВерсияСервиса) Тогда
		
		Элементы.ГруппаСтраницыПодключения.ТекущаяСтраница = Элементы.СтраницаДокументооборотНедоступен;
		ФормаОбработанаУспешно = Ложь;
		
	ИначеЕсли ИнтеграцияС1СДокументооборот3.ДоступенФункционалФайлов() Тогда
		
		Элементы.ГруппаСтраницыПодключения.ТекущаяСтраница = Элементы.СтраницаДокументооборотДоступен;
		
		НастройкиДокументооборота = ИнтеграцияС1СДокументооборотБазоваяФункциональностьПовтИсп.ПолучитьНастройки();
		ЗаголовокСообщенияВОбластиПредпросмотра = НастройкиДокументооборота.ЗаголовокСообщенияВОбластиПредпросмотра;
		ИспользоватьЭлектронныеПодписиДО = (НастройкиДокументооборота.ИспользоватьЭлектронныеЦифровыеПодписи = Истина);
		ПоказыватьPDFСредствами1С = НастройкиДокументооборота.ПоказыватьPDFСредствами1С;
		СписокРасширенийСканКопийОригиналов = НастройкиДокументооборота.СписокРасширенийСканКопийОригиналов;
		
		Элементы.ФайлыПодписанЗашифрован.Видимость = ИспользоватьЭлектронныеПодписиДО;
		Элементы.ФайлыПодписатьФайл.Видимость = (ИспользоватьЭлектронныеПодписиДО И ИспользоватьЭлектронныеПодписиИС);
		Элементы.ФайлыПодписатьФайлКонтекст.Видимость = (ИспользоватьЭлектронныеПодписиДО И ИспользоватьЭлектронныеПодписиИС);
		Элементы.ФайлыДобавитьЭПИзФайла.Видимость = (ИспользоватьЭлектронныеПодписиДО И ИспользоватьЭлектронныеПодписиИС);
		Элементы.ФайлыДобавитьЭПИзФайлаКонтекст.Видимость = (ИспользоватьЭлектронныеПодписиДО И ИспользоватьЭлектронныеПодписиИС);
		Элементы.ФайлыСохранитьВместеСЭП.Видимость = (ИспользоватьЭлектронныеПодписиДО И ИспользоватьЭлектронныеПодписиИС);
		Элементы.ФайлыСохранитьВместеСЭПКонтекст.Видимость = (ИспользоватьЭлектронныеПодписиДО И ИспользоватьЭлектронныеПодписиИС);
		
		Если ПоказыватьPDFСредствами1С Тогда
			ИнтеграцияС1СДокументооборот3.ВывестиPDFДокументНаФорму(
				ЭтотОбъект,
				"СтраницаГруппаPDFОбзор",
				"ДокументPDFОбзорПоле",
				"ДокументPDFОбзорРеквизит");
			ИнтеграцияС1СДокументооборот3.ВывестиPDFДокументНаФорму(
				ЭтотОбъект,
				"СтраницаГруппаPDFСвязи",
				"ДокументPDFСвязиПоле",
				"ДокументPDFСвязиРеквизит");
		КонецЕсли;
		
		ИнтеграцияС1СДокументооборотБазоваяФункциональностьКлиентСервер.УстановитьЗначенияВсехПолейНДПС(
			ЭтотОбъект,
			Истина);
		
	Иначе
		
		Элементы.ГруппаСтраницыПодключения.ТекущаяСтраница = Элементы.СтраницаВерсияНеПоддерживается;
		ФормаОбработанаУспешно = Ложь;
		
	КонецЕсли;
	
	Возврат ФормаОбработанаУспешно;
	
КонецФункции

&НаСервере
Процедура ОчиститьДанныеОбъектаДО()
	
	ОбъектДО = "";
	ОбъектДОID = "";
	ОбъектДОТип = "";
	ОбновитьЗаголовокСвязанногоОбъекта();
	ВидОбъектаДО = "";
	ВидОбъектаДОID = "";
	ВидОбъектаДОТип = "";
	ОбъектДОНавигационнаяСсылка = "";
	ПредставлениеHTML = "";
	Действия.ПолучитьЭлементы().Очистить();
	
КонецПроцедуры

&НаСервере
Процедура ПеречитатьФункциональныеОпции(Знач ТипОбъектаДО)
	
	ИспользоватьОбработкуОбъектов1СДокументооборота =
		Константы.ИспользоватьОбработкуОбъектов1СДокументооборота.Получить();
	
	ОбновитьВидимостьСтраниц(ТипОбъектаДО);
	
КонецПроцедуры

&НаСервере
Процедура ПоказатьОшибкуПриОбновлении(Ошибка)
	
	ТекстОшибкиПриОбновлении = Ошибка;
	Элементы.ГруппаСтраницыПодключения.ТекущаяСтраница = Элементы.СтраницаОшибкаПриОбновлении;
	
	ОбзорЗаполнен = Ложь;
	ТекущаяЗакладка = "СтраницаОбзор";
	Элементы.ГруппаСтраницы.ТекущаяСтраница = Элементы.СтраницаОбзор;
	
КонецПроцедуры

#КонецОбласти

#Область ОбновитьФорму

&НаКлиенте
Процедура НачатьОбновлениеФормы(ТекущаяСтраница, ВыводитьОкноОжидания = Истина, ПриСменеСтраницы = Ложь)
	
	Если ПустаяСтрока(ОбъектДОID) Или ПустаяСтрока(ОбъектДОТип) Тогда
		НачатьПолучениеДанныхСвязанногоОбъектаДО(Элементы.ГруппаСтраницы.ТекущаяСтраница, Истина);
		Возврат;
	КонецЕсли;
	
	ДлительнаяОперация = ОбновитьФорму(ТекущаяСтраница.Имя, ВыводитьОкноОжидания);
	Если ДлительнаяОперация = Неопределено Тогда
		// Получать данные из ДО не требуется.
		Возврат;
	КонецЕсли;
	
	ПараметрыОповещения = Новый Структура("ТекущаяСтраницаИмя, ВыводитьОкноОжидания, ПриСменеСтраницы",
		ТекущаяСтраница.Имя,
		ВыводитьОкноОжидания,
		ПриСменеСтраницы);
	ОповещениеОЗавершении = Новый ОписаниеОповещения(
		"ОбновлениеФормыЗавершение",
		ЭтотОбъект,
		ПараметрыОповещения);
	ИнтеграцияС1СДокументооборотБазоваяФункциональностьКлиент.ВыполнитьЗапросАсинхронно(
		ЭтотОбъект,
		ДлительнаяОперация,
		ОповещениеОЗавершении,
		ВыводитьОкноОжидания,
		НСтр("ru = 'Получение данных из 1С:Документооборота.'"),
		Ложь);
	
КонецПроцедуры

&НаСервере
Функция ОбновитьФорму(Знач ТекущаяСтраницаИмя, Знач ВыводитьОкноОжидания)
	
	Прокси = ИнтеграцияС1СДокументооборотБазоваяФункциональностьПовтИсп.ПолучитьПрокси();
	
	ЗапросыПакета = Новый Массив;
	
	Если ДоступенОбзор И Не ОбзорЗаполнен
			И (ТекущаяСтраницаИмя = "СтраницаОбзор" Или ТекущаяСтраницаИмя = "СтраницаЭП") Тогда
		ОбъектДляПолученияИзДО = Новый Структура;
		ОбъектДляПолученияИзДО.Вставить("ID", ОбъектДОID);
		ОбъектДляПолученияИзДО.Вставить("Тип", ОбъектДОТип);
		ОбъектДляПолученияИзДО.Вставить("ВнешнийОбъектИС", ВнешнийОбъект);
		Колонки = КолонкиДляПолученияОбъектаДО(ОбъектДОТип, ТекущаяСтраницаИмя);
		ЗапросыПакета.Добавить(
			ИнтеграцияС1СДокументооборотБазоваяФункциональность.ПолучитьОбъектыЗапрос(
				Прокси,
				ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(ОбъектДляПолученияИзДО),
				Колонки));
		ЗапросыПакета.Добавить(
			ИнтеграцияС1СДокументооборот3.HTMLПредпросмотрОбъектаЗапрос(
				Прокси,
				ОбъектДОID,
				ОбъектДОТип));
		Если Не ВыводитьОкноОжидания Тогда
			Элементы.ГруппаСтраницыПолученияДанныхОбзор.ТекущаяСтраница = Элементы.СтраницаЗагрузкаИзДООбзор;
			Элементы.ГруппаСтраницыПолученияДанныхПодписи.ТекущаяСтраница = Элементы.СтраницаЗагрузкаИзДОПодписи;
		КонецЕсли;
	КонецЕсли;
	
	Если ДоступенПросмотрОбработки И Не ОбработкаЗаполнена И ТекущаяСтраницаИмя = "СтраницаОбработка" Тогда
		ЗапросыПакета.Добавить(
			ИнтеграцияС1СДокументооборот3.ТекущаяОбработкаОбъектаЗапрос(
				Прокси,
				ОбъектДОID,
				ОбъектДОТип));
		Если Не ВыводитьОкноОжидания Тогда
			Элементы.ГруппаСтраницыПолученияДанныхОбработка.ТекущаяСтраница = Элементы.СтраницаЗагрузкаИзДООбработка;
		КонецЕсли;
	КонецЕсли;
	
	Если ДоступноДеревоСвязей И Не ДеревоСвязейЗаполнено И ТекущаяСтраницаИмя = "СтраницаСвязи" Тогда
		Если ДеревоСвязейРазворачиваемаяСтрока <> 0 Тогда
			СтрокаДереваСвязей = ДеревоСвязей.НайтиПоИдентификатору(ДеревоСвязейРазворачиваемаяСтрока).ПолучитьРодителя();
			РеквизитыОбъекта =
				ИнтеграцияС1СДокументооборотБазоваяФункциональностьКлиентСервер.ДанныеСсылочногоОбъектаДО(
					СтрокаДереваСвязей.СвязанныйОбъектID, СтрокаДереваСвязей.СвязанныйОбъектТип);
		Иначе
			РеквизитыОбъекта =
				ИнтеграцияС1СДокументооборотБазоваяФункциональностьКлиентСервер.ДанныеСсылочногоОбъектаДО(
					ОбъектДОID, ОбъектДОТип);
		КонецЕсли;
		ЗапросыПакета.Добавить(ИнтеграцияС1СДокументооборот3.СвязиОбъектаЗапрос(Прокси, РеквизитыОбъекта));
		Если Не ВыводитьОкноОжидания И ДеревоСвязейРазворачиваемаяСтрока = 0 Тогда
			Элементы.ГруппаСтраницыПолученияДанныхСвязи.ТекущаяСтраница = Элементы.СтраницаЗагрузкаИзДОСвязи;
		КонецЕсли;
	КонецЕсли;
	
	Если ЗапросыПакета.Количество() > 0 Тогда
		Возврат ИнтеграцияС1СДокументооборотБазоваяФункциональность.ВыполнитьПакетныйЗапросАсинхронно(
			Прокси,
			ЗапросыПакета,
			УникальныйИдентификатор,
			НСтр("ru = 'Получение данных из 1С:Документооборота'"));
	КонецЕсли;
	
КонецФункции

&НаКлиенте
Процедура ОбновлениеФормыЗавершение(Результат, ПараметрыОповещения) Экспорт
	
	ОбработатьФорму = Ложь;
	ПроверитьОшибкиПриОбновленииФормы(Результат, ОбработатьФорму);
	Если ОбработатьФорму Тогда
		ОбработатьФормуСогласноВерсииСервиса();
	КонецЕсли;
	
	Если Результат <> Неопределено И Результат.Статус = "Ошибка" Тогда
		ТекстОшибкиПриОбновлении = Результат.КраткоеПредставлениеОшибки;
		Если Не ПараметрыОповещения.ВыводитьОкноОжидания Тогда
			ПоказатьОшибкуПриОбновлении(Результат.КраткоеПредставлениеОшибки);
		КонецЕсли;
	КонецЕсли;
	
	Если ИнтеграцияС1СДокументооборотБазоваяФункциональностьКлиент.ОперацияВыполнена(Результат, ОбработатьФорму) Тогда
		ТипДерева = ИнтеграцияС1СДокументооборот3Клиент.ТипДерева();
		ТипДерева.ЭтоДеревоОбработки = Истина;
		СостояниеДереваОбработки = ИнтеграцияС1СДокументооборот3Клиент.ТекущееСостояниеДерева(
			ТипДерева,
			Действия.ПолучитьЭлементы(),
			Элементы.Действия);
		ВыполняетсяОбновлениеДереваОбработки = Истина;
		ОбновитьФормуЗавершение(Результат.РезультатДлительнойОперации, ПараметрыОповещения);
		ОбновитьДекорацииОбъектаДО(ПараметрыОповещения.ПриСменеСтраницы);
		ВыполняетсяОбновлениеДереваОбработки = Ложь;
	ИначеЕсли ОбработатьФорму Тогда
		ОбработатьФормуСогласноВерсииСервиса();
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьФормуЗавершение(Знач ОтветНаЗапросыПакетаСтрока, Знач ПараметрыОповещения)
	
	Прокси = ИнтеграцияС1СДокументооборотБазоваяФункциональностьПовтИсп.ПолучитьПрокси();
	ОтветНаЗапросыПакета = ИнтеграцияС1СДокументооборотБазоваяФункциональность.СтрокаВОбъектXDTO(
		Прокси,
		ОтветНаЗапросыПакетаСтрока);
	
	Если ДоступенОбзор
			И (ПараметрыОповещения.ТекущаяСтраницаИмя = "СтраницаОбзор"
				Или ПараметрыОповещения.ТекущаяСтраницаИмя = "СтраницаЭП") Тогда
		ОтветПолучениеДанных = ОтветНаЗапросыПакета.responses[0];
		ОтветПредставлениеHTML = ОтветНаЗапросыПакета.responses[1];
		Если ИнтеграцияС1СДокументооборотБазоваяФункциональность.ПроверитьТип(Прокси, ОтветПолучениеДанных, "DMError") Тогда
			ПоказатьОшибкуПриОбновлении(ОтветПолучениеДанных.description);
		ИначеЕсли ИнтеграцияС1СДокументооборотБазоваяФункциональность.ПроверитьТип(Прокси, ОтветПредставлениеHTML, "DMError") Тогда
			ПоказатьОшибкуПриОбновлении(ОтветПредставлениеHTML.description);
		Иначе
			ОбъектXDTO = ОтветПолучениеДанных.objects[0];
			ИнтеграцияС1СДокументооборот3.ЗаполнитьЗакладкуОбзорВФорме(
				ЭтотОбъект,
				ОтветПредставлениеHTML,
				ОбъектXDTO);
			ОбзорЗаполнен = Истина;
			Если Элементы.ГруппаСтраницыПодключения.ТекущаяСтраница = Элементы.СтраницаОшибкаПриОбновлении Тогда
				Элементы.ГруппаСтраницыПодключения.ТекущаяСтраница = Элементы.СтраницаДокументооборотДоступен;
			КонецЕсли;
			Если Не ПараметрыОповещения.ВыводитьОкноОжидания Тогда
				Элементы.ГруппаСтраницыПолученияДанныхОбзор.ТекущаяСтраница = Элементы.СтраницаДанныеПолученыОбзор;
				Элементы.ГруппаСтраницыПолученияДанныхПодписи.ТекущаяСтраница = Элементы.СтраницаДанныеПолученыПодписи;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	Если ДоступенПросмотрОбработки И ПараметрыОповещения.ТекущаяСтраницаИмя = "СтраницаОбработка" Тогда
		ОтветОбработка = ОтветНаЗапросыПакета.responses[0];
		Если ИнтеграцияС1СДокументооборотБазоваяФункциональность.ПроверитьТип(Прокси, ОтветОбработка, "DMError") Тогда
			ПоказатьОшибкуПриОбновлении(ОтветОбработка.description);
		Иначе
			ИнтеграцияС1СДокументооборот3.ЗаполнитьОбработкуВФорме(ЭтотОбъект, ОтветОбработка);
			ОбработкаЗаполнена = Истина;
			Если Элементы.ГруппаСтраницыПодключения.ТекущаяСтраница = Элементы.СтраницаОшибкаПриОбновлении Тогда
				Элементы.ГруппаСтраницыПодключения.ТекущаяСтраница = Элементы.СтраницаДокументооборотДоступен;
			КонецЕсли;
			Если Не ПараметрыОповещения.ВыводитьОкноОжидания Тогда
				Элементы.ГруппаСтраницыПолученияДанныхОбработка.ТекущаяСтраница = Элементы.СтраницаДанныеПолученыОбработка;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	Если ДоступноДеревоСвязей И ПараметрыОповещения.ТекущаяСтраницаИмя = "СтраницаСвязи" Тогда
		ОтветСвязи = ОтветНаЗапросыПакета.responses[0];
		Если ИнтеграцияС1СДокументооборотБазоваяФункциональность.ПроверитьТип(Прокси, ОтветСвязи, "DMError") Тогда
			ПоказатьОшибкуПриОбновлении(ОтветСвязи.description);
		Иначе
			ИнтеграцияС1СДокументооборот3.ЗаполнитьДеревоСвязейВФорме(ЭтотОбъект, ОтветСвязи);
			ДеревоСвязейЗаполнено = Истина;
			ДеревоСвязейРазвернуто = Ложь;
			Если Элементы.ГруппаСтраницыПодключения.ТекущаяСтраница = Элементы.СтраницаОшибкаПриОбновлении Тогда
				Элементы.ГруппаСтраницыПодключения.ТекущаяСтраница = Элементы.СтраницаДокументооборотДоступен;
			КонецЕсли;
			Если Не ПараметрыОповещения.ВыводитьОкноОжидания Тогда
				Элементы.ГруппаСтраницыПолученияДанныхСвязи.ТекущаяСтраница = Элементы.СтраницаДанныеПолученыСвязи;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ПолучениеДанныхСвязанногоОбъекта

&НаКлиенте
Процедура НачатьПолучениеДанныхСвязанногоОбъектаДО(ТекущаяСтраница, ПриОткрытии = Ложь)
	
	ОбзорЗаполнен = Ложь;
	ОбработкаЗаполнена = Ложь;
	ДеревоСвязейЗаполнено = Ложь;
	ПредставлениеСвязиHTML =
		ИнтеграцияС1СДокументооборотБазоваяФункциональностьКлиентСервер.СообщениеОбОтсутствииПредпросмотра(
			ЗаголовокСообщенияВОбластиПредпросмотра);
	ПрочитаноСвязей = 0;
	ВсегоСвязей = 0;
	
	ТолькоВажныеСвязи = Истина;
	ПоказыватьТолькоОригиналыВСвязях = Ложь;
	Элементы.ДеревоСвязейПоказатьВсеСвязи.Доступность = Истина;
	Элементы.ГруппаИнфоСвязи.Видимость = Истина;
	
	Если Не ЗначениеЗаполнено(ТекущаяЗакладка) Тогда
		ТекущаяЗакладка = ТекущаяСтраница.Имя;
	КонецЕсли;
	
	ПараметрыОповещения = Новый Структура("ВыборкаИдентификаторОбъектаДО, ВыборкаТипОбъектаДО", "", "");
	ДлительнаяОперация = ПолучитьДанныеСвязанногоОбъектаДО(
		ПараметрыОповещения.ВыборкаИдентификаторОбъектаДО,
		ПараметрыОповещения.ВыборкаТипОбъектаДО);
	Если ДлительнаяОперация = Неопределено Тогда
		// Связанного объекта нет.
		ОбновитьДекорацииОбъектаДО();
		Возврат;
	КонецЕсли;
	
	ПараметрыОповещения.Вставить("ТекущаяСтраницаИмя", ТекущаяЗакладка);
	ПараметрыОповещения.Вставить("ПриОткрытии", ПриОткрытии);
	ОповещениеОЗавершении = Новый ОписаниеОповещения(
		"ПолучениеДанныхСвязанногоОбъектаДОЗавершение",
		ЭтотОбъект,
		ПараметрыОповещения);
	ИнтеграцияС1СДокументооборотБазоваяФункциональностьКлиент.ВыполнитьЗапросАсинхронно(
		ЭтотОбъект,
		ДлительнаяОперация,
		ОповещениеОЗавершении);
	
КонецПроцедуры

&НаСервере
Функция ПолучитьДанныеСвязанногоОбъектаДО(ВыборкаИдентификаторОбъектаДО, ВыборкаТипОбъектаДО)
	
	ОчиститьДанныеОбъектаДО();
	
	ЗапросыПакета = Новый Массив;
	
	Запрос = Новый Запрос(
		"ВЫБРАТЬ
		|	ОбъектыИнтегрированныеС1СДокументооборотом.ТипОбъектаДО КАК ТипОбъектаДО,
		|	ОбъектыИнтегрированныеС1СДокументооборотом.ИдентификаторОбъектаДО КАК ИдентификаторОбъектаДО
		|ИЗ
		|	РегистрСведений.ОбъектыИнтегрированныеС1СДокументооборотом КАК ОбъектыИнтегрированныеС1СДокументооборотом
		|ГДЕ
		|	ОбъектыИнтегрированныеС1СДокументооборотом.Объект = &ВнешнийОбъект");
	Запрос.УстановитьПараметр("ВнешнийОбъект", ВнешнийОбъект);
	
	Выборка = Запрос.Выполнить().Выбрать();
	КоличествоСвязей = Выборка.Количество();
	
	Если КоличествоСвязей = 0 Тогда
		
		ОбновитьВидимостьСтраниц(ОбъектДОТип);
		
	ИначеЕсли КоличествоСвязей = 1 Тогда
		
		Выборка.Следующий();
		ВыборкаИдентификаторОбъектаДО = Выборка.ИдентификаторОбъектаДО;
		ВыборкаТипОбъектаДО = Выборка.ТипОбъектаДО;
		
		ОбновитьВидимостьСтраниц(Выборка.ТипОбъектаДО);
		
		Прокси = ИнтеграцияС1СДокументооборотБазоваяФункциональностьПовтИсп.ПолучитьПрокси();
		
		ОбъектДляПолученияИзДО = Новый Структура;
		ОбъектДляПолученияИзДО.Вставить("ID", ВыборкаИдентификаторОбъектаДО);
		ОбъектДляПолученияИзДО.Вставить("Тип", ВыборкаТипОбъектаДО);
		ОбъектДляПолученияИзДО.Вставить("ВнешнийОбъектИС", ВнешнийОбъект);
		
		ПолучатьФайлы = Ложь;
		Колонки = КолонкиДляПолученияОбъектаДО(ВыборкаТипОбъектаДО, ТекущаяЗакладка, ПолучатьФайлы);
		ЗапросыПакета.Добавить(
			ИнтеграцияС1СДокументооборотБазоваяФункциональность.ПолучитьОбъектыЗапрос(
				Прокси,
				ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(ОбъектДляПолученияИзДО),
				Колонки));
		
		Если ПолучатьФайлы Тогда
			ЗапросыПакета.Добавить(
				ИнтеграцияС1СДокументооборот3.HTMLПредпросмотрОбъектаЗапрос(
					Прокси,
					ВыборкаИдентификаторОбъектаДО,
					ВыборкаТипОбъектаДО));
		КонецЕсли;
		
		Если ДоступенПросмотрОбработки И ТекущаяЗакладка = "СтраницаОбработка" Тогда
			ЗапросыПакета.Добавить(
				ИнтеграцияС1СДокументооборот3.ТекущаяОбработкаОбъектаЗапрос(
					Прокси,
					ВыборкаИдентификаторОбъектаДО,
					ВыборкаТипОбъектаДО));
		КонецЕсли;
		
		Если ДоступноДеревоСвязей И ТекущаяЗакладка = "СтраницаСвязи" Тогда
			РеквизитыОбъекта =
				ИнтеграцияС1СДокументооборотБазоваяФункциональностьКлиентСервер.ДанныеСсылочногоОбъектаДО(
					ВыборкаИдентификаторОбъектаДО, ВыборкаТипОбъектаДО);
			ЗапросыПакета.Добавить(ИнтеграцияС1СДокументооборот3.СвязиОбъектаЗапрос(Прокси, РеквизитыОбъекта));
		КонецЕсли;
		
		Возврат ИнтеграцияС1СДокументооборотБазоваяФункциональность.ВыполнитьПакетныйЗапросАсинхронно(
			Прокси,
			ЗапросыПакета,
			УникальныйИдентификатор,
			НСтр("ru = 'Открытие формы Документооборот'"));
		
	ИначеЕсли КоличествоСвязей > 1 Тогда
		
		ВызватьИсключение СтрШаблон(НСтр("ru = 'С объектом ""%1"" связано более одного объекта в 1С:Документооборот.
			|Общее количество связей: %2'"),
			ВнешнийОбъект,
			КоличествоСвязей);
		
	КонецЕсли;
	
КонецФункции

&НаКлиенте
Процедура ПолучениеДанныхСвязанногоОбъектаДОЗавершение(Результат, ПараметрыОповещения) Экспорт
	
	ОбработатьФорму = Ложь;
	ПроверитьОшибкиПриОбновленииФормы(Результат, ОбработатьФорму);
	Если ОбработатьФорму Тогда
		ОбработатьФормуСогласноВерсииСервиса();
	КонецЕсли;
	
	Если ИнтеграцияС1СДокументооборотБазоваяФункциональностьКлиент.ОперацияВыполнена(Результат, ОбработатьФорму) Тогда
		ВыполняетсяОбновлениеДереваОбработки = Истина;
		ПолучитьДанныеСвязанногоОбъектаДОЗавершение(Результат.РезультатДлительнойОперации, ПараметрыОповещения);
		ОбновитьДекорацииОбъектаДО(ПараметрыОповещения.ПриОткрытии);
		ВыполняетсяОбновлениеДереваОбработки = Ложь;
		ИнициализацияВыполнена = Истина;
	ИначеЕсли ОбработатьФорму Тогда
		ОбработатьФормуСогласноВерсииСервиса();
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ПолучитьДанныеСвязанногоОбъектаДОЗавершение(Знач ОтветНаЗапросыПакетаСтрока, Знач ПараметрыОповещения)
	
	Прокси = ИнтеграцияС1СДокументооборотБазоваяФункциональностьПовтИсп.ПолучитьПрокси();
	ОтветНаЗапросыПакета = ИнтеграцияС1СДокументооборотБазоваяФункциональность.СтрокаВОбъектXDTO(
		Прокси,
		ОтветНаЗапросыПакетаСтрока);
	
	Элементы.ГруппаСтраницы.Видимость = Истина;
	
	ОтветПолучениеДанных = ОтветНаЗапросыПакета.responses[0];
	Попытка
		ИнтеграцияС1СДокументооборотБазоваяФункциональность.ПроверитьВозвратВебСервиса(Прокси, ОтветПолучениеДанных);
	Исключение
		ОбщегоНазначения.СообщитьПользователю(ОбработкаОшибок.КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));
		Элементы.ГруппаСтраницы.Видимость = Ложь;
		// На стороне ДО такого документа нет. Дальше можно ничего не проверять.
		// Страницу ошибки при обновлении не показываем т.к. нужно оставить возможность очистить связь, и выбрать
		// другой объект ДО.
		Возврат;
	КонецПопытки;
	
	Если ОтветПолучениеДанных.objects.Количество() = 1 Тогда
		ОбъектXDTO = ОтветПолучениеДанных.objects[0];
		Если ИнтеграцияС1СДокументооборотБазоваяФункциональность.СвойствоУстановлено(ОбъектXDTO, "name") Тогда
			ОбъектДО = ОбъектXDTO.name;
			ОбъектДОID = ПараметрыОповещения.ВыборкаИдентификаторОбъектаДО;
			ОбъектДОТип = ПараметрыОповещения.ВыборкаТипОбъектаДО;
			ОбновитьЗаголовокСвязанногоОбъекта();
			ОбъектДОНавигационнаяСсылка = ОбъектXDTO.objectID.navigationRef;
		КонецЕсли;
		Если ОбъектДОТип = "DMDocument"
				И ИнтеграцияС1СДокументооборотБазоваяФункциональность.СвойствоУстановлено(ОбъектXDTO, "documentType") Тогда
			ВидОбъектаДО = ОбъектXDTO.documentType.name;
			ВидОбъектаДОID = ОбъектXDTO.documentType.objectID.id;
			ВидОбъектаДОТип = ОбъектXDTO.documentType.objectID.type;
		ИначеЕсли ОбъектДОТип = "DMMeeting"
				И ИнтеграцияС1СДокументооборотБазоваяФункциональность.СвойствоУстановлено(ОбъектXDTO, "type") Тогда
			ВидОбъектаДО = ОбъектXDTO.type.name;
			ВидОбъектаДОID = ОбъектXDTO.type.objectID.id;
			ВидОбъектаДОТип = ОбъектXDTO.type.objectID.type;
		КонецЕсли;
	КонецЕсли;
	
	Если ДоступенОбзор
			И (ПараметрыОповещения.ТекущаяСтраницаИмя = "СтраницаОбзор"
				Или ПараметрыОповещения.ТекущаяСтраницаИмя = "СтраницаЭП") Тогда
		ОтветПредставлениеHTML = ОтветНаЗапросыПакета.responses[1];
		Если ИнтеграцияС1СДокументооборотБазоваяФункциональность.ПроверитьТип(Прокси, ОтветПредставлениеHTML, "DMError") Тогда
			ПоказатьОшибкуПриОбновлении(ОтветПредставлениеHTML.description);
		Иначе
			ИнтеграцияС1СДокументооборот3.ЗаполнитьЗакладкуОбзорВФорме(
				ЭтотОбъект,
				ОтветПредставлениеHTML,
				ОбъектXDTO);
			ОбзорЗаполнен = Истина;
		КонецЕсли;
	КонецЕсли;
	
	Если ДоступенПросмотрОбработки И ПараметрыОповещения.ТекущаяСтраницаИмя = "СтраницаОбработка" Тогда
		ОтветОбработка = ОтветНаЗапросыПакета.responses[1];
		Если ИнтеграцияС1СДокументооборотБазоваяФункциональность.ПроверитьТип(Прокси, ОтветОбработка, "DMError") Тогда
			ПоказатьОшибкуПриОбновлении(ОтветОбработка.description);
		Иначе
			ИнтеграцияС1СДокументооборот3.ЗаполнитьОбработкуВФорме(ЭтотОбъект, ОтветОбработка);
			ОбработкаЗаполнена = Истина;
		КонецЕсли;
	КонецЕсли;
	
	Если ДоступноДеревоСвязей И ПараметрыОповещения.ТекущаяСтраницаИмя = "СтраницаСвязи" Тогда
		ОтветСвязи = ОтветНаЗапросыПакета.responses[1];
		Если ИнтеграцияС1СДокументооборотБазоваяФункциональность.ПроверитьТип(Прокси, ОтветСвязи, "DMError") Тогда
			ПоказатьОшибкуПриОбновлении(ОтветСвязи.description);
		Иначе
			ИнтеграцияС1СДокументооборот3.ЗаполнитьДеревоСвязейВФорме(ЭтотОбъект, ОтветСвязи);
			ДеревоСвязейЗаполнено = Истина;
			ДеревоСвязейРазвернуто = Ложь;
			ДеревоСвязейРазворачиваемаяСтрока = 0;
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ДействиеСОбработкой

&НаКлиенте
Процедура ДействиеСОбработкой(ТипОперации, ПараметрыДействияСОбработкой = Неопределено) Экспорт
	
	Если ПараметрыДействияСОбработкой = Неопределено Тогда
		ПараметрыДействияСОбработкой = ПараметрыДействияСОбработкой();
	КонецЕсли;
	
	ДанныеОбработки = ИнтеграцияС1СДокументооборот3КлиентСервер.ДанныеОбработки(
		ОбъектДОID,
		ОбъектДОТип,
		СостояниеОбработки,
		ПараметрыДействияСОбработкой.ПричинаПрерывания);
	ДанныеОбработки.ТребуемоеИнтерактивноеДействие = ПараметрыДействияСОбработкой.ТребуемоеИнтерактивноеДействие;
	
	ВыполняетсяОбновлениеОбъекта = Ложь;
	КонтрольОтправкиФайлов = Неопределено;
	
	Попытка
		ДлительнаяОперацияСОбработкой = ИнтеграцияС1СДокументооборот3ВызовСервера.ДлительнаяОперацияСОбработкой(
			ТипОперации,
			ДанныеОбработки,
			ВнешнийОбъект,
			УникальныйИдентификатор,
			ПараметрыДействияСОбработкой.ТребуетсяОбновлениеДанных,
			ВыполняетсяОбновлениеОбъекта,
			КонтрольОтправкиФайлов);
	Исключение
		ИнформацияОбОшибке = ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
		Если ИнтеграцияС1СДокументооборотБазоваяФункциональностьВызовСервера.НужноОбработатьФорму(ИнформацияОбОшибке) Тогда
			ОбработатьФормуСогласноВерсииСервиса();
		КонецЕсли;
	КонецПопытки;
	
	ПараметрыОповещения = Новый Структура("ТипОперации, ДанныеОбработки, ПараметрыДействияСОбработкой",
		ТипОперации, ДанныеОбработки, ПараметрыДействияСОбработкой);
	ПараметрыОповещения.Вставить("ВыполняетсяОбновлениеОбъекта", ВыполняетсяОбновлениеОбъекта);
	ПараметрыОповещения.Вставить("КонтрольОтправкиФайлов", КонтрольОтправкиФайлов);
	ОповещениеОЗавершении = Новый ОписаниеОповещения(
		"ДействиеСОбработкойЗавершение",
		ЭтотОбъект,
		ПараметрыОповещения);
	
	ИнтеграцияС1СДокументооборотБазоваяФункциональностьКлиент.ВыполнитьЗапросАсинхронно(
		ЭтотОбъект,
		ДлительнаяОперацияСОбработкой,
		ОповещениеОЗавершении,
		Истина,
		НСтр("ru = 'Выполняется действие с обработкой.'"));
	
КонецПроцедуры

&НаКлиенте
Процедура ДействиеСОбработкойЗавершение(Результат, ПараметрыОповещения) Экспорт
	
	ОбработатьФорму = Ложь;
	Если ИнтеграцияС1СДокументооборотБазоваяФункциональностьКлиент.ОперацияВыполнена(Результат, ОбработатьФорму) Тогда
		ВыполняетсяОбновлениеДереваОбработки = Истина;
		РезультатДействия = ДействиеСОбработкойНаСервереЗавершение(
			Результат.РезультатДлительнойОперации,
			ПараметрыОповещения.ВыполняетсяОбновлениеОбъекта,
			ПараметрыОповещения.КонтрольОтправкиФайлов);
		ПовторноеДействие = Новый ОписаниеОповещения(
			"ДействиеСОбработкой",
			ЭтотОбъект,
			ПараметрыОповещения.ПараметрыДействияСОбработкой);
		Если ИнтеграцияС1СДокументооборот3Клиент.ВызванаИнтерактивнаяОбработка(
				РезультатДействия, ПараметрыОповещения.ТипОперации, ПовторноеДействие) Тогда
			Возврат;
		КонецЕсли;
		Если РезультатДействия.Успешно Тогда
			ОбновитьДекорацииОбъектаДО();
			Оповестить("Документооборот_ДействиеСОбработкой", ПараметрыОповещения, ЭтотОбъект);
		Иначе
			ИнтеграцияС1СДокументооборот3Клиент.ПоказатьПредупреждениеИзДО(,РезультатДействия.ТекстПредупреждения);
		КонецЕсли;
		ВыполняетсяОбновлениеДереваОбработки = Ложь;
	ИначеЕсли ОбработатьФорму Тогда
		ОбработатьФормуСогласноВерсииСервиса();
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция ДействиеСОбработкойНаСервереЗавершение(Знач РезультатДействияСтрока, Знач ВыполняетсяОбновлениеОбъекта,
		Знач КонтрольОтправкиФайлов)
	
	ДанныеДляОбновления = Неопределено;
	РезультатДействия = ИнтеграцияС1СДокументооборот3.РезультатВыполненияКомандыПоОбъекту(
		РезультатДействияСтрока,
		ДанныеДляОбновления,
		ВыполняетсяОбновлениеОбъекта,
		КонтрольОтправкиФайлов);
	
	Если РезультатДействия.Успешно И ДанныеДляОбновления <> Неопределено Тогда
		Прокси = ИнтеграцияС1СДокументооборотБазоваяФункциональностьПовтИсп.ПолучитьПрокси();
		Если ИнтеграцияС1СДокументооборотБазоваяФункциональность.ПроверитьТип(Прокси, ДанныеДляОбновления, "DMError") Тогда
			ТекстОшибкиПриОбновлении = ДанныеДляОбновления.description;
			Элементы.ГруппаСтраницыПодключения.ТекущаяСтраница = Элементы.СтраницаОшибкаПриОбновлении;
		Иначе
			ИнтеграцияС1СДокументооборот3.ЗаполнитьОбработкуВФорме(ЭтотОбъект, ДанныеДляОбновления);
			ОбработкаЗаполнена = Истина;
		КонецЕсли;
	КонецЕсли;
	
	Возврат РезультатДействия;
	
КонецФункции

#КонецОбласти

#КонецОбласти