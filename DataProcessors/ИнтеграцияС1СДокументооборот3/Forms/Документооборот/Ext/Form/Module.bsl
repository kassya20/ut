&НаКлиенте
Процедура ПодписатьДокумент(Команда)
	
	ПараметрыОповещения = Новый Структура;
	ПараметрыОповещения.Вставить("МассивДанныхДляЗанесенияВБазу", Новый Массив);
	ПараметрыОповещения.Вставить("МассивАдресов", Новый Массив);
	Оповещение = Новый ОписаниеОповещения("ПодписатьДокументЗавершение", ЭтотОбъект, ПараметрыОповещения);
	
	ОбъектДокументооборота =
		ИнтеграцияС1СДокументооборотБазоваяФункциональностьКлиентСервер.ДанныеСсылочногоОбъектаДО(
			ОбъектДОID,
			ОбъектДОТип,
			ОбъектДО,
			СтрШаблон(НСтр("ru = '%1 (Документ предприятия)'"), ОбъектДО));
	
	Файлы = Новый Массив;
	Для Каждого Строка Из ДеревоФайлов.ПолучитьЭлементы() Цикл
		Если Строка.Тип = "DMFile" Тогда
			Файлы.Добавить(Строка);
		КонецЕсли;
		Для Каждого Подстрока Из Строка.ПолучитьЭлементы() Цикл
			Если Подстрока.Тип = "DMFile" Тогда
				Файлы.Добавить(Подстрока);
			КонецЕсли;
		КонецЦикла;
	КонецЦикла;
	
	ИнтеграцияС1СДокументооборотБазоваяФункциональностьКлиент.НачатьФормированиеПодписиОбъекта(
		ОбъектДокументооборота,
		Файлы,
		АдресДвоичныхДанныхОбъекта,
		Оповещение);
	
КонецПроцедуры

