&НаКлиенте
Процедура ДействияПриАктивизацииСтроки(Элемент)
	
	Если Не ВыполняетсяОбновлениеДереваОбработки Тогда
		ТипДерева = ИнтеграцияС1СДокументооборот3Клиент.ТипДерева();
		ТипДерева.ЭтоДеревоОбработки = Истина;
		СостояниеДереваОбработки = ИнтеграцияС1СДокументооборот3Клиент.ТекущееСостояниеДерева(
			ТипДерева,
			Действия.ПолучитьЭлементы(),
			Элементы.Действия);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ДействияВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	ТекущиеДанные = Элемент.ТекущиеДанные;
	СтандартнаяОбработка = Ложь;
	
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ОткрытьЗадачуСотрудника = Истина;
	Если ТекущиеДанные.ЭтоУчастник И ТекущиеДанные.ЭтоДействие И Поле <> Элементы.ДействияПредставлениеСотрудники Тогда
		ОткрытьЗадачуСотрудника = Ложь;
	КонецЕсли;
	
	Если ОткрытьЗадачуСотрудника И ОбработатьДвойнойКликНаУчастникаДействия(ТекущиеДанные) Тогда
		Возврат;
	КонецЕсли;
	
	Если ИнтеграцияС1СДокументооборот3КлиентСервер.ЭтоДействиеОзнакомления(ТекущиеДанные.ДействиеТип)
			И ТекущиеДанные.ЭтоУчастник
			И Поле = Элементы.ДействияПредставлениеСотрудники Тогда
		
		Если ЗначениеЗаполнено(ТекущиеДанные.ДействиеЗадачиID) И ЗначениеЗаполнено(ТекущиеДанные.ДействиеЗадачиТип) Тогда
			ПараметрыФормы = Новый Структура(
				"ОсновнойПредмет, ОсновнойПредметID, ОсновнойПредметТип", ОбъектДО, ОбъектДОID, ОбъектДОТип);
			ИнтеграцияС1СДокументооборотБазоваяФункциональностьКлиент.ОткрытьОбъект(
				ТекущиеДанные.ДействиеЗадачиТип,
				ТекущиеДанные.ДействиеЗадачиID,
				ЭтотОбъект,
				ПараметрыФормы);
			Возврат;
		КонецЕсли;
		
	КонецЕсли;
	
	Если ТекущиеДанные.ЭтоПодзадача
			И ЗначениеЗаполнено(ТекущиеДанные.ДействиеЗадачиID)
			И ЗначениеЗаполнено(ТекущиеДанные.ДействиеЗадачиТип) Тогда
		ПараметрыФормы = Новый Структура(
			"ОсновнойПредмет, ОсновнойПредметID, ОсновнойПредметТип", ОбъектДО, ОбъектДОID, ОбъектДОТип);
		ИнтеграцияС1СДокументооборотБазоваяФункциональностьКлиент.ОткрытьОбъект(
			ТекущиеДанные.ДействиеЗадачиТип,
			ТекущиеДанные.ДействиеЗадачиID,
			ЭтотОбъект,
			ПараметрыФормы);
		Возврат;
	КонецЕсли;
	
	Если ДоступенПросмотрДействий
			И ЗначениеЗаполнено(ТекущиеДанные.ДействиеID)
			И ЗначениеЗаполнено(ТекущиеДанные.ДействиеТип) Тогда
		ПараметрыФормы = Новый Структура(
			"ОсновнойПредмет, ОсновнойПредметID, ОсновнойПредметТип", ОбъектДО, ОбъектДОID, ОбъектДОТип);
		ИнтеграцияС1СДокументооборотБазоваяФункциональностьКлиент.ОткрытьОбъект(
			ТекущиеДанные.ДействиеТип,
			ТекущиеДанные.ДействиеID,
			ЭтотОбъект,
			ПараметрыФормы);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ДействияПередНачаломИзменения(Элемент, Отказ)
	
	Отказ = Истина;
	
	ТекущиеДанные = Элементы.Действия.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	ИначеЕсли ТекущиеДанные.ЭтоУчастник И Не ТекущиеДанные.ЭтоДействие
			И ОбработатьДвойнойКликНаУчастникаДействия(ТекущиеДанные) Тогда
		Возврат;
	КонецЕсли;
	
	Если ТекущиеДанные.ЭтоПодзадача
			И ЗначениеЗаполнено(ТекущиеДанные.ДействиеЗадачиID)
			И ЗначениеЗаполнено(ТекущиеДанные.ДействиеЗадачиТип) Тогда
		ПараметрыФормы = Новый Структура(
			"ОсновнойПредмет, ОсновнойПредметID, ОсновнойПредметТип", ОбъектДО, ОбъектДОID, ОбъектДОТип);
		ИнтеграцияС1СДокументооборотБазоваяФункциональностьКлиент.ОткрытьОбъект(
			ТекущиеДанные.ДействиеЗадачиТип,
			ТекущиеДанные.ДействиеЗадачиID,
			ЭтотОбъект,
			ПараметрыФормы);
		Возврат;
	КонецЕсли;
	
	Если ДоступенПросмотрДействий
			И ЗначениеЗаполнено(ТекущиеДанные.ДействиеID)
			И ЗначениеЗаполнено(ТекущиеДанные.ДействиеТип) Тогда
		ПараметрыФормы = Новый Структура(
			"ОсновнойПредмет, ОсновнойПредметID, ОсновнойПредметТип", ОбъектДО, ОбъектДОID, ОбъектДОТип);
		ИнтеграцияС1СДокументооборотБазоваяФункциональностьКлиент.ОткрытьОбъект(
			ТекущиеДанные.ДействиеТип,
			ТекущиеДанные.ДействиеID,
			ЭтотОбъект,
			ПараметрыФормы);
	ИначеЕсли ЗначениеЗаполнено(ТекущиеДанные.ДействиеЗадачиID) И ЗначениеЗаполнено(ТекущиеДанные.ДействиеЗадачиТип) Тогда
		ПараметрыФормы = Новый Структура(
			"ОсновнойПредмет, ОсновнойПредметID, ОсновнойПредметТип", ОбъектДО, ОбъектДОID, ОбъектДОТип);
		ИнтеграцияС1СДокументооборотБазоваяФункциональностьКлиент.ОткрытьОбъект(
			ТекущиеДанные.ДействиеЗадачиТип,
			ТекущиеДанные.ДействиеЗадачиID,
			ЭтотОбъект,
			ПараметрыФормы);
	КонецЕсли;
	
КонецПроцедуры

