	Результат = СоздатьЗаявкиНаОплатуДСНаСервере();
	Если Результат <> Неопределено Тогда
		ДенежныеСредстваКлиент.ОткрытьРезультатОплатыСтрокГрафика(Элементы.ПлатежиВКалендаре, Результат);
