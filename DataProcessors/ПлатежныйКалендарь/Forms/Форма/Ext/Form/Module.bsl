&НаСервере
Процедура ПриИзмененииДнейПланированияНаСервере()
	
	Обработки.ПлатежныйКалендарь.ЗаполнитьДатыОкончания(Объект);
	
	ОбновитьСпискиНаСервере();
	ДополнитьКолонкиДней();
	ДополнитьКолонкиДолгосрочногоПланирования();
	
	Если РежимОтображения <> "СписокЗаявок" Тогда
		ИзменитьВидимостьДнейПланирования();
	КонецЕсли;
	
	Если РежимОтображения <> "КалендарьПлатежи" Тогда
		УстановитьОтборыДинамическихСписков();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОтборОрганизацииНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	ОповещениеОЗакрытии = Новый ОписаниеОповещения("ВыборОрганизацийОтбора", ЭтотОбъект);
	
	Отмеченные = Новый СписокЗначений;
	Для каждого ЭлементОрганизация Из Объект.ОтборОрганизации Цикл
		Если ЭлементОрганизация.Пометка Тогда
			Отмеченные.Добавить(ЭлементОрганизация.Значение,, Истина);
		КонецЕсли;
	КонецЦикла;
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("ОграничиватьВыборУказаннымиЗначениями", Истина);
	ПараметрыФормы.Вставить("Представление", НСтр("ru = 'Отбор организаций'"));
	ПараметрыФормы.Вставить("ЗначенияДляВыбора", Объект.ОтборОрганизации);
	ПараметрыФормы.Вставить("ОписаниеТипов", ОтборОрганизации.ТипЗначения);
	ПараметрыФормы.Вставить("Отмеченные", Отмеченные);
	
	ОткрытьФорму("ОбщаяФорма.ВводЗначенийСпискомСФлажками", ПараметрыФормы, ЭтотОбъект,,,,
		ОповещениеОЗакрытии, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	
КонецПроцедуры

&НаКлиенте
Процедура ВыборОрганизацийОтбора(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат <> Неопределено И ТипЗнч(Результат) = Тип("СписокЗначений") Тогда
		Объект.ОтборОрганизации = Результат;
		ОтборОрганизацииПредставление = ОтборПредставление(Объект.ОтборОрганизации);
		УстановитьКомпоновщикОтборПоОтборОрганизации(Объект.КомпоновщикОтбор, Объект.ОтборОрганизации);
		ОбновитьСписки();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОтборОрганизацииОчистка(Элемент, СтандартнаяОбработка)
	
	Объект.ОтборОрганизации.ЗаполнитьПометки(Ложь);
	УстановитьКомпоновщикОтборПоОтборОрганизации(Объект.КомпоновщикОтбор, Объект.ОтборОрганизации);
	ОбновитьСписки();
	
КонецПроцедуры

&НаКлиенте
Процедура ОтборОрганизацииОбработкаВыбора(Элемент, ВыбранноеЗначение, СтандартнаяОбработка)
	
	ЭлементВыбраннойОрганизации = Объект.ОтборОрганизации.НайтиПоЗначению(ВыбранноеЗначение);
	Если ЭлементВыбраннойОрганизации <> Неопределено Тогда
		Объект.ОтборОрганизации.ЗаполнитьПометки(Ложь);
		ЭлементВыбраннойОрганизации.Пометка = Истина;
		УстановитьКомпоновщикОтборПоОтборОрганизации(Объект.КомпоновщикОтбор, Объект.ОтборОрганизации);
		ОбновитьСписки();
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийТаблицыФормы

&НаКлиенте
Процедура ЗаявкиКОплатеПриАктивизацииСтроки(Элемент)
	
	Если РежимОтображения = "ЗаявкиКалендарь" Тогда
		
		Если Объект.ФильтрСчетовКалендаря = 2 Тогда
			
			ТекущаяСтрокаСписка = Элементы.ЗаявкиКОплате.ТекущаяСтрока;
			
			Если ЗначениеЗаполнено(ТекущаяСтрокаСписка) И ТипЗнч(ТекущаяСтрокаСписка) <> Тип("СтрокаГруппировкиДинамическогоСписка") Тогда
				ТекущаяЗаявка = Элементы.ЗаявкиКОплате.ТекущиеДанные.ОбъектОплаты;
				Элементы.ГруппаПанельПлатежей.ТекущаяСтраница = Элементы.СтраницаЗаполнение;
				ПодключитьОбработчикОжидания("ЗапуститьЗаполнениеПриАктивизацииСпискаЗаявок", 0.1, Истина);
			Иначе
				ТекущаяЗаявка = Неопределено;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ДеревоПлатежейПриАктивизацииЯчейки(Элемент)
	
	Если РежимОтображения <> "СписокЗаявок" И Не ОтключенаАктивацияЯчейкиКалендаряПриПеретаскивании Тогда
		
		ТекущийЭлементДерева = Элемент.ТекущийЭлемент; // ПолеФормы
		
		Если ТекущийЭлементДерева <> Неопределено Тогда
			
			Если (РежимОтображения = "КалендарьПлатежи") И (ТекущаяКолонкаДерева <> ТекущийЭлементДерева.Имя) Тогда
				ОчиститьПомеченныеЗаписи();
			КонецЕсли;
			
			ТекущаяСтрокаДерева = Элемент.ТекущаяСтрока;
			ТекущаяКолонкаДерева = Элемент.ТекущийЭлемент.Имя;
			
			ТекущиеДанные = Элемент.ТекущиеДанные;
			Если ТекущиеДанные <> Неопределено Тогда
				
				ТекстКритическийОстаток = НСтр("ru = 'Остаток денежных средств ниже критической суммы %1.'");
				ТекстНеСозданаЗаявка = НСтр("ru = 'Для оплаты требуется оформить заявку на расходование денежных средств.'");
				ТекстИсходнаяДатаПлатежаМеньшеПеренесенной =
					НСтр("ru = 'Платеж перенесен на дату позже, даты установленной в документе.'");
				ТекстОшибкиТекущейЯчейки = "";
				ТекстыОшибок = Новый Массив;
				
				Если НЕ (  ТекущаяГруппировкаДерева   = ТекущиеДанные.Группировка
						 И ТекущийБанковскийСчетКасса = ТекущиеДанные.БанковскийСчетКасса
						 И ТекущаяВалюта			  = ТекущиеДанные.Валюта)
					И (РежимОтображения = "КалендарьПлатежи") Тогда
					ОчиститьПомеченныеЗаписи();
				КонецЕсли;
				
				ТекущаяГруппировкаДерева		  = ТекущиеДанные.Группировка;
				ТекущаяСтрокаДереваНеРаспределено = ТекущиеДанные.СтрокаНеРаспределено;
				ТекущаяСтрокаДереваРаспределено	  = ТекущиеДанные.СтрокаРаспределено;
				ТекущийБанковскийСчетКасса		  = ТекущиеДанные.БанковскийСчетКасса;
				ТекущаяВалюта					  = ТекущиеДанные.Валюта;
				ТекущийВидСтроки				  = ТекущиеДанные.ВидСтроки;
				ТекущийТипДвижения				  = ТекущиеДанные.ПоступлениеСписание;
				ТекущаяОрганизация				  = ТекущиеДанные.Организация;
				ТекущийТипДенежныхСредств		  = ТекущиеДанные.ТипДенежныхСредств;
				ТекущийБанк						  = ТекущиеДанные.БанкКассы;
				
				Безналичные = ПредопределенноеЗначение("Перечисление.ТипыДенежныхСредств.Безналичные");
				Наличные = ПредопределенноеЗначение("Перечисление.ТипыДенежныхСредств.Наличные");
				
				Если ТекущаяКолонкаДерева <> "ДеревоПлатежейНеснижаемыйОстаток"
					И СтрНайти(ТекущаяКолонкаДерева, "Остаток") > 0 Тогда
					Если ТекущиеДанные.ОстатокОшибкаКритическийОстаток Тогда
						Если ТекущийТипДенежныхСредств = Безналичные Тогда
							ТекстыОшибок.Добавить(СтрШаблон(ТекстКритическийОстаток, НСтр("ru = 'банковского счета'")));
						ИначеЕсли ТекущийТипДенежныхСредств = Наличные Тогда
							ТекстыОшибок.Добавить(СтрШаблон(ТекстКритическийОстаток, НСтр("ru = 'кассы'")));
						КонецЕсли;
					КонецЕсли;
				
				ИначеЕсли СтрНайти(ТекущаяКолонкаДерева, "День") > 0
					ИЛИ СтрНайти(ТекущаяКолонкаДерева, "ДолгосрочныйПериод") > 0 Тогда
					ЭтоДень = (СтрНайти(ТекущаяКолонкаДерева, "День") > 0);
			
					Если ЭтоДень Тогда
						Номер = НомерДня(ТекущаяКолонкаДерева);
						ИмяПериода = "День";
					Иначе
						Номер = НомерДолгосрочногоПериода(ТекущаяКолонкаДерева);
						ИмяПериода = "ДолгосрочныйПериод";
					КонецЕсли;
			
					Если Номер > 0 Тогда
						ЕстьОшибкаКритическийОстаток = Ложь;
						ИмяКолонкиОшибкаКритическийОстаток = ИмяПериода + Номер + "ОшибкаКритическийОстаток";
						Если ТекущиеДанные.Свойство(ИмяКолонкиОшибкаКритическийОстаток, ЕстьОшибкаКритическийОстаток)
							И ЕстьОшибкаКритическийОстаток Тогда
							Если ТекущийТипДенежныхСредств = Безналичные Тогда
								ТекстыОшибок.Добавить(СтрШаблон(ТекстКритическийОстаток, НСтр("ru = 'банковского счета'")));
							ИначеЕсли ТекущийТипДенежныхСредств = Наличные Тогда
								ТекстыОшибок.Добавить(СтрШаблон(ТекстКритическийОстаток, НСтр("ru = 'кассы'")));
							КонецЕсли;
						КонецЕсли;
					КонецЕсли;
					
					ЕстьОшибкаНеСозданаЗаявка = Ложь;
					ИмяКолонкиЕстьОшибкаНеСозданаЗаявка = ИмяПериода + Номер + "ЕстьОшибкаНеСозданаЗаявка";
					Если ТекущиеДанные.Свойство(ИмяКолонкиЕстьОшибкаНеСозданаЗаявка, ЕстьОшибкаНеСозданаЗаявка)
						И ЕстьОшибкаНеСозданаЗаявка Тогда
						ТекстыОшибок.Добавить(ТекстНеСозданаЗаявка);
					КонецЕсли;
					
					ЕстьИсходнаяДатаПлатежаМеньшеПеренесенной = Ложь;
					ИмяКолонкиЕстьИсходнаяДатаПлатежаМеньшеПеренесенной = ИмяПериода + Номер
						+ "ЕстьИсходнаяДатаПлатежаМеньшеПеренесенной";
					Если ТекущиеДанные.Свойство(ИмяКолонкиЕстьИсходнаяДатаПлатежаМеньшеПеренесенной,
						ЕстьИсходнаяДатаПлатежаМеньшеПеренесенной)
						И ЕстьИсходнаяДатаПлатежаМеньшеПеренесенной Тогда
						ТекстыОшибок.Добавить(ТекстИсходнаяДатаПлатежаМеньшеПеренесенной);
					КонецЕсли;
				КонецЕсли;
				
				Если ТекстыОшибок.Количество() Тогда
					ТекстОшибкиТекущейЯчейки = СтрСоединить(ТекстыОшибок, " ");
				КонецЕсли;
			Иначе
				ТекущаяГруппировкаДерева = Неопределено;
				ТекущаяСтрокаДереваНеРаспределено = ЛОЖЬ;
				ТекущаяСтрокаДереваРаспределено = ЛОЖЬ;
				ТекущийБанковскийСчетКасса = Неопределено;
				ТекущаяВалюта = Неопределено;
				ТекущийВидСтроки = -1;
				ТекущийТипДвижения = Неопределено;
				ТекущаяОрганизация = Неопределено;
				ТекущийТипДенежныхСредств = Неопределено;
				ТекущийБанк = Неопределено;
			КонецЕсли;
		КонецЕсли;
		
		ПодключитьОбработчикОжидания("Подключаемый_УстановитьОтборВКалендаре", 0.1, Истина);
	КонецЕсли;
	
	ОтключенаАктивацияЯчейкиКалендаряПриПеретаскивании = Ложь;
	
КонецПроцедуры

&НаКлиенте
Процедура ПлатежиВКалендареВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	Если ТипЗнч(ВыбраннаяСтрока) <> Тип("СтрокаГруппировкиДинамическогоСписка") Тогда
		СтандартнаяОбработка = Ложь;
		Если Поле = Элементы.ПлатежиВКалендареПометка Тогда
			ТекущиеДанные = Элементы.ПлатежиВКалендаре.ТекущиеДанные;
			Если ТекущиеДанные <> Неопределено Тогда
				
				ИдентификаторСозданный = "";
				Если НЕ ЗначениеЗаполнено(ТекущиеДанные.Идентификатор) Тогда
					
					ИзмеренияГрафика = ИзмеренияГрафика();
					ЗаполнитьЗначенияСвойств(ИзмеренияГрафика, ТекущиеДанные);
					ИдентификаторСозданный = ЗаполнитьИдентификаторИсходныеРеквизитыВОтмеченойСтроке(ИзмеренияГрафика);
				КонецЕсли;
					
				Если ЗначениеЗаполнено(ИдентификаторСозданный) ИЛИ ЗначениеЗаполнено(ТекущиеДанные.Идентификатор) Тогда
					
					ИдентификаторЗаписи = ?(ЗначениеЗаполнено(ТекущиеДанные.Идентификатор), ТекущиеДанные.Идентификатор,
						ИдентификаторСозданный);
					
					Если ТекущиеДанные.Пометка Тогда
						ЭлементСписка = ПомеченныеЗаписиПлатежейВКалендаре.НайтиПоЗначению(ИдентификаторЗаписи);
						Если ЭлементСписка <> Неопределено Тогда
							ПомеченныеЗаписиПлатежейВКалендаре.Удалить(ЭлементСписка);
							ИтогиСумма = ИтогиСумма - ТекущиеДанные.Сумма;
							ИтогиКоличество = ИтогиКоличество - 1;
						КонецЕсли;
					Иначе
						ЭлементСписка = ПомеченныеЗаписиПлатежейВКалендаре.НайтиПоЗначению(ИдентификаторЗаписи);
						Если ЭлементСписка = Неопределено Тогда
							ПомеченныеЗаписиПлатежейВКалендаре.Добавить(ИдентификаторЗаписи);
							ИтогиСумма = ИтогиСумма + ТекущиеДанные.Сумма;
							ИтогиКоличество = ИтогиКоличество + 1;
						КонецЕсли;
					КонецЕсли;
				КонецЕсли;
			КонецЕсли;
			ОбщегоНазначенияКлиентСервер.УстановитьПараметрДинамическогоСписка(ПлатежиВКалендаре, "ПомеченныеЗаписи",
				ПомеченныеЗаписиПлатежейВКалендаре);
			Элементы.ПлатежиВКалендаре.Обновить();
		Иначе
			ОткрытьОбъектОплаты();
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаявкиКОплатеВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	Если ТипЗнч(ВыбраннаяСтрока) <> Тип("СтрокаГруппировкиДинамическогоСписка") Тогда
		СтандартнаяОбработка = Ложь;
		Если Поле = Элементы.ЗаявкиКОплатеПометка Тогда
			ТекущиеДанные = Элементы.ЗаявкиКОплате.ТекущиеДанные;
			Если ТекущиеДанные <> Неопределено Тогда
				
				ИдентификаторСозданный = "";
				Если НЕ ЗначениеЗаполнено(ТекущиеДанные.Идентификатор) Тогда
					
					ИзмеренияГрафика = ИзмеренияГрафика();
					ЗаполнитьЗначенияСвойств(ИзмеренияГрафика, ТекущиеДанные);
					ИдентификаторСозданный = ЗаполнитьИдентификаторИсходныеРеквизитыВОтмеченойСтроке(ИзмеренияГрафика);
				КонецЕсли;
				
				Если ЗначениеЗаполнено(ИдентификаторСозданный) ИЛИ ЗначениеЗаполнено(ТекущиеДанные.Идентификатор) Тогда
					
					ИдентификаторЗаписи = ?(ЗначениеЗаполнено(ТекущиеДанные.Идентификатор), ТекущиеДанные.Идентификатор,
						ИдентификаторСозданный);
				
					Если ТекущиеДанные.Пометка Тогда
						ЭлементСписка = ПомеченныеЗаписиЗаявкиКОплате.НайтиПоЗначению(ИдентификаторЗаписи);
						Если ЭлементСписка <> Неопределено Тогда
							ПомеченныеЗаписиЗаявкиКОплате.Удалить(ЭлементСписка);
							ИтогиСумма = ИтогиСумма - ТекущиеДанные.Сумма;
							ИтогиКоличество = ИтогиКоличество - 1;
						КонецЕсли;
					Иначе
						ЭлементСписка = ПомеченныеЗаписиЗаявкиКОплате.НайтиПоЗначению(ИдентификаторЗаписи);
						Если ЭлементСписка = Неопределено Тогда
							ПомеченныеЗаписиЗаявкиКОплате.Добавить(ИдентификаторЗаписи);
							ИтогиСумма = ИтогиСумма + ТекущиеДанные.Сумма;
							ИтогиКоличество = ИтогиКоличество + 1;
						КонецЕсли;
					КонецЕсли;
				КонецЕсли;
			КонецЕсли;
			ОбщегоНазначенияКлиентСервер.УстановитьПараметрДинамическогоСписка(ЗаявкиКОплате, "ПомеченныеЗаписи",
				ПомеченныеЗаписиЗаявкиКОплате);
			Элементы.ЗаявкиКОплате.Обновить();
		Иначе
			ОткрытьОбъектОплаты();
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

#Область ОформлениеФормы

&НаСервере
Процедура УстановитьУсловноеОформление()
	
	ПутьДеревоПлатежей = "Объект.ДеревоПлатежей";
	УсловноеОформление.Элементы.Очистить();
	
	// Отрицательные остатки
	
	Элемент = УсловноеОформление.Элементы.Добавить();
	
	ПолеЭлемента = Элемент.Поля.Элементы.Добавить();
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(Элементы.ДеревоПлатежей.Имя);
	
	ВидыСтроки = Новый СписокЗначений;
	ВидыСтроки.Добавить(0);
	ВидыСтроки.Добавить(2);
	
	ФинансоваяОтчетностьСервер.УстановитьОтбор(Элемент.Отбор, ПутьДеревоПлатежей + ".ВидСтроки",
		ВидыСтроки);
	
	Элемент.Оформление.УстановитьЗначениеПараметра("ВыделятьОтрицательные", Истина);
	
	// Шрифт итогов
	
	Элемент = УсловноеОформление.Элементы.Добавить();
	
	ПолеЭлемента = Элемент.Поля.Элементы.Добавить();
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(Элементы.ДеревоПлатежейГруппировка.Имя);
	ПолеЭлемента = Элемент.Поля.Элементы.Добавить();
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(Элементы.ДеревоПлатежейВалюта.Имя);
	
	ФинансоваяОтчетностьСервер.УстановитьОтбор(Элемент.Отбор, ПутьДеревоПлатежей + ".СтрокаНераспределено", Истина);
	
	Элемент.Оформление.УстановитьЗначениеПараметра("Шрифт", Новый Шрифт(ЭтаФорма.Элементы.ДеревоПлатежей.Шрифт,,, Истина));
	
	// Фон итогов
	
	Элемент = УсловноеОформление.Элементы.Добавить();
	
	ПолеЭлемента = Элемент.Поля.Элементы.Добавить();
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(Элементы.ДеревоПлатежей.Имя);
	
	ФинансоваяОтчетностьСервер.УстановитьОтбор(Элемент.Отбор, ПутьДеревоПлатежей + ".СтрокаИтогов", Истина);
	
	Элемент.Оформление.УстановитьЗначениеПараметра("ЦветФона", Новый Цвет(242, 242, 242));
	
	// Видимость валют
	
	Элемент = УсловноеОформление.Элементы.Добавить();
	
	ПолеЭлемента = Элемент.Поля.Элементы.Добавить();
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(Элементы.ДеревоПлатежейВалюта.Имя);
	
	ГруппаОтбора1 = Элемент.Отбор.Элементы.Добавить(Тип("ГруппаЭлементовОтбораКомпоновкиДанных"));
	ГруппаОтбора1.ТипГруппы = ТипГруппыЭлементовОтбораКомпоновкиДанных.ГруппаИли;
	
	ГруппаОтбора2 = ГруппаОтбора1.Элементы.Добавить(Тип("ГруппаЭлементовОтбораКомпоновкиДанных"));
	ГруппаОтбора2.ТипГруппы = ТипГруппыЭлементовОтбораКомпоновкиДанных.ГруппаИ;
	
	ФинансоваяОтчетностьСервер.УстановитьОтбор(ГруппаОтбора2, ПутьДеревоПлатежей + ".ВидСтроки", 1);
	
	ФинансоваяОтчетностьСервер.УстановитьОтбор(ГруппаОтбора2, ПутьДеревоПлатежей + ".Группировка",
		"распределено", ВидСравненияКомпоновкиДанных.НеСодержит);
	
	ГруппаОтбора3 = ГруппаОтбора1.Элементы.Добавить(Тип("ГруппаЭлементовОтбораКомпоновкиДанных"));
	ГруппаОтбора3.ТипГруппы = ТипГруппыЭлементовОтбораКомпоновкиДанных.ГруппаИ;
	
	ВидыСтроки = Новый СписокЗначений;
	ВидыСтроки.Добавить(2);
	ВидыСтроки.Добавить(3);
	
	ФинансоваяОтчетностьСервер.УстановитьОтбор(ГруппаОтбора3, ПутьДеревоПлатежей + ".ВидСтроки", ВидыСтроки);
	
	ФинансоваяОтчетностьСервер.УстановитьОтбор(ГруппаОтбора3, ПутьДеревоПлатежей + ".Группировка",
		"Итого", ВидСравненияКомпоновкиДанных.НеСодержит);
	
	Элемент.Оформление.УстановитьЗначениеПараметра("Текст", "");
	
	// Дата платежа просроченных заявок
	
	Элемент = УсловноеОформление.Элементы.Добавить();
	
	ПолеЭлемента = Элемент.Поля.Элементы.Добавить();
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(Элементы.ЗаявкиКОплатеДатаПлатежа.Имя);
	
	ФинансоваяОтчетностьСервер.УстановитьОтбор(Элемент.Отбор, "ЗаявкиКОплате.ДатаПлатежа",
		Новый ПолеКомпоновкиДанных("Объект.ПланироватьСДаты"), ВидСравненияКомпоновкиДанных.Меньше);
	
	Элемент.Оформление.УстановитьЗначениеПараметра("ЦветТекста", ЦветаСтиля.ПросроченныеДанныеЦвет);
	
	// Заголовок остатков по валютам
	
	Элемент = УсловноеОформление.Элементы.Добавить();
	
	ПолеЭлемента = Элемент.Поля.Элементы.Добавить();
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(Элементы.ДеревоПлатежейГруппировка.Имя);
	
	ФинансоваяОтчетностьСервер.УстановитьОтбор(Элемент.Отбор, ПутьДеревоПлатежей + ".ВидСтроки", 0);
	
	ФинансоваяОтчетностьСервер.УстановитьОтбор(Элемент.Отбор, ПутьДеревоПлатежей + ".БанковскийСчетКасса",,
		ВидСравненияКомпоновкиДанных.НеЗаполнено);
	
	// Растяжка
	
	Элемент = УсловноеОформление.Элементы.Добавить();
	
	ПолеЭлемента = Элемент.Поля.Элементы.Добавить();
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(Элементы.ДеревоПлатежейРастяжка.Имя);
	
	Элемент.Оформление.УстановитьЗначениеПараметра("Текст", "");
	
	// Фон остатков меньше или равно критическому остатку
	
	Элемент = УсловноеОформление.Элементы.Добавить();
	
	ПолеЭлемента = Элемент.Поля.Элементы.Добавить();
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(Элементы.ДеревоПлатежейОстаток.Имя);
	
	ФинансоваяОтчетностьСервер.УстановитьОтбор(Элемент.Отбор, ПутьДеревоПлатежей + ".ОстатокОшибкаКритическийОстаток",
		Истина);
	
	Элемент.Оформление.УстановитьЗначениеПараметра("ЦветФона", ЦветаСтиля.ЦветФонаОтрицательногоЗначения);
	
	// Ни в один день не было плановых оборотов
	
	Элемент = УсловноеОформление.Элементы.Добавить();
	
	ПолеЭлемента = Элемент.Поля.Элементы.Добавить();
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(Элементы.ДеревоПлатежей.Имя);
	
	ФинансоваяОтчетностьСервер.УстановитьОтбор(Элемент.Отбор, ПутьДеревоПлатежей + ".Сумма", 0);
		
	Элемент.Оформление.УстановитьЗначениеПараметра("ЦветТекста", ЦветаСтиля.СерыйЦветТекста1);
	
	// Фон суммы объекта оплаты без заявки в расшифровке
	
	Элемент = ПлатежиВКалендаре.КомпоновщикНастроек.Настройки.УсловноеОформление.Элементы.Добавить();
	
	ПолеЭлемента = Элемент.Поля.Элементы.Добавить();
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных("Сумма");
	
	ФинансоваяОтчетностьСервер.УстановитьОтбор(Элемент.Отбор, "ЕстьОшибкаНеСозданаЗаявка", Истина);
	
	Элемент.Оформление.УстановитьЗначениеПараметра("ЦветФона", ЦветаСтиля.ЦветФонаОтрицательногоЗначения);
	Элемент.Использование = Истина;
	Элемент.РежимОтображения = РежимОтображенияЭлементаНастройкиКомпоновкиДанных.Недоступный;
	
	// Исходная дата платежа меньше, чем перенесенная в расшифровке
	
	Элемент = ПлатежиВКалендаре.КомпоновщикНастроек.Настройки.УсловноеОформление.Элементы.Добавить();
	
	ПолеЭлемента = Элемент.Поля.Элементы.Добавить();
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных("Сумма");
	
	ФинансоваяОтчетностьСервер.УстановитьОтбор(Элемент.Отбор, "ЕстьИсходнаяДатаПлатежаМеньшеПеренесенной", Истина);
	
	Элемент.Оформление.УстановитьЗначениеПараметра("ЦветФона", ЦветаСтиля.ЦветФонаОтрицательногоЗначения);
	Элемент.Использование = Истина;
	Элемент.РежимОтображения = РежимОтображенияЭлементаНастройкиКомпоновкиДанных.Недоступный;
	
	// Отличия валюты платежа от валюты счета / кассы в расшифровке
	
	Элемент = ПлатежиВКалендаре.КомпоновщикНастроек.Настройки.УсловноеОформление.Элементы.Добавить();
	
	ПолеЭлемента = Элемент.Поля.Элементы.Добавить();
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных("Валюта");
	
	ФинансоваяОтчетностьСервер.УстановитьОтбор(Элемент.Отбор, "ЕстьОтличиеВалютПлатежаОтСчетаКассы", Истина);
		
	Элемент.Оформление.УстановитьЗначениеПараметра("Шрифт", Новый Шрифт(Элементы.ПлатежиВКалендареВалюта.Шрифт,,,, Истина));
	Элемент.Использование = Истина;
	Элемент.РежимОтображения = РежимОтображенияЭлементаНастройкиКомпоновкиДанных.Недоступный;
	
КонецПроцедуры

&НаСервере
Процедура УстановитьУсловноеОформлениеДнейДолгосрочныйПериодов()

	УсловноеОформлениеКУдалению = Новый Массив;

	Для Каждого ЭлементОформления Из УсловноеОформление.Элементы Цикл
		Если ЭлементОформления.Представление = "ДеньДолгосрочныйПериод" Тогда
			УсловноеОформлениеКУдалению.Добавить(ЭлементОформления);
		КонецЕсли;
	КонецЦикла;
	
	Для Каждого ЭлементОформления Из УсловноеОформлениеКУдалению Цикл
		УсловноеОформление.Элементы.Удалить(ЭлементОформления);
	КонецЦикла;

	ПутьДеревоПлатежей = "Объект.ДеревоПлатежей";
	
	ПоляФлаги = Новый Массив;
	ПоляФлаги.Добавить(Новый Структура("Поле, ОформлениеПараметр, ОформлениеЗначение",
		"ОшибкаКритическийОстаток", "ЦветФона", ЦветаСтиля.ЦветФонаОтрицательногоЗначения));
	
	ПоляФлаги.Добавить(Новый Структура("Поле, ОформлениеПараметр, ОформлениеЗначение",
		"ЕстьОшибкаНеСозданаЗаявка", "ЦветФона", ЦветаСтиля.ЦветФонаОтрицательногоЗначения));
		
	ПоляФлаги.Добавить(Новый Структура("Поле, ОформлениеПараметр, ОформлениеЗначение",
		"ЕстьИсходнаяДатаПлатежаМеньшеПеренесенной", "ЦветФона", ЦветаСтиля.ЦветФонаОтрицательногоЗначения));
		
	ШрифтЕстьОтличиеВалютПлатежаОтСчетаКассы = Новый Шрифт(Элементы.ПлатежиВКалендареВалюта.Шрифт,,,, Истина);
	ПоляФлаги.Добавить(Новый Структура("Поле, ОформлениеПараметр, ОформлениеЗначение",
		"ЕстьОтличиеВалютПлатежаОтСчетаКассы", "Шрифт", ШрифтЕстьОтличиеВалютПлатежаОтСчетаКассы));

	Для Каждого РеквизитДерева Из ПолучитьРеквизиты(ПутьДеревоПлатежей) Цикл
		Если (СтрНайти(РеквизитДерева.Имя, "День") > 0 ИЛИ СтрНайти(РеквизитДерева.Имя, "ДолгосрочныйПериод") > 0)
			И Элементы.Найти("ДеревоПлатежей" + РеквизитДерева.Имя) <> Неопределено Тогда
			
			ЭтоДень = (СтрНайти(РеквизитДерева.Имя, "День") > 0);
			
			Если ЭтоДень Тогда
				Номер = НомерДня(РеквизитДерева.Имя);
				ИмяПериода = "День";
				
			Иначе
				Номер = НомерДолгосрочногоПериода(РеквизитДерева.Имя);
				ИмяПериода = "ДолгосрочныйПериод";
			КонецЕсли;
			
			Для Каждого ПолеФлаг Из ПоляФлаги Цикл
				
				Если Номер = 0 И ПолеФлаг.Поле = "ОшибкаКритическийОстаток" Тогда
					Продолжить;
				КонецЕсли;
				
				Элемент = УсловноеОформление.Элементы.Добавить();
				
				ПолеЭлемента = Элемент.Поля.Элементы.Добавить();
				ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(Элементы["ДеревоПлатежей" + ИмяПериода + Номер].Имя);
				
				ФинансоваяОтчетностьСервер.УстановитьОтбор(Элемент.Отбор,
					ПутьДеревоПлатежей + "." + ИмяПериода + Номер + ПолеФлаг.Поле, Истина);
					
				Элемент.Оформление.УстановитьЗначениеПараметра(ПолеФлаг.ОформлениеПараметр, ПолеФлаг.ОформлениеЗначение);
				Элемент.Представление = "ДеньДолгосрочныйПериод";
			КонецЦикла;
		КонецЕсли;
	КонецЦикла;

КонецПроцедуры

&НаСервере
Процедура ИзменитьВидимостьЭлементовФормы()
	
	Элементы.ИзменитьРежим.Картинка = ЭтаФорма.Команды["Режим" + РежимОтображения].Картинка;
	
	ЗаявкиВидны = (РежимОтображения = "СписокЗаявок" Или РежимОтображения = "ЗаявкиКалендарь");
	КалендарьВиден = (РежимОтображения = "КалендарьПлатежи" Или РежимОтображения = "ЗаявкиКалендарь");
	
	Элементы.ГруппаЛеваяКолонка.Видимость  = ЗаявкиВидны;
	Элементы.ГруппаВКалендаре.Видимость    = Не ЗаявкиВидны;
	
	Элементы.ГруппаПраваяКолонка.Видимость         = КалендарьВиден;
	Элементы.СдвинутьВверх.Видимость               = КалендарьВиден;
	Элементы.СдвинутьВниз.Видимость                = КалендарьВиден;
	Элементы.ДеревоПлатежейСвернутьВсе.Видимость   = КалендарьВиден;
	Элементы.ДеревоПлатежейРазвернутьВсе.Видимость = КалендарьВиден;
	Элементы.ГруппаУправлениеГруппировками.Видимость = КалендарьВиден;
	Элементы.ЗаморозитьПросроченныеПлатежи.Видимость = КалендарьВиден;
	
	Элементы.ФильтрСчетовПодходящие.Видимость = ЗаявкиВидны И КалендарьВиден;
	
	Если КалендарьВиден Тогда
		Элементы.Переместить(Элементы.ГруппаКомандыДерева, Элементы.ГруппаПраваяКолонка, Элементы.ГруппаПанельПлатежей);
	Иначе
		Элементы.Переместить(Элементы.ГруппаКомандыДерева, Элементы.ГруппаКомандыЗаявки);
	КонецЕсли;
	
	Элементы.ГруппаФильтрСчетовИКасс.Видимость = (РежимОтображения = "ЗаявкиКалендарь");
	
	Если РежимОтображения = "СписокЗаявок" Тогда
		Элементы.Переместить(Элементы.ГруппаПланирование, Элементы.ГруппаКоманднаяПанельЗаявки);
		Элементы.Переместить(Элементы.РеестрПлатежей, Элементы.ГруппаКоманднаяПанельЗаявки);
	ИначеЕсли РежимОтображения = "ЗаявкиКалендарь" Тогда
		Элементы.Переместить(Элементы.ГруппаПланирование, Элементы.ГруппаКомандыДерева, Элементы.ЗаморозитьПросроченныеПлатежи);
		Элементы.Переместить(Элементы.РеестрПлатежей, Элементы.ГруппаКомандыДерева);
	Иначе
		Элементы.Переместить(Элементы.ГруппаПланирование, Элементы.ГруппаКомандыДерева, Элементы.ЗаморозитьПросроченныеПлатежи);
		Элементы.Переместить(Элементы.РеестрПлатежей, Элементы.ГруппаКомандыДерева);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ИзменитьВидимостьДнейПланирования()
	
	ЧислоДней = Объект.ДнейПланирования;
	Инд = 1;
	
	Для Инд = 1 По Объект.ДнейПланирования Цикл
		Если Объект.СкрыватьВыходные Тогда
			ДатаПлатежа = ДенежныеСредстваКлиентСервер.ДатаПлатежа(Объект.ПланироватьСДаты, Инд);
			Если ВыходныеДни.НайтиПоЗначению(ДатаПлатежа) <> Неопределено Тогда
				ЧислоДней = ЧислоДней + 1;
				Элементы["ДеревоПлатежей" + "День" + Инд].Видимость = Ложь;
			Иначе
				Элементы["ДеревоПлатежей" + "День" + Инд].Видимость = Истина;
			КонецЕсли;
		Иначе
			Элементы["ДеревоПлатежей" + "День" + Инд].Видимость = Истина;
		КонецЕсли;
	КонецЦикла;
	
	ПройденоДней = Инд - 1;
	
	Для Инд = ПройденоДней + 1 По Объект.ДнейПланирования Цикл
		Элементы["ДеревоПлатежей" + "День" + Инд].Видимость = Ложь;
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти

#Область НастройкиИОтборы

&НаКлиенте
Процедура ПриИзмененииНастроек(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ЗаполнитьЗначенияСвойств(Объект, Результат);
	ПриИзмененииНастроекНаСервере();
	УправлениеЭлементамиИстории();
	
КонецПроцедуры

&НаСервере
Процедура ПриИзмененииНастроекНаСервере()
	
	Обработка = РеквизитФормыВЗначение("Объект");
	ОтборОбластиПланирования.ЗагрузитьЗначения(Обработка.ОбластиПланирования());
	
	ОбновитьСпискиНаСервере();
	ИнициализироватьМенюУровнейГруппировок();
	
КонецПроцедуры

&НаКлиенте
Процедура Подключаемый_УстановитьОтборВКалендаре()
	
	УстановитьОтборПлатежиВКалендареНаСервере();
	
КонецПроцедуры

&НаСервере
Процедура УстановитьОтборПлатежиВКалендареНаСервере()
	
	ОбщегоНазначенияКлиентСервер.УстановитьПараметрДинамическогоСписка(ПлатежиВКалендаре, "ПомеченныеЗаписи",
		ПомеченныеЗаписиПлатежейВКалендаре);
		
	ДатаНачалаОтображенияПросроченныхПлатежей = Обработки.ПлатежныйКалендарь.ДатаНачалаОтображенияПросроченныхПлатежей(
		Объект.ПланироватьСДаты, Объект.ГлубинаОтображенияПросроченныхПлатежей);
	ОбщегоНазначенияКлиентСервер.УстановитьПараметрДинамическогоСписка(ПлатежиВКалендаре,
		"ДатаНачалаОтображенияПросроченныхПлатежей", ДатаНачалаОтображенияПросроченныхПлатежей);
	
	ПлатежиВКалендаре.Отбор.Элементы.Очистить();
	
	ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(ПлатежиВКалендаре, "Заморожен",
		ЗамороженныеПлатежи);
		
	ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(
		ПлатежиВКалендаре, "ОбластьПланирования", ОтборОбластиПланирования,,, ОтборОбластиПланирования.Количество());
		
	Если ЗамороженныеПлатежи Тогда
		
		ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(ПлатежиВКалендаре, "ДатаПлатежа",
			Объект.ДатаОкончания, ВидСравненияКомпоновкиДанных.МеньшеИлиРавно,, Истина);
		
		ПоляОтбора = Новый Массив;
		ПоляОтбора.Добавить("Организация");
		ПоляОтбора.Добавить("Валюта");
		ПоляОтбора.Добавить("Банк");
		ПоляОтбора.Добавить("ТипДенежныхСредств");
		
		Для Каждого Поле Из ПоляОтбора Цикл
			УстановитьОтборПлатежиВКалендареПоПолю(Поле);
		КонецЦикла;
		
		Возврат;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(ТекущаяГруппировкаДерева) Тогда
		Возврат;
	КонецЕсли;
	
	ОтборСпискаПлатежиВКалендаре = ОбщегоНазначенияУТКлиентСервер.ПолучитьОтборДинамическогоСписка(ПлатежиВКалендаре);
	ГруппаДатаАктуальности = ОбщегоНазначенияКлиентСервер.СоздатьГруппуЭлементовОтбора(
		ОтборСпискаПлатежиВКалендаре.Элементы, "ГруппаДатаАктуальности", ТипГруппыЭлементовОтбораКомпоновкиДанных.ГруппаИли);
	ОбщегоНазначенияКлиентСервер.ДобавитьЭлементКомпоновки(
		ГруппаДатаАктуальности, "ДатаАктуальностиГрафика", ВидСравненияКомпоновкиДанных.Равно, Дата(1,1,1),, Истина);
	ОбщегоНазначенияКлиентСервер.ДобавитьЭлементКомпоновки(
		ГруппаДатаАктуальности, "ДатаАктуальностиГрафика", ВидСравненияКомпоновкиДанных.БольшеИлиРавно,
		Объект.ПланироватьСДаты,, Истина);
	
	Если ЗначениеЗаполнено(ТекущаяКолонкаДерева) Тогда
	
		Если ТекущаяКолонкаДерева = "ДеревоПлатежейОстаток"
			Или ТекущаяКолонкаДерева = "ДеревоПлатежейРастяжка" Тогда // Ничего не показываем
			
			ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(ПлатежиВКалендаре, "ДатаПлатежа",
				Дата("39990101"),,, Истина);
		Иначе
			ТекущаяДатаКалендаря = ВыделенныйДень(ТекущаяКолонкаДерева, Объект.ПланироватьСДаты);
			
			Если ЗначениеЗаполнено(ТекущаяДатаКалендаря) Тогда
				
				ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(ПлатежиВКалендаре,
					"ДатаПлатежа", ТекущаяДатаКалендаря,
					?(ТекущаяДатаКалендаря < Объект.ПланироватьСДаты, ВидСравненияКомпоновкиДанных.МеньшеИлиРавно,
						ВидСравненияКомпоновкиДанных.Равно),, Истина);
			Иначе
				ТекущийДолгосрочныйПериодДатаНачала = ВыделенныйДолгосрочныйПериод(ТекущаяКолонкаДерева,
					Объект.ДатаОкончанияПланированияПоДням, Объект.ПериодичностьДолгосрочногоПланирования);
					
				Если ЗначениеЗаполнено(ТекущийДолгосрочныйПериодДатаНачала) Тогда

					ТекущийДолгосрочныйПериодДатаКонца = РаботаСПериодамиКлиентСервер.ДатаКонцаПериода(
						ТекущийДолгосрочныйПериодДатаНачала, Объект.ПериодичностьДолгосрочногоПланирования);
					
					ДополнительныеПараметры = Новый Структура("ЗаменятьСуществующий", Ложь);
						
					КомпоновкаДанныхКлиентСервер.ДобавитьОтбор(ПлатежиВКалендаре.Отбор, "ДатаПлатежа",
						ТекущийДолгосрочныйПериодДатаНачала, ВидСравненияКомпоновкиДанных.БольшеИлиРавно,,
						ДополнительныеПараметры);
						
					КомпоновкаДанныхКлиентСервер.ДобавитьОтбор(ПлатежиВКалендаре.Отбор, "ДатаПлатежа",
						ТекущийДолгосрочныйПериодДатаКонца, ВидСравненияКомпоновкиДанных.МеньшеИлиРавно,,
						ДополнительныеПараметры);
				Иначе
					ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(ПлатежиВКалендаре,
						"ДатаПлатежа", Объект.ДатаОкончания, ВидСравненияКомпоновкиДанных.МеньшеИлиРавно,, Истина);
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Объект.ОтборВалюта) Тогда
		ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(ПлатежиВКалендаре, "ВалютаПлатежа",
			Объект.ОтборВалюта,,, Истина);
	Иначе
		ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(ПлатежиВКалендаре, "ВалютаПлатежа",
			ТекущаяВалюта,,, ЗначениеЗаполнено(ТекущаяВалюта));
	КонецЕсли;
	
	ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(ПлатежиВКалендаре, "ПоступлениеСписание",
		ТекущийТипДвижения,,, ЗначениеЗаполнено(ТекущийТипДвижения));
	
	ВидСравненияСчетаКассы = ВидСравненияКомпоновкиДанных.Равно;
	ИспользоватьОтборПоСчетуКассе = ЗначениеЗаполнено(ТекущийБанковскийСчетКасса);
	
	Если ТипЗнч(ТекущаяГруппировкаДерева) = Тип("Строка") Тогда
		Если ТекущаяСтрокаДереваНеРаспределено Тогда
			ВидСравненияСчетаКассы = ВидСравненияКомпоновкиДанных.НеЗаполнено;
			ИспользоватьОтборПоСчетуКассе = Истина;
		ИначеЕсли ТекущаяСтрокаДереваРаспределено Тогда
			ВидСравненияСчетаКассы = ВидСравненияКомпоновкиДанных.Заполнено;
			ИспользоватьОтборПоСчетуКассе = Истина;
		ИначеЕсли ТекущаяГруппировкаДерева = "Итого" Тогда
			ИспользоватьОтборПоСчетуКассе = Ложь;
		КонецЕсли;
	КонецЕсли;
	
	Если ИспользоватьОтборПоСчетуКассе Тогда
		ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(ПлатежиВКалендаре,
			"БанковскийСчетКасса", ТекущийБанковскийСчетКасса, ВидСравненияСчетаКассы,, Истина);
	Иначе
		УстановитьОтборПлатежиВКалендареПоПолю("БанковскийСчетКасса");
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ТекущаяОрганизация) Тогда
		ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(ПлатежиВКалендаре, "Организация",
			ТекущаяОрганизация,,, ЗначениеЗаполнено(ТекущаяОрганизация));
	Иначе
		УстановитьОтборПлатежиВКалендареПоПолю("Организация");
	КонецЕсли;
		
	Если ЗначениеЗаполнено(ТекущийТипДенежныхСредств) Тогда
		ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(ПлатежиВКалендаре, "ТипДенежныхСредств",
			ТекущийТипДенежныхСредств,,, Истина);
	Иначе
		УстановитьОтборПлатежиВКалендареПоПолю("ТипДенежныхСредств");
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ТекущийБанк) Тогда
		ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(ПлатежиВКалендаре, "Банк",
			ТекущийБанк,,, Истина);
	Иначе
		УстановитьОтборПлатежиВКалендареПоПолю("Банк");
	КонецЕсли;
		
КонецПроцедуры

&НаСервере
Процедура УстановитьОтборыДинамическихСписков()
	
	Если ИмяТекущегоСписка = "ПлатежиВКалендаре" Тогда
		Возврат;
	КонецЕсли;
	
	ДинамическийСписок = ЭтаФорма[ИмяТекущегоСписка];
	
	Организации = Новый Массив;
	Для каждого ЭлементОтбора Из Объект.ОтборОрганизации Цикл
		Если ЭлементОтбора.Пометка Тогда
			Организации.Добавить(ЭлементОтбора.Значение);
		КонецЕсли;
	КонецЦикла;
	
	ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(
		ДинамическийСписок,
		"Организация",
		Организации,,,
		Организации.Количество());
		
	ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(
		ДинамическийСписок,
		"Валюта",
		Объект.ОтборВалюта,,,
		ЗначениеЗаполнено(Объект.ОтборВалюта));
		
	ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(
		ДинамическийСписок,
		"ДатаПлатежа",
		ДенежныеСредстваКлиентСервер.ДатаПлатежа(Объект.ПланироватьСДаты, Объект.ДнейПланирования),
		ВидСравненияКомпоновкиДанных.МеньшеИлиРавно);
		
	ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(
		ДинамическийСписок,
		"ОбластьПланирования",
		ОтборОбластиПланирования,,,
		ОтборОбластиПланирования.Количество());
		
	ОбщегоНазначенияКлиентСервер.УстановитьПараметрДинамическогоСписка(ДинамическийСписок, "ПомеченныеЗаписи",
		ЭтотОбъект[ИмяТекущегоСпискаПомеченныеЗаписи]);
		
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьФормуНастройкиБанковскихСчетов()
	
	ЗаполнитьСписокСчетовКассНаСервере();
	
	ОповещениеОЗакрытии = Новый ОписаниеОповещения("ВыборБанковскихСчетовКасс", ЭтотОбъект);
	
	Отмеченные = Новый СписокЗначений;
	Для каждого ЭлементОтборБанковскиеСчетаКассы Из Объект.ОтборБанковскиеСчетаКассы Цикл
		Если ЭлементОтборБанковскиеСчетаКассы.Пометка Тогда
			Отмеченные.Добавить(ЭлементОтборБанковскиеСчетаКассы.Значение, , Истина);
		КонецЕсли;
	КонецЦикла;
	
	МассивТипов = Новый Массив;
	МассивТипов.Добавить(Тип("СправочникСсылка.БанковскиеСчетаОрганизаций"));
	МассивТипов.Добавить(Тип("СправочникСсылка.Кассы"));
	МассивТипов.Добавить(Тип("Строка"));
	ДопустимыеТипы = Новый ОписаниеТипов(МассивТипов);
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("ОграничиватьВыборУказаннымиЗначениями", Истина);
	ПараметрыФормы.Вставить("Представление", НСтр("ru = 'Отбор банковских счетов / касс'"));
	ПараметрыФормы.Вставить("ЗначенияДляВыбора", Объект.ОтборБанковскиеСчетаКассы);
	ПараметрыФормы.Вставить("ОписаниеТипов", ДопустимыеТипы);
	ПараметрыФормы.Вставить("Отмеченные", Отмеченные);
	
	ОткрытьФорму("ОбщаяФорма.ВводЗначенийСпискомСФлажками", ПараметрыФормы, ЭтотОбъект,,,,
		ОповещениеОЗакрытии, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	
КонецПроцедуры

&НаКлиенте
Процедура ВыборБанковскихСчетовКасс(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат <> Неопределено И ТипЗнч(Результат) = Тип("СписокЗначений") Тогда
		Объект.ОтборБанковскиеСчетаКассы = Результат;
		ОтборБанковскийСчетКассаПредставление = ОтборПредставление(Объект.ОтборБанковскиеСчетаКассы);
		Если Не ЗначениеЗаполнено(ОтборБанковскийСчетКассаПредставление) Тогда
			Объект.ФильтрСчетовКалендаря = 0;
		Иначе
			Объект.ФильтрСчетовКалендаря = 1;
		КонецЕсли;
		УстановитьКомпоновщикОтборПоОтборБанковскиеСчетаКассы(Объект.КомпоновщикОтбор, Объект.ОтборБанковскиеСчетаКассы);
		ОбновитьСписки();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьСписки()
	
	ПроверитьДатуПланированияИОбновитьСписки();
	УправлениеЭлементамиИстории();
	
КонецПроцедуры

&НаСервере
Процедура ПроверитьДатуПланированияИОбновитьСписки()
	
	ОбновитьСпискиНаСервере();
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьСпискиНаСервере()
	
	УстановитьОтборыДинамическихСписков();
	
	Если РежимОтображения <> "СписокЗаявок" Тогда
		
		КлючеваяОперация = "ПланированиеИКонтрольДенежныхСредств.ОбновлениеДанныхПлатежногоКалендаря";
		ОписаниеЗамера = ОценкаПроизводительности.НачатьЗамерДлительнойОперации(КлючеваяОперация);
		
		ДополнитьКолонкиДней();
		ДополнитьКолонкиДолгосрочногоПланирования();
		
		Обработка = РеквизитФормыВЗначение("Объект");
		Обработка.РассчитатьДанныеКалендаря(ПараметрыРасчетаКалендаря());
		ЗначениеВРеквизитФормы(Обработка, "Объект");
		
		Элементы.ГруппаПанельПлатежей.ТекущаяСтраница = Элементы.СтраницаДеревоПлатежей;
		
		ИзменитьВидимостьДнейПланирования();
		
		ОтметитьФильтрСчетов();
		
		Если ТекущаяКолонкаДерева <> Неопределено Тогда
			ЭлементУправления = Элементы.ДеревоПлатежей.ПодчиненныеЭлементы.Найти(ТекущаяКолонкаДерева);
			Если ЭлементУправления <> Неопределено Тогда
				Элементы.ДеревоПлатежей.ТекущийЭлемент = ЭлементУправления;
			КонецЕсли;
		КонецЕсли;
		
		РеквизитыПоискаСтроки = Новый Структура;
		РеквизитыПоискаСтроки.Вставить("Группировка", ТекущаяГруппировкаДерева);
		РеквизитыПоискаСтроки.Вставить("ВидСтроки", ТекущийВидСтроки);
		РеквизитыПоискаСтроки.Вставить("БанковскийСчетКасса", ТекущийБанковскийСчетКасса);
		РеквизитыПоискаСтроки.Вставить("Валюта", ТекущаяВалюта);
		
		НайденнаяСтрока = ПодчиненныйЭлемент(Объект.ДеревоПлатежей, РеквизитыПоискаСтроки);
		Если НайденнаяСтрока <> Неопределено Тогда
			Элементы.ДеревоПлатежей.ТекущаяСтрока = НайденнаяСтрока.ПолучитьИдентификатор();
		КонецЕсли;
		
		Если РежимОтображения = "КалендарьПлатежи" Тогда
			УстановитьОтборПлатежиВКалендареНаСервере();
		КонецЕсли;
		
		ИсторияИзменений.Очистить();
		ТекущийИндексИстории = 0;
		
		ОценкаПроизводительности.ЗакончитьЗамерДлительнойОперации(ОписаниеЗамера, 1);
	КонецЕсли;
	
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(
		Элементы,
		"РасширенныйОтбор",
		"Заголовок",
		ПолучитьЗаголовокГиперссылкиРасширенныйОтбор(Объект.КомпоновщикОтбор));
	
КонецПроцедуры

&НаСервере
Процедура НастроитьОтображениеГруппировки()
	
	ПользовательскиеНастройки = Этаформа[ИмяТекущегоСписка].КомпоновщикНастроек.ПользовательскиеНастройки; // ПользовательскиеНастройкиКомпоновкиДанных 
	НастройкаГруппировки = ПользовательскиеНастройки.Элементы[3];
	
	ИмяГруппировки = "";
	Если НастройкаГруппировки.Структура.Количество() = 1 Тогда
		ПоляГруппировки = НастройкаГруппировки.Структура[0].ПоляГруппировки; // ПоляГруппировкиКомпоновкиДанных
		ИмяГруппировки = Строка(ПоляГруппировки.Элементы[0].Поле);
	КонецЕсли;
	
	ОтметитьГруппировкуСписка(ИмяГруппировки);
	
КонецПроцедуры

&НаСервере
Функция ПараметрыФормыРасширенногоОтбора()
	
	ПараметрыОткрытия = Новый Структура;
	ПараметрыОткрытия.Вставить("НастройкиОтбора", Объект.КомпоновщикОтбор.ПолучитьНастройки());
	ПараметрыОткрытия.Вставить("СкрыватьСлужебныеОтборы", Истина);
	
	Возврат ПараметрыОткрытия;
	
КонецФункции

&НаКлиенте
Процедура УстановитьРасширенныйОтборЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	УстановитьОтборыНаСервере(Результат.НастройкиОтбора);

КонецПроцедуры

&НаСервере
Процедура УстановитьОтборыНаСервере(Знач НастройкиОтбора)

	Объект.КомпоновщикОтбор.ЗагрузитьНастройки(НастройкиОтбора);
	УстановитьОтборОрганизацииПоКомпоновщикОтбор(Объект.КомпоновщикОтбор, Объект.ОтборОрганизации);
	УстановитьОтборВалютаПоКомпоновщикОтбор(Объект.КомпоновщикОтбор, Объект.ОтборВалюта);
	УстановитьОтборБанковскиеСчетаКассыПоКомпоновщикОтбор(Объект.КомпоновщикОтбор, Объект.ОтборБанковскиеСчетаКассы);
	
	ОтборОрганизацииПредставление = ОтборПредставление(Объект.ОтборОрганизации);
	ОтборБанковскийСчетКассаПредставление = ОтборПредставление(Объект.ОтборБанковскиеСчетаКассы);
	
	ОбновитьСпискиНаСервере();

КонецПроцедуры

&НаСервереБезКонтекста
Функция ПолучитьЗаголовокГиперссылкиРасширенныйОтбор(Знач НастройкиОтбора)
	
	УстановленоОтборов = 0;
	Заголовок = НСтр("ru = 'Расширенный отбор'");
	ТекстОтбора = "";
	
	ПоляОтбора = Новый СписокЗначений;
	ПоляОтбора.Добавить("Валюта", НСтр("ru = 'Валюта'"));
	ПоляОтбора.Добавить("Организация", НСтр("ru = 'Организация'"));
	ПоляОтбора.Добавить("ТипДенежныхСредств", НСтр("ru = 'Тип денежных средств'"));
	ПоляОтбора.Добавить("БанкКассы", НСтр("ru = 'Банк'"));
	ПоляОтбора.Добавить("БанковскийСчетКасса", НСтр("ru = 'Банковский счет / Касса'"));
	
	Для Каждого Поле Из ПоляОтбора Цикл
		ЭлементОтбора = НайтиЭлементОтбораБезПоискаВГруппах(НастройкиОтбора.Настройки.Отбор, Поле.Значение);

		Если ЭлементОтбора <> Неопределено И ЭлементОтбора.Использование Тогда
			ТекстОтбора = ТекстОтбора + ?(ПустаяСтрока(ТекстОтбора), "", ", ") + Поле.Представление;
			УстановленоОтборов = УстановленоОтборов + 1;
		КонецЕсли;
	КонецЦикла;
	
	Если УстановленоОтборов = 0 Тогда
		Для Каждого ЭлементОтбора Из НастройкиОтбора.Настройки.Отбор.Элементы Цикл
			Если ЭлементОтбора.Использование Тогда
				УстановленоОтборов = УстановленоОтборов + 1;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ТекстОтбора) Тогда
		Заголовок = ?(УстановленоОтборов > 2,
			СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(НСтр("ru = 'Установлено отборов: %1'"), УстановленоОтборов),
			СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(НСтр("ru = 'Установлен отбор по: %1'"), ТекстОтбора));
	ИначеЕсли УстановленоОтборов > 0 Тогда
		Заголовок = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(НСтр("ru = 'Установлено отборов: %1'"),
			УстановленоОтборов);
	КонецЕсли;
	
	Возврат Заголовок;
	
КонецФункции

// Устанавливает отбор по полю "Организация" в переданный компоновщик настроек.
// 
// Параметры:
//  КомпоновщикОтбор - КомпоновщикНастроекКомпоновкиДанных
//  ОтборОрганизации - СписокЗначений из СправочникСсылка.Организации
//
&НаСервереБезКонтекста
Процедура УстановитьОтборОрганизацииПоКомпоновщикОтбор(Знач КомпоновщикОтбор, ОтборОрганизации)
	
	ОтборОрганизации.ЗаполнитьПометки(Ложь);
	
	ЭлементОтбора = НайтиЭлементОтбораБезПоискаВГруппахРавноВСписке(КомпоновщикОтбор.Настройки.Отбор, "Организация");
	
	Если ЭлементОтбора <> Неопределено И ЭлементОтбора.Использование
		И ЗначениеЗаполнено(ЭлементОтбора.ПравоеЗначение) Тогда
	
		Если ТипЗнч(ЭлементОтбора.ПравоеЗначение) = Тип("СправочникСсылка.Организации") Тогда
			
			ЭлементСписка = ОтборОрганизации.НайтиПоЗначению(ЭлементОтбора.ПравоеЗначение);
			
			Если ЭлементСписка = Неопределено Тогда
				ОтборОрганизации.Добавить(ЭлементОтбора.ПравоеЗначение, , Истина);
			Иначе
				ЭлементСписка.Пометка = Истина;
			КонецЕсли;
			
		ИначеЕсли ТипЗнч(ЭлементОтбора.ПравоеЗначение) = Тип("СписокЗначений") Тогда

			Для Каждого ЭлементМассива Из ЭлементОтбора.ПравоеЗначение Цикл // ЭлементСпискаЗначений
				
				ЭлементСписка = ОтборОрганизации.НайтиПоЗначению(ЭлементОтбора.ПравоеЗначение);
			
				Если ЭлементСписка = Неопределено Тогда
					ОтборОрганизации.Добавить(ЭлементМассива.Значение, , Истина);
				Иначе
					ЭлементСписка.Пометка = Истина;
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

// Устанавливает отбор по полю "БанковскийСчетКасса" в переданный компоновщик настроек.
// 
// Параметры:
//  КомпоновщикОтбор - КомпоновщикНастроекКомпоновкиДанных
//  ОтборБанковскиеСчетаКассы - СписокЗначений из СправочникСсылка.БанковскиеСчетаОрганизаций, СправочникСсылка.Кассы
//
&НаСервереБезКонтекста
Процедура УстановитьОтборБанковскиеСчетаКассыПоКомпоновщикОтбор(Знач КомпоновщикОтбор, ОтборБанковскиеСчетаКассы)

	ОтборБанковскиеСчетаКассы.ЗаполнитьПометки(Ложь);

	ЭлементОтбора = НайтиЭлементОтбораБезПоискаВГруппахРавноВСписке(КомпоновщикОтбор.Настройки.Отбор, "БанковскийСчетКасса");
	
	Если ЭлементОтбора <> Неопределено И ЭлементОтбора.Использование
		И ЗначениеЗаполнено(ЭлементОтбора.ПравоеЗначение) Тогда
	
		Если ТипЗнч(ЭлементОтбора.ПравоеЗначение) = Тип("СписокЗначений") Тогда

			Для Каждого ЭлементМассива Из ЭлементОтбора.ПравоеЗначение Цикл // ЭлементСпискаЗначений
				
				ЭлементСписка = ОтборБанковскиеСчетаКассы.НайтиПоЗначению(ЭлементОтбора.ПравоеЗначение);
			
				Если ЭлементСписка = Неопределено Тогда
					ОтборБанковскиеСчетаКассы.Добавить(ЭлементМассива.Значение, , Истина);
				Иначе
					ЭлементСписка.Пометка = Истина;
				КонецЕсли;
			КонецЦикла;
		Иначе
			ЭлементСписка = ОтборБанковскиеСчетаКассы.НайтиПоЗначению(ЭлементОтбора.ПравоеЗначение);
			
			Если ЭлементСписка = Неопределено Тогда
				ОтборБанковскиеСчетаКассы.Добавить(ЭлементОтбора.ПравоеЗначение, , Истина);
			Иначе
				ЭлементСписка.Пометка = Истина;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;

КонецПроцедуры

&НаСервереБезКонтекста
Процедура УстановитьОтборВалютаПоКомпоновщикОтбор(Знач КомпоновщикОтбор, ОтборВалюта)
	
	ОтборВалюта = Справочники.Валюты.ПустаяСсылка();
	ЭлементОтбора = НайтиЭлементОтбораБезПоискаВГруппахРавноВСписке(КомпоновщикОтбор.Настройки.Отбор, "Валюта");
	
	Если ЭлементОтбора <> Неопределено И ЭлементОтбора.Использование
		И ЗначениеЗаполнено(ЭлементОтбора.ПравоеЗначение) Тогда
	
		Если ТипЗнч(ЭлементОтбора.ПравоеЗначение) = Тип("СправочникСсылка.Валюты") Тогда
			ОтборВалюта = ЭлементОтбора.ПравоеЗначение;
			
		ИначеЕсли ТипЗнч(ЭлементОтбора.ПравоеЗначение) = Тип("СписокЗначений") Тогда
			
			Если ЭлементОтбора.ПравоеЗначение.Количество() = 1 Тогда
				ОтборВалюта = ЭлементОтбора.ПравоеЗначение[0].Значение;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаСервереБезКонтекста
Процедура УстановитьКомпоновщикОтборПоОтборОрганизации(КомпоновщикОтбор, Знач ОтборОрганизации)

	Организации = Новый СписокЗначений;
	Для каждого ЭлементОтбора Из ОтборОрганизации Цикл
		Если ЭлементОтбора.Пометка Тогда
			Организации.Добавить(ЭлементОтбора.Значение);
		КонецЕсли;
	КонецЦикла;
	
	СписокНеПустой = (Организации.Количество() > 0);
	УстановитьОтборБезПоискаВГруппах(КомпоновщикОтбор.Настройки.Отбор, "Организация", Организации,, СписокНеПустой);

КонецПроцедуры

&НаСервереБезКонтекста
Процедура УстановитьКомпоновщикОтборПоОтборВалюта(КомпоновщикОтбор, Знач ОтборВалюта)

	УстановитьОтборБезПоискаВГруппах(КомпоновщикОтбор.Настройки.Отбор, "Валюта", ОтборВалюта,,
		ЗначениеЗаполнено(ОтборВалюта));

КонецПроцедуры

&НаСервереБезКонтекста
Процедура УстановитьКомпоновщикОтборПоОтборБанковскиеСчетаКассы(КомпоновщикОтбор, Знач ОтборБанковскиеСчетаКассы)

	БанковскиеСчетаКассы = Новый СписокЗначений;
	Для каждого ЭлементОтбора Из ОтборБанковскиеСчетаКассы Цикл
		Если ЭлементОтбора.Пометка Тогда
			БанковскиеСчетаКассы.Добавить(ЭлементОтбора.Значение);
		КонецЕсли;
	КонецЦикла;
	
	СписокНеПустой = (БанковскиеСчетаКассы.Количество() > 0);
	УстановитьОтборБезПоискаВГруппах(КомпоновщикОтбор.Настройки.Отбор, "БанковскийСчетКасса", БанковскиеСчетаКассы,,
		СписокНеПустой);

КонецПроцедуры

&НаСервере
Процедура УстановитьОтборПлатежиВКалендареПоПолю(ИмяПоля)
	
	ОтборПоля = НайтиЭлементОтбораБезПоискаВГруппахРавноВСписке(Объект.КомпоновщикОтбор.Настройки.Отбор, ИмяПоля);
	
	Если ОтборПоля <> Неопределено Тогда
		ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(ПлатежиВКалендаре, ИмяПоля,
			ОтборПоля.ПравоеЗначение, ОтборПоля.ВидСравнения,, ОтборПоля.Использование);
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

&НаСервере
Процедура ОтметитьФильтрСчетов()
	
	Элементы.ФильтрСчетовВсе.Пометка = (Объект.ФильтрСчетовКалендаря = 0);
	Элементы.ФильтрСчетовВыбранные.Пометка = (Объект.ФильтрСчетовКалендаря = 1);
	Элементы.ФильтрСчетовПодходящие.Пометка = (Объект.ФильтрСчетовКалендаря = 2);
	
	Если Объект.ФильтрСчетовКалендаря = 0 Тогда
		ЗаголовокФильтра = НСтр("ru = 'Счета / Кассы: Все'");
	ИначеЕсли Объект.ФильтрСчетовКалендаря = 1 Тогда
		ЗаголовокФильтра = НСтр("ru = 'Счета / Кассы: Выбранные'");
	ИначеЕсли Объект.ФильтрСчетовКалендаря = 2 Тогда
		ЗаголовокФильтра = НСтр("ru = 'Счета / Кассы: Подходящие'");
	КонецЕсли;
	
	Элементы.ГруппаФильтрСчетовИКасс.Заголовок = ЗаголовокФильтра;
	
КонецПроцедуры

&НаСервере
Процедура ОтметитьГруппировкуСписка(ИмяГруппировки)
	
	Если ИмяТекущегоСписка = "ЗаявкиКОплате" Тогда
		Элементы.ЗаявкиКОплатеГруппировкаПриоритетСтатьиДДС.Пометка        = (ИмяГруппировки = "ПриоритетСтатьиДДС");
		Элементы.ЗаявкиКОплатеГруппировкаСтатьяДДС.Пометка                 = (ИмяГруппировки = "СтатьяДДС");
		Элементы.ЗаявкиКОплатеГруппировкаПриоритетЗаявки.Пометка           = (ИмяГруппировки = "ПриоритетЗаявки");
		Элементы.ЗаявкиКОплатеГруппировкаХозяйственнаяОперация.Пометка     = (ИмяГруппировки = "Операция");
		Элементы.ЗаявкиКОплатеГруппировкаПодразделение.Пометка             = (ИмяГруппировки = "Подразделение");
		Элементы.ЗаявкиКОплатеГруппировкаПлательщикПолучатель.Пометка      = (ИмяГруппировки = "ПлательщикПолучатель");
		Элементы.ЗаявкиКОплатеБезГруппировки.Пометка                       = (ИмяГруппировки = "");
	Иначе
		Элементы.ПлатежиВКалендареГруппировкаПриоритетСтатьиДДС.Пометка    = (ИмяГруппировки = "ПриоритетСтатьиДДС");
		Элементы.ПлатежиВКалендареГруппировкаСтатьяДДС.Пометка             = (ИмяГруппировки = "СтатьяДДС");
		Элементы.ПлатежиВКалендареГруппировкаПриоритетЗаявки.Пометка       = (ИмяГруппировки = "ПриоритетЗаявки");
		Элементы.ПлатежиВКалендареГруппировкаХозяйственнаяОперация.Пометка = (ИмяГруппировки = "Операция");
		Элементы.ПлатежиВКалендареГруппировкаПодразделение.Пометка         = (ИмяГруппировки = "Подразделение");
		Элементы.ПлатежиВКалендареГруппировкаПлательщикПолучатель.Пометка  = (ИмяГруппировки = "ПлательщикПолучатель");
		Элементы.ПлатежиВКалендареБезГруппировки.Пометка                   = (ИмяГруппировки = "");
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ИнициализироватьОтборОрганизаций()
	
	ДоступныеОрганизации = Справочники.Организации.ДоступныеОрганизации(Истина, Ложь);
	Элементы.ОтборОрганизации.СписокВыбора.ЗагрузитьЗначения(ДоступныеОрганизации);
	Объект.ОтборОрганизации.ЗагрузитьЗначения(ДоступныеОрганизации);
	ОтборОрганизации.ЗагрузитьЗначения(ДоступныеОрганизации);
	
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьОбъектОплаты()
	
	ТекущаяСтрока = Элементы[ИмяТекущегоСписка].ТекущаяСтрока;
	
	Если ТипЗнч(ТекущаяСтрока) = Тип("СтрокаГруппировкиДинамическогоСписка") Тогда
		
		ПоказатьЗначение(, ТекущаяСтрока.Ключ);
		
	Иначе
		ТекущиеДанные = Элементы[ИмяТекущегоСписка].ТекущиеДанные;
		
		Если ТекущиеДанные <> Неопределено Тогда
			ПоказатьЗначение(, ТекущиеДанные.ОбъектОплаты);
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция ПараметрыРасчетаКалендаря()
	
	ПараметрыРасчета = Новый Структура;
	ПараметрыРасчета.Вставить("ИдФормы", УникальныйИдентификатор);
	
	Если Объект.ФильтрСчетовКалендаря = 2 Тогда
		ПараметрыРасчета.Вставить("Заявка", ТекущаяЗаявка);
	КонецЕсли;
	
	Возврат ПараметрыРасчета;
	
КонецФункции

&НаСервере
Процедура ДополнитьКолонкиДней()
	
	ЗаполнитьВыходныеДни();
	
	ОписаниеЧисла = ОбщегоНазначенияУТ.ОписаниеТипаДенежногоПоля();
	ПутьРеквизитов = "Объект.ДеревоПлатежей";
	
	ВсегоКолонокДолгосрочныхПериодов = 0;
	Для Каждого РеквизитДерева Из ПолучитьРеквизиты(ПутьРеквизитов) Цикл
		Если СтрНайти(РеквизитДерева.Имя, "ДолгосрочныйПериод") > 0 Тогда
			ВсегоКолонокДолгосрочныхПериодов = ВсегоКолонокДолгосрочныхПериодов + 1;
		КонецЕсли;
	КонецЦикла;
	
	ПодчиненныхЭлементов = ПолучитьРеквизиты(ПутьРеквизитов).Количество();
	ВсегоКолонокДней = (ПодчиненныхЭлементов - ЭлементовДереваБезДобавленныхДней - ВсегоКолонокДолгосрочныхПериодов) / 7;
	
	РеквизитыКДобавлению = Новый Массив;
	ЭлементыКДобавлению = Новый Массив; // Массив из ПолеФормы
	РеквизитыКУдалению = Новый Массив;
	
	Поля = Новый Соответствие;
	Поля.Вставить("ВВалюте", ОписаниеЧисла);
	Поля.Вставить("ВОднойВалюте", ОписаниеЧисла);
	Поля.Вставить("ОшибкаКритическийОстаток", Новый ОписаниеТипов("Булево"));
	Поля.Вставить("ЕстьОшибкаНеСозданаЗаявка", Новый ОписаниеТипов("Булево"));
	Поля.Вставить("ЕстьИсходнаяДатаПлатежаМеньшеПеренесенной", Новый ОписаниеТипов("Булево"));
	Поля.Вставить("ЕстьОтличиеВалютПлатежаОтСчетаКассы", Новый ОписаниеТипов("Булево"));
	
	Пока ВсегоКолонокДней > Объект.ДнейПланирования + 1 Цикл
		НомерДня = ВсегоКолонокДней - 1;
		ПутьУдаляемогоРеквизита = ПутьРеквизитов + ".День" + Строка(НомерДня);
		РеквизитыКУдалению.Добавить(ПутьУдаляемогоРеквизита);
		
		Для Каждого Поле Из Поля Цикл
			РеквизитыКУдалению.Добавить(ПутьУдаляемогоРеквизита + Поле.Ключ);
		КонецЦикла;
		ВсегоКолонокДней = НомерДня;
	КонецЦикла;
	
	Для Инд = ВсегоКолонокДней По Объект.ДнейПланирования Цикл
		
		ИмяРеквизита = "День" + Инд;
		
		РеквизитДерева = Новый РеквизитФормы(ИмяРеквизита, ОписаниеЧисла, ПутьРеквизитов);
		РеквизитыКДобавлению.Добавить(РеквизитДерева);
		ЭлементыКДобавлению.Добавить(РеквизитДерева);
		
		Для Каждого Поле Из Поля Цикл
			РеквизитДерева = Новый РеквизитФормы(ИмяРеквизита + Поле.Ключ, Поле.Значение, ПутьРеквизитов);
			РеквизитыКДобавлению.Добавить(РеквизитДерева);
		КонецЦикла;
	КонецЦикла;
	
	ИзменитьРеквизиты(РеквизитыКДобавлению, РеквизитыКУдалению);
	
	ЭлементДеревоПлатежейДолгосрочныйПериод1 = Элементы.Найти("ДеревоПлатежейДолгосрочныйПериод1");
	ПоследнийЭлементВДеревоПлатежей = ?(ЭлементДеревоПлатежейДолгосрочныйПериод1 <> Неопределено,
		ЭлементДеревоПлатежейДолгосрочныйПериод1, Элементы.ДеревоПлатежейРастяжка);
	
	Для Каждого ЭлементКДобавлению Из ЭлементыКДобавлению Цикл
		НовыйЭлемент = Элементы.Вставить("ДеревоПлатежей" + ЭлементКДобавлению.Имя, Тип("ПолеФормы"), Элементы.ДеревоПлатежей, 
			ПоследнийЭлементВДеревоПлатежей);
		НовыйЭлемент.Вид = ВидПоляФормы.ПолеНадписи;
		НовыйЭлемент.ПутьКДанным = ПутьРеквизитов + "." + ЭлементКДобавлению.Имя;
		НовыйЭлемент.Ширина = 12;
		НовыйЭлемент.РастягиватьПоГоризонтали = Ложь;
		НовыйЭлемент.ГоризонтальноеПоложение = ГоризонтальноеПоложениеЭлемента.Право;
	КонецЦикла;
	
	ЭлементДень0 = Элементы.Найти("ДеревоПлатежей" + "День0");
	Если ЭлементДень0 <> Неопределено Тогда
		ЭлементДень0.Заголовок = НСтр("ru = 'Просрочено'");
		ЭлементДень0.ЦветТекста = ЦветаСтиля.ПросроченныеДанныеЦвет;
		ЭлементДень0.ЦветТекстаЗаголовка = ЦветаСтиля.ПросроченныеДанныеЦвет;
	КонецЕсли;
	Дни.Очистить();
	
	Для Инд = 1 По Объект.ДнейПланирования Цикл
		ИмяЭлемента = "ДеревоПлатежей" + "День" + Инд;
		ДатаЗаголовка = ДенежныеСредстваКлиентСервер.ДатаПлатежа(Объект.ПланироватьСДаты, Инд);
		НоваяСтр = Дни.Добавить();
		НоваяСтр.ИмяПоля = ИмяЭлемента;
		НоваяСтр.Дата = ДатаЗаголовка;
		
		Элементы[ИмяЭлемента].Заголовок =
			Формат(ДатаЗаголовка, НСтр("ru='ДФ=''ддд'''")) + " " + Формат(ДатаЗаголовка, "ДЛФ=Д");
		
		Если ВыходныеДни.НайтиПоЗначению(ДатаЗаголовка) <> Неопределено Тогда
			Элементы[ИмяЭлемента].ЦветТекстаЗаголовка = ЦветаСтиля.СерыйЦветТекста1;
		Иначе
			Элементы[ИмяЭлемента].ЦветТекстаЗаголовка = Новый Цвет();
		КонецЕсли;
	КонецЦикла;
	
	Если РеквизитыКДобавлению.Количество() > 0 ИЛИ РеквизитыКУдалению.Количество() > 0 Тогда
		УстановитьУсловноеОформлениеДнейДолгосрочныйПериодов();
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ДополнитьКолонкиДолгосрочногоПланирования()
	
	ОписаниеЧисла = ОбщегоНазначенияУТ.ОписаниеТипаДенежногоПоля();
	ПутьРеквизитов = "Объект.ДеревоПлатежей";
	
	РеквизитыДерева = ПолучитьРеквизиты(ПутьРеквизитов);
	ПодчиненныхЭлементов = РеквизитыДерева.Количество();
	ВсегоКолонокДней = 0;
	
	Для Каждого РеквизитДерева Из РеквизитыДерева Цикл
		Если СтрНайти(РеквизитДерева.Имя, "День") > 0 Тогда
			ВсегоКолонокДней = ВсегоКолонокДней + 1;
		КонецЕсли; 
	КонецЦикла;
	
	ВсегоКолонокДолгосрочныхПериодов = (ПодчиненныхЭлементов - ЭлементовДереваБезДобавленныхДней - ВсегоКолонокДней) / 7;
	
	РеквизитыКДобавлению = Новый Массив;
	ЭлементыКДобавлению = Новый Массив; // Массив из ПолеФормы
	РеквизитыКУдалению = Новый Массив;
	
	Поля = Новый Соответствие;
	Поля.Вставить("ВВалюте", ОписаниеЧисла);
	Поля.Вставить("ВОднойВалюте", ОписаниеЧисла);
	Поля.Вставить("ОшибкаКритическийОстаток", Новый ОписаниеТипов("Булево"));
	Поля.Вставить("ЕстьОшибкаНеСозданаЗаявка", Новый ОписаниеТипов("Булево"));
	Поля.Вставить("ЕстьИсходнаяДатаПлатежаМеньшеПеренесенной", Новый ОписаниеТипов("Булево"));
	Поля.Вставить("ЕстьОтличиеВалютПлатежаОтСчетаКассы", Новый ОписаниеТипов("Булево"));
	
	Пока ВсегоКолонокДолгосрочныхПериодов > Объект.ПериодовДолгосрочногоПланирования Цикл
		НомерПериода = ВсегоКолонокДолгосрочныхПериодов;
		ПутьУдаляемогоРеквизита = ПутьРеквизитов + ".ДолгосрочныйПериод" + Строка(НомерПериода);
		РеквизитыКУдалению.Добавить(ПутьУдаляемогоРеквизита);
		
		Для Каждого Поле Из Поля Цикл
			РеквизитыКУдалению.Добавить(ПутьУдаляемогоРеквизита + Поле.Ключ);
		КонецЦикла;
		ВсегоКолонокДолгосрочныхПериодов = НомерПериода - 1;
	КонецЦикла;
	
	Для Инд = ВсегоКолонокДолгосрочныхПериодов + 1 По Объект.ПериодовДолгосрочногоПланирования Цикл
		
		ИмяРеквизита = "ДолгосрочныйПериод" + Инд;
		
		РеквизитДерева = Новый РеквизитФормы(ИмяРеквизита, ОписаниеЧисла, ПутьРеквизитов);
		РеквизитыКДобавлению.Добавить(РеквизитДерева);
		ЭлементыКДобавлению.Добавить(РеквизитДерева);
		
		Для Каждого Поле Из Поля Цикл
			РеквизитДерева = Новый РеквизитФормы(ИмяРеквизита + Поле.Ключ, Поле.Значение, ПутьРеквизитов);
			РеквизитыКДобавлению.Добавить(РеквизитДерева);
		КонецЦикла;
	КонецЦикла;
	
	ИзменитьРеквизиты(РеквизитыКДобавлению, РеквизитыКУдалению);
	
	Для Каждого ЭлементКДобавлению Из ЭлементыКДобавлению Цикл
		НовыйЭлемент = Элементы.Вставить("ДеревоПлатежей" + ЭлементКДобавлению.Имя, Тип("ПолеФормы"), 
			Элементы.ДеревоПлатежей, Элементы.ДеревоПлатежейРастяжка);
		НовыйЭлемент.Вид = ВидПоляФормы.ПолеНадписи;
		НовыйЭлемент.ПутьКДанным = ПутьРеквизитов + "." + ЭлементКДобавлению.Имя;
		НовыйЭлемент.Ширина = 12;
		НовыйЭлемент.РастягиватьПоГоризонтали = Ложь;
		НовыйЭлемент.ГоризонтальноеПоложение = ГоризонтальноеПоложениеЭлемента.Право;
	КонецЦикла;
	
	ДатаНачалаПериода = РаботаСПериодамиКлиентСервер.ДатаКонцаПериода(Объект.ДатаОкончанияПланированияПоДням,
		Объект.ПериодичностьДолгосрочногоПланирования) + 86400;
	ДатаНачалаПериода = ПланированиеКлиентСерверПовтИсп.РассчитатьДатуНачалаПериода(ДатаНачалаПериода,
		Объект.ПериодичностьДолгосрочногоПланирования);
	ДатаОкончанияПериода = ПланированиеКлиентСерверПовтИсп.РассчитатьДатуОкончанияПериода(ДатаНачалаПериода, 
		Объект.ПериодичностьДолгосрочногоПланирования);
	ДолгосрочныеПериоды.Очистить();
	
	Для Инд = 1 По Объект.ПериодовДолгосрочногоПланирования Цикл
		ИмяЭлемента = "ДеревоПлатежей" + "ДолгосрочныйПериод" + Инд;
		НоваяСтр = ДолгосрочныеПериоды.Добавить();
		НоваяСтр.Номер = Инд;
		НоваяСтр.ИмяПоля = ИмяЭлемента;
		НоваяСтр.ДатаНачала = ДатаНачалаПериода;
		НоваяСтр.ДатаОкончания = ДатаОкончанияПериода;
		
		ЗаголовокПериода = ПланированиеКлиентСервер.СформироватьЗаголовокПериода(Объект.ПериодичностьДолгосрочногоПланирования, 
			ДатаНачалаПериода, ДатаОкончанияПериода);
		Элементы[ИмяЭлемента].Заголовок = ЗаголовокПериода;
		ДатаНачалаПериода = ПланированиеКлиентСерверПовтИсп.РассчитатьДатуНачалаПериода(ДатаОкончанияПериода+1,
			Объект.ПериодичностьДолгосрочногоПланирования);
		ДатаОкончанияПериода = ПланированиеКлиентСерверПовтИсп.РассчитатьДатуОкончанияПериода(ДатаОкончанияПериода+1, 
			Объект.ПериодичностьДолгосрочногоПланирования);
	КонецЦикла;
	
	Если РеквизитыКДобавлению.Количество() > 0 ИЛИ РеквизитыКУдалению.Количество() > 0 Тогда
		УстановитьУсловноеОформлениеДнейДолгосрочныйПериодов();
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьВыходныеДни()
	
	ВыходныеДни.Очистить();
	
	Если ЗначениеЗаполнено(ОсновнойКалендарьПредприятия) Тогда
		
		ДниПланирования = Новый Массив;
		
		Для Инд = 1 По Объект.ДнейПланирования Цикл
			ДниПланирования.Добавить(ДенежныеСредстваКлиентСервер.ДатаПлатежа(Объект.ПланироватьСДаты, Инд));
		КонецЦикла;
		
		УстановитьПривилегированныйРежим(Истина);
		ПроизводственныйКалендарь = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ОсновнойКалендарьПредприятия, "ПроизводственныйКалендарь");
		ПараметрыПолучения = КалендарныеГрафики.ПараметрыПолученияБлижайшихРабочихДат();
		ПараметрыПолучения.ПолучатьПредшествующие = Ложь;
		ПараметрыПолучения.ВызыватьИсключение = Ложь;
		ДниКалендаря = КалендарныеГрафики.БлижайшиеРабочиеДаты(ПроизводственныйКалендарь, ДниПланирования, ПараметрыПолучения);
		УстановитьПривилегированныйРежим(Ложь);
		
		Если ДниКалендаря <> Неопределено Тогда
			Для каждого ДеньКалендаря Из ДниКалендаря Цикл
				Если ДеньКалендаря.Ключ <> ДеньКалендаря.Значение Тогда
					ВыходныеДни.Добавить(ДеньКалендаря.Ключ);
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Функция ВыделенныйДень(ИмяКолонкиДерева, ПланироватьСДаты)
	
	НомерПозицииДня = Найти(ИмяКолонкиДерева, "День");
	Если НомерПозицииДня Тогда
		НомерДня = Прав(ИмяКолонкиДерева, СтрДлина(ИмяКолонкиДерева) - НомерПозицииДня - СтрДлина("День") + 1);
		Возврат ДенежныеСредстваКлиентСервер.ДатаПлатежа(ПланироватьСДаты, Число(НомерДня))
	Иначе
		Возврат Неопределено;
	КонецЕсли;
	
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Функция ВыделенныйДолгосрочныйПериод(ИмяКолонкиДерева, ДатаОкончанияПланированияПоДням,
	ПериодичностьДолгосрочногоПланирования)
	
	НомерПозицииПериода = СтрНайти(ИмяКолонкиДерева, "ДолгосрочныйПериод");
	Если НомерПозицииПериода > 0 Тогда
		НомерПериода = Прав(ИмяКолонкиДерева, СтрДлина(ИмяКолонкиДерева) - НомерПозицииПериода 
			- СтрДлина("ДолгосрочныйПериод") + 1);
		Дата = РаботаСПериодамиКлиентСервер.ДобавитьИнтервал(ДатаОкончанияПланированияПоДням, 
			ПериодичностьДолгосрочногоПланирования, НомерПериода);
		
		Возврат РаботаСПериодамиКлиентСервер.ДатаНачалаПериода(Дата, ПериодичностьДолгосрочногоПланирования);
	Иначе
		Возврат Неопределено;
	КонецЕсли;
	
КонецФункции

&НаСервере
Процедура ОтборЗаявокПриИзмененииНаСервере()
	
	Элементы.ЗаявкиКОплатеСумма.Видимость = Не ОтборЗаявок;
	Элементы.ЗаявкиКОплатеБанковскийСчетКасса.Видимость = Не ОтборЗаявок;
	
	ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(
		ЗаявкиКОплате,
		"БанковскийСчетКасса",,
		ВидСравненияКомпоновкиДанных.НеЗаполнено,,
		ОтборЗаявок);
	
	ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(ЗаявкиКОплате, "Заморожен", ЗамороженныеПлатежи);
	
КонецПроцедуры

&НаКлиенте
Процедура ЗапуститьЗаполнениеПриАктивизацииСпискаЗаявок()
	
	ОбновитьСписки();
	
КонецПроцедуры

#Область Перенос

&НаКлиенте
Процедура СдвинутьОбъектыОплаты(ИмяКоманды)
	
	ПлатежиКПереносу = ЭтотОбъект[ИмяТекущегоСпискаПомеченныеЗаписи];
	
	Если ПлатежиКПереносу.Количество() = 0 Тогда
			
		ОчиститьСообщения();
		ТекстСообщения = НСтр("ru = 'Не отмечено ни одного платежа.'");
		ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения);
		Возврат;
	КонецЕсли;
	
	Если ИмяКоманды = "Вправо" Тогда
		
		ДатаПлатежа = "+1";
		ПеренестиОбъектыОплатыКлиент(ПлатежиКПереносу, ДатаПлатежа, Null);
		
	ИначеЕсли ИмяКоманды = "ВКонец" Тогда
		
		ДатаПлатежа = ДенежныеСредстваКлиентСервер.ДатаПлатежа(Объект.ПланироватьСДаты, Объект.ДнейПланирования);
		ПеренестиОбъектыОплатыКлиент(ПлатежиКПереносу, ДатаПлатежа, Null);
		
	ИначеЕсли ИмяКоманды = "Влево" Тогда
		
		ДатаПлатежа = "-1";
		ПеренестиОбъектыОплатыКлиент(ПлатежиКПереносу, ДатаПлатежа, Null);
		
	ИначеЕсли ИмяКоманды = "ВНачало" Тогда
		
		ПеренестиОбъектыОплатыКлиент(ПлатежиКПереносу, Объект.ПланироватьСДаты, Null);
		
	ИначеЕсли ИмяКоманды = "НаДату" Тогда
		
		ОписаниеОповещения = Новый ОписаниеОповещения("СвигЗаявокНаДату", ЭтотОбъект, ПлатежиКПереносу);
		ТекстПодсказки = НСтр("ru = 'Выберите дату для переноса оплаты заявок.'");
		
		ПоказатьВводДаты(ОписаниеОповещения, Объект.ПланироватьСДаты, ТекстПодсказки, ЧастиДаты.Дата);
		
	ИначеЕсли ИмяКоманды = "НаСчет" Тогда
		
		ОписаниеОповещения = Новый ОписаниеОповещения("СвигЗаявокНаСчет", ЭтотОбъект, ПлатежиКПереносу);
		ТекстПодсказки = НСтр("ru = 'Выберите банковский счет для переноса оплаты заявок.'");
		
		СписокСчетов = Новый СписокЗначений;
		СписокСчетов.ЗагрузитьЗначения(БанковскиеСчетаКассыДоступныеДляОбъектаОплаты(ПлатежиКПереносу));
		Если СписокСчетов.Количество() Тогда
			СписокСчетов.ПоказатьВыборЭлемента(ОписаниеОповещения, ТекстПодсказки);
		Иначе
			ОчиститьСообщения();
			ТекстСообщения = НСтр("ru = 'Нет доступных счетов для распределения платежа.'");
			ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения);
		КонецЕсли;
		
	ИначеЕсли ИмяКоманды = "Разбить" Тогда
		
		Если ПлатежиКПереносу.Количество() > 1 Тогда
			
			ОчиститьСообщения();
			ТекстСообщения = НСтр("ru = 'Разбиение оплаты доступно для одного платежа.'");
			ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения);
		Иначе
			ДополнительныеПараметры = Новый Структура;
			ДополнительныеПараметры.Вставить("ЗаявкиКПереносу", ПлатежиКПереносу);
			
			ОписаниеОповещения = Новый ОписаниеОповещения("СдвигЗаявокСРазбиением", ЭтотОбъект, ДополнительныеПараметры);
			
			ТекущиеДанныеСтроки = Элементы[ИмяТекущегоСписка].ТекущиеДанные;
			
			Если ТекущиеДанныеСтроки <> Неопределено
				И ТекущиеДанныеСтроки.Свойство("БанковскийСчетКасса")
				И ТекущиеДанныеСтроки.Свойство("Сумма") Тогда
			
				ПараметрыФормы = Новый Структура;
				ПараметрыФормы.Вставить("ЗаявкиКПереносу", ПлатежиКПереносу);
				ПараметрыФормы.Вставить("БанковскийСчетКасса", ТекущиеДанныеСтроки.БанковскийСчетКасса);
				ПараметрыФормы.Вставить("Сумма", ТекущиеДанныеСтроки.Сумма);
				ПараметрыФормы.Вставить("Объект", Объект);
				
				ОткрытьФорму("Обработка.ПлатежныйКалендарь.Форма.РазбиениеОплаты", ПараметрыФормы, ЭтаФорма,,,,
					ОписаниеОповещения, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
			КонецЕсли;
		КонецЕсли;
		
	ИначеЕсли ИмяКоманды = "НеРаспределено" Тогда
		
		ДатаПлатежа = Дата("00010101");
		ПеренестиОбъектыОплатыКлиент(ПлатежиКПереносу, ДатаПлатежа, Неопределено);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура СвигЗаявокНаДату(Результат, ЗаявкиКПереносу) Экспорт
	
	Если ЗначениеЗаполнено(Результат) Тогда
		ПеренестиОбъектыОплатыКлиент(ЗаявкиКПереносу, Результат, Null);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура СвигЗаявокНаСчет(Результат, ЗаявкиКПереносу) Экспорт
	
	Если ТипЗнч(Результат) = Тип("ЭлементСпискаЗначений") И ЗначениеЗаполнено(Результат.Значение) Тогда
		ПеренестиОбъектыОплатыКлиент(ЗаявкиКПереносу, Дата("00010101"), Результат.Значение);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура СдвигЗаявокСРазбиением(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = КодВозвратаДиалога.ОК Тогда
		
		ПлатежиКПереносу = Новый СписокЗначений;
		ПлатежиКПереносу.Добавить(ДополнительныеПараметры.ЗаявкиКПереносу[0].Значение);
		
		ПеренестиОбъектыОплатыКлиент(ПлатежиКПереносу, ДополнительныеПараметры.Дата,
			ДополнительныеПараметры.БанковскийСчетКасса, , Истина, ДополнительныеПараметры.Сумма);
	КонецЕсли;
	
КонецПроцедуры

// Возвращает таблицу отмеченных флажками записей в текущем динамическом списке
//
// Параметры:
//  ТаблицаПлатежей - ДинамическийСписок - Таблица, в которой нужно получить отмеченные записи.
//  ПомеченныеЗаписи - СписокЗначений из Строка - Список, в который будут помещены идентификаторы отмеченных записей.
//  ЭтоСписание - Булево - Признак того, что нужно получить только списания
//  ЭтоЗаявка - Булево - Признак того, что нужно получить тольо заявки на расходование ДС
//
// Возвращаемое значение:
//  ТаблицаЗначений - Таблица отмеченных флажками записей:
//		* ОбъектОплаты - ОпределяемыйТип.ОбъектОплаты - Измерение РС ГрафикПлатежей.
//		* БанковскийСчетКасса - СправочникСсылка.БанковскиеСчетаОрганизаций, СправочникСсылка.Кассы - Измерение РС ГрафикПлатежей.
//		* ДатаПлатежа - Дата - Измерение РС ГрафикПлатежей.
//		* ПлательщикПолучатель - СправочникСсылка.Организации, СправочникСсылка.Контрагенты, СправочникСсылка.ФизическиеЛица - Измерение РС ГрафикПлатежей.
//		* Организация - СправочникСсылка.Организации - Измерение РС ГрафикПлатежей.
//		* ТипСуммы - ПеречислениеСсылка.ТипыСуммГрафикаКредитовИДепозитов, ПеречислениеСсылка.ВидыПереводовДенежныхСредств, ПеречислениеСсылка.ТипыПлатежейПоАренде - Измерение РС ГрафикПлатежей.
//		* ПоступлениеСписание - ПеречислениеСсылка.ТипыДвиженияДенежныхСредств - Измерение РС ГрафикПлатежей.
//		* Валюта - СправочникСсылка.Валюты - Измерение РС ГрафикПлатежей.
//		* Сумма - ОпределяемыйТип.ДенежнаяСуммаНеотрицательная - Ресурс РС ГрафикПлатежей.
//		* Идентификатор - Строка - Реквизит РС ГрафикПлатежей.
//		* Статус - ПеречислениеСсылка.СтатусыЗаявокНаРасходованиеДенежныхСредств - Реквизит РС ГрафикПлатежей.
//		* ИсходныйБанковскийСчетКасса - СправочникСсылка.БанковскиеСчетаОрганизаций, СправочникСсылка.Кассы - Реквизит РС ГрафикПлатежей.
//		* ИсходнаяДатаПлатежа - Дата - Реквизит РС ГрафикПлатежей.
//		* ИсходнаяСумма - ОпределяемыйТип.ДенежнаяСуммаНеотрицательная - Реквизит РС ГрафикПлатежей.
//		* ЖелательнаяДатаПлатежа - Дата - Реквизит ДокументаСсылка.ЗаявкаНаРасходованиеДенежныхСредств, ДокументаСсылка.ЗаявкаНаКомандировку.
//
&НаСервереБезКонтекста
Функция ПомеченныеЗаписи(ТаблицаПлатежей, ПомеченныеЗаписи, ЭтоСписание = Ложь, ЭтоЗаявка = Ложь)
	
	Компановка = КомпановкаТекущегоСписка(ТаблицаПлатежей);
	СКД = Компановка.СКД;
	Настройки = Компановка.Настройки;
	
	ДетальныеЗаписи = Настройки.Структура.Добавить(Тип("ГруппировкаКомпоновкиДанных"));
	ФинансоваяОтчетностьСервер.НовоеПолеВыбора(ДетальныеЗаписи, "ОбъектОплаты");
	ФинансоваяОтчетностьСервер.НовоеПолеВыбора(ДетальныеЗаписи, "БанковскийСчетКасса");
	ФинансоваяОтчетностьСервер.НовоеПолеВыбора(ДетальныеЗаписи, "ДатаПлатежа");
	ФинансоваяОтчетностьСервер.НовоеПолеВыбора(ДетальныеЗаписи, "ПлательщикПолучатель");
	ФинансоваяОтчетностьСервер.НовоеПолеВыбора(ДетальныеЗаписи, "Организация");
	ФинансоваяОтчетностьСервер.НовоеПолеВыбора(ДетальныеЗаписи, "ТипСуммы");
	ФинансоваяОтчетностьСервер.НовоеПолеВыбора(ДетальныеЗаписи, "ПоступлениеСписание");
	ФинансоваяОтчетностьСервер.НовоеПолеВыбора(ДетальныеЗаписи, "Валюта");
	ФинансоваяОтчетностьСервер.НовоеПолеВыбора(ДетальныеЗаписи, "Сумма");
	ФинансоваяОтчетностьСервер.НовоеПолеВыбора(ДетальныеЗаписи, "Идентификатор");
	ФинансоваяОтчетностьСервер.НовоеПолеВыбора(ДетальныеЗаписи, "Статус");
	ФинансоваяОтчетностьСервер.НовоеПолеВыбора(ДетальныеЗаписи, "ИсходныйБанковскийСчетКасса");
	ФинансоваяОтчетностьСервер.НовоеПолеВыбора(ДетальныеЗаписи, "ИсходнаяДатаПлатежа");
	ФинансоваяОтчетностьСервер.НовоеПолеВыбора(ДетальныеЗаписи, "ИсходнаяСумма");
	ФинансоваяОтчетностьСервер.НовоеПолеВыбора(ДетальныеЗаписи, "ЖелательнаяДатаПлатежа");
	
	ФинансоваяОтчетностьСервер.УстановитьОтбор(Настройки.Отбор, "Идентификатор", ПомеченныеЗаписи);
		
	Если ЭтоСписание Тогда
		ФинансоваяОтчетностьСервер.УстановитьОтбор(Настройки.Отбор, "ЭтоСписание", Истина);
	КонецЕсли;
	
	Если ЭтоЗаявка Тогда
		ФинансоваяОтчетностьСервер.УстановитьОтбор(Настройки.Отбор, "ЭтоЗаявка", Истина);
	КонецЕсли;
	
	Возврат ФинансоваяОтчетностьСервер.ВыгрузитьРезультатСКД(СКД, Настройки);
	
КонецФункции

&НаСервереБезКонтекста
Процедура ПолучитьСтрокиОстаткиПоСчетамКассам(ОстаткиПоСчетамКассам, СтрокаДерева)
	
	Если ЗначениеЗаполнено(СтрокаДерева.БанковскийСчетКасса) И НЕ ЗначениеЗаполнено(СтрокаДерева.ПоступлениеСписание) Тогда
		НоваяСтрока = ОстаткиПоСчетамКассам.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаДерева);
	КонецЕсли;
	
	Строки = СтрокаДерева.ПолучитьЭлементы();
	
	Для каждого СтрокаДереваДочерняя Из Строки Цикл
		ПолучитьСтрокиОстаткиПоСчетамКассам(ОстаткиПоСчетамКассам, СтрокаДереваДочерняя);
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти

#Область Перетаскивание

&НаКлиенте
Процедура ПомеченныеЗаписиНачалоПеретаскивания(Элемент, ПараметрыПеретаскивания, Выполнение)
	
	ПлатежиКПеретаскиванию = ЭтотОбъект[ИмяТекущегоСпискаПомеченныеЗаписи];
	
	Если ПлатежиКПеретаскиванию.Количество() = 0 Тогда
		Выполнение = Ложь;
	Иначе
		ПараметрыПеретаскивания.Значение = ПлатежиКПеретаскиванию;
	КонецЕсли;
	
	ДоступныеСчетаКассы = БанковскиеСчетаКассыДоступныеДляОбъектаОплаты(ПлатежиКПеретаскиванию);
	ДоступныеСчетаКассы.Добавить(Неопределено);
	Для Каждого СтрокаДерева Из Объект.ДеревоПлатежей.ПолучитьЭлементы() Цикл
		ИзменитьФлагДоступностиСчетов(СтрокаДерева, ДоступныеСчетаКассы);
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура ИзменитьФлагДоступностиСчетов(СтрокаДерева, ДоступныеСчетаКассы)
	
	СтрокаДерева.ДоступноДляПереноса = (ДоступныеСчетаКассы.Найти(СтрокаДерева.БанковскийСчетКасса) <> Неопределено);
	
	Для Каждого СтрокаДерева Из СтрокаДерева.ПолучитьЭлементы() Цикл
		ИзменитьФлагДоступностиСчетов(СтрокаДерева, ДоступныеСчетаКассы);
	КонецЦикла;
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Функция НомерДня(ИмяПоля)
	
	НомерДня = 0;
	
	ПозДня = СтрНайти(ИмяПоля, "День");
	Если ПозДня Тогда
		НомерДня = Число(Прав(ИмяПоля, СтрДлина(ИмяПоля) - СтрДлина("День") - ПозДня + 1));
	КонецЕсли;
	
	Возврат НомерДня;
	
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Функция НомерДолгосрочногоПериода(ИмяПоля)
	
	НомерПериода = 0;
	
	ПозПериода = СтрНайти(ИмяПоля, "ДолгосрочныйПериод");
	Если ПозПериода > 0 Тогда
		НомерПериода = Число(Прав(ИмяПоля, СтрДлина(ИмяПоля) - СтрДлина("ДолгосрочныйПериод") - ПозПериода + 1));
	КонецЕсли;
	
	Возврат НомерПериода;
	
КонецФункции

// Выполняет операции измененения платежа.
// 
// Параметры:
//  ОбъектыОплатыКПереносу - СписокЗначений из Строка.
//  ДатаПлатежа - Дата, Строка.
//  БанковскийСчетКасса - СправочникСсылка.БанковскиеСчетаОрганизаций, СправочникСсылка.Кассы - .
//  ФлагЗакрыть - Булево - Признак выполнения команды "Закрыть".
//  ЭтоРазбиение - Булево - Признак выполнения команды "Разбить оплату".
//  СуммаРазбиения - Число - Сумма команды "Разбить оплату".
//
&НаКлиенте
Процедура ПеренестиОбъектыОплатыКлиент(ОбъектыОплатыКПереносу, ДатаПлатежа, БанковскийСчетКасса, ФлагЗакрыть = Ложь,
	ЭтоРазбиение = Ложь, СуммаРазбиения = 0)
	
	ДлительнаяОперация = ПеренестиОбъектыОплатыСервер(ОбъектыОплатыКПереносу, ДатаПлатежа, БанковскийСчетКасса,
		ФлагЗакрыть, ЭтоРазбиение, СуммаРазбиения);
	ПараметрыОжидания = ДлительныеОперацииКлиент.ПараметрыОжидания(ЭтотОбъект);
	ОписаниеОповещения = Новый ОписаниеОповещения("ПриЗавершенииПереносаОбъектовОплаты", ЭтотОбъект, ДатаПлатежа);
	ДлительныеОперацииКлиент.ОжидатьЗавершение(ДлительнаяОперация, ОписаниеОповещения, ПараметрыОжидания);
	
КонецПроцедуры

&НаСервере
Функция ПеренестиОбъектыОплатыСервер(Знач ОбъектыОплатыКПереносу, ДатаПлатежа, БанковскийСчетКасса, ФлагЗакрыть,
	ЭтоРазбиение, СуммаРазбиения)
		
	Если ФлагЗакрыть Тогда
		
		ПомеченныеЗаписи = ПомеченныеЗаписи(Элементы[ИмяТекущегоСписка], ОбъектыОплатыКПереносу, , Истина);
		
		Если ПомеченныеЗаписи.Количество() = 0 Тогда
			Возврат ОписатьРезультатОшибкиДлительнойОперации(
				НСтр("ru = 'Не отмечено ни одной заявки на расходование денежных средств.'"));
		КонецЕсли;
	Иначе
		ПомеченныеЗаписи = ПомеченныеЗаписи(Элементы[ИмяТекущегоСписка], ОбъектыОплатыКПереносу);
	КонецЕсли;
	
	ДанныеПереноса = Новый Соответствие;
	ПодготовитьДанныеПереносаОбъектовОплаты(ДанныеПереноса, ПомеченныеЗаписи, ДатаПлатежа, БанковскийСчетКасса,
		ФлагЗакрыть, ЭтоРазбиение, СуммаРазбиения);
	
	Если Не ДанныеПереноса.Количество() Тогда
		Возврат ОписатьРезультатОшибкиДлительнойОперации(НСтр("ru = 'Не удалось обработать плановые платежи.'"));
	КонецЕсли;
	
	НаименованиеЗадания = НСтр("ru = 'Перенос объектов оплаты'");
	ВыполняемыйМетод = "Обработки.ПлатежныйКалендарь.ПеренестиОбъектыОплаты";
	
	СтруктураПараметров = Новый Структура;
	СтруктураПараметров.Вставить("ДанныеПереноса", ДанныеПереноса);
	СтруктураПараметров.Вставить("ПланироватьСДаты", Объект.ПланироватьСДаты);
	
	ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияВФоне(УникальныйИдентификатор);
	ПараметрыВыполнения.НаименованиеФоновогоЗадания = НаименованиеЗадания;
	Если ДанныеПереноса.Количество() = 1 Тогда
		ПараметрыВыполнения.ЗапуститьНеВФоне = Истина;
	КонецЕсли;
	
	Возврат ДлительныеОперации.ВыполнитьВФоне(ВыполняемыйМетод, СтруктураПараметров, ПараметрыВыполнения);
	
КонецФункции

&НаКлиенте
Процедура ПриЗавершенииПереносаОбъектовОплаты(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если Результат.Статус = "Ошибка" Тогда
		ОчиститьСообщения();
		ОбщегоНазначенияКлиент.СообщитьПользователю(Результат.КраткоеПредставлениеОшибки);
		Возврат;
	КонецЕсли;
	
	ПриЗавершенииПереносаОбъектовОплатыНаСервере(Результат.АдресРезультата, ДополнительныеПараметры);
	УправлениеЭлементамиИстории();
	
КонецПроцедуры

&НаСервере
Процедура ПриЗавершенииПереносаОбъектовОплатыНаСервере(АдресРезультата, ДополнительныеПараметры)
	
	ПеренесенныеЗаявки = ПолучитьИзВременногоХранилища(АдресРезультата);
	Если ПеренесенныеЗаявки.Количество() Тогда
		ОтразитьРезультатПереносаВДеревеПлатежей(ПеренесенныеЗаявки);
		Если ДополнительныеПараметры <> Дата("00010101") Тогда
			ЗаписатьИсториюИзменений(ПеренесенныеЗаявки);
		КонецЕсли;
		ТекущийСписокФормы = Элементы[ИмяТекущегоСписка]; // ТаблицаФормы
		ТекущийСписокФормы.Обновить();
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция ОтменитьПовторитьОперациюНаСервере(Изменения)
	
	НаименованиеЗадания = НСтр("ru = 'Перенос объектов оплаты'");
	ВыполняемыйМетод = "Обработки.ПлатежныйКалендарь.ПеренестиОбъектыОплаты";
	
	СтруктураПараметров = Новый Структура;
	СтруктураПараметров.Вставить("ДанныеПереноса", Изменения);
	СтруктураПараметров.Вставить("ПланироватьСДаты", Объект.ПланироватьСДаты);
	
	ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияВФоне(УникальныйИдентификатор);
	ПараметрыВыполнения.НаименованиеФоновогоЗадания = НаименованиеЗадания;
	Если Изменения.Количество() = 1 Тогда
		ПараметрыВыполнения.ЗапуститьНеВФоне = Истина;
	КонецЕсли;
	
	Возврат ДлительныеОперации.ВыполнитьВФоне(ВыполняемыйМетод, СтруктураПараметров, ПараметрыВыполнения);
	
КонецФункции

&НаКлиенте
Процедура ПриЗавершенииОтменыПовтораОперации(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если Результат.Статус = "Ошибка" Тогда
		Возврат;
	КонецЕсли;
	
	ПриЗавершенииОтменыПовтораОперацииНаСервере(Результат.АдресРезультата);
	УправлениеЭлементамиИстории();
	
КонецПроцедуры

&НаСервере
Процедура ПриЗавершенииОтменыПовтораОперацииНаСервере(АдресРезультата)
	
	ПеренесенныеЗаявки = ПолучитьИзВременногоХранилища(АдресРезультата);
	ОтразитьРезультатПереносаВДеревеПлатежей(ПеренесенныеЗаявки);
	ТекущийСписокФормы = Элементы[ИмяТекущегоСписка]; // ТаблицаФормы
	ТекущийСписокФормы.Обновить();
	
КонецПроцедуры

&НаСервереБезКонтекста
Процедура ПодготовитьДанныеПереносаОбъектовОплаты(ДанныеПереноса, ОбъектыОплатыКПереносу, ДатаПлатежа, БанковскийСчетКасса,
	ФлагЗакрыть, ЭтоРазбиение, СуммаРазбиения)
	
	Для Каждого ОбъектКПереносу Из ОбъектыОплатыКПереносу Цикл
		
		СтруктураПереноса = Обработки.ПлатежныйКалендарь.СтруктураПереноса();
			
		ЗаполнитьЗначенияСвойств(СтруктураПереноса, ОбъектКПереносу);
		
		Если Не СуммаРазбиения = 0 Тогда
			СтруктураПереноса.СуммаПереноса = СуммаРазбиения;
		ИначеЕсли ОбъектКПереносу.Сумма < 0 Тогда
			СтруктураПереноса.СуммаПереноса = -ОбъектКПереносу.Сумма;
		Иначе
			СтруктураПереноса.СуммаПереноса = ОбъектКПереносу.Сумма;
		КонецЕсли;
		СтруктураПереноса.ЭтоРазбиение = ЭтоРазбиение;
		ОбъектОплаты = ?(ТипЗнч(ОбъектКПереносу.ОбъектОплаты) = Тип("ДокументСсылка.ЗаявкаНаРасходованиеДенежныхСредств"),
			ОбъектКПереносу.ОбъектОплаты, ОбъектКПереносу.Идентификатор);
		
		Если ЗначениеЗаполнено(СтруктураПереноса.БанковскийСчетКасса) Тогда
			СтруктураПереноса.ВалютаПереноса =
				ОбщегоНазначения.ЗначениеРеквизитаОбъекта(СтруктураПереноса.БанковскийСчетКасса, "ВалютаДенежныхСредств");
		Иначе
			СтруктураПереноса.ВалютаПереноса = СтруктураПереноса.Валюта;
		КонецЕсли;
		
		ДанныеПереносаОбъектаОплаты = ДанныеПереноса.Получить(ОбъектОплаты);
		Если ДанныеПереносаОбъектаОплаты = Неопределено Тогда
			ДанныеПереносаОбъектаОплаты = Новый Массив;
		КонецЕсли;
		
		СтруктураПереноса.Коэффициент = 1;
		ДанныеПереносаОбъектаОплаты.Добавить(СтруктураПереноса);
		
		Если ФлагЗакрыть Тогда
			СтруктураПереноса.ФлагЗакрыть = Истина;
		Иначе
			СтруктураПереноса.ФлагЗакрыть = Ложь;
			СтруктураПереносаКон = Обработки.ПлатежныйКалендарь.СтруктураПереноса();
			ЗаполнитьЗначенияСвойств(СтруктураПереносаКон, СтруктураПереноса);
			СтруктураПереносаКон.Коэффициент = -1;
			
			Если ДатаПлатежа = "+1" Тогда
				СтруктураПереносаКон.ДатаПлатежа = ДенежныеСредстваКлиентСервер.ДатаПлатежа(СтруктураПереноса.ДатаПлатежа, 2);
			ИначеЕсли ДатаПлатежа = "-1" Тогда
				СтруктураПереносаКон.ДатаПлатежа = ДенежныеСредстваКлиентСервер.ДатаПлатежа(СтруктураПереноса.ДатаПлатежа, 0);
			Иначе
				Если ЗначениеЗаполнено(ДатаПлатежа) Тогда
					СтруктураПереносаКон.ДатаПлатежа = ДатаПлатежа;
				Иначе
					СтруктураПереносаКон.ДатаПлатежа =
						?(ТипЗнч(ОбъектОплаты) = Тип("ДокументСсылка.ЗаявкаНаРасходованиеДенежныхСредств"),
							ОбъектКПереносу.ДатаПлатежа, ДатаПлатежа);
				КонецЕсли;
				Если БанковскийСчетКасса <> Null Тогда
					СтруктураПереносаКон.БанковскийСчетКасса = БанковскийСчетКасса;
				КонецЕсли;
			КонецЕсли;
			
			Если ЗначениеЗаполнено(СтруктураПереносаКон.БанковскийСчетКасса) Тогда
				СтруктураПереносаКон.ВалютаПереноса =
					ОбщегоНазначения.ЗначениеРеквизитаОбъекта(СтруктураПереносаКон.БанковскийСчетКасса, "ВалютаДенежныхСредств");
			Иначе
				СтруктураПереносаКон.ВалютаПереноса = СтруктураПереносаКон.Валюта;
			КонецЕсли;
			
			ДанныеПереносаОбъектаОплаты.Добавить(СтруктураПереносаКон);
		КонецЕсли;
		
		ДанныеПереноса.Вставить(ОбъектОплаты, ДанныеПереносаОбъектаОплаты);
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Функция РаспределитьНаСервере(ПомеченныеЗаписи)
	
	ОбъектыОплатыКРаспределению = ПомеченныеЗаписи(Элементы[ИмяТекущегоСписка], ПомеченныеЗаписи, Истина);
	
	Если ОбъектыОплатыКРаспределению.Количество() = 0 Тогда
		Возврат ОписатьРезультатОшибкиДлительнойОперации(НСтр("ru = 'Не отмечено ни одного списания.'"));
	КонецЕсли;
	
	ОстаткиПоСчетамКассам = Новый ТаблицаЗначений;
	ОстаткиПоСчетамКассам.Колонки.Добавить("БанковскийСчетКасса");
	ОстаткиПоСчетамКассам.Колонки.Добавить("Валюта");
	Для Инд = 1 По Объект.ДнейПланирования Цикл
		ОстаткиПоСчетамКассам.Колонки.Добавить("День" + Инд);
	КонецЦикла;
	
	СтрокиДерева = Объект.ДеревоПлатежей.ПолучитьЭлементы();
	Для Каждого СтрокаДерева Из СтрокиДерева Цикл
		ПолучитьСтрокиОстаткиПоСчетамКассам(ОстаткиПоСчетамКассам, СтрокаДерева);
	КонецЦикла;
	
	ДанныеРаспределения = Новый Соответствие;
	ПодготовитьДанныеРаспределенияОбъектовОплаты(ДанныеРаспределения, ОбъектыОплатыКРаспределению, ОстаткиПоСчетамКассам,
		Объект.ПланироватьСДаты, Объект.ДнейПланирования);
		
	НаименованиеЗадания = НСтр("ru = 'Распределение объектов оплаты'");
	ВыполняемыйМетод = "Обработки.ПлатежныйКалендарь.ПеренестиОбъектыОплаты";
	
	СтруктураПараметров = Новый Структура;
	СтруктураПараметров.Вставить("ДанныеПереноса", ДанныеРаспределения);
	СтруктураПараметров.Вставить("ПланироватьСДаты", Объект.ПланироватьСДаты);
	
	ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияВФоне(УникальныйИдентификатор);
	ПараметрыВыполнения.НаименованиеФоновогоЗадания = НаименованиеЗадания;
	Если ДанныеРаспределения.Количество() = 1 Тогда
		ПараметрыВыполнения.ЗапуститьНеВФоне = Истина;
	КонецЕсли;
	
	Возврат ДлительныеОперации.ВыполнитьВФоне(ВыполняемыйМетод, СтруктураПараметров, ПараметрыВыполнения);
	
КонецФункции

&НаСервере
Процедура ЗаписатьИсториюИзменений(ПеренесенныеЗаявки)
	
	Если Не ПеренесенныеЗаявки.Количество() Тогда
		Возврат;
	КонецЕсли;
	
	Пока ИсторияИзменений.Количество() > ТекущийИндексИстории Цикл
		ИсторияИзменений.Удалить(ИсторияИзменений.Количество() - 1);
	КонецЦикла;
	
	ИсторияИзменений.Добавить(ПеренесенныеЗаявки);
	ТекущийИндексИстории = ТекущийИндексИстории + 1;
	Если ИсторияИзменений.Количество() > 100 Тогда
		ИсторияИзменений.Удалить(0);
		ТекущийИндексИстории = ТекущийИндексИстории - 1;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ОтразитьРезультатПереносаВДеревеПлатежей(ПеренесенныеЗаявки)
	
	ОбновитьКалендарь = Ложь;
	СтрокиДерева = Объект.ДеревоПлатежей.ПолучитьЭлементы();
	Для каждого ОбъектОплаты Из ПеренесенныеЗаявки Цикл
		Для каждого СтруктураПереноса Из ОбъектОплаты.Значение Цикл
			НайденаСтрокаОборот = Ложь;
			Для каждого СтрокаДерева Из СтрокиДерева Цикл
				РассчитатьПереносВСтрокахДерева(СтрокаДерева, СтруктураПереноса, НайденаСтрокаОборот);
			КонецЦикла;
			Если Не НайденаСтрокаОборот Тогда
				Если ЗначениеЗаполнено(СтруктураПереноса.БанковскийСчетКасса) Тогда
					СоздатьСтрокуСписания(СтруктураПереноса);
				Иначе
					ОбновитьКалендарь = Истина;
				КонецЕсли;
			КонецЕсли;
		КонецЦикла;
	КонецЦикла;
	
	Если ПеренесенныеЗаявки.Количество() Тогда
		Для каждого СтрокаДерева Из СтрокиДерева Цикл
			ДенежныеСредстваКлиентСервер.ПересчитатьПодчиненныеСтрокиДерева(СтрокаДерева, Объект.ДнейПланирования);
			Обработки.ПлатежныйКалендарь.ПересчитатьДолгосрочныеПериодыВПодчиненныхСтрокахДерева(СтрокаДерева,
				Объект.ПериодовДолгосрочногоПланирования, Объект.ДнейПланирования);
		КонецЦикла;
	КонецЕсли;
	
	Если ОбновитьКалендарь Тогда
		ОбновитьСпискиНаСервере();
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура РассчитатьПереносВСтрокахДерева(СтрокаДерева, СтруктураПереноса, НайденаСтрокаОборот = Истина)

	Если СтруктураПереноса.ДатаПлатежа > Объект.ДатаОкончания Тогда
		Возврат;
	КонецЕсли;
	
	ЭтоКолонкаДолгосрочныйПериод = Ложь;
	Если СтруктураПереноса.ДатаПлатежа > Объект.ДатаОкончанияПланированияПоДням Тогда
		СтрокаДолгосрочныйПериод = ДолгосрочныйПериодПоДатеПлатежа(СтруктураПереноса.ДатаПлатежа, ДолгосрочныеПериоды);
		ЭтоКолонкаДолгосрочныйПериод = (СтрокаДолгосрочныйПериод <> Неопределено);
	КонецЕсли;
	
	Если ЭтоКолонкаДолгосрочныйПериод Тогда
		ДеньПлатежа = Неопределено;
		ИмяКолонки = "ДолгосрочныйПериод" + СтрокаДолгосрочныйПериод.Номер;
	Иначе
		ДеньПлатежа = ДенежныеСредстваКлиентСервер.ДеньПлатежа(Объект.ПланироватьСДаты, СтруктураПереноса.ДатаПлатежа);
		ИмяКолонки = "День" + ДеньПлатежа;
	КонецЕсли;
	
	ТипСписание = Перечисления.ТипыДвиженияДенежныхСредств.Списание;
	Обрабатывать = Ложь;
	КоэффициентКонвертации = 1;
	
	// Обороты в валюте
	Если СтрокаДерева.ВидСтроки = 1
		И СтрокаДерева.ПоступлениеСписание = ТипСписание Тогда
		
		Если ТипЗнч(СтрокаДерева.Группировка) = Тип("Строка")
			И СтрокаДерева.СтрокаНераспределено Тогда
			
			Обрабатывать = (СтрокаДерева.БанковскийСчетКасса = СтруктураПереноса.БанковскийСчетКасса)
				И (СтрокаДерева.Валюта = СтруктураПереноса.Валюта);
			
		ИначеЕсли ЗначениеЗаполнено(СтрокаДерева.БанковскийСчетКасса) Тогда
			Обрабатывать = (СтрокаДерева.БанковскийСчетКасса = СтруктураПереноса.БанковскийСчетКасса);
		Иначе
			Обрабатывать = (СтрокаДерева.Валюта = СтруктураПереноса.ВалютаПереноса);
		КонецЕсли;
		
		Если Обрабатывать Тогда
			Если ЗначениеЗаполнено(СтрокаДерева.Валюта) И СтрокаДерева.Валюта <> СтруктураПереноса.Валюта Тогда
				КоэффициентКонвертации = ДенежныеСредстваПовтИсп.КоэффициентКонвертации(
					СтруктураПереноса.Валюта, СтрокаДерева.Валюта, Объект.ПланироватьСДаты);
			КонецЕсли;
			СуммаПереноса = Окр(СтруктураПереноса.СуммаПереноса * СтруктураПереноса.Коэффициент * КоэффициентКонвертации, 2);
			
			СтрокаДерева[ИмяКолонки + "ВВалюте"] = СтрокаДерева[ИмяКолонки + "ВВалюте"] + СуммаПереноса;
			СтрокаДерева.Сумма = СтрокаДерева.Сумма + СуммаПереноса;
			
			Если ДеньПлатежа = 0 Тогда
				СтрокаДерева.Просрочено = СтрокаДерева.Просрочено + СуммаПереноса;
			КонецЕсли;
			
			Если ЗначениеЗаполнено(СтруктураПереноса.БанковскийСчетКасса) Тогда
				НайденаСтрокаОборот = НайденаСтрокаОборот Или ЗначениеЗаполнено(СтрокаДерева.БанковскийСчетКасса);
			Иначе
				НайденаСтрокаОборот = НайденаСтрокаОборот Или (ТипЗнч(СтрокаДерева.Группировка) = Тип("Строка"));
			КонецЕсли;
		КонецЕсли;
		
	// Обороты в одной валюте
	ИначеЕсли СтрокаДерева.ВидСтроки = 3
		И СтрокаДерева.ПоступлениеСписание = ТипСписание Тогда
		
		Если ЗначениеЗаполнено(СтруктураПереноса.БанковскийСчетКасса)
			И ТипЗнч(СтрокаДерева.Группировка) = Тип("Строка")
			И СтрокаДерева.СтрокаНераспределено Тогда
			Обрабатывать = Ложь;
		Иначе
			Обрабатывать = Истина;
		КонецЕсли;
		
		Если Обрабатывать Тогда
			Если Объект.ВалютаИтогов <> СтруктураПереноса.Валюта Тогда
				КоэффициентКонвертации = ДенежныеСредстваПовтИсп.КоэффициентКонвертации(
					СтруктураПереноса.Валюта, Объект.ВалютаИтогов, Объект.ПланироватьСДаты);
			КонецЕсли;
			СуммаПереноса = Окр(СтруктураПереноса.СуммаПереноса * СтруктураПереноса.Коэффициент * КоэффициентКонвертации, 2);
			
			СтрокаДерева[ИмяКолонки + "ВОднойВалюте"] = СтрокаДерева[ИмяКолонки + "ВОднойВалюте"] + СуммаПереноса;
			СтрокаДерева.Сумма = СтрокаДерева.Сумма + СуммаПереноса;
			
			Если ДеньПлатежа = 0 Тогда
				СтрокаДерева.ПросроченоВОднойВалюте = СтрокаДерева.ПросроченоВОднойВалюте + СуммаПереноса;
			КонецЕсли;
		КонецЕсли;
			
	// Остатки в валюте
	ИначеЕсли СтрокаДерева.ВидСтроки = 0 Тогда
		
		Если ЗначениеЗаполнено(СтрокаДерева.БанковскийСчетКасса) Тогда
			Обрабатывать = (СтрокаДерева.БанковскийСчетКасса = СтруктураПереноса.БанковскийСчетКасса);
		Иначе
			Обрабатывать = (СтрокаДерева.Валюта = СтруктураПереноса.ВалютаПереноса);
		КонецЕсли;
		
		Если Обрабатывать Тогда
			Если ЗначениеЗаполнено(СтрокаДерева.Валюта) И СтрокаДерева.Валюта <> СтруктураПереноса.Валюта Тогда
				КоэффициентКонвертации = ДенежныеСредстваПовтИсп.КоэффициентКонвертации(
					СтруктураПереноса.Валюта, СтрокаДерева.Валюта, Объект.ПланироватьСДаты);
			КонецЕсли;
			СуммаПереноса = Окр(СтруктураПереноса.СуммаПереноса * СтруктураПереноса.Коэффициент * КоэффициентКонвертации, 2);
			
			СтрокаДерева[ИмяКолонки + "ВВалюте"] = СтрокаДерева[ИмяКолонки + "ВВалюте"] + СуммаПереноса;
			СтрокаДерева.Сумма = СтрокаДерева.Сумма + СуммаПереноса;
			
			Если ДеньПлатежа = 0 Тогда
				СтрокаДерева.Просрочено = СтрокаДерева.Просрочено + СуммаПереноса;
			КонецЕсли;
		КонецЕсли;
		
	// Остатки в одной валюте
	ИначеЕсли СтрокаДерева.ВидСтроки = 2 Тогда
		
		Обрабатывать = (СтрокаДерева.Валюта = СтруктураПереноса.ВалютаПереноса) Или Не ЗначениеЗаполнено(СтрокаДерева.Валюта);
		
		Если Обрабатывать Тогда
			Если Объект.ВалютаИтогов <> СтруктураПереноса.Валюта Тогда
				КоэффициентКонвертации = ДенежныеСредстваПовтИсп.КоэффициентКонвертации(
					СтруктураПереноса.Валюта, Объект.ВалютаИтогов, Объект.ПланироватьСДаты);
			КонецЕсли;
			СуммаПереноса = Окр(СтруктураПереноса.СуммаПереноса * СтруктураПереноса.Коэффициент * КоэффициентКонвертации, 2);
			
			СтрокаДерева[ИмяКолонки + "ВОднойВалюте"] = СтрокаДерева[ИмяКолонки + "ВОднойВалюте"] + СуммаПереноса;
			СтрокаДерева.Сумма = СтрокаДерева.Сумма + СуммаПереноса;
			
			Если ДеньПлатежа = 0 Тогда
				СтрокаДерева.ПросроченоВОднойВалюте = СтрокаДерева.ПросроченоВОднойВалюте + СуммаПереноса;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	Для Каждого СтрокаДерева Из СтрокаДерева.ПолучитьЭлементы() Цикл
		РассчитатьПереносВСтрокахДерева(СтрокаДерева, СтруктураПереноса, НайденаСтрокаОборот);
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура СоздатьСтрокуСписания(ДанныеСтроки)
	
	ДеньПлатежа = ДенежныеСредстваКлиентСервер.ДеньПлатежа(Объект.ПланироватьСДаты, ДанныеСтроки.ДатаПлатежа);
	
	Если ДеньПлатежа > Объект.ДнейПланирования Тогда
		Возврат;
	КонецЕсли;
	
	БанковскийСчетКасса = ДанныеСтроки.БанковскийСчетКасса;
	
	СтрокаСчета = ФинансоваяОтчетностьСервер.ПодчиненныйЭлемент(Объект.ДеревоПлатежей, "Группировка", БанковскийСчетКасса);
	Если СтрокаСчета <> Неопределено Тогда
		
		НоваяСтрока = СтрокаСчета.ПолучитьЭлементы().Добавить();
		НоваяСтрока.БанковскийСчетКасса = БанковскийСчетКасса;
		НоваяСтрока.ПоступлениеСписание = Перечисления.ТипыДвиженияДенежныхСредств.Списание;
		НоваяСтрока.Группировка         = Перечисления.ТипыДвиженияДенежныхСредств.Списание;
		НоваяСтрока.ВидСтроки           = 1;
		
		ВалютаДенежныхСредств = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(БанковскийСчетКасса, "ВалютаДенежныхСредств");
		НоваяСтрока.Валюта = ВалютаДенежныхСредств;
		
		КоэффициентКонвертации = 1;
		Если ВалютаДенежныхСредств <> ДанныеСтроки.Валюта Тогда
			КоэффициентКонвертации = ДенежныеСредстваПовтИсп.КоэффициентКонвертации(
				ДанныеСтроки.Валюта, ВалютаДенежныхСредств, Объект.ПланироватьСДаты);
		КонецЕсли;
		
		НоваяСтрока["День" + ДеньПлатежа + "ВВалюте"] = ДанныеСтроки.СуммаПереноса * ДанныеСтроки.Коэффициент * КоэффициентКонвертации;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ПодготовитьДанныеРаспределенияОбъектовОплаты(ДанныеРаспределения, ОбъектыОплатыКРаспределению,
	ОстаткиПоСчетамКассам, ПланироватьСДаты, ДнейПланирования)
	
	Заявки = Новый Массив;
	СтрокиУдалить = Новый Массив;
	
	Для Каждого Платеж Из ОбъектыОплатыКРаспределению Цикл
			
		Если ЗначениеЗаполнено(Платеж.БанковскийСчетКасса) Тогда
			
			ОбщегоНазначения.СообщитьПользователю(
				СтрШаблон(НСтр("ru = 'Не удалось распределить оплату объекта оплаты %1. %2'"),
					Платеж.ОбъектОплаты, НСтр("ru = 'Уже заполнен Банковский счет / Касса.'")));
			СтрокиУдалить.Добавить(Платеж);
			Продолжить;
		КонецЕсли;
		
		КлючРаспределения = ?(ТипЗнч(Платеж.ОбъектОплаты) = Тип("ДокументСсылка.ЗаявкаНаРасходованиеДенежныхСредств"),
			Платеж.ОбъектОплаты, Платеж.Идентификатор);
		
		ДанныеПереносаОбъектаОплаты = ДанныеРаспределения.Получить(КлючРаспределения);
		Если ДанныеПереносаОбъектаОплаты = Неопределено Тогда
			ДанныеПереносаОбъектаОплаты = Новый Массив;
		КонецЕсли;
		
		СтруктураПереноса = Обработки.ПлатежныйКалендарь.СтруктураПереноса();
		ЗаполнитьЗначенияСвойств(СтруктураПереноса, Платеж);
		СтруктураПереноса.ВалютаПереноса = Платеж.Валюта;

		СтруктураПереноса.СуммаПереноса = ?(Платеж.Сумма < 0, -Платеж.Сумма, Платеж.Сумма);
		
		СтруктураПереноса.Коэффициент = 1;
		СтруктураПереноса.ФлагЗакрыть = Ложь;
		ДанныеПереносаОбъектаОплаты.Добавить(СтруктураПереноса);
		
		ДанныеРаспределения.Вставить(КлючРаспределения, ДанныеПереносаОбъектаОплаты);
		
		Если ТипЗнч(Платеж.ОбъектОплаты) = Тип("ДокументСсылка.ЗаявкаНаРасходованиеДенежныхСредств") Тогда
			Заявки.Добавить(Платеж.ОбъектОплаты);
		КонецЕсли;
	КонецЦикла;
	
	Для Каждого СтрокаУдалить Из СтрокиУдалить Цикл
		ОбъектыОплатыКРаспределению.Удалить(СтрокаУдалить);
	КонецЦикла;
	
	ИдентификаторыПлатежей = Новый СписокЗначений;
	Для Каждого Платеж Из ОбъектыОплатыКРаспределению Цикл
		ИдентификаторыПлатежей.Добавить(Платеж.Идентификатор);
	КонецЦикла;
	
	СписокРеквизитов = "Ссылка, БанковскийСчет, Касса";
	РеквизитыЗаявок = ОбщегоНазначения.ЗначенияРеквизитовОбъектов(Заявки, СписокРеквизитов); // Соответствие
	
	ЗначенияБанковскихСчетовКасс = БанковскиеСчетаКассыДоступныеДляОбъектаОплаты(ИдентификаторыПлатежей, Ложь);
	
	Для Каждого Платеж Из ОбъектыОплатыКРаспределению Цикл
		
		ЭтоЗаявка = (ТипЗнч(Платеж.ОбъектОплаты) = Тип("ДокументСсылка.ЗаявкаНаРасходованиеДенежныхСредств"));
		
		РеквизитыЗаявки = ?(ЭтоЗаявка, РеквизитыЗаявок.Получить(Платеж.ОбъектОплаты), Неопределено);
		КлючРаспределения = ?(ЭтоЗаявка, Платеж.ОбъектОплаты, Платеж.Идентификатор);
		
		ДеньПлатежа = ДенежныеСредстваКлиентСервер.ДеньПлатежа(ПланироватьСДаты,
			Платеж.ЖелательнаяДатаПлатежа);
		Если ДеньПлатежа > (ДнейПланирования + 1) Тогда
			ОбщегоНазначения.СообщитьПользователю(
				СтрШаблон(НСтр("ru = 'Не удалось распределить оплату объекта оплаты %1. %2'"),
					Платеж.ОбъектОплаты, НСтр("ru = 'Дата платежа превышает дату окончания планирования по дням.'")));
			Продолжить;
		КонецЕсли;
		
		ДанныеРаспределенияЗаявки = ДанныеРаспределения.Получить(КлючРаспределения);
		СтруктураРаспределения = ДанныеРаспределенияЗаявки[0];
		
		ЖелательныйБанковскийСчетКасса = Неопределено;
		Если ЭтоЗаявка Тогда
			Если ЗначениеЗаполнено(РеквизитыЗаявки.БанковскийСчет) Тогда
				ЖелательныйБанковскийСчетКасса = РеквизитыЗаявки.БанковскийСчет;
			ИначеЕсли ЗначениеЗаполнено(РеквизитыЗаявки.Касса) Тогда
				ЖелательныйБанковскийСчетКасса = РеквизитыЗаявки.Касса;
			КонецЕсли;
		КонецЕсли;
		
		Если ЖелательныйБанковскийСчетКасса <> Неопределено Тогда
			НайденныеСтроки = ОстаткиПоСчетамКассам.НайтиСтроки(Новый Структура("БанковскийСчетКасса",
				ЖелательныйБанковскийСчетКасса));
			Если НайденныеСтроки.Количество() Тогда
				ПервыйСчет = ОстаткиПоСчетамКассам.Найти(НайденныеСтроки[0].БанковскийСчетКасса);
				Если ПервыйСчет <> Неопределено Тогда
					ИндексСтроки = ОстаткиПоСчетамКассам.Индекс(ПервыйСчет);
					ОстаткиПоСчетамКассам.Сдвинуть(ИндексСтроки, -ИндексСтроки);
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
		
		Если ТипЗнч(ЗначенияБанковскихСчетовКасс) = Тип("Соответствие") Тогда
		
			ДоступныеБанковскиеСчетаКассы = ЗначенияБанковскихСчетовКасс.Получить(КлючРаспределения);
		Иначе
			ДоступныеБанковскиеСчетаКассы = Неопределено;
		КонецЕсли;
		
		Если ДоступныеБанковскиеСчетаКассы = Неопределено Тогда
			ОтменитьРаспределениеОбъектаОплаты(ДанныеРаспределения, Платеж.ОбъектОплаты,
				НСтр("ru = 'Не подобран доступный Банковский счет / Касса.'"));
			Продолжить;
		КонецЕсли;
		
		ОсталосьОплатить = СтруктураРаспределения.СуммаПереноса;
		ОплатитьОбъектОплатыПоДеревуПлатежей(ДанныеРаспределенияЗаявки, ОсталосьОплатить, ДоступныеБанковскиеСчетаКассы,
			ОстаткиПоСчетамКассам, ПланироватьСДаты, ДнейПланирования);
		
		СуммаРаспределения = 0;
		Для каждого СтрокаРаспределения Из ДанныеРаспределенияЗаявки Цикл
			СуммаРаспределения = СуммаРаспределения + СтрокаРаспределения.СуммаПереноса * СтрокаРаспределения.Коэффициент;
		КонецЦикла;
		Если СуммаРаспределения Тогда
			ОтменитьРаспределениеОбъектаОплаты(ДанныеРаспределения, Платеж.ОбъектОплаты,
				НСтр("ru = 'Недостаточно остатков.'"));
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

// Отменяет распределение объекта оплаты, удаляя из данных на распределение
// 
// Параметры:
//  ДанныеРаспределения - Соответствие из КлючИЗначение - Выбранные строки для распределения, 
//                        где Ключ - ОпределяемыйТип.ОбъектОплаты - заявка на расходование ДС из списка заявок,
//                        Значение - Массив из Структура- данные для заявки из графика платежей.
//  Заявка - РегистрСведенийКлючЗаписи.ГрафикПлатежей - строка из списка заявок.
//  ПричинаОшибки - Строка.
//
&НаСервере
Процедура ОтменитьРаспределениеОбъектаОплаты(ДанныеРаспределения, Заявка, ПричинаОшибки = "")
	
	ДанныеРаспределения.Удалить(Заявка);
	ОбщегоНазначения.СообщитьПользователю(
		СтрШаблон(НСтр("ru = 'Не удалось распределить оплату документа %1. %2'"), Заявка, ПричинаОшибки),
		Заявка);
	
КонецПроцедуры

&НаСервере
Процедура ОплатитьОбъектОплатыПоДеревуПлатежей(ДанныеРаспределенияЗаявки, ОсталосьОплатить, ДоступныеБанковскиеСчетаКассы,
	СтрокиОстатков, ПланироватьСДаты, ДнейПланирования)
	
	СтруктураРаспределения = ДанныеРаспределенияЗаявки[0];
	
	МинимальныйДеньОплаты = 0;
	
	Для Инд = 1 По ДнейПланирования Цикл
		
		ДеньПроверки = ДнейПланирования - Инд + 1;
		ВсегоДоступноПоСчетамЗаДень = 0;
		
		Для каждого СтрокаОстатков Из СтрокиОстатков Цикл
			
			Если ДоступныеБанковскиеСчетаКассы.Найти(СтрокаОстатков.БанковскийСчетКасса) = Неопределено Тогда
				Продолжить;
			КонецЕсли;
			
			КоэффициентКонвертации = 1;
			Если ЗначениеЗаполнено(СтрокаОстатков.Валюта) И СтрокаОстатков.Валюта <> СтруктураРаспределения.Валюта Тогда
				КоэффициентКонвертации = ДенежныеСредстваПовтИсп.КоэффициентКонвертации(
					СтрокаОстатков.Валюта, СтруктураРаспределения.Валюта, ПланироватьСДаты);
			КонецЕсли;
			
			Если СтрокаОстатков["День" + ДеньПроверки] > 0 Тогда
				ВсегоДоступноПоСчетамЗаДень = ВсегоДоступноПоСчетамЗаДень + СтрокаОстатков["День" + ДеньПроверки]
					* КоэффициентКонвертации;
			КонецЕсли;
			
			Если ВсегоДоступноПоСчетамЗаДень >= ОсталосьОплатить Тогда
				МинимальныйДеньОплаты = ДеньПроверки;
				Прервать;
			КонецЕсли;
		КонецЦикла;
	КонецЦикла;
	
	Если Не МинимальныйДеньОплаты Тогда
		Возврат;
	КонецЕсли;
	
	МинимальнаяДатаПлатежа = ДенежныеСредстваКлиентСервер.ДатаПлатежа(ПланироватьСДаты, МинимальныйДеньОплаты);
	РасчетнаяДатаОплаты = Макс(МинимальнаяДатаПлатежа, СтруктураРаспределения.ДатаПлатежа);
	
	Для каждого СтрокаОстатков Из СтрокиОстатков Цикл
		
		Если ДоступныеБанковскиеСчетаКассы.Найти(СтрокаОстатков.БанковскийСчетКасса) = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		КоэффициентКонвертации = 1;
		Если ЗначениеЗаполнено(СтрокаОстатков.Валюта) И СтрокаОстатков.Валюта <> СтруктураРаспределения.Валюта Тогда
			КоэффициентКонвертации = ДенежныеСредстваПовтИсп.КоэффициентКонвертации(
				СтруктураРаспределения.Валюта, СтрокаОстатков.Валюта, ПланироватьСДаты);
		КонецЕсли;
		
		ОплатитьСоСчета = Мин(СтрокаОстатков["День" + МинимальныйДеньОплаты], ОсталосьОплатить * КоэффициентКонвертации);
		
		Если ОплатитьСоСчета <= 0 Тогда
			Продолжить;
		КонецЕсли;
		
		СтрокаОстатков["День" + МинимальныйДеньОплаты] = СтрокаОстатков["День" + МинимальныйДеньОплаты] - ОплатитьСоСчета;
		ОсталосьОплатить = ОсталосьОплатить - ОплатитьСоСчета / КоэффициентКонвертации;
		
		СтруктураПереноса = Обработки.ПлатежныйКалендарь.СтруктураПереноса();
		СтруктураПереноса.БанковскийСчетКасса = СтрокаОстатков.БанковскийСчетКасса;
		СтруктураПереноса.ДатаПлатежа = РасчетнаяДатаОплаты;
		СтруктураПереноса.Валюта = СтруктураРаспределения.Валюта;
		СтруктураПереноса.ВалютаПереноса = СтрокаОстатков.Валюта;
		СтруктураПереноса.СуммаПереноса = ОплатитьСоСчета / КоэффициентКонвертации;
		СтруктураПереноса.Коэффициент = -1;
		СтруктураПереноса.ФлагЗакрыть = Ложь;
		СтруктураПереноса.ОбъектОплаты = СтруктураРаспределения.ОбъектОплаты;
		ДанныеРаспределенияЗаявки.Добавить(СтруктураПереноса);
		
		Если Не ОсталосьОплатить Тогда
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти

&НаКлиенте
Функция СтрокуМожноСдвинуть(Направление)
	
	ТекущиеДанные = Элементы.ДеревоПлатежей.ТекущиеДанные;
	
	Если ТекущиеДанные = Неопределено Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Если ТипЗнч(ТекущиеДанные.Группировка) <> Тип("СправочникСсылка.БанковскиеСчетаОрганизаций")
		И ТипЗнч(ТекущиеДанные.Группировка) <> Тип("СправочникСсылка.Кассы") Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Родитель = ТекущиеДанные.ПолучитьРодителя();
	Если Родитель = Неопределено Тогда
		ЭлементыУровняСчетов = Объект.ДеревоПлатежей.ПолучитьЭлементы();
	Иначе
		ЭлементыУровняСчетов = Родитель.ПолучитьЭлементы();
	КонецЕсли;
	
	ИндексСтроки = ЭлементыУровняСчетов.Индекс(ТекущиеДанные);
	НовыйИндексСтроки = ИндексСтроки + Направление;
	
	Если НовыйИндексСтроки < 0 Или НовыйИндексСтроки > ЭлементыУровняСчетов.Количество() - 1 Тогда
		Возврат Ложь;
	КонецЕсли;
	
	ДанныеЗамены = ЭлементыУровняСчетов.Получить(НовыйИндексСтроки);
	
	Если ТипЗнч(ДанныеЗамены.Группировка) <> Тип("СправочникСсылка.БанковскиеСчетаОрганизаций")
		И ТипЗнч(ДанныеЗамены.Группировка) <> Тип("СправочникСсылка.Кассы") Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Возврат Истина;
	
КонецФункции

&НаСервере
Процедура СдвинутьСтроку(Направление)
	
	ТекущаяСтрока = Элементы.ДеревоПлатежей.ТекущаяСтрока;
	ТекущиеДанные = Объект.ДеревоПлатежей.НайтиПоИдентификатору(ТекущаяСтрока);
	
	Родитель = ТекущиеДанные.ПолучитьРодителя();
	Если Родитель = Неопределено Тогда
		ЭлементыУровняСчетов = Объект.ДеревоПлатежей.ПолучитьЭлементы();
	Иначе
		ЭлементыУровняСчетов = Родитель.ПолучитьЭлементы();
	КонецЕсли;
	
	ЭлементыУровняСчетов.Сдвинуть(ЭлементыУровняСчетов.Индекс(ТекущиеДанные), Направление);
	
	НаборЗаписей = РегистрыСведений.ПорядокПлатежногоКалендаря.СоздатьНаборЗаписей();
	НаборЗаписей.Заполнить(Неопределено);
	ТаблицаНабора = НаборЗаписей.Выгрузить();
	
	Для Каждого СтрокаДерева Из ЭлементыУровняСчетов Цикл
		
		Если Не ЗначениеЗаполнено(СтрокаДерева.БанковскийСчетКасса) Тогда
			Продолжить;
		КонецЕсли;
		
		НоваяСтрока = ТаблицаНабора.Добавить();
		НоваяСтрока.БанковскийСчетКасса = СтрокаДерева.БанковскийСчетКасса;
		НоваяСтрока.ЗначениеПорядка = ЭлементыУровняСчетов.Индекс(СтрокаДерева);
	КонецЦикла;
	
	Для Каждого СтрокаТаблицы Из ТаблицаНабора Цикл
		Запись = РегистрыСведений.ПорядокПлатежногоКалендаря.СоздатьМенеджерЗаписи();
		Запись.Заполнить(Неопределено);
		ЗаполнитьЗначенияСвойств(Запись, СтрокаТаблицы);
		Запись.Записать(Истина);
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура УправлениеЭлементамиИстории()
	
	Элементы.ОтменитьОперацию.Доступность = (ТекущийИндексИстории > 0);
	Элементы.ПовторитьОперацию.Доступность = (ТекущийИндексИстории < ИсторияИзменений.Количество());
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Функция ОтборПредставление(Список)
	
	Представление = "";
	Для Каждого ЭлементСписка Из Список Цикл
		Если ЭлементСписка.Пометка Тогда
			ПредставлениеЭлемента = ?(ЗначениеЗаполнено(ЭлементСписка.Представление), ЭлементСписка.Представление, ЭлементСписка.Значение);
			Представление = Представление + ?(ЗначениеЗаполнено(Представление), ", ", "") + ПредставлениеЭлемента;
		КонецЕсли;
	КонецЦикла;
	
	Возврат Представление;
	
КонецФункции

&НаСервереБезКонтекста
Функция БанковскиеСчетаКассыДоступныеДляОбъектаОплаты(ПлатежиКПереносу, Исключительные = Истина)
	
	Возврат Обработки.ПлатежныйКалендарь.БанковскиеСчетаКассыДоступныеДляОбъектаОплаты(ПлатежиКПереносу, Исключительные);
	
КонецФункции

&НаСервере
Процедура ЗаполнитьСписокСчетовКассНаСервере()
	
	Организации = Новый Массив;
	Для каждого ЭлементОтбора Из Объект.ОтборОрганизации Цикл
		Если ЭлементОтбора.Пометка Тогда
			Организации.Добавить(ЭлементОтбора.Значение);
		КонецЕсли;
	КонецЦикла;
	
	БанковскиеСчетаКассы = Новый Массив;
	Для каждого ЭлементОтбора Из Объект.ОтборБанковскиеСчетаКассы Цикл
		Если ЭлементОтбора.Пометка Тогда
			БанковскиеСчетаКассы.Добавить(ЭлементОтбора.Значение);
		КонецЕсли;
	КонецЦикла;
	
	Запрос = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ДанныеСправочника.Ссылка,
	|	ДанныеСправочника.Наименование КАК Наименование,
	|	1 КАК ПолеПорядка
	|ПОМЕСТИТЬ ОбъектыУчетаДС
	|ИЗ
	|	Справочник.БанковскиеСчетаОрганизаций КАК ДанныеСправочника
	|	ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Организации КАК Организации
	|	ПО Организации.Ссылка = ДанныеСправочника.Владелец
	|	
	|ГДЕ
	|	НЕ ДанныеСправочника.ПометкаУдаления
	|	И НЕ ДанныеСправочника.Закрыт
	|	И (&НеНуженОтборПоОрганизациям
	|			ИЛИ ДанныеСправочника.Владелец В (&Организации))
	|	И (&НеНуженОтборПоВалюте
	|			ИЛИ ДанныеСправочника.ВалютаДенежныхСредств = &Валюта)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ДанныеСправочника.Ссылка,
	|	ДанныеСправочника.Наименование,
	|	1 КАК ПолеПорядка
	|ИЗ
	|	Справочник.Кассы КАК ДанныеСправочника
	|	ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Организации КАК Организации
	|	ПО Организации.Ссылка = ДанныеСправочника.Владелец
	|	
	|ГДЕ
	|	НЕ ДанныеСправочника.ПометкаУдаления
	|	И (&НеНуженОтборПоОрганизациям
	|			ИЛИ ДанныеСправочника.Владелец В (&Организации))
	|	И (&НеНуженОтборПоВалюте
	|			ИЛИ ДанныеСправочника.ВалютаДенежныхСредств = &Валюта)
	|	
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	""НераспределенныеПлатежи"",
	|	&СтрокаНераспределенныеПлатежи,
	|	0 КАК ПолеПорядка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ОбъектыУчетаДС.Ссылка КАК Значение,
	|	ОбъектыУчетаДС.Наименование КАК Представление,
	|	ВЫБОР
	|		КОГДА ОбъектыУчетаДС.Ссылка В (&БанковскиеСчетаКассы)
	|			ТОГДА ИСТИНА
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ КАК Пометка
	|ИЗ
	|	ОбъектыУчетаДС КАК ОбъектыУчетаДС
	|
	|УПОРЯДОЧИТЬ ПО
	|	ПолеПорядка,
	|	Представление";
	
	Запрос.УстановитьПараметр("БанковскиеСчетаКассы", БанковскиеСчетаКассы);
	Запрос.УстановитьПараметр("Организации", Организации);
	Запрос.УстановитьПараметр("НеНуженОтборПоОрганизациям", Не Организации.Количество());
	Запрос.УстановитьПараметр("Валюта", Объект.ОтборВалюта);
	Запрос.УстановитьПараметр("НеНуженОтборПоВалюте", Не ЗначениеЗаполнено(Объект.ОтборВалюта));
	Запрос.УстановитьПараметр("СтрокаНераспределенныеПлатежи", НСтр("ru = '<Нераспределенные платежи>'"));
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();
	
	Объект.ОтборБанковскиеСчетаКассы.Очистить();
	Пока Выборка.Следующий() Цикл
		Объект.ОтборБанковскиеСчетаКассы.Добавить(Выборка.Значение, Выборка.Представление, Выборка.Пометка);
	КонецЦикла;
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Функция ПодчиненныйЭлемент(Дерево, Реквизиты)
	
	ПодчиненныйЭлемент = Неопределено;
	ПодчиненныеСтроки = Дерево.ПолучитьЭлементы();
	Для каждого СтрокаДерева Из ПодчиненныеСтроки Цикл
		СтрокаПодходит = Истина;
		Для каждого Реквизит Из Реквизиты Цикл
			Если СтрокаДерева[Реквизит.Ключ] <> Реквизит.Значение Тогда
				СтрокаПодходит = Ложь;
			КонецЕсли;
		КонецЦикла;
		Если СтрокаПодходит Тогда
			ПодчиненныйЭлемент = СтрокаДерева;
			Прервать;
		КонецЕсли;
		ПодчиненныйЭлемент = ПодчиненныйЭлемент(СтрокаДерева, Реквизиты);
		Если ПодчиненныйЭлемент <> Неопределено Тогда
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
	Возврат ПодчиненныйЭлемент;
	
КонецФункции

&НаКлиенте
Процедура УстановитьСоответствиеРежимовОтображенияКомандам()
	
	СоответвиеКомандИРежимовОтображения = Новый Соответствие();
	СоответвиеКомандИРежимовОтображения.Вставить("РежимЗаявкиКалендарь", "ЗаявкиКалендарь");
	СоответвиеКомандИРежимовОтображения.Вставить("РежимКалендарьПлатежи", "КалендарьПлатежи");
	СоответвиеКомандИРежимовОтображения.Вставить("РежимСписокЗаявок", "СписокЗаявок");
	
КонецПроцедуры

&НаСервере
Функция СоздатьЗаявкиНаОплатуДСНаСервере()

	Компановка = КомпановкаТекущегоСписка(Элементы.ПлатежиВКалендаре);
	СКД = Компановка.СКД;
	Настройки = Компановка.Настройки;

	ДетальныеЗаписи = Настройки.Структура.Добавить(Тип("ГруппировкаКомпоновкиДанных"));
	ФинансоваяОтчетностьСервер.НовоеПолеВыбора(ДетальныеЗаписи, "ОбъектОплаты");
	ФинансоваяОтчетностьСервер.НовоеПолеВыбора(ДетальныеЗаписи, "БанковскийСчетКасса");
	ФинансоваяОтчетностьСервер.НовоеПолеВыбора(ДетальныеЗаписи, "ДатаПлатежа");
	ФинансоваяОтчетностьСервер.НовоеПолеВыбора(ДетальныеЗаписи, "ПлательщикПолучатель");
	ФинансоваяОтчетностьСервер.НовоеПолеВыбора(ДетальныеЗаписи, "Организация");
	ФинансоваяОтчетностьСервер.НовоеПолеВыбора(ДетальныеЗаписи, "ТипСуммы");
	ФинансоваяОтчетностьСервер.НовоеПолеВыбора(ДетальныеЗаписи, "ПоступлениеСписание");
	ФинансоваяОтчетностьСервер.НовоеПолеВыбора(ДетальныеЗаписи, "Валюта");

	ФинансоваяОтчетностьСервер.УстановитьОтбор(Настройки.Отбор, "Идентификатор", ПомеченныеЗаписиПлатежейВКалендаре);
		
	ФинансоваяОтчетностьСервер.УстановитьОтбор(Настройки.Отбор, "ПоступлениеСписание",
		Перечисления.ТипыДвиженияДенежныхСредств.Списание);
		
	ФинансоваяОтчетностьСервер.УстановитьОтбор(Настройки.Отбор, "ЭтоЗаявка", Ложь);

	ОснованияЗаявок = ФинансоваяОтчетностьСервер.ВыгрузитьРезультатСКД(СКД, Настройки);
	
	Если ОснованияЗаявок.Количество() Тогда
		Возврат ДенежныеСредстваСервер.ОплатитьСтрокиГрафика(ОснованияЗаявок, "ЗаявкаНаРасходованиеДенежныхСредств",
					Объект.ГруппироватьДокументыПриСоздании);
	Иначе
		ОбщегоНазначения.СообщитьПользователю(НСтр("ru='В списке нет строк для формирования заявок к оплате.'"));
		Возврат Неопределено;
	КонецЕсли;

КонецФункции

&НаСервере
Функция СоздатьРКОНаСервере()
	
	Компановка = КомпановкаТекущегоСписка(Элементы.ПлатежиВКалендаре);
	СКД = Компановка.СКД;
	Настройки = Компановка.Настройки;

	ДетальныеЗаписи = Настройки.Структура.Добавить(Тип("ГруппировкаКомпоновкиДанных"));
	ФинансоваяОтчетностьСервер.НовоеПолеВыбора(ДетальныеЗаписи, "ОбъектОплаты");
	ФинансоваяОтчетностьСервер.НовоеПолеВыбора(ДетальныеЗаписи, "БанковскийСчетКасса");
	ФинансоваяОтчетностьСервер.НовоеПолеВыбора(ДетальныеЗаписи, "ДатаПлатежа");
	ФинансоваяОтчетностьСервер.НовоеПолеВыбора(ДетальныеЗаписи, "ПлательщикПолучатель");
	ФинансоваяОтчетностьСервер.НовоеПолеВыбора(ДетальныеЗаписи, "Организация");
	ФинансоваяОтчетностьСервер.НовоеПолеВыбора(ДетальныеЗаписи, "ТипСуммы");
	ФинансоваяОтчетностьСервер.НовоеПолеВыбора(ДетальныеЗаписи, "ПоступлениеСписание");
	ФинансоваяОтчетностьСервер.НовоеПолеВыбора(ДетальныеЗаписи, "Валюта");

	ФинансоваяОтчетностьСервер.УстановитьОтбор(Настройки.Отбор, "Идентификатор", ПомеченныеЗаписиПлатежейВКалендаре);
		
	ФинансоваяОтчетностьСервер.УстановитьОтбор(Настройки.Отбор, "ПоступлениеСписание",
		Перечисления.ТипыДвиженияДенежныхСредств.Списание);
		
	ФинансоваяОтчетностьСервер.УстановитьОтбор(Настройки.Отбор, "ФормаОплаты", Перечисления.ФормыОплаты.Безналичная,
		ВидСравненияКомпоновкиДанных.НеРавно);

	СтатусыКОплате = Новый Массив;
	СтатусыКОплате.Добавить(Перечисления.СтатусыЗаявокНаРасходованиеДенежныхСредств.КОплате);
	СтатусыКОплате.Добавить(Перечисления.СтатусыРаспоряженийНаПеремещениеДенежныхСредств.КОплате);
	СтатусыКОплате.Добавить(Перечисления.СтатусыЗаявокСотрудников.Согласована);
	
	ФинансоваяОтчетностьСервер.УстановитьОтбор(Настройки.Отбор, "СтатусЗаявки", СтатусыКОплате);
	
	ОснованияРКО = ФинансоваяОтчетностьСервер.ВыгрузитьРезультатСКД(СКД, Настройки);
	
	Если ОснованияРКО.Количество() Тогда
		Возврат ДенежныеСредстваСервер.ОплатитьСтрокиГрафика(ОснованияРКО, "РасходныйКассовыйОрдер",
					Объект.ГруппироватьДокументыПриСоздании);
	Иначе
		ТекстСообщения = НСтр("ru='В списке нет документов к оплате для формирования документов Расходный кассовый ордер.'");
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);
		Возврат Неопределено;
	КонецЕсли;

КонецФункции

&НаСервереБезКонтекста
Функция ИзмеренияГрафика()
	
	Измерения = Новый Структура;
	
	Для Каждого Измерение Из Метаданные.РегистрыСведений.ГрафикПлатежей.Измерения Цикл
		Измерения.Вставить(Измерение.Имя);
	КонецЦикла;
	
	Возврат Измерения;
	
КонецФункции 

&НаСервереБезКонтекста
Функция ЗаполнитьИдентификаторИсходныеРеквизитыВОтмеченойСтроке(ИзмеренияГрафика)
	
	Идентификатор = "";
	Запись = РегистрыСведений.ГрафикПлатежей.СоздатьМенеджерЗаписи();
	Запись.Заполнить(Неопределено);
	ЗаполнитьЗначенияСвойств(Запись, ИзмеренияГрафика);
	Запись.Прочитать();

	Если Запись.Выбран() Тогда
		
		Запись.Идентификатор = Новый УникальныйИдентификатор();
		
		Если НЕ ЗначениеЗаполнено(Запись.ИсходнаяДатаПлатежа) Тогда
			Запись.ИсходныйБанковскийСчетКасса = Запись.БанковскийСчетКасса;
			Запись.ИсходнаяДатаПлатежа = Запись.ДатаПлатежа;
			Запись.ИсходнаяСумма = Запись.Сумма;
		КонецЕсли;
		
		Запись.Записать();
		Идентификатор = Запись.Идентификатор;
	КонецЕсли;
	
	Возврат Идентификатор;
	
КонецФункции

#Область УровниГруппировок

&НаСервере
Процедура ИнициализироватьМенюУровнейГруппировок()

	ОчиститьМенюУровнейГруппировок();
	ЗаполнитьМенюУровнейГруппировок();
	
	УстановитьДоступностьМенюУровнейГруппировок();

КонецПроцедуры

&НаСервере
Процедура ОчиститьМенюУровнейГруппировок()
	
	Кнопки = Элементы.ГруппаУровниГруппировок.ПодчиненныеЭлементы;
	Индекс = Кнопки.Количество() - 1;

	Пока Индекс >= 0 Цикл

		Кнопка = Кнопки[Индекс];
		Индекс = Индекс - 1;

		Если Кнопка = Элементы.ПоказатьУровеньГруппировок Тогда
			Продолжить;
		КонецЕсли;

		Команда = Команды.Найти(Кнопка.Имя);

		Если Команда <> Неопределено Тогда
			Команды.Удалить(Команда);
		КонецЕсли;

		Элементы.Удалить(Кнопка);
	КонецЦикла;

КонецПроцедуры

&НаСервере
Процедура ЗаполнитьМенюУровнейГруппировок()
	
	ИндексСтруктурыОтчета = НовыйИндексСтруктурыОтчета();
	
	СвойстваМеню = СвойстваМенюУровнейГруппировокОтчета(ИндексСтруктурыОтчета);

	Для Каждого Свойства Из СвойстваМеню Цикл

		Команда = Команды.Добавить(Свойства.ИмяКоманды);
		Команда.Заголовок = Свойства.ПредставлениеУровняГруппировки;
		Команда.Действие = "Подключаемый_ПоказатьУровеньГруппировок";
		
		Кнопка = Элементы.Добавить(Свойства.ИмяКоманды, Тип("КнопкаФормы"), Элементы.ГруппаУровниГруппировок);
		Кнопка.Вид = ВидКнопкиФормы.КнопкаКоманднойПанели;
		Кнопка.ИмяКоманды = Свойства.ИмяКоманды;
		Кнопка.Заголовок = Свойства.ПредставлениеУровняГруппировки;
		Кнопка.ПоложениеВКоманднойПанели = ПоложениеКнопкиВКоманднойПанели.ВКоманднойПанели;
	КонецЦикла;

КонецПроцедуры

&НаСервере
Функция СвойстваМенюУровнейГруппировокОтчета(ИндексСтруктурыОтчета)
	
	СвойстваМеню = СвойстваМенюИзСтруктурыОтчета(ИндексСтруктурыОтчета);
	УровеньГруппировки = 0;
	
	Для Индекс = 0 По Объект.ГруппировкиОтчета.Количество() - 1 Цикл
		
		ТекущаяГруппировка = Объект.ГруппировкиОтчета.Получить(Индекс);
		
		Если ТекущаяГруппировка.Пометка Тогда
			УровеньГруппировки = УровеньГруппировки + 1;
			
			Свойства = СвойстваМеню.Добавить();
			Свойства.ИмяКоманды = Элементы.ПоказатьУровеньГруппировок.Имя + УровеньГруппировки;
			Свойства.ПредставлениеУровняГруппировки = ТекущаяГруппировка.Представление;
		КонецЕсли;
	КонецЦикла;
	
	СвойстваМеню.Сортировать("УровеньГруппировки");
	Возврат СвойстваМеню;
	
КонецФункции

// Параметры:
//  ИндексСтруктурыОтчета - см. ВариантыОтчетовСлужебный.НовыйИндексСтруктурыОтчета 
// 
// Возвращаемое значение:
//  ТаблицаЗначений:
//    * ИмяКоманды - Строка
//    * УровеньГруппировки - Число
//    * ПредставлениеУровняГруппировки - Строка
//
&НаСервереБезКонтекста
Функция СвойстваМенюИзСтруктурыОтчета(ИндексСтруктурыОтчета)

	СвойстваМеню = ИндексСтруктурыОтчета.СкопироватьКолонки("ПорядокГруппировки, ПредставлениеГруппировки"); // ТаблицаЗначений

	СвойстваМеню.Колонки.Вставить(1, "ИмяКоманды", Новый ОписаниеТипов("Строка"));

	Колонка = СвойстваМеню.Колонки.Найти("ПорядокГруппировки"); // КолонкаТаблицыЗначений
	Колонка.Имя = "УровеньГруппировки";

	Колонка = СвойстваМеню.Колонки.Найти("ПредставлениеГруппировки"); // КолонкаТаблицыЗначений
	Колонка.Имя = "ПредставлениеУровняГруппировки";

	Возврат СвойстваМеню;

КонецФункции

&НаСервере
Процедура УстановитьДоступностьМенюУровнейГруппировок()

	МенюЗаполнено = (Элементы.ГруппаУровниГруппировок.ПодчиненныеЭлементы.Количество() > 1);

	Элементы.ПоказатьУровеньГруппировок.Видимость = Не МенюЗаполнено;

	Элементы.ГруппаУровниГруппировок.Видимость = МенюЗаполнено;

КонецПроцедуры

&НаКлиенте
Процедура ПоказатьВыбранныйУровеньГруппировок(УровеньГруппировки = Неопределено)

	СвернутьВсеУровниДерева(Объект.ДеревоПлатежей.ПолучитьЭлементы());

	Если УровеньГруппировки = Неопределено Тогда
		УровеньГруппировки = 1;
	КонецЕсли;
	
	Если УровеньГруппировки > 1 Тогда
		РазвернутьДанныеФормыДерево(Объект.ДеревоПлатежей, УровеньГруппировки);
	КонецЕсли;

	ЭталонноеМеню = Элементы.ГруппаУровниГруппировок;
	ЭталоннаяКнопка = Элементы.ПоказатьУровеньГруппировок;
	
	ОбластиВыводаМеню = Новый Соответствие;
	ОбластиВыводаМеню.Вставить(ЭталонноеМеню, ЭталоннаяКнопка);

	Для Каждого Область Из ОбластиВыводаМеню Цикл

		Кнопки = Область.Ключ.ПодчиненныеЭлементы;
		Для Каждого Кнопка Из Кнопки Цикл
			Кнопка.Пометка = Ложь;
		КонецЦикла;

		ИмяКнопки = ЭталоннаяКнопка.Имя + УровеньГруппировки + СтрЗаменить(Область.Значение.Имя, ЭталоннаяКнопка.Имя, "");
		Кнопка = Кнопки.Найти(ИмяКнопки);
		Если Кнопка <> Неопределено Тогда
			Кнопка.Пометка = Истина;
		КонецЕсли;
	КонецЦикла;

КонецПроцедуры

&НаКлиенте
Процедура РазвернутьДанныеФормыДерево(Дерево, Уровень)

	РазвернутьУровеньДерева(Дерево.ПолучитьЭлементы(), Уровень, 1);
	
КонецПроцедуры

&НаКлиенте
Процедура РазвернутьУровеньДерева(ЭлементыДерева, Уровень, ТекущийУровень)
	
	Если ТекущийУровень >= Уровень Тогда
		Возврат;
	КонецЕсли;
	
	Для Каждого ЭлементДерева Из ЭлементыДерева Цикл
		
		Элементы.ДеревоПлатежей.Развернуть(ЭлементДерева.ПолучитьИдентификатор());
		
		Если ЭлементДерева.ПолучитьЭлементы().Количество() > 0 Тогда
			РазвернутьУровеньДерева(ЭлементДерева.ПолучитьЭлементы(), Уровень, ТекущийУровень + 1);
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура СвернутьВсеУровниДерева(ЭлементыДерева)
	
	Для Каждого ЭлементДерева Из ЭлементыДерева Цикл

		ПодчиненныеЭлементДерева = ЭлементДерева.ПолучитьЭлементы();
		
		Если ПодчиненныеЭлементДерева.Количество() > 0 Тогда
			СвернутьВсеУровниДерева(ПодчиненныеЭлементДерева);
		КонецЕсли;
		Элементы.ДеревоПлатежей.Свернуть(ЭлементДерева.ПолучитьИдентификатор());
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти

#Область ЗамороженныеПлатежи

&НаСервере
Функция ПлатежиДляЗамораживанияИВозвратаНаИсполнение(Заморожен)
	
	Компановка = КомпановкаТекущегоСписка(Элементы[ИмяТекущегоСписка]);
	СКД = Компановка.СКД;
	Настройки = Компановка.Настройки;
	
	ДетальныеЗаписи = Настройки.Структура.Добавить(Тип("ГруппировкаКомпоновкиДанных"));
	ФинансоваяОтчетностьСервер.НовоеПолеВыбора(ДетальныеЗаписи, "ОбъектОплаты");
	ФинансоваяОтчетностьСервер.НовоеПолеВыбора(ДетальныеЗаписи, "БанковскийСчетКасса");
	ФинансоваяОтчетностьСервер.НовоеПолеВыбора(ДетальныеЗаписи, "ДатаПлатежа");
	ФинансоваяОтчетностьСервер.НовоеПолеВыбора(ДетальныеЗаписи, "ПлательщикПолучатель");
	ФинансоваяОтчетностьСервер.НовоеПолеВыбора(ДетальныеЗаписи, "Организация");
	ФинансоваяОтчетностьСервер.НовоеПолеВыбора(ДетальныеЗаписи, "ТипСуммы");
	ФинансоваяОтчетностьСервер.НовоеПолеВыбора(ДетальныеЗаписи, "ПоступлениеСписание");
	ФинансоваяОтчетностьСервер.НовоеПолеВыбора(ДетальныеЗаписи, "Валюта");
	
	ФинансоваяОтчетностьСервер.УстановитьОтбор(Настройки.Отбор, "Идентификатор",
		ЭтотОбъект[ИмяТекущегоСпискаПомеченныеЗаписи]);
	ФинансоваяОтчетностьСервер.УстановитьОтбор(Настройки.Отбор, "Заморожен", Заморожен);
	
	Возврат ФинансоваяОтчетностьСервер.ВыгрузитьРезультатСКД(СКД, Настройки);
	
КонецФункции

&НаСервере
Функция КоличествоПлатежейДляЗамораживанияИВозвратаНаИсполнение(Заморожен)
	
	ТаблицаЗначений = ПлатежиДляЗамораживанияИВозвратаНаИсполнение(Заморожен);
	
	Возврат ТаблицаЗначений.Количество();
	
КонецФункции

&НаСервере
Функция ЗаморозитьПомеченныеПлатежиНаСервере()
	
	ПлатежиДляЗамораживания = ПлатежиДляЗамораживанияИВозвратаНаИсполнение(Ложь);
	
	НаименованиеЗадания = НСтр("ru = 'Заморозить платежи.'");
	ВыполняемыйМетод = "Обработки.ПлатежныйКалендарь.ЗаморозитьВернутьНаИсполнениеПлатежи";
	
	СтруктураПараметров = Новый Структура;
	СтруктураПараметров.Вставить("Платежи", ПлатежиДляЗамораживания);
	СтруктураПараметров.Вставить("Заморожен", Истина);
	
	ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияВФоне(УникальныйИдентификатор);
	ПараметрыВыполнения.НаименованиеФоновогоЗадания = НаименованиеЗадания;
	ПараметрыВыполнения.ЗапуститьНеВФоне = Истина;

	Возврат ДлительныеОперации.ВыполнитьВФоне(ВыполняемыйМетод, СтруктураПараметров, ПараметрыВыполнения);

КонецФункции

&НаКлиенте
Процедура ВводДатыДляВозвратаНаИсполнениеЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ДлительнаяОперация = ВернутьНаИсполнениеНаСервере(Результат);
	ПараметрыОжидания = ДлительныеОперацииКлиент.ПараметрыОжидания(ЭтотОбъект);
	ОписаниеОповещения = Новый ОписаниеОповещения("ПриЗавершенииЗаморозитьВернутьНаИсполнение", ЭтотОбъект);
	ДлительныеОперацииКлиент.ОжидатьЗавершение(ДлительнаяОперация, ОписаниеОповещения, ПараметрыОжидания);
	
КонецПроцедуры

&НаКлиенте
Процедура ВводГлубиныПросрочкиЗавершение(Результат, ДополнительныеПараметры) Экспорт

	Если Результат = Неопределено ИЛИ Результат <= 0 Тогда
		Возврат;
	КонецЕсли;
	
	ЗаморозитьПросроченныеПлатежиНаСервере(Результат);

КонецПроцедуры

&НаСервере
Функция ВернутьНаИсполнениеНаСервере(ДатаПлатежа)
	
	ПлатежиДляВозвратаНаИсполнение = ПлатежиДляЗамораживанияИВозвратаНаИсполнение(Истина);
	
	НаименованиеЗадания = НСтр("ru = 'Вернуть на исполнение платежи.'");
	ВыполняемыйМетод = "Обработки.ПлатежныйКалендарь.ЗаморозитьВернутьНаИсполнениеПлатежи";
	
	СтруктураПараметров = Новый Структура;
	СтруктураПараметров.Вставить("Платежи", ПлатежиДляВозвратаНаИсполнение);
	СтруктураПараметров.Вставить("Заморожен", Ложь);
	СтруктураПараметров.Вставить("ДатаПлатежа", ДатаПлатежа);
	
	ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияВФоне(УникальныйИдентификатор);
	ПараметрыВыполнения.НаименованиеФоновогоЗадания = НаименованиеЗадания;
	ПараметрыВыполнения.ЗапуститьНеВФоне = Истина;

	Возврат ДлительныеОперации.ВыполнитьВФоне(ВыполняемыйМетод, СтруктураПараметров, ПараметрыВыполнения);
	
КонецФункции

&НаСервере
Процедура ЗаморозитьПросроченныеПлатежиНаСервере(ДнейПросрочки)
	
	ОбработкаОбъект = РеквизитФормыВЗначение("Объект");
	
	СКД = ОбработкаОбъект.ПолучитьМакет("ДеревоПлатежей");
	ВариантНастроек = СКД.НастройкиПоУмолчанию;
	
	ИсточникДоступныхНастроек = Новый ИсточникДоступныхНастроекКомпоновкиДанных(СКД);
	Компоновщик = Новый КомпоновщикНастроекКомпоновкиДанных;
	Компоновщик.Инициализировать(ИсточникДоступныхНастроек);
	Компоновщик.ЗагрузитьНастройки(ВариантНастроек);

	КомпоновкаДанныхКлиентСервер.СкопироватьЭлементы(Компоновщик.Настройки.Отбор, Объект.КомпоновщикОтбор.Настройки.Отбор);
		
	ОбработкаОбъект.ЗаполнитьПараметрыКомпоновки(Компоновщик.Настройки.ПараметрыДанных);
	Компоновщик.Восстановить(СпособВосстановленияНастроекКомпоновкиДанных.Полное);

	Компоновщик.Настройки.Структура.Очистить();

	ДетальныеЗаписи = Компоновщик.Настройки.Структура.Добавить(Тип("ГруппировкаКомпоновкиДанных"));
	
	ФинансоваяОтчетностьСервер.НовоеПолеВыбора(ДетальныеЗаписи, "ОбъектОплаты");
	ФинансоваяОтчетностьСервер.НовоеПолеВыбора(ДетальныеЗаписи, "БанковскийСчетКасса");
	ФинансоваяОтчетностьСервер.НовоеПолеВыбора(ДетальныеЗаписи, "ДатаПлатежаИсходная");
	ФинансоваяОтчетностьСервер.НовоеПолеВыбора(ДетальныеЗаписи, "ПлательщикПолучатель");
	ФинансоваяОтчетностьСервер.НовоеПолеВыбора(ДетальныеЗаписи, "Организация");
	ФинансоваяОтчетностьСервер.НовоеПолеВыбора(ДетальныеЗаписи, "ТипСуммы");
	ФинансоваяОтчетностьСервер.НовоеПолеВыбора(ДетальныеЗаписи, "ПоступлениеСписание");
	ФинансоваяОтчетностьСервер.НовоеПолеВыбора(ДетальныеЗаписи, "Валюта");
	ФинансоваяОтчетностьСервер.НовоеПолеВыбора(ДетальныеЗаписи, "ДнейПросрочено");
	
	ФинансоваяОтчетностьСервер.УстановитьОтбор(Компоновщик.Настройки.Отбор, "ПлательщикПолучатель", ,
		ВидСравненияКомпоновкиДанных.Заполнено);
	ФинансоваяОтчетностьСервер.УстановитьОтбор(Компоновщик.Настройки.Отбор, "Заморожен", Ложь);
	ФинансоваяОтчетностьСервер.УстановитьОтбор(Компоновщик.Настройки.Отбор, "ДатаПлатежа", Объект.ПланироватьСДаты,
		ВидСравненияКомпоновкиДанных.Меньше);
	ФинансоваяОтчетностьСервер.УстановитьОтбор(Компоновщик.Настройки.Отбор, "ДнейПросрочено", ДнейПросрочки,
		ВидСравненияКомпоновкиДанных.БольшеИлиРавно);

	МакетСКД = ФинансоваяОтчетностьСервер.ПодготовитьМакетКомпоновкиДляВыгрузкиСКД(СКД, Компоновщик);
	Платежи = ФинансоваяОтчетностьСервер.ВыгрузитьРезультатСКДПоМакету(МакетСКД);

	УстановитьПривилегированныйРежим(Истина);
	
	НачатьТранзакцию();
	
	Попытка
		Для Каждого Платеж Из Платежи Цикл
		
			Запись = РегистрыСведений.ГрафикПлатежей.СоздатьМенеджерЗаписи();
			Запись.Заполнить(Неопределено);
			ЗаполнитьЗначенияСвойств(Запись, Платеж);
			Запись.ДатаПлатежа = Платеж.ДатаПлатежаИсходная;
			Запись.Прочитать();
			
			Если Запись.Выбран() Тогда
				Запись.Заморожен = Истина;
				Запись.Записать();
			КонецЕсли;
		КонецЦикла;
		
		ЗафиксироватьТранзакцию();
		
	Исключение
		ОтменитьТранзакцию();
			
		ТекстСообщения = НСтр("ru = 'Не удалось заморозить просроченные платежи по причине: %1'");
		ТекстСообщения = СтрШаблон(ТекстСообщения, ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
		
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);
	КонецПопытки;
	
	ОбновитьСпискиНаСервере();
	
	ТекущийСписокФормы = Элементы[ИмяТекущегоСписка]; // ТаблицаФормы
	ТекущийСписокФормы.Обновить();
	
КонецПроцедуры

&НаКлиенте
Процедура ПриЗавершенииЗаморозитьВернутьНаИсполнение(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	ОчиститьПомеченныеЗаписи();
	ПриЗавершенииЗаморозитьВернутьНаИсполнениеНаСервере();
	
КонецПроцедуры

&НаСервере
Процедура ПриЗавершенииЗаморозитьВернутьНаИсполнениеНаСервере()
	
	ОбновитьСпискиНаСервере();
	
	ТекущийСписокФормы = Элементы[ИмяТекущегоСписка]; // ТаблицаФормы
	ТекущийСписокФормы.Обновить();
	
КонецПроцедуры

#КонецОбласти

#Область ИнтерактивныеДействия

&НаСервере
Функция ЗаявкиКОплатеНаСервере()

	Компановка = КомпановкаТекущегоСписка(Элементы[ИмяТекущегоСписка]);
	СКД = Компановка.СКД;
	Настройки = Компановка.Настройки;

	ДетальныеЗаписи = Настройки.Структура.Добавить(Тип("ГруппировкаКомпоновкиДанных"));
	ФинансоваяОтчетностьСервер.НовоеПолеВыбора(ДетальныеЗаписи, "ОбъектОплаты");

	СтатусыПредшествующиеКОплате = Новый Массив;
	СтатусыПредшествующиеКОплате.Добавить(Перечисления.СтатусыЗаявокНаРасходованиеДенежныхСредств.НеСогласована);
	СтатусыПредшествующиеКОплате.Добавить(Перечисления.СтатусыЗаявокНаРасходованиеДенежныхСредств.Согласована);

	ФинансоваяОтчетностьСервер.УстановитьОтбор(Настройки.Отбор, "Идентификатор",
		ЭтотОбъект[ИмяТекущегоСпискаПомеченныеЗаписи]);
	ФинансоваяОтчетностьСервер.УстановитьОтбор(Настройки.Отбор, "ЭтоЗаявка", Истина);
	ФинансоваяОтчетностьСервер.УстановитьОтбор(Настройки.Отбор, "Статус", СтатусыПредшествующиеКОплате);
	
	Заявки = ФинансоваяОтчетностьСервер.ВыгрузитьРезультатСКД(СКД, Настройки).ВыгрузитьКолонку("ОбъектОплаты");
	
	Если Заявки.Количество() = 0 Тогда
		ТекстОшибки = СтрШаблон(НСтр("ru='Не отмечено ни одного документа ""%1"" в статусах ""%2"", ""%3"".'"),
			Метаданные.Документы.ЗаявкаНаРасходованиеДенежныхСредств.Синоним,
			Метаданные.Перечисления.СтатусыЗаявокНаРасходованиеДенежныхСредств.ЗначенияПеречисления.НеСогласована.Синоним,
			Метаданные.Перечисления.СтатусыЗаявокНаРасходованиеДенежныхСредств.ЗначенияПеречисления.Согласована.Синоним);
		ОбщегоНазначения.СообщитьПользователю(ТекстОшибки);
	КонецЕсли;
	
	Возврат Заявки;

КонецФункции

&НаСервере
Функция ОтклонитьЗаявкиНаСервере()
	
	Компановка = КомпановкаТекущегоСписка(Элементы[ИмяТекущегоСписка]);
	СКД = Компановка.СКД;
	Настройки = Компановка.Настройки;

	ДетальныеЗаписи = Настройки.Структура.Добавить(Тип("ГруппировкаКомпоновкиДанных"));
	ФинансоваяОтчетностьСервер.НовоеПолеВыбора(ДетальныеЗаписи, "ОбъектОплаты");

	ФинансоваяОтчетностьСервер.УстановитьОтбор(Настройки.Отбор, "Идентификатор",
		ЭтотОбъект[ИмяТекущегоСпискаПомеченныеЗаписи]);
	ФинансоваяОтчетностьСервер.УстановитьОтбор(Настройки.Отбор, "ЭтоЗаявка", Истина);
	
	Заявки = ФинансоваяОтчетностьСервер.ВыгрузитьРезультатСКД(СКД, Настройки).ВыгрузитьКолонку("ОбъектОплаты");
	
	Если Заявки.Количество() = 0 Тогда
		ТекстОшибки = СтрШаблон(НСтр("ru='Не отмечено ни одного документа ""%1"".'"),
			Метаданные.Документы.ЗаявкаНаРасходованиеДенежныхСредств.Синоним);
		ОбщегоНазначения.СообщитьПользователю(ТекстОшибки);
	КонецЕсли;
	
	Возврат Заявки;
	
КонецФункции

#КонецОбласти

#Область Прочее

&НаКлиенте
Процедура ОчиститьПомеченныеЗаписи()
	
	ПомеченныеЗаписиПлатежейВКалендаре.Очистить();
	ПомеченныеЗаписиЗаявкиКОплате.Очистить();
	ИтогиКоличество = 0;
	ИтогиСумма = 0;
	
КонецПроцедуры

// Получает СхемаКомпоновкиДанных, НастройкиКомпоновкиДанных текущего списка
// 
// Параметры:
//  Таблица - ДинамическийСписок.
// 
// Возвращаемое значение:
//  Структура:
//   * СКД - СхемаКомпоновкиДанных.
//   * Настройки - НастройкиКомпоновкиДанных. 
//
&НаСервереБезКонтекста
Функция КомпановкаТекущегоСписка(Таблица)
	
	СКД = Таблица.ПолучитьИсполняемуюСхемуКомпоновкиДанных(); // СхемаКомпоновкиДанных
	СКД.НаборыДанных.НаборДанныхДинамическогоСписка.Запрос =
		СтрЗаменить(СКД.НаборыДанных.НаборДанныхДинамическогоСписка.Запрос,
			"ВЫБРАТЬ РАЗРЕШЕННЫЕ",
			"ВЫБРАТЬ РАЗЛИЧНЫЕ РАЗРЕШЕННЫЕ"); //@query-part-1 @query-part-2
	Настройки = Таблица.ПолучитьИсполняемыеНастройкиКомпоновкиДанных(); // НастройкиКомпоновкиДанных
	Настройки.Структура.Очистить();

	Возврат Новый Структура("СКД, Настройки", СКД, Настройки);
	
КонецФункции

&НаСервере
Процедура УстановитьФлажкиНаСервере()

	Компановка = КомпановкаТекущегоСписка(Элементы[ИмяТекущегоСписка]);
	СКД = Компановка.СКД;
	Настройки = Компановка.Настройки;
	
	ДетальныеЗаписи = Настройки.Структура.Добавить(Тип("ГруппировкаКомпоновкиДанных"));
	ФинансоваяОтчетностьСервер.НовоеПолеВыбора(ДетальныеЗаписи, "Идентификатор");
	ФинансоваяОтчетностьСервер.НовоеПолеВыбора(ДетальныеЗаписи, "Сумма");
	
	Платежи = ФинансоваяОтчетностьСервер.ВыгрузитьРезультатСКД(СКД, Настройки);
	
	Для Каждого Платеж Из Платежи Цикл
		
		Если Не ЗначениеЗаполнено(Платеж.Идентификатор) Тогда
			Продолжить;
		КонецЕсли;
		ЭлементСписка = ЭтотОбъект[ИмяТекущегоСпискаПомеченныеЗаписи].НайтиПоЗначению(Платеж.Идентификатор);
		Если ЭлементСписка = Неопределено Тогда
			ЭтотОбъект[ИмяТекущегоСпискаПомеченныеЗаписи].Добавить(Платеж.Идентификатор);
			ИтогиСумма = ИтогиСумма + Платеж.Сумма;
			ИтогиКоличество = ИтогиКоличество + 1;
		КонецЕсли;
	КонецЦикла;

КонецПроцедуры

&НаСервере
Функция ОписатьРезультатОшибкиДлительнойОперации(ТекстОшибки)
	
	Результат = Новый Структура;
	Результат.Вставить("Статус", "Ошибка");
	Результат.Вставить("АдресРезультата", "");
	Результат.Вставить("АдресДополнительногоРезультата", "");
	Результат.Вставить("КраткоеПредставлениеОшибки", ТекстОшибки);
	Результат.Вставить("ПодробноеПредставлениеОшибки", "");
	Результат.Вставить("ИдентификаторЗадания", УникальныйИдентификатор);
	Результат.Вставить("ИнформацияОбОшибке", "");
	
	Сообщения = Новый Массив();
	Сообщения.Добавить(ТекстОшибки);
	Результат.Вставить("Сообщения", Сообщения);
	
	Возврат Результат;
	
КонецФункции

// Устанавливает новый отбор в переданном отборе схемы компоновки данных.
//
// Параметры:
//  ОтборКД - ОтборКомпоновкиДанных - отбор схемы компоновки в который необходимо добавить новый элемент.
//  ЛевоеЗначение - Строка, ПолеКомпоновкиДанных - поле компоновки по которому необходимо установить отбор.
//  ПравоеЗначение  - Произвольный - значение отбора (необязательное).
//  ВидСравнения  - ВидСравненияКомпоновкиДанных - вид сравнение компоновки данных (необязательное).
//  Использование  - Булево - использование нового элемента отбора (необязательное по умолчанию Истина).
//
&НаСервереБезКонтекста
Процедура УстановитьОтборБезПоискаВГруппах(ОтборКД, ЛевоеЗначение, ПравоеЗначение = Неопределено,
	ВидСравнения = Неопределено, Использование = Истина)
	
	ЭлементОтбора = НайтиЭлементОтбораБезПоискаВГруппахРавноВСписке(ОтборКД, ЛевоеЗначение);
	Если ЭлементОтбора = Неопределено Тогда
		ЭлементОтбора = ФинансоваяОтчетностьСервер.НовыйОтбор(ОтборКД, ЛевоеЗначение, ПравоеЗначение);
	КонецЕсли;
	ЭлементОтбора.Использование = Использование;
	Если ВидСравнения <> Неопределено Тогда
		ЭлементОтбора.ВидСравнения = ВидСравнения;
	КонецЕсли;
	Если Использование Тогда
		ЭлементОтбора.ПравоеЗначение = ПравоеЗначение;
	КонецЕсли;
	
КонецПроцедуры

// Возвращает ссылку на элемент отбора в переданном отборе схемы компоновки данных.
//
// Параметры:
//  ОтборКД - ОтборКомпоновкиДанных - отбор схемы компоновки в который необходимо добавить новый элемент.
//  ИмяЭлемента - Строка - имя поля компоновки по которому необходимо найти элемент отбора.
//
// Возвращаемое значение:
//   ЭлементОтбораКомпоновкиДанных - ссылка на найденный элемент отбора схемы компоновки данных.
//
&НаСервереБезКонтекста
Функция НайтиЭлементОтбораБезПоискаВГруппахРавноВСписке(ОтборКД, ИмяЭлемента)
	
	Результат = Неопределено;
	Для Каждого ЭлементОтбора Из ОтборКД.Элементы Цикл
		Если ТипЗнч(ЭлементОтбора) <> Тип("ГруппаЭлементовОтбораКомпоновкиДанных")
			И ЭлементОтбора.ЛевоеЗначение = Новый ПолеКомпоновкиДанных(ИмяЭлемента) Тогда
			Если ЭлементОтбора.ВидСравнения = ВидСравненияКомпоновкиДанных.Равно
				Или ЭлементОтбора.ВидСравнения = ВидСравненияКомпоновкиДанных.ВСписке Тогда
				Результат = ЭлементОтбора;
				Прервать;
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	Возврат Результат;
	
КонецФункции

// Возвращает ссылку на элемент отбора в переданном отборе схемы компоновки данных.
