	КонецЕсли;
	
	ДлительнаяОперация = РаспределитьНаСервере(ЭтотОбъект[ИмяТекущегоСпискаПомеченныеЗаписи]);
	ПараметрыОжидания = ДлительныеОперацииКлиент.ПараметрыОжидания(ЭтотОбъект);
