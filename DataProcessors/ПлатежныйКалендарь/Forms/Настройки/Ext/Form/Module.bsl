
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	// Пропускаем инициализацию, чтобы гарантировать получение формы при передаче параметра "АвтоТест".
	Если Параметры.Свойство("АвтоТест") Тогда
		Возврат;
	КонецЕсли;
	
	ЗаполнитьЗначенияСвойств(Объект, Параметры.Объект, ИзменяемыеРеквизиты());
	
	ДоступнаАренда = Ложь;
	Элементы.Аренда.Видимость = ДоступнаАренда;
	
	ПредставлениеГруппировокОтчета = ПредставлениеГруппировокОтчета(Объект.ГруппировкиОтчета);
	
	Если НЕ ПолучитьФункциональнуюОпцию("ИспользоватьЗаявкиНаРасходованиеДенежныхСредств") Тогда
		
		Элементы.НесогласованныеЗаявки.Видимость = Ложь;
		Элементы.ОжидаемыеПоступления.Видимость = Ложь;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ОбработкаПроверкиЗаполненияНаСервере(Отказ, ПроверяемыеРеквизиты)
	
	ПроверяемыеРеквизиты.Очистить();
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	СтрокаДнейПланирования = СтрокаДнейПланирования();

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура ПланироватьСДатыПриИзменении(Элемент)
	
	ЗаполнитьДатыОкончания();
	
КонецПроцедуры

&НаКлиенте
Процедура ДнейПланированияПриИзменении(Элемент)
	
	ЗаполнитьДатыОкончания();
	СтрокаДнейПланирования = СтрокаДнейПланирования();

КонецПроцедуры

&НаКлиенте
Процедура ПериодовДолгосрочногоПланированияПриИзменении(Элемент)
	
	ЗаполнитьДатыОкончания();

КонецПроцедуры

&НаКлиенте
Процедура ПериодичностьПланированияПриИзменении(Элемент)
	
	Если НЕ ЗначениеЗаполнено(Объект.ПериодичностьДолгосрочногоПланирования) Тогда
		Объект.ПериодовДолгосрочногоПланирования = 0;
	КонецЕсли;
	
	ЗаполнитьДатыОкончания();
	
КонецПроцедуры

&НаКлиенте
Процедура ДатаОкончанияПриИзменении(Элемент)
	
	Если Объект.ДатаОкончания < Объект.ПланироватьСДаты Тогда
		Объект.ДатаОкончания = Объект.ПланироватьСДаты;
	КонецЕсли;
	
	Если Объект.ПериодовДолгосрочногоПланирования = 0 Тогда
		Объект.ДнейПланирования = (Объект.ДатаОкончания - Объект.ПланироватьСДаты) / 86400 + 1;
	ИначеЕсли ЗначениеЗаполнено(Объект.ПериодичностьДолгосрочногоПланирования) Тогда
		Объект.ДатаОкончанияПланированияПоДням = РаботаСПериодамиКлиентСервер.ДобавитьИнтервал(Объект.ДатаОкончания,
			Объект.ПериодичностьДолгосрочногоПланирования, -Объект.ПериодовДолгосрочногоПланирования);
		Объект.ДнейПланирования = (Объект.ДатаОкончанияПланированияПоДням - Объект.ПланироватьСДаты) / 86400 + 1;
	КонецЕсли;
	
	Если Объект.ДнейПланирования <= 0 Тогда
		Объект.ДнейПланирования = 1;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПредставлениеГруппировокОтчетаНачалоВыбора(Элемент, ДанныеВыбора, ВыборДобавлением, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	ОткрытьФорму("Обработка.ПлатежныйКалендарь.Форма.НастройкаГруппировок",
		Новый Структура("ГруппировкиОтчета", Объект.ГруппировкиОтчета),
		,,,,
		Новый ОписаниеОповещения("ПредставлениеГруппировокОтчетаНачалоВыбораЗавершение", ЭтотОбъект),
		РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура ПрименитьИЗакрыть(Команда)
	
	Если ПроверитьЗаполнение() Тогда
		Результат = Новый Структура(ИзменяемыеРеквизиты());
		ЗаполнитьЗначенияСвойств(Результат, Объект);
		Закрыть(Результат);
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиентеНаСервереБезКонтекста
Функция ИзменяемыеРеквизиты()
	
	Возврат "ПланироватьСДаты, ВалютаИтогов, СкрыватьВыходные,
		|НесогласованныеЗаявки, ОжидаемыеПоступления, ЗаказыКлиентов, ЗаказыПоставщикам, ВозвратыКлиентам, ВозвратыОтПоставщиков,
		|КредитыИлиЗаймыПолученные, Депозиты, ЗаймыВыданные, Аренда,
		|ДнейПланирования, ДатаОкончания, ДатаОкончанияПланированияПоДням, ПериодовДолгосрочногоПланирования,
		|ПериодичностьДолгосрочногоПланирования, ДатаОкончанияДолгосрочногоПланирования, НулевыеОстаткиИОбороты,
		|ГруппировкиОтчета, ГлубинаОтображенияПросроченныхПлатежей, ГруппироватьДокументыПриСоздании";
	
КонецФункции

&НаСервере
Процедура ЗаполнитьДатыОкончания()
	
	Обработки.ПлатежныйКалендарь.ЗаполнитьДатыОкончания(Объект);
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Функция ПредставлениеГруппировокОтчета(Группировки)

	Представление = "";
	Для Каждого ЭлГруппировка Из Группировки Цикл
		Если ЭлГруппировка.Пометка Тогда
			Представление = Представление + "," + ЭлГруппировка.Представление;
		КонецЕсли;
	КонецЦикла;
	
	Возврат Сред(Представление, 2);

КонецФункции

&НаКлиенте
Процедура ПредставлениеГруппировокОтчетаНачалоВыбораЗавершение(СписокГруппировок, ДополнительныеПараметры) Экспорт

	Если ТипЗнч(СписокГруппировок) = Тип("СписокЗначений") Тогда
		Объект.ГруппировкиОтчета = СписокГруппировок;
		ПредставлениеГруппировокОтчета = ПредставлениеГруппировокОтчета(СписокГруппировок);
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Функция СтрокаДнейПланирования()

	Возврат СтроковыеФункцииКлиентСервер.СтрокаСЧисломДляЛюбогоЯзыка(НСтр("ru=';день;;дня;дней;дня'"),
		Объект.ДнейПланирования);

КонецФункции

#КонецОбласти
