	<Attributes>
		<Attribute name="КассовыеЧеки" id="1">
			<Title>
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Кассовые чеки</v8:content>
				</v8:item>
			</Title>
			<Type>
				<v8:Type>cfg:DynamicList</v8:Type>
			</Type>
			<MainAttribute>true</MainAttribute>
			<UseAlways>
				<Field>КассовыеЧеки.ПодотчетноеЛицо</Field>
				<Field>КассовыеЧеки.Ссылка</Field>
				<Field>КассовыеЧеки.Статус</Field>
			</UseAlways>
			<Settings xsi:type="DynamicList">
				<ManualQuery>true</ManualQuery>
				<DynamicDataRead>true</DynamicDataRead>
				<QueryText>ВЫБРАТЬ РАЗЛИЧНЫЕ
	РаспознанныйДокумент.Ссылка КАК Ссылка,
	ВЫБОР
		КОГДА РаспознанныйДокумент.ПометкаУдаления
			ТОГДА 0
		ИНАЧЕ ВЫБОР
			КОГДА РаспознанныйДокумент.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыСозданныхДокументовРаспознаваниеДокументов.Ошибка)
				ТОГДА 1
			КОГДА РаспознанныйДокумент.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыСозданныхДокументовРаспознаваниеДокументов.Новый)
				ТОГДА 2
			КОГДА
				РаспознанныйДокумент.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыСозданныхДокументовРаспознаваниеДокументов.Обработан)
				ТОГДА 4
			ИНАЧЕ 3
		КОНЕЦ
	КОНЕЦ КАК Статус,
	ПРЕДСТАВЛЕНИЕ(РеквизитПартнер.Значение) КАК ПоставщикНаименование,
	ВЫРАЗИТЬ(РеквизитИННПродавца.Значение КАК СТРОКА(12)) КАК ПоставщикИНН,
	ВЫРАЗИТЬ(РеквизитИтогоВсего.Значение КАК ЧИСЛО(31, 2)) КАК СуммаДокумента,
	ВЫРАЗИТЬ(РеквизитДатаДокумента.Значение КАК ДАТА) КАК Дата,
	ВЫРАЗИТЬ(РеквизитНомерДокумента.Значение КАК СТРОКА(100)) КАК Номер,
	РеквизитQRКод.Значение КАК QRКод,
	ЕСТЬNULL(ВЫРАЗИТЬ(ИсходныеДанныеЗаданийРаспознаваниеДокументов.Пользователь КАК
		Справочник.Пользователи).ФизическоеЛицо, ЗНАЧЕНИЕ(Справочник.ФизическиеЛица.ПустаяСсылка)) КАК ПодотчетноеЛицо
ИЗ
	Документ.РаспознанныйДокумент КАК РаспознанныйДокумент
		ЛЕВОЕ СОЕДИНЕНИЕ Документ.РаспознанныйДокумент.РеквизитыДокумента КАК РеквизитПартнер
		ПО РаспознанныйДокумент.Ссылка = РеквизитПартнер.Ссылка
		И РеквизитПартнер.ИмяРеквизита = "Партнер"
		ЛЕВОЕ СОЕДИНЕНИЕ Документ.РаспознанныйДокумент.РеквизитыДокумента КАК РеквизитИННПродавца
		ПО РаспознанныйДокумент.Ссылка = РеквизитИННПродавца.Ссылка
		И РеквизитИННПродавца.ИмяРеквизита = "ИННПродавца"
		ЛЕВОЕ СОЕДИНЕНИЕ Документ.РаспознанныйДокумент.РеквизитыДокумента КАК РеквизитИтогоВсего
		ПО РаспознанныйДокумент.Ссылка = РеквизитИтогоВсего.Ссылка
		И РеквизитИтогоВсего.ИмяРеквизита = "ИтогоВсего"
		ЛЕВОЕ СОЕДИНЕНИЕ Документ.РаспознанныйДокумент.РеквизитыДокумента КАК РеквизитДатаДокумента
		ПО РаспознанныйДокумент.Ссылка = РеквизитДатаДокумента.Ссылка
		И РеквизитДатаДокумента.ИмяРеквизита = "ДатаДокумента"
		ЛЕВОЕ СОЕДИНЕНИЕ Документ.РаспознанныйДокумент.РеквизитыДокумента КАК РеквизитНомерДокумента
		ПО РаспознанныйДокумент.Ссылка = РеквизитНомерДокумента.Ссылка
		И РеквизитНомерДокумента.ИмяРеквизита = "НомерДокумента"
		ЛЕВОЕ СОЕДИНЕНИЕ Документ.РаспознанныйДокумент.РеквизитыДокумента КАК РеквизитQRКод
		ПО РаспознанныйДокумент.Ссылка = РеквизитQRКод.Ссылка
		И РеквизитQRКод.ИмяРеквизита = "QRКод"
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ИсходныеДанныеЗаданийРаспознаваниеДокументов КАК
			ИсходныеДанныеЗаданийРаспознаваниеДокументов
		ПО РаспознанныйДокумент.ИдентификаторЗадания = ИсходныеДанныеЗаданийРаспознаваниеДокументов.ИдентификаторЗадания
ГДЕ
	РаспознанныйДокумент.ТипДокумента = ЗНАЧЕНИЕ(Перечисление.ТипыДокументовРаспознаваниеДокументов.КассовыйЧек)
	И НЕ РаспознанныйДокумент.ПометкаУдаления</QueryText>
				<Field xsi:type="dcssch:DataSetFieldField">
					<dcssch:dataPath>Ссылка</dcssch:dataPath>
					<dcssch:field>Ссылка</dcssch:field>
