// Возвращает признак использования устаревшей функциональности при проверке вывода уведомления.
//
// Возвращаемое значение:
//  Булево - признак использования устаревшей функциональности в системе.
//
Функция ПроверитьИспользованиеУстаревшейФункциональности() Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	Если ОбщегоНазначения.РазделениеВключено() Тогда
		ИспользуетсяУстаревшаяФункциональностьВСистеме = Ложь;
	Иначе
	
		ИспользуетсяУстаревшаяФункциональностьВСистеме = ИспользуетсяУстаревшаяФункциональность();
			
		Если НЕ ИспользуетсяУстаревшаяФункциональностьВСистеме Тогда
			УстановитьКонстантуУведомленияОбУстаревшейФункциональности(Ложь);
		КонецЕсли;
		
	КонецЕсли;
		
	УстановитьПривилегированныйРежим(Ложь);
		
	Возврат ИспользуетсяУстаревшаяФункциональностьВСистеме;

КонецФункции

// Возвращает признак использования устаревшей функциональности в привелигированном режиме.
//
// Возвращаемое значение:
//  Булево - признак использования устаревшей функциональности в системе.
//
Функция ИспользуетсяУстаревшаяФункциональность() Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	ИспользуетсяУстаревшаяФункциональность = Ложь
		
		
		
		ИЛИ ШагКомиссионныеПродажиИспользуетсяУстаревшаяФункциональность()
		ИЛИ ШагЦенообразованиеИспользуетсяУстаревшаяФункциональность()
		ИЛИ ШагВзаиморасчетыИспользуетсяУстаревшаяФункциональность()
		
		//++ Локализация
		ИЛИ ШагПартионныйУчетИспользуетсяУстаревшаяФункциональность()
		//-- Локализация
		
		ИЛИ ШагRLSИспользуетсяУстаревшаяФункциональность();
		
	УстановитьПривилегированныйРежим(Ложь);
		
	Возврат ИспользуетсяУстаревшаяФункциональность;

КонецФункции

// Возвращает таблицу значений с устаревшей функциональностью.
//
// Параметры:
// 	РассчитыватьСостояние - Булево
// 	
// Возвращаемое значение:
//  ТаблицаЗначений:
//   * Идентификатор - Число
//   * УстаревшаяФункциональность - Строка
//   * НоваяФункциональность - Строка
//   * Статус - Число
//   * Состояние - Строка
//   * Рекомендация - Строка
//   * Действие - Строка
//   * РежимДействия - Число
//   * ИспользуетсяУстаревшаяФункциональность - Булево
//   * ИспользуетсяНоваяФункциональность - Булево
//   * РекомендацияТребующаяДействий - Булево
//   * ИнформацияНеПрипятствующаяОбновлению - Булево
//   * ДатаДокумента - Дата
//   * ТребуетсяРассчитатьСостояние - Булево
//
Функция ТаблицаУстаревшейФункциональности(РассчитыватьСостояние) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	Таблица = Новый ТаблицаЗначений;
	Таблица.Колонки.Добавить("Идентификатор", ОбщегоНазначения.ОписаниеТипаЧисло(2));
	Таблица.Колонки.Добавить("УстаревшаяФункциональность", ОбщегоНазначения.ОписаниеТипаСтрока(200));
	Таблица.Колонки.Добавить("НоваяФункциональность", ОбщегоНазначения.ОписаниеТипаСтрока(200));
	Таблица.Колонки.Добавить("Статус", ОбщегоНазначения.ОписаниеТипаЧисло(1));
	Таблица.Колонки.Добавить("Состояние", ОбщегоНазначения.ОписаниеТипаСтрока(100));
	Таблица.Колонки.Добавить("Рекомендация", ОбщегоНазначения.ОписаниеТипаСтрока(0));
	Таблица.Колонки.Добавить("Действие", ОбщегоНазначения.ОписаниеТипаСтрока(100));
	Таблица.Колонки.Добавить("РежимДействия", ОбщегоНазначения.ОписаниеТипаЧисло(1));
	Таблица.Колонки.Добавить("ИспользуетсяУстаревшаяФункциональность", Новый ОписаниеТипов("Булево"));
	Таблица.Колонки.Добавить("ИспользуетсяНоваяФункциональность", Новый ОписаниеТипов("Булево"));
	Таблица.Колонки.Добавить("РекомендацияТребующаяДействий", Новый ОписаниеТипов("Булево"));
	Таблица.Колонки.Добавить("ИнформацияНеПрипятствующаяОбновлению", Новый ОписаниеТипов("Булево"));
	Таблица.Колонки.Добавить("ДатаДокумента", ОбщегоНазначения.ОписаниеТипаДата(ЧастиДаты.Дата));
	Таблица.Колонки.Добавить("ТребуетсяРассчитатьСостояние", Новый ОписаниеТипов("Булево"));
	Таблица.Колонки.Добавить("ЕстьДанныеПоУстаревшейФункциональности", Новый ОписаниеТипов("Булево"));
	
	
	
	
	
	ДобавитьШагКомиссионныеПродажи(Таблица, РассчитыватьСостояние);
	ДобавитьШагЦенообразование(Таблица, РассчитыватьСостояние);
	ДобавитьШагВзаиморасчеты(Таблица, РассчитыватьСостояние);
	
	//++ Локализация
	ДобавитьШагПартионныйУчет(Таблица, РассчитыватьСостояние);
	//-- Локализация
	
	
	ДобавитьШагВводОстатков(Таблица, РассчитыватьСостояние);
	ДобавитьШагRLS(Таблица, РассчитыватьСостояние);
	
	УстановитьПривилегированныйРежим(Ложь);
	
	Возврат Таблица;

КонецФункции

// Получение данных в длительной операции.
//
// Параметры:
// 	Параметры - Структура
// 	АдресХранилища - Строка
//
Процедура ПолучитьДанныеУстаревшейФункциональностиВФоне(Параметры, АдресХранилища) Экспорт
	
	ТаблицаДанных = ТаблицаУстаревшейФункциональности(Истина);
	
	ПоместитьВоВременноеХранилище(ТаблицаДанных, АдресХранилища);
	
КонецПроцедуры

// Устанавливает значение константы для показа формы уведомления об устаревшей функциональности.
//
// Параметры:
//  Значение - Булево - устанавливаемое значение.
//
Процедура УстановитьКонстантуУведомленияОбУстаревшейФункциональности(Значение) Экспорт

	УстановитьПривилегированныйРежим(Истина);
	
	Если ОбщегоНазначения.РазделениеВключено() Тогда
		Возврат;
	Иначе
		Константы.УведомитьОбУстаревшейФункциональности.Установить(Значение);
	КонецЕсли;
	
	УстановитьПривилегированныйРежим(Ложь);

КонецПроцедуры


