Процедура ЗаполнитьДанныеВСтроке(Строка)
	
	ИспользуетсяТолькоНоваяФункциональность = НЕ Строка.ИспользуетсяУстаревшаяФункциональность И Строка.ИспользуетсяНоваяФункциональность;
	ФункциональностьНеИспользуется = НЕ Строка.ИспользуетсяУстаревшаяФункциональность И НЕ Строка.ИспользуетсяНоваяФункциональность;
	ЕстьДанныеПоУстаревшейФункциональности = Строка.ЕстьДанныеПоУстаревшейФункциональности;
	
	#Область Состояние
	МожноПерейтиНа26 = Строка.ИнформацияНеПрипятствующаяОбновлению ИЛИ ИспользуетсяТолькоНоваяФункциональность ИЛИ ФункциональностьНеИспользуется;
		
	Если МожноПерейтиНа26 Тогда
		ТекстСостояния = НСтр("ru = 'Можно переходить на редакцию 11.6'");
	Иначе
		ТекстСостояния = НСтр("ru = 'Нельзя переходить на редакцию 11.6'");
	КонецЕсли;
	
	Если Строка.ТребуетсяРассчитатьСостояние Тогда
		ТекстСостояния = НСтр("ru = 'Рассчитывается'");
	КонецЕсли;
	
	Строка.Состояние = ТекстСостояния;
	#КонецОбласти
	
	#Область Рекомендация
	Рекомендация = Строка.Рекомендация;
	
	Если Не Строка.ТребуетсяРассчитатьСостояние Тогда
	
		Если ИспользуетсяТолькоНоваяФункциональность
		 ИЛИ ФункциональностьНеИспользуется Тогда
			Рекомендация = НСтр("ru = 'Дополнительных действий не требуется.'");
		ИначеЕсли Строка.РежимДействия = РежимДействияПереходКПомощнику() Тогда
			Рекомендация = НСтр("ru = 'Воспользуйтесь помощником перехода.'");
		КонецЕсли;
	
	КонецЕсли;
	
	Строка.Рекомендация = Рекомендация;
	#КонецОбласти
	
	#Область СтатусКартинка
	Если ФункциональностьНеИспользуется И ЕстьДанныеПоУстаревшейФункциональности Тогда
		Строка.Статус = КартинкаГотово();
	ИначеЕсли ФункциональностьНеИспользуется И НЕ ЕстьДанныеПоУстаревшейФункциональности Тогда
		Строка.Статус = КартинкаНеИспользуется();
	ИначеЕсли Строка.ИнформацияНеПрипятствующаяОбновлению И НЕ ИспользуетсяТолькоНоваяФункциональность Тогда
		Строка.Статус = КартинкаИнформация();
	ИначеЕсли ИспользуетсяТолькоНоваяФункциональность Тогда
		Строка.Статус = КартинкаГотово();
	Иначе
		Строка.Статус = КартинкаТребуетсяВнимание();
	КонецЕсли;
	#КонецОбласти
	
	#Область Действие
	Если Не Строка.ТребуетсяРассчитатьСостояние Тогда
	
		Если ИспользуетсяТолькоНоваяФункциональность ИЛИ ФункциональностьНеИспользуется Тогда
			ТекстДействия = "";
		ИначеЕсли Строка.РежимДействия = РежимДействияПереходКПомощнику() Тогда
			ТекстДействия = НСтр("ru = 'Помощник перехода'");
		ИначеЕсли Строка.РежимДействия = РежимДействияПереходВСписокДокументов() Тогда
			ТекстДействия = НСтр("ru = 'Переход к списку документов'");
		ИначеЕсли Строка.РежимДействия = РежимДействияПереходВРаздел() Тогда
			ТекстДействия = НСтр("ru = 'Переход к разделу администрирования'");
		ИначеЕсли Строка.РежимДействия = РежимДействияПереходКНастройке() Тогда
			ТекстДействия = НСтр("ru = 'Переход к настройке'");
		КонецЕсли;
	
	КонецЕсли;
	
	Строка.Действие = ТекстДействия;
	#КонецОбласти
	
	#Область РекомендацияТребующаяДействий
	Если ИспользуетсяТолькоНоваяФункциональность ИЛИ ФункциональностьНеИспользуется Тогда
		Строка.РекомендацияТребующаяДействий = Ложь;
	КонецЕсли;
	#КонецОбласти
	
КонецПроцедуры



#Область КомиссионныеПродажи

Процедура ДобавитьШагКомиссионныеПродажи(Таблица, РассчитыватьСостояние)
	
	Строка = Таблица.Добавить();
	Строка.Идентификатор = ШагКомиссионныеПродажиИдентификатор();
	Строка.УстаревшаяФункциональность = НСтр("ru = 'Комиссионные продажи, версия 11.0'");
	Строка.НоваяФункциональность = НСтр("ru = 'Комиссионные продажи, версия 11.5'");
	Строка.РекомендацияТребующаяДействий = Истина;
	Строка.РежимДействия = РежимДействияПереходВСписокДокументов();
	
	Строка.ТребуетсяРассчитатьСостояние = НЕ РассчитыватьСостояние;
	Если РассчитыватьСостояние Тогда
	
		Строка.ИспользуетсяУстаревшаяФункциональность = ШагКомиссионныеПродажиИспользуетсяУстаревшаяФункциональность();
		Строка.ИспользуетсяНоваяФункциональность = ШагКомиссионныеПродажиИспользуетсяНоваяФункциональность();
		Строка.ДатаДокумента = ШагКомиссионныеПродажиДатаПоследнегоДокумента();
		Строка.ЕстьДанныеПоУстаревшейФункциональности = ЗначениеЗаполнено(Строка.ДатаДокумента);
	
	КонецЕсли;
	
	Строка.Рекомендация = НСтр("ru = 'Для перехода на функциональность ""Комиссионные продажи, версия 11.5"" необходимо выполнить следующие шаги:
		|1. Создать новые договоры передачи на комиссию с указанием в них версии 11.5 (использование договоров обязательно). Создать новые соглашения, если используются.
		|2. Недооформленные документы (отчеты комиссионеров) в рамках соглашений и договоров версии 11.0 - дооформить по версии 11.0.
		|3. Для остающихся товаров оформить возвраты по версии комиссии 11.0  и последующую передачу по версии 11.5.
		|4. В настройках комиссионных продаж выбрать версию 11.5 взамен 11.0/11.5.'");
	
	
	ЗаполнитьДанныеВСтроке(Строка);

КонецПроцедуры

Функция ШагКомиссионныеПродажиИдентификатор() Экспорт

	Возврат 5;

КонецФункции

Функция ШагКомиссионныеПродажиИспользуетсяУстаревшаяФункциональность()
	
	ЗначениеОпций = ПолучитьФункциональнуюОпцию("ИспользоватьКомиссиюПриПродажах") И ПолучитьФункциональнуюОпцию("ВыбиратьВерсиюКомиссионныхПродаж");
	
	Если ЗначениеОпций Тогда
		Возврат Истина;
	Иначе
		Возврат ШагКомиссионныеПродажиЕстьОстаткиВФинансовомУчете();
	КонецЕсли;
	
КонецФункции

Функция ШагКомиссионныеПродажиИспользуетсяНоваяФункциональность()

	Возврат ПолучитьФункциональнуюОпцию("ИспользоватьКомиссиюПриПродажах") И НЕ ПолучитьФункциональнуюОпцию("ВыбиратьВерсиюКомиссионныхПродаж");

КонецФункции

Функция ШагКомиссионныеПродажиДатаПоследнегоДокумента()
	
	Дата = Дата(1, 1, 1); 
	
	Запрос = Новый Запрос(ШагКомиссионныеПродажиТекстЗапросаДатаПоследнегоДокумента());
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Дата = Выборка.ДатаДокумента;
	КонецЕсли;
	
	Возврат Дата;

КонецФункции

Функция ШагКомиссионныеПродажиТекстЗапросаДатаПоследнегоДокумента()

	Возврат 
	"ВЫБРАТЬ
	|	МАКСИМУМ(Таблица.Дата) КАК ДатаДокумента
	|ИЗ
	|	(ВЫБРАТЬ
	|		МАКСИМУМ(ТоварыПереданные.Период) КАК Дата
	|	ИЗ
	|		РегистрНакопления.ТоварыПереданныеНаКомиссию КАК ТоварыПереданные
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ
	|		МАКСИМУМ(Распоряжения.Дата)
	|	ИЗ
	|		Документ.ЗаказКлиента КАК Распоряжения
	|	ГДЕ
	|		Распоряжения.ХозяйственнаяОперация = ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.ПередачаНаКомиссию)
	|		И Распоряжения.Проведен
	|		И НЕ ЕСТЬNULL(Распоряжения.Договор.КомиссионныеПродажи25, ЛОЖЬ)
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ
	|		МАКСИМУМ(Распоряжения.Дата)
	|	ИЗ
	|		Документ.ЗаявкаНаВозвратТоваровОтКлиента КАК Распоряжения
	|	ГДЕ
	|		Распоряжения.ХозяйственнаяОперация = ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.ВозвратОтКомиссионера)
	|		И Распоряжения.Проведен
	|		И НЕ ЕСТЬNULL(Распоряжения.Договор.КомиссионныеПродажи25, ЛОЖЬ)) КАК Таблица";

КонецФункции

Функция ШагКомиссионныеПродажиЕстьОстаткиВФинансовомУчете()

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	Распоряжения.Распоряжение КАК Распоряжение
		|ИЗ
		|	РегистрСведений.РаспоряженияНаОтгрузкуИВозвратКВыполнению КАК Распоряжения
		|ГДЕ
		|	Распоряжения.СостояниеКОформлению <> ЗНАЧЕНИЕ(Перечисление.СостояниеОформленияДокументовПоРаспоряжению.Оформлены)
		|	И Распоряжения.ХозяйственнаяОперация = ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.ПередачаНаКомиссию)
		|	И НЕ ЕСТЬNULL(Распоряжения.Распоряжение.Договор.КомиссионныеПродажи25, ЛОЖЬ)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ТоварыПереданные.АналитикаУчетаНоменклатуры КАК АналитикаУчетаНоменклатуры,
		|	ТоварыПереданные.Соглашение КАК Соглашение,
		|	ТоварыПереданные.Организация КАК Организация,
		|	ТоварыПереданные.ВидЗапасов КАК ВидЗапасов,
		|	ТоварыПереданные.НомерГТД КАК НомерГТД,
		|	ТоварыПереданные.КоличествоОстаток КАК КоличествоОстаток,
		|	ТоварыПереданные.КоличествоПоРНПТОстаток КАК КоличествоПоРНПТОстаток
		|ИЗ
		|	РегистрНакопления.ТоварыПереданныеНаКомиссию.Остатки(, ) КАК ТоварыПереданные
		|ГДЕ
		|	(ТоварыПереданные.КоличествоОстаток <> 0
		|			ИЛИ ТоварыПереданные.КоличествоПоРНПТОстаток <> 0)";
	
	МассивРезультатов = Запрос.ВыполнитьПакет();
	Возврат НЕ МассивРезультатов[0].Пустой() ИЛИ НЕ МассивРезультатов[1].Пустой();

КонецФункции

