КонецФункции

Функция ШагПартионныйУчетДатаПоследнегоДокумента()
	
	Дата = Дата(1, 1, 1); 
	
	Если РасчетСебестоимостиПовтИсп.ПартионныйУчетВерсии22() Тогда

		Дата = РасчетСебестоимостиПовтИсп.ДатаПереходаНаПартионныйУчетВерсии22();
		
		Если ЗначениеЗаполнено(Дата) И РасчетСебестоимостиПовтИсп.ИспользовалсяПартионныйУчетДоПереходаНаВерсию22(Дата-1) = Истина Тогда
			
			Запрос = Новый Запрос;
			Запрос.УстановитьПараметр("Дата", Дата);
			
			Запрос.Текст =
			"ВЫБРАТЬ
			|	МАКСИМУМ(Т.Период) КАК Период
			|ИЗ
			|	(ВЫБРАТЬ
			|		МАКСИМУМ(Т.Период) КАК Период
			|	ИЗ
			|		РегистрНакопления.ПартииТоваровОрганизаций КАК Т
			|ГДЕ
			|	Т.Период < &Дата
			|	
			|	ОБЪЕДИНИТЬ ВСЕ
			|	
			|	ВЫБРАТЬ
			|		МАКСИМУМ(Т.Период)
			|	ИЗ
			|		РегистрНакопления.СебестоимостьТоваров КАК Т
			|ГДЕ
			|	Т.Период < &Дата
			|	) КАК Т";

			Выборка = Запрос.Выполнить().Выбрать();
			
			Если Выборка.Следующий() Тогда
				Дата = Выборка.Период;
			КонецЕсли;
			
		Иначе
			Дата = Дата(1, 1, 1); 
		КонецЕсли;
		
	ИначеЕсли РасчетСебестоимостиПовтИсп.ПартионныйУчетВерсии21() Тогда
		
		Запрос = Новый Запрос;
		Запрос.Текст =
		"ВЫБРАТЬ
		|	МАКСИМУМ(Т.Период) КАК Период
		|ИЗ
		|	(ВЫБРАТЬ
		|		МАКСИМУМ(Т.Период) КАК Период
		|	ИЗ
		|		РегистрНакопления.ПартииТоваровОрганизаций КАК Т
		|	
		|	ОБЪЕДИНИТЬ ВСЕ
		|	
		|	ВЫБРАТЬ
		|		МАКСИМУМ(Т.Период)
		|	ИЗ
		|		РегистрНакопления.СебестоимостьТоваров КАК Т) КАК Т";

		Выборка = Запрос.Выполнить().Выбрать();
		
		Если Выборка.Следующий() Тогда
			Дата = Выборка.Период;
		КонецЕсли;

	КонецЕсли;
	
	Возврат Дата;

КонецФункции

