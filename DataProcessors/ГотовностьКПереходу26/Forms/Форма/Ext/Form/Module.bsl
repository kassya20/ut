
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	УстановитьУсловноеОформление();
	
	ЦветВыбранногоРежима = ЦветаСтиля.ЦветТекстаФормы;
	ЦветНеВыбранногоРежима = ЦветаСтиля.ГиперссылкаЦвет;
	
	Элементы.ГиперссылкаВсе.ЦветФона = ЦветаСтиля.ПодсказкаСинхронизации;
	Элементы.ГиперссылкаВсе.ЦветТекста = ЦветВыбранногоРежима;
	Элементы.ГиперссылкаСостояниеИспользуется.ЦветТекста = ЦветНеВыбранногоРежима;
	
	Заголовок = НСтр("ru = 'Готовность к переходу на редакцию 11.6'");
	
	ЗаполнитьТаблицу(Ложь);
	ЗаполнитьТекстИнформационнойСтроки();
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	ПолучитьДанныеВДлительнойОперации();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура ГиперссылкаВсеНажатие(Элемент)
	
	УстановитьОтбор(Истина);
	
КонецПроцедуры

&НаКлиенте
Процедура ГиперссылкаСостояниеИспользуетсяНажатие(Элемент)
	
	УстановитьОтбор(Ложь);
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыТаблицаФункциональности

&НаКлиенте
Процедура ТаблицаФункциональностиВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	Если Поле.Имя = "ТаблицаФункциональностиОткрытьРекомендацию" Тогда
		СтандартнаяОбработка = Ложь;
		ТекДанные = Элементы.ТаблицаФункциональности.ТекущиеДанные;
		Если ТекДанные.РекомендацияТребующаяДействий Тогда
			ОткрытьФорму("Обработка.ГотовностьКПереходу26.Форма.ФормаРекомендация", Новый Структура("Текст", ТекДанные.Рекомендация)
				,,,,,,РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
		КонецЕсли;
		
	КонецЕсли;
	
	Если Поле.Имя = "ТаблицаФункциональностиДействие" Тогда
	
		ПроверитьВыполнитьПереходПоДействию();
	
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура КомандаОбновить(Команда)
	
	ПолучитьДанныеВДлительнойОперации();
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Процедура ПолучитьДанныеВДлительнойОперации()

	ДлительнаяОперация = ПолучитьДанныеДлительнаяОперация();
	
	Если ДлительнаяОперация = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ДополнительныеПараметры = Новый Структура;
	
	Если ДлительнаяОперация.Статус = "Выполнено" Тогда
		
		ПолучитьДанныеВДлительнойОперацииЗавершение(ДлительнаяОперация, ДополнительныеПараметры);
		
	ИначеЕсли ДлительнаяОперация.Статус = "Выполняется" Тогда
		
		ПараметрыОжидания = ДлительныеОперацииКлиент.ПараметрыОжидания(ЭтотОбъект);
		ПараметрыОжидания.ВыводитьОкноОжидания = Ложь;
		
		ОповещениеОЗавершении = Новый ОписаниеОповещения("ПолучитьДанныеВДлительнойОперацииЗавершение", ЭтотОбъект, ДополнительныеПараметры);
		ДлительныеОперацииКлиент.ОжидатьЗавершение(ДлительнаяОперация, ОповещениеОЗавершении, ПараметрыОжидания);
		
	КонецЕсли;	

КонецПроцедуры

&НаСервере
Функция ПолучитьДанныеДлительнаяОперация()
	
	ПараметрыПроцедуры = Новый Структура;
	
	ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияВФоне(УникальныйИдентификатор);
	ПараметрыВыполнения.НаименованиеФоновогоЗадания = НСтр("ru = 'Получение данных об устаревшей функциональности'");
	
	ДлительнаяОперация = ДлительныеОперации.ВыполнитьВФоне("Обработки.ГотовностьКПереходу26.ПолучитьДанныеУстаревшейФункциональностиВФоне",
		ПараметрыПроцедуры, ПараметрыВыполнения);
	Возврат ДлительнаяОперация;
	
КонецФункции

&НаКлиенте
Процедура ПолучитьДанныеВДлительнойОперацииЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если Результат.Статус = "Ошибка" Тогда
		ВызватьИсключение Результат.КраткоеПредставлениеОшибки;
	КонецЕсли;
	
	Если Результат.Статус = "Выполнено" Тогда
		ЗаполнитьДанные(Результат.АдресРезультата);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьДанные(АдресРезультата)

	ТаблицаФункциональности.Очистить();
	ЗаполнитьТаблицуИзХранилища(АдресРезультата);
	СкрытьКолонкиРасчетаСостояния();
	ПроверитьВывестиНадписьОГотовностиКПереходу();

КонецПроцедуры

&НаСервере
Процедура ПроверитьВывестиНадписьОГотовностиКПереходу()

	ДействияВыполнены = ТаблицаФункциональности.НайтиСтроки(Новый Структура("Статус", СтатусТребуетсяДействие())).Количество() = 0;
	Элементы.ГруппаПереходЗавершен.Видимость = ДействияВыполнены;
	Если ДействияВыполнены Тогда
		
		МаксимальнаяДата = Дата(1,1,1);
		Для каждого СтрокаТЗ Из ТаблицаФункциональности Цикл
			Если СтрокаТЗ.ДатаДокумента > МаксимальнаяДата Тогда
				МаксимальнаяДата = СтрокаТЗ.ДатаДокумента;
			КонецЕсли;
		КонецЦикла;
		
		Если МаксимальнаяДата <> Дата(1, 1, 1) Тогда
			
			ДатаВФормате = Формат(ДобавитьМесяц(МаксимальнаяДата, 2), "ДФ='MMММ yyyy'");
			Шаблон = НСтр("ru = 'Вы готовы к переходу на редакцию 11.6. Рекомендуемая дата: %1.'");
		
			
			ТекстСтроки = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(Шаблон, ДатаВФормате);
			
		Иначе
			
			ТекстСтроки = НСтр("ru = 'Вы готовы к переходу на редакцию 11.6.'");
		
			
		КонецЕсли;
		
		ИнформационнаяСтрокаГотово = Новый ФорматированнаяСтрока(
			ТекстСтроки,,
			ЦветаСтиля.РезультатУспехЦвет);
		
	КонецЕсли;

КонецПроцедуры

&НаСервере
Процедура УстановитьУсловноеОформление()
	
	УсловноеОформление.Элементы.Очистить();
	
	Элемент = УсловноеОформление.Элементы.Добавить();

	ПолеЭлемента = Элемент.Поля.Элементы.Добавить();
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(Элементы.ТаблицаФункциональности.Имя);
	
	ГруппаОтбора = Элемент.Отбор.Элементы.Добавить(Тип("ГруппаЭлементовОтбораКомпоновкиДанных"));
	ГруппаОтбора.ТипГруппы = ТипГруппыЭлементовОтбораКомпоновкиДанных.ГруппаИ;
	
	ОтборЭлемента = ГруппаОтбора.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ОтборЭлемента.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("ТаблицаФункциональности.ИспользуетсяУстаревшаяФункциональность");
	ОтборЭлемента.ВидСравнения = ВидСравненияКомпоновкиДанных.Равно;
	ОтборЭлемента.ПравоеЗначение = Ложь;
	
	ОтборЭлемента = ГруппаОтбора.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ОтборЭлемента.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("ТаблицаФункциональности.ИспользуетсяНоваяФункциональность");
	ОтборЭлемента.ВидСравнения = ВидСравненияКомпоновкиДанных.Равно;
	ОтборЭлемента.ПравоеЗначение = Ложь;
	
	ОтборЭлемента = ГруппаОтбора.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ОтборЭлемента.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("ТаблицаФункциональности.ЕстьДанныеПоУстаревшейФункциональности");
	ОтборЭлемента.ВидСравнения = ВидСравненияКомпоновкиДанных.Равно;
	ОтборЭлемента.ПравоеЗначение = Ложь;
	
	ОтборЭлемента = ГруппаОтбора.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ОтборЭлемента.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("ТаблицаФункциональности.ТребуетсяРассчитатьСостояние");
	ОтборЭлемента.ВидСравнения = ВидСравненияКомпоновкиДанных.Равно;
	ОтборЭлемента.ПравоеЗначение = Ложь;
	
	Элемент.Оформление.УстановитьЗначениеПараметра("ЦветТекста", ЦветаСтиля.ЦветТекстаОтмененнойСтрокиДокумента);

КонецПроцедуры

&НаКлиенте
Процедура СкрытьКолонкиРасчетаСостояния()

	Элементы.ТаблицаФункциональностиРассчитаноСостояние.Видимость = Ложь;
	Элементы.ТаблицаФункциональностиРассчитаноСостояние1.Видимость = Ложь;
	Элементы.ТаблицаФункциональностиРассчитаноСостояние2.Видимость = Ложь;

КонецПроцедуры

&НаСервере
Процедура ЗаполнитьТекстИнформационнойСтроки()
	
	Шаблон = НСтр("ru = 'Функциональность устарела и будет удалена в редакции 11.6. Необходимо выполнить переход на новую функциональность.
			|После отключения устаревшей функциональности рекомендуется до перехода на редакцию 11.6 выполнить как минимум 2 закрытия месяца.
			|Корректировка закрытых периодов, в которых система работала на старой функциональности, будет невозможна в редакции 11.6.'");
	
	
	ИнформационнаяСтрока = Новый ФорматированнаяСтрока(Шаблон,, ЦветаСтиля.ЦветТекстаПредупреждение);
	Элементы.ИнформационнаяПанельСтраницы.ТекущаяСтраница = Элементы.ИнформационнаяПанельСтраницаОтобразить;

КонецПроцедуры

&НаСервере
Процедура ЗаполнитьТаблицу(РассчитыватьСостояние)

	ТаблицаУстаревшейФункциональности = Обработки.ГотовностьКПереходу26.ТаблицаУстаревшейФункциональности(РассчитыватьСостояние);
	ТаблицаФункциональности.Загрузить(ТаблицаУстаревшейФункциональности);
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьТаблицуИзХранилища(АдресРезультата)

	ТаблицаУстаревшейФункциональности = ПолучитьИзВременногоХранилища(АдресРезультата);
	ТаблицаФункциональности.Загрузить(ТаблицаУстаревшейФункциональности);
	
КонецПроцедуры

&НаКлиенте
Процедура ПроверитьВыполнитьПереходПоДействию()
	
	ОчиститьСообщения();
	ТекДанные = Элементы.ТаблицаФункциональности.ТекущиеДанные;
	
	Если ПустаяСтрока(ТекДанные.Действие) Тогда
		Возврат;
	КонецЕсли;
	
	Если Не ЕстьПравоПерехода(ТекДанные.Идентификатор) Тогда
		
		Текст = НСтр("ru = 'Недостаточно прав для перехода, обратитесь к администратору.'");
		ОбщегоНазначенияКлиент.СообщитьПользователю(Текст);
		
		Возврат;
	
	КонецЕсли;
	
	Если ТекДанные.Идентификатор = 1 Тогда
	ИначеЕсли ТекДанные.Идентификатор = 2 Тогда
	ИначеЕсли ТекДанные.Идентификатор = 3 Тогда
	ИначеЕсли ТекДанные.Идентификатор = 4 Тогда
	ИначеЕсли ТекДанные.Идентификатор = 5 Тогда
		ОткрытьФорму("Обработка.ЖурналДокументовПродажи.Форма.СписокДокументов",, ЭтотОбъект, УникальныйИдентификатор);
	ИначеЕсли ТекДанные.Идентификатор = 6 Тогда
		ОткрытьФорму("Обработка.ПомощникПереходаНаЦенообразованиеВерсии25.Форма.ПереходНаЦенообразованиеВерсии25",, ЭтотОбъект, УникальныйИдентификатор);
	ИначеЕсли ТекДанные.Идентификатор = 7 Тогда
		ОткрытьФорму("Обработка.ПанельАдминистрированияУТ.Форма.Казначейство",, ЭтотОбъект, УникальныйИдентификатор);
	ИначеЕсли ТекДанные.Идентификатор = 8 Тогда
		//++ Локализация
		ОткрытьФорму("Обработка.ПанельАдминистрированияУТ.Форма.ДопНастройкиУчетаСебестоимости",, ЭтотОбъект, УникальныйИдентификатор);
		//-- Локализация
	ИначеЕсли ТекДанные.Идентификатор = 9 Тогда
	ИначеЕсли ТекДанные.Идентификатор = 10 Тогда
	ИначеЕсли ТекДанные.Идентификатор = 11 Тогда
	ИначеЕсли ТекДанные.Идентификатор = 12 Тогда
		// Действий не требуется
	ИначеЕсли ТекДанные.Идентификатор = 13 Тогда
		ОткрытьФорму("Обработка.ПанельАдминистрированияБСП.Форма.НастройкиПользователейИПрав",, ЭтотОбъект, УникальныйИдентификатор);
	КонецЕсли;

КонецПроцедуры

&НаСервереБезКонтекста
Функция ЕстьПравоПерехода(Идентификатор)
	
	Если Идентификатор = 1 Тогда
	ИначеЕсли Идентификатор = 2 Тогда
	ИначеЕсли Идентификатор = 3 Тогда
	ИначеЕсли Идентификатор = 4 Тогда
	ИначеЕсли Идентификатор = 5 Тогда
		Возврат ПравоДоступа("Использование", Метаданные.Обработки.ЖурналДокументовПродажи);
	ИначеЕсли Идентификатор = 6 Тогда
		Возврат ПравоДоступа("Использование", Метаданные.Обработки.ПомощникПереходаНаЦенообразованиеВерсии25);
	ИначеЕсли Идентификатор = 7 Тогда
		Возврат ПравоДоступа("Использование", Метаданные.Обработки.ПанельАдминистрированияУТ);
	ИначеЕсли Идентификатор = 8 Тогда
		//++ Локализация
		Возврат ПравоДоступа("Использование", Метаданные.Обработки.ПанельАдминистрированияУТ);
		//-- Локализация
	ИначеЕсли Идентификатор = 9 Тогда
	ИначеЕсли Идентификатор = 10 Тогда
	ИначеЕсли Идентификатор = 11 Тогда
	ИначеЕсли Идентификатор = 12 Тогда
		// Действий не требуется
		Возврат Ложь;
	ИначеЕсли Идентификатор = 13 Тогда
		Возврат ПравоДоступа("Использование", Метаданные.Обработки.ПанельАдминистрированияБСП);
	КонецЕсли;
	
	Возврат Ложь;

КонецФункции



&НаСервере
Процедура УстановитьОтбор(ОтобразитьВсе)
	
	ЦветФона = ЦветаСтиля.ПодсказкаСинхронизации;
	ФонФормы = Новый Цвет();
	
	Элементы.ГиперссылкаВсе.ЦветФона = ?(ОтобразитьВсе, ЦветФона, ФонФормы);
	Элементы.ГиперссылкаВсе.ЦветТекста = ?(ОтобразитьВсе, ЦветВыбранногоРежима, ЦветНеВыбранногоРежима);
	Элементы.ГиперссылкаСостояниеИспользуется.ЦветФона = ?(ОтобразитьВсе, ФонФормы, ЦветФона);
	Элементы.ГиперссылкаСостояниеИспользуется.ЦветТекста = ?(ОтобразитьВсе, ЦветНеВыбранногоРежима, ЦветВыбранногоРежима);
	
	Если ОтобразитьВсе Тогда
		Элементы.ТаблицаФункциональности.ОтборСтрок = Неопределено;
	Иначе
		Элементы.ТаблицаФункциональности.ОтборСтрок = Новый ФиксированнаяСтруктура("Статус", СтатусТребуетсяДействие());
	КонецЕсли;
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Функция СтатусТребуетсяДействие()
	Возврат 1;
КонецФункции

#КонецОбласти
