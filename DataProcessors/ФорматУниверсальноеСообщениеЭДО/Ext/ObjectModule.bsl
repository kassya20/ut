#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ОписаниеПеременных

Перем ДатаФормирования; // Дата

#КонецОбласти

#Область СлужебныйПрограммныйИнтерфейс

// Возвращаемое значение:
//  Массив Из см. ОбщегоНазначенияБЭДКлиентСервер.НовыеПараметрыОшибки
//
Функция ПолучитьОшибкиЗаполнения() Экспорт
	Возврат Новый Массив;
КонецФункции

// Параметры:
//  СоответствиеНоменклатуры - см. СопоставлениеНоменклатурыКонтрагентов.НайтиСоответствиеНоменклатуры
//
Процедура ЗаполнитьДанныеСопоставления(СоответствиеНоменклатуры) Экспорт

КонецПроцедуры

// Возвращаемое значение:
//  Соответствие Из КлючИЗначение:
//  * Ключ - см. СопоставлениеНоменклатурыКонтрагентов.ИдентификаторНоменклатурыКонтрагентаПоНатуральнымКлючам
//  * Значение - см. ФорматыЭДО.НовыеДанныеДляСопоставленияТоваров
//
Функция СтрокиТребующиеСопоставления() Экспорт
	
	Возврат Новый Соответствие;

КонецФункции

// Параметры:
//  ДополнительныеДанные - см. ФорматыЭДО.НовыеДанныеДляФормированияОсновногоТитула 
//
Процедура УстановитьДополнительныеДанныеДляФормирования(ДополнительныеДанные) Экспорт

КонецПроцедуры

#Область ФормированиеЭлектронногоДокумента

// Параметры:
//  ДанныеДляФормирования - см. ФорматыЭДО.НовыеДанныеДляФормированияСлужебногоСообщения
// 
// Возвращаемое значение:
//  Строка - Идентификатор файла
Функция ИдентификаторФайла(ДанныеДляФормирования)
	
	ДанныеШаблона = Новый Структура;
	ДанныеШаблона.Вставить("ТипФайла", "DP_UNISOOBSCH");
	ДанныеШаблона.Вставить("Получатель", ДанныеДляФормирования.Участники.Получатель.Абонент.Идентификатор);
	ДанныеШаблона.Вставить("Отправитель", ДанныеДляФормирования.Участники.Отправитель.Идентификатор);
	ДанныеШаблона.Вставить("Дата", Формат(ДатаФормирования, "ДФ=yyyyMMdd"));
	ДанныеШаблона.Вставить("УникальныйИдентификатор", ДанныеДляФормирования.УникальныйИдентификатор);
	
	Возврат СтроковыеФункцииКлиентСервер.ВставитьПараметрыВСтроку(
		"[ТипФайла]_[Получатель]_[Отправитель]_[Дата]_[УникальныйИдентификатор]", ДанныеШаблона);

КонецФункции

// Возвращаемое значение:
//  Строка - Пространство имен по данным формата
//
Функция ПространствоИмен() Экспорт
	Возврат "DP_UNISOOBSCH_1_982_02_05_01_01";
КонецФункции

// Параметры:
//  ДанныеДляФормирования - см. ФорматыЭДО.НовыеДанныеДляФормированияСлужебногоСообщения
Процедура ЗаполнитьОбъектXDTO(ДанныеДляФормирования) Экспорт 
	
	Файл = НовыйXDTOОбъект();
	
	Идентификатор = ИдентификаторФайла(ДанныеДляФормирования);
	РаботаСФайламиБЭД.ЗаполнитьСвойствоXDTO(Файл, "ИдФайл", Идентификатор, Истина);
	РаботаСФайламиБЭД.ЗаполнитьСвойствоXDTO(Файл, "ВерсПрог", ДанныеДляФормирования.ВерсияПрограммы, Истина);
	РаботаСФайламиБЭД.ЗаполнитьСвойствоXDTO(Файл, "ВерсФорм", "5.01", Истина);

	ДокументУС = ДокументУС(ДанныеДляФормирования);
	РаботаСФайламиБЭД.ЗаполнитьСвойствоXDTO(Файл, "Документ", ДокументУС, Истина);
	ОбъектXDTO = Файл;
КонецПроцедуры

// Возвращаемое значение:
//  См. РаботаСФайламиБЭДКлиентСервер.НовоеОписаниеФайла
Функция СформироватьФайл() Экспорт
	ПространствоИмен = ПространствоИмен();
	
	Результат = РаботаСФайламиБЭДКлиентСервер.НовоеОписаниеФайла();
	
	ДвоичныеДанные = РаботаСФайламиБЭД.XDTOВДвоичныеДанные(ОбъектXDTO, Ложь, , "Файл");
	Результат.ДвоичныеДанные = ОбщегоНазначенияБЭД.УдалитьПространствоИмен(ДвоичныеДанные, ПространствоИмен);
	Результат.ИмяФайла = СтрШаблон("%1.%2", ОбъектXDTO.ИдФайл, "xml");
	
	Возврат Результат; 
КонецФункции

// Свойства универсального сообщения.
// 
// Возвращаемое значение:
//  Структура - Свойства универсального сообщения:
// * ИмяФайлаНазначения - Строка 
// * ТекстСообщения - Строка
// * Статус - Строка 
Функция СвойстваУниверсальногоСообщения() Экспорт

	Результат = Новый Структура;
	Результат.Вставить("ИмяФайлаНазначения", РаботаСФайламиБЭД.ЗначениеСвойстваXDTO(ОбъектXDTO, "Документ.СведУС.ИмяПолФайл"));
	Результат.Вставить("ТекстСообщения", РаботаСФайламиБЭД.ЗначениеСвойстваXDTO(ОбъектXDTO, "Документ.СвСобытДок.ТекстУС"));
	Результат.Вставить("Статус", РаботаСФайламиБЭД.ЗначениеСвойстваXDTO(ОбъектXDTO, "Документ.СвСобытДок.СтатусУС"));
	
	Возврат Результат;
КонецФункции 

// Возвращаемое значение:
//  Дата
Функция ДатаИВремяФормирования() Экспорт

	ДатаСтрокой = РаботаСФайламиБЭД.ЗначениеСвойстваXDTO(ОбъектXDTO, "Документ.СведУС.ДатаФорм");
	ВремяСтрокой = РаботаСФайламиБЭД.ЗначениеСвойстваXDTO(ОбъектXDTO, "Документ.СведУС.ВремФорм");
	ДатаИВремяОтправкиСтрокой = СтрШаблон("%1 %2", ДатаСтрокой, ВремяСтрокой);
	Результат = ОбщегоНазначенияБЭДКлиентСервер.ПолучитьДатуВремяИзСтроки(ДатаИВремяОтправкиСтрокой);
	
	Возврат Результат;
КонецФункции

#КонецОбласти

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция ДокументУС(ДанныеДляФормирования)

	ДокументУС = ПолучитьXDTOОбъект(АнонимныйТип("Файл.Документ"));
	РаботаСФайламиБЭД.ЗаполнитьСвойствоXDTO(ДокументУС, "КНД", "1115144", Истина);
	
	СведУС = СведУС(ДанныеДляФормирования);
	РаботаСФайламиБЭД.ЗаполнитьСвойствоXDTO(ДокументУС, "СведУС", СведУС, Истина);
	
	СвСобытДок = СвСобытДок(ДанныеДляФормирования);
	ДокументУС.СвСобытДок.Добавить(СвСобытДок);
	
	ОтпрУС = ОтпрУС(ДанныеДляФормирования);
	РаботаСФайламиБЭД.ЗаполнитьСвойствоXDTO(ДокументУС, "ОтпрУС", ОтпрУС, Истина);
	
	ПолучУС = ПолучУС(ДанныеДляФормирования);
	РаботаСФайламиБЭД.ЗаполнитьСвойствоXDTO(ДокументУС, "ПолучУС", ПолучУС, Истина);

	Возврат ДокументУС; 

КонецФункции

Функция СведУС(ДанныеДляФормирования)

	СведУС = ПолучитьXDTOОбъект(АнонимныйТип("Файл.Документ.СведУС"));
	РаботаСФайламиБЭД.ЗаполнитьСвойствоXDTO(СведУС, "ДатаФорм", Формат(ДатаФормирования, "ДФ=dd.MM.yyyy"), Истина);
	РаботаСФайламиБЭД.ЗаполнитьСвойствоXDTO(СведУС, "ВремФорм", Формат(ДатаФормирования, "ДФ=HH.mm.ss"), Истина); 
	РаботаСФайламиБЭД.ЗаполнитьСвойствоXDTO(СведУС, "ИмяПолФайл", ДанныеДляФормирования.Основание.ИмяБезРасширения, Истина);
	
	Возврат СведУС;

КонецФункции

Функция СвСобытДок(ДанныеДляФормирования)
	
	СвСобытДок = ПолучитьXDTOОбъект(АнонимныйТип("Файл.Документ.СвСобытДок"));
	СоответствиеЭлементовРегламентаТипуУС = СоответствиеЭлементаРегламентаТипуУС();
	РаботаСФайламиБЭД.ЗаполнитьСвойствоXDTO(СвСобытДок, 
		"СтатусУС", 
		СоответствиеЭлементовРегламентаТипуУС[ДанныеДляФормирования.ТипЭлементаРегламента], 
		Истина);
	РаботаСФайламиБЭД.ЗаполнитьСвойствоXDTO(СвСобытДок, "ТекстУС", ДанныеДляФормирования.ТекстУточнения);
	
	Возврат СвСобытДок;

КонецФункции

Функция ОтпрУС(ДанныеДляФормирования)

	ОтпрУС = ПолучитьXDTOОбъект(АнонимныйТип("Файл.Документ.ОтпрУС"));
	РаботаСФайламиБЭД.ЗаполнитьСвойствоXDTO(ОтпрУС, "ИдОтпрУС", ДанныеДляФормирования.Участники.Отправитель.Идентификатор, Истина);
	Возврат ОтпрУС;
	
КонецФункции

Функция ПолучУС(ДанныеДляФормирования)

	ПолучУС = ПолучитьXDTOОбъект(АнонимныйТип("Файл.Документ.ПолучУС"));                                                                        
	РаботаСФайламиБЭД.ЗаполнитьСвойствоXDTO(ПолучУС, "ИдПолучУС", ДанныеДляФормирования.Участники.Получатель.Абонент.Идентификатор, Истина);
	Возврат ПолучУС;
	
КонецФункции

// Возвращаемое значение:
//  ОбъектXDTO
//
Функция НовыйXDTOОбъект()
	ПространствоИмен = ПространствоИмен();
	Возврат РаботаСФайламиБЭД.ПолучитьОбъектТипаCML("{" + ПространствоИмен + "}.Файл", ПространствоИмен);
КонецФункции

Функция ПолучитьXDTOОбъект(ТипОбъекта)
	Возврат РаботаСФайламиБЭД.ПолучитьОбъектТипаCML(ТипОбъекта, ПространствоИмен());
КонецФункции  

Функция АнонимныйТип(Тип)
	Возврат СтрШаблон("{%1}.%2", ПространствоИмен(), Тип);
КонецФункции     

Функция СоответствиеЭлементаРегламентаТипуУС()
		
	Результат = Новый Соответствие;
	
	СтатусыУС = СтатусыУС();	

	Результат.Вставить(Перечисления.ТипыЭлементовРегламентаЭДО.УС_ИОП, СтатусыУС.ИзвещениеОПолучении);
	Результат.Вставить(Перечисления.ТипыЭлементовРегламентаЭДО.УС_УОУ, СтатусыУС.УведомлениеОбУточнении);
	Результат.Вставить(Перечисления.ТипыЭлементовРегламентаЭДО.УС_ОтказВПодписи, СтатусыУС.ОтказВПодписи);
	Результат.Вставить(Перечисления.ТипыЭлементовРегламентаЭДО.УС_ДополнительнаяИнформация, СтатусыУС.ДополнительнаяИнформация);
	Возврат Результат;
	
КонецФункции

Функция СтатусыУС()
	Результат = Новый Структура;
	Результат.Вставить("ИзвещениеОПолучении", "1999");
	Результат.Вставить("УведомлениеОбУточнении", "2999");
	Результат.Вставить("ОтказВПодписи", "3999");
	Результат.Вставить("ДополнительнаяИнформация", "4002");
	Возврат Результат;
КонецФункции

Процедура Инициализировать()
	
	ДатаФормирования = ТекущаяДатаСеанса();
	
КонецПроцедуры

#КонецОбласти

#Область Инициализация

Инициализировать();

#КонецОбласти

#КонецЕсли