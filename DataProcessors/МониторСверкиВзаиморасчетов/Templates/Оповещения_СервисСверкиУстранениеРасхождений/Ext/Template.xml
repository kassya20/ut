		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ РАЗЛИЧНЫЕ
	ВложенныйЗапрос.Ссылка КАК Ссылка,
	ВложенныйЗапрос.Роль КАК Роль
ПОМЕСТИТЬ втПрофилиСДоступомКСервисуСверки
ИЗ
	(ВЫБРАТЬ
		РолиПрофиля.Ссылка КАК Ссылка,
		РолиПрофиля.Роль КАК Роль
	ИЗ
		Справочник.ПрофилиГруппДоступа.Роли КАК РолиПрофиля
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ИдентификаторыОбъектовМетаданных КАК Идентификаторы
			ПО РолиПрофиля.Роль = Идентификаторы.Ссылка
			И Идентификаторы.Имя = &amp;ИмяРолиДоступаКСервисуСверки
			
	ОБЪЕДИНИТЬ ВСЕ

	ВЫБРАТЬ
		РолиПрофиля.Ссылка КАК Ссылка,
		РолиПрофиля.Роль КАК Роль
	ИЗ
		Справочник.ПрофилиГруппДоступа.Роли КАК РолиПрофиля
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ИдентификаторыОбъектовМетаданных КАК Идентификаторы
			ПО РолиПрофиля.Роль = Идентификаторы.Ссылка
			И Идентификаторы.Имя = &amp;ИмяРолиПолныеПрава
) КАК ВложенныйЗапрос
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ РАЗЛИЧНЫЕ
	ПользователиГруппДоступа.Пользователь КАК Пользователь,
	ГруппыДоступа.Ссылка КАК ГруппаДоступа,
	ГруппыДоступа.Профиль КАК Профиль
ПОМЕСТИТЬ втПользователиСервисаСверки
ИЗ
	Справочник.ГруппыДоступа.Пользователи КАК ПользователиГруппДоступа
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ГруппыДоступа КАК ГруппыДоступа
			ПО ПользователиГруппДоступа.Ссылка = ГруппыДоступа.Ссылка
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ втПрофилиСДоступомКСервисуСверки КАК ПрофилиСДоступом
			ПО (ГруппыДоступа.Профиль = ПрофилиСДоступом.Ссылка)
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Пользователи КАК ВсеПользователи
		ПО ПользователиГруппДоступа.Пользователь = ВсеПользователи.Ссылка
ГДЕ
	НЕ ВсеПользователи.ПометкаУдаления
	И НЕ ВсеПользователи.Недействителен
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	УстраненныеРасхождения.Организация КАК Организация,
	УстраненныеРасхождения.Контрагент КАК Контрагент,
	СУММА(УстраненныеРасхождения.СуммаДокумента) КАК СуммаДокумента,
	СУММА(УстраненныеРасхождения.НДСДокумента) КАК НДСДокумента
ПОМЕСТИТЬ втУстраненыРасхожденияПредварительная
ИЗ
	РегистрСведений.СервисСверкиРасчетовУстраненныеРасхождения КАК УстраненныеРасхождения
	ЛЕВОЕ СОЕДИНЕНИЕ ВТКэшРеквизитов КАК ВТКэшРеквизитов
		ПО УстраненныеРасхождения.Организация = ВТКэшРеквизитов.Организация
		И (УстраненныеРасхождения.Контрагент = ВТКэшРеквизитов.Контрагент
			ИЛИ ВТКэшРеквизитов.Контрагент = НЕОПРЕДЕЛЕНО)
ГДЕ
	ВТКэшРеквизитов.Контрагент ЕСТЬ NULL
	
СГРУППИРОВАТЬ ПО
	УстраненныеРасхождения.Организация,
	УстраненныеРасхождения.Контрагент
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	УстраненыРасхождения.Организация КАК Организация,
	НЕОПРЕДЕЛЕНО КАК Контрагент,
	КОЛИЧЕСТВО(УстраненыРасхождения.Контрагент) КАК ВсегоКонтрагентов,
	СУММА(УстраненыРасхождения.СуммаДокумента) КАК СуммаДокумента,
	СУММА(УстраненыРасхождения.НДСДокумента) КАК НДСДокумента
ПОМЕСТИТЬ втМногоКонтрагентов
ИЗ
	втУстраненыРасхожденияПредварительная КАК УстраненыРасхождения

СГРУППИРОВАТЬ ПО
	УстраненыРасхождения.Организация
ИМЕЮЩИЕ
	КОЛИЧЕСТВО(УстраненыРасхождения.Контрагент) &gt; &amp;ПределГруппировки
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	МногоКонтрагентов.Организация КАК Организация,
	МногоКонтрагентов.Контрагент КАК Контрагент,
	МногоКонтрагентов.ВсегоКонтрагентов КАК ВсегоКонтрагентов,
	МногоКонтрагентов.СуммаДокумента КАК СуммаДокумента,
	МногоКонтрагентов.НДСДокумента КАК НДСДокумента
ПОМЕСТИТЬ втУстраненыРасхождения
ИЗ
	втМногоКонтрагентов КАК МногоКонтрагентов
	
ОБЪЕДИНИТЬ ВСЕ

ВЫБРАТЬ
	УстраненыРасхождения.Организация КАК Организация,
	УстраненыРасхождения.Контрагент КАК Контрагент,
	1 КАК ВсегоКонтрагентов,
	УстраненыРасхождения.СуммаДокумента КАК СуммаДокумента,
	УстраненыРасхождения.НДСДокумента КАК НДСДокумента
ИЗ
	втУстраненыРасхожденияПредварительная КАК УстраненыРасхождения
	ЛЕВОЕ СОЕДИНЕНИЕ втМногоКонтрагентов КАК МногоКонтрагентов
	ПО УстраненыРасхождения.Организация = МногоКонтрагентов.Организация
ГДЕ
	МногоКонтрагентов.Организация ЕСТЬ NULL
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	УстраненыРасхождения.Организация КАК ИсточникОповещения,
	НЕОПРЕДЕЛЕНО КАК КонтекстОповещения,
	ПользователиСервисаСверки.Пользователь КАК ПолучательОповещения,
	УстраненыРасхождения.Организация КАК Организация,
	УстраненыРасхождения.Контрагент КАК Контрагент,
	УстраненыРасхождения.ВсегоКонтрагентов КАК ВсегоКонтрагентов,
	ВЫРАЗИТЬ(УстраненыРасхождения.СуммаДокумента КАК ЧИСЛО(32,2)) КАК СуммаДокумента,
	ВЫРАЗИТЬ(УстраненыРасхождения.НДСДокумента КАК ЧИСЛО(32,2)) КАК НДСДокумента
ИЗ
	втПользователиСервисаСверки КАК ПользователиСервисаСверки
	ЛЕВОЕ СОЕДИНЕНИЕ втУстраненыРасхождения КАК УстраненыРасхождения
	ПО ИСТИНА</query>
	</dataSet>
	<calculatedField>
		<dataPath>ТекстОповещения</dataPath>
		<expression>ВЫБОР  
	КОГДА Контрагент = НЕОПРЕДЕЛЕНО 
		ТОГДА &amp;ПоДаннымСервиса+ " " + Представление(Организация) + &amp;УстраненыРасхожденияСКонтрагентами + " ("+ Строка(ВсегоКонтрагентов) + " " + &amp;ШтНаСумму + " " + Строка(СуммаДокумента) + " " + &amp;Руб
	ИНАЧЕ
		&amp;ПоДаннымСервиса + " " + Представление(Организация) + " 
	" + &amp;УстраненыРасхожденияСКонтрагентом + " " + Представление(Контрагент) + " " + &amp;НаСумму + " " + Строка(СуммаДокумента) + " " + &amp;Руб
КОНЕЦ</expression>
		<title xsi:type="v8:LocalStringType">
			<v8:item>
				<v8:lang>ru</v8:lang>
				<v8:content>Текст оповещения</v8:content>
