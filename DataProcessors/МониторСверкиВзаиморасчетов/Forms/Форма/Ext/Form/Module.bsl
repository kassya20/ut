#Область ОбработчикиСобытийЭлементовТаблицыФормыСверкаСКонтрагентами

&НаКлиенте
Процедура СверкаСКонтрагентамиВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	Если ЗапускИзКонфигурации Тогда
		ОбъектФормы = "Обработка.";
	Иначе
		ОбъектФормы = "ВнешняяОбработка.";
	КонецЕсли;
	
	ТекущаяСтрока = Элемент.ТекущиеДанные;
	
	ПараметрыФормы = Новый Структура("Отбор", Новый Структура);
	ПараметрыФормы.Вставить("УникальныйИдентификатор", УникальныйИдентификатор);
	ПараметрыФормы.Вставить("НачалоПериода", Объект.НачалоПериода);
	ПараметрыФормы.Вставить("КонецПериода", Объект.КонецПериода);
	ПараметрыФормы.Вставить("Организация", Объект.Организация);
	ПараметрыФормы.Вставить("Контрагент", ТекущаяСтрока.Контрагент);
	ПараметрыФормы.Вставить("Менеджер", ТекущаяСтрока.Менеджер);
	ПараметрыФормы.Вставить("Валюта", ТекущаяСтрока.Валюта);
	ПараметрыФормы.Вставить("ВключатьДоговорыБезОборотов", ВключатьДоговорыБезОборотов);
	ТипыРасчетов = Новый Массив;
	Для Каждого Отбор Из ОтборТипыРасчетов Цикл
		Если Отбор.Использование Тогда
			ТипыРасчетов.Добавить(Отбор.ТипРасчетов);
		КонецЕсли;
	КонецЦикла;
	ПараметрыФормы.Вставить("ТипыРасчетов", ТипыРасчетов);
	//++ Локализация
	ПараметрыФормы.Вставить("УчастникЭДО", ТекущаяСтрока.УчастникЭДО);
	//-- Локализация
	
	Если Поле.Имя = "СверкаСКонтрагентамиКонтрагент" Тогда
		ОткрытьЗначениеАсинх(ТекущаяСтрока.Контрагент);
		
	ИначеЕсли Поле.Имя = "СверкаСКонтрагентамиДолгКонтрагента"
			ИЛИ Поле.Имя = "СверкаСКонтрагентамиНашДолг" Тогда
		ОткрытьВедомостьРасчетов(Элемент, ТекущаяСтрока);
	
	ИначеЕсли (Поле.Имя = "СверкаСКонтрагентамиСтатусСверкиПредставление"
			ИЛИ Поле.Имя = "СверкаСКонтрагентамиСверка20") Тогда
		ОткрытьФорму(ОбъектФормы + "МониторСверкиВзаиморасчетов.Форма.СостояниеСверки",ПараметрыФормы,,Истина);
	//++ Локализация
	ИначеЕсли Поле.Имя = "СверкаСКонтрагентамиНеПолученыДокументыПоЭДО" И ТекущаяСтрока.НеЗавершенОбменЭДОКоличество > 0 Тогда
		ОткрытьФорму(ОбъектФормы + "МониторСверкиВзаиморасчетов.Форма.ДокументыНеПолученныеПоЭДО",ПараметрыФормы,ЭтотОбъект,,,,,РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	//-- Локализация
	
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура СверкаСКонтрагентамиКомментарийТекстПриИзменении(Элемент)
	
	ТекущаяСтрока = Элементы.СверкаСКонтрагентами.ТекущиеДанные;
	Отбор = Новый Структура("Контрагент", ТекущаяСтрока.Контрагент);
	НайденныеСтроки = СверкаСКонтрагентами.НайтиСтроки(Отбор);
	Если НайденныеСтроки.Количество() > 1 Тогда
		Для Каждого Строка Из НайденныеСтроки Цикл
			Строка.Комментарий = ТекущаяСтрока.Комментарий;
		КонецЦикла;
	КонецЕсли;
	ЗаписатьКомментарийНаСревере(ТекущаяСтрока.Контрагент, ТекущаяСтрока.Комментарий);
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура УстановитьИнтервалПериода(Команда)
	
	ОповещениеОЗавершении = Новый ОписаниеОповещения("УстановитьИнтервалЗавершение", ЭтотОбъект);
	ПараметрыПериода = Новый Структура("ДатаНачала, ДатаОкончания", "НачалоПериода", "КонецПериода");
	ОбщегоНазначенияУТКлиент.РедактироватьПериод(Объект, ПараметрыПериода, ОповещениеОЗавершении);
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьДанныеСверки(Команда)
	
	ОчиститьСообщения();
	Отказ = Ложь;
	Если НЕ ЗначениеЗаполнено(Объект.НачалоПериода) Тогда
		ТекстСообщение = НСтр("ru = 'Не указано ""Начало периода""'");
		ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщение,,"НачалоПериода","Объект.НачалоПериода",Отказ);
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(Объект.КонецПериода) Тогда
		ТекстСообщение = НСтр("ru = 'Не указан ""Конец периода""'");
		ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщение,,"КонецПериода","Объект.КонецПериода",Отказ);
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(Объект.Организация) Тогда
		ТекстСообщение = НСтр("ru = 'Не указана ""Организация""'");
		ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщение,,"Организация","Объект.Организация",Отказ);
	КонецЕсли;
	
	Если НЕ Отказ Тогда
		ЗаполнитьПоДаннымРасчетов();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПоказатьБыстрыеОтборы(Команда)
	
	ПоказыватьБыстрыеОтборы = НЕ Элементы.ГруппаОтборы.Видимость;
	УстановитьВидимостьБыстрыхОтборов(Элементы.БыстрыеОтборы, Элементы.ГруппаОтборы, ПоказыватьБыстрыеОтборы);
	
КонецПроцедуры

&НаКлиенте
Процедура СоздатьДокументСверки(Команда)
	
	СоздатьДокументСверкиВзаиморасчетов();
	
КонецПроцедуры

&НаКлиенте
Процедура ПомощникСозданияСверки(Команда)
	
	ОчиститьСообщения();
	Если НЕ ПроверитьЗаполнение() Тогда
		Возврат;
	КонецЕсли;
	
	ТекущаяСтрока = Элементы.СверкаСКонтрагентами.ТекущиеДанные;
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("Организация", Объект.Организация);
	ПараметрыФормы.Вставить("Контрагент", СписокКонтрагентов);
	ПараметрыФормы.Вставить("НачалоПериода", Объект.НачалоПериода);
	ПараметрыФормы.Вставить("КонецПериода", Объект.КонецПериода);
	ПараметрыФормы.Вставить("ДоговорыБезОборотов", ВключатьДоговорыБезОборотов);
	ПараметрыФормы.Вставить("ОсновнойМенеджер", Менеджер);
	ПараметрыФормы.Вставить("ЗаменитьНастройкиФормы", Истина);
	ВыбраныеТипыРасчетов = Новый СписокЗначений;
	Для Каждого Отбор Из ОтборТипыРасчетов Цикл
		Если Отбор.Использование Тогда
			ВыбраныеТипыРасчетов.Добавить(Отбор.ТипРасчетов);
		КонецЕсли;
	КонецЦикла;
	ПараметрыФормы.Вставить("ТипыРасчетов", ВыбраныеТипыРасчетов);
	
	ОткрытьФорму("Документ.СверкаВзаиморасчетов2_5_11.Форма.ФормаПомощникаСоздания", ПараметрыФормы);
	
КонецПроцедуры

