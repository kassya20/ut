#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ПрограммныйИнтерфейс

// Процедура формирует расшифровочный отчет в форме состояния сверки
// 
// Параметры:
//    ПараметрыСверки - Структура - Структура с параметрами для заполнения.
// 
// Возвращаемое значение:
//  Структура - Сформировать расшифровку:
// * Результат - ТабличныйДокумент - 
// * АдресДанныхРасшифровки - Строка - 
//
Функция СформироватьРасшифровку(ПараметрыСверки) Экспорт
	
	ДанныеОтчета = ПолучитьДанныеОтчета(ПараметрыСверки);
	ИспользуетсяСервисСверкиРасчетов = Ложь;
	//++ Локализация
	ИспользуетсяСервисСверкиРасчетов = ПолучитьФункциональнуюОпцию("ИспользуетсяСервисСверкиРасчетов");
	//-- Локализация
	
	СхемаКомпоновкиДанных = ПолучитьМакет("СостояниеСверки");
	
	НастройкиПоУмолчанию = СхемаКомпоновкиДанных.НастройкиПоУмолчанию;
	Если НЕ ПараметрыСверки.УчастникЭДО И ИспользуетсяСервисСверкиРасчетов Тогда
		НастройкиПоУмолчанию.Структура[1].Имя = "СверкаБезЭДО";
		НастройкиПоУмолчанию.Структура[1].Структура[0].Имя = "РасхожденияБезЭДО";
	ИначеЕсли ПараметрыСверки.УчастникЭДО И НЕ ИспользуетсяСервисСверкиРасчетов Тогда
		НастройкиПоУмолчанию.Структура[1].Имя = "СверкаБезСверка20";
		НастройкиПоУмолчанию.Структура[1].Структура[0].Имя = "РасхожденияБезСверка20";
	ИначеЕсли НЕ ПараметрыСверки.УчастникЭДО И НЕ ИспользуетсяСервисСверкиРасчетов Тогда
		НастройкиПоУмолчанию.Структура[1].Имя = "СверкаБезЭДОиСверка20";
		НастройкиПоУмолчанию.Структура[1].Структура[0].Имя = "РасхожденияБезЭДОиСверка20";
	КонецЕсли;
	
	КомпоновщикНастроек = Новый КомпоновщикНастроекКомпоновкиДанных;
	КомпоновщикНастроек.Инициализировать(Новый ИсточникДоступныхНастроекКомпоновкиДанных(СхемаКомпоновкиДанных));
	КомпоновщикНастроек.ЗагрузитьНастройки(НастройкиПоУмолчанию);
	
	Период = Новый СтандартныйПериод(ПараметрыСверки.НачалоПериода, ПараметрыСверки.КонецПериода);
	КомпоновкаДанныхКлиентСервер.УстановитьПараметр(КомпоновщикНастроек, "Период", Период);
	КомпоновкаДанныхКлиентСервер.УстановитьПараметр(КомпоновщикНастроек, "Организация", ПараметрыСверки.Организация);
	КомпоновкаДанныхКлиентСервер.УстановитьПараметр(КомпоновщикНастроек, "Контрагент", ПараметрыСверки.Контрагент);
	КомпоновкаДанныхКлиентСервер.УстановитьПараметр(КомпоновщикНастроек, "ПустаяСтрока", "");
	
	НастройкиДляКомпоновкиМакета = КомпоновщикНастроек.ПолучитьНастройки();
	
	КомпоновщикМакета = Новый КомпоновщикМакетаКомпоновкиДанных;
	ДанныеРасшифровки = Новый ДанныеРасшифровкиКомпоновкиДанных;
	Макет = КомпоновщикМакета.Выполнить(СхемаКомпоновкиДанных, НастройкиДляКомпоновкиМакета, ДанныеРасшифровки);
	
	ПроцессорКомпоновки = Новый ПроцессорКомпоновкиДанных;
	ВнешниеНаборы = Новый Структура;
	ВнешниеНаборы.Вставить("ДанныеСверки", ДанныеОтчета.Сверка);
	ВнешниеНаборы.Вставить("КонтрольПериодаСверки", ДанныеОтчета.КонтрольСроков);
	ПроцессорКомпоновки.Инициализировать(Макет, ВнешниеНаборы, ДанныеРасшифровки, Истина);
	
	Результат = Новый ТабличныйДокумент;
	ПроцессорВывода = Новый ПроцессорВыводаРезультатаКомпоновкиДанныхВТабличныйДокумент;
	ПроцессорВывода.УстановитьДокумент(Результат);
	ПроцессорВывода.Вывести(ПроцессорКомпоновки);
	
	АдресДанныхРасшифровки = ПоместитьВоВременноеХранилище(ДанныеРасшифровки, ПараметрыСверки.УникальныйИдентификатор);
	РезультатРасшифровка = Новый Структура("Результат, АдресДанныхРасшифровки", Результат, АдресДанныхРасшифровки);
	
	Возврат РезультатРасшифровка;
	
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция ПолучитьДанныеОтчета(ПараметрыСверки)
	
	//++ Локализация
	ИспользуетсяСервисСверкиРасчетов = ПолучитьФункциональнуюОпцию("ИспользуетсяСервисСверкиРасчетов");
	//-- Локализация
	Запрос = Новый Запрос;
	Запрос.Текст = ТекстЗаспросаРасшифровочногоОтчета();
	Запрос.УстановитьПараметр("НачалоПериода", ПараметрыСверки.НачалоПериода);
	Запрос.УстановитьПараметр("КонецПериода", ПараметрыСверки.КонецПериода);
	Запрос.УстановитьПараметр("ТипыРасчетов", ПараметрыСверки.ТипыРасчетов);
	Запрос.УстановитьПараметр("Организация", ПараметрыСверки.Организация);
	Запрос.УстановитьПараметр("Контрагент", ПараметрыСверки.Контрагент);
	Запрос.УстановитьПараметр("ПоВсемКонтрагентам", НЕ ЗначениеЗаполнено(ПараметрыСверки.Контрагент));
	Запрос.УстановитьПараметр("ТолькоНашиОрганизации", Ложь);
	Запрос.УстановитьПараметр("Менеджер", ПараметрыСверки.Менеджер);
	Запрос.УстановитьПараметр("ПоВсемМенеджерам", НЕ ЗначениеЗаполнено(ПараметрыСверки.Менеджер));
	Запрос.УстановитьПараметр("Валюта", ПараметрыСверки.Валюта);
	Запрос.УстановитьПараметр("ВалютаРегл", ЗначениеНастроекПовтИсп.ВалютаРегламентированногоУчетаОрганизации(ПараметрыСверки.Организация));
	Запрос.УстановитьПараметр("ПоВсемВалютам", Ложь);
	Запрос.УстановитьПараметр("ЭтоВалютаРегл", ПараметрыСверки.ЭтоВалютаРегл);
	Запрос.УстановитьПараметр("ДоговорыБезОборотов", ПараметрыСверки.ВключатьДоговорыБезОборотов);
	//++ Локализация
	Запрос.УстановитьПараметр("ИспользуетсяСервисСверкиРасчетов", ИспользуетсяСервисСверкиРасчетов);
	//-- Локализация
	Запрос.УстановитьПараметр("ТипыСуммыАрендыДляСверки", Документы.СверкаВзаиморасчетов2_5_11.ТипыСуммАрендыДляСверки());
	Запрос.УстановитьПараметр("ПустаяСтрока", "");
	
	РезультатЗапроса = Запрос.ВыполнитьПакет();
	
	Результат = Новый Структура;
	Сверка = РезультатЗапроса[РезультатЗапроса.ВГраница()].Выгрузить();
	//++ Локализация
	ЕстьНеОтраженныеДокументыПоДаннымСерка20 = Ложь;
	//-- Локализация
	Для Каждого Запись Из Сверка Цикл
		Если НЕ ЗначениеЗаполнено(Запись.РасчетныйДокумент) И ЗначениеЗаполнено(Запись.ПредставлениеДокумента) Тогда
			Запись.ПредставлениеДокумента = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку("<%1 №%2 от %3>",
				Запись.ПредставлениеДокумента, Запись.НомерДокумента, Формат(Запись.ДатаДокумента, "ДЛФ=D"));
		КонецЕсли;
		Если Запись.СсылкаПредставление = Неопределено Тогда
			Запись.СсылкаПредставление = "<"+НСтр("ru = 'Не отражено в документах сверки взаиморасчетов'")+">";
			//++ Локализация
			ЕстьНеОтраженныеДокументыПоДаннымСерка20 = Истина;
			//-- Локализация
		КонецЕсли;
	КонецЦикла;
	
	СрокиСверки = РезультатЗапроса[РезультатЗапроса.ВГраница()-1].Выгрузить();
	КонтрольСроков = Новый ТаблицаЗначений;
	КонтрольСроков.Колонки.Добавить("Организация", Новый ОписаниеТипов("СправочникСсылка.Организации"));
	КонтрольСроков.Колонки.Добавить("Контрагент", Новый ОписаниеТипов("СправочникСсылка.Контрагенты"));
	ТипСрока150 = Новый ОписаниеТипов("Строка",,Новый КвалификаторыСтроки(150));
	КонтрольСроков.Колонки.Добавить("ПоДаннымРасчетов", ТипСрока150);
	КонтрольСроков.Колонки.Добавить("Комментарий", ТипСрока150);
	Для Каждого Запись Из СрокиСверки Цикл
		НетДокументовРасчетов = НЕ ЗначениеЗаполнено(Запись.ДатаОперацииРасчетов);
		НетДокументовСверки = НЕ ЗначениеЗаполнено(Запись.МаксимальныйКонецПериодаСверки);
		НоваяСтрока = КонтрольСроков.Добавить();
		НоваяСтрока.Организация = Запись.Организация;
		НоваяСтрока.Контрагент = Запись.Контрагент;
		Запись.ДатаОперацииРасчетов = Макс(Запись.ДатаОперацииРасчетов, ПараметрыСверки.НачалоПериода);
		Запись.МаксимальныйКонецПериодаСверки = Макс(Запись.МаксимальныйКонецПериодаСверки, ПараметрыСверки.КонецПериода);
		
		Если НетДокументовРасчетов Тогда
			НоваяСтрока.ПоДаннымРасчетов = НСтр("ru = 'Расчеты за текущий период не производились'");
		Иначе
			НоваяСтрока.ПоДаннымРасчетов = НСтр("ru = 'Дата последней операции с контрагентом'") + " " + Формат(Запись.ДатаОперацииРасчетов, "ДЛФ=D");
		КонецЕсли;
		Если НетДокументовСверки Тогда
			Шаблон = НСтр("ru = 'Требуется ввести сверку с %1 по %2'");
			ТекстКомментария = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
				Шаблон,
				Формат(ПараметрыСверки.НачалоПериода, "ДЛФ=D"),
				Формат(ПараметрыСверки.КонецПериода, "ДЛФ=D"));
		ИначеЕсли Запись.ДатаОперацииРасчетов > Запись.МаксимальныйКонецПериодаСверки Тогда
			Шаблон = НСтр("ru = 'Требуется ввести сверку с %1 по %2'");
			ТекстКомментария = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
				Шаблон,
				Формат(Запись.МаксимальныйКонецПериодаСверки, "ДЛФ=D"),
				Формат(Запись.ДатаОперацииРасчетов, "ДЛФ=D"));
		//++ Локализация
		ИначеЕсли ЕстьНеОтраженныеДокументыПоДаннымСерка20 Тогда
			ТекстКомментария = НСтр("ru = 'По данным сервиса 1С:Сверка 2.0 у одной из сторон не отражены первичные документы'");
			
		//-- Локализация
		Иначе
			ТекстКомментария = НСтр("ru = 'Ввод документов сверки не требуется'");
		КонецЕсли;
		НоваяСтрока.Комментарий = ТекстКомментария;
	КонецЦикла;
	
	Если СрокиСверки.Количество() = 0 Тогда
		НоваяСтрока = КонтрольСроков.Добавить();
		НоваяСтрока.Организация = ПараметрыСверки.Организация;
		НоваяСтрока.Контрагент = ПараметрыСверки.Контрагент;
		НоваяСтрока.ПоДаннымРасчетов = НСтр("ru = 'Расчеты с контрагентом не производились'");
		Если Сверка.Количество() = 0 Тогда
			ТекстКомментария = НСтр("ru = 'Требуется сверка входящей задолженности'");
		Иначе
			ТекстКомментария = НСтр("ru = 'Требуется актуализировать документы сверки'");
		КонецЕсли;
		НоваяСтрока.Комментарий = ТекстКомментария;
	КонецЕсли;
	
	Результат.Вставить("Сверка", Сверка);
	Результат.Вставить("КонтрольСроков", КонтрольСроков);
	
	Возврат Результат;
	
КонецФункции

Функция ТекстЗаспросаРасшифровочногоОтчета()

	ТекстЗапроса = Обработки.МониторСверкиВзаиморасчетов.ТекстЗапросаДанныеРасчетов() + 
	"////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	Сверка.Ссылка КАК Ссылка,
	|	Сверка.Номер КАК Номер,
	|	Сверка.Дата КАК Дата,
	|	Сверка.Валюта КАК Валюта,
	|	Сверка.Статус КАК Статус,
	|	СостоянияЭДО.СостояниеЭДО КАК СостояниеЭДО,
	|	Сверка.ЕстьРасхождения КАК ЕстьРасхождения,
	|	Сверка.НачалоПериода КАК НачалоПериода,
	|	Сверка.КонецПериода КАК КонецПериода,
	|	Сверка.Контрагент КАК Контрагент,
	|	Сверка.Организация КАК Организация,
	|	СУММА(тчИтоговыеЗаписи.КонечноеСальдоДт) КАК КонечноеСальдоДт,
	|	СУММА(тчИтоговыеЗаписи.КонечноеСальдоКт) КАК КонечноеСальдоКт,
	|	СУММА(ВЫБОР 
	|			КОГДА Сверка.ЕстьРасхождения 
	|				ТОГДА тчИтоговыеЗаписи.КонечноеСальдоДтКонтрагент
	|			ИНАЧЕ
	|				тчИтоговыеЗаписи.КонечноеСальдоДт
	|	КОНЕЦ) КАК КонечноеСальдоДтКонтрагент,
	|	СУММА(ВЫБОР 
	|			КОГДА Сверка.ЕстьРасхождения 
	|				ТОГДА тчИтоговыеЗаписи.КонечноеСальдоКтКонтрагент
	|			ИНАЧЕ
	|				тчИтоговыеЗаписи.КонечноеСальдоКт
	|	КОНЕЦ) КАК КонечноеСальдоКтКонтрагент
	|ПОМЕСТИТЬ втДокументыСверкиИтоги
	|ИЗ
	|	Документ.СверкаВзаиморасчетов2_5_11 КАК Сверка
	|	ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.СверкаВзаиморасчетов2_5_11.ИтоговыеЗаписи КАК тчИтоговыеЗаписи
	|		ПО Сверка.Ссылка = тчИтоговыеЗаписи.Ссылка
	//++ Локализация
	|//++ Локализация
	|	ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СостоянияПоОбъектамУчетаЭДО КАК СостоянияЭДО
	|		ПО Сверка.Ссылка = СостоянияЭДО.СсылкаНаОбъект
	|//-- Локализация
	//-- Локализация
	|
	|ГДЕ
	|	Сверка.Проведен
	|	И (Сверка.Валюта = &Валюта ИЛИ Сверка.Валюта = &ВалютаРегл)
	|	И Сверка.Статус <> ЗНАЧЕНИЕ(Перечисление.СтатусыСверокВзаиморасчетов2_5_11.Отклонена)
	|	И Сверка.Организация В (&Организация)
	|	И (&ПоВсемКонтрагентам ИЛИ Сверка.Контрагент В (&Контрагент))
	|	И ИтоговыеЗаписи.ТипРасчетов В (&ТипыРасчетов)
	|	И Сверка.НачалоПериода <= &КонецПериода
	|	И Сверка.КонецПериода >= &НачалоПериода
	|	И ИСТИНА В (ВЫБРАТЬ ПЕРВЫЕ 1 ИСТИНА 
	|				ИЗ 
	|					втОстаткиИОборотыПоДоговорам КАК ОстаткиИОбороты
	|				ГДЕ
	|					ОстаткиИОбороты.Договор = тчИтоговыеЗаписи.Договор)
	|	
	|СГРУППИРОВАТЬ ПО
	|	Сверка.Ссылка,
	|	Сверка.Номер,
	|	Сверка.Дата,
	|	Сверка.Валюта,
	|	Сверка.Статус,
	//++ Локализация
	|//++ Локализация
	|	СостоянияЭДО.СостояниеЭДО,
	|//-- Локализация
	//-- Локализация
	|	Сверка.ЕстьРасхождения,
	|	Сверка.НачалоПериода,
	|	Сверка.КонецПериода,
	|	Сверка.Контрагент,
	|	Сверка.Организация
	|	
	|ИНДЕКСИРОВАТЬ ПО
	|	Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	Сверка.Ссылка КАК Ссылка,
	|	Сверка.Статус КАК Статус,
	|	Сверка.ЕстьРасхождения КАК ЕстьРасхождения,
	|	Сверка.НачалоПериода КАК НачалоПериода,
	|	Сверка.КонецПериода КАК КонецПериода,
	|	Сверка.Контрагент КАК Контрагент,
	|	Сверка.Организация КАК Организация,
	|	тчДетальныеЗаписи.РасчетныйДокумент КАК РасчетныйДокумент,
	|	тчДетальныеЗаписи.НомерДокумента КАК НомерДокумента,
	|	тчДетальныеЗаписи.ДатаДокумента КАК ДатаДокумента,
	|	ЕСТЬNULL(РеестрДокументов.НомерДокументаИБ, &ПустаяСтрока) КАК НомерДокументаИБ,
	|	ЕСТЬNULL(РеестрДокументов.ДатаДокументаИБ, ДАТАВРЕМЯ(1,1,1)) КАК ДатаДокументаИБ,
	|	СУММА(тчДетальныеЗаписи.СуммаДебет) КАК СуммаДт,
	|	СУММА(ВЫБОР 
