//++ Локализация
Процедура ЗаполнитьПредставлениеПолейСверки(СтрокаСверки, КэшНеЗавершенОбменЭДОТекст, КодТекущегоЯзыкаПользователя)
	
	//По данным сервиса Сверка 2.0
	Если СтрокаСверки.СервисСверкиКонтрагентПодключен Тогда
		Если СтрокаСверки.СервисСверкиЕстьРасхождения Тогда
			СтрокаСверки.Сверка20 = НСтр("ru = 'Обнаружены расхождения'");
		Иначе
			СтрокаСверки.Сверка20 = НСтр("ru = 'Расхождения не обнаружены'");
		КонецЕсли;
	Иначе
		СтрокаСверки.Сверка20 = НСтр("ru = 'Контрагент не подключен к сервису'");
	КонецЕсли;
	
	//Не полученные первичные документы по ЭДО
	Если НЕ СтрокаСверки.УчастникЭДО Тогда
		СтрокаСверки.НеЗавершенОбменЭДОПредставление = НСтр("ru = 'Контрагент не подключен к ЭДО'");
	
	ИначеЕсли СтрокаСверки.НеЗавершенОбменЭДОКоличество > 0 Тогда
		Текст = КэшНеЗавершенОбменЭДОТекст[СтрокаСверки.НеЗавершенОбменЭДОКоличество];
		Если Текст = Неопределено Тогда
			Если КодТекущегоЯзыкаПользователя = "ru" Тогда
				Текст = ПолучитьСклоненияСтрокиПоЧислу(
					НСтр("ru = 'документ'"),
					СтрокаСверки.НеЗавершенОбменЭДОКоличество,
					"",
					"Л= ru_RU; ЧС=Количественное",
					"ПЧ=Число")[0];
			Иначе
				Текст = Формат(СтрокаСверки.НеЗавершенОбменЭДОКоличество, "ЧДЦ=0;") + " " + НСтр("ru = 'документ(ов)'");
			КонецЕсли;
			КэшНеЗавершенОбменЭДОТекст.Вставить(СтрокаСверки.НеЗавершенОбменЭДОКоличество, Текст);
		КонецЕсли;
		СтрокаСверки.НеЗавершенОбменЭДОПредставление = Текст;
	КонецЕсли;
	
КонецПроцедуры
