//Возвращаемое значение:
//  Структура из КлючИЗначение :
//   Имя - Строка - строковый идентификатор статуса.
//   Представление - Строка - представление статуса в пользовательском интерфейсе.
//   Картинка - Число - Индекс в картинке КоллекцияСветофор.
//
Функция НовыйСтатус(Имя = "", Представление = "", Картинка = 0)
	
	Результат = Новый Структура;
	Результат.Вставить("Имя", Имя);
	Результат.Вставить("Представление", Представление);
	Результат.Вставить("Картинка", Картинка);
	
	Возврат Результат;
	
КонецФункции

