#Область ПрограммныйИнтерфейс

// Процедура подготавливает данные для таблицы СверкаСКонтрагентами в форме монитора сверки
// 
// Параметры:
//    ПараметрыСверки - Структура - Структура с параметрами для заполнения.
//    АдресРезультата - Строка - Адрес во временном хранилище, куда будет помещен результат выполнения процедуры.
//
Процедура ПолучитьДанныеСверки(ПараметрыСверки, АдресРезультата) Экспорт
	
	ЗамерПолучениеДанных = ОценкаПроизводительности.НачатьЗамерДлительнойОперации("Обработка.МониторСверкиВзаиморасчетов.ПолучитьДанныеСверки");

	ТекстЗапроса = ТекстЗапросаДанныеМонитораСверки();
	Сортировка = ПараметрыСверки.ВсеПоляСортировки;
	Если ПараметрыСверки.Сортировать <> "КонтрагентНаименование" Тогда
		Индекс = Сортировка.Найти(ПараметрыСверки.Сортировать);
		Если Индекс <> Неопределено Тогда
			Сортировка.Удалить(Индекс);
		КонецЕсли;
		Сортировка.Вставить(0,ПараметрыСверки.Сортировать);
	КонецЕсли;
	СтрокаСортировки = СтрСоединить(Сортировка,",");
	СтрокаСортировки = "
	|УПОРЯДОЧИТЬ ПО
	|" + СтрокаСортировки;
	
	Запрос = Новый Запрос;
	Запрос.Текст = ТекстЗапроса + СтрокаСортировки;
	Запрос.УстановитьПараметр("НачалоПериода", ПараметрыСверки.НачалоПериода);
	Запрос.УстановитьПараметр("КонецПериода", ПараметрыСверки.КонецПериода);
	Запрос.УстановитьПараметр("ТипыРасчетов", ПараметрыСверки.ТипыРасчетов);
	Запрос.УстановитьПараметр("Организация", ПараметрыСверки.Организация);
	Запрос.УстановитьПараметр("ВалютаРегл", ЗначениеНастроекПовтИсп.ВалютаРегламентированногоУчетаОрганизации(ПараметрыСверки.Организация));
	Запрос.УстановитьПараметр("Контрагент", ПараметрыСверки.Контрагент);
	Запрос.УстановитьПараметр("ПоВсемКонтрагентам", НЕ ЗначениеЗаполнено(ПараметрыСверки.Контрагент));
	Запрос.УстановитьПараметр("ТолькоНашиОрганизации", ПараметрыСверки.ТолькоНашиОрганизации);
	Запрос.УстановитьПараметр("Менеджер", ПараметрыСверки.Менеджер);
	Запрос.УстановитьПараметр("ПоВсемМенеджерам", НЕ ЗначениеЗаполнено(ПараметрыСверки.Менеджер));
	Запрос.УстановитьПараметр("Валюта", Неопределено);
	Запрос.УстановитьПараметр("ПоВсемВалютам", Истина);
	Запрос.УстановитьПараметр("ДоговорыБезОборотов", ПараметрыСверки.ВключатьДоговорыБезОборотов);
	//++ Локализация
	Запрос.УстановитьПараметр("ИспользуетсяСервисСверкиРасчетов", ПолучитьФункциональнуюОпцию("ИспользуетсяСервисСверкиРасчетов"));
	//-- Локализация
	Запрос.УстановитьПараметр("ТипыСуммыАрендыДляСверки", Документы.СверкаВзаиморасчетов2_5_11.ТипыСуммАрендыДляСверки());
	Запрос.УстановитьПараметр("ВыводитьРегистраторы", Ложь);
	Запрос.УстановитьПараметр("ПустаяСтрока", "");
	Для Каждого Статус Из СтатусыСверки() Цикл
		Запрос.УстановитьПараметр(Статус.Имя, Статус.Имя);
	КонецЦикла;
	//++ Локализация
	СтатусыЭДО = СтатусыЭДООбменЗавершен();
	Запрос.УстановитьПараметр("СтатусЗавершенОбменЭДО", СтатусыЭДО);
	КодТекущегоЯзыкаПользователя = ТекущийЯзык().КодЯзыка;
	//-- Локализация
	
	РезультатЗапроса = Запрос.Выполнить();
	ДанныеСверки = Новый ТаблицаЗначений;
	Для Каждого КолонкаРезультата Из РезультатЗапроса.Колонки Цикл
		ДанныеСверки.Колонки.Добавить(КолонкаРезультата.Имя, КолонкаРезультата.ТипЗначения);
	КонецЦикла;
	ТипСтрока50 = ОбщегоНазначения.ОписаниеТипаСтрока(50);
	ТипЧисло1 = ОбщегоНазначения.ОписаниеТипаЧисло(1);
	ТипСумма = РаботаСКурсамиВалют.ОписаниеТипаДенежногоПоля();
	ДанныеСверки.Колонки.Добавить("СтатусСверкиПредставление", ТипСтрока50);
	ДанныеСверки.Колонки.Добавить("СтатусСверкиКартинка", ТипЧисло1);
	ДанныеСверки.Колонки.Добавить("НашДолгСверен", ТипСумма);
	ДанныеСверки.Колонки.Добавить("ДолгКонтрагентаСверен", ТипСумма);
	ДанныеСверки.Колонки.Добавить("Сверка20", ТипСтрока50);
	ДанныеСверки.Колонки.Добавить("КодТипРасчетов", ТипСтрока50);
	ДанныеСверки.Колонки.Добавить("НеЗавершенОбменЭДОПредставление", ТипСтрока50);
	
	Выборка = РезультатЗапроса.Выбрать();
	
	// Заполним текстовые поля построчно и одновременно посчитаем итоги
	КэшНеЗавершенОбменЭДОТекст = Новый Соответствие;
	
	ИтогиЗадолженности = Новый Структура();
	ИтогиЗадолженности.Вставить("НашДолг", Новый Структура);
	ИтогиЗадолженности.НашДолг.Вставить("Всего", 0);
	ИтогиЗадолженности.НашДолг.Вставить("Сверено", 0);
	
	ИтогиЗадолженности.Вставить("ДолгКонтрагента", Новый Структура);
	ИтогиЗадолженности.ДолгКонтрагента.Вставить("Всего", 0);
	ИтогиЗадолженности.ДолгКонтрагента.Вставить("Сверено", 0);
	
	ДолгКонтрагента = ИтогиЗадолженности.ДолгКонтрагента;
	НашДолг = ИтогиЗадолженности.НашДолг;
	
	ОтборПоСтатусам = ПараметрыСверки.СтатусыСверки;
	СтатусыСверки = СтатусыСверки(Истина);
	СтатусСверена = СтатусыСверки["Сверена"];
	ИтогиПоСтатусамСверки = Новый Соответствие;// ключ - строковый статус сверки, значение - количество контрагентов
	Для Каждого Статус Из СтатусыСверки Цикл
		ИтогиПоСтатусамСверки.Вставить(Статус.Ключ, 0);
	КонецЦикла;
	ЕстьРасхождения = СтатусЕстьРасхождения().Имя;
	ИтогиПоСтатусамСверки.Вставить(ЕстьРасхождения, 0);
	
	Пока Выборка.Следующий() Цикл
		
		// Чтобы посчитать статистику в общей массе контрагентов, не отбираем по статусам сразу в запросе.
		// Контрагентов, не проходящих по статусу сверки, ниже не добавляем в итоговую таблицу.
		ИтогиПоСтатусамСверки[Выборка.СтатусСверки] = ИтогиПоСтатусамСверки[Выборка.СтатусСверки] + 1;
		ИтогиПоСтатусамСверки[ЕстьРасхождения] = ИтогиПоСтатусамСверки[ЕстьРасхождения] + Число(Выборка.ЕстьРасхождения);
		ДолгКонтрагента.Всего = ДолгКонтрагента.Всего + Выборка.ДолгКонтрагентаРегл;
		НашДолг.Всего = НашДолг.Всего + Выборка.НашДолгРегл;
		Если СтатусСверена[Выборка.СтатусСверки] <> Неопределено Тогда
			ДолгКонтрагента.Сверено = ДолгКонтрагента.Сверено + Выборка.ДолгКонтрагентаРегл;
			НашДолг.Сверено = НашДолг.Сверено + Выборка.НашДолгРегл;
		КонецЕсли;
		
		Если НЕ ОтборПоСтатусам[Выборка.СтатусСверки]
			 ИЛИ ПараметрыСверки.ЕстьРасхождения И НЕ Выборка.ЕстьРасхождения Тогда
			Продолжить;
		КонецЕсли;
		
		НоваяСтрока = ДанныеСверки.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, Выборка);
		НоваяСтрока.КодТипРасчетов = СтрЗаменить(Формат(Выборка.КодТипРасчетовЧисло, "ЧГ=0"),"0","");
		Статус = СтатусыСверки[Выборка.СтатусСверки];
		НоваяСтрока.СтатусСверкиПредставление = Статус.Представление;
		НоваяСтрока.СтатусСверкиКартинка = Статус.Картинка;
		//++ Локализация
		ЗаполнитьПредставлениеПолейСверки(НоваяСтрока, КэшНеЗавершенОбменЭДОТекст, КодТекущегоЯзыкаПользователя);
		//-- Локализация
		
	КонецЦикла;
	
	Результат = Новый Структура;
	Результат.Вставить("Контрагенты", ДанныеСверки);
	Результат.Вставить("ИтогиПоСтатусамСверки", ИтогиПоСтатусамСверки);
	Результат.Вставить("ИтогиЗадолженности", ИтогиЗадолженности);
	
	ПоместитьВоВременноеХранилище(Результат, АдресРезультата);
	
	ОценкаПроизводительности.ЗакончитьЗамерДлительнойОперации(ЗамерПолучениеДанных, Выборка.Количество()/100);
	
КонецПроцедуры

// Функция возвращает описание статусов сверки в виде правильно упорядоченного массива или соответствия
// Параметры:
//  ВернутьСоответствие - Булево - Задает тип возращаемого значения
//
// Возвращаемое значение:
//  Массив из Структура, 
//  Соответствие Из КлючИЗначение - описание статусов сверки
//
Функция СтатусыСверки(ВернутьСоответствие = Ложь) Экспорт
	
	Требуется = НовыйСтатус("ТребуетсяСверка", НСтр("ru = 'Требуется сверка'"),2);//красный шар
	Создана = НовыйСтатус("Создана", Строка(Перечисления.СтатусыСверокВзаиморасчетов2_5_11.Создана),0);//серый шар
	НаСверке = НовыйСтатус("НаСверке", Строка(Перечисления.СтатусыСверокВзаиморасчетов2_5_11.НаСверке),1);//желтый шар
	СверенаСРазногласиями = НовыйСтатус("СверенаСРазногласиями", Строка(Перечисления.СтатусыСверокВзаиморасчетов2_5_11.СверенаСРазногласиями),4);//зеленая галка
	СверенаБезРазногласий = НовыйСтатус("СверенаБезРазногласий", Строка(Перечисления.СтатусыСверокВзаиморасчетов2_5_11.СверенаБезРазногласий),4);//зеленая галка
	
	Если ВернутьСоответствие Тогда
		Результат = Новый Соответствие;
		Результат.Вставить(Требуется.Имя, Требуется);
		Результат.Вставить(Создана.Имя, Создана);
		Результат.Вставить(НаСверке.Имя, НаСверке);
		Результат.Вставить(СверенаСРазногласиями.Имя, СверенаСРазногласиями);
		Результат.Вставить(СверенаБезРазногласий.Имя, СверенаБезРазногласий);
			
		Сверена = Новый Соответствие;
		Сверена.Вставить(СверенаСРазногласиями.Имя,Истина);
		Сверена.Вставить(СверенаБезРазногласий.Имя,Истина);
		Результат.Вставить("Сверена",Сверена);
	Иначе
		Результат = Новый Массив;
		Результат.Добавить(Требуется);
		Результат.Добавить(Создана);
		Результат.Добавить(НаСверке);
		Результат.Добавить(СверенаСРазногласиями);
		Результат.Добавить(СверенаБезРазногласий);
	КонецЕсли;
		
	Возврат Результат;
	
КонецФункции

// Возвращает описание отбора по наличию расхождений в документах сверки 
//
// Возвращаемое значение:
//  Структура - Статус есть расхождения:
// * Имя - Строка - Идентификатор
// * Представление - Строка - Пользовательское представление.
//
Функция СтатусЕстьРасхождения() Экспорт
	
	Возврат Новый Структура("Имя,Представление", "ЕстьРасхождения", НСтр("ru = 'Зафиксированы расхождения'"));
	
КонецФункции
//++ Локализация

// Возвращает статусы ЭДО завершеного обмена
//
// Возвращаемое значение:
//  Массив из ПеречислениеСсылка.СостоянияДокументовЭДО
//
Функция СтатусыЭДООбменЗавершен() Экспорт
	
	СтатусыЭДО = Новый Массив;
	СтатусыЭДО.Добавить(Перечисления.СостоянияДокументовЭДО.Аннулирован);
	СтатусыЭДО.Добавить(Перечисления.СостоянияДокументовЭДО.ЗакрытПринудительно);
	СтатусыЭДО.Добавить(Перечисления.СостоянияДокументовЭДО.ЗакрытСОтклонением);
	СтатусыЭДО.Добавить(Перечисления.СостоянияДокументовЭДО.ЗакрытСОтклонениемПриглашения);
	СтатусыЭДО.Добавить(Перечисления.СостоянияДокументовЭДО.ЗакрытСОшибкойПередачи);
	СтатусыЭДО.Добавить(Перечисления.СостоянияДокументовЭДО.ОбменЗавершен);
	СтатусыЭДО.Добавить(Перечисления.СостоянияДокументовЭДО.ОбменЗавершенСИсправлением);
	
	Возврат СтатусыЭДО;
	
КонецФункции
//-- Локализация

// Текст запроса документы расчетов.
// 
// Возвращаемое значение:
//  Строка - Текст запроса документы расчетов
Функция ТекстЗапросаДанныеРасчетов() Экспорт
	
	ТекстЗапроса =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	НАЧАЛОПЕРИОДА(ВложенныйЗапрос.Период, ДЕНЬ) КАК Период,
	|	ВложенныйЗапрос.Организация КАК Организация,
	|	ВложенныйЗапрос.Контрагент КАК Контрагент,
	|	ВЫБОР 
	|		КОГДА ВложенныйЗапрос.Договор В (
	|			ЗНАЧЕНИЕ(Справочник.ДоговорыКонтрагентов.ПустаяСсылка),
	|			ЗНАЧЕНИЕ(Справочник.ДоговорыМеждуОрганизациями.ПустаяСсылка))
	|		ТОГДА НЕОПРЕДЕЛЕНО
	|		ИНАЧЕ ВложенныйЗапрос.Договор
	|	КОНЕЦ КАК Договор,
	|	ВложенныйЗапрос.Менеджер КАК Менеджер,
	|	ВложенныйЗапрос.Валюта КАК Валюта,
	|	СУММА(ВложенныйЗапрос.НашДолг) КАК НашДолг,
	|	СУММА(ВложенныйЗапрос.ДолгКонтрагента) КАК ДолгКонтрагента,
	|	СУММА(ВложенныйЗапрос.НашДолгРегл) КАК НашДолгРегл,
	|	СУММА(ВложенныйЗапрос.ДолгКонтрагентаРегл) КАК ДолгКонтрагентаРегл,
	|	ВложенныйЗапрос.Ссылка КАК Ссылка,
	|	ВложенныйЗапрос.ТипРасчетов КАК ТипРасчетов,
	|	ВложенныйЗапрос.Порядок КАК Порядок,
	|	ТИПЗНАЧЕНИЯ(ВложенныйЗапрос.Ссылка) = ТИП(Документ.НачисленияКредитовИДепозитов) КАК ЭтоНачисленияКредитовИДепозитов
	|	
	|ПОМЕСТИТЬ втДокументыРасчетов
	|ИЗ 
	|	(ВЫБРАТЬ
	|		Расчеты.Период КАК Период,
	|		Аналитика.Организация КАК Организация,
	|		Аналитика.Контрагент КАК Контрагент,
	|		Аналитика.Договор КАК Договор,
	|		ЕСТЬNULL(Контрагенты.Партнер.ОсновнойМенеджер, НЕОПРЕДЕЛЕНО) КАК Менеджер,
	|		Расчеты.Валюта КАК Валюта,
	|		ВЫБОР 
	|			КОГДА Расчеты.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход)
	|				ТОГДА Расчеты.Предоплата
	|			ИНАЧЕ -Расчеты.Предоплата
	|		КОНЕЦ КАК НашДолг,
	|		ВЫБОР 
	|			КОГДА Расчеты.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход)
	|				ТОГДА Расчеты.Долг
	|			ИНАЧЕ -Расчеты.Долг
	|		КОНЕЦ КАК ДолгКонтрагента,
	|		ВЫБОР 
	|			КОГДА Расчеты.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход)
	|				ТОГДА Расчеты.ПредоплатаРегл
	|			ИНАЧЕ -Расчеты.ПредоплатаРегл
	|		КОНЕЦ КАК НашДолгРегл,
	|		ВЫБОР 
	|			КОГДА Расчеты.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход)
	|				ТОГДА Расчеты.ДолгРегл
	|			ИНАЧЕ -Расчеты.ДолгРегл
	|		КОНЕЦ КАК ДолгКонтрагентаРегл,
	|		Расчеты.ДокументРегистратор КАК Ссылка,
	|		ЗНАЧЕНИЕ(Перечисление.ТипыРасчетовСПартнерами.РасчетыСКлиентом) КАК ТипРасчетов,
	|		10 КАК Порядок
	|	ИЗ
	|		РегистрНакопления.РасчетыСКлиентамиПоСрокам КАК Расчеты
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.АналитикаУчетаПоПартнерам КАК Аналитика
	|		ПО Расчеты.АналитикаУчетаПоПартнерам = Аналитика.КлючАналитики
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Контрагенты КАК Контрагенты
