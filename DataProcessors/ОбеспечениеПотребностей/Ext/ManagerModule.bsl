		|	Запасы.Характеристика,
		|	Топология.Центр,
		|	Запасы.Назначение,
		|	Запасы.Заказ
		|ИНДЕКСИРОВАТЬ ПО
		|	Номенклатура, Характеристика, Склад, Назначение
		|;
		|
		|/////////////////////////////////////////////////////
		|УНИЧТОЖИТЬ ЗапасыИПотребностиОстаткиКонтролируемыхПартий
		|;
		|
		|/////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Расчет.Номенклатура КАК Номенклатура,
		|	Расчет.Характеристика КАК Характеристика,
		|	Расчет.Склад КАК Склад,
		|	Расчет.Назначение КАК Назначение,
		|	
		|	Расчет.ВНаличии КАК ВНаличии,
		|	Расчет.ВНаличииСБлокировкой КАК НаКонтролеКачестваВНаличии,
		|	
		|	Расчет.Ожидается
		|		+ Расчет.ОжидаетсяСБлокировкой
		|		+ Расчет.НаСогласовании КАК Заказано,
		|	
		|	Расчет.ВНаличии_Излишек КАК ИзлишекНаСкладе,
		|	Расчет.ВНаличииСБлокировкой_Излишек КАК НаКонтролеКачестваИзлишекНаСкладе,
		|	
		|	Расчет.Ожидается_Излишек
		|			+ Расчет.ОжидаетсяСБлокировкой_Излишек
		|			+ Расчет.НаСогласовании_Излишек КАК ИзлишекВЗаказах,
		|	
		|	Расчет.Резервировать КАК РезервироватьНаСкладе,
		|	
		|	Расчет.ВНаличии_Излишек
		|		+ Расчет.ВНаличии_РезервироватьПоМере
		|		+ Расчет.ВНаличии_Отложить
		|		+ Расчет.ВНаличии_КОбеспечению
		|		+ Расчет.ВНаличииСБлокировкой_Излишек
		|		+ Расчет.ВНаличииСБлокировкой_РезервироватьПоМере
		|		+ Расчет.ВНаличииСБлокировкой_Отложить
		|		+ Расчет.ВНаличииСБлокировкой_КОбеспечению
		|		+ Расчет.Ожидается
		|		+ Расчет.ОжидаетсяСБлокировкой_Излишек
		|		+ Расчет.ОжидаетсяСБлокировкой_РезервироватьПоМере
		|		+ Расчет.ОжидаетсяСБлокировкой_Отложить
		|		+ Расчет.ОжидаетсяСБлокировкой_КОбеспечению
		|		+ Расчет.НаСогласовании КАК РаспределитьНаЗаказы
		|ПОМЕСТИТЬ ВтСвободныеОстатки
		|ИЗ
		|	РасчетРаспределенияЗапасов КАК Расчет
		|
		|ИНДЕКСИРОВАТЬ ПО
		|	Склад, Номенклатура, Характеристика, Назначение
		|;
		|
		|/////////////////////////////////////////////////////
		|УНИЧТОЖИТЬ ЗапасыИПотребностиОстаткиСУчетомТопологии
		|;
		|
		|/////////////////////////////////////////////////////
		|УНИЧТОЖИТЬ ЗапасыИПотребностиОстаткиКонтролируемыхПартийСУчетомТопологии";
		
	Подстановка = "ЗНАЧЕНИЕ(Справочник.Назначения.ПустаяСсылка)";
	ПодстановкаНазначение = "ТаблицаОтбора.Назначение";
	ПодстановкаИтоговая = ?(ВТаблицеОтбораЕстьНазначения, ПодстановкаНазначение, Подстановка);
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&УсловиеОтбораНазначений", ПодстановкаИтоговая);
	
	ИменаТаблиц = ОбеспечениеВДокументахСервер.НовыеИменаТаблицДляРаспределенияЗапасов();
	ИменаТаблиц.Остатки = "ЗапасыИПотребностиОстаткиСУчетомТопологии"; // @query-part-1
	ИменаТаблиц.ОстаткиКонтролируемыхПартий = "ЗапасыИПотребностиОстаткиКонтролируемыхПартийСУчетомТопологии"; // @query-part-1
	ИменаТаблиц.Сторно = "ПеремещенияВнутриСети"; // @query-part-1
	ИменаТаблиц.Результат = "РасчетРаспределенияЗапасов"; // @query-part-1
	
	ОбеспечениеВДокументахСервер.РаспределениеЗапасов(ТекстЗапроса, ИменаТаблиц);
	
	Возврат ТекстЗапроса;
	
КонецФункции

Функция ВременнаяТаблицаЗапретЗакупкиПоАссортименту(ИспользоватьАссортимент, ИспользоватьКонтрольКачества)
	
	Если Не ИспользоватьАссортимент Тогда
		
		Текст =
			"ВЫБРАТЬ ПЕРВЫЕ 0
			|	НЕОПРЕДЕЛЕНО КАК Склад,
			|	НЕОПРЕДЕЛЕНО КАК Номенклатура,
			|	НЕОПРЕДЕЛЕНО КАК ДатаВозможнойПоставки
			|ПОМЕСТИТЬ ЗапретЗакупкиПоАссортименту";
			
	Иначе
		
		Текст =
			"ВЫБРАТЬ РАЗЛИЧНЫЕ
			|	Товары.Склад КАК Склад,
			|	Товары.Номенклатура КАК Номенклатура,
			|	ВЫБОР
			|		КОГДА ТаблицаСпособовОбеспечения.ДатаПоставкиБезУчетаКонтроляКачества <> ДАТАВРЕМЯ(1, 1, 1)
			|			ТОГДА ТаблицаСпособовОбеспечения.ДатаПоставкиБезУчетаКонтроляКачества
			|		ИНАЧЕ &НачалоТекущегоДня
			|	КОНЕЦ КАК ДатаВозможнойПоставки
			|ПОМЕСТИТЬ СкладыИДатыПоставок
			|ИЗ
			|	ВтТовары КАК Товары
			|		ЛЕВОЕ СОЕДИНЕНИЕ БлижайшийЦиклПоСпособамОбеспечения КАК ТаблицаСпособовОбеспечения
			|		ПО Товары.СпособОбеспечения = ТаблицаСпособовОбеспечения.Ссылка
			|		И &СоединениеПоТоваруКонтрольКачества
			|ГДЕ
			|	ВЫРАЗИТЬ(Товары.Склад КАК Справочник.Склады).ТипСклада = ЗНАЧЕНИЕ(Перечисление.ТипыСкладов.РозничныйМагазин)
			|ИНДЕКСИРОВАТЬ ПО
			|	Склад, ДатаВозможнойПоставки
			|;
			|
			|///////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ
			|	Таблица.Склад КАК Склад,
			|	Таблица.Номенклатура КАК Номенклатура,
			|	Таблица.ДатаВозможнойПоставки КАК ДатаВозможнойПоставки
			|ПОМЕСТИТЬ ЗапретЗакупкиПоАссортименту
			|ИЗ
			|	СкладыИДатыПоставок КАК Таблица
			|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ИсторияИзмененияФорматовМагазинов КАК ИсторияНастроек
			|		ПО Таблица.Склад = ИсторияНастроек.Склад
			|			И ИсторияНастроек.Период В(
			|				ВЫБРАТЬ
			|					МАКСИМУМ (История.Период) КАК Период
			|				ИЗ
			|					РегистрСведений.ИсторияИзмененияФорматовМагазинов КАК История
			|				ГДЕ
			|					История.Склад = ИсторияНастроек.Склад
			|					И История.Период < Таблица.ДатаВозможнойПоставки)
			|		
			|		ЛЕВОЕ СОЕДИНЕНИЕ Константа.ИспользоватьФорматыМагазинов КАК ИспользоватьФорматыМагазинов
			|		ПО ИСТИНА
			|		
			|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.Ассортимент КАК Ассортимент
			|		ПО ЕСТЬNULL(ИсторияНастроек.КонтролироватьАссортимент, ЛОЖЬ)
			|		 И Ассортимент.Номенклатура = Таблица.Номенклатура
			|		 И Ассортимент.ОбъектПланирования
			|			= ВЫБОР КОГДА ИспользоватьФорматыМагазинов.Значение ТОГДА
			|						ЕСТЬNULL(ИсторияНастроек.ФорматМагазина, ЗНАЧЕНИЕ(Справочник.ФорматыМагазинов.ПустаяСсылка))
			|					ИНАЧЕ
			|						Таблица.Склад
			|				КОНЕЦ
			|		 И Ассортимент.РазрешеныЗакупки
			|		 И Ассортимент.Период В(
			|			ВЫБРАТЬ
			|					МАКСИМУМ (Ассорти.Период) КАК Период
			|				ИЗ
			|					РегистрСведений.Ассортимент КАК Ассорти
			|				ГДЕ
			|					Ассорти.Номенклатура = Ассортимент.Номенклатура
			|					И Ассорти.ОбъектПланирования = Ассортимент.ОбъектПланирования
			|					И Ассорти.Период <= Таблица.ДатаВозможнойПоставки)
			|ГДЕ
			|		ИсторияНастроек.КонтролироватьАссортимент
			|			И Ассортимент.Номенклатура ЕСТЬ NULL
			|ИНДЕКСИРОВАТЬ ПО
			|	Склад, Номенклатура, ДатаВозможнойПоставки";
		
		СоединениеПоТоваруКонтрольКачества = "ИСТИНА";
		Если ИспользоватьКонтрольКачества Тогда
			
			СоединениеПоТоваруКонтрольКачества =
			"(Товары.Номенклатура = ТаблицаСпособовОбеспечения.Номенклатура
			|И Товары.Склад = ТаблицаСпособовОбеспечения.Склад)";
			Текст = СтрЗаменить(Текст, "БлижайшийЦиклПоСпособамОбеспечения", "БлижайшийЦиклПоСпособамОбеспеченияСУчетомКонтроляКачества");
			
		Иначе
			
			Текст = СтрЗаменить(Текст, "ДатаПоставкиБезУчетаКонтроляКачества", "ДатаПоставки");
			
		КонецЕсли;
		Текст = СтрЗаменить(Текст, "&СоединениеПоТоваруКонтрольКачества", СоединениеПоТоваруКонтрольКачества);
		
	КонецЕсли;
	
	Возврат Текст;
	
КонецФункции

Процедура ЗаписатьДокумент(ДокументОбъект, СообщенияОбОшибках)

	ОшибокНеОбнаружено = ДокументОбъект.ПроверитьЗаполнение();

	Если Не ОшибокНеОбнаружено Тогда

		ДокументОбъект.Записать(РежимЗаписиДокумента.Запись);

	Иначе //нет ошибок, проводим документ

		Попытка

			ДокументОбъект.Записать(РежимЗаписиДокумента.Проведение);

		Исключение

			ДокументОбъект.Записать(РежимЗаписиДокумента.Запись);
			ИмяГруппыСобытий = НСтр("ru = 'Обеспечение потребностей'", ОбщегоНазначения.КодОсновногоЯзыка());
			Если ЭтоЗаявка(ДокументОбъект.Ссылка) Тогда
				ИмяСобытияВГруппе = НСтр("ru = 'Создание заявок'", ОбщегоНазначения.КодОсновногоЯзыка());
			Иначе
				ИмяСобытияВГруппе = НСтр("ru = 'Создание заказов'", ОбщегоНазначения.КодОсновногоЯзыка());
			КонецЕсли;
			ИмяСобытияЖурнала = ИмяГруппыСобытий + "." + ИмяСобытияВГруппе;
			ЗаписьЖурналаРегистрации(ИмяСобытияЖурнала, УровеньЖурналаРегистрации.Ошибка,,, ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));

		КонецПопытки;

	КонецЕсли;

	Ошибки = ПолучитьСообщенияПользователю(Истина);
	Для Каждого Ошибка Из Ошибки Цикл

		Ошибка.КлючДанных = ДокументОбъект.Ссылка;
		СообщенияОбОшибках.Добавить(Ошибка);

	КонецЦикла;

КонецПроцедуры


Функция НайтиОтборРекурсивно(КоллекцияЭлементов, ЗначениеПоиска)
	
	Для Каждого ЭлементОтбора Из КоллекцияЭлементов Цикл
		
		Если ТипЗнч(ЭлементОтбора) = Тип("ЭлементОтбораКомпоновкиДанных") Тогда
			
			Если Не ЭлементОтбора.Использование Тогда
				Продолжить;
			КонецЕсли;
			
			МассивИменПолей = СтрРазделить(Строка(ЭлементОтбора.ЛевоеЗначение), ".");
			Если Новый ПолеКомпоновкиДанных(МассивИменПолей[0]) = ЗначениеПоиска Тогда
				Возврат Истина;
			КонецЕсли;
			
		Иначе
			
			Возврат НайтиОтборРекурсивно(ЭлементОтбора.Элементы, ЗначениеПоиска);
			
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Ложь;
	
КонецФункции

Функция ВременнаяТаблицаОтборПоСегментам()
	
