		|	ВтДанныеЗаполненияЗаказаПоставщикуСНомеромСтроки КАК Т
		|СГРУППИРОВАТЬ ПО
		|	Т.Номенклатура, Т.Характеристика, Т.Склад
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Т.Номенклатура КАК Номенклатура,
		|	Т.Характеристика КАК Характеристика,
		|	Т.Склад КАК Склад,
		|	Т.Партнер КАК Партнер,
		|	Т.Соглашение КАК Соглашение,
		|	Т.Валюта КАК Валюта,
		|	Т.ВидЦеныПоставщика КАК ВидЦеныПоставщика
		|ПОМЕСТИТЬ ВтДанныеЗаполненияЗаказаПоставщику
		|ИЗ
		|	ВтДанныеЗаполненияЗаказаПоставщикуСНомеромСтроки КАК Т
		|	ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВтДанныеЗаполненияЗаказаПоставщикуСгруппировано КАК ДанныеСМаксНомеромСтроки
		|		ПО Т.Номенклатура = ДанныеСМаксНомеромСтроки.Номенклатура
		|			И Т.Характеристика = ДанныеСМаксНомеромСтроки.Характеристика
		|			И Т.Склад = ДанныеСМаксНомеромСтроки.Склад
		|			И Т.НомерСтроки = ДанныеСМаксНомеромСтроки.НомерСтроки
		|";
		
	КонецЕсли;
		
		// 6) Условия поставок
	Тексты.Добавить(ТекстЗапроса);
	ТекстЗапроса =
		"ВЫБРАТЬ
		|	УсловияЗакупок.Номенклатура КАК Номенклатура,
		|	УсловияЗакупок.Характеристика КАК Характеристика,
		|	УсловияЗакупок.ВидЦеныПоставщика КАК ВидЦеныПоставщика,
		|	УсловияЗакупок.УпаковкаЗаказа КАК УпаковкаЗаказа,
		|	УсловияЗакупок.МинимальнаяПартияПоставки КАК МинимальнаяПартияПоставки
		|ПОМЕСТИТЬ ВТУсловияЗакупок
		|ИЗ
		|	РегистрСведений.УсловияЗакупок.СрезПоследних(
		|		КОНЕЦПЕРИОДА(&НачалоПериода, ДЕНЬ),
		|		(Номенклатура, Характеристика, ВидЦеныПоставщика)
		|			В (
		|				ВЫБРАТЬ
		|					ТаблицаОтбора.Номенклатура                                      КАК Номенклатура,
		|					ТаблицаОтбора.Характеристика                                    КАК Характеристика,
		|					ВЫБОР
		|						КОГДА ЕСТЬNULL(ТаблицаОтбора.СпособОбеспечения.ВидЦеныПоставщика, ЗНАЧЕНИЕ(Справочник.ВидыЦенПоставщиков.ПустаяСсылка))
		|								<> ЗНАЧЕНИЕ(Справочник.ВидыЦенПоставщиков.ПустаяСсылка)
		|							ТОГДА ТаблицаОтбора.СпособОбеспечения.ВидЦеныПоставщика
		|						ИНАЧЕ ЕСТЬNULL(ТаблицаОтбора.СпособОбеспечения.Соглашение.ВидЦеныПоставщика, ЗНАЧЕНИЕ(Справочник.ВидыЦенПоставщиков.ПустаяСсылка))
		|					КОНЕЦ КАК ВидЦеныПоставщика
		|				ИЗ
		|					ВтТовары КАК ТаблицаОтбора)) КАК УсловияЗакупок
		|ИНДЕКСИРОВАТЬ ПО
		|	Номенклатура,
		|	Характеристика,
		|	ВидЦеныПоставщика
		|;
		|////////////////////////////////////////////////////////////////////////////////
		// 7) Цены номенклатуры.
		|ВЫБРАТЬ
		|		ЦеныПоставщиков.Номенклатура                КАК Номенклатура,
		|		ЦеныПоставщиков.Характеристика              КАК Характеристика,
		|		ЦеныПоставщиков.Партнер                     КАК Партнер,
		|		ЦеныПоставщиков.ВидЦеныПоставщика           КАК ВидЦеныПоставщика,
		|		ЦеныПоставщиков.Цена                        КАК Цена,
		|		ЦеныПоставщиков.Упаковка                    КАК Упаковка,
		|		ЦеныПоставщиков.Валюта                      КАК Валюта
		|ПОМЕСТИТЬ ВТЦеныПоставщиков
		|ИЗ
		|	РегистрСведений.ЦеныНоменклатурыПоставщиков.СрезПоследних(
		|		КОНЕЦПЕРИОДА(&НачалоПериода, ДЕНЬ),
		|		(Номенклатура, Характеристика, Партнер, ВидЦеныПоставщика)
		|			В (
		|				ВЫБРАТЬ
		|					ТаблицаОтбора.Номенклатура                                      КАК Номенклатура,
		|					ТаблицаОтбора.Характеристика                                    КАК Характеристика,
		|					ТаблицаОтбора.СпособОбеспечения.ИсточникОбеспеченияПотребностей КАК Партнер,
		|					ВЫБОР
		|						КОГДА ЕСТЬNULL(ТаблицаОтбора.СпособОбеспечения.ВидЦеныПоставщика, ЗНАЧЕНИЕ(Справочник.ВидыЦенПоставщиков.ПустаяСсылка))
		|								<> ЗНАЧЕНИЕ(Справочник.ВидыЦенПоставщиков.ПустаяСсылка)
		|							ТОГДА ТаблицаОтбора.СпособОбеспечения.ВидЦеныПоставщика
		|						ИНАЧЕ ЕСТЬNULL(ТаблицаОтбора.СпособОбеспечения.Соглашение.ВидЦеныПоставщика, ЗНАЧЕНИЕ(Справочник.ВидыЦенПоставщиков.ПустаяСсылка))
		|					КОНЕЦ КАК ВидЦеныПоставщика
		|				ИЗ
		|					ВтТовары КАК ТаблицаОтбора
		|
		|				ОБЪЕДИНИТЬ ВСЕ
		|
		|				ВЫБРАТЬ
		|					Т.Номенклатура           КАК Номенклатура,
		|					Т.Характеристика         КАК Характеристика,
		|					Т.Партнер                КАК Партнер,
		|					Т.ВидЦеныПоставщика      КАК ВидЦеныПоставщика
		|				ИЗ
		|					ВтДанныеЗаполненияЗаказаПоставщику КАК Т)
		|	) КАК ЦеныПоставщиков
		|ИНДЕКСИРОВАТЬ ПО
		|	Номенклатура,
		|	Характеристика,
		|	Партнер,
		|	ВидЦеныПоставщика
		|
		|;
		|////////////////////////////////////////////////////////////////////////////////
		// 8) Цены + Условия закупок.
		|ВЫБРАТЬ
		|	ВТЦеныПоставщиков.Номенклатура КАК Номенклатура,
		|	ВТЦеныПоставщиков.Характеристика КАК Характеристика,
		|	ВТЦеныПоставщиков.Партнер КАК Партнер,
		|	ВТЦеныПоставщиков.ВидЦеныПоставщика КАК ВидЦеныПоставщика,
		|	ВТЦеныПоставщиков.Цена КАК Цена,
		|	ВТЦеныПоставщиков.Упаковка КАК Упаковка,
		|	ВТЦеныПоставщиков.Валюта КАК Валюта,
		|	ВТУсловияЗакупок.УпаковкаЗаказа КАК УпаковкаЗаказаПоставщика,
		|	ВТУсловияЗакупок.МинимальнаяПартияПоставки КАК МинимальнаяПартияПоставки
		|ПОМЕСТИТЬ ЦеныПоставщиков
		|ИЗ
		|	ВТЦеныПоставщиков КАК ВТЦеныПоставщиков
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТУсловияЗакупок КАК ВТУсловияЗакупок
		|		ПО ВТЦеныПоставщиков.Номенклатура = ВТУсловияЗакупок.Номенклатура
		|			И ВТЦеныПоставщиков.Характеристика = ВТУсловияЗакупок.Характеристика
		|			И ВТЦеныПоставщиков.ВидЦеныПоставщика = ВТУсловияЗакупок.ВидЦеныПоставщика
		|ИНДЕКСИРОВАТЬ ПО
		|	Номенклатура,
		|	Характеристика,
		|	Партнер,
		|	ВидЦеныПоставщика
		|;
		|////////////////////////////////////////////////////////////////////////////////
		// 9) Курсы валют.
		|ВЫБРАТЬ
		|		КурсыВалют.Валюта                      КАК Валюта,
		|		ВЫБОР
		|			КОГДА КурсыВалют.КурсЗнаменатель = 0
		|				ТОГДА 0
		|			ИНАЧЕ КурсыВалют.КурсЧислитель / КурсыВалют.КурсЗнаменатель
		|		КОНЕЦ КАК Коэффициент
		|ПОМЕСТИТЬ КурсыВалют
		|ИЗ
		|	РегистрСведений.ОтносительныеКурсыВалют.СрезПоследних(КОНЕЦПЕРИОДА(&НачалоПериода, ДЕНЬ),
		|		БазоваяВалюта В (ВЫБРАТЬ
		|		БазоваяВалютаПоУмолчанию.Значение КАК Значение
		|	ИЗ
		|		Константа.БазоваяВалютаПоУмолчанию КАК БазоваяВалютаПоУмолчанию)) КАК КурсыВалют
		|	
		|ИНДЕКСИРОВАТЬ ПО
		|	Валюта";

	Тексты.Добавить(ТекстЗапроса);
	ТекстЗапроса = СтрСоединить(Тексты, ОбщегоНазначения.РазделительПакетаЗапросов());
	Возврат ТекстЗапроса;

КонецФункции

Функция ВременнаяТаблицаПеремещенияВнутриСети(ИмяТаблицыФильтра, ВТаблицеОтбораЕстьНазначения)
	
	ТекстЗапроса =
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	Перемещения.Номенклатура КАК Номенклатура,
		|	Перемещения.Характеристика КАК Характеристика,
		|	Перемещения.Склад КАК Склад,
		|	Перемещения.Назначение КАК Назначение,
		|	Перемещения.Заказ КАК Заказ,
		|	Перемещения.ЗаказаноОстаток КАК Заказано,
		|	Перемещения.ПоступитОстаток КАК Поступит,
		|	Перемещения.РезервироватьНаСкладеОстаток КАК РезервироватьНаСкладе,
		|	Перемещения.РезервироватьПоМереПоступленияОстаток КАК РезервироватьПоМереПоступления,
		|	Перемещения.ОтложитьРезервированиеОстаток КАК ОтложитьРезервирование,
		|	Перемещения.КОбеспечениюОстаток КАК КОбеспечению,
		|	Перемещения.НеОбеспечиватьОстаток КАК НеОбеспечивать,
		|	Перемещения.ЗаблокированоПоступитОстаток КАК ЗаблокированоПоступит,
		|	Перемещения.КРазблокировкеОстаток КАК КРазблокировке,
		|	Перемещения.РезервироватьНаСкладеИзЗаблокированныхОстаток КАК РезервироватьНаСкладеИзЗаблокированных,
		|	Перемещения.РезервироватьПоМереПоступленияИзЗаблокированныхОстаток КАК РезервироватьПоМереПоступленияИзЗаблокированных
		|ПОМЕСТИТЬ ВсеПеремещения
		|ИЗ
		|	РегистрНакопления.ЗапасыИПотребности.Остатки(,
		|			ТИПЗНАЧЕНИЯ(Заказ) В(
		|				ТИП(Справочник.КонтролируемыеПартии),
		|				ТИП(Документ.ЗаказНаПеремещение))
		|			И (Номенклатура, Характеристика, Склад, Назначение) В(
		|				ВЫБРАТЬ
		|					ТаблицаОтбора.Номенклатура КАК Номенклатура,
		|					ТаблицаОтбора.Характеристика КАК Характеристика,
		|					ТаблицаОтбора.Склад КАК Склад,
		|					&УсловиеОтбораНазначений КАК Назначение
		|				ИЗ
		|					ИмяТаблицыФильтраПереопределяемый КАК ТаблицаОтбора)) КАК Перемещения
		|ИНДЕКСИРОВАТЬ ПО
		|	Заказ
		|;
		|
		|/////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Заказы.Номенклатура КАК Номенклатура,
		|	Заказы.Характеристика КАК Характеристика,
		|	Заказы.Назначение КАК Назначение,
		|	Заказы.Центр КАК Склад,
		|	ВЫБОР
		|		КОГДА ТИПЗНАЧЕНИЯ(Заказы.Заказ) = ТИП(Справочник.КонтролируемыеПартии)
		|			ТОГДА Заказы.Заказ
		|		ИНАЧЕ НЕОПРЕДЕЛЕНО
		|	КОНЕЦ КАК Заказ,
		|	
		|	0 КАК ВНаличии,
		|	0 КАК ЗаблокированоВНаличии,
		|	
		|	СУММА(
		|		ВЫБОР
		|			КОГДА 0 > Заказы.Заказано
		|				ТОГДА 0
		|			КОГДА Заказы.НеОбеспечивать > Заказы.Заказано
		|				ТОГДА Заказы.Заказано
		|			ИНАЧЕ Заказы.НеОбеспечивать
		|		КОНЕЦ) КАК НеОбеспечивать,
		|	
		|	СУММА(
		|		ВЫБОР
		|			КОГДА 0 > Заказы.Заказано - Заказы.НеОбеспечивать
		|				ТОГДА 0
		|			КОГДА Заказы.КОбеспечению > Заказы.Заказано - Заказы.НеОбеспечивать
		|				ТОГДА Заказы.Заказано - Заказы.НеОбеспечивать
		|			ИНАЧЕ Заказы.КОбеспечению
		|		КОНЕЦ) КАК КОбеспечению,
		|	
		|	СУММА(
		|		ВЫБОР
		|			КОГДА 0 > Заказы.Заказано - Заказы.КОбеспечениюИтог
		|				ТОГДА 0
		|			КОГДА Заказы.ОтложитьРезервирование > Заказы.Заказано - Заказы.КОбеспечениюИтог
		|				ТОГДА Заказы.Заказано - Заказы.КОбеспечениюИтог
		|			ИНАЧЕ Заказы.ОтложитьРезервирование
		|		КОНЕЦ) КАК ОтложитьРезервирование,
		|	
		|	СУММА(
		|		ВЫБОР
		|			КОГДА 0 > Заказы.Заказано - Заказы.ОтложитьРезервированиеИтог
		|				ТОГДА 0
		|			КОГДА Заказы.РезервироватьПоМереПоступления > Заказы.Заказано - Заказы.ОтложитьРезервированиеИтог
		|				ТОГДА Заказы.Заказано - Заказы.ОтложитьРезервированиеИтог
		|			ИНАЧЕ Заказы.РезервироватьПоМереПоступления
		|		КОНЕЦ) КАК РезервироватьПоМереПоступления,
		|	
		|	СУММА(
		|		ВЫБОР
		|			КОГДА 0 > Заказы.Заказано -Заказы.РезервироватьПоМереПоступленияИтог
		|				ТОГДА 0
		|			КОГДА Заказы.РезервироватьНаСкладе > Заказы.Заказано -Заказы.РезервироватьПоМереПоступленияИтог
		|				ТОГДА Заказы.Заказано -Заказы.РезервироватьПоМереПоступленияИтог
		|			ИНАЧЕ Заказы.РезервироватьНаСкладе
		|		КОНЕЦ) КАК РезервироватьНаСкладе,
		|	
		|	СУММА(
		|		ВЫБОР
		|			КОГДА
		|				0 > Заказы.Заказано - Заказы.РезервироватьНаСкладеИтог
		|				ТОГДА 0
		|			КОГДА Заказы.РезервироватьПоМереПоступленияИзЗаблокированных > Заказы.Заказано - Заказы.РезервироватьНаСкладеИтог
		|				ТОГДА Заказы.Заказано - Заказы.РезервироватьНаСкладеИтог
		|			ИНАЧЕ Заказы.РезервироватьПоМереПоступленияИзЗаблокированных
		|		КОНЕЦ) КАК РезервироватьПоМереПоступленияИзЗаблокированных,
		|	
		|	СУММА(
		|		ВЫБОР
		|			КОГДА 0 > Заказы.Заказано - Заказы.РезервироватьПоМереПоступленияИзЗаблокированныхИтог
		|				ТОГДА 0
		|			КОГДА Заказы.РезервироватьНаСкладеИзЗаблокированных > Заказы.Заказано - Заказы.РезервироватьПоМереПоступленияИзЗаблокированныхИтог
		|				ТОГДА Заказы.Заказано - Заказы.РезервироватьПоМереПоступленияИзЗаблокированныхИтог
		|			ИНАЧЕ Заказы.РезервироватьНаСкладеИзЗаблокированных
		|		КОНЕЦ) КАК РезервироватьНаСкладеИзЗаблокированных,
		|	
		|	СУММА(
		|		ВЫБОР
		|			КОГДА Заказы.Заказано > Заказы.РезервироватьНаСкладеИзЗаблокированныхИтог
		|				ТОГДА Заказы.РезервироватьНаСкладеИзЗаблокированныхИтог
		|			ИНАЧЕ Заказы.Заказано
		|		КОНЕЦ) КАК Заказано,
		|	
		|	СУММА(
		|		ВЫБОР
		|			КОГДА Заказы.Поступит > Заказы.РезервироватьНаСкладеИзЗаблокированныхИтог
		|				ТОГДА Заказы.РезервироватьНаСкладеИзЗаблокированныхИтог
		|			ИНАЧЕ Заказы.Поступит
		|		КОНЕЦ) КАК Поступит,
		|	
		|	СУММА(
		|		ВЫБОР
		|			КОГДА Заказы.ЗаблокированоПоступит > Заказы.РезервироватьНаСкладеИзЗаблокированныхИтог
		|				ТОГДА Заказы.РезервироватьНаСкладеИзЗаблокированныхИтог
		|			ИНАЧЕ Заказы.ЗаблокированоПоступит
		|		КОНЕЦ) КАК ЗаблокированоПоступит,
		|	
		|	СУММА(
		|		ВЫБОР
		|			КОГДА Заказы.КРазблокировке > Заказы.РезервироватьНаСкладеИзЗаблокированныхИтог
		|				ТОГДА Заказы.РезервироватьНаСкладеИзЗаблокированныхИтог
		|			ИНАЧЕ Заказы.КРазблокировке
		|		КОНЕЦ) КАК КРазблокировке
		|ПОМЕСТИТЬ ПеремещенияВнутриСети
		|ИЗ(
		|	ВЫБРАТЬ
		|		Перемещения.Номенклатура КАК Номенклатура,
		|		Перемещения.Характеристика КАК Характеристика,
		|		Перемещения.Назначение КАК Назначение,
		|		Перемещения.Заказ КАК Заказ,
		|		Топология.Центр КАК Центр,
		|		СУММА(Перемещения.РезервироватьНаСкладеИзЗаблокированных) КАК РезервироватьНаСкладеИзЗаблокированных,
		|		СУММА(Перемещения.РезервироватьПоМереПоступленияИзЗаблокированных) КАК РезервироватьПоМереПоступленияИзЗаблокированных,
		|		СУММА(Перемещения.РезервироватьНаСкладе) КАК РезервироватьНаСкладе,
		|		СУММА(Перемещения.РезервироватьПоМереПоступления) КАК РезервироватьПоМереПоступления,
		|		СУММА(Перемещения.ОтложитьРезервирование) КАК ОтложитьРезервирование,
		|		СУММА(Перемещения.КОбеспечению) КАК КОбеспечению,
		|		СУММА(Перемещения.НеОбеспечивать) КАК НеОбеспечивать,
		|		
		|		СУММА(Перемещения.Заказано) КАК Заказано,
		|		СУММА(Перемещения.Поступит) КАК Поступит,
		|		СУММА(Перемещения.ЗаблокированоПоступит) КАК ЗаблокированоПоступит,
		|		СУММА(Перемещения.КРазблокировке) КАК КРазблокировке,
		|		
		|		СУММА(Перемещения.РезервироватьНаСкладеИзЗаблокированных
		|				+ Перемещения.РезервироватьПоМереПоступленияИзЗаблокированных
		|				+ Перемещения.РезервироватьНаСкладе
		|				+ Перемещения.РезервироватьПоМереПоступления
		|				+ Перемещения.ОтложитьРезервирование
		|				+ Перемещения.КОбеспечению
		|				+ Перемещения.НеОбеспечивать) КАК РезервироватьНаСкладеИзЗаблокированныхИтог,
		|		СУММА(Перемещения.РезервироватьПоМереПоступленияИзЗаблокированных
		|				+ Перемещения.РезервироватьНаСкладе
		|				+ Перемещения.РезервироватьПоМереПоступления
		|				+ Перемещения.ОтложитьРезервирование
		|				+ Перемещения.КОбеспечению
		|				+ Перемещения.НеОбеспечивать) КАК РезервироватьПоМереПоступленияИзЗаблокированныхИтог,
		|		СУММА(Перемещения.РезервироватьНаСкладе
		|				+ Перемещения.РезервироватьПоМереПоступления
		|				+ Перемещения.ОтложитьРезервирование
		|				+ Перемещения.КОбеспечению
		|				+ Перемещения.НеОбеспечивать) КАК РезервироватьНаСкладеИтог,
		|		СУММА(Перемещения.РезервироватьПоМереПоступления
		|				+ Перемещения.ОтложитьРезервирование
		|				+ Перемещения.КОбеспечению
		|				+ Перемещения.НеОбеспечивать) КАК РезервироватьПоМереПоступленияИтог,
		|		СУММА(Перемещения.ОтложитьРезервирование
		|				+ Перемещения.КОбеспечению
		|				+ Перемещения.НеОбеспечивать) КАК ОтложитьРезервированиеИтог,
		|		СУММА(Перемещения.КОбеспечению + Перемещения.НеОбеспечивать) КАК КОбеспечениюИтог
		|	ИЗ
		|		ВсеПеремещения КАК Перемещения
		|		
		|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ ТопологияСкладов КАК Топология
		|			ПО Топология.Номенклатура   = Перемещения.Номенклатура
		|			 И Топология.Характеристика = Перемещения.Характеристика
		|			 И Топология.Склад          = Перемещения.Склад
		|		
		|	СГРУППИРОВАТЬ ПО
		|		Перемещения.Номенклатура,
		|		Перемещения.Характеристика,
		|		Перемещения.Назначение,
		|		Перемещения.Заказ,
		|		Топология.Центр) КАК Заказы
		|СГРУППИРОВАТЬ ПО
		|	Заказы.Номенклатура,
		|	Заказы.Характеристика,
		|	Заказы.Назначение,
		|	Заказы.Центр,
		|	ВЫБОР
		|		КОГДА ТИПЗНАЧЕНИЯ(Заказы.Заказ) = ТИП(Справочник.КонтролируемыеПартии)
		|			ТОГДА Заказы.Заказ
		|		ИНАЧЕ НЕОПРЕДЕЛЕНО
		|	КОНЕЦ
		|ИНДЕКСИРОВАТЬ ПО
		|	Номенклатура,Характеристика,Склад,Назначение
		|;
		|
		|/////////////////////////////////////////////
		|УНИЧТОЖИТЬ ВсеПеремещения";
		
	Подстановка = "ЗНАЧЕНИЕ(Справочник.Назначения.ПустаяСсылка)";
	ПодстановкаНазначение = "ТаблицаОтбора.Назначение";
	ПодстановкаИтоговая = ?(ВТаблицеОтбораЕстьНазначения, ПодстановкаНазначение, Подстановка);
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&УсловиеОтбораНазначений", ПодстановкаИтоговая);
	
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "ИмяТаблицыФильтраПереопределяемый", ИмяТаблицыФильтра);
	Возврат ТекстЗапроса;
	
КонецФункции

