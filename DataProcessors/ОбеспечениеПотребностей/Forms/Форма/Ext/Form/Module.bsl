	|- [ К поступлению ]
	|- [ Страховой запас ]
	|+ [ Восполнение страхового запаса ]'");
	Элементы.ФормулаТочкаЗаказаНеДостигнута1.Подсказка = НСтр("ru = '[ Максимальный запас ]
	|- [ К поступлению ]
	|- (  [ В наличии ] - [ Минимальный запас ]  )'");
	Элементы.ФормулаТочкаЗаказаНеДостигнута2.Подсказка = НСтр("ru = '[ Максимальный запас ]
	|- [ К поступлению ]
	|- (  [ В наличии ] - [ Минимальный запас ]  )'");
	Элементы.ФормулаТочкаЗаказаНеДостигнута3.Подсказка = НСтр("ru = '[ Максимальный запас ]
	|- [ К поступлению ]
	|- (  [ Остаток ] - [ Минимальный запас ]  )
	|- [ Страховой запас ]'");
	Элементы.ФормулаТочкаЗаказаНеДостигнута4.Подсказка = НСтр("ru = '[ Максимальный запас ]
	|- [ К поступлению ]
	|- (  [ Остаток ] - [ Минимальный запас ]  )
	|- [ Страховой запас ]'");
	
	Элементы.ШагРедактированиеЗаказов.Заголовок = НСтр("ru = 'Шаг редактирование заявок'");
	Элементы.ШагСформированныеЗаказы.Заголовок = НСтр("ru = 'Шаг сформированные заявки'");
		
	ФормироватьЗаявкиНаЗакупку = Истина;
	Элементы.УстановитьСтатус.Видимость = Ложь; // Статусы для заявок на закупку не устанавливаются, остальные неактуальны.
	
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьФормуВыбораМенеджера(Оповещение)
	
	ПараметрыОткрытия = Новый Структура;
