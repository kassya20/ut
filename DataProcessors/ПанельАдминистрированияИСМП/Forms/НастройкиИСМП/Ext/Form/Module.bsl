&НаСервере
Процедура УстановитьУсловноеОформление()
	
	УсловноеОформление.Элементы.Очистить();
	
	// отображение пустых дат контролей и действующих дат
	СоответствиеНастроекДатИЭлементовФормы = Новый Соответствие;
	СоответствиеНастроекДатИЭлементовФормы.Вставить("МаркируемаяПродукция.ДатаНачалаПроизводства",
		Элементы.МаркируемаяПродукцияДатаНачалаПроизводства.Имя);
	СоответствиеНастроекДатИЭлементовФормы.Вставить("МаркируемаяПродукция.ДатаНачалаВыводаИзОборота",
		Элементы.МаркируемаяПродукцияДатаНачалаВыводаИзОборота.Имя);
	СоответствиеНастроекДатИЭлементовФормы.Вставить("МаркируемаяПродукция.ДатаНачалаЗапретаПродажБезМарок",
		Элементы.МаркируемаяПродукцияДатаНачалаЗапретаПродажБезМарок.Имя);
	СоответствиеНастроекДатИЭлементовФормы.Вставить("МаркируемаяПродукция.ДатаНачалаОформленияУПДОСУ",
		Элементы.МаркируемаяПродукцияДатаНачалаОформленияУПДОСУ.Имя);
	СоответствиеНастроекДатИЭлементовФормы.Вставить("МаркируемаяПродукция.ДатаНачалаОформленияУПДПоштучно",
		Элементы.МаркируемаяПродукцияДатаНачалаОформленияУПДПоштучно.Имя);
	СоответствиеНастроекДатИЭлементовФормы.Вставить("МаркируемаяПродукция.ДатаНачалаРазрешительногоРежима",
		Элементы.МаркируемаяПродукцияДатаНачалаРазрешительногоРежима.Имя);
	СоответствиеНастроекДатИЭлементовФормы.Вставить("МаркируемаяПродукция.ДатаНачалаРозничныхПродаж",
		Элементы.МаркируемаяПродукцияДатаНачалаРозничныхПродаж.Имя);
	СоответствиеНастроекДатИЭлементовФормы.Вставить("МаркируемаяПродукция.ДатаНачалаИспользованияЛокальногоМодуля",
		Элементы.МаркируемаяПродукцияДатаНачалаИспользованияЛокальногоМодуля.Имя);
	СоответствиеНастроекДатИЭлементовФормы.Вставить("МаркируемаяПродукция.ДатаНачалаПрослеживаемостиПеремещенияМеждуМОД",
		Элементы.МаркируемаяПродукцияДатаНачалаПрослеживаемостиПеремещенияМеждуМОД.Имя);
	СоответствиеНастроекДатИЭлементовФормы.Вставить("МаркируемаяПродукция.ДатаНачалаКонтроляРазрешительныхДокументов",
		Элементы.МаркируемаяПродукцияДатаНачалаКонтроляРазрешительныхДокументов.Имя);
	
	ТекущаяДата = НачалоДня(ТекущаяДатаСеанса());
	
	Для Каждого КлючИЗначение Из СоответствиеНастроекДатИЭлементовФормы Цикл
		
		Элемент = УсловноеОформление.Элементы.Добавить();
		
		ПолеЭлемента = Элемент.Поля.Элементы.Добавить();
		ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(КлючИЗначение.Значение);
		
		ОтборЭлемента = Элемент.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
		ОтборЭлемента.ЛевоеЗначение = Новый ПолеКомпоновкиДанных(КлючИЗначение.Ключ);
		ОтборЭлемента.ВидСравнения  = ВидСравненияКомпоновкиДанных.НеЗаполнено;
		
		Элемент.Оформление.УстановитьЗначениеПараметра("Текст",      НСтр("ru = 'нет данных'"));
		Элемент.Оформление.УстановитьЗначениеПараметра("ЦветТекста", ЦветаСтиля.ЦветТекстаНеТребуетВниманияГосИС);
		
		Элемент = УсловноеОформление.Элементы.Добавить();
		
		ПолеЭлемента = Элемент.Поля.Элементы.Добавить();
		ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(КлючИЗначение.Значение);
		
		ГруппаОтбора = Элемент.Отбор.Элементы.Добавить(Тип("ГруппаЭлементовОтбораКомпоновкиДанных"));
		ГруппаОтбора.ТипГруппы = ТипГруппыЭлементовОтбораКомпоновкиДанных.ГруппаИ;
		
		ОтборЭлемента = ГруппаОтбора.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
		ОтборЭлемента.ЛевоеЗначение = Новый ПолеКомпоновкиДанных(КлючИЗначение.Ключ);
		ОтборЭлемента.ВидСравнения  = ВидСравненияКомпоновкиДанных.МеньшеИлиРавно;
		ОтборЭлемента.ПравоеЗначение = ТекущаяДата;
		
		ОтборЭлемента = ГруппаОтбора.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
		ОтборЭлемента.ЛевоеЗначение = Новый ПолеКомпоновкиДанных(КлючИЗначение.Ключ);
		ОтборЭлемента.ВидСравнения  = ВидСравненияКомпоновкиДанных.Заполнено;
		
		Элемент.Оформление.УстановитьЗначениеПараметра("Текст", НСтр("ru = 'действует'"));
		
	КонецЦикла;
	
	Если ЭтоРасширеннаяВерсияГосИС Тогда
		МодульПанельАдминистрированияИСМП = ОбщегоНазначенияИСПовтИсп.ОбщийМодуль("ПанельАдминистрированияИСМП");
		МодульПанельАдминистрированияИСМП.УстановитьУсловноеОформление(ЭтотОбъект);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
