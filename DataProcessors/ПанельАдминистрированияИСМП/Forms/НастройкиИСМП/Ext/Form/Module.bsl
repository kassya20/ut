#КонецОбласти

#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ЭтоРасширеннаяВерсияГосИС = ОбщегоНазначенияИСМПКлиентСерверПовтИсп.ЭтоРасширеннаяВерсияГосИС();
	УстановитьУсловноеОформление();
	
	Если Параметры.Свойство("АвтоТест") Тогда
		Возврат;
	КонецЕсли;
	
	Если Параметры.РежимОткрытия = "ТоварныеГруппы" Тогда
		УпрощеннаяИнтеграцияБЭД = Истина;
	ИначеЕсли ЭтоРасширеннаяВерсияГосИС Тогда
		МодульИнтеграцияИС = ОбщегоНазначенияИСПовтИсп.ОбщийМодуль("ИнтеграцияИС");
		УпрощеннаяИнтеграцияБЭД = МодульИнтеграцияИС.УпрощеннаяИнтеграцияБЭД();
	КонецЕсли;
	
	ЦветГиперссылки = ЦветаСтиля.ЦветГиперссылкиГосИС;
	
	ЗаполнитьМаркируемуюПродукцию();
	
	Если ЭтоРасширеннаяВерсияГосИС Тогда
		МодульПанельАдминистрированияИСМП = ОбщегоНазначенияИСПовтИсп.ОбщийМодуль("ПанельАдминистрированияИСМП");
		МодульПанельАдминистрированияИСМП.ПриСозданииНаСервере(ЭтотОбъект, Отказ, СтандартнаяОбработка);
	КонецЕсли;
	
	ЭтоПолноправныйПользователь = Пользователи.ЭтоПолноправныйПользователь();
	
	ПараметрыАварийногоРежима = ПолучитьПараметрыАварийногоРежима();
	
	СодержимоеКонстанты = ОбщегоНазначенияИСМПКлиентСерверПовтИсп.НастройкиСканированияКодовМаркировки();
	ЗаполнитьЗначенияСвойств(ЭтотОбъект, СодержимоеКонстанты);
	
	СписокУчитываемойПродукцииТребующейОбязательнойПроверкиПриПродажеВРозницу.ЗагрузитьЗначения(
		КонструкторИСМПОбщегоНазначенияКлиентСервер.ВидыПродукцииОбязательнойОнлайнПроверкиПередРозничнойПродажей());
	
	УстановитьСоответствиеИспользованияРегламентныхЗаданийКонстантам();
	НастроитьЭлементыФормыНаСервере();
	// Обновление состояния элементов
	НастроитьФормуПриИзменииЭлементовУправления();
	УстановитьДоступность();
	
	ОбщегоНазначенияСобытияФормИСПереопределяемый.ПриСозданииНаСервере(ЭтотОбъект, Отказ, СтандартнаяОбработка);
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	ОбновитьПредставлениеАварийногоРежима();
	
КонецПроцедуры

&НаКлиенте
Процедура ПриЗакрытии(ЗавершениеРаботы)
	
	Если ЗавершениеРаботы Тогда
		Возврат;
	КонецЕсли;
	
	ОбновитьИнтерфейсПрограммы();
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	Если ИмяСобытия = "ИСМП_СинхронизированыТоварныеГруппы" Тогда
		ЗаполнитьМаркируемуюПродукцию();
		ОбщегоНазначенияКлиент.ОбновитьИнтерфейсПрограммы();
	КонецЕсли;
	
КонецПроцедуры

