&НаКлиенте
Процедура МаркируемаяПродукцияПередНачаломДобавления(Элемент, Отказ, Копирование, Родитель, ЭтоГруппа, Параметр)
	
	Отказ = Истина;
	
	Если Копирование Тогда
		Возврат;
	КонецЕсли;
	
	Если ОбщегоНазначенияИСВызовСервера.КлассификаторНастроекВидовПродукцийЗагружен() Тогда
		ОткрытьФормуВыбораВидаПродукцииПриДобавлении();
	Иначе
		
		ЗагрузкаКлассификатораНастроекЗавершение = Новый ОписаниеОповещения(
			"ЗагрузкаКлассификатораНастроекЗавершение", ЭтотОбъект);
		
		ДлительнаяОперация = НачатьЗагрузкуКлассификатораНастроекВидовПродукции();
		
		ПараметрыОжидания = ДлительныеОперацииКлиент.ПараметрыОжидания(ЭтотОбъект);
		ПараметрыОжидания.ТекстСообщения             = НСтр("ru='Выполняется загрузка классификатора настроек видов продукции.'");
		ПараметрыОжидания.ВыводитьСообщения          = Истина;
		
		ДлительныеОперацииКлиент.ОжидатьЗавершение(
			ДлительнаяОперация,
			ЗагрузкаКлассификатораНастроекЗавершение,
			ПараметрыОжидания);
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура МаркируемаяПродукцияПередУдалением(Элемент, Отказ)
	
	Отказ = Истина;
	
	ПараметрыЗаписи = АдминистрированиеИСМПКлиентСервер.ПараметрыЗаписиМаркируемойПродукции();
	ПараметрыЗаписи.ЗаписыватьВидПродукции = Истина;
	
	Для Каждого Строка Из Элемент.ВыделенныеСтроки Цикл
		ТекущиеДанные = МаркируемаяПродукция.НайтиПоИдентификатору(Строка);
		Если ТекущиеДанные.ПолучитьРодителя() <> Неопределено Тогда
			Продолжить;
		КонецЕсли;
		СтрокаДанных = АдминистрированиеИСМПКлиентСервер.СтрокаДанныхЗаписиМаркируемойПродукции();
		ЗаполнитьЗначенияСвойств(СтрокаДанных, ТекущиеДанные);
		СтрокаДанных.ВидПродукцииВерхнегоУровня = Истина;
		СтрокаДанных.УдалениеДанных = Истина;
		ПараметрыЗаписи.Данные.Добавить(СтрокаДанных);
		Для Каждого ТекущиеДанные Из ТекущиеДанные.ПолучитьЭлементы() Цикл
			СтрокаДанных = АдминистрированиеИСМПКлиентСервер.СтрокаДанныхЗаписиМаркируемойПродукции();
			ЗаполнитьЗначенияСвойств(СтрокаДанных, ТекущиеДанные);
			СтрокаДанных.УдалениеДанных = Истина;
			ПараметрыЗаписи.Данные.Добавить(СтрокаДанных);
		КонецЦикла;
	КонецЦикла;
	
	Если ПараметрыЗаписи.Данные.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	РезультатЗаписи = ЗаписатьДанныеМаркируемойПродукции(ПараметрыЗаписи);
	
	Если ЗначениеЗаполнено(РезультатЗаписи) Тогда
		ОчиститьСообщения();
		ОбщегоНазначенияКлиент.СообщитьПользователю(РезультатЗаписи);
	Иначе
		ЗаполнитьМаркируемуюПродукцию();
		ПослеРедактированияСпискаМаркируемойПродукции();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура МаркируемаяПродукцияПередНачаломИзменения(Элемент, Отказ)
	
	ТекущиеДанные = Элемент.ТекущиеДанные;
	
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если ДатыНачалаРаботыСМаркируемойПродукцией = Неопределено Тогда
		ДатыНачалаРаботыСМаркируемойПродукцией = Новый Структура;
	КонецЕсли;
	
	Для Каждого Имя Из КонструкторИСМПОбщегоНазначенияКлиентСервер.ИменаДатНачалаРаботыСМаркируемойПродукцией() Цикл
		ДатыНачалаРаботыСМаркируемойПродукцией.Вставить(Имя, ТекущиеДанные[Имя]);
	КонецЦикла;
	
КонецПроцедуры

