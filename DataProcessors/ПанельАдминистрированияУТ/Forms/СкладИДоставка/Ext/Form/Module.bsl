&НаСервере
Процедура ВыключитьКонтрольРезервовТоваровПоЗаказамСервер()
	
	ПараметрыСеанса.ПроводитьБезКонтроляРезервовТоваровПоЗаказам = Не ПараметрыСеанса.ПроводитьБезКонтроляРезервовТоваровПоЗаказам;
	
	ОбновитьНадписьКнопкиВыключитьКонтрольРезервовТоваровПоЗаказам(ПараметрыСеанса.ПроводитьБезКонтроляРезервовТоваровПоЗаказам);
	
	Если ПараметрыСеанса.ПроводитьБезКонтроляРезервовТоваровПоЗаказам Тогда
		ТекстСообщения = НСтр("ru = 'Пользователем %ИмяПользователя% в рамках своего сеанса выключен контроль резервов по заказам.'",
			ОбщегоНазначения.КодОсновногоЯзыка());
	Иначе
		ТекстСообщения = НСтр("ru = 'Пользователем %ИмяПользователя% возобновлен контроль резервов по заказам.'",
			ОбщегоНазначения.КодОсновногоЯзыка());
	КонецЕсли;
	ТекстСообщения = СтрЗаменить(ТекстСообщения, "%ИмяПользователя%", Пользователи.ТекущийПользователь());
	
	ЗаписьЖурналаРегистрации(ОбеспечениеВДокументахСервер.ИмяСобытияВыключенКонтрольРезервовТоваровПоЗаказам(),
		УровеньЖурналаРегистрации.Предупреждение, , , ТекстСообщения);
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьНадписьКнопкиВыключитьКонтрольРезервовТоваровПоЗаказам(КонтрольВыключен)
	
	Если КонтрольВыключен Тогда
		Элементы.ВыключитьКонтрольРезервовТоваровПоЗаказам.Заголовок = НСтр("ru = 'Возобновить контроль резервов'");
		Элементы.ВыключитьКонтрольРезервовТоваровПоЗаказам.РасширеннаяПодсказка.Заголовок
			= НСтр("ru = 'Восстановление контроля резервов товаров по заказам для текущего пользователя, ранее выключенных на время сеанса.'");
	Иначе
		Элементы.ВыключитьКонтрольРезервовТоваровПоЗаказам.Заголовок = НСтр("ru = 'Отключить контроль резервов (на время сеанса)'");
		Элементы.ВыключитьКонтрольРезервовТоваровПоЗаказам.РасширеннаяПодсказка.Заголовок
			= НСтр("ru = 'Выключение контроля резервов товаров по заказам для текущего пользователя на время сеанса работы. Возможность также доступна в ""НСИ и администрирование"" - ""Персональные настройки"".'");
	КонецЕсли;
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция СтатусПереходаНаДоставку25()
	
	ДанныеСтатуса = ДанныеСтатусаПереходаНаДоставку25();
	ДанныеСтатуса.Вставить("ПереходЗапущен", Ложь);
	ДанныеСтатуса.Вставить("ДанныеОбработаны", Ложь);
	ДанныеСтатуса.Вставить("ПереходЗавершен", Ложь);
	
	СтатусПерехода = ДоставкаТоваров.СтатусПереходаНаДоставку25();
	ЗаполнитьЗначенияСвойств(ДанныеСтатуса, СтатусПерехода);
	
	Возврат ДанныеСтатуса;
	
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Функция ДанныеСтатусаПереходаНаДоставку25()
	
	ДанныеСтатуса = Новый Структура;
	ДанныеСтатуса.Вставить("ПереходЗапущен", Ложь);
	ДанныеСтатуса.Вставить("ДанныеОбработаны", Ложь);
	ДанныеСтатуса.Вставить("ПереходЗавершен", Ложь);
	
	Возврат ДанныеСтатуса;
	
КонецФункции

&НаСервере
Процедура УстановитьВидимостьЭлементовПереходаНаДоставку25(Знач ИспользуетсяДоставка25 = Неопределено, Знач СтатусПерехода = Неопределено)
	
	ИспользуетсяДоставка = НаборКонстант.ИспользоватьУправлениеДоставкой;
	Если ИспользуетсяДоставка25 = Неопределено Тогда
		
		ИспользуетсяДоставка25 = ДоставкаТоваровКлиентСервер.ИспользуетсяДоставка25();
		
	КонецЕсли;
	
	ВидимостьГруппы = ИспользуетсяДоставка И (НЕ ИспользуетсяДоставка25);
	ОбщегоНазначенияУТКлиентСервер.УстановитьСвойствоЭлементаФормы(
		Элементы,
		"ГруппаУправлениеДоставкой25",
		"Видимость",
		ВидимостьГруппы);
	
	Если ВидимостьГруппы Тогда
		
		Если СтатусПерехода = Неопределено Тогда
			
			СтатусПерехода = СтатусПереходаНаДоставку25();
			
		КонецЕсли;
		
		ОтображатьКомандуЗапуска = НЕ СтатусПерехода.ПереходЗапущен;
		ОтображатьКомандуСостояния = СтатусПерехода.ПереходЗапущен И (НЕ СтатусПерехода.ДанныеОбработаны);
		ОтображатьКомандуЗавершения = СтатусПерехода.ДанныеОбработаны;
		
		ОбщегоНазначенияУТКлиентСервер.УстановитьСвойствоЭлементаФормы(
			Элементы,
			"ПерейтиНаДоставку25",
			"Видимость",
			ОтображатьКомандуЗапуска);
		
		ОбщегоНазначенияУТКлиентСервер.УстановитьСвойствоЭлементаФормы(
			Элементы,
			"ПроверитьСостояниеПереходаНаДоставку25",
			"Видимость",
			ОтображатьКомандуСостояния);
		
		ОбщегоНазначенияУТКлиентСервер.УстановитьСвойствоЭлементаФормы(
			Элементы,
			"ЗавершитьПереходНаДоставку25",
			"Видимость",
			ОтображатьКомандуЗавершения);
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура УстановитьДоступностьИзмененияПорядкаОформленияНакладныхИОрдеров()
	
	ИзменениеДоступно = ДоступноИзменениеПорядкаОформленияНакладныхИОрдеров(
		НаборКонстант.ПорядокОформленияНакладныхРасходныхОрдеров);
	
	Элементы.ПорядокОформленияНакладныхРасходныхОрдеров.Доступность = ИзменениеДоступно;
	Элементы.ГруппаКомментарийПорядокОформленияРасходныхОрдеров.Видимость = Не ИзменениеДоступно;
	
КонецПроцедуры

&НаСервереБезКонтекста
Процедура ЗавершитьПереходНаДоставку25НаСервере()
	
	ДоставкаТоваров.ЗавершитьПереходНаДоставку25();
	
КонецПроцедуры

&НаСервере
Процедура УстановитьТекстПодсказкиУправленияДоставкой()
	
	ТекстПодсказки20 = НСтр("ru = 'Возможность указывать реквизиты доставки, использовать зоны доставки, формировать задания на перевозку.'");
	ТекстПодсказки25 = НСтр("ru = 'Возможность планировать доставку в документах, формировать рейсы.'");
	
	ИспользуетсяДоставка = ДоставкаТоваровКлиентСервер.ИспользуетсяДоставка();
	
	Если ИспользуетсяДоставка Тогда
		
		Если ДоставкаТоваровКлиентСервер.ИспользуетсяДоставка20() Тогда
			
			ТекстПодсказки = ТекстПодсказки20;
			
		Иначе
			
			ТекстПодсказки = ТекстПодсказки25;
			
		КонецЕсли;
		
	ИначеЕсли ДоставкаТоваров.ИспользоваласьДоставка25() Тогда
		
		ТекстПодсказки = ТекстПодсказки25;
		
	Иначе
		
		ТекстПодсказки = ТекстПодсказки20;
		
	КонецЕсли;
	
	Элементы.ИспользоватьУправлениеДоставкой.РасширеннаяПодсказка.Заголовок = ТекстПодсказки;
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ИнформацияОСоединениях()
	
	Информация = СоединенияИБ.ИнформацияОСоединениях();
	Возврат Информация;
	
КонецФункции

&НаСервереБезКонтекста
Функция ДоступноИзменениеПорядкаОформленияНакладныхИОрдеров(Знач ПорядокОформления)
	
	ИспользуетсяДоставка25 = ДоставкаТоваровКлиентСервер.ИспользуетсяДоставка25();
	БлокироватьНастройку =
		(ИспользуетсяДоставка25
			И ПорядокОформления = Перечисления.ПорядокОформленияНакладныхРасходныхОрдеров.СначалаОрдера
			И ДоставкаТоваров.ЕстьСкладыССборкойПослеДоставки());
	
	Возврат Не БлокироватьНастройку;
	
КонецФункции

