&НаКлиенте
Асинх Процедура ПерейтиНаДоставку25(Команда)
	
	СтатусПерехода = СтатусПереходаНаДоставку25();
	
	Если СтатусПерехода.ПереходЗавершен Тогда
		
		СообщитьОЗавершенномПереходеНаДоставку25();
		УстановитьДоступность();
		
	ИначеЕсли НЕ СтатусПерехода.ПереходЗапущен Тогда 
		
		КнопкиПредупреждения = Новый СписокЗначений;
		КнопкиПредупреждения.Добавить(КодВозвратаДиалога.ОК, "Продолжить");
		КнопкиПредупреждения.Добавить(КодВозвратаДиалога.Отмена);
		
		ТекстВопроса = ТекстПредупрежденияНачалаПереходаНаД25();
		
		Ответ = Ждать ВопросАсинх(ТекстВопроса, КнопкиПредупреждения,, КодВозвратаДиалога.ОК);
		Если Ответ = КодВозвратаДиалога.ОК Тогда
			
			НачатьПереходНаДоставку25ПослеПроверки();
			
		КонецЕсли;
		
	ИначеЕсли НЕ СтатусПерехода.ДанныеОбработаны Тогда
		
		ОткрытьФорму("Обработка.ПомощникПереходаНаДоставкуВерсии25.Форма");
		УстановитьДоступность();
		
	Иначе
		
		СообщитьОНеобходимостиЗавершенияПереходаНаДоставку25();
		УстановитьДоступность();
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПроверитьСостояниеПереходаНаДоставку25(Команда)
	
	СтатусПерехода = СтатусПереходаНаДоставку25();
	
	Если СтатусПерехода.ПереходЗавершен Тогда
		
		СообщитьОЗавершенномПереходеНаДоставку25();
		УстановитьДоступность();
		
	ИначеЕсли СтатусПерехода.ПереходЗапущен
			И НЕ СтатусПерехода.ДанныеОбработаны Тогда
		
		ОткрытьФорму("Обработка.ПомощникПереходаНаДоставкуВерсии25.Форма");
		
	Иначе
		
		СообщитьОНеобходимостиЗавершенияПереходаНаДоставку25();
		УстановитьДоступность();
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Асинх Процедура ЗавершитьПереходНаДоставку25(Команда)
	
	СтатусПерехода = СтатусПереходаНаДоставку25();
	
	Если СтатусПерехода.ПереходЗавершен Тогда
		
		СообщитьОЗавершенномПереходеНаДоставку25();
		
	ИначеЕсли СтатусПерехода.ПереходЗапущен
			И СтатусПерехода.ДанныеОбработаны Тогда
		
		ИнформацияОСоединениях = ИнформацияОСоединениях();
		Если ИнформацияОСоединениях.НаличиеАктивныхСоединений Тогда
			
			ТекстСообщения = ДоставкаТоваровКлиентСервер.ТекстПроверкиАктивныхСеансов();
			ПредупреждениеАсинх(ТекстСообщения);
			
			Возврат;
			
		КонецЕсли;
		
		ЗавершитьПереход = Ждать ДоставкаТоваровКлиент.ПроверитьВозможностьПереходаНаДоставку25Асинх();
		
		Если ЗавершитьПереход Тогда
			
			ЗавершитьПереходНаДоставку25НаСервере();
			
			ОбновитьИнтерфейс = Истина;
			ОбновитьИнтерфейсПрограммы();
			УстановитьДоступность();
			ПоказатьОповещениеОЗавершенииПереходаНаДоставку25();
			
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

