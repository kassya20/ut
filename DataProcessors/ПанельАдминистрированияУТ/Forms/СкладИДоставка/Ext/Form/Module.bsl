	Если ДоступноНачалоПерехода Тогда
		
		ТекстВопроса = НСтр("ru = 'Будет запущена операция перехода на управление доставкой версии 2.5. Длительность операции зависит от количества партнеров и складов с заполненными адресами, а также от загруженности оборудования.
								  |Продолжить?'");
		
		Ответ = Ждать ВопросАсинх(ТекстВопроса, РежимДиалогаВопрос.ДаНет);
		Если Ответ = КодВозвратаДиалога.Да Тогда
			
			ПараметрыОткрытия = Новый Структура;
			ПараметрыОткрытия.Вставить("ЗапускПерехода", Истина);
			
			ОткрытьФорму("Обработка.ПомощникПереходаНаДоставкуВерсии25.Форма", ПараметрыОткрытия);
			
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьСтатусПереходаНаДоставку25()
	
	Статус = СтатусПереходаНаДоставку25();
	
	Если Статус.ПереходЗавершен Тогда
		
