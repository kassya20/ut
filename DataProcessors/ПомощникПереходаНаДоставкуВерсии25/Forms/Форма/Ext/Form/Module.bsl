//@strict-types

#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Если Параметры.Свойство("ЗапускПерехода") Тогда
		
		ЗапускПерехода = Параметры.ЗапускПерехода;
		
	КонецЕсли;
	
	Статус = СтатусПерехода();
	ЗаполнитьЗначенияСвойств(ЭтотОбъект, Статус);
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	Если ПереходЗавершен Тогда
		
		ОповеститьОбОкончанииПереходаИЗакрытьПомощник();
		
	КонецЕсли;
	
	УстановитьВидимостьКомандыЗавершенияПерехода();
	
	Если НЕ ПереходЗапущен Тогда
		
		СоздатьИЗапуститьРегламентноеЗаданиеПереходаНаДоставку25();
		УстановитьВремяНачалаПерехода();
		
		Оповестить("НачалоПереходаНаДоставку25");
		ПодключитьОбработчикОжидания("ОбновлениеСтатусаПерехода", 5, Ложь);
		
	ИначеЕсли НЕ ДанныеОбработаны Тогда
		
		ПодключитьОбработчикОжидания("ОбновлениеСтатусаПерехода", 5, Ложь);
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура ЗакрытьПомощник(Команда)
	
	Закрыть();
	
КонецПроцедуры

&НаКлиенте
Асинх Процедура ЗавершитьПереход(Команда)
	
	ИнформацияОСоединениях = ИнформацияОСоединениях();
	Если ИнформацияОСоединениях.НаличиеАктивныхСоединений Тогда
		
		ТекстСообщения = ДоставкаТоваровКлиентСервер.ТекстПроверкиАктивныхСеансов();
		ПредупреждениеАсинх(ТекстСообщения);
		
		Возврат;
		
	КонецЕсли;
	
	ЗавершитьПереход = Ждать ДоставкаТоваровКлиент.ПроверитьВозможностьПереходаНаДоставку25Асинх();
	
	Если ЗавершитьПереход Тогда
		
		ЗавершитьПереходНаСервере();
		ОбщегоНазначенияКлиент.ОбновитьИнтерфейсПрограммы();
		ОповеститьОбОкончанииПереходаИЗакрытьПомощник();
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура СоздатьИЗапуститьРегламентноеЗаданиеПереходаНаДоставку25()
	
	МетаданныеЗадания = Метаданные.РегламентныеЗадания.ПереходНаУправлениеДоставкой25;
	
	Отбор = Новый Структура;
	Отбор.Вставить("Ключ", МетаданныеЗадания.Ключ);
	Отбор.Вставить("Состояние", СостояниеФоновогоЗадания.Активно);
	ФоновыеЗаданияПерехода = ФоновыеЗадания.ПолучитьФоновыеЗадания(Отбор);
	
	Если ФоновыеЗаданияПерехода.Количество() = 0 Тогда
		
		ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияПроцедуры();
		ПараметрыВыполнения.ОжидатьЗавершение = 0;
		ПараметрыВыполнения.НаименованиеФоновогоЗадания = МетаданныеЗадания.Наименование;
		ПараметрыВыполнения.КлючФоновогоЗадания = МетаданныеЗадания.Ключ;
		
		ДлительныеОперации.ВыполнитьПроцедуру(ПараметрыВыполнения, "ДоставкаТоваров.ЗапуститьПереходНаДоставку25");
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновлениеСтатусаПерехода()
	
	Статус = СтатусПерехода(ЗапускПерехода);
	ЗаполнитьЗначенияСвойств(ЭтотОбъект, Статус);
	
	ОбновитьШаги();
	
	Если ЗапускПерехода
	   И СозданоЗадание Тогда
		
		ЗапускПерехода = Ложь;
		
	КонецЕсли;
	
	Если ДанныеОбработаны Тогда
		
		Оповестить("ОбработаныДанныеДляПереходаНаДоставку25");
		ОтключитьОбработчикОжидания("ОбновлениеСтатусаПерехода");
		
		УстановитьВидимостьКомандыЗавершенияПерехода(Истина);
		
	ИначеЕсли ПереходЗавершен Тогда
		
		ОповеститьОбОкончанииПереходаИЗакрытьПомощник();
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура УстановитьВидимостьКомандыЗавершенияПерехода(ДанныеОбработаны = Ложь)
	
	Элементы.ГруппаИнформацияОбщая.Видимость = НЕ ДанныеОбработаны;
	Элементы.ГруппаЗавершениеПерехода.Видимость = ДанныеОбработаны;
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьШаги()
	
	Если НЕ ДанныеОбработаны Тогда
		
		ПартнерыОбработаны = (КоличествоПартнеров = КоличествоПартнеровОбработано);
		СкладыОбработаны = (КоличествоСкладов = КоличествоСкладовОбработано);
		
		Если ПартнерыОбработаны Тогда
			
			Элементы.Шаг1Надпись.ТекущаяСтраница = Элементы.Шаг1НадписьВыполнено;
			Элементы.ДекорацияШаг1ВыполненоНадпись.Заголовок = ТекстЗаголовкаШагаПартнеры();
			
		Иначе
			
			Элементы.Шаг1Надпись.ТекущаяСтраница = Элементы.Шаг1НадписьВыполняется;
			Элементы.ДекорацияШаг1ВыполняетсяНадпись.Заголовок = ТекстЗаголовкаШагаПартнеры();
			
		КонецЕсли;
		
		Если СкладыОбработаны Тогда
			
			Элементы.Шаг2Надпись.ТекущаяСтраница = Элементы.Шаг2НадписьВыполнено;
			Элементы.ДекорацияШаг2ВыполненоНадпись.Заголовок = ТекстЗаголовкаШагаСклады();
			
		Иначе
			
			Элементы.Шаг2Надпись.ТекущаяСтраница = Элементы.Шаг2НадписьВыполняется;
			Элементы.ДекорацияШаг2ВыполняетсяНадпись.Заголовок = ТекстЗаголовкаШагаСклады();
			
		КонецЕсли;
		
		Если ПартнерыОбработаны
		   И СкладыОбработаны Тогда
			
			Элементы.Шаг3Надпись.ТекущаяСтраница = Элементы.Шаг3НадписьВыполняется;
			ДанныеОбработаны = Истина;
			
		КонецЕсли;
		
	Иначе
		
		Элементы.Шаг1Надпись.ТекущаяСтраница = Элементы.Шаг1НадписьВыполнено;
		Элементы.ДекорацияШаг1ВыполненоНадпись.Заголовок = ТекстЗаголовкаШагаПартнеры();
		
		Элементы.Шаг2Надпись.ТекущаяСтраница = Элементы.Шаг2НадписьВыполнено;
		Элементы.ДекорацияШаг2ВыполненоНадпись.Заголовок = ТекстЗаголовкаШагаСклады();
		
		Элементы.Шаг3Надпись.ТекущаяСтраница = Элементы.Шаг3НадписьВыполняется;
		
	КонецЕсли;
	
	Если ПереходЗавершен Тогда 
		
		Элементы.Шаг1Надпись.ТекущаяСтраница = Элементы.Шаг1НадписьВыполнено;
		Элементы.Шаг2Надпись.ТекущаяСтраница = Элементы.Шаг2НадписьВыполнено;
		Элементы.Шаг3Надпись.ТекущаяСтраница = Элементы.Шаг3НадписьВыполнено;
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция СтатусПерехода(Знач ЗапускПерехода = Ложь)
	
	СтатусПерехода = ДоставкаТоваров.СтатусПереходаНаДоставку25(ЗапускПерехода);
	Возврат СтатусПерехода;
	
КонецФункции

&НаСервере
Процедура УстановитьВремяНачалаПерехода()
	
	ВремяНачала = ТекущаяДатаСеанса();
	ДатаВремяСтрокой = Формат(ВремяНачала, "ДЛФ=DT;");
	ШаблонПереходНачался = НСтр("ru = 'Переход начался: %1'");
	
	Элементы.ДекорацияВремяНачалаПерехода.Видимость = Истина;
	Элементы.ДекорацияВремяНачалаПерехода.Заголовок = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
		ШаблонПереходНачался,
		ДатаВремяСтрокой);
	
КонецПроцедуры

&НаКлиенте
Функция ТекстЗаголовкаШагаПартнеры()
	
	Шаблон = НСтр("ru = '1. Формирование точек доставки партнеров (%1 из %2).'");
	
	Текст = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
		Шаблон,
		Формат(КоличествоПартнеровОбработано, "ЧН=0; ЧГ=0;"),
		Формат(КоличествоПартнеров, "ЧН=0; ЧГ=0;"));
	
	Возврат Текст;
	
КонецФункции

&НаКлиенте
Функция ТекстЗаголовкаШагаСклады()
	
	Шаблон = НСтр("ru = '2. Формирование точек доставки складов (%1 из %2).'");
	
	Текст = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
		Шаблон,
		Формат(КоличествоСкладовОбработано, "ЧН=0; ЧГ=0;"),
		Формат(КоличествоСкладов, "ЧН=0; ЧГ=0;"));
	
	Возврат Текст;
	
КонецФункции

&НаСервереБезКонтекста
Процедура ЗавершитьПереходНаСервере()
	
	ДоставкаТоваров.ЗавершитьПереходНаДоставку25();
	
КонецПроцедуры

&НаКлиенте
Процедура ОповеститьОбОкончанииПереходаИЗакрытьПомощник()
	
	Оповестить("ОкончаниеПереходаНаДоставку25");
	Закрыть();
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ИнформацияОСоединениях()
	
	Информация = СоединенияИБ.ИнформацияОСоединениях();
	Возврат Информация;
	
КонецФункции

#КонецОбласти