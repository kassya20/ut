 
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Если Параметры.Свойство("АвтоТест") Тогда // Возврат при получении формы для анализа.
		Возврат;
	КонецЕсли;

	ИспользоватьМногострановойУчет = ПолучитьФункциональнуюОпцию("ИспользоватьМногострановойУчет");
	Элементы.ВидыЦенСтрана.Видимость = ИспользоватьМногострановойУчет;
	
	Если Параметры.Свойство("МассивВидовЦен") Тогда
		Для Каждого СтрокаМассива Из Параметры.МассивВидовЦен Цикл
			СтрокаВидаЦен = ВидыЦен.Добавить();
			ЗаполнитьЗначенияСвойств(СтрокаВидаЦен, СтрокаМассива);
		КонецЦикла;
	КонецЕсли;
	
	Если Параметры.Свойство("ТолькоВыделенные") Тогда
		ТолькоВыделенныеСтроки = Параметры.ТолькоВыделенные;
	КонецЕсли;
	
	Если Параметры.Свойство("ДатаДействия") Тогда
		ДатаДействия = Параметры.ДатаДействия;
	КонецЕсли;
	
	УчетНДСЛокализация.НастроитьФормуЗаполненияСтавокНДС(ЭтотОбъект, ДатаДействия);
	
	ИзменитьСвернутостьГруппы(Элементы, Истина);
	
	СобытияФорм.ПриСозданииНаСервере(ЭтотОбъект, Отказ, СтандартнаяОбработка);

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура СвернутьРазвернутьГруппу(Элемент)
	
	ИзменитьСвернутостьГруппы(Элементы);
	
КонецПроцедуры

&НаКлиенте
Процедура ВладелецТовараПриИзменении(Элемент)
	
	Если Не ЗначениеЗаполнено(ВладелецТовара) Тогда
		Возврат;
	КонецЕсли;
	ПолучитьНалогообложениеКонтрагентаНаСервере(ВладелецТовара, ДатаДействия, СтавкаНДС);
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура ИзменитьСтавкуНДС(Команда)
		
	МассивВидовЦен = Новый Массив();
	Для Каждого ВидЦены Из ВидыЦен Цикл
		Если ВидЦены.Пересчитать Тогда
			МассивВидовЦен.Добавить(ВидЦены.ВидЦены);
		КонецЕсли;
	КонецЦикла;
	
	Результат = Новый Структура();
	Результат.Вставить("ВыбранныеВидыЦен",			МассивВидовЦен);
	Результат.Вставить("ТолькоВыделенныеСтроки",	ТолькоВыделенныеСтроки = 1);
	Результат.Вставить("ДатаДействия",				ДатаДействия);
	
	Если Элементы.ГруппаСтавкиНДС.Видимость Тогда
		Результат.Вставить("СтавкаНДС", СправочникСтавкаНДС);
	Иначе
		Результат.Вставить("СтавкаНДС", СтавкаНДС);
	КонецЕсли;
		
	Закрыть(Результат);
	
КонецПроцедуры

&НаКлиенте
Процедура ВидыЦенВыбратьВсе(Команда)
	
	Для Каждого ВидЦены Из ВидыЦен Цикл
		Если Не ВидЦены.Пересчитать Тогда
			ВидЦены.Пересчитать = Истина;
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура ВидыЦенИсключитьВсе(Команда)
	
	Для Каждого ВидЦены Из ВидыЦен Цикл
		Если ВидЦены.Пересчитать Тогда
			ВидЦены.Пересчитать = Ложь;
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура Подключаемый_ВыполнитьПереопределяемуюКоманду(Команда)
	
	СобытияФормКлиент.ВыполнитьПереопределяемуюКоманду(ЭтотОбъект, Команда);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиентеНаСервереБезКонтекста
Процедура ИзменитьСвернутостьГруппы(Элементы, Свернуть = Неопределено)
	
	Элементы.ГруппаНастроекСворачиваемая.Видимость = ?(Свернуть = Неопределено, Не Элементы.ГруппаНастроекСворачиваемая.Видимость, Не Свернуть);
	Элементы.ДекорацияОткрыть.Видимость = ?(Свернуть = Неопределено, Не Элементы.ДекорацияОткрыть.Видимость, Свернуть);
	Элементы.ДекорацияЗакрыть.Видимость = ?(Свернуть = Неопределено, Не Элементы.ДекорацияЗакрыть.Видимость, Не Свернуть);
	
КонецПроцедуры

&НаСервереБезКонтекста
Процедура ПолучитьНалогообложениеКонтрагентаНаСервере(Контрагент, ДатаДействия, СтавкаНДС)
	
	ПартнерыИКонтрагентыЛокализация.ПолучитьНалогообложениеКонтрагента(Контрагент, ДатаДействия, СтавкаНДС);
	
КонецПроцедуры

#КонецОбласти