#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Если Не ПолучитьФункциональнуюОпцию("ИспользоватьОповещенияПользователейВTelegram") Тогда
		ВызватьИсключение НСтр("ru = 'В системе не включено использование интеграции оповещений с Telegram.'");
	КонецЕсли;
	
	ОповещенияПользователейОСобытиях.ПроверитьПодготовитьСоединениеССистемойВзаимодействия();
	
	АдресБота = Константы.АдресБотаОповещенийВTelegram.Получить();
	Если ЗначениеЗаполнено(АдресБота) Тогда
		ОписаниеИнтеграции = ОповещенияПользователейОСобытиях.НайтиСуществующуюИнтеграцию(АдресБота);
		ЗаполнитьСуществующуюИнтеграцию(ОписаниеИнтеграции);
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Асинх Процедура АктивироватьБота(Команда)
	Если НЕ ПроверитьЗаполнение() Тогда
		Возврат;
	КонецЕсли;
	
	Наименование = СокрЛП(Наименование);
	ОчиститьНастройкиПолучателей = Ложь;
	Если ЗначениеЗаполнено(АдресБота) И СокрЛП(Наименование) <> АдресБота Тогда
		ТекстВопроса = НСтр("ru = 'Наименование бота отличается от сохраненного ранее.
		|После изменения бота все существующие интеграции будут удалены. Продолжить?'");
		
		Результат = Ждать ВопросАсинх(ТекстВопроса, РежимДиалогаВопрос.ОКОтмена);
		Если Результат = КодВозвратаДиалога.ОК Тогда
			ОчиститьНастройкиПолучателей = Истина;
		ИначеЕсли Результат = КодВозвратаДиалога.Отмена Тогда
			Возврат
		КонецЕсли;
	КонецЕсли;
	
	АктивироватьСервер(ОчиститьНастройкиПолучателей);
	Закрыть(Истина);
	
КонецПроцедуры

&НаКлиенте
Процедура Отключить(Команда)
	
	ОтключитьСервер();
	Закрыть(Истина);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура АктивироватьСервер(ОчиститьНастройкиПолучателей)
	
	ОписаниеИнтеграции = ОповещенияПользователейОСобытиях.НайтиСуществующуюИнтеграцию(Наименование);
	Если ОписаниеИнтеграции <> Неопределено Тогда
		Идентификатор = ОписаниеИнтеграции.Идентификатор;
	КонецЕсли;
	
	ПараметрыИнтеграции = ОбсужденияСлужебный.ПараметрыИнтеграции();
	ПараметрыИнтеграции.Идентификатор = Идентификатор;
	ПараметрыИнтеграции.Ключ = Наименование;
	ПараметрыИнтеграции.Тип = ОбсужденияСлужебныйКлиентСервер.ТипыВнешнихСистем().Telegram;
	ПараметрыИнтеграции.Участники = ОбязательныеУчастники();
	ПараметрыИнтеграции.token = Токен;
	
	Попытка
		Бот = ОповещенияПользователейОСобытиях.ПолучитьСоздатьБотаСистемыВзаимодействия();
		
		ПараметрыИнтеграции.Участники.Добавить(Бот.Пользователь);
		ОповещенияПользователейОСобытиях.СоздатьИзменитьИнтеграцию(ПараметрыИнтеграции);
		
		Константы.АдресБотаОповещенийВTelegram.Установить(Наименование);
		
		Если ОчиститьНастройкиПолучателей Тогда
			ОповещенияПользователейОСобытиях.ОчиститьНастройкиПолучателейОповещений(
				Перечисления.СпособыОповещенийПользователей.Telegram);
			АдресБота = Наименование;
		КонецЕсли;
	Исключение
		ИнформацияОбОшибке = ИнформацияОбОшибке();
		ЗаписьЖурналаРегистрации(ОбсужденияСлужебный.СобытиеЖурналаРегистрации(),
			УровеньЖурналаРегистрации.Ошибка,,,
			ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке));
		Уточнение = ОбщегоНазначенияКлиентСервер.УточнениеИсключения(ИнформацияОбОшибке, 
			НСтр("ru='Не удалось записать настройки бота по причине:'"), Истина);
		ВызватьИсключение(Уточнение.Текст, Уточнение.Категория,,, ИнформацияОбОшибке);
	КонецПопытки;
	
КонецПроцедуры

&НаСервере
Процедура ОтключитьСервер()
	
	Попытка
		ОбсужденияСлужебный.ОтключитьИнтеграцию(Идентификатор);
		ОповещенияПользователейОСобытиях.УдалитьБотовСистемыВзаимодействия();
		ОповещенияПользователейОСобытиях.ОчиститьНастройкиПолучателейОповещений(Перечисления.СпособыОповещенийПользователей.Telegram);
	Исключение
		ИнформацияОбОшибке = ИнформацияОбОшибке();
		ЗаписьЖурналаРегистрации(ОбсужденияСлужебный.СобытиеЖурналаРегистрации(),
			УровеньЖурналаРегистрации.Ошибка,,,
			ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке));
		Уточнение = ОбщегоНазначенияКлиентСервер.УточнениеИсключения(ИнформацияОбОшибке, 
			НСтр("ru='Не удалось записать настройки бота по причине:'"), Истина);
		ВызватьИсключение(Уточнение.Текст, Уточнение.Категория,,, ИнформацияОбОшибке);
	КонецПопытки;
	
КонецПроцедуры

&НаСервере
Функция ОбязательныеУчастники()
	
	Участники = Новый Массив();
	
	НовыйУчастник = ОповещенияПользователейОСобытияхПовтИсп.ИдентификаторПользователяСистемыВзаимодействияАвторОповещений();
	Участники.Добавить(НовыйУчастник);
	
	Возврат Участники;
	
КонецФункции

&НаСервере
Процедура ЗаполнитьСуществующуюИнтеграцию(ОписаниеИнтеграции)
	
	Если ОписаниеИнтеграции <> Неопределено Тогда
		Наименование = ОписаниеИнтеграции.Представление;
		Токен = ОписаниеИнтеграции.ПараметрыВнешнейСистемы.Получить("token");
		Идентификатор = ОписаниеИнтеграции.Идентификатор;
	
		Если ОписаниеИнтеграции.Использование Тогда
			Элементы.Закрыть.Заголовок = НСтр("ru='Записать и закрыть'");
			Элементы.Отключить.Видимость = Истина;
		Иначе
			Элементы.Закрыть.Заголовок = НСтр("ru='Активировать'");
			Элементы.Отключить.Видимость = Ложь;
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

