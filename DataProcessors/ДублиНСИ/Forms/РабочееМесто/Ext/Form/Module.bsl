	Попытка
		РегистрыСведений.ДублиНСИ.УдалитьДубли(Дубли, СнятьПометку);
		ЗафиксироватьТранзакцию();
	Исключение
		ОтменитьТранзакцию();
		ВызватьИсключение;
	КонецПопытки;
	
