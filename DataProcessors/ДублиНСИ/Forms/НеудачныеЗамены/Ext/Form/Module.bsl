#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ФорматированныйЗаголовок = СтроковыеФункции.ФорматированнаяСтрока(
		НСтр("ru='<b>Не удалось заменить</b> <a href=%1>%2</a> <b>на</b> <a href=%3>%4</a> <b>в некоторых местах использования:</b>'"),
		ПолучитьНавигационнуюСсылку(Параметры.Дубль),
		Строка(Параметры.Дубль),
		ПолучитьНавигационнуюСсылку(Параметры.Оригинал),
		Строка(Параметры.Оригинал));
	
	КореньДерева = МестаИспользованияНеобработанных.ПолучитьЭлементы();
	
	ИндексГруппировок = Новый Соответствие;
	
	Для Каждого Ошибка Из Параметры.Ошибки Цикл
		ИмяБазовогоТипа = ОбщегоНазначения.ИмяБазовогоТипаПоОбъектуМетаданных(Ошибка.ОбъектОшибки.Метаданные());
		
		Если ИндексГруппировок[ИмяБазовогоТипа] = Неопределено Тогда
			СтрокаГруппировка = КореньДерева.Добавить();
			СтрокаГруппировка.ТипМетаданных = ИмяБазовогоТипа;
			
			ИндексГруппировок.Вставить(СтрокаГруппировка.ТипМетаданных, СтрокаГруппировка);
		Иначе
			СтрокаГруппировка = ИндексГруппировок[ИмяБазовогоТипа];
		КонецЕсли;
		
		СтрокаРасшифровка = СтрокаГруппировка.ПолучитьЭлементы().Добавить();
		СтрокаРасшифровка.ОбъектОшибки = Ошибка.ОбъектОшибки;
		СтрокаРасшифровка.ТекстОшибки = Ошибка.ТекстОшибки;
		
		Если ИмяБазовогоТипа = "РегистрыСведений" Тогда
			
			МетаданныеРегистра = Ошибка.ОбъектОшибки.Метаданные();
			ЧастиПредставления = Новый Массив;
			ДанныеОбъектаОшибки = Новый Структура;
			ОписаниеКлюча = Новый Структура;
			
			// Период
			Если МетаданныеРегистра.ПериодичностьРегистраСведений <> Метаданные.СвойстваОбъектов.ПериодичностьРегистраСведений.Непериодический Тогда
				Период = Ошибка.ОбъектОшибки.Период;
				ОписаниеКлюча.Вставить("Период", Период);
				ЧастиПредставления.Добавить(Строка(Период));
			КонецЕсли;
			
			// Регистратор
			Если МетаданныеРегистра.РежимЗаписи = Метаданные.СвойстваОбъектов.РежимЗаписиРегистра.ПодчинениеРегистратору Тогда
				Регистратор = Ошибка.ОбъектОшибки.Регистратор;
				ОписаниеКлюча.Вставить("Регистратор", Регистратор);
				ЧастиПредставления.Добавить(Строка(Регистратор));
			КонецЕсли;
			
			// Измерения
			МассивИзмерений = МетаданныеРегистра.Измерения;
			Для Каждого Измерение Из МассивИзмерений Цикл
				ИмяИзмерения = Измерение.Имя;
				ЗначениеИзмерения = Ошибка.ОбъектОшибки[ИмяИзмерения];
				ОписаниеКлюча.Вставить(ИмяИзмерения, ЗначениеИзмерения);
				Если ЗначениеЗаполнено(ЗначениеИзмерения) Тогда
					ЧастиПредставления.Добавить(Строка(ЗначениеИзмерения));
				Иначе
					ЧастиПредставления.Добавить("");
				КонецЕсли;
			КонецЦикла;
			
			Представление = СтрСоединить(ЧастиПредставления, ", ");
			ДанныеОбъектаОшибки.Вставить("ИмяРегистра", МетаданныеРегистра.Имя);
			ДанныеОбъектаОшибки.Вставить("ОписаниеКлюча", ОписаниеКлюча);
			СтрокаРасшифровка.ДанныеОбъектаОшибки = ДанныеОбъектаОшибки;
			СтрокаРасшифровка.ОбъектОшибки = СтрШаблон("%1 (%2)", Представление, Строка(Ошибка.ОбъектОшибки));
			
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыМестаИспользованияНеобработанных

&НаКлиенте
Процедура МестаИспользованияНеобработанныхПриАктивизацииСтроки(Элемент)
	
	ТекущиеДанные = Элемент.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено
		Или Не ЗначениеЗаполнено(ТекущиеДанные.ТекстОшибки) Тогда
		
		ПодробностиОшибки = "";
		Возврат;
	КонецЕсли;
	
	ПодробностиОшибки = СтрШаблон(НСтр("ru = 'Не удалось заменить по причине:
		|%1'"), ТекущиеДанные.ТекстОшибки);
	
КонецПроцедуры

&НаКлиенте
Процедура МестаИспользованияНеобработанныхВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	ТекущиеДанные = Элементы.МестаИспользованияНеобработанных.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	СтандартнаяОбработка = Ложь;
	
	Если ЗначениеЗаполнено(ТекущиеДанные.ДанныеОбъектаОшибки) Тогда
		
		ДанныеОбъектаОшибки = ТекущиеДанные.ДанныеОбъектаОшибки;
		ИмяРегистра = ДанныеОбъектаОшибки.ИмяРегистра;
		
		СтруктураИзмерений = Новый Структура;
		Для Каждого ПолеКлюча Из ДанныеОбъектаОшибки.ОписаниеКлюча Цикл
			СтруктураИзмерений.Вставить(ПолеКлюча.Ключ, ПолеКлюча.Значение);
		КонецЦикла;
		
		МассивПараметровКонструктора = Новый Массив();
		МассивПараметровКонструктора.Добавить(СтруктураИзмерений);
		КлючЗаписи = Новый("РегистрСведенийКлючЗаписи." + ИмяРегистра, МассивПараметровКонструктора);
		ПараметрыФормы = Новый Структура("Ключ", КлючЗаписи);
		
		ПутьКФорме = "РегистрСведений." + ИмяРегистра + ".ФормаЗаписи";
		ОткрытьФорму(ПутьКФорме, ПараметрыФормы, , , , , , РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
		
	Иначе
		ПоказатьЗначение(, ТекущиеДанные.ОбъектОшибки);
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти
