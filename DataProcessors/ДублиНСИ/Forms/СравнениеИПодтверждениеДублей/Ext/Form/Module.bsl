#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ИдентификаторДублей = Параметры.ИдентификаторОбъектаМетаданных;
	Если ИдентификаторДублей.Пустая() Тогда
		ТипСсылки = Параметры.ТипСсылки;
		ИдентификаторДублей = ОбщегоНазначения.ИдентификаторОбъектаМетаданных(ТипСсылки);
	КонецЕсли;
	
	ИдентификаторыГрупп = РегистрыСведений.ДублиНСИКПодтверждению.СвязанныеГруппы(Параметры.ИдентификаторГруппы);
	
	ПриСозданииЧтенииНаСервере(ИдентификаторДублей, ИдентификаторыГрупп);
	
	Элементы.СвернутьПанель.Видимость = Ложь;
	Элементы.ГруппаДубли.Видимость = Ложь;
	Элементы.РазвернутьПанель.Видимость = Истина;
	
	Для Каждого СтрокаТаблицы Из Дубли Цикл
		СтрокаТаблицы.Пометка = Истина;
	КонецЦикла;
	
	ВариантСравненияДублей = "ТолькоОтличия";
	
	ЕстьДоступКПравилам = ПравоДоступа("Редактирование", Метаданные.Справочники.ПравилаПоискаДублейНСИ);
	ЕстьДоступКПользователям = ПравоДоступа("Просмотр", Метаданные.Справочники.Пользователи);
	ЕстьПолныеПрава = Пользователи.ЭтоПолноправныйПользователь();
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	СформироватьОтчетОСравнении();
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура КСравнениюДобавленыСвязанныеДублиОбработкаНавигационнойСсылки(Элемент, НавигационнаяСсылкаФорматированнойСтроки, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	ДеревоИсточникиИДубли = Новый Соответствие;
	Для Каждого СтрокаДублей Из ДублиСПовторамиВГруппах Цикл
		Если ДеревоИсточникиИДубли[СтрокаДублей.ГруппаДублей] = Неопределено Тогда
			ДеревоИсточникиИДубли.Вставить(СтрокаДублей.ГруппаДублей, Новый Массив);
		КонецЕсли;
		
		ИнформацияОДубле = Новый Структура;
		ИнформацияОДубле.Вставить("Код", СтрокаДублей.Код);
		ИнформацияОДубле.Вставить("Дубль", СтрокаДублей.Дубль);
		ИнформацияОДубле.Вставить("Источник", СтрокаДублей.Источник);
		ИнформацияОДубле.Вставить("ИндексКартинки", СтрокаДублей.ИндексКартинки);
		ДеревоИсточникиИДубли[СтрокаДублей.ГруппаДублей].Добавить(ИнформацияОДубле);
	КонецЦикла;
	
	ПараметрыОткрытия = Новый Структура("ИсточникиИДубли", ДеревоИсточникиИДубли);
	ОткрытьФорму("Обработка.ДублиНСИ.Форма.СвязанныеГруппыДублей", ПараметрыОткрытия, , , , , , РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	
КонецПроцедуры

&НаКлиенте
Процедура ОтчетОСравненииОбработкаРасшифровки(Элемент, Расшифровка, СтандартнаяОбработка, ДополнительныеПараметры)
	
	Если ТипЗнч(Расшифровка) = Тип("Структура") Тогда
		
		СтандартнаяОбработка = Ложь;
		
		Если Расшифровка.Свойство("РасшифровкаСтатуса") Тогда
			
			Статусы = Новый СписокЗначений;
			Статусы.Добавить(ПоискИЗаменаДублейНСИКлиентСервер.СтатусДубльЗаменить());
			Статусы.Добавить(ПоискИЗаменаДублейНСИКлиентСервер.СтатусДубльНеУдалять());
			Статусы.Добавить(ПоискИЗаменаДублейНСИКлиентСервер.СтатусОригинал());
			Статусы.Добавить(ПоискИЗаменаДублейНСИКлиентСервер.СтатусНеЯвляетсяДублем());
			Статусы.Добавить(ПоискИЗаменаДублейНСИКлиентСервер.СтатусТребуетсяПодтверждение());
			
			ОповещениеОбОкончанииВыбора = Новый ОписаниеОповещения("ПослеВыбораСтатусаВОтчете", ЭтотОбъект, Расшифровка);
			ПоказатьВыборИзМеню(ОповещениеОбОкончанииВыбора, Статусы);
			
		ИначеЕсли Расшифровка.Свойство("РасшифровкаМестИспользования") Тогда
			
			ПоискИУдалениеДублейКлиент.ПоказатьМестаИспользования(Расшифровка.Дубль);
			
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ВариантСравненияДублейПриИзменении(Элемент)
	ПриИзмененииНастроекОтчета();
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыДубли

&НаКлиенте
Процедура ДублиВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	ТекущиеДанные = Элементы.Дубли.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если Поле.Имя = "ДублиМестИспользования" Тогда
		СтандартнаяОбработка = Ложь;
		ПоискИУдалениеДублейКлиент.ПоказатьМестаИспользования(ТекущиеДанные.Дубль);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ДублиПриАктивизацииСтроки(Элемент)
	
	ТекущиеДанные = Элементы.Дубли.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Источник = ТекущиеДанные.Источник;
	Если ЗначениеЗаполнено(Источник) Тогда
		
		Если ТипЗнч(Источник) = Тип("СправочникСсылка.ПравилаПоискаДублейНСИ") Тогда
			Если ЕстьДоступКПравилам Или ЕстьПолныеПрава Тогда
				ДубльНайденПоПравилу = СтроковыеФункцииКлиент.ФорматированнаяСтрока(
					НСтр("ru = 'Дубль найден по правилу <a href=""%1"">%2</a>'"),
					ПолучитьНавигационнуюСсылку(Источник),
					Строка(Источник));
			Иначе
				ДубльНайденПоПравилу = СтроковыеФункцииКлиент.ФорматированнаяСтрока(
					НСтр("ru = 'Дубль найден по правилу ""%1""'"), 
					Строка(Источник));
			КонецЕсли;
			
		ИначеЕсли ТипЗнч(Источник) = Тип("СправочникСсылка.Пользователи") Тогда
			Если ЕстьДоступКПользователям Или ЕстьПолныеПрава Тогда
				ДубльНайденПоПравилу = СтроковыеФункцииКлиент.ФорматированнаяСтрока(
					НСтр("ru = 'Дубль зарегистрирован пользователем <a href=""%1"">%2</a>'"), 
					ПолучитьНавигационнуюСсылку(Источник),
					Строка(Источник));
			Иначе
				ДубльНайденПоПравилу = СтроковыеФункцииКлиент.ФорматированнаяСтрока(
					НСтр("ru = 'Дубль зарегистрирован пользователем ""%1""'"), 
					Строка(Источник));
			КонецЕсли;
			
		Иначе
			Если ЕстьПолныеПрава Тогда
				ДубльНайденПоПравилу = СтроковыеФункцииКлиент.ФорматированнаяСтрока(
					НСтр("ru = 'Дубль зарегистрирован <a href=""%1"">%2</a>'"),
					ПолучитьНавигационнуюСсылку(Источник),
					Строка(Источник));
			Иначе
				ДубльНайденПоПравилу = СтроковыеФункцииКлиент.ФорматированнаяСтрока(
					НСтр("ru = 'Дубль зарегистрирован ""%1""'"),
					Строка(Источник));
			КонецЕсли;
			
		КонецЕсли;
		
	Иначе
		ДубльНайденПоПравилу = СтроковыеФункцииКлиент.ФорматированнаяСтрока(НСтр("ru = 'Дубль подтвержден'"));
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

