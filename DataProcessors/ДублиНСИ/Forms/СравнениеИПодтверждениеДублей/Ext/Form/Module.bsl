	Элементы.ГруппаДубли.Видимость = Истина;
	Элементы.СвернутьПанель.Видимость = Истина;
	
КонецПроцедуры

&НаКлиенте
Процедура СвернутьПанель(Команда)
	
	Элементы.СвернутьПанель.Видимость = Ложь;
	Элементы.ГруппаДубли.Видимость = Ложь;
	Элементы.РазвернутьПанель.Видимость = Истина;
	
КонецПроцедуры

&НаКлиенте
Процедура УстановитьСтатусДубльЗаменить(Команда)
	УстановитьСтатусДляВыделенных(ПоискИЗаменаДублейНСИКлиентСервер.СтатусДубльЗаменить());
КонецПроцедуры

&НаКлиенте
Процедура УстановитьСтатусДубльНеУдалять(Команда)
	УстановитьСтатусДляВыделенных(ПоискИЗаменаДублейНСИКлиентСервер.СтатусДубльНеУдалять());
КонецПроцедуры

&НаКлиенте
Процедура УстановитьСтатусОригинал(Команда)
	УстановитьСтатусДляВыделенных(ПоискИЗаменаДублейНСИКлиентСервер.СтатусОригинал());
КонецПроцедуры

&НаКлиенте
Процедура УстановитьСтатусНеЯвляетсяДублем(Команда)
	УстановитьСтатусДляВыделенных(ПоискИЗаменаДублейНСИКлиентСервер.СтатусНеЯвляетсяДублем());
КонецПроцедуры

&НаКлиенте
Процедура УстановитьСтатусТребуетсяПодтверждение(Команда)
	УстановитьСтатусДляВыделенных(ПоискИЗаменаДублейНСИКлиентСервер.СтатусТребуетсяПодтверждение());
КонецПроцедуры

&НаКлиенте
Процедура ПоказатьСсылку(Команда)
	
	ТекущиеДанные = Элементы.Дубли.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ПоказатьЗначение(, ТекущиеДанные.Дубль);
	
КонецПроцедуры

&НаКлиенте
Процедура ПодтвердитьДубли(Команда)
	
	РезультатПодтверждения = РезультатПодтвержденияДублей();
	
	Если ЗначениеЗаполнено(РезультатПодтверждения.ТекстПредупрежденияОНесоответствии) Тогда
		
		ПоказатьПредупреждение(, РезультатПодтверждения.ТекстПредупрежденияОНесоответствии);
		Возврат;
		
	ИначеЕсли ЗначениеЗаполнено(РезультатПодтверждения.ТекстПредупрежденияОПовторномПоиске) Тогда
		
		ОписаниеОповещения = Новый ОписаниеОповещения("ПослеПодтвержденияЗаменыДублей", ЭтотОбъект);
		Кнопки = Новый СписокЗначений;
		Кнопки.Добавить("Продолжить", НСтр("ru = 'Продолжить'"));
		Кнопки.Добавить("Отмена", НСтр("ru = 'Отмена'"));
		
		ПоказатьВопрос(ОписаниеОповещения, РезультатПодтверждения.ТекстПредупрежденияОПовторномПоиске, Кнопки);
		Возврат;
		
	КонецЕсли;
	
	Ошибки = РезультатПодтверждения.ОшибкиВыбораСтатуса;
	Если ТипЗнч(Ошибки) = Тип("Массив") И Ошибки.Количество() > 0 Тогда
		Элементы.РазвернутьПанель.Видимость = Ложь;
		Элементы.ГруппаДубли.Видимость = Истина;
		Элементы.СвернутьПанель.Видимость = Истина;
		
		ОчиститьСообщения();
		Для Каждого Ошибка Из Ошибки Цикл
			ОбщегоНазначенияКлиент.СообщитьПользователю(Ошибка.ТекстОшибки, , Ошибка.Поле);
		КонецЦикла;
	Иначе
		ЗавершитьПодтверждениеДублей();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура Сформировать(Команда)
	СформироватьОтчетОСравнении();
КонецПроцедуры

&НаКлиенте
Процедура Отмена(Команда)
	Закрыть();
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура ПриСозданииЧтенииНаСервере(ИдентификаторДублей, ИдентификаторыГрупп)
	
	Дубли.Очистить();
	ДублиСПовторамиВГруппах.Очистить();
	
	ДублиЗаполнение = Обработки.ДублиНСИ.ДанныеЗаполненияФормыСравненияДублей(
		ИдентификаторыГрупп, ИдентификаторДублей);
	
	КоллекцияДублей = Новый Массив;
	ИндексыОригиналов = Новый Массив;
	Для Каждого СтрокаЗаполнение Из ДублиЗаполнение Цикл
		КоллекцияДублей.Добавить(СтрокаЗаполнение.Дубль);
		ЗаполнитьЗначенияСвойств(ДублиСПовторамиВГруппах.Добавить(), СтрокаЗаполнение);
		
		Если Дубли.НайтиСтроки(Новый Структура("Дубль", СтрокаЗаполнение.Дубль)).Количество() = 0 Тогда
			ЗаполнитьЗначенияСвойств(Дубли.Добавить(), СтрокаЗаполнение);
		КонецЕсли;
		
		Если СтрокаЗаполнение.Статус = ПоискИЗаменаДублейНСИКлиентСервер.СтатусОригинал() Тогда
			ИндексыОригиналов.Добавить(ДублиЗаполнение.Индекс(СтрокаЗаполнение));
		КонецЕсли;
	КонецЦикла;
	
	Источники = ДублиЗаполнение.Скопировать(, "Источник");
	Источники.Свернуть("Источник");
	НесколькоИсточников = (Источники.Количество() > 1);
	Элементы.КСравнениюДобавленыСвязанныеДубли.Видимость = НесколькоИсточников;
	
	Если ИндексыОригиналов.Количество() > 1 Тогда
		Элементы.ПодтвердитьДубли.Доступность = Ложь;
		
		ТекстСообщения = НСтр("ru = 'В группе существует несколько подтвержденных оригиналов. Необходимо дождаться окончания процедуры замены дублей'");
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);
	КонецЕсли;
	
	ПометкиУдаления = ОбщегоНазначения.ЗначениеРеквизитаОбъектов(КоллекцияДублей, "ПометкаУдаления");
	Для Каждого СтрокаДубль Из Дубли Цикл
		СтрокаДубль.ИндексКартинки = Число(ПометкиУдаления[СтрокаДубль.Дубль]) + 1;
	КонецЦикла;
	Для Каждого СтрокаДубль Из ДублиСПовторамиВГруппах Цикл
		СтрокаДубль.ИндексКартинки = Число(ПометкиУдаления[СтрокаДубль.Дубль]) + 1;
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура УстановитьСтатусДляВыделенных(Статус)
	
	Для Каждого ИндексСтроки Из Элементы.Дубли.ВыделенныеСтроки Цикл
		Дубли[ИндексСтроки].Статус = Статус;
	КонецЦикла;
	
	ПриИзмененииНастроекОтчета();
	
КонецПроцедуры

&НаКлиенте
Процедура УстановитьЗначениеПометки(Значение)
	
	ВыделенныеСтроки = Элементы.Дубли.ВыделенныеСтроки;
	Если ВыделенныеСтроки.Количество() = 1 Тогда
		Для Каждого СтрокаТаблицы Из Дубли Цикл
			СтрокаТаблицы.Пометка = Значение;
		КонецЦикла;
	Иначе
		Для Каждого ИндексСтроки Из ВыделенныеСтроки Цикл
			Дубли[ИндексСтроки].Пометка = Значение;
		КонецЦикла;
	КонецЕсли;
	
	ПриИзмененииНастроекОтчета();
	
КонецПроцедуры

&НаКлиенте
Процедура ПослеВыбораСтатусаВОтчете(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат <> Неопределено Тогда
		ОбластьОтчета = ОтчетОСравнении.Область(ДополнительныеПараметры.СтрокаНомер, ДополнительныеПараметры.КолонкаНомер);
		ОбластьОтчета.Значение = Результат.Значение;
		
		Дубль = Дубли.НайтиСтроки(Новый Структура("Дубль", ДополнительныеПараметры.Дубль))[0];
		Дубль.Статус = Результат.Значение;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция РезультатПодтвержденияДублей()
	
	Результат = Обработки.ДублиНСИ.ПодтвердитьДубли(Дубли, ИдентификаторДублей);
	
	ТаблицаОшибок = Результат.ОшибкиВыбораСтатуса;
	Если ТипЗнч(ТаблицаОшибок) = Тип("ТаблицаЗначений") Тогда
		Ошибки = Новый Массив;
		Для Каждого СтрокаОшибки Из ТаблицаОшибок Цикл
			СтруктураОшибки = Новый Структура("ТекстОшибки,Поле", СтрокаОшибки.ТекстОшибки, СтрокаОшибки.Поле);
			Ошибки.Добавить(СтруктураОшибки);
		КонецЦикла;
		Результат.ОшибкиВыбораСтатуса = Ошибки;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

&НаКлиенте
Процедура ПослеПодтвержденияЗаменыДублей(КодВозврата, ДополнительныеПараметры) Экспорт
	
	Если КодВозврата = "Продолжить" Тогда
		ОбработатьПодтверждениеДублейНаСервере();
		ЗавершитьПодтверждениеДублей();
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ОбработатьПодтверждениеДублейНаСервере()
	Обработки.ДублиНСИ.ПодтвердитьДубли(Дубли, ИдентификаторДублей, Ложь)
КонецПроцедуры

&НаКлиенте
Процедура ЗавершитьПодтверждениеДублей()
	
	Оповестить("ОбновитьРабочееМестоУдалениеДублейНСИ", ИдентификаторДублей);
	Закрыть();
	
КонецПроцедуры

&НаКлиенте
Процедура СформироватьОтчетОСравнении()
	
	ДлительнаяОперация = ПодготовитьДлительнуюОперациюОтчета();
	
	Если ДлительнаяОперация <> Неопределено Тогда
		Оповещение = Новый ОписаниеОповещения("ПослеФормированияОтчета", ЭтотОбъект);
		ДлительныеОперацииКлиент.ОжидатьЗавершение(ДлительнаяОперация, Оповещение);
	Иначе
		ОбщегоНазначенияКлиент.СообщитьПользователю(
			НСтр("ru = 'Для построения отчета о сравнении необходимо выбрать не меньше двух дублей'"),
				,
				"Дубли[0].Пометка");
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция ПодготовитьДлительнуюОперациюОтчета()
	
	ОтмеченныеДубли = Дубли.НайтиСтроки(Новый Структура("Пометка", Истина));
	
	Если ОтмеченныеДубли.Количество() > 1 Тогда
		ПередФормированиемОтчетаНаСервере();
		ДлительнаяОперация = НачатьФормированиеОтчетаНаСервере();
	Иначе
		ДлительнаяОперация = Неопределено;
	КонецЕсли;
	
	Возврат ДлительнаяОперация;
	
КонецФункции

&НаСервере
Функция НачатьФормированиеОтчетаНаСервере()
	
	ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияФункции(УникальныйИдентификатор);
	ПараметрыВыполнения.НаименованиеФоновогоЗадания = НСтр("ru = 'Формирование отчета о сравнении дублей НСИ'");
	
	Возврат ДлительныеОперации.ВыполнитьФункцию(
		ПараметрыВыполнения,
		"Обработки.ДублиНСИ.ОтчетОСравнении",
		ИдентификаторДублей,
		Дубли.Выгрузить(),
		ВариантСравненияДублей);
		
КонецФункции

&НаКлиенте
Процедура ПослеФормированияОтчета(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если Результат.Статус = "Ошибка" Тогда
		СтандартныеПодсистемыКлиент.ВывестиИнформациюОбОшибке(Результат.ИнформацияОбОшибке);
		Возврат;
	КонецЕсли;
	
	ОтчетОСравнении = ПолучитьИзВременногоХранилища(Результат.АдресРезультата);
	ОтчетСформирован = Истина;
	ПоискИЗаменаДублейНСИКлиентСервер.УстановитьСостояниеПоляОтчета(Элементы.ОтчетОСравнении, Ложь);
	
КонецПроцедуры

&НаСервере
Процедура ПередФормированиемОтчетаНаСервере()
	ПоискИЗаменаДублейНСИКлиентСервер.УстановитьСостояниеПоляОтчета(Элементы.ОтчетОСравнении, Ложь);
КонецПроцедуры

&НаКлиенте
Процедура ПриИзмененииНастроекОтчета()
	
	Если ОтчетСформирован Тогда
		ПоискИЗаменаДублейНСИКлиентСервер.УстановитьСостояниеПоляОтчета(Элементы.ОтчетОСравнении, Истина);
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти
