#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Для Каждого Источник Из Параметры.ИсточникиИДубли Цикл
		
		СтрокаПервогоУровня = Дерево.ПолучитьЭлементы().Добавить();
		
		СтрокиВторогоУровня = СтрокаПервогоУровня.ПолучитьЭлементы();
		Источники = Источник.Значение; // Массив Из Структура
		Для Каждого Дубль Из Источники Цикл
			ЗаполнитьЗначенияСвойств(СтрокиВторогоУровня.Добавить(), Дубль, , "Источник");
		КонецЦикла;
		
		СтрокаПервогоУровня.Источник = ?(
			Дубль.Источник <> Неопределено,
			Дубль.Источник, 
			НСтр("ru = 'Дубли подтверждены'"));
		
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти
