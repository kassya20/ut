// @strict-types

#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	УчетнаяЗапись = Параметры.УчетнаяЗапись;
	ТорговаяПлощадка = ИнтеграцияСМаркетплейсамиПовтИсп.ВидМаркетплейсаУчетнойЗаписи(УчетнаяЗапись);
	
	Если Не ЗначениеЗаполнено(УчетнаяЗапись) Тогда
		Отказ = Истина;
		Возврат;
	КонецЕсли;
	
	ТроеСуток = 60 * 60 * 24 * 3;
	НачалоПериода = НачалоДня(ТекущаяДатаСеанса()) - ТроеСуток;
	КонецПериода = КонецДня(ТекущаяДатаСеанса()) + ТроеСуток;
	
	НастроитьФормуПоУчетнойЗаписи();
	УстановитьУсловноеОформление();
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	ПроверитьПериодИПолучитьОтгрузкиНаКлиенте();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура НачалоПериодаОбработкаВыбора(Элемент, ВыбранноеЗначение, ДополнительныеДанные, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	УказаннаяДата = ВыбранноеЗначение; // Дата
	
	НачалоПериода = НачалоДня(УказаннаяДата);
	
КонецПроцедуры

&НаКлиенте
Процедура КонецПериодаОбработкаВыбора(Элемент, ВыбранноеЗначение, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	УказаннаяДата = ВыбранноеЗначение; // Дата
	
	КонецПериода = КонецДня(УказаннаяДата);
	
КонецПроцедуры

&НаКлиенте
Процедура ФильтрСтатусаПриИзменении(Элемент)
	
	УстановитьОтбор();
	ПроверитьПериодИПолучитьОтгрузкиНаКлиенте();
	
КонецПроцедуры

&НаКлиенте
Процедура ФильтрСтатусаОчистка(Элемент, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	ФильтрСтатуса = "Все";
	
	УстановитьОтбор();
	ПроверитьПериодИПолучитьОтгрузкиНаКлиенте();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыТаблицаОтгрузок

&НаКлиенте
Процедура ТаблицаОтгрузокВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	ТекущаяСтрока = Элементы.ТаблицаОтгрузок.ТекущиеДанные;
	
	Если ТекущаяСтрока = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ИдентификаторСклада = ПолучитьИдентификаторСклада(УчетнаяЗапись);

	ПараметрыФормы = ИнтеграцияСМаркетплейсамиКлиентСервер.НовыеПараметрыОткрытияПодготовкиОтгрузки();
	ПараметрыФормы.УчетнаяЗапись = УчетнаяЗапись;
	ПараметрыФормы.ИдентификаторОтгрузки = ТекущаяСтрока.ИдентификаторОтгрузки;
	ПараметрыФормы.ИдентификаторСклада = ИдентификаторСклада;
	ПараметрыФормы.ДатаОтгрузки = ТекущаяСтрока.КонецПлановогоИнтервала;
	
	ОткрытьФорму("РегистрСведений.ЗаказыТорговыхПлощадок.Форма.ПодготовкаОтгрузки",
		ПараметрыФормы,
		ЭтотОбъект,
		ТекущаяСтрока.ИдентификаторОтгрузки, , , ,
		РежимОткрытияОкнаФормы.Независимый);
	
КонецПроцедуры

&НаКлиенте
Процедура ТаблицаОтгрузокПередНачаломДобавления(Элемент, Отказ, Копирование, Родитель, Группа, Параметр)
	
	Отказ = Истина;
	
КонецПроцедуры

&НаКлиенте
Процедура ТаблицаОтгрузокПередНачаломИзменения(Элемент, Отказ)
	
	Отказ = Истина;
	
КонецПроцедуры

&НаКлиенте
Процедура ТаблицаОтгрузокПередУдалением(Элемент, Отказ)
	
	Отказ = Истина;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура УстановитьПериод(Элемент)
	
	ОповещениеОЗакрытии = Новый ОписаниеОповещения("ОбработкаВыбораПериода", ЭтотОбъект);
	
	Диалог = Новый ДиалогРедактированияСтандартногоПериода();
	Диалог.Период = Новый СтандартныйПериод(НачалоПериода, КонецПериода);
	Диалог.Показать(ОповещениеОЗакрытии);
	
КонецПроцедуры

&НаКлиенте
Процедура ПроверитьПериодИПолучитьОтгрузки(Команда)
	
	ПроверитьПериодИПолучитьОтгрузкиНаКлиенте();
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура УстановитьУсловноеОформление()
	
	УсловноеОформление.Элементы.Очистить();
	
	ЭлементУсловногоОформления = УсловноеОформление.Элементы.Добавить();
	
	ЭлементыТаблицы = ПолучитьПодчиненныеЭлементыФормы(Элементы.ТаблицаОтгрузок);
	Для Каждого ЭлементКоллекции Из ЭлементыТаблицы Цикл
		ПолеЭлемента = ЭлементУсловногоОформления.Поля.Элементы.Добавить();
		ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(ЭлементКоллекции.Имя);
	КонецЦикла;
	
	ОтборЭлемента = ЭлементУсловногоОформления.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ОтборЭлемента.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("ТаблицаОтгрузок.СтатусОтгрузки");
	ОтборЭлемента.ВидСравнения = ВидСравненияКомпоновкиДанных.Равно;
	ОтборЭлемента.ПравоеЗначение = "ПринятаСРасхождениями";
	
	ЭлементУсловногоОформления.Оформление.УстановитьЗначениеПараметра("ЦветФона", ЦветаСтиля.ПолеСОшибкойФон);
	
	ЭлементУсловногоОформления = УсловноеОформление.Элементы.Добавить();
	
	ЭлементыТаблицы = ПолучитьПодчиненныеЭлементыФормы(Элементы.ТаблицаОтгрузок);
	Для Каждого ЭлементКоллекции Из ЭлементыТаблицы Цикл
		ПолеЭлемента = ЭлементУсловногоОформления.Поля.Элементы.Добавить();
		ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(ЭлементКоллекции.Имя);
	КонецЦикла;
	
	ОтборЭлемента = ЭлементУсловногоОформления.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ОтборЭлемента.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("ТаблицаОтгрузок.СтатусОтгрузки");
	ОтборЭлемента.ВидСравнения = ВидСравненияКомпоновкиДанных.Равно;
	ОтборЭлемента.ПравоеЗначение = "Завершена";
	
	ЭлементУсловногоОформления.Оформление.УстановитьЗначениеПараметра("ЦветТекста", ЦветаСтиля.ПоясняющийТекст);
	
КонецПроцедуры

// Настраивает элементы формы в соответствии с данными о торговой площадке.
&НаСервере
Процедура НастроитьФормуПоУчетнойЗаписи()
	
	Элементы.Логотип.Картинка = ИнтеграцияСМаркетплейсамиКлиентСервер.ЛоготипТорговойПлощадки(ТорговаяПлощадка);
	ЗаполнитьФильтрСтатусов(ТорговаяПлощадка);
	Если ИнтеграцияСМаркетплейсамиКлиентСервер.ЭтоЯндексМаркет(ТорговаяПлощадка) Тогда
		Элементы.ДекорацияТестовыйРежим.Видимость =
			ИнтеграцияСЯндексМаркетСервер.ВключенТестовыйРежимЗаказов(УчетнаяЗапись);
	КонецЕсли;
	
КонецПроцедуры

// Заполняет значения списка выбора фильтра статусов.
&НаСервере
Процедура ЗаполнитьФильтрСтатусов(ТорговаяПлощадка)
	
	СписокВыбораФильтра = Элементы.ФильтрСтатуса.СписокВыбора; // СписокЗначений из Строка
	СписокВыбораФильтра.Добавить("Все", "Все");
	
	Если ИнтеграцияСМаркетплейсамиКлиентСервер.ЭтоЯндексМаркет(ТорговаяПлощадка) Тогда
		ВозможныеСтатусыОтгрузки = ИнтеграцияСЯндексМаркетСервер.ВозможныеСтатусыОтгрузки();
	Иначе
		ВозможныеСтатусыОтгрузки = Новый Структура;
	КонецЕсли;

	Для Каждого КлючЗначение Из ВозможныеСтатусыОтгрузки Цикл
		ЗначениеСтатуса = КлючЗначение.Ключ;
		ОписаниеСтатуса = КлючЗначение.Значение;// см. ИнтеграцияСМаркетплейсамиСервер.НовоеЗначениеТорговойПлощадки
		
		СписокВыбораФильтра.Добавить(ЗначениеСтатуса, ОписаниеСтатуса.Представление);
	КонецЦикла;
	
	ФильтрСтатуса = "Все";
	
КонецПроцедуры

// Определяет подчиненные элементы.
//
// Параметры:
//   Элемент - ТаблицаФормы, ГруппаФормы - родительский элемент.
//
// Возвращаемое значение:
//   Массив из ПолеФормы
//
&НаСервереБезКонтекста
Функция ПолучитьПодчиненныеЭлементыФормы(Знач Элемент)
	
	Результат = Новый Массив; // Массив из ПолеФормы
	
	Для Каждого ЭлементКоллекции Из Элемент.ПодчиненныеЭлементы Цикл
		Если ТипЗнч(ЭлементКоллекции) = Тип("ГруппаФормы") Тогда
			ОбщегоНазначенияКлиентСервер.ДополнитьМассив(Результат, ПолучитьПодчиненныеЭлементыФормы(ЭлементКоллекции));
		Иначе
			Результат.Добавить(ЭлементКоллекции);
		КонецЕсли;
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

&НаСервереБезКонтекста
Функция ПолучитьИдентификаторСклада(Знач УчетнаяЗапись)
	
	ДанныеСклада = ИнтеграцияСЯндексМаркетСервер.СкладУчетнойЗаписиДляВыгрузкиОстатков(УчетнаяЗапись);
	ИдентификаторСклада = ДанныеСклада.ИдентификаторСклада;
	
	Возврат ИдентификаторСклада;
	
КонецФункции

// Обработчик события выбора периода.
//
// Параметры:
//   Период - СтандартныйПериод - выбранный период.
//   ДополнительныеПараметры - Неопределено, Произвольный - переданные дополнительные параметры.
//
&НаКлиенте
Процедура ОбработкаВыбораПериода(Период, ДополнительныеПараметры) Экспорт
	
	Если Период <> Неопределено Тогда
		НачалоПериода = НачалоДня(Период.ДатаНачала);
		КонецПериода = КонецДня(Период.ДатаОкончания);
		
		ПроверитьПериодИПолучитьОтгрузкиНаКлиенте();
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура УстановитьОтбор()
	
	Отбор = Новый Структура;
	
	Если ЗначениеЗаполнено(ФильтрСтатуса) И ФильтрСтатуса <>"Все" Тогда
		Отбор.Вставить("СтатусОтгрузки", ФильтрСтатуса);
	КонецЕсли;
		
	Если Отбор.Количество() > 0 Тогда
		Элементы.ТаблицаОтгрузок.ОтборСтрок = Новый ФиксированнаяСтруктура(Отбор);
	Иначе
		Элементы.ТаблицаОтгрузок.ОтборСтрок = Неопределено;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПроверитьПериодИПолучитьОтгрузкиНаКлиенте()
	
	ОчиститьСообщения();
	
	Если НачалоПериода > КонецПериода Тогда
		ОбщегоНазначенияКлиент.СообщитьПользователю(
			НСтр("ru = 'Некорректно задан период: дата окончания ранее даты начала.'"), , "НачалоПериода");
		Возврат;
	КонецЕсли;
	
	РазницаВДнях = (НачалоДня(КонецПериода) - НачалоДня(НачалоПериода)) / (60 * 60 * 24);
	
	Если РазницаВДнях > 30 Тогда
		ТекстВопроса = Нстр(
			"ru = 'Период запроса данных превышает месяц.
			|Чтобы избежать долгой загрузки данных рекомендуется сократить запрашиваемый период.
			|Продолжить получение данных?'");
		ОповещениеОЗавершении = Новый ОписаниеОповещения("ПроверитьПериодИПолучитьОтгрузкиЗавершение", ЭтотОбъект);
		ПоказатьВопрос(ОповещениеОЗавершении, ТекстВопроса, РежимДиалогаВопрос.ДаНет, , КодВозвратаДиалога.Нет);
		
	Иначе
		ПроверитьПериодИПолучитьОтгрузкиЗавершение(КодВозвратаДиалога.Да, Неопределено);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПроверитьПериодИПолучитьОтгрузкиЗавершение(РезультатВопроса, ДополнительныеПараметры) Экспорт
	
	Если РезультатВопроса = КодВозвратаДиалога.Да Тогда
		ПолучитьОтгрузкиНаКлиенте();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПолучитьОтгрузкиНаКлиенте()
	
	ОповещениеОЗавершении = Новый ОписаниеОповещения("ПолучитьОтгрузкиЗавершениеФоновогоЗадания", ЭтотОбъект);
	ДлительнаяОперация = ПолучитьОтгрузкиНаСервере();
	
	Если ДлительнаяОперация.Статус = "Выполнено" Тогда
		ВыполнитьОбработкуОповещения(ОповещениеОЗавершении, ДлительнаяОперация);
	Иначе
		ПараметрыОжидания = ДлительныеОперацииКлиент.ПараметрыОжидания(ЭтотОбъект);
		ПараметрыОжидания.ВыводитьОкноОжидания = Истина;
		ПараметрыОжидания.ТекстСообщения = НСтр("ru = 'Получение данных об отгрузках'");
		ПараметрыОжидания.ОповещениеПользователя.Показать = Истина;
		ПараметрыОжидания.ОповещениеПользователя.Текст =
			ИнтеграцияСМаркетплейсамиКлиентСервер.ПредставлениеВидаТорговойПлощадки(ТорговаяПлощадка);
		ПараметрыОжидания.ОповещениеПользователя.Пояснение = НСтр("ru = 'Завершено получение данных об отгрузках FBS'");
		ПараметрыОжидания.ОповещениеПользователя.Картинка = 
			ИнтеграцияСМаркетплейсамиКлиентСервер.ЛоготипТорговойПлощадки(ТорговаяПлощадка);
		
		ДлительныеОперацииКлиент.ОжидатьЗавершение(ДлительнаяОперация, ОповещениеОЗавершении, ПараметрыОжидания);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция ПолучитьОтгрузкиНаСервере()
	
	ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияФункции(УникальныйИдентификатор);
	ПараметрыВыполнения.ОжидатьЗавершение = 0;
	ПараметрыВыполнения.НаименованиеФоновогоЗадания  = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
		НСтр("ru = '%1. Получение данных об отгрузках FBS.'"),
		ИнтеграцияСМаркетплейсамиКлиентСервер.ПредставлениеВидаТорговойПлощадки(ТорговаяПлощадка));
	ПараметрыВыполнения.ЗапуститьВФоне = Истина;
	ПараметрыВыполнения.ПрерватьВыполнениеЕслиОшибка = Истина;
	
	Если ИнтеграцияСМаркетплейсамиКлиентСервер.ЭтоЯндексМаркет(ТорговаяПлощадка) Тогда
		ПараметрыФункции = ИнтеграцияСЯндексМаркетСервер.НовыеПараметрыПолученияСпискаОтгрузок(
			НачалоПериода, КонецПериода);
		
		Если ЗначениеЗаполнено(ФильтрСтатуса) И ФильтрСтатуса <>"Все" Тогда
			ВозможныеСтатусыОтгрузки = ИнтеграцияСЯндексМаркетСервер.ВозможныеСтатусыОтгрузки();
			
			СтатусОтгрузки = ВозможныеСтатусыОтгрузки[ФильтрСтатуса]; // Структура
			ПараметрыФункции.Фильтр.СтатусыОтгрузок.Добавить(СтатусОтгрузки);
		КонецЕсли;
		
		ИмяМетода = "ИнтеграцияСЯндексМаркетСервер.СписокОтгрузок";
	КонецЕсли;
	
	Возврат ДлительныеОперации.ВыполнитьФункцию(ПараметрыВыполнения,
		ИмяМетода,
		УчетнаяЗапись,
		ПараметрыФункции);
		
КонецФункции

// Параметры:
//  Результат - см. ДлительныеОперации.ВыполнитьВФоне
//  ДополнительныеПараметры - Неопределено
//
&НаКлиенте
Процедура ПолучитьОтгрузкиЗавершениеФоновогоЗадания(Результат, ДополнительныеПараметры) Экспорт
	
	Если ТипЗнч(Результат) = Тип("Структура") Тогда
		Если Результат.Статус = "Ошибка" Тогда
			ОбщегоНазначенияКлиент.СообщитьПользователю(Результат.ПодробноеПредставлениеОшибки);
		
		ИначеЕсли Результат.Статус = "Выполнено" Тогда
			Ошибка = ПолучитьОтгрузкиЗавершениеФоновогоЗаданияНаСервере(Результат.АдресРезультата);
			Логотип = ИнтеграцияСМаркетплейсамиКлиентСервер.ЛоготипТорговойПлощадки(ТорговаяПлощадка);
			ИнтеграцияСМаркетплейсамиКлиент.ВывестиСостояние(Ошибка, Неопределено, Истина, Логотип);
			
			Элементы.ТаблицаОтгрузок.Обновить();
		КонецЕсли;
	КонецЕсли;
		
КонецПроцедуры

// Обрабатывает результат получения отправлений.
//
// Параметры:
//   АдресРезультата - Строка - адрес временного хранилища, в которое будет помещен (или уже помещен) результат работы 
//                       процедуры длительной операции.
//
// Возвращаемое значение:
//   См. ИнтеграцияСМаркетплейсамиСервер.НоваяОшибка.
//
&НаСервере
Функция ПолучитьОтгрузкиЗавершениеФоновогоЗаданияНаСервере(Знач АдресРезультата)
	
	ТаблицаОтгрузок.Очистить();
	
	РезультатПолучения = ПолучитьИзВременногоХранилища(АдресРезультата); // см. ИнтеграцияСЯндексМаркетСервер.СписокОтгрузок
	УдалитьИзВременногоХранилища(АдресРезультата);
	
	Ошибка = РезультатПолучения.Ошибка;
	
	Если Не ПустаяСтрока(Ошибка.КодОшибки) Тогда
		Возврат Ошибка;
	КонецЕсли;
	
	Если ИнтеграцияСМаркетплейсамиКлиентСервер.ЭтоЯндексМаркет(ТорговаяПлощадка) Тогда
		ВозможныеСпособыОтгрузкиЗаказов = ИнтеграцияСЯндексМаркетСервер.ВозможныеСпособыОтгрузкиЗаказов();
		ВозможныеСтатусыОтгрузки = ИнтеграцияСЯндексМаркетСервер.ВозможныеСтатусыОтгрузки();
	Иначе
		ВозможныеСпособыОтгрузкиЗаказов = Новый Структура;
		ВозможныеСтатусыОтгрузки = Новый Структура;
	КонецЕсли;
	
	Для Каждого СтрокаТаблицы Из РезультатПолучения.ТаблицаОтгрузок Цикл
		НоваяСтрока = ТаблицаОтгрузок.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТаблицы);
		
		СпособОтгрузки = ИнтеграцияСМаркетплейсамиСервер.ЗначениеТорговойПлощадкиИзКоллекции(
			ВозможныеСпособыОтгрузкиЗаказов,
			СтрокаТаблицы.СпособОтгрузки);
		НоваяСтрока.СпособОтгрузки = СпособОтгрузки.Представление;
		
		СтатусОтгрузки = ИнтеграцияСМаркетплейсамиСервер.ЗначениеТорговойПлощадкиИзКоллекции(
			ВозможныеСтатусыОтгрузки,
			СтрокаТаблицы.СтатусОтгрузки);
		НоваяСтрока.СтатусОтгрузки = СтатусОтгрузки.Представление;
	КонецЦикла;
	
	Возврат Ошибка;
	
КонецФункции

#КонецОбласти
