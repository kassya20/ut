// @strict-types

#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Объект.Направление = Перечисления.НаправленияДоставки.СкладПартнер;
	ДатаОтбора = ТекущаяДатаСеанса();
	Объект.ДатаОтгрузкиЗаказовС = ДатаОтбора;
	Объект.ПериодОтгрузки.ДатаОкончания = ДатаОтбора;
	
	Если НЕ ПолучитьФункциональнуюОпцию("ИспользоватьНесколькоОрганизаций") Тогда
		
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "Организация", "Видимость", Ложь);
		
	КонецЕсли;
	
	УточнитьТипыОтправителяПолучателя();
	ПодставитьВыраженияВесОбъем();
	ИнициализироватьДополнительныеСвойстваСписков();
	
	АдресДанныеДляОформления = ПоместитьВоВременноеХранилище(Неопределено, УникальныйИдентификатор);
	
	УстановитьУсловноеОформление();
	
КонецПроцедуры

&НаСервере
Процедура ПриЗагрузкеДанныхИзНастроекНаСервере(Настройки)
	
	ИнициализироватьОтборыСписков();
	
	ТекущееНаправление = Объект.Направление;
	ТекущийОтправитель = Объект.Отправитель;
	ТекущийПолучатель = Объект.Получатель;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура НаправлениеПриИзменении(Элемент)
	
	Если Объект.Направление = ТекущееНаправление Тогда
		Возврат;
	КонецЕсли;
	
	УточнитьТипыОтправителяПолучателя();
	
	Списки = ВсеСписки();
	УстановитьОтборПоОтправителю(ЭтотОбъект, Списки, Объект.Отправитель);
	УстановитьОтборПоПолучателю(ЭтотОбъект, Списки, Объект.Получатель);
	
	ТекущееНаправление = Объект.Направление;
	ТекущийОтправитель = Объект.Отправитель;
	ТекущийПолучатель = Объект.Получатель;
	
КонецПроцедуры

&НаКлиенте
Процедура ОрганизацияПриИзменении(Элемент)
	
	Списки = ВсеСписки();
	УстановитьОтборПоОрганизации(ЭтотОбъект, Списки, Объект.Организация);
	
КонецПроцедуры

&НаКлиенте
Процедура ОтправительПриИзменении(Элемент)
	
	Если Объект.Отправитель = ТекущийОтправитель Тогда
		Возврат;
	КонецЕсли;
	
	Списки = ВсеСписки();
	УстановитьОтборПоОтправителю(ЭтотОбъект, Списки, Объект.Отправитель);
	
	ТекущийОтправитель = Объект.Отправитель;
	
КонецПроцедуры

&НаКлиенте
Процедура ПолучательПриИзменении(Элемент)
	
	Если Объект.Получатель = ТекущийПолучатель Тогда
		Возврат;
	КонецЕсли;
	
	Списки = ВсеСписки();
	УстановитьОтборПоПолучателю(ЭтотОбъект, Списки, Объект.Получатель);
	
	ТекущийПолучатель = Объект.Получатель;
	
КонецПроцедуры

&НаКлиенте
Процедура ПериодОтгрузкиДатаОкончанияПриИзменении(Элемент)
	
	Списки = СпискиОстатков();
	УстановитьОтборПоПериодуОтгрузки(ЭтотОбъект, Списки, Объект.ПериодОтгрузки);
	
КонецПроцедуры

&НаКлиенте
Процедура ДатаОтгрузкиЗаказовСПриИзменении(Элемент)
	
	УстановитьОтборПоДатеОтгрузкеЗаказов(СписокЗаказыНаДоставку, Объект.ДатаОтгрузкиЗаказовС);
	
КонецПроцедуры

&НаКлиенте
Процедура ГруппаСтраницыПриСменеСтраницы(Элемент, ТекущаяСтраница)
	
	Если ТекущаяСтраница = Элементы.СтраницаПоДокументам Тогда
		Элементы.СписокПоДокументамСформироватьЗаказНаДоставку.КнопкаПоУмолчанию = Истина;
	Иначе
		Элементы.СписокПоТоварамСформироватьЗаказНаДоставку.КнопкаПоУмолчанию = Истина;
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыСписокПоТоварам

&НаСервереБезКонтекста
Процедура СписокПоТоварамПриПолученииДанныхНаСервере(ИмяЭлемента, Настройки, Строки)
	
	СписокПриПолученииДанныхНаСервере(ИмяЭлемента, Настройки, Строки);
	
КонецПроцедуры

&НаКлиенте
Процедура СписокПоТоварамНачалоПеретаскивания(Элемент, ПараметрыПеретаскивания, Выполнение)
	
	СписокНачалоПеретаскивания(Элемент, ПараметрыПеретаскивания, Выполнение);
	
КонецПроцедуры

&НаКлиенте
Процедура СписокПоТоварамПриАктивизацииСтроки(Элемент)
	
	ОтключитьОбработчикОжидания("СписокПоТоварамОбновитьДопПараметры");
	ПодключитьОбработчикОжидания("СписокПоТоварамОбновитьДопПараметры", 0.1, Истина);
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыСписокПоДокументам

&НаСервереБезКонтекста
Процедура СписокПоДокументамПриПолученииДанныхНаСервере(ИмяЭлемента, Настройки, Строки)
	
	СписокПриПолученииДанныхНаСервере(ИмяЭлемента, Настройки, Строки);
	
КонецПроцедуры

&НаКлиенте
Процедура СписокПоДокументамНачалоПеретаскивания(Элемент, ПараметрыПеретаскивания, Выполнение)
	
	СписокНачалоПеретаскивания(Элемент, ПараметрыПеретаскивания, Выполнение);
	
КонецПроцедуры

&НаКлиенте
Процедура СписокПоДокументамПриАктивизацииСтроки(Элемент)
	
	ОтключитьОбработчикОжидания("СписокПоДокументамОбновитьДопПараметры");
	ПодключитьОбработчикОжидания("СписокПоДокументамОбновитьДопПараметры", 0.1, Истина);
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыСписокЗаказыНаДоставку

&НаКлиенте
Процедура СписокЗаказыНаДоставкуПроверкаПеретаскивания(Элемент, ПараметрыПеретаскивания, СтандартнаяОбработка, Строка, Поле)
	
	СтандартнаяОбработка = Ложь;
	
	Если ЗначениеЗаполнено(Строка)
	   И ТипЗнч(Строка) = Тип("ДокументСсылка.ЗаказНаДоставку") Тогда
		
		ПараметрыПеретаскивания.Действие = ДействиеПеретаскивания.Перемещение;
		
	Иначе
		
		ПараметрыПеретаскивания.Действие = ДействиеПеретаскивания.Отмена;
		
	КонецЕсли;
	
КонецПроцедуры

// Параметры:
//  Элемент - ТаблицаФормы
//  ПараметрыПеретаскивания - ПараметрыПеретаскивания:
//   * Значение - Массив Из См. ДанныеСтрокиСпискаДоставить
//  СтандартнаяОбработка - Булево
//  Строка - ДокументСсылка.ЗаказНаДоставку
//  Поле - ПолеФормы
//
&НаКлиенте
Асинх Процедура СписокЗаказыНаДоставкуПеретаскивание(Элемент, ПараметрыПеретаскивания, СтандартнаяОбработка, Строка, Поле)
	
	Если ТипЗнч(ПараметрыПеретаскивания.Значение) <> Тип("Массив") Тогда
		Возврат;
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(Строка)
	 ИЛИ ТипЗнч(Строка) <> Тип("ДокументСсылка.ЗаказНаДоставку") Тогда
		Возврат;
	КонецЕсли;
	
	ПредставлениеЗаказа = Строка(Строка);
	ШаблонВопроса = НСтр("ru = 'Документ ""%1"" будет дополнен выбранными данными. Продолжить?'");
	ТекстВопроса = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(ШаблонВопроса, ПредставлениеЗаказа);
	ШаблонОповещения = НСтр("ru = 'Данные успешно добавлены в документ ""%1""'");
	ТекстОповещения = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(ШаблонОповещения, ПредставлениеЗаказа);
	
	Ответ = Ждать ВопросАсинх(ТекстВопроса, РежимДиалогаВопрос.ДаНет); // КодВозвратаДиалога
	Если Ответ = КодВозвратаДиалога.Да Тогда
		
		Замер = ОценкаПроизводительностиКлиент.НачатьЗамерДлительнойОперации(
			"Обработка.ФормированиеЗаказовНаДоставку.Форма.СписокЗаказыНаДоставкуПеретаскивание");
		ДополнитьЗаказНаСервере(Строка, ПараметрыПеретаскивания.Значение);
		ОценкаПроизводительностиКлиент.ЗафиксироватьЗамерДлительнойОперации(
			Замер, ПараметрыПеретаскивания.Значение.Количество(), "ДополнитьЗаказНаСервере");
		
		ОповеститьОбИзменении(Строка);
		ОповеститьОбИзменении(Тип("РегистрНакопленияКлючЗаписи.Доставка"));
		
		НавигационнаяСсылка = ПолучитьНавигационнуюСсылку(Строка);
		ПоказатьОповещениеПользователя(
			НСтр("ru = 'Изменение'"),
			НавигационнаяСсылка,
			ТекстОповещения,
			БиблиотекаКартинок.Информация32);
		ОценкаПроизводительностиКлиент.ЗакончитьЗамерДлительнойОперации(Замер, 1, "ПоследнийШаг");
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Асинх Процедура СформироватьЗаказНаДоставку(Команда)
	
	Если Элементы.ГруппаСтраницы.ТекущаяСтраница = Элементы.СтраницаПоТоварам Тогда
		
		ИмяСписка = "СписокПоТоварам";
		ВыделенныеСтроки = Элементы.СписокПоТоварам.ВыделенныеСтроки;
		
	ИначеЕсли Элементы.ГруппаСтраницы.ТекущаяСтраница = Элементы.СтраницаПоДокументам Тогда
		
		ИмяСписка = "СписокПоДокументам";
		ВыделенныеСтроки = Элементы.СписокПоДокументам.ВыделенныеСтроки;
		
	Иначе
		
		ВызватьИсключение НСтр("ru = 'Не определен активный список для получения выделенных строк'");
		
	КонецЕсли;
	
	Если ВыделенныеСтроки.Количество() = 0 Тогда
		
		ПоказатьПредупреждение(, НСтр("ru = 'Не выбраны строки для создания заказа на доставку.'"));
		Возврат;
		
	КонецЕсли;
	
	Замер = ОценкаПроизводительностиКлиент.НачатьЗамерДлительнойОперации("Обработка.ФормированиеЗаказовНаДоставку.Форма.СформироватьЗаказНаДоставку");
	
	ДанныеВыделенныхСтрок = Новый Массив; // Массив Из См. ДанныеСтрокиСпискаДоставить
	Для Каждого ВыделеннаяСтрока Из ВыделенныеСтроки Цикл
		
		ДанныеСтроки = Элементы[ИмяСписка].ДанныеСтроки(ВыделеннаяСтрока); // См. ДанныеСтрокиСпискаДоставить
		ДанныеВыделенныхСтрок.Добавить(ДанныеСтроки);
		
	КонецЦикла;
	
	ПараметрыЗаполнения = ПараметрыЗаполненияНовогоЗаказаПоВыделеннымСтрокам(ДанныеВыделенныхСтрок);
	
	КоэффициентШагаЗамера = 100;
	ОценкаПроизводительностиКлиент.ЗафиксироватьЗамерДлительнойОперации(
		Замер, ВыделенныеСтроки.Количество() / КоэффициентШагаЗамера, "ПараметрыЗаполнения");
	
	Если ПараметрыЗаполнения.ЕстьОтличияПараметров Тогда
		
		ТекстВопроса = НСтр("ru = 'При формировании заказа на доставку объединяются строки с разными параметрами доставки.
							|Продолжить?'");
		Ответ = Ждать ВопросАсинх(ТекстВопроса, РежимДиалогаВопрос.ДаНет); // КодВозвратаДиалога
		Если Ответ <> КодВозвратаДиалога.Да Тогда
			Возврат;
		КонецЕсли;
		
	КонецЕсли;
	
	ОценкаПроизводительностиКлиент.ЗафиксироватьЗамерДлительнойОперации(Замер, 1, "ДиалогЕстьОтличияПараметров");
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("ЗначенияЗаполнения", ПараметрыЗаполнения);
	ОткрытьФорму("Документ.ЗаказНаДоставку.ФормаОбъекта", ПараметрыФормы);
	
	ОценкаПроизводительностиКлиент.ЗакончитьЗамерДлительнойОперации(Замер, ВыделенныеСтроки.Количество(), "ОткрытьФорму");
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура ИнициализироватьОтборыСписков()
	
	СпискиОстатков = СпискиОстатков();
	ВсеСписки = ВсеСписки();
	
	Если ПолучитьФункциональнуюОпцию("ИспользоватьНесколькоОрганизаций") Тогда
		УстановитьОтборПоОрганизации(ЭтотОбъект, ВсеСписки, Объект.Организация);
	КонецЕсли;
	
	УстановитьОтборПоПолучателю(ЭтотОбъект, ВсеСписки, Объект.Получатель);
	УстановитьОтборПоОтправителю(ЭтотОбъект, ВсеСписки, Объект.Отправитель);
	
	УстановитьОтборПоПериодуОтгрузки(ЭтотОбъект, СпискиОстатков, Объект.ПериодОтгрузки);
	УстановитьОтборПоДатеОтгрузкеЗаказов(СписокЗаказыНаДоставку, Объект.ДатаОтгрузкиЗаказовС);
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Процедура УстановитьОтборПоОрганизации(Форма, Списки, Организация)
	
	Для Каждого ИмяСписка Из Списки Цикл
		
		Список = Форма[ИмяСписка]; // ДинамическийСписок
		ОбщегоНазначенияКлиентСервер.УстановитьПараметрДинамическогоСписка(
			Список, "Организация", Организация);
		
	КонецЦикла;
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Процедура УстановитьОтборПоПериодуОтгрузки(Форма, Списки, ПериодОтгрузки)
	
	Для Каждого ИмяСписка Из Списки Цикл
		
		Список = Форма[ИмяСписка]; // ДинамическийСписок
		
		ОбщегоНазначенияКлиентСервер.УстановитьПараметрДинамическогоСписка(
			Список, "ДатаОтгрузкиС", ПериодОтгрузки.ДатаНачала, ЗначениеЗаполнено(ПериодОтгрузки.ДатаНачала));
		
		ОбщегоНазначенияКлиентСервер.УстановитьПараметрДинамическогоСписка(
			Список, "ДатаОтгрузкиПо", ПериодОтгрузки.ДатаОкончания, ЗначениеЗаполнено(ПериодОтгрузки.ДатаОкончания));
		
	КонецЦикла;
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Процедура УстановитьОтборПоДатеОтгрузкеЗаказов(СписокЗаказыНаДоставку, ДатаОтгрузкиС)
	
	ОбщегоНазначенияКлиентСервер.УстановитьПараметрДинамическогоСписка(
		СписокЗаказыНаДоставку, "ДатаОтгрузкиС", ДатаОтгрузкиС);
	
КонецПроцедуры

&НаСервере
Процедура УточнитьТипыОтправителяПолучателя()
	
	Если Объект.Направление = Перечисления.НаправленияДоставки.СкладПартнер Тогда
		
		Если ТипЗнч(Объект.Отправитель) <> Тип("СправочникСсылка.Склады") Тогда
			Объект.Отправитель = Справочники.Склады.ПустаяСсылка();
		КонецЕсли;
		Элементы.Отправитель.ВыбиратьТип = Ложь;
		
		Если ТипЗнч(Объект.Получатель) <> Тип("СправочникСсылка.Партнеры") Тогда
			Объект.Получатель = Справочники.Партнеры.ПустаяСсылка();
		КонецЕсли;
		Элементы.Получатель.ВыбиратьТип = Ложь;
		
	Иначе
		
		Объект.Отправитель = Неопределено;
		Объект.Получатель = Неопределено;
		Элементы.Отправитель.ВыбиратьТип = Истина;
		Элементы.Получатель.ВыбиратьТип = Истина;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Процедура УстановитьОтборПоПолучателю(Форма, Списки, Получатель)
	
	Для Каждого ИмяСписка Из Списки Цикл
		
		Список = Форма[ИмяСписка]; // ДинамическийСписок
		ОбщегоНазначенияКлиентСервер.УстановитьПараметрДинамическогоСписка(Список, "КонечныйПолучатель", Получатель);
		
	КонецЦикла;
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Процедура УстановитьОтборПоОтправителю(Форма, Списки, Отправитель)
	
	Для Каждого ИмяСписка Из Списки Цикл
		
		Список = Форма[ИмяСписка]; // ДинамическийСписок
		ОбщегоНазначенияКлиентСервер.УстановитьПараметрДинамическогоСписка(Список, "НачальныйОтправитель", Отправитель);
		
		ДопСвойства = Список.КомпоновщикНастроек.Настройки.ДополнительныеСвойства;
		ДопСвойства.Вставить("Отправитель", Отправитель);
		
	КонецЦикла;
	
КонецПроцедуры

// Параметры:
//  Настройки - НастройкиКомпоновкиДанных
// 
// Возвращаемое значение:
//  Структура:
//    * ТекстЗапросаДетальныеДанныеПорцииСтрок - Строка
//    * Отправитель - СправочникСсылка.Склады
//  
&НаКлиентеНаСервереБезКонтекста
Функция ДопСвойстваНастроекСписка(Настройки)
	
	Возврат Настройки.ДополнительныеСвойства;
	
КонецФункции

&НаСервереБезКонтекста
Процедура СписокПриПолученииДанныхНаСервере(ИмяЭлемента, Настройки, Строки)
	
	ЭтоСписокПоТоварам = (ИмяЭлемента = "СписокПоТоварам");
	
	ДопСвойства = ДопСвойстваНастроекСписка(Настройки);
	ТекстЗапроса = ДопСвойства.ТекстЗапросаДетальныеДанныеПорцииСтрок;
	Отправитель = ДопСвойства.Отправитель;
	ДетальныеДанные = ДетальныеДанныеПорцииСтрок(Строки, ЭтоСписокПоТоварам, ТекстЗапроса, Отправитель);
	
	ОтборДетальныхОстатков = ОтборДетальныхОстатков(ЭтоСписокПоТоварам);
	
	КолонкиДетальныхОстатков = Новый Массив; // Массив Из Строка
	КолонкиДетальныхОстатков.Добавить("КодСтроки");
	КолонкиДетальныхОстатков.Добавить("Отправитель");
	КолонкиДетальныхОстатков.Добавить("ТочкаОтправителя");
	КолонкиДетальныхОстатков.Добавить("ЗонаОтправителя");
	КолонкиДетальныхОстатков.Добавить("СпособДоставкиКонечногоПлеча");
	КолонкиДетальныхОстатков.Добавить("ПолучательКонечногоПлеча");
	КолонкиДетальныхОстатков.Добавить("ТочкаПолучателяКонечногоПлеча");
	КолонкиДетальныхОстатков.Добавить("ЗонаПолучателяКонечногоПлеча");
	КолонкиДетальныхОстатков.Добавить("ПеревозчикКонечногоПлеча");
	КолонкиДетальныхОстатков.Добавить("Остаток");
	Если НЕ ЭтоСписокПоТоварам Тогда
		
		КолонкиДетальныхОстатков.Добавить("Номенклатура");
		КолонкиДетальныхОстатков.Добавить("Характеристика");
		КолонкиДетальныхОстатков.Добавить("Серия");
		КолонкиДетальныхОстатков.Добавить("Упаковка");
		
	КонецЕсли;
	КолонкиСтрокой = СтрСоединить(КолонкиДетальныхОстатков, ",");
	
	ОтборСостояния = ОтборСостоянияОформления(ЭтоСписокПоТоварам);
	ОтборСостояния.Отправитель = Отправитель;
	
	Для Каждого СтрокаСписка Из Строки Цикл
		
		ДанныеСтрокиСписка = ДанныеСтрокиСпискаДоставить(СтрокаСписка);
		ЗаполнитьЗначенияСвойств(ОтборДетальныхОстатков, ДанныеСтрокиСписка);
		
		ДетализацияСтроки = ДетальныеДанные.ДетальныеОстаткиПорции.Скопировать(ОтборДетальныхОстатков, КолонкиСтрокой);
		ДанныеСтрокиСписка.Детализация = Новый ХранилищеЗначения(ДетализацияСтроки);
		
		ЗаполнитьЗначенияСвойств(ОтборСостояния, ДанныеСтрокиСписка);
		СостояниеСтроки = ДетальныеДанные.СостоянияОформления.НайтиСтроки(ОтборСостояния);
		Если СостояниеСтроки.Количество() > 0 Тогда
			ДанныеСтрокиСписка.Состояние = СостояниеСтроки[0].Состояние;
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ОтборДетальныхОстатков(ЭтоСписокПоТоварам)
	
	ОтборДетальныхОстатков = Новый Структура;
	ОтборДетальныхОстатков.Вставить("Распоряжение", Неопределено);
	ОтборДетальныхОстатков.Вставить("СпособДоставки", Перечисления.СпособыДоставки25.ПустаяСсылка());
	ОтборДетальныхОстатков.Вставить("Получатель", Справочники.Партнеры.ПустаяСсылка());
	ОтборДетальныхОстатков.Вставить("ТочкаПолучателя", Справочники.ТочкиДоставки.ПустаяСсылка());
	ОтборДетальныхОстатков.Вставить("ЗонаПолучателя", Справочники.ЗоныДоставки.ПустаяСсылка());
	ОтборДетальныхОстатков.Вставить("ДатаОтгрузки", '00010101');
	
	Если ЭтоСписокПоТоварам Тогда
		
		ОтборДетальныхОстатков.Вставить("Номенклатура", Справочники.Номенклатура.ПустаяСсылка());
		ОтборДетальныхОстатков.Вставить("Характеристика", Справочники.ХарактеристикиНоменклатуры.ПустаяСсылка());
		ОтборДетальныхОстатков.Вставить("Серия", Справочники.СерииНоменклатуры.ПустаяСсылка());
		ОтборДетальныхОстатков.Вставить("Упаковка", Справочники.УпаковкиЕдиницыИзмерения.ПустаяСсылка());
		
	КонецЕсли;
	
	Возврат ОтборДетальныхОстатков;
	
КонецФункции

&НаСервереБезКонтекста
Функция ОтборСостоянияОформления(ЭтоСписокПоТоварам)
	
	Отбор = Новый Структура;
	Отбор.Вставить("Распоряжение", Неопределено);
	Отбор.Вставить("СпособДоставки", Перечисления.СпособыДоставки25.ПустаяСсылка());
	Отбор.Вставить("Отправитель", Неопределено);
	Отбор.Вставить("Перевозчик", Справочники.Партнеры.ПустаяСсылка());
	Отбор.Вставить("Получатель", Справочники.Партнеры.ПустаяСсылка());
	Отбор.Вставить("ТочкаПолучателя", Справочники.ТочкиДоставки.ПустаяСсылка());
	Отбор.Вставить("ЗонаПолучателя", Справочники.ЗоныДоставки.ПустаяСсылка());
	Отбор.Вставить("ДатаОтгрузки", '00010101');
	
	Если ЭтоСписокПоТоварам Тогда
		
		Отбор.Вставить("Номенклатура", Справочники.Номенклатура.ПустаяСсылка());
		Отбор.Вставить("Характеристика", Справочники.ХарактеристикиНоменклатуры.ПустаяСсылка());
		Отбор.Вставить("Серия", Справочники.СерииНоменклатуры.ПустаяСсылка());
		Отбор.Вставить("Упаковка", Справочники.УпаковкиЕдиницыИзмерения.ПустаяСсылка());
		
	КонецЕсли;
	
	Возврат Отбор;
	
КонецФункции

// Параметры:
//  СтрокаСписка - СтрокаДинамическогоСписка
// 
// Возвращаемое значение:
//  ДанныеФормыСтруктура - Данные строки:
//  * Номенклатура - СправочникСсылка.Номенклатура
//  * Подобрано - Число
//  * Остаток - Число
//  * ЕстьОтличияВПараметрахДоставки - Булево
//  * ИндексКартинки - Число
//  * Детализация - ХранилищеЗначения
//  * ВариантыПараметровДоставки - ХранилищеЗначения
//  * Распоряжение - ОпределяемыйТип.РаспоряжениеНаДоставку25
//  * ТипДоставки - ПеречислениеСсылка.ТипыДоставки
//  * Получатель - СправочникСсылка.Партнеры
//  * ТочкаПолучателя - СправочникСсылка.ТочкиДоставки
//  * ЗонаПолучателя - СправочникСсылка.ЗоныДоставки
//  * Состояние - Число
//
&НаСервереБезКонтекста
Функция ДанныеСтрокиСпискаДоставить(СтрокаСписка)
	
	ДанныеСтрокиСписка = СтрокаСписка.Значение.Данные;
	Возврат ДанныеСтрокиСписка;
	
КонецФункции

&НаСервере
Процедура ИнициализироватьДополнительныеСвойстваСписков()
	
	Списки = СпискиОстатков();
	
	Для Каждого ИмяСписка Из Списки Цикл
		
		СписокОстатков = ЭтотОбъект[ИмяСписка]; // ДинамическийСписок
		ЭтоСписокПоТоварам = (СписокОстатков = СписокПоТоварам);
		
		ДопСвойства = СписокОстатков.КомпоновщикНастроек.Настройки.ДополнительныеСвойства;
		
		ТекстЗапроса = ТекстЗапросаДетальныеДанныеПорцииСтрок(ЭтоСписокПоТоварам);
		ДопСвойства.Вставить("ТекстЗапросаДетальныеДанныеПорцииСтрок", ТекстЗапроса);
		ДопСвойства.Вставить("Отправитель", Объект.Отправитель);
		
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Функция ТекстЗапросаДетальныеДанныеПорцииСтрок(ЭтоСписокПоТоварам)
	
	ПакетЗапросов = Новый Массив; // Массив Из Строка
	
	ТекстЗапросаВТОстатки =
	"ВЫБРАТЬ
	|	ДоставкаОбороты.Распоряжение КАК Распоряжение,
	|	ДоставкаОбороты.КодСтроки КАК КодСтроки,
	|	ДоставкаОбороты.Номенклатура КАК Номенклатура,
	|	ДоставкаОбороты.Характеристика КАК Характеристика,
	|	ДоставкаОбороты.Серия КАК Серия,
	|	ДоставкаОбороты.ДатаОтгрузки КАК ДатаОтгрузки,
	|	ДоставкаОбороты.СпособДоставки КАК СпособДоставки,
	|	ДоставкаОбороты.Перевозчик КАК Перевозчик,
	|	ДоставкаОбороты.Отправитель КАК Отправитель,
	|	ДоставкаОбороты.ТочкаОтправителя КАК ТочкаОтправителя,
	|	ДоставкаОбороты.ЗонаОтправителя КАК ЗонаОтправителя,
	|	ДоставкаОбороты.Получатель КАК Получатель,
	|	ДоставкаОбороты.ТочкаПолучателя КАК ТочкаПолучателя,
	|	ДоставкаОбороты.ЗонаПолучателя КАК ЗонаПолучателя,
	|	ЗНАЧЕНИЕ(Справочник.УпаковкиЕдиницыИзмерения.ПустаяСсылка) КАК Упаковка,
	|	ДоставкаОбороты.КДоставкеОборот - ДоставкаОбороты.КРейсуОборот КАК Остаток
	|ПОМЕСТИТЬ ВТОстатки
	|ИЗ
	|	РегистрНакопления.Доставка.Обороты(
	|			,
	|			,
	|			,
	|			Плечо = 1
	|				И Распоряжение В (&РаспоряженияПорцииСтрок)
	|				И Отправитель = &Отправитель
	|				И &УсловиеПоТоварам) КАК ДоставкаОбороты
	|ГДЕ
	|	ДоставкаОбороты.КДоставкеОборот - ДоставкаОбороты.КРейсуОборот > 0";
	
	Если ЭтоСписокПоТоварам Тогда
		УсловиеПоТоварам = "Номенклатура В (&НоменклатураПорцииСтрок)";
	Иначе
		УсловиеПоТоварам = "ИСТИНА";
	КонецЕсли;
	
	ТекстЗапросаВТОстатки = СтрЗаменить(ТекстЗапросаВТОстатки, "&УсловиеПоТоварам", УсловиеПоТоварам);
	
	ПакетЗапросов.Добавить(ТекстЗапросаВТОстатки);
	
	ТекстЗапросаПараметрыКонечногоПлеча =
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ВТОстатки.Распоряжение КАК Распоряжение,
	|	ВТОстатки.КодСтроки КАК КодСтроки,
	|	Доставка.ДатаОтгрузки КАК ДатаОтгрузки,
	|	Доставка.СпособДоставки КАК СпособДоставки,
	|	Доставка.Перевозчик КАК Перевозчик,
	|	Доставка.Получатель КАК Получатель,
	|	Доставка.ТочкаПолучателя КАК ТочкаПолучателя,
	|	Доставка.ЗонаПолучателя КАК ЗонаПолучателя
	|ПОМЕСТИТЬ ВТПараметрыКонечногоПлеча
	|ИЗ
	|	ВТОстатки КАК ВТОстатки
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрНакопления.Доставка КАК Доставка
	|		ПО ВТОстатки.Распоряжение = Доставка.Распоряжение
	|			И ВТОстатки.КодСтроки = Доставка.КодСтроки
	|			И Доставка.ЭтоКонечноеПлечо
	|			И Доставка.КДоставке > 0
	|			И Доставка.ДокументПланирования = НЕОПРЕДЕЛЕНО
	|			И НЕ 1 В
	|				(ВЫБРАТЬ ПЕРВЫЕ 1
	|					1
	|				ИЗ
	|					РегистрСведений.ИсправленияДокументов КАК ИсправленияДокументов
	|				ГДЕ
	|					ИсправленияДокументов.ИсправляемыйДокумент = Доставка.Регистратор
	|					ИЛИ ИсправленияДокументов.ПредыдущееИсправление = Доставка.Регистратор)
	|";
	
	ПакетЗапросов.Добавить(ТекстЗапросаПараметрыКонечногоПлеча);
	
	ТекстЗапросаСостояние =
	"ВЫБРАТЬ
	|	ВТОстатки.Распоряжение КАК Распоряжение,
	|	ВТОстатки.СпособДоставки КАК СпособДоставки,
	|	ВТОстатки.Отправитель КАК Отправитель,
	|	ВТОстатки.Перевозчик КАК Перевозчик,
	|	ВТОстатки.Получатель КАК Получатель,
	|	ВТОстатки.ТочкаПолучателя КАК ТочкаПолучателя,
	|	ВТОстатки.ЗонаПолучателя КАК ЗонаПолучателя,
	|	ВТОстатки.ДатаОтгрузки КАК ДатаОтгрузки,
	|	&ПоляТовара,
	|	МАКСИМУМ(ВЫБОР
	|			КОГДА ДоставкаОбороты.Регистратор ССЫЛКА Документ.ЗаказНаДоставку
	|				ТОГДА 2
	|			ИНАЧЕ 1
	|		КОНЕЦ) КАК Состояние
	|ИЗ
	|	ВТОстатки КАК ВТОстатки
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.Доставка.Обороты(, , Регистратор, Распоряжение В (&РаспоряженияПорцииСтрок)) КАК ДоставкаОбороты
	|		ПО ВТОстатки.Распоряжение = ДоставкаОбороты.Распоряжение
	|			И ВТОстатки.КодСтроки = ДоставкаОбороты.КодСтроки
	|
	|СГРУППИРОВАТЬ ПО
	|	ВТОстатки.Распоряжение,
	|	ВТОстатки.СпособДоставки,
	|	ВТОстатки.Отправитель,
	|	ВТОстатки.Перевозчик,
	|	ВТОстатки.Получатель,
	|	ВТОстатки.ТочкаПолучателя,
	|	ВТОстатки.ЗонаПолучателя,
	|	ВТОстатки.ДатаОтгрузки,
	|	&ПоляГруппировкиТовара";
	
	Если ЭтоСписокПоТоварам Тогда
		
		ПоляТовара =
		"ВТОстатки.Номенклатура КАК Номенклатура,
		|	ВТОстатки.Характеристика КАК Характеристика,
		|	ВТОстатки.Серия КАК Серия,
		|	ЗНАЧЕНИЕ(Справочник.УпаковкиЕдиницыИзмерения.ПустаяСсылка) КАК Упаковка";
		
		ПоляГруппировкиТовара =
		"ВТОстатки.Номенклатура,
		|	ВТОстатки.Характеристика,
		|	ВТОстатки.Серия,
		|	ЗНАЧЕНИЕ(Справочник.УпаковкиЕдиницыИзмерения.ПустаяСсылка)";
		
	Иначе
		
		ПоляТовара = "NULL";
		ПоляГруппировкиТовара = "NULL";
		
	КонецЕсли;
	
	ТекстЗапросаСостояние = СтрЗаменить(ТекстЗапросаСостояние, "&ПоляТовара", ПоляТовара);
	ТекстЗапросаСостояние = СтрЗаменить(ТекстЗапросаСостояние, "&ПоляГруппировкиТовара", ПоляГруппировкиТовара);
	
	ПакетЗапросов.Добавить(ТекстЗапросаСостояние);
	
	ТекстЗапросаДетальныеОстатки =
	"ВЫБРАТЬ
	|	ВТОстатки.Распоряжение КАК Распоряжение,
	|	ВТОстатки.КодСтроки КАК КодСтроки,
	|	ВТОстатки.Номенклатура КАК Номенклатура,
	|	ВТОстатки.Характеристика КАК Характеристика,
	|	ВТОстатки.Серия КАК Серия,
	|	ВТОстатки.Упаковка КАК Упаковка,
	|	ВТОстатки.ДатаОтгрузки КАК ДатаОтгрузки,
	|	ВТОстатки.СпособДоставки КАК СпособДоставки,
	|	ВТОстатки.Отправитель КАК Отправитель,
	|	ВТОстатки.ТочкаОтправителя КАК ТочкаОтправителя,
	|	ВТОстатки.ЗонаОтправителя КАК ЗонаОтправителя,
	|	ВТОстатки.Получатель КАК Получатель,
	|	ВТОстатки.ТочкаПолучателя КАК ТочкаПолучателя,
	|	ВТОстатки.ЗонаПолучателя КАК ЗонаПолучателя,
	|	ЕСТЬNULL(ВТПараметрыКонечногоПлеча.СпособДоставки, ВТОстатки.СпособДоставки) КАК СпособДоставкиКонечногоПлеча,
	|	ЕСТЬNULL(ВТПараметрыКонечногоПлеча.Перевозчик, ВТОстатки.Перевозчик) КАК ПеревозчикКонечногоПлеча,
	|	ЕСТЬNULL(ВТПараметрыКонечногоПлеча.Получатель, ВТОстатки.Получатель) КАК ПолучательКонечногоПлеча,
	|	ЕСТЬNULL(ВТПараметрыКонечногоПлеча.ТочкаПолучателя, ВТОстатки.ТочкаПолучателя) КАК ТочкаПолучателяКонечногоПлеча,
	|	ЕСТЬNULL(ВТПараметрыКонечногоПлеча.ЗонаПолучателя, ВТОстатки.ЗонаПолучателя) КАК ЗонаПолучателяКонечногоПлеча,
	|	СУММА(ВТОстатки.Остаток) КАК Остаток
	|ИЗ
	|	ВТОстатки КАК ВТОстатки
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТПараметрыКонечногоПлеча КАК ВТПараметрыКонечногоПлеча
	|		ПО ВТОстатки.Распоряжение = ВТПараметрыКонечногоПлеча.Распоряжение
	|			И ВТОстатки.КодСтроки = ВТПараметрыКонечногоПлеча.КодСтроки
	|
	|СГРУППИРОВАТЬ ПО
	|	ВТОстатки.Распоряжение,
	|	ВТОстатки.КодСтроки,
	|	ВТОстатки.Номенклатура,
	|	ВТОстатки.Характеристика,
	|	ВТОстатки.Серия,
	|	ВТОстатки.Упаковка,
	|	ВТОстатки.ДатаОтгрузки,
	|	ВТОстатки.СпособДоставки,
	|	ВТОстатки.Отправитель,
	|	ВТОстатки.ТочкаОтправителя,
	|	ВТОстатки.ЗонаОтправителя,
	|	ВТОстатки.Получатель,
	|	ВТОстатки.ТочкаПолучателя,
	|	ВТОстатки.ЗонаПолучателя,
	|	ЕСТЬNULL(ВТПараметрыКонечногоПлеча.СпособДоставки, ВТОстатки.СпособДоставки),
	|	ЕСТЬNULL(ВТПараметрыКонечногоПлеча.Перевозчик, ВТОстатки.Перевозчик),
	|	ЕСТЬNULL(ВТПараметрыКонечногоПлеча.Получатель, ВТОстатки.Получатель),
	|	ЕСТЬNULL(ВТПараметрыКонечногоПлеча.ТочкаПолучателя, ВТОстатки.ТочкаПолучателя),
	|	ЕСТЬNULL(ВТПараметрыКонечногоПлеча.ЗонаПолучателя, ВТОстатки.ЗонаПолучателя)";
	
	ПакетЗапросов.Добавить(ТекстЗапросаДетальныеОстатки);
	
	ТекстЗапроса = СтрСоединить(ПакетЗапросов, ОбщегоНазначения.РазделительПакетаЗапросов());
	
	Возврат ТекстЗапроса;
	
КонецФункции

// Параметры:
//  Строки - СтрокиДинамическогоСписка
//  ЭтоСписокПоТоварам - Булево
//  ТекстЗапроса - Строка
//  Отправитель - СправочникСсылка.Склады
// 
// Возвращаемое значение:
//  Структура - Детальные данные порции строк:
//   * ДетальныеОстаткиПорции - См. ДетальныеОстаткиПорции
//   * СостоянияОформления - См. СостоянияОформленияПорции
//
&НаСервереБезКонтекста
Функция ДетальныеДанныеПорцииСтрок(Строки, ЭтоСписокПоТоварам, ТекстЗапроса, Отправитель)
	
	РаспоряженияПорцииСтрок = Новый Массив; // Массив Из ОпределяемыйТип.РаспоряжениеНаДоставку25
	НоменклатураПорцииСтрок = Новый Массив; // Массив Из СправочникСсылка.Номенклатура
	
	Для Каждого СтрокаСписка Из Строки Цикл
		
		ДанныеСтрокиСписка = ДанныеСтрокиСпискаДоставить(СтрокаСписка);
		
		Если РаспоряженияПорцииСтрок.Найти(ДанныеСтрокиСписка.Распоряжение) = Неопределено Тогда
			РаспоряженияПорцииСтрок.Добавить(ДанныеСтрокиСписка.Распоряжение);
		КонецЕсли;
		
		Если ЭтоСписокПоТоварам Тогда
			
			Если НоменклатураПорцииСтрок.Найти(ДанныеСтрокиСписка.Номенклатура) = Неопределено Тогда
				НоменклатураПорцииСтрок.Добавить(ДанныеСтрокиСписка.Номенклатура);
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЦикла;
	
	Запрос = Новый Запрос;
	Запрос.Текст = ТекстЗапроса;
	Запрос.УстановитьПараметр("РаспоряженияПорцииСтрок", РаспоряженияПорцииСтрок);
	Запрос.УстановитьПараметр("Отправитель", Отправитель);
	Если ЭтоСписокПоТоварам Тогда
		Запрос.УстановитьПараметр("НоменклатураПорцииСтрок", НоменклатураПорцииСтрок);
	КонецЕсли;
	
	РезультатЗапроса = Запрос.ВыполнитьПакет();
	ДетальныеОстаткиПорции = ДетальныеОстаткиПорции(РезультатЗапроса);
	СостоянияОформления = СостоянияОформленияПорции(РезультатЗапроса);
	
	Результат = Новый Структура;
	Результат.Вставить("ДетальныеОстаткиПорции", ДетальныеОстаткиПорции);
	Результат.Вставить("СостоянияОформления", СостоянияОформления);
	
	Возврат Результат;
	
КонецФункции

// Возвращаемое значение:
// ТаблицаЗначений:
//  * КодСтроки - Число
//  * Остаток - Число
//
&НаСервереБезКонтекста
Функция ДетальныеОстаткиПорции(РезультатЗапроса)
	
	Возврат РезультатЗапроса[РезультатЗапроса.ВГраница()].Выгрузить();
	
КонецФункции

// Возвращаемое значение:
// ТаблицаЗначений:
//  * Распоряжение - ОпределяемыйТип.РаспоряжениеНаДоставку25
//  * Состояние - Число
//
&НаСервереБезКонтекста
Функция СостоянияОформленияПорции(РезультатЗапроса)
	
	Возврат РезультатЗапроса[РезультатЗапроса.ВГраница() - 1].Выгрузить();
	
КонецФункции

&НаСервере
Функция ДанныеДляОформленияПоВыделеннымСтрокам(ДанныеВыделенныхСтрок)
	
	ДанныеДляОформления = НовыеДанныеДляОформления();
	
	Для Каждого ДанныеСтроки Из ДанныеВыделенныхСтрок Цикл
		
		ДетализацияСтроки = ДанныеСтроки.Детализация.Получить(); // См. ДетальныеОстаткиПорции
		
		Для Каждого ВариантДетализации Из ДетализацияСтроки Цикл
			
			СтрокаДляОформления = ДанныеДляОформления.Добавить();
			ЗаполнитьЗначенияСвойств(СтрокаДляОформления, ДанныеСтроки);
			ЗаполнитьЗначенияСвойств(СтрокаДляОформления, ВариантДетализации);
			
			СтрокаДляОформления.КодСтрокиДоставки = ВариантДетализации.КодСтроки;
			СтрокаДляОформления.Количество = ВариантДетализации.Остаток;
			СтрокаДляОформления.КоличествоУпаковок = ВариантДетализации.Остаток;
			
		КонецЦикла;
		
	КонецЦикла;
	
	Возврат ДанныеДляОформления;
	
КонецФункции

&НаСервереБезКонтекста
Функция НовыеДанныеДляОформления()
	
	ДанныеДляОформления = Новый ТаблицаЗначений();
	МетаданныеДоставка = Метаданные.РегистрыНакопления.Доставка;
	ДанныеДляОформления.Колонки.Добавить("Распоряжение", МетаданныеДоставка.Измерения.Распоряжение.Тип);
	ДанныеДляОформления.Колонки.Добавить("КодСтрокиДоставки", МетаданныеДоставка.Измерения.КодСтроки.Тип);
	ДанныеДляОформления.Колонки.Добавить("Номенклатура", МетаданныеДоставка.Измерения.Номенклатура.Тип);
	ДанныеДляОформления.Колонки.Добавить("Характеристика", МетаданныеДоставка.Измерения.Характеристика.Тип);
	ДанныеДляОформления.Колонки.Добавить("Серия", МетаданныеДоставка.Измерения.Серия.Тип);
	ДанныеДляОформления.Колонки.Добавить("Упаковка", МетаданныеДоставка.Измерения.Упаковка.Тип);
	ДанныеДляОформления.Колонки.Добавить("ДатаОтгрузки", МетаданныеДоставка.Измерения.ДатаОтгрузки.Тип);
	ДанныеДляОформления.Колонки.Добавить("СпособДоставки", МетаданныеДоставка.Измерения.СпособДоставки.Тип);
	ДанныеДляОформления.Колонки.Добавить("Отправитель", МетаданныеДоставка.Измерения.Отправитель.Тип);
	ДанныеДляОформления.Колонки.Добавить("ТочкаОтправителя", МетаданныеДоставка.Измерения.ТочкаОтправителя.Тип);
	ДанныеДляОформления.Колонки.Добавить("ЗонаОтправителя", МетаданныеДоставка.Измерения.ЗонаОтправителя.Тип);
	ДанныеДляОформления.Колонки.Добавить("Получатель", МетаданныеДоставка.Измерения.Получатель.Тип);
	ДанныеДляОформления.Колонки.Добавить("ТочкаПолучателя", МетаданныеДоставка.Измерения.ТочкаПолучателя.Тип);
	ДанныеДляОформления.Колонки.Добавить("ЗонаПолучателя", МетаданныеДоставка.Измерения.ЗонаПолучателя.Тип);
	ДанныеДляОформления.Колонки.Добавить("Перевозчик", МетаданныеДоставка.Измерения.Перевозчик.Тип);
	ДанныеДляОформления.Колонки.Добавить("СпособДоставкиКонечногоПлеча", МетаданныеДоставка.Измерения.СпособДоставки.Тип);
	ДанныеДляОформления.Колонки.Добавить("ПолучательКонечногоПлеча", МетаданныеДоставка.Измерения.Получатель.Тип);
	ДанныеДляОформления.Колонки.Добавить("ТочкаПолучателяКонечногоПлеча", МетаданныеДоставка.Измерения.ТочкаПолучателя.Тип);
	ДанныеДляОформления.Колонки.Добавить("ЗонаПолучателяКонечногоПлеча", МетаданныеДоставка.Измерения.ЗонаПолучателя.Тип);
	ДанныеДляОформления.Колонки.Добавить("ПеревозчикКонечногоПлеча", МетаданныеДоставка.Измерения.Перевозчик.Тип);
	ДанныеДляОформления.Колонки.Добавить("Количество", МетаданныеДоставка.Ресурсы.КДоставке.Тип);
	ДанныеДляОформления.Колонки.Добавить("КоличествоУпаковок", МетаданныеДоставка.Ресурсы.КДоставке.Тип);
	
	Возврат ДанныеДляОформления;
	
КонецФункции

&НаСервере
Функция ПараметрыЗаполненияНовогоЗаказа(ДанныеДляОформления)
	
	Результат = Новый Структура;
	Результат.Вставить("ЕстьОтличияПараметров", Ложь);
	Результат.Вставить("Отправитель", Справочники.Склады.ПустаяСсылка());
	Результат.Вставить("ТочкаДоставкиОтправителя", Справочники.ТочкиДоставки.ПустаяСсылка());
	Результат.Вставить("ЗонаОтправления", Справочники.ЗоныДоставки.ПустаяСсылка());
	Результат.Вставить("Получатель", Справочники.Партнеры.ПустаяСсылка());
	Результат.Вставить("ТочкаДоставкиПолучателя", Справочники.ТочкиДоставки.ПустаяСсылка());
	Результат.Вставить("ЗонаДоставки", Справочники.ЗоныДоставки.ПустаяСсылка());
	Результат.Вставить("СпособДоставки", Перечисления.СпособыДоставки25.ПустаяСсылка());
	Результат.Вставить("ДоставкаДоПеревозчика", Ложь);
	Результат.Вставить("Перевозчик", Справочники.Партнеры.ПустаяСсылка());
	Результат.Вставить("ТочкаДоставкиПеревозчика", Справочники.ТочкиДоставки.ПустаяСсылка());
	Результат.Вставить("ЗонаДоставкиПеревозчика", Справочники.ЗоныДоставки.ПустаяСсылка());
	Результат.Вставить("АдресТаблицаТовары", "");
	Результат.Вставить("Дата", ТекущаяДатаСеанса());
	Результат.Вставить("Организация", Объект.Организация);
	Результат.Вставить("ДатаОтгрузки", '00010101');
	Результат.Вставить("НаправлениеДоставки", Объект.Направление);
	Результат.Вставить("ЗаполнятьТочкиЗоныПоУмолчанию", Ложь);
	Результат.Вставить("ОбновитьДополнительныеПараметры", Истина);
	
	КолонкиПараметров = Новый Массив; // Массив Из Строка
	КолонкиПараметров.Добавить("Отправитель");
	КолонкиПараметров.Добавить("ТочкаОтправителя");
	КолонкиПараметров.Добавить("ЗонаОтправителя");
	КолонкиПараметров.Добавить("Получатель");
	КолонкиПараметров.Добавить("ТочкаПолучателя");
	КолонкиПараметров.Добавить("ЗонаПолучателя");
	КолонкиПараметров.Добавить("СпособДоставки");
	КолонкиПараметров.Добавить("Перевозчик");
	КолонкиПараметров.Добавить("ПолучательКонечногоПлеча");
	КолонкиПараметров.Добавить("ТочкаПолучателяКонечногоПлеча");
	КолонкиПараметров.Добавить("ЗонаПолучателяКонечногоПлеча");
	КолонкиПараметров.Добавить("ПеревозчикКонечногоПлеча");
	КолонкиПараметров.Добавить("ДатаОтгрузки");
	
	КолонкиПараметровИсключения = Новый Массив; // Массив Из Строка
	КолонкиПараметровИсключения.Добавить("ДатаОтгрузки");
	
	УникальныеЗначенияПараметров = НовыеУникальныеЗначенияПараметров();
	
	Для Каждого ИмяПараметра Из КолонкиПараметров Цикл
		
		ЗначенияПараметра = ОбщегоНазначенияУТ.УникальныеЗначенияИзКолонкиТаблицы(ДанныеДляОформления, ИмяПараметра);
		КоличествоЗначений = ЗначенияПараметра.Количество();
		Для ОбратныйИндекс = 1 По КоличествоЗначений Цикл
			
			Индекс = КоличествоЗначений - ОбратныйИндекс;
			Если НЕ ЗначениеЗаполнено(ЗначенияПараметра[Индекс]) Тогда
				ЗначенияПараметра.Удалить(Индекс);
			КонецЕсли;
			
		КонецЦикла;
		
		УникальныеЗначенияПараметров.Вставить(ИмяПараметра, ЗначенияПараметра);
		
		Если КолонкиПараметровИсключения.Найти(ИмяПараметра) = Неопределено Тогда
			
			Результат.ЕстьОтличияПараметров = (Результат.ЕстьОтличияПараметров ИЛИ ЗначенияПараметра.Количество() > 1);
			
		КонецЕсли;
		
	КонецЦикла;
	
	Результат.Отправитель = ОбщееЗначениеПараметра(УникальныеЗначенияПараметров, "Отправитель");
	Результат.ТочкаДоставкиОтправителя = ОбщееЗначениеПараметра(УникальныеЗначенияПараметров, "ТочкаОтправителя");
	Результат.ЗонаОтправления = ОбщееЗначениеПараметра(УникальныеЗначенияПараметров, "ЗонаОтправителя");
	Результат.ЗонаОтправления = ОбщееЗначениеПараметра(УникальныеЗначенияПараметров, "ЗонаОтправителя");
	Результат.ДатаОтгрузки = ОбщееЗначениеПараметра(УникальныеЗначенияПараметров, "ДатаОтгрузки");
	
	ОтличаютсяПолучатели = (УникальныеЗначенияПараметров["Получатель"].Количество() > 1);
	
	Если ОтличаютсяПолучатели Тогда
		
		Результат.Получатель = ОбщееЗначениеПараметра(УникальныеЗначенияПараметров, "ПолучательКонечногоПлеча");
		Результат.ТочкаДоставкиПолучателя = ОбщееЗначениеПараметра(УникальныеЗначенияПараметров, "ТочкаПолучателяКонечногоПлеча");
		Результат.ЗонаДоставки = ОбщееЗначениеПараметра(УникальныеЗначенияПараметров, "ЗонаПолучателяКонечногоПлеча");
		Результат.Перевозчик = ОбщееЗначениеПараметра(УникальныеЗначенияПараметров, "Перевозчик");
		Результат.СпособДоставки = ОбщееЗначениеПараметра(УникальныеЗначенияПараметров, "СпособДоставки");
		Результат.ДоставкаДоПеревозчика = Ложь;
		
	Иначе
		
		Получатель = ОбщееЗначениеПараметра(УникальныеЗначенияПараметров, "Получатель");
		ПолучательКонечногоПлеча = ОбщееЗначениеПараметра(УникальныеЗначенияПараметров, "ПолучательКонечногоПлеча");
		
		Если Получатель = ПолучательКонечногоПлеча Тогда
			
			Результат.Получатель = Получатель;
			Результат.ТочкаДоставкиПолучателя = ОбщееЗначениеПараметра(УникальныеЗначенияПараметров, "ТочкаПолучателяКонечногоПлеча");
			Результат.ЗонаДоставки = ОбщееЗначениеПараметра(УникальныеЗначенияПараметров, "ЗонаПолучателяКонечногоПлеча");
			Результат.Перевозчик = ОбщееЗначениеПараметра(УникальныеЗначенияПараметров, "Перевозчик");
			Результат.СпособДоставки = ОбщееЗначениеПараметра(УникальныеЗначенияПараметров, "СпособДоставки");
			Результат.ДоставкаДоПеревозчика = Ложь;
			
		Иначе
			
			Результат.Перевозчик = Получатель;
			Результат.ТочкаДоставкиПеревозчика = ОбщееЗначениеПараметра(УникальныеЗначенияПараметров, "ТочкаПолучателя");
			Результат.ЗонаДоставкиПеревозчика = ОбщееЗначениеПараметра(УникальныеЗначенияПараметров, "ЗонаПолучателя");
			
			Результат.Получатель = ПолучательКонечногоПлеча;
			Результат.ТочкаДоставкиПолучателя = ОбщееЗначениеПараметра(УникальныеЗначенияПараметров, "ТочкаПолучателяКонечногоПлеча");
			Результат.ЗонаДоставки = ОбщееЗначениеПараметра(УникальныеЗначенияПараметров, "ЗонаПолучателяКонечногоПлеча");
			
			Результат.СпособДоставки = ОбщееЗначениеПараметра(УникальныеЗначенияПараметров, "СпособДоставки");
			Результат.ДоставкаДоПеревозчика = Истина;
			
		КонецЕсли;
		
	КонецЕсли;
	
	СвернутьДанныеДляОформления(ДанныеДляОформления);
	ПоместитьВоВременноеХранилище(ДанныеДляОформления, АдресДанныеДляОформления);
	Результат.АдресТаблицаТовары = АдресДанныеДляОформления;
	
	Возврат Результат;
	
КонецФункции

// Возвращаемое значение:
//  Структура - Уникальные значения параметров:
//   * Отправитель - Массив Из СправочникСсылка.Склады
//   * ТочкаОтправителя - Массив Из СправочникСсылка.ТочкиДоставки
//   * ЗонаОтправителя - Массив Из СправочникСсылка.ЗоныДоставки
//   * ПолучательКонечногоПлеча - Массив Из СправочникСсылка.Партнеры
//   * ТочкаПолучателяКонечногоПлеча - Массив Из СправочникСсылка.ТочкиДоставки
//   * ЗонаПолучателяКонечногоПлеча - Массив Из СправочникСсылка.ЗоныДоставки
//   * Получатель - Массив Из СправочникСсылка.Партнеры
//   * Перевозчик - Массив Из СправочникСсылка.Партнеры
//   * СпособДоставки - Массив Из ПеречислениеСсылка.СпособыДоставки25
//
&НаСервере
Функция НовыеУникальныеЗначенияПараметров()
	
	УникальныеЗначенияПараметров = Новый Структура;
	УникальныеЗначенияПараметров.Вставить("Отправитель", Новый Массив);
	УникальныеЗначенияПараметров.Вставить("ТочкаОтправителя", Новый Массив);
	УникальныеЗначенияПараметров.Вставить("ЗонаОтправителя", Новый Массив);
	УникальныеЗначенияПараметров.Вставить("ПолучательКонечногоПлеча", Новый Массив);
	УникальныеЗначенияПараметров.Вставить("ТочкаПолучателяКонечногоПлеча", Новый Массив);
	УникальныеЗначенияПараметров.Вставить("ЗонаПолучателяКонечногоПлеча", Новый Массив);
	УникальныеЗначенияПараметров.Вставить("Получатель", Новый Массив);
	УникальныеЗначенияПараметров.Вставить("Перевозчик", Новый Массив);
	УникальныеЗначенияПараметров.Вставить("СпособДоставки", Новый Массив);
	
	Возврат УникальныеЗначенияПараметров;
	
КонецФункции

&НаСервере
Функция ОбщееЗначениеПараметра(ЗначенияПараметров, ИмяПараметра)
	
	Возврат ?(ЗначенияПараметров[ИмяПараметра].Количество() = 1, ЗначенияПараметров[ИмяПараметра][0], Неопределено);
	
КонецФункции

&НаСервере
Функция ПараметрыЗаполненияНовогоЗаказаПоВыделеннымСтрокам(Знач ДанныеВыделенныхСтрок)
	
	ДанныеДляОформления = ДанныеДляОформленияПоВыделеннымСтрокам(ДанныеВыделенныхСтрок);
	ПараметрыЗаполнения = ПараметрыЗаполненияНовогоЗаказа(ДанныеДляОформления);
	Возврат ПараметрыЗаполнения;
	
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Функция СпискиОстатков()
	
	СпискиОстатков = Новый Массив; // Массив Из Строка
	СпискиОстатков.Добавить("СписокПоТоварам");
	СпискиОстатков.Добавить("СписокПоДокументам");
	
	Возврат СпискиОстатков;
	
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Функция ВсеСписки()
	
	Списки = СпискиОстатков();
	Списки.Добавить("СписокЗаказыНаДоставку");
	Возврат Списки;
	
КонецФункции

&НаКлиенте
Процедура СписокНачалоПеретаскивания(Элемент, ПараметрыПеретаскивания, Выполнение)
	
	ПараметрыПеретаскивания.ДопустимыеДействия = ДопустимыеДействияПеретаскивания.Перемещение;
	
	ДанныеВыделенныхСтрок = Новый Массив; // Массив Из См. ДанныеСтрокиСпискаДоставить
	Для Каждого ВыделеннаяСтрока Из Элемент.ВыделенныеСтроки Цикл
		
		ДанныеСтроки = Элемент.ДанныеСтроки(ВыделеннаяСтрока); // См. ДанныеСтрокиСпискаДоставить
		ДанныеВыделенныхСтрок.Добавить(ДанныеСтроки);
		
	КонецЦикла;
	
	ПараметрыПеретаскивания.Значение = ДанныеВыделенныхСтрок;
	
КонецПроцедуры

// Параметры:
//  ЗаказНаДоставкуСсылка - ДокументСсылка.ЗаказНаДоставку
//  ДанныеВыделенныхСтрок - Массив Из См. ДанныеСтрокиСпискаДоставить
//
&НаСервере
Процедура ДополнитьЗаказНаСервере(Знач ЗаказНаДоставкуСсылка, Знач ДанныеВыделенныхСтрок)
	
	ЗаказНаДоставкуОбъект = ЗаказНаДоставкуСсылка.ПолучитьОбъект();
	ЗаказНаДоставкуОбъект.Заблокировать();
	
	ДанныеДляОформления = ДанныеДляОформленияПоВыделеннымСтрокам(ДанныеВыделенныхСтрок);
	СвернутьДанныеДляОформления(ДанныеДляОформления);
	
	КэшированныеЗначения = ПакетнаяОбработкаТабличнойЧастиКлиентСервер.ПолучитьСтруктуруКэшируемыеЗначения();
	СтруктураДействияПересчитатьКоличествоУпаковок = Новый Структура("ПересчитатьКоличествоУпаковок", Неопределено);
	
	ОтборСтрок = Новый Структура;
	ОтборСтрок.Вставить("Распоряжение", Неопределено);
	ОтборСтрок.Вставить("КодСтрокиДоставки", 0);
	
	НовыеСтрокиТоваров = Новый Массив; // Массив Из СтрокаТабличнойЧасти: См. Документ.ЗаказНаДоставку.Товары
	
	Для Каждого СтрокаДанных Из ДанныеДляОформления Цикл
		
		ЗаполнитьЗначенияСвойств(ОтборСтрок, СтрокаДанных);
		СуществующиеСтроки = ЗаказНаДоставкуОбъект.Товары.НайтиСтроки(ОтборСтрок);
		Если СуществующиеСтроки.Количество() > 0 Тогда
			
			СтрокаТЧ = СуществующиеСтроки[0];
			СтрокаТЧ.Количество = СтрокаТЧ.Количество + СтрокаДанных.Количество;
			СтрокаТЧ.КоличествоУпаковок = СтрокаТЧ.КоличествоУпаковок + СтрокаДанных.КоличествоУпаковок;
			
		Иначе
			
			СтрокаТЧ = ЗаказНаДоставкуОбъект.Товары.Добавить();
			ЗаполнитьЗначенияСвойств(СтрокаТЧ, СтрокаДанных);
			НовыеСтрокиТоваров.Добавить(СтрокаТЧ);
			
		КонецЕсли;
		
		ПакетнаяОбработкаТабличнойЧастиКлиентСервер.ПересчитатьКоличествоУпаковокВСтрокеТЧ(
			СтрокаТЧ, СтруктураДействияПересчитатьКоличествоУпаковок, КэшированныеЗначения);
		
	КонецЦикла;
	
	Документы.ЗаказНаДоставку.ОбновитьДополнительныеПараметры(ЗаказНаДоставкуОбъект, НовыеСтрокиТоваров);
	
	Если ЗаказНаДоставкуОбъект.Проведен Тогда
		РежимЗаписи = РежимЗаписиДокумента.Проведение;
	Иначе
		РежимЗаписи = РежимЗаписиДокумента.Запись;
	КонецЕсли;
	
	ЗаказНаДоставкуОбъект.Записать(РежимЗаписи);
	
КонецПроцедуры

&НаСервере
Процедура СвернутьДанныеДляОформления(ДанныеДляОформления)
	
	МетаданныеРеквизитыТЧ = Метаданные.Документы.ЗаказНаДоставку.ТабличныеЧасти.Товары.Реквизиты;
	КоличествоКолонок = ДанныеДляОформления.Колонки.Количество();
	Для ОбратныйИндекс = 1 По КоличествоКолонок Цикл
		
		Индекс = КоличествоКолонок - ОбратныйИндекс;
		ИмяКолонки = ДанныеДляОформления.Колонки[Индекс].Имя;
		Если МетаданныеРеквизитыТЧ.Найти(ИмяКолонки) = Неопределено Тогда
			ДанныеДляОформления.Колонки.Удалить(Индекс);
		КонецЕсли;
		
	КонецЦикла;
	
	КолонкиСуммирования = Новый Массив; // Массив Из Строка
	КолонкиСуммирования.Добавить(ДанныеДляОформления.Колонки.Количество.Имя);
	КолонкиСуммирования.Добавить(ДанныеДляОформления.Колонки.КоличествоУпаковок.Имя);
	
	КолонкиГруппировки = Новый Массив; // Массив Из Строка
	Для Каждого Колонка Из ДанныеДляОформления.Колонки Цикл
		
		Если КолонкиСуммирования.Найти(Колонка.Имя) = Неопределено Тогда
			КолонкиГруппировки.Добавить(Колонка.Имя);
		КонецЕсли;
		
	КонецЦикла;
	
	КолонкиГруппировкиСтрокой = СтрСоединить(КолонкиГруппировки, ",");
	КолонкиСуммированияСтрокой = СтрСоединить(КолонкиСуммирования, ",");
	
	ДанныеДляОформления.Свернуть(КолонкиГруппировкиСтрокой, КолонкиСуммированияСтрокой);
	
КонецПроцедуры

&НаСервере
Процедура ПодставитьВыраженияВесОбъем()
	
	ТекстЗапросаПоТоварам = СписокПоТоварам.ТекстЗапроса;
	ТекстЗапросаПоДокументам = СписокПоДокументам.ТекстЗапроса;
	
	ВыражениеВесУпаковки = Справочники.УпаковкиЕдиницыИзмерения.ТекстЗапросаВесУпаковки(
		"ДоставкаОбороты.Номенклатура.ЕдиницаИзмерения", "ДоставкаОбороты.Номенклатура", Ложь);
	ТекстЗапросаПоТоварам = СтрЗаменить(ТекстЗапросаПоТоварам, "&ВыражениеВесУпаковки", ВыражениеВесУпаковки);
	ТекстЗапросаПоДокументам = СтрЗаменить(ТекстЗапросаПоДокументам, "&ВыражениеВесУпаковки", ВыражениеВесУпаковки);
	
	ВыражениеОбъемУпаковки = Справочники.УпаковкиЕдиницыИзмерения.ТекстЗапросаОбъемУпаковки(
		"ДоставкаОбороты.Номенклатура.ЕдиницаИзмерения", "ДоставкаОбороты.Номенклатура", Ложь);
	ТекстЗапросаПоТоварам = СтрЗаменить(ТекстЗапросаПоТоварам, "&ВыражениеОбъемУпаковки", ВыражениеОбъемУпаковки);
	ТекстЗапросаПоДокументам = СтрЗаменить(ТекстЗапросаПоДокументам, "&ВыражениеОбъемУпаковки", ВыражениеОбъемУпаковки);
	
	СписокПоТоварам.ТекстЗапроса = ТекстЗапросаПоТоварам;
	СписокПоДокументам.ТекстЗапроса = ТекстЗапросаПоДокументам;
	
КонецПроцедуры

&НаКлиенте
Процедура СписокПоДокументамОбновитьДопПараметры()
	
	Если Элементы.СписокПоДокументам.ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ДанныеСтроки = Элементы.СписокПоДокументам.ТекущиеДанные; // См. ДанныеСтрокиСпискаДоставить
	ОбновитьДопПараметрыНаСервере(Элементы.СписокПоДокументам.Имя, ДанныеСтроки);
	
КонецПроцедуры

&НаКлиенте
Процедура СписокПоТоварамОбновитьДопПараметры()
	
	Если Элементы.СписокПоТоварам.ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ДанныеСтроки = Элементы.СписокПоТоварам.ТекущиеДанные; // См. ДанныеСтрокиСпискаДоставить
	ОбновитьДопПараметрыНаСервере(Элементы.СписокПоТоварам.Имя, ДанныеСтроки);
	
КонецПроцедуры

// Параметры:
//  ИмяЭлемента - Строка - 
//  ДанныеСтроки - См. ДанныеСтрокиСпискаДоставить
//
&НаСервере
Процедура ОбновитьДопПараметрыНаСервере(Знач ИмяЭлемента, Знач ДанныеСтроки)
	
	Если ИмяЭлемента = Элементы.СписокПоДокументам.Имя Тогда
		
		ЭтоСписокПоТоварам = Ложь;
		ПрефиксПолей = "СведенияПоДокументам";
		
	Иначе
		
		ЭтоСписокПоТоварам = Истина;
		ПрефиксПолей = "СведенияПоТоварам";
		
	КонецЕсли;
	
	ОтборПараметров = ОтборДетальныхОстатков(ЭтоСписокПоТоварам);
	ЗаполнитьЗначенияСвойств(ОтборПараметров, ДанныеСтроки);
	
	Распоряжение = ДанныеСтроки.Распоряжение;
	
	Если ТипЗнч(Распоряжение) = Тип("ДокументСсылка.ЗаказКлиента") Тогда
		
		СпособУказанияДоставки = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Распоряжение, "СпособУказанияДоставки");
		Если СпособУказанияДоставки = Перечисления.СпособыУказанияДоставки.НаВесьДокумент Тогда
			
			ДопПараметры = ДоставкаТоваров.ДополнительныеПараметрыИзШапкиДокумента(Распоряжение);
			
		Иначе
			
			ДокументыДоставки = ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(Распоряжение);
			ДопПараметры = ДоставкаТоваров.СовпадающиеДополнительныеПараметрыИзСтрокДокументов(
				ДокументыДоставки, ОтборПараметров, ЭтоСписокПоТоварам);
			
		КонецЕсли;
		
	Иначе
		
		ДопПараметры = ДоставкаТоваров.ДополнительныеПараметрыИзШапкиДокумента(Распоряжение);
		
	КонецЕсли;
	
	Для Каждого ЭлементДопПараметров Из ДопПараметры Цикл
		
		Если ЭлементДопПараметров.Ключ = "Совпадают" Тогда
			Продолжить;
		КонецЕсли;
		ИмяПоля = ПрефиксПолей + ЭлементДопПараметров.Ключ;
		ОбщегоНазначенияКлиентСервер.УстановитьРеквизитФормыПоПути(ЭтотОбъект, ИмяПоля, ЭлементДопПараметров.Значение);
		
	КонецЦикла;
	
	ЭлементыДопПараметров = Новый Массив; // Массив Из Строка
	
	Если ЭтоСписокПоТоварам Тогда
		
		НадписьОтличаютсяСведения = Элементы.НадписьОтличаютсяСведенияПоТоварам;
		
		ЭлементыДопПараметров.Добавить(Элементы.СведенияПоТоварамВремяДоставкиС.Имя);
		ЭлементыДопПараметров.Добавить(Элементы.СведенияПоТоварамВремяДоставкиПо.Имя);
		ЭлементыДопПараметров.Добавить(Элементы.СведенияПоТоварамДополнительнаяИнформацияПоДоставке.Имя);
		ЭлементыДопПараметров.Добавить(Элементы.СведенияПоТоварамОсобыеУсловияПеревозки.Имя);
		ЭлементыДопПараметров.Добавить(Элементы.СведенияПоТоварамОсобыеУсловияПеревозкиОписание.Имя);
		
	Иначе
		
		НадписьОтличаютсяСведения = Элементы.НадписьОтличаютсяСведенияПоДокументам;
		
		ЭлементыДопПараметров.Добавить(Элементы.СведенияПоДокументамВремяДоставкиС.Имя);
		ЭлементыДопПараметров.Добавить(Элементы.СведенияПоДокументамВремяДоставкиПо.Имя);
		ЭлементыДопПараметров.Добавить(Элементы.СведенияПоДокументамДополнительнаяИнформацияПоДоставке.Имя);
		ЭлементыДопПараметров.Добавить(Элементы.СведенияПоДокументамОсобыеУсловияПеревозки.Имя);
		ЭлементыДопПараметров.Добавить(Элементы.СведенияПоДокументамОсобыеУсловияПеревозкиОписание.Имя);
		
	КонецЕсли;
	
	Если ДопПараметры.Совпадают Тогда
		
		ОбщегоНазначенияУТКлиентСервер.УстановитьСвойствоЭлементовФормы(Элементы, ЭлементыДопПараметров, "Видимость", Истина);
		НадписьОтличаютсяСведения.Видимость = Ложь;
		
	Иначе
		
		ОбщегоНазначенияУТКлиентСервер.УстановитьСвойствоЭлементовФормы(Элементы, ЭлементыДопПараметров, "Видимость", Ложь);
		НадписьОтличаютсяСведения.Видимость = Истина;
		
	КонецЕсли;
	
КонецПроцедуры

#Область УсловноеОформление

&НаСервере
Процедура УстановитьУсловноеОформление()
	
	УсловноеОформление.Элементы.Очистить();
	
	УстановитьУсловноеОформлениеОстаткиНезаполненныйПеревозчик();
	УстановитьУсловноеОформлениеЗаказыНезаполненныйПеревозчик();
	УстановитьУсловноеОформлениеНезаполненнаяТочкаДоставки();
	УстановитьУсловноеОформлениеНезаполненнаяЗонаДоставки();
	УстановитьУсловноеОформлениеВесОбъемНеИспользуются();
	
КонецПроцедуры

&НаСервере
Процедура УстановитьУсловноеОформлениеОстаткиНезаполненныйПеревозчик()
	
	#Область СписокПоТоварамПеревозчик_Неприменимо
	Элемент = УсловноеОформление.Элементы.Добавить();
	
	ПолеЭлемента = Элемент.Поля.Элементы.Добавить();
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(Элементы.СписокПоТоварамПеревозчик.Имя);
	
	ОтборЭлемента = Элемент.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ОтборЭлемента.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("СписокПоТоварам.Перевозчик");
	ОтборЭлемента.ВидСравнения = ВидСравненияКомпоновкиДанных.НеЗаполнено;
	
	ОтборЭлемента = Элемент.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ОтборЭлемента.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("СписокПоТоварам.СпособДоставки");
	ОтборЭлемента.ВидСравнения = ВидСравненияКомпоновкиДанных.НеРавно;
	ОтборЭлемента.ПравоеЗначение = Перечисления.СпособыДоставки25.СиламиПеревозчика;
	
	Элемент.Оформление.УстановитьЗначениеПараметра("ЦветТекста", ЦветаСтиля.ЦветТекстаОтмененнойСтрокиДокумента);
	Элемент.Оформление.УстановитьЗначениеПараметра("Текст", НСтр("ru = '<неприменимо>'"));
	#КонецОбласти
	
	#Область СписокПоДокументамПеревозчик_Неприменимо
