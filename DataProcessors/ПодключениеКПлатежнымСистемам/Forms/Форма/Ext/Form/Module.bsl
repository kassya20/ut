		НавигационнаяСсылкаФорматированнойСтроки,
		СтандартнаяОбработка);
	
КонецПроцедуры

&НаКлиенте
Процедура ПарольИПППриИзменении(Элемент)
	
	ИнтернетПоддержкаПользователейКлиент.ПриИзмененииСекретныхДанных(Элемент);
	
КонецПроцедуры

&НаКлиенте
Процедура ПарольИППНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	ИнтернетПоддержкаПользователейКлиент.ОтобразитьСекретныеДанные(
		ЭтотОбъект,
		Элемент,
		"ПарольИПП");
	
КонецПроцедуры

&НаКлиенте
Процедура ДекорацияПользовательскоеСоглашениеОбработкаНавигационнойСсылки(
	Элемент,
	НавигационнаяСсылкаФорматированнойСтроки,
	СтандартнаяОбработка)
	
	ПлатежныеСистемыКлиентСобытия.ПриОбработкеНавигационнойСсылки(
		НавигационнаяСсылкаФорматированнойСтроки,
		СтандартнаяОбработка);
	
КонецПроцедуры

&НаКлиенте
Процедура Подключаемый_ПриИзмененииДанныхАутентификации(Элемент)
	
	ЭтотОбъект[Элемент.Имя] = НастройкиПлатежныхСистемКлиентСервер.УдалитьНечитаемыеСимволы(
		ЭтотОбъект[Элемент.Имя]);
	
КонецПроцедуры

&НаКлиенте
Процедура Подключаемый_ПриИзмененииСекретныхДанных(Элемент)
	
	ЭтотОбъект[Элемент.Имя] = НастройкиПлатежныхСистемКлиентСервер.УдалитьНечитаемыеСимволы(
		ЭтотОбъект[Элемент.Имя]);
	ИнтернетПоддержкаПользователейКлиент.ПриИзмененииСекретныхДанных(Элемент);
	
КонецПроцедуры

&НаКлиенте
Процедура Подключаемый_НачалоВыбораСекретныхДанных(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	ИнтернетПоддержкаПользователейКлиент.ОтобразитьСекретныеДанные(
		ЭтотОбъект,
		Элемент,
		Элемент.Имя);
	
КонецПроцедуры

&НаКлиенте
Процедура Подключаемый_ПриИзмененииНастройкиОплаты(Элемент)
	
	ПриИзмененииНастройкиОплатыНаСервере();
	
КонецПроцедуры

&НаКлиенте
Процедура ДекорацияОписаниеРезультатаОбработкаНавигационнойСсылки(
	Элемент,
	НавигационнаяСсылкаФорматированнойСтроки,
	СтандартнаяОбработка)
	
	ПлатежныеСистемыКлиентСобытия.ПриОбработкеНавигационнойСсылки(
		НавигационнаяСсылкаФорматированнойСтроки,
		СтандартнаяОбработка,
		НастройкаПодключения);
	
КонецПроцедуры

&НаКлиенте
Процедура ДекорацияОписаниеОбработкаНавигационнойСсылки(
		Элемент,
		НавигационнаяСсылкаФорматированнойСтроки,
		СтандартнаяОбработка)
	
	ПлатежныеСистемыКлиентСобытия.ПриОбработкеНавигационнойСсылки(
		НавигационнаяСсылкаФорматированнойСтроки,
		СтандартнаяОбработка);
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура Далее(Команда)
	
	Отказ = Ложь;
	Если Элементы.ГруппаСтраницы.ТекущаяСтраница = Элементы.ГруппаОписаниеСервиса Тогда
		
		ДобавитьСтраницуВИсторию();
		Если Не ЗаполненыДанныеАутентификации Тогда
			Элементы.ГруппаСтраницы.ТекущаяСтраница = Элементы.ГруппаПодключениеИПП;
		Иначе
			Элементы.ГруппаСтраницы.ТекущаяСтраница = Элементы.ГруппаНастройкиПлатежнойСистемы;
		КонецЕсли;
		
	ИначеЕсли Элементы.ГруппаСтраницы.ТекущаяСтраница = Элементы.ГруппаПодключениеИПП Тогда
		
		РезультатПроверки = ИнтернетПоддержкаПользователейКлиентСервер.ПроверитьДанныеАутентификации(
			Новый Структура("Логин,Пароль", ЛогинИПП, ПарольИПП));
		
		Если РезультатПроверки.Отказ Тогда
			ОбщегоНазначенияКлиент.СообщитьПользователю(
				РезультатПроверки.СообщениеОбОшибке,
				,
				РезультатПроверки.Поле + "ИПП",
				,
				Отказ);
		Иначе
			Отказ = ПроверитьПодключениеИПП(ЛогинИПП, ПарольИПП);
		КонецЕсли;
		
		Если Отказ Тогда
			Возврат;
		КонецЕсли;
		
		ЛогинИПП = "";
		ПарольИПП = "";
		ЗаполненыДанныеАутентификации = Истина;
		
		Элементы.ГруппаСтраницы.ТекущаяСтраница = Элементы.ГруппаНастройкиПлатежнойСистемы;
		
	ИначеЕсли Элементы.ГруппаСтраницы.ТекущаяСтраница = Элементы.ГруппаНастройкиПлатежнойСистемы Тогда
		
		РезультатПроверки = ПроверитьПодключениеПлатежнойСистемы();
		Если РезультатПроверки.Ошибка Тогда
			Возврат;
		КонецЕсли;
		
		Если РезультатПроверки.ДлительнаяОперация.Статус = "Выполнено"
			Или РезультатПроверки.ДлительнаяОперация.Статус = "Ошибка" Тогда
			
			ПроверитьПодключениеПлатежнойСистемыЗавершение(РезультатПроверки.ДлительнаяОперация, Неопределено);
			
		Иначе
			
			Элементы.ГруппаСтраницы.ТекущаяСтраница = Элементы.ГруппаДлительнаяОперация;
			Элементы.ДекорацияСостояние.Заголовок   =
				НСтр("ru = 'Проверка параметров подключения к платежной системе.'");
			
			ОповещениеОЗавершении = Новый ОписаниеОповещения(
				"ПроверитьПодключениеПлатежнойСистемыЗавершение",
				ЭтотОбъект);
			
			ПараметрыОжидания = ДлительныеОперацииКлиент.ПараметрыОжидания(ЭтотОбъект);
			ПараметрыОжидания.ВыводитьОкноОжидания = Ложь;
			
			ДлительныеОперацииКлиент.ОжидатьЗавершение(
				РезультатПроверки.ДлительнаяОперация,
				ОповещениеОЗавершении,
				ПараметрыОжидания);
			
		КонецЕсли;
		
	ИначеЕсли Элементы.ГруппаСтраницы.ТекущаяСтраница = Элементы.ГруппаПрикладныеНастройки Тогда
		
		ДобавитьСтраницуВИсторию();
		
		Если Не ЗначениеЗаполнено(Наименование) Тогда
			ОбщегоНазначенияКлиент.СообщитьПользователю(
				НСтр("ru = 'Не заполнено поле ""Наименование"".'"),
				,
				,
				"Наименование");
			Возврат;
		КонецЕсли;
		
		Если НоваяНастройкаПодключения() Тогда
			ПодключениеЗавершено = Истина;
			ОповеститьОЗаписиНового(НастройкаПодключения);
			ПроверитьНеобходимостьПривязкиОнлайнЗаказов();
		КонецЕсли;
	
	ИначеЕсли Элементы.ГруппаСтраницы.ТекущаяСтраница = Элементы.ГруппаОнлайнЗаказы Тогда
		
		ОбработатьПривязкуКОнлайнЗаказам();
		
	ИначеЕсли Элементы.ГруппаСтраницы.ТекущаяСтраница = Элементы.ГруппаРезультат Тогда
		Если РежимРаботы = НастройкиПлатежныхСистемКлиентСервер.ИдентификаторОперацииСозданиеНастройкиОнлайнЗаказы() Тогда
			Закрыть(НастройкаПодключения);
		Иначе
			Закрыть(Истина);
		КонецЕсли;
	КонецЕсли;
	
	УправлениеФормой(ЭтотОбъект);
	
КонецПроцедуры

&НаКлиенте
Процедура Назад(Команда)
	
	Массив = Новый Массив(ИсторияСтраниц);
	Индекс = Массив.ВГраница();
	
	Элементы.ГруппаСтраницы.ТекущаяСтраница = Элементы[Массив[Индекс]];
	
	Массив.Удалить(Индекс);
	
	ИсторияСтраниц = Новый ФиксированныйМассив(Массив);
	
	УправлениеФормой(ЭтотОбъект);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

#Область ОбщегоНазначения

&НаКлиентеНаСервереБезКонтекста
Процедура УправлениеФормой(Форма)
	
	Элементы = Форма.Элементы;
	
	Элементы.Назад.Видимость  = (Форма.ИсторияСтраниц.Количество() > 0);
	Элементы.Далее.Видимость  = Истина;
	Элементы.Далее.Заголовок  = "";
	Если Элементы.ГруппаСтраницы.ТекущаяСтраница = Элементы.ГруппаДлительнаяОперация Тогда
		Элементы.Назад.Видимость = Ложь;
		Элементы.Далее.Видимость = Ложь;
	ИначеЕсли Элементы.ГруппаСтраницы.ТекущаяСтраница = Элементы.ГруппаОнлайнЗаказы Тогда
		Элементы.Назад.Видимость = Ложь;
	ИначеЕсли Элементы.ГруппаСтраницы.ТекущаяСтраница = Элементы.ГруппаРезультат Тогда
		Если Форма.ПодключениеЗавершено Тогда
			Элементы.Далее.Заголовок  = НСтр("ru = 'Завершить'");
			Элементы.Назад.Видимость  = Ложь;
		Иначе
			Элементы.Далее.Видимость = Ложь;
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Процедура ОтобразитьИнформациюОбОшибке(
	Форма,
	ИнформацияОбОшибке,
	Ошибка = Истина,
	ОтобразитьЖурнал = Истина)
	
	Элементы = Форма.Элементы;
	
	Если ОтобразитьЖурнал Тогда
		
		ТекстСообщения = НСтр("ru = '%1
			|
			|
			|Подробную информацию см. в <a href = ""open:Log"">Журнале регистрации</a>.'");
		
		#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда
			ПредставлениеОшибки = СтроковыеФункции.ФорматированнаяСтрока(ТекстСообщения, ИнформацияОбОшибке);
		#Иначе
			ПредставлениеОшибки = СтроковыеФункцииКлиент.ФорматированнаяСтрока(ТекстСообщения, ИнформацияОбОшибке);
		#КонецЕсли
		
	Иначе
		ПредставлениеОшибки = ИнформацияОбОшибке;
	КонецЕсли;
	
	Элементы.ГруппаСтраницы.ТекущаяСтраница = Элементы.ГруппаРезультат;
	Элементы.ДекорацияОписаниеРезультата.Заголовок = ПредставлениеОшибки;
	Элементы.ДекорацияКартинкаРезультат.Картинка = ?(Ошибка,
		БиблиотекаКартинок.Ошибка32,
		БиблиотекаКартинок.Предупреждение32);
	
	УправлениеФормой(Форма);
	
КонецПроцедуры

&НаСервере
Процедура ОтобразитьИнформациюОбУспешномЗавершении()
	
	Элементы.ГруппаСтраницы.ТекущаяСтраница = Элементы.ГруппаРезультат;
	Элементы.ДекорацияКартинкаРезультат.Картинка = БиблиотекаКартинок.Успешно32;
	Элементы.ДекорацияОписаниеРезультата.Заголовок = НСтр("ru = 'Настройка подключения создана.'");

КонецПроцедуры

&НаСервере
Процедура ПроверитьНеобходимостьПривязкиОнлайнЗаказов()
	
	Если Параметры.НеПредлагатьПодключениеКОнлайнЗаказам
		Или РежимРаботы = НастройкиПлатежныхСистемКлиентСервер.ИдентификаторОперацииСозданиеНастройкиОнлайнЗаказы() Тогда
		ОтобразитьИнформациюОбУспешномЗавершении();
		Возврат;
	КонецЕсли;
	
	ОнлайнЗаказыВариант = "";
	ОнлайнЗаказыПодключить = Ложь;
	
	ТребуетсяПривязка = Ложь;
	
	НастройкиПлатежныхСистемСобытия.ПриОпределенииНеобходимостиПривязкиКОнлайнЗаказам(
		ПлатежнаяСистема,
		ТребуетсяПривязка);
		
	Если Не ТребуетсяПривязка Тогда
		ОтобразитьИнформациюОбУспешномЗавершении();
		Возврат;
	КонецЕсли;
	
	ОнлайнЗаказыОрганизация = ОрганизацияНастройки();
	Если Не ЗначениеЗаполнено(ОнлайнЗаказыОрганизация) Тогда
		// Не удалось определить организацию. Автоматическое создание настройки невозможно.
		ОтобразитьИнформациюОбУспешномЗавершении();
		Возврат;
	Иначе
		МодульНастройкиПодключенияКОнлайнЗаказам = ОбщегоНазначения.ОбщийМодуль(
			"Справочники.НастройкиПодключенияКОнлайнЗаказам");
		НастройкиОрганизации = МодульНастройкиПодключенияКОнлайнЗаказам.НастройкиОрганизации(
			ОнлайнЗаказыОрганизация);
		Если НастройкиОрганизации.ИспользуемыеНастройки.Количество() = 0 Тогда
			ОнлайнЗаказыВариант = "Новый";
			ТекстЗаголовка = НСтр("ru = 'Создать новую настройку подключения к Онлайн-заказам'");
		Иначе
			ОнлайнЗаказыНастройка = НастройкиОрганизации.ИспользуемыеНастройки[0];
			ОнлайнЗаказыВариант = "Существующий";
			ПредставлениеСсылки = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(
				ОнлайнЗаказыНастройка,
				"Представление");
			Если СтрДлина(ПредставлениеСсылки) > 30 Тогда
				ПредставлениеСсылки = Лев(ПредставлениеСсылки, 30) + "...";
			КонецЕсли;
			
			ТекстЗаголовка = СтроковыеФункции.ФорматированнаяСтрока(
				НСтр("ru = 'Подключить к настройке Онлайн-заказов <a href=""%1"">%2</a>'"),
				ПолучитьНавигационнуюСсылку(ОнлайнЗаказыНастройка),
				ПредставлениеСсылки);
		КонецЕсли;
		ОнлайнЗаказыПодключить = Истина;
		Элементы.ДекорацияОнлайнЗаказыЗаголовок.Заголовок = ТекстЗаголовка;
	КонецЕсли;
	
	Элементы.ГруппаСтраницы.ТекущаяСтраница = Элементы.ГруппаОнлайнЗаказы;
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработатьПривязкуКОнлайнЗаказам()
	
	Если ОнлайнЗаказыВариант = "" Тогда // нет организации
		ОтобразитьИнформациюОбУспешномЗавершении();
		Возврат;
	КонецЕсли;
	
	Если Не ОнлайнЗаказыПодключить Тогда // Пользователь снял галку
		ОтобразитьИнформациюОбУспешномЗавершении();
		Возврат;
	КонецЕсли; 
		
	Если ОнлайнЗаказыВариант = "Существующий" Тогда // Привязать к существующей
		ПривязатьНастройкуОнлайнЗаказы();
		
	ИначеЕсли ОнлайнЗаказыВариант = "Новый" Тогда // Создать новую
		СоздатьНастройкуОнлайнЗаказы();
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ДобавитьСтраницуВИсторию(ТекущаяСтраница = Неопределено)
	
	ИмяСтраницы = ?(ТекущаяСтраница = Неопределено, Элементы.ГруппаСтраницы.ТекущаяСтраница, ТекущаяСтраница).Имя;
	
	Массив = Новый Массив(ИсторияСтраниц);
	Массив.Добавить(ИмяСтраницы);
	
	ИсторияСтраниц = Новый ФиксированныйМассив(Массив);
	
КонецПроцедуры

&НаСервере
Функция НоваяНастройкаПодключения()
	
	Отказ = Ложь;
	ПлатежныеСистемыСлужебный.ПроверитьНастройкиОплаты(
		ЭтотОбъект,
		Отказ);
	
	Если Отказ Тогда
		Возврат Ложь;
	КонецЕсли;
	
	ПараметрыЗаполнения = Новый Структура;
	ПараметрыЗаполнения.Вставить("Наименование", Наименование);
	ПараметрыЗаполнения.Вставить("ПлатежнаяСистема", ПлатежнаяСистема);
	
	ПараметрыАутентификации = ПлатежныеСистемыСлужебный.НастройкиАутентификацииПоДаннымФормы(ЭтотОбъект);
	ПараметрыОплаты = ПлатежныеСистемыСлужебный.НастройкиОплатыПоДаннымФормы(ЭтотОбъект);
	
	Результат = Справочники.НастройкиПодключенияКПлатежнымСистемам.НоваяНастройкаПодключения(
		ПараметрыЗаполнения,
		ПараметрыАутентификации,
		ПараметрыОплаты);
	Если Результат.Ошибка Тогда
		ОтобразитьИнформациюОбОшибке(ЭтотОбъект, Результат.СообщениеОбОшибке, Истина, Ложь);
	Иначе
		НастройкаПодключения = Результат.Ссылка;
	КонецЕсли;
	
	Возврат Не Результат.Ошибка;
	
КонецФункции

&НаСервере
Процедура ЗаполнитьОписаниеПлатежнойСистемы()
	
	ПараметрыСистем = НастройкиПлатежныхСистемПовтИсп.ОписаниеПлатежныхСервисов();
	ОписаниеСистемы = Неопределено;
	
	Если ПлатежнаяСистема = Перечисления.ПлатежныеСервисы.ОзонПэй Тогда
		ОписаниеСистемы = ПараметрыСистем.Получить(
			НастройкиПлатежныхСистемКлиентСервер.ИмяПодсистемыОзонПэй());
		Элементы.ДекорацияЛоготип.РазмерКартинки = РазмерКартинки.Пропорционально;
	КонецЕсли;
	
	Если ОписаниеСистемы <> Неопределено Тогда
		Заголовок = ОписаниеСистемы.ЗаголовокПодключения;
		Элементы.ДекорацияОписание.Заголовок = ОписаниеСистемы.Описание;
		Элементы.ДекорацияПодсказка.Заголовок = ОписаниеСистемы.Подключение;
		ИмяЛоготип = ОписаниеСистемы.Логотип;
		Если ПустаяСтрока(ИмяЛоготип) Тогда
			ИмяЛоготип = ОписаниеСистемы.Картинка;
		КонецЕсли;
		Попытка
			Элементы.ДекорацияЛоготип.Картинка = БиблиотекаКартинок[ИмяЛоготип];
		Исключение
			Элементы.ДекорацияЛоготип.Картинка = Неопределено;
		КонецПопытки;
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область НастройкиАутентификации

&НаКлиенте
Процедура ПолучитьПараметрыПодсказки()
	
	ДлительнаяОперация = ПодсказкиПлатежнойСистемыВФоне(ПлатежнаяСистема, УникальныйИдентификатор);
	Если ДлительнаяОперация.Статус = "Выполняется" Тогда
		
		ОповещениеОЗавершении = Новый ОписаниеОповещения("ПолучитьПараметрыПодсказкиЗавершение", ЭтотОбъект);
		
		ПараметрыОжидания = ДлительныеОперацииКлиент.ПараметрыОжидания(ЭтотОбъект);
		ПараметрыОжидания.ВыводитьОкноОжидания = Ложь;
		
		ДлительныеОперацииКлиент.ОжидатьЗавершение(ДлительнаяОперация, ОповещениеОЗавершении, ПараметрыОжидания);
		
	Иначе
		ПолучитьПараметрыПодсказкиЗавершение(ДлительнаяОперация, Неопределено);
	КонецЕсли;
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ПодсказкиПлатежнойСистемыВФоне(Знач ПлатежнаяСистема, Знач ИдентификаторФормы)
	
	ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияФункции(ИдентификаторФормы);
	ПараметрыВыполнения.НаименованиеФоновогоЗадания = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
		НСтр("ru = 'Получение описания платежной системы %1'"),
		Строка(ПлатежнаяСистема));
	
	Возврат ДлительныеОперации.ВыполнитьФункцию(
		ПараметрыВыполнения,
		"ПлатежныеСистемыСлужебный.ПодсказкиПлатежнойСистемы",
		ПлатежнаяСистема);
	
КонецФункции

&НаКлиенте
Процедура ПолучитьПараметрыПодсказкиЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	ИначеЕсли Результат.Статус = "Выполнено" Тогда
		
		// см. ПлатежныеСистемыСлужебный.ПодсказкиПлатежнойСистемы.
		РезультатОперации = ПолучитьИзВременногоХранилища(Результат.АдресРезультата);
		Если ПустаяСтрока(РезультатОперации.КодОшибки) Тогда
			Элементы.ДекорацияПодсказка.Заголовок = РезультатОперации.Подключение;
			Элементы.ДекорацияОписание.Заголовок  = РезультатОперации.Описание;
		КонецЕсли;
		
		УдалитьИзВременногоХранилища(Результат.АдресРезультата);
		
	КонецЕсли;

	Если ОтображатьОписаниеСервиса Тогда
		Элементы.ГруппаСтраницы.ТекущаяСтраница = Элементы.ГруппаОписаниеСервиса;
	ИначеЕсли Не ЗаполненыДанныеАутентификации Тогда
		Элементы.ГруппаСтраницы.ТекущаяСтраница = Элементы.ГруппаПодключениеИПП;
	Иначе
		Элементы.ГруппаСтраницы.ТекущаяСтраница = Элементы.ГруппаНастройкиПлатежнойСистемы;
	КонецЕсли;
	
	УправлениеФормой(ЭтотОбъект);
	
КонецПроцедуры

#КонецОбласти

#Область Подключение

&НаСервереБезКонтекста
Функция ПроверитьПодключениеИПП(Знач Логин, Знач Пароль)
	
	Отказ = Ложь;
	
	РезультатПроверки = ИнтернетПоддержкаПользователей.ПроверитьЛогинИПароль(Логин, Пароль);
	Если РезультатПроверки.Результат Тогда
		
		ДанныеАутентификации = Новый Структура();
		ДанныеАутентификации.Вставить("Логин" , Логин);
		ДанныеАутентификации.Вставить("Пароль", Пароль);
		
		УстановитьПривилегированныйРежим(Истина);
		ИнтернетПоддержкаПользователей.СохранитьДанныеАутентификации(ДанныеАутентификации);
		УстановитьПривилегированныйРежим(Ложь);
		
	Иначе
		ОбщегоНазначения.СообщитьПользователю(
			РезультатПроверки.СообщениеОбОшибке,
			,
			,
			,
			Отказ);
	КонецЕсли;
	
	Возврат Отказ;
	
КонецФункции

&НаСервере
Функция ПроверитьПодключениеПлатежнойСистемы()
	
	ДлительнаяОперация = Неопределено; // Неопределено, см. ДлительныеОперации.ВыполнитьФункцию
	
	Результат = Новый Структура();
	Результат.Вставить("ДлительнаяОперация", ДлительнаяОперация);
	Результат.Вставить("Ошибка" , Ложь);
	
	ПлатежныеСистемыСлужебный.ПроверитьДанныеАутентификации(ЭтотОбъект, Результат.Ошибка);
	Если Результат.Ошибка Тогда
		Возврат Результат;
	КонецЕсли;
	
	ДанныеАутентификации = ПлатежныеСистемыСлужебный.НастройкиАутентификацииПоДаннымФормы(ЭтотОбъект);
	
	ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияВФоне(УникальныйИдентификатор);
	ПараметрыВыполнения.НаименованиеФоновогоЗадания =
		НСтр("ru = 'Проверка параметров подключения к платежной системе.'");
	
	Результат.ДлительнаяОперация = ДлительныеОперации.ВыполнитьФункцию(
		ПараметрыВыполнения,
		"ПлатежныеСистемыСлужебный.ПроверитьПараметрыПодключенияНового",
		ПлатежнаяСистема,
		ДанныеАутентификации);
	
	Возврат Результат;
	
КонецФункции

&НаКлиенте
Процедура ПроверитьПодключениеПлатежнойСистемыЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если Результат.Статус = "Выполнено" Тогда
		
		РезультатОперации = ПолучитьИзВременногоХранилища(Результат.АдресРезультата);
		Если ЗначениеЗаполнено(РезультатОперации.КодОшибки) Тогда
			Элементы.ГруппаСтраницы.ТекущаяСтраница = Элементы.ГруппаНастройкиПлатежнойСистемы;
			ПоказатьПредупреждение(, РезультатОперации.СообщениеОбОшибке);
		Иначе
			Если Не ЗаполненыНастройкиОплаты Тогда
				ЗаполнитьНастройкиОплаты();
			КонецЕсли;
			ДобавитьСтраницуВИсторию(Элементы.ГруппаНастройкиПлатежнойСистемы);
			Элементы.ГруппаСтраницы.ТекущаяСтраница = Элементы.ГруппаПрикладныеНастройки;
		КонецЕсли;
		
		УдалитьИзВременногоХранилища(Результат.АдресРезультата);
		
	ИначеЕсли Результат.Статус = "Ошибка" Тогда
		Элементы.ГруппаСтраницы.ТекущаяСтраница = Элементы.ГруппаНастройкиПлатежнойСистемы;
		ПоказатьПредупреждение(, Результат.КраткоеПредставлениеОшибки);
	КонецЕсли;
	
	УправлениеФормой(ЭтотОбъект);
	
КонецПроцедуры

#КонецОбласти

#Область НастройкиОплаты

&НаСервере
Процедура ЗаполнитьНастройкиОплаты()
	
	ПлатежныеСистемыСлужебный.ЗаполнитьНастройкиОплатыНового(
		ЭтотОбъект,
		ПлатежнаяСистема,
		ДополнительныеПараметры);
	
	ЗаполненыНастройкиОплаты = Истина;
	
КонецПроцедуры

&НаСервере
Процедура ПриИзмененииНастройкиОплатыНаСервере()
	
	ПлатежныеСистемыСлужебный.НастроитьЭлементыФормыПодключения(
		ЭтотОбъект,
		ПлатежнаяСистема,
		Неопределено,
		ДополнительныеПараметры);
	
КонецПроцедуры

#КонецОбласти

#Область ОнлайнЗаказы

&НаСервере
Функция ОрганизацияНастройки()
	
	ПоискОрганизации = Неопределено;
	ОтключитьЛогикуБИП = Ложь;
	
	ПараметрыОплаты = ПлатежныеСистемыСлужебный.НастройкиОплатыПоДаннымФормы(ЭтотОбъект);
	
	ИнтеграцияПодсистемБИП.ПриОпределенииОрганизацииПлатежныхСистем(
		ПлатежнаяСистема,
		ПоискОрганизации,
		ПараметрыОплаты,
		ОтключитьЛогикуБИП);
	ПлатежныеСистемыПереопределяемый.ПриОпределенииОрганизации(
		ПлатежнаяСистема,
		ПоискОрганизации,
		ПараметрыОплаты,
		ОтключитьЛогикуБИП);
	
	Если Не ЗначениеЗаполнено(ПоискОрганизации) И Не ОтключитьЛогикуБИП Тогда
		ПоискОрганизации = НастройкиПлатежныхСистемСлужебный.ОпределитьОрганизациюПоНастройкам(
			ПараметрыОплаты);
	КонецЕсли;
	
	Возврат ПоискОрганизации;
	
КонецФункции

&НаКлиенте
Процедура ПривязатьНастройкуОнлайнЗаказы()
	
	Если ОнлайнЗаказыНастройка = Неопределено Тогда
		ОтобразитьИнформациюОбУспешномЗавершении();
		Возврат;
	КонецЕсли;
	
	ДлительнаяОперация = ПривязатьНастройкуОнлайнЗаказыВФоне();
	
	Если ДлительнаяОперация.Статус = "Выполнено"
		Или ДлительнаяОперация.Статус = "Ошибка" Тогда
		
		ПривязатьНастройкуОнлайнЗаказыЗавершение(ДлительнаяОперация, Неопределено);
		
	Иначе
		
		Элементы.ГруппаСтраницы.ТекущаяСтраница = Элементы.ГруппаДлительнаяОперация;
		Элементы.ДекорацияСостояние.Заголовок   =
			НСтр("ru = 'Привязка к настройке подключения к Онлайн-заказам.'");
		
		ОповещениеОЗавершении = Новый ОписаниеОповещения(
			"ПривязатьНастройкуОнлайнЗаказыЗавершение",
			ЭтотОбъект);
		
		ПараметрыОжидания = ДлительныеОперацииКлиент.ПараметрыОжидания(ЭтотОбъект);
		ПараметрыОжидания.ВыводитьОкноОжидания = Ложь;
		
		ДлительныеОперацииКлиент.ОжидатьЗавершение(
			ДлительнаяОперация,
			ОповещениеОЗавершении,
			ПараметрыОжидания);
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция ПривязатьНастройкуОнлайнЗаказыВФоне()
	
	ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияВФоне(УникальныйИдентификатор);
	ПараметрыВыполнения.НаименованиеФоновогоЗадания =
		НСтр("ru = 'Привязка платежной системы к настройке Онлайн-заказов.'");
	
	Возврат ДлительныеОперации.ВыполнитьФункцию(
		ПараметрыВыполнения,
		"ОнлайнЗаказыСлужебный.ПривязатьНастройкуПлатежнойСистемы",
		ОнлайнЗаказыНастройка,
		НастройкаПодключения);
	
КонецФункции

&НаКлиенте
Процедура ПривязатьНастройкуОнлайнЗаказыЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если Результат.Статус = "Выполнено" Тогда
		
		РезультатОперации = ПолучитьИзВременногоХранилища(Результат.АдресРезультата); // см. ОнлайнЗаказыСлужебный.ПривязатьНастройкуПлатежнойСистемы
		Если ЗначениеЗаполнено(РезультатОперации.КодОшибки) Тогда
		
			ЗаписатьИнформациюВЖурналРегистрации(
				РезультатОперации.СообщениеОбОшибке,
				Истина);
			
			ТекстПредупреждения = НСтр("ru = 'Настройка подключения создана.
				|
				|Не удалось привязать настройку к подключению к Онлайн-заказам.'");
				
			ОтобразитьИнформациюОбОшибке(
				ЭтотОбъект,
				ТекстПредупреждения,
				Ложь);
			
		Иначе
			ОтобразитьИнформациюОбУспешномЗавершении();
		КонецЕсли;
		
		УдалитьИзВременногоХранилища(Результат.АдресРезультата);
		
	ИначеЕсли Результат.Статус = "Ошибка" Тогда
		
		ТекстПредупреждения = НСтр("ru = 'Настройка подключения создана.
			|
			|Не удалось привязать настройку к подключению к Онлайн-заказам.'");
			
		ОтобразитьИнформациюОбОшибке(
			ЭтотОбъект,
			ТекстПредупреждения,
			Ложь);

	КонецЕсли;
	
	УправлениеФормой(ЭтотОбъект);
	
КонецПроцедуры

&НаКлиенте
Процедура СоздатьНастройкуОнлайнЗаказы()
	
	НастройкиОплат = Новый Соответствие;
	МодульОнлайнЗаказыКлиент = ОбщегоНазначенияКлиент.ОбщийМодуль("ОнлайнЗаказыКлиент");
	Если ПлатежнаяСистема = ПредопределенноеЗначение("Перечисление.ПлатежныеСервисы.ОзонПэй") Тогда
		НастройкиОплат.Вставить(
			МодульОнлайнЗаказыКлиент.СпособОплатыОзонПэй(),
			НастройкаПодключения);
	КонецЕсли;

	Если НастройкиОплат.Количество() = 0 Тогда
		ТекстПредупреждения = НСтр("ru = 'Настройка подключения создана.
			|
			|Не удалось создать настройку подключения к Онлайн-заказам.'");
		
		ОтобразитьИнформациюОбОшибке(
			ЭтотОбъект,
			ТекстПредупреждения,
			Ложь);
		
		ТекстДляЖурнала = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
			НСтр("ru = 'Не удалось определить платежную систему для создания настройки подключения к Онлайн-заказам: %1'"),
			Строка(ПлатежнаяСистема));
		
		ЗаписатьИнформациюВЖурналРегистрации(
			ТекстДляЖурнала,
			Истина);
		
		Возврат;
		
	КонецЕсли;
	
	ДлительнаяОперация = СоздатьНастройкуОнлайнЗаказыВФоне(НастройкиОплат);
	
	Если ДлительнаяОперация.Статус = "Выполнено"
		Или ДлительнаяОперация.Статус = "Ошибка" Тогда
		
		СоздатьНастройкуОнлайнЗаказыЗавершение(ДлительнаяОперация, Неопределено);
		
	Иначе
		
		Элементы.ГруппаСтраницы.ТекущаяСтраница = Элементы.ГруппаДлительнаяОперация;
		Элементы.ДекорацияСостояние.Заголовок   =
			НСтр("ru = 'Создание новой настройки подключения к Онлайн-заказам.'");
		
		ОповещениеОЗавершении = Новый ОписаниеОповещения(
			"СоздатьНастройкуОнлайнЗаказыЗавершение",
			ЭтотОбъект);
		
		ПараметрыОжидания = ДлительныеОперацииКлиент.ПараметрыОжидания(ЭтотОбъект);
		ПараметрыОжидания.ВыводитьОкноОжидания = Ложь;
		
		ДлительныеОперацииКлиент.ОжидатьЗавершение(
			ДлительнаяОперация,
			ОповещениеОЗавершении,
			ПараметрыОжидания);
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция СоздатьНастройкуОнлайнЗаказыВФоне(Знач НастройкиОплат)

	ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияВФоне(УникальныйИдентификатор);
	ПараметрыВыполнения.НаименованиеФоновогоЗадания =
		НСтр("ru = 'Создание новой настройки подключения к Онлайн-заказам.'");
	
	Возврат ДлительныеОперации.ВыполнитьФункцию(
		ПараметрыВыполнения,
		"Справочники.НастройкиПодключенияКОнлайнЗаказам.НоваяНастройкаПодключения",
		ОнлайнЗаказыОрганизация,
		НастройкиОплат,
		"");

КонецФункции

&НаКлиенте
Процедура СоздатьНастройкуОнлайнЗаказыЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если Результат.Статус = "Ошибка" Тогда
		
		ТекстДляЖурнала = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
				НСтр("ru = 'Не удалось создать настройку подключения к Онлайн-заказам:
					|
					|%1'"),
				ОбработкаОшибок.ПодробноеПредставлениеОшибки(Результат.ИнформацияОбОшибке));
		
		ТекстПредупреждения = НСтр("ru = 'Настройка подключения создана.
			|
			|Не удалось создать настройку подключения к Онлайн-заказам.'");
			
		ОтобразитьИнформациюОбОшибке(
			ЭтотОбъект,
			ТекстПредупреждения,
			Ложь);
		
	ИначеЕсли Результат.Статус = "Выполнено" Тогда
		
		// см. Справочники.НастройкиПодключенияКОнлайнЗаказам.НоваяНастройкаПодключения.
		РезультатОперации = ПолучитьИзВременногоХранилища(Результат.АдресРезультата);

		Если РезультатОперации.ОшибкаОтправкиВСервис Тогда
			
			ТекстДляЖурнала = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
				НСтр("ru = 'Не удалось отправить информацию по настройке подключения к Онлайн-заказам в сервис:
					|
					|%1'"),
				РезультатОперации.СообщениеОбОшибке);
			
			ЗаписатьИнформациюВЖурналРегистрации(
				ТекстДляЖурнала,
				Истина);
			
			ТекстПредупреждения = НСтр("ru = 'Настройка подключения создана.
				|
				|отправить информацию по настройке подключения к Онлайн-заказам в сервис.'");
			
			ОтобразитьИнформациюОбОшибке(
				ЭтотОбъект,
				ТекстПредупреждения,
				Ложь);
		Иначе
			ОтобразитьИнформациюОбУспешномЗавершении();
			ОповеститьОбИзменении(РезультатОперации.Ссылка);
		КонецЕсли;
		
		УдалитьИзВременногоХранилища(Результат.АдресРезультата);

	КонецЕсли;

	УправлениеФормой(ЭтотОбъект);
	
КонецПроцедуры

#КонецОбласти

#Область ПрочиеСлужебныеПроцедурыИФункции

&НаСервереБезКонтекста
Процедура ЗаписатьИнформациюВЖурналРегистрации(Знач Сообщение, Знач Ошибка = Ложь)
	
	ПлатежныеСистемыСлужебный.ЗаписатьИнформациюВЖурналРегистрации(
		Сообщение,
		Ошибка);
	
КонецПроцедуры

#КонецОбласти

#КонецОбласти