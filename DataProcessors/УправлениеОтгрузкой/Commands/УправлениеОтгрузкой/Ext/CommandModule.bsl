
#Область ОбработчикиСобытий

&НаКлиенте
Процедура ОбработкаКоманды(ПараметрКоманды, ПараметрыВыполненияКоманды)
	
	// &ЗамерПроизводительности
	СуффиксОперации = СуффиксКлючевойОперации();
	КлючеваяОперация = СтрШаблон("Обработка.УправлениеОтгрузкой.Команда.УправлениеОтгрузкой.%1", СуффиксОперации);
	ОценкаПроизводительностиКлиент.ЗамерВремени(КлючеваяОперация);
	
	ОткрытьФорму("Обработка.УправлениеОтгрузкой.Форма.Форма",,,,ПараметрыВыполненияКоманды.Окно);	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Функция СуффиксКлючевойОперации()
	
	Если ПолучитьФункциональнуюОпцию("ИспользоватьДопустимоеОтклонениеОтгрузкиПриемкиМерныхТоваров") Тогда
		Суффикс = "ИспользоватьДопустимоеОтклонение";
	Иначе
		Суффикс = "НеИспользоватьДопустимоеОтклонение";
	КонецЕсли;
	
	Возврат Суффикс;
	
КонецФункции

#КонецОбласти
