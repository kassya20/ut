		ДанныеПодсказки.Вставить(Элементы.ДекорацияОКПД2, СтрокаДанных["КодОКПД2"]);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(СтрокаДанных["ПроизводственныйВСД"]) Тогда
		ДанныеПодсказки.Вставить(
			Элементы.ДекорацияВСД,
			Новый ФорматированнаяСтрока(
				СтрокаДанных["ИдентификаторПроизводственногоВСД"],,,,
				ПолучитьНавигационнуюСсылку(СтрокаДанных["ПроизводственныйВСД"])));
	КонецЕсли;
	
	Если ЗначениеЗаполнено(СтрокаДанных["АлкогольнаяПродукция"]) Тогда
		ДанныеПодсказки.Вставить(
			Элементы.ДекорацияАлкогольнаяПродукция,
			Новый ФорматированнаяСтрока(
				Строка(СтрокаДанных["АлкогольнаяПродукция"]),,,,
				ПолучитьНавигационнуюСсылку(СтрокаДанных["АлкогольнаяПродукция"])));
	КонецЕсли;
	
	ПредставлениеНоменклатурыИБ = СтрокаДанных["ПредставлениеНоменклатурыИБ"];
	
	ДанныеПодсказки.Вставить(Элементы.ДекорацияНоменклатура, ПредставлениеНоменклатурыИБ);
	
	Если ЗначениеЗаполнено(СтрокаДанных["Статус"]) Тогда
		
		ЧастиПредставленияСтатуса = Новый Массив();
		
		Если СтрокаДанных["ОсобоеСостояние"] = ПредопределенноеЗначение("Перечисление.СтатусыКодовМаркировкиИСМП.ЗаблокированОГВ") Тогда
			
			ЗначениеСтатус = СтрокаДанных["Статус"];
			ЧастиПредставленияСтатуса.Добавить(Строка(ЗначениеСтатус));
			ЧастиПредставленияСтатуса.Добавить(" (");
			ЧастиПредставленияСтатуса.Добавить(
				Новый ФорматированнаяСтрока(Строка(СтрокаДанных["ОсобоеСостояние"]),, Форма.ЦветТребуетВнимания));
			ЧастиПредставленияСтатуса.Добавить(")");
			
		ИначеЕсли ЗначениеЗаполнено(СтрокаДанных["ОсобоеСостояние"])
			И СтрокаДанных["ОсобоеСостояние"] <> ПредопределенноеЗначение("Перечисление.СтатусыКодовМаркировкиИСМП.Неопределен") Тогда
			
			ЗначениеСтатус = СтрокаДанных["Статус"];
			ЗначениеСтатус = СтрШаблон("%1 (%2)", ЗначениеСтатус, СтрокаДанных["ОсобоеСостояние"]);
			ЧастиПредставленияСтатуса.Добавить(ЗначениеСтатус);
			
		Иначе
			
			ЗначениеСтатус = СтрокаДанных["Статус"];
			ЧастиПредставленияСтатуса.Добавить(Строка(ЗначениеСтатус));
			
		КонецЕсли;
		
		ДанныеПодсказки.Вставить(Элементы.ДекорацияСостояние, Новый ФорматированнаяСтрока(ЧастиПредставленияСтатуса));
		
	Иначе
		
		ДанныеПодсказки.Вставить(Элементы.ДекорацияСостояние, Неопределено);
		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(СтрокаДанных["ГоденДо"]) Тогда
		
		ЧастиПредставленияСрокаГодности = Новый Массив();
		ЧастиПредставленияСрокаГодности.Добавить(Формат(СтрокаДанных["ГоденДо"], "ДФ=dd.MM.yyyy;"));
		ДанныеПредставленияСрока = ОбщегоНазначенияИСКлиентСервер.ДанныеПредставленияСрокаГодности(
			СтрокаДанных["ГоденДо"], Форма.ТекущаяДата);
		
		Если ДанныеПредставленияСрока.ОсталосьДней < 0 Тогда
			ЧастиПредставленияСрокаГодности.Добавить(" (");
			ЧастиПредставленияСрокаГодности.Добавить(
				Новый ФорматированнаяСтрока(ДанныеПредставленияСрока.Представление,, Форма.ЦветТребуетВнимания));
			ЧастиПредставленияСрокаГодности.Добавить(")");
		ИначеЕсли ДанныеПредставленияСрока.ОсталосьДней = 0 Тогда
			ЧастиПредставленияСрокаГодности.Добавить(" (");
			ЧастиПредставленияСрокаГодности.Добавить(
				Новый ФорматированнаяСтрока(ДанныеПредставленияСрока.Представление,, Форма.ЦветПроблема));
			ЧастиПредставленияСрокаГодности.Добавить(")");
		КонецЕсли;
		
		ДанныеПодсказки.Вставить(Элементы.ДекорацияГоденДо, Новый ФорматированнаяСтрока(ЧастиПредставленияСрокаГодности));
		
	Иначе
		
		ДанныеПодсказки.Вставить(Элементы.ДекорацияГоденДо, Неопределено);
		
