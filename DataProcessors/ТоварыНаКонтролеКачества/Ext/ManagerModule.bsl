#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ПрограммныйИнтерфейс

// Процедура длительной операции получения данных для заоплнения списка товаров рабочего места ТоварыНаКонтролеКачества.
//  Параметры:
//   ПараметрыЗаполнения - см. КонтрольКачестваКлиентСервер.ПараметрыЗаполненияТоваровДляКонтроляКачества
//  Возвращаемое значение:
//   ТаблицаЗначений - таблица с полями:
//    * Номенклатура - СправочникСсылка.Номенклатура - номенклатура товара партии.
//    * ЕдиницаИзмерения - СправочникСсылка.УпаковкиЕдиницыИзмерения - единица хранения товара партии.
//    * Характеристика - СправочникСсылка.ХарактеристикиНоменклатуры - характеристика товара партии.
//    * Склад - СправочникСсылка.Склады - склад, в котором находится товар партии.
//    * Назначение - СправочникСсылка.Назначения - назначение, дляч которого предназначается товар партии.
//    * КонтролируемаяПартия - СправочникСсылка.КонтролируемыеПартии - партия товара, по которой имеются остатки заблокированного товара.
//    * ЭтоЗаявкаНаКонтроль - Булево - партия образована заявкой на контроль качества.
//    * Серия - СправочникСсылка.СерииНоменклатуры - серия товара партии.
//    * Помещение - СправочникСсылка.СкладскиеПомещения - помещение, в котором находится товар партии.
//    * Заблокировано - Число - количество товара партии на складе.
//    * СвободныйОстатокНаСкладе - Число - свободный остаток на складе, где находится товар партии.
//    * СрокКонтроля - Дата - Планируемая дата завершения контроля качества.
//    * ЕстьСтрокКонтроля - Булево - признак, что поле СрокКонтроля заполнено.
//    * ЕстьВПроцессеПеремещения - Булево - признак, что не некоторое количество партии запланировано к перемещению или находится в процессе перемещения между складами.
Функция ВыполнитьЗаданиеЗаполненияТоваров(ПараметрыЗаполнения) Экспорт
	
	// 1. Получаем остатки товаров на складах в разрезе партий, за вычетом товаров,
	//    на которые уже оформлены расходные ордера на перемещение в нефинальных статусах.
	//    Эти товары на складах, все серии и помещения составят основу отображаемого в рабочем месте списка.
	// 2. Получаем товары на складе-отправителе в разрезе партий,
	//    запланированные к перемещению с действием Резервировать по мере поступления.
	//    В них нет серий и помещщений.
	// 3. Получаем товары на складе-отправителе в разрезе партий, по которым выдано распоряжение
	//    на отгрузку (заказ либо перемещение), но не созданы ордера.
	// 4. Товары 2 и 3 отображаются в составе 1 на складе-отправителе.
	//    Если товары 2 и 3 есть, то в РМ для склада-отправителя будет отображен индикатор, ЕстьВПроцессеПеремещения
	//    Для товаров 2 сопоставление с 1 идет без учета серий и помещений
	//    Для товаров 3 сопоставление с 1 идет без учета помещений, если в 3 заполнена серия,
	//    то с учетом серии, иначе без учета серии.
	// 5. Получаем Товары к поступлению на складе-получателе в разрезе партий
	//    по распоряжениям на поступление (заказ либо перемещение). Движения в заказах по
	//    Товарам к отгрузке и Товарам к поступлению синорнизированы, появляются после действия Отгрузить.
	// 6. Для каждого распоряжения на перемещения сопоставляем данные 2 и 5 без учета серий.
	//    Находим величину, на которое Товары к поступлению превосходят Товары к отгрузке
	//    Это количество уже не отображается на складе-отправителе, его нужно отображать на складе получателе.
	//    Обратную ситуацию, когда Товары к поступлению меньше чем Товары к отгрузке не рассматриваем.
	// 7. Добавляем товары 6 у основе списка 1. Если сопоставили, то увеличиваем количество, если нет, добачляем
	//    отдельной строкой. Если используются помещения и серии, то всегда будет отдельной строкой,
	//    так как в Товарах к поступлению помещение и серия отсутствует.
	// 8. Куда добавили, будет отображен индикатор, ЕстьВПроцессеПеремещения
	// 9. Для каждой аналитики товара и склада основной таблицы получаем свободный остаток на складе,
	//    для отображения в подвале рабочего места.
	// 10.Для каждой аналитики товара, склада и партии основной таблицы получаем минимальный срок контроля,
	//    по данным обеспечения как минимальная Дата подтверждения качества.
	// 11.Таблица рабочего места упорядочивается по возрастанию срока. Если разблокировка партии не планируется
	//    то партия отображается внизу списка.
	// 12.Упорядочивание по СрокКонтроля, Партия, Номенклатура, Характеристика, Серия, Назначение, Помещение, Склад
	
	Подстановки = Новый Массив();
	Если ПараметрыЗаполнения.Отбор.Склад <> Неопределено Тогда
		Подстановка = "Склад = &Склад";
		Подстановки.Добавить(Подстановка);
	КонецЕсли;
	
	Если ПараметрыЗаполнения.Отбор.Номенклатура <> Неопределено Тогда
		Подстановка = "Номенклатура = &Номенклатура";
		Подстановки.Добавить(Подстановка);
	КонецЕсли;

	Если ПараметрыЗаполнения.Отбор.Назначение <> Неопределено Тогда
		Подстановка = "Назначение = &Назначение";
		Подстановки.Добавить(Подстановка);
	КонецЕсли;
	
	Если Подстановки.Количество() = 0 Тогда
		Подстановка = "ИСТИНА"; // @query-part-1
	Иначе
		Подстановка = СтрСоединить(Подстановки, " И "); // @query-part-1
	КонецЕсли;
	
	ТекстЗапроса =
		"ВЫБРАТЬ
		|	ТоварыКОтгрузке.Номенклатура КАК Номенклатура,
		|	ТоварыКОтгрузке.Характеристика КАК Характеристика,
		|	ТоварыКОтгрузке.Назначение КАК Назначение,
		|	ТоварыКОтгрузке.Склад КАК Склад,
		|	ТоварыКОтгрузке.Получатель КАК Получатель,
		|	ТоварыКОтгрузке.Серия КАК Серия,
		|	ТоварыКОтгрузке.ДокументОтгрузки КАК ДокументОтгрузки,
		|	ТоварыКОтгрузке.КонтролируемаяПартия КАК КонтролируемаяПартия,
		|	ТоварыКОтгрузке.ВРезервеОстаток КАК РезервироватьНаСкладе,
		// Количество за вычетом того, что попало в расходные ордера. Отображается на складе-отправителе.
		|	ТоварыКОтгрузке.КОтгрузкеОстаток
		|		- ТоварыКОтгрузке.КСборкеОстаток
		|		- ТоварыКОтгрузке.СобираетсяОстаток
		|		- ТоварыКОтгрузке.СобраноОстаток КАК КОтгрузке
		|ПОМЕСТИТЬ ТоварыКОтгрузке
		|ИЗ
		|	РегистрНакопления.ТоварыКОтгрузке.Остатки(,
		|		&ОтборПереопределяемый
		|		И КонтролируемаяПартия <> ЗНАЧЕНИЕ(Справочник.КонтролируемыеПартии.ПустаяСсылка)
		|		{Номенклатура.* КАК Номенклатура,
		|			Характеристика.* КАК Характеристика,
		|			Склад.* КАК Склад,
		|			КонтролируемаяПартия.* КАК КонтролируемаяПартия,
		|			Назначение.* КАК Назначение}) КАК ТоварыКОтгрузке
		|;
		|
		|///////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ТоварыКОтгрузке.Номенклатура КАК Номенклатура,
		|	ТоварыКОтгрузке.Характеристика КАК Характеристика,
		|	ТоварыКОтгрузке.Назначение КАК Назначение,
		|	ТоварыКОтгрузке.Склад КАК Склад,
		|	ТоварыКОтгрузке.Получатель КАК Получатель,
		|	ТоварыКОтгрузке.КонтролируемаяПартия КАК КонтролируемаяПартия,
		|	СУММА(ТоварыКОтгрузке.КОтгрузке) КАК Количество
		|ПОМЕСТИТЬ ТоварыКОтгрузкеДляРасчетаПеремещаемыхТоваров
		|ИЗ
		|	ТоварыКОтгрузке КАК ТоварыКОтгрузке
		|ГДЕ
		|	ТоварыКОтгрузке.КОтгрузке > 0
		|СГРУППИРОВАТЬ ПО
		|	ТоварыКОтгрузке.Номенклатура,
		|	ТоварыКОтгрузке.Характеристика,
		|	ТоварыКОтгрузке.Назначение,
		|	ТоварыКОтгрузке.Склад,
		|	ТоварыКОтгрузке.Получатель,
		|	ТоварыКОтгрузке.КонтролируемаяПартия
		|ИНДЕКСИРОВАТЬ ПО
		|	Номенклатура, Характеристика, Назначение, Склад, Получатель, КонтролируемаяПартия
		|;
		|
		|///////////////////////////////////////////////////////////////////////////
		// ТоварыКОтгрузкеДляИндикатора.
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ТоварыКОтгрузке.Номенклатура КАК Номенклатура,
		|	ТоварыКОтгрузке.Характеристика КАК Характеристика,
		|	ТоварыКОтгрузке.Назначение КАК Назначение,
		|	ТоварыКОтгрузке.Склад КАК Склад,
		|	ТоварыКОтгрузке.Серия КАК Серия,
		|	ТоварыКОтгрузке.КонтролируемаяПартия КАК КонтролируемаяПартия
		|ПОМЕСТИТЬ ТоварыКОтгрузкеДляИндикатора
		|ИЗ
		|	ТоварыКОтгрузке КАК ТоварыКОтгрузке
		|ИНДЕКСИРОВАТЬ ПО
		|	Номенклатура, Характеристика, Назначение, Склад, Серия
		|;
		|
		|///////////////////////////////////////////////////////////////////////////////
		|УНИЧТОЖИТЬ ТоварыКОтгрузке
		|;
		// Запрос выше нужно выполнять в привилегированном режиме, чтобы корректно рассчитывалась временная таблица
		// ПеремещаемыеТовары. Запросы отделяются по ключевой фразе "УНИЧТОЖИТЬ ТоварыКОтгрузке".
		|
		|///////////////////////////////////////////////////////////////////////////////
		// ЗапасыИПотребностиДляИндикатора.
		|ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
		|	ЗапасыИПотребности.Номенклатура КАК Номенклатура,
		|	ЗапасыИПотребности.Характеристика КАК Характеристика,
		|	ЗапасыИПотребности.Склад КАК Склад,
		|	ЗапасыИПотребности.Назначение КАК Назначение,
		|	ЗапасыИПотребности.Заказ КАК КонтролируемаяПартия
		|ПОМЕСТИТЬ ЗапасыИПотребностиДляИндикатора
		|ИЗ
		|	РегистрНакопления.ЗапасыИПотребности.Остатки(,
		|		&ОтборПереопределяемый
		|		И ТИПЗНАЧЕНИЯ(Заказ) = ТИП(Справочник.КонтролируемыеПартии)
		|		{Номенклатура.* КАК Номенклатура,
		|			Характеристика.* КАК Характеристика,
		|			Склад.* КАК Склад,
		|			Назначение.* КАК Назначение,
		|			Заказ.* КАК КонтролируемаяПартия}) КАК ЗапасыИПотребности
		|ГДЕ
		|	ЗапасыИПотребности.РезервироватьПоМереПоступленияИзЗаблокированныхОстаток > 0
		|		ИЛИ ЗапасыИПотребности.РезервироватьНаСкладеИзЗаблокированныхОстаток > 0
		|ИНДЕКСИРОВАТЬ ПО
		|	Номенклатура, Характеристика, Склад, Назначение, КонтролируемаяПартия
		|;
		|
		|///////////////////////////////////////////////////////
		// СрокиКонтроля.
		|ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	ЗапасыИПотребности.Номенклатура КАК Номенклатура,
		|	ЗапасыИПотребности.Характеристика КАК Характеристика,
		|	ЗапасыИПотребности.Склад КАК Склад,
		|	ЗапасыИПотребности.Назначение КАК Назначение,
		|	ЗапасыИПотребности.Заказ КАК КонтролируемаяПартия,
		|	МИНИМУМ(ЗапасыИПотребности.ДатаСобытия) КАК СрокКонтроля
		|ПОМЕСТИТЬ СрокиКонтроля
		|ИЗ
		|	РегистрНакопления.ЗапасыИПотребности.Остатки(,
		|		&ОтборПереопределяемый
		// Партия поступила
		|		И ТИПЗНАЧЕНИЯ(Заказ) = ТИП(Справочник.КонтролируемыеПартии)
		|		{Номенклатура.* КАК Номенклатура,
		|			Характеристика.* КАК Характеристика,
		|			Склад.* КАК Склад,
		|			Назначение.* КАК Назначение,
		|			Заказ.* КАК КонтролируемаяПартия}) КАК ЗапасыИПотребности
		|ГДЕ
		|	ЗапасыИПотребности.КРазблокировкеОстаток > 0
		|СГРУППИРОВАТЬ ПО
		|	ЗапасыИПотребности.Номенклатура,
		|	ЗапасыИПотребности.Характеристика,
		|	ЗапасыИПотребности.Назначение,
		|	ЗапасыИПотребности.Склад,
		|	ЗапасыИПотребности.Заказ
		|ИНДЕКСИРОВАТЬ ПО
		|	Номенклатура, Характеристика, Склад, Назначение, КонтролируемаяПартия
		|;
		|
		|///////////////////////////////////////////////////////////////////////////
		// ПеремещаемыеТовары.
		|ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	ТоварыКПоступлению.Номенклатура КАК Номенклатура,
		|	ТоварыКПоступлению.Характеристика КАК Характеристика,
		|	ТоварыКПоступлению.Назначение КАК Назначение,
		|	ТоварыКПоступлению.Склад КАК Склад,
		|	ТоварыКПоступлению.Отправитель КАК Отправитель,
		|	ТоварыКПоступлению.КонтролируемаяПартия КАК КонтролируемаяПартия,
		// Количество, которое не отражено в товарах на складах на неордерном складе
		|	ТоварыКПоступлению.КОформлениюПоступленийПоРаспоряжениюОстаток
		// Поправка на превышение ордера над поступлением на ордерном складе
		|		- ТоварыКПоступлению.КОформлениюПоступленийПоОрдерамОстаток КАК Количество
		|ПОМЕСТИТЬ ТоварыКПоступлениюДляРасчетаПеремещаемыхТоваров
		|ИЗ
		|	РегистрНакопления.ТоварыКПоступлению.Остатки(,
		|		&ОтборПереопределяемый
		|			И КонтролируемаяПартия <> ЗНАЧЕНИЕ(Справочник.КонтролируемыеПартии.ПустаяСсылка)
		|		{Номенклатура.* КАК Номенклатура,
		|			Характеристика.* КАК Характеристика,
		|			Склад.* КАК Склад,
		|			КонтролируемаяПартия.* КАК КонтролируемаяПартия,
		|			Назначение.* КАК Назначение}) КАК ТоварыКПоступлению
		|ИНДЕКСИРОВАТЬ ПО
		|	Номенклатура, Характеристика, Назначение, Склад, Отправитель, КонтролируемаяПартия
		|;
		|
		|///////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	ТоварыКПоступлению.Номенклатура КАК Номенклатура,
		|	ТоварыКПоступлению.Характеристика КАК Характеристика,
		|	ТоварыКПоступлению.Назначение КАК Назначение,
		|	ТоварыКПоступлению.Склад КАК Склад,
		|	ТоварыКПоступлению.КонтролируемаяПартия КАК КонтролируемаяПартия,
		|	СУММА(ТоварыКПоступлению.Количество - ЕСТЬNULL(ТоварыКОтгрузке.Количество, 0)) КАК Количество
		|ПОМЕСТИТЬ ПеремещаемыеТовары
		|ИЗ
		|	ТоварыКПоступлениюДляРасчетаПеремещаемыхТоваров КАК ТоварыКПоступлению
		|		
		|		ЛЕВОЕ СОЕДИНЕНИЕ ТоварыКОтгрузкеДляРасчетаПеремещаемыхТоваров КАК ТоварыКОтгрузке
		|		ПО ТоварыКОтгрузке.Номенклатура = ТоварыКПоступлению.Номенклатура
		|		 И ТоварыКОтгрузке.Характеристика = ТоварыКПоступлению.Характеристика
		|		 И ТоварыКОтгрузке.Назначение = ТоварыКПоступлению.Назначение
		|		 И ТоварыКОтгрузке.Склад = ТоварыКПоступлению.Отправитель
		|		 И ТоварыКОтгрузке.Получатель = ТоварыКПоступлению.Склад
		|		 И ТоварыКОтгрузке.КонтролируемаяПартия = ТоварыКПоступлению.КонтролируемаяПартия
		|ГДЕ
		|	ТоварыКПоступлению.Количество - ЕСТЬNULL(ТоварыКОтгрузке.Количество, 0) > 0
		|{ГДЕ
		|	ВЫРАЗИТЬ(ЗНАЧЕНИЕ(Справочник.СкладскиеПомещения.ПустаяСсылка) КАК Справочник.СкладскиеПомещения).* КАК Помещение,
		|	ВЫРАЗИТЬ(ЗНАЧЕНИЕ(Справочник.СерииНоменклатуры.ПустаяСсылка) КАК Справочник.СерииНоменклатуры).* КАК Серия}
		|СГРУППИРОВАТЬ ПО
		|	ТоварыКПоступлению.Номенклатура,
		|	ТоварыКПоступлению.Характеристика,
		|	ТоварыКПоступлению.Назначение,
		|	ТоварыКПоступлению.Склад,
		|	ТоварыКПоступлению.КонтролируемаяПартия
		|ИНДЕКСИРОВАТЬ ПО
		|	Номенклатура, Характеристика, Назначение, Склад, КонтролируемаяПартия
		|;
		|
		|///////////////////////////////////////////////////////////////////////////
		|УНИЧТОЖИТЬ ТоварыКПоступлениюДляРасчетаПеремещаемыхТоваров
		|;
		|
		|///////////////////////////////////////////////////////////////////////////
		|УНИЧТОЖИТЬ ТоварыКОтгрузкеДляРасчетаПеремещаемыхТоваров
		|;
		|
		|///////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	ТоварыНаСкладах.Номенклатура КАК Номенклатура,
		|	ТоварыНаСкладах.Характеристика КАК Характеристика,
		|	ТоварыНаСкладах.Склад КАК Склад,
		|	ТоварыНаСкладах.Помещение КАК Помещение,
		|	ТоварыНаСкладах.Назначение КАК Назначение,
		|	ТоварыНаСкладах.КонтролируемаяПартия КАК КонтролируемаяПартия,
		|	ТоварыНаСкладах.Серия КАК Серия,
		|	ТоварыНаСкладах.ВНаличииОстаток
		// В ордерах
		|		- ТоварыНаСкладах.КОтгрузкеОстаток КАК Количество
		|ПОМЕСТИТЬ ТоварыНаСкладах
		|ИЗ
		|	РегистрНакопления.ТоварыНаСкладах.Остатки(,
		|		&ОтборПереопределяемый
		|		И КонтролируемаяПартия <> ЗНАЧЕНИЕ(Справочник.КонтролируемыеПартии.ПустаяСсылка)
		|		{Номенклатура.* КАК Номенклатура,
		|			Характеристика.* КАК Характеристика,
		|			Склад.* КАК Склад,
		|			Назначение.* КАК Назначение,
		|			КонтролируемаяПартия.*,
		|			Помещение.*,
		|			Серия.*}) КАК ТоварыНаСкладах
		|ГДЕ
		|	ТоварыНаСкладах.ВНаличииОстаток > 0
		|ИНДЕКСИРОВАТЬ ПО
		|	Номенклатура, Характеристика, Склад, Помещение, Назначение, КонтролируемаяПартия, Серия
		|;
		|
		|///////////////////////////////////////////////////////////////////////////
		// ОсновнаяТаблица.
		|ВЫБРАТЬ
		|	ТоварыНаСкладах.Номенклатура КАК Номенклатура,
		|	ТоварыНаСкладах.Характеристика КАК Характеристика,
		|	ТоварыНаСкладах.Склад КАК Склад,
		|	ТоварыНаСкладах.Помещение КАК Помещение,
		|	ТоварыНаСкладах.Назначение КАК Назначение,
		|	ТоварыНаСкладах.КонтролируемаяПартия КАК КонтролируемаяПартия,
		|	ТоварыНаСкладах.Серия КАК Серия,
		|	ТоварыНаСкладах.Количество
		|		+ ЕСТЬNULL(ПеремещаемыеТовары.Количество, 0) КАК Количество,
		|	НЕ ПеремещаемыеТовары.Номенклатура ЕСТЬ NULL ЕстьВПроцессеПеремещения
		|ПОМЕСТИТЬ ОсновнаяТаблица
		|ИЗ
		|	ТоварыНаСкладах КАК ТоварыНаСкладах
		|		
		|		ЛЕВОЕ СОЕДИНЕНИЕ ПеремещаемыеТовары КАК ПеремещаемыеТовары
		|		ПО ПеремещаемыеТовары.Номенклатура = ТоварыНаСкладах.Номенклатура
		|		 И ПеремещаемыеТовары.Характеристика = ТоварыНаСкладах.Характеристика
		|		 И ПеремещаемыеТовары.Склад = ТоварыНаСкладах.Склад
		|		 И ТоварыНаСкладах.Помещение = ЗНАЧЕНИЕ(Справочник.СкладскиеПомещения.ПустаяСсылка)
		|		 И ПеремещаемыеТовары.Назначение = ТоварыНаСкладах.Назначение
		|		 И ПеремещаемыеТовары.КонтролируемаяПартия = ТоварыНаСкладах.КонтролируемаяПартия
		|		 И ТоварыНаСкладах.Серия = ЗНАЧЕНИЕ(Справочник.СерииНоменклатуры.ПустаяСсылка)
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	ПеремещаемыеТовары.Номенклатура КАК Номенклатура,
		|	ПеремещаемыеТовары.Характеристика КАК Характеристика,
		|	ПеремещаемыеТовары.Склад КАК Склад,
		|	ЗНАЧЕНИЕ(Справочник.СкладскиеПомещения.ПустаяСсылка) КАК Помещение,
		|	ПеремещаемыеТовары.Назначение КАК Назначение,
		|	ПеремещаемыеТовары.КонтролируемаяПартия КАК КонтролируемаяПартия,
		|	ЗНАЧЕНИЕ(Справочник.СерииНоменклатуры.ПустаяСсылка) КАК Серия,
		|	ПеремещаемыеТовары.Количество КАК Количество,
		|	ИСТИНА ЕстьВПроцессеПеремещения
		|ИЗ
		|	ПеремещаемыеТовары КАК ПеремещаемыеТовары
		|		
		|		ЛЕВОЕ СОЕДИНЕНИЕ ТоварыНаСкладах КАК ТоварыНаСкладах
		|		ПО ТоварыНаСкладах.Номенклатура = ПеремещаемыеТовары.Номенклатура
		|		 И ТоварыНаСкладах.Характеристика = ПеремещаемыеТовары.Характеристика
		|		 И ТоварыНаСкладах.Склад = ПеремещаемыеТовары.Склад
		|		 И ТоварыНаСкладах.Помещение = ЗНАЧЕНИЕ(Справочник.СкладскиеПомещения.ПустаяСсылка)
		|		 И ТоварыНаСкладах.Назначение = ПеремещаемыеТовары.Назначение
		|		 И ТоварыНаСкладах.КонтролируемаяПартия = ПеремещаемыеТовары.КонтролируемаяПартия
		|		 И ТоварыНаСкладах.Серия = ЗНАЧЕНИЕ(Справочник.СерииНоменклатуры.ПустаяСсылка)
		|
		|ИНДЕКСИРОВАТЬ ПО
		|	Номенклатура, Характеристика, Склад, Назначение, КонтролируемаяПартия, Серия, Помещение
		|;
		|
		|///////////////////////////////////////////////////////////////////////////
		|УНИЧТОЖИТЬ ТоварыНаСкладах
		|;
		|
		|///////////////////////////////////////////////////////////////////////////
		|УНИЧТОЖИТЬ ПеремещаемыеТовары
		|;
		|
		|///////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	Аналитики.Номенклатура КАК Номенклатура,
		|	Аналитики.Характеристика КАК Характеристика,
		|	Аналитики.Склад КАК Склад,
		|	Аналитики.Назначение КАК Назначение
		|ПОМЕСТИТЬ АналитикиДляПолученияОстатков
		|ИЗ
		|	ОсновнаяТаблица КАК Аналитики
		|ИНДЕКСИРОВАТЬ ПО
		|	Номенклатура, Характеристика, Склад, Назначение
		|;
		|
		|///////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	Запасы.Номенклатура КАК Номенклатура,
		|	Запасы.Характеристика КАК Характеристика,
		|	Запасы.Склад КАК Склад,
		|	Запасы.Назначение КАК Назначение,
		|	Запасы.ВНаличииОстаток КАК ВНаличииОстаток,
		|	Запасы.ЗаблокированоВНаличииОстаток КАК ЗаблокированоВНаличииОстаток,
		|	Запасы.ЗаказаноОстаток КАК ЗаказаноОстаток,
		|	Запасы.ПоступитОстаток КАК ПоступитОстаток,
		|	Запасы.ЗаблокированоПоступитОстаток КАК ЗаблокированоПоступитОстаток,
		|	Запасы.РезервироватьНаСкладеОстаток КАК РезервироватьНаСкладеОстаток,
		|	Запасы.РезервироватьПоМереПоступленияОстаток КАК РезервироватьПоМереПоступленияОстаток,
		|	Запасы.ОтложитьРезервированиеОстаток КАК ОтложитьРезервированиеОстаток,
		|	Запасы.КОбеспечениюОстаток КАК КОбеспечениюОстаток,
		|	Запасы.НеОбеспечиватьОстаток КАК НеОбеспечиватьОстаток
		|ПОМЕСТИТЬ ЗапасыИПотребностиОстатки
		|ИЗ
		|	РегистрНакопления.ЗапасыИПотребности.Остатки(,
		|		(Номенклатура, Характеристика, Склад, Назначение) В(
		|			ВЫБРАТЬ
		|				Фильтр.Номенклатура КАК Номенклатура,
		|				Фильтр.Характеристика КАК Характеристика,
		|				Фильтр.Склад КАК Склад,
		|				Фильтр.Назначение КАК Назначение
		|			ИЗ
		|				АналитикиДляПолученияОстатков КАК Фильтр)) КАК Запасы
		|;
		|
		|///////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Таблица.Номенклатура КАК Номенклатура,
		|	Таблица.Номенклатура.ЕдиницаИзмерения КАК ЕдиницаИзмерения,
		|	Таблица.Характеристика КАК Характеристика,
		|	Таблица.Склад КАК Склад,
		|	Таблица.Назначение КАК Назначение,
		|	Таблица.КонтролируемаяПартия КАК КонтролируемаяПартия,
		|	ТИПЗНАЧЕНИЯ(Таблица.КонтролируемаяПартия.Партия) = ТИП(Документ.ЗаявкаНаКонтрольКачестваТоваров) КАК ЭтоЗаявкаНаКонтроль,
		|	Таблица.Серия КАК Серия,
		|	Таблица.Помещение КАК Помещение,
		|	Таблица.Количество КАК Заблокировано,
		|	ЕСТЬNULL(Расчет.КоличествоДляДействияОтгрузить, 0) КАК СвободныйОстатокНаСкладе,
		|	ЕСТЬNULL(СрокиКонтроля.СрокКонтроля, ДАТАВРЕМЯ(1,1,1)) КАК СрокКонтроля,
		|	НЕ СрокиКонтроля.СрокКонтроля ЕСТЬ NULL КАК ЕстьСтрокКонтроля,
		|	Таблица.ЕстьВПроцессеПеремещения
		|		ИЛИ НЕ ТоварыКОтгрузке.Номенклатура ЕСТЬ NULL
		|		ИЛИ НЕ ЗапасыИПотребности.Номенклатура ЕСТЬ NULL КАК ЕстьВПроцессеПеремещения
		|{ВЫБРАТЬ
		|	Номенклатура.*,
		|	ЕдиницаИзмерения.*,
		|	Характеристика.*,
		|	Склад.*,
		|	Назначение.*,
		|	КонтролируемаяПартия.*,
		|	Серия.*,
		|	Помещение.*,
		|	Заблокировано,
		|	СвободныйОстатокНаСкладе,
		|	СрокКонтроля,
		|	ЕстьСтрокКонтроля,
		|	ЕстьВПроцессеПеремещения}
		|ИЗ
		|	ОсновнаяТаблица КАК Таблица
		|		
		|		ЛЕВОЕ СОЕДИНЕНИЕ РасчетОстатковДляУстановкиДействий КАК Расчет
		|		ПО Расчет.Номенклатура = Таблица.Номенклатура
		|		 И Расчет.Характеристика = Таблица.Характеристика
		|		 И Расчет.Склад = Таблица.Склад
		|		 И Расчет.Назначение = Таблица.Назначение
		|		 И Расчет.КоличествоДляДействияОтгрузить > 0
		|		
		|		ЛЕВОЕ СОЕДИНЕНИЕ СрокиКонтроля КАК СрокиКонтроля
		|		ПО СрокиКонтроля.Номенклатура = Таблица.Номенклатура
		|		 И СрокиКонтроля.Характеристика = Таблица.Характеристика
		|		 И СрокиКонтроля.Назначение = Таблица.Назначение
		|		 И СрокиКонтроля.Склад = Таблица.Склад
		|		 И СрокиКонтроля.КонтролируемаяПартия = Таблица.КонтролируемаяПартия
		|		
		|		ЛЕВОЕ СОЕДИНЕНИЕ ТоварыКОтгрузкеДляИндикатора КАК ТоварыКОтгрузке
		|		ПО ТоварыКОтгрузке.Номенклатура = Таблица.Номенклатура
		|		 И ТоварыКОтгрузке.Характеристика = Таблица.Характеристика
		|		 И ТоварыКОтгрузке.Назначение = Таблица.Назначение
		|		 И ТоварыКОтгрузке.Склад = Таблица.Склад
		|		 И ТоварыКОтгрузке.КонтролируемаяПартия = Таблица.КонтролируемаяПартия
		|		 И (ТоварыКОтгрузке.Серия = Таблица.Серия
		|			ИЛИ ТоварыКОтгрузке.Серия = ЗНАЧЕНИЕ(Справочник.СерииНоменклатуры.ПустаяСсылка))
		|		
		|		ЛЕВОЕ СОЕДИНЕНИЕ ЗапасыИПотребностиДляИндикатора КАК ЗапасыИПотребности
		|		ПО ЗапасыИПотребности.Номенклатура = Таблица.Номенклатура
		|		 И ЗапасыИПотребности.Характеристика = Таблица.Характеристика
		|		 И ЗапасыИПотребности.Назначение = Таблица.Назначение
		|		 И ЗапасыИПотребности.Склад = Таблица.Склад
		|		 И ЗапасыИПотребности.КонтролируемаяПартия = Таблица.КонтролируемаяПартия
		|ГДЕ
		|	(&ЗаявкаОформленаПереопределяемый)
		|{ГДЕ
		|	(ЕСТЬNULL(СрокиКонтроля.СрокКонтроля, ДАТАВРЕМЯ(1, 1, 1))) КАК СрокКонтроля,
		|	(Таблица.ЕстьВПроцессеПеремещения
		|			ИЛИ НЕ ТоварыКОтгрузке.Номенклатура ЕСТЬ NULL
		|			ИЛИ НЕ ЗапасыИПотребности.Номенклатура ЕСТЬ NULL) КАК ЕстьВПроцессеПеремещения}
		|УПОРЯДОЧИТЬ ПО
		|	ЕстьСтрокКонтроля УБЫВ,
		|	СрокКонтроля,
		|	КонтролируемаяПартия,
		|	Номенклатура,
		|	Характеристика,
		|	Серия,
		|	Назначение,
		|	Помещение,
		|	Склад";
		
	ИменаТаблиц = ОбеспечениеВДокументахСервер.НовыеИменаТаблицДляРасчетаОстатковДляУстановкиДействий();
	ИменаТаблиц.Остатки = "ЗапасыИПотребностиОстатки"; // @query-part-1
	ИменаТаблиц.Результат = "РасчетОстатковДляУстановкиДействий"; // @query-part-1
	ОбеспечениеВДокументахСервер.РасчетОстатковДляУстановкиДействий(ТекстЗапроса, ИменаТаблиц);
	
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&ОтборПереопределяемый", Подстановка);
	
	Если ПараметрыЗаполнения.Отбор.ЗаявкаОформлена = Неопределено Тогда
		Подстановка = "ИСТИНА";
	ИначеЕсли ПараметрыЗаполнения.Отбор.ЗаявкаОформлена Тогда
		Подстановка = "ТИПЗНАЧЕНИЯ(Таблица.КонтролируемаяПартия.Партия) = ТИП(Документ.ЗаявкаНаКонтрольКачестваТоваров)";
	Иначе
		Подстановка = "ТИПЗНАЧЕНИЯ(Таблица.КонтролируемаяПартия.Партия) <> ТИП(Документ.ЗаявкаНаКонтрольКачестваТоваров)";
	КонецЕсли;
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&ЗаявкаОформленаПереопределяемый", Подстановка);
	
	Отборы = Обработки.ТоварыНаКонтролеКачества.ПолучитьМакет("Отборы");
	Отборы.НаборыДанных[0].Запрос = ТекстЗапроса;
	КомпоновщикМакетаКомпоновкиДанных = Новый КомпоновщикМакетаКомпоновкиДанных;
	МакетКомпоновкиДанных = КомпоновщикМакетаКомпоновкиДанных.Выполнить(
		Отборы,
		ПараметрыЗаполнения.НастройкиКомпоновки,
		,
		,
		,
		Ложь);
	
	Запрос = Новый Запрос();
	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц();
	Для каждого ПараметрКомпоновки Из МакетКомпоновкиДанных.ЗначенияПараметров Цикл
		Запрос.УстановитьПараметр(ПараметрКомпоновки.Имя, ПараметрКомпоновки.Значение);
	КонецЦикла;
	
	Для Каждого ЭлементОтбора Из ПараметрыЗаполнения.Отбор Цикл
		Запрос.УстановитьПараметр(ЭлементОтбора.Ключ, ЭлементОтбора.Значение);
	КонецЦикла;
	
	ТекстЗапроса = МакетКомпоновкиДанных.НаборыДанных[0].Запрос;
	Разделитель = "УНИЧТОЖИТЬ ТоварыКОтгрузке";
	КонецПервогоБлока = СтрНайти(ТекстЗапроса, Разделитель) + СтрДлина(Разделитель) + 1;
	// Нужно получить, даже если нет доступа к складу-отправителя перемещения,
	// чтобы верно рассчитать временную таблицу ПеремещаемыеТовары.
	УстановитьПривилегированныйРежим(Истина);
	Запрос.Текст = Лев(ТекстЗапроса, КонецПервогоБлока);
	Запрос.Выполнить();
	УстановитьПривилегированныйРежим(Ложь);
	Запрос.Текст = Сред(ТекстЗапроса, КонецПервогоБлока + 1);
	Результат = Запрос.Выполнить().Выгрузить();
	
	Возврат Результат;
	
КонецФункции

// Инициализирует параметры, обслуживающие выбор назначений в формах документа.
//
//  Возвращаемое значение:
//  См. Справочники.Назначения.МакетФормыВыбораНазначений
//
Функция МакетФормыВыбораНазначений() Экспорт
	
	МакетФормы = Справочники.Назначения.МакетФормыВыбораНазначений();
	
	Справочники.Назначения.ДобавитьОписаниеКолонок(МакетФормы, "ВсеНазначения", Ложь, "Назначение");
	Возврат МакетФормы;
	
КонецФункции

