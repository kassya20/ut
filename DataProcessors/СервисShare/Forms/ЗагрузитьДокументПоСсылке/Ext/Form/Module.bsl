#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	СсылкаНаИнструкциюСервиса = ИнтеграцияShare.СсылкаНаИнструкциюСервиса();
	
	// Сбрасываем сохранение окна, т.к. после просмотра документа окно всегда слишком широкое.
	КлючСохраненияПоложенияОкна = Новый УникальныйИдентификатор;
	ИспользоватьФормуЗагрузкиДокументаПоУмолчанию = Истина;
	
	ЭтоМобильныйКлиент = ОбщегоНазначения.ЭтоМобильныйКлиент();
	
	ДанныеЭлектронногоДокумента = Параметры.ДанныеЭлектронногоДокумента;
	
	Если ДанныеЭлектронногоДокумента <> Неопределено
		И ЗначениеЗаполнено(ДанныеЭлектронногоДокумента.ОписаниеЭлектронногоДокумента) Тогда
		
		ОписаниеЭлектронногоДокумента = ДанныеЭлектронногоДокумента.ОписаниеЭлектронногоДокумента;
		СсылкаДляСкачиванияДокумента = ДанныеЭлектронногоДокумента.СсылкаДляСкачивания;
		
		ТекстОшибки = "";
		НастройкиЗагрузки = ИнтеграцияShare.НастройкиЗагрузкиДокументаПоСсылке(ОписаниеЭлектронногоДокумента, , ТекстОшибки);
		
		Если ЗначениеЗаполнено(ТекстОшибки) Тогда
			ОбщегоНазначения.СообщитьПользователю(ТекстОшибки);
		КонецЕсли;

		ЗаполнитьСтраницуЗагрузкиДокумента(НастройкиЗагрузки.ПараметрыОтраженияВУчете);
		Возврат;
	КонецЕсли;
	
	УстановитьВидимостьФормыПриОткрытии(Элементы);
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	ОжидатьЗавершенияПолученияФайловВизуализацииВФоне();
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура ПодсказкаКакПолучитьСсылкуОбработкаНавигационнойСсылки(Элемент, НавигационнаяСсылка, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	ОткрытьНавигационнуюСсылку(СсылкаНаИнструкциюСервиса);
	
КонецПроцедуры

&НаКлиенте
Процедура СсылкаПоискаИзменениеТекстаРедактирования(Элемент, Текст, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	УстановитьВидимостьФормыПриОткрытии(Элементы);
	
КонецПроцедуры

&НаКлиенте
Процедура СсылкаПоискаОткрытие(Элемент, СтандартнаяОбработка) 
	
	СтандартнаяОбработка = Ложь;
	
	ОткрытьНавигационнуюСсылку(Элемент.ТекстРедактирования);
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыСписокФайлов

&НаКлиенте
Процедура СписокФайловПриАктивизацииСтроки(Элемент)
	
	ТекущиеДанные = Элемент.ТекущиеДанные;
	
	Если ЭтоМобильныйКлиент
		Или ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	УстановитьПредставлениеФайлаСписка(ТекущиеДанные);
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура ЗагрузитьДокумент(Команда)
	
	ОчиститьСообщения();
	
	ЭлементСписка = СпособОтраженияВУчетеПоКомандам.НайтиПоЗначению(Команда.Имя);
	Если ЭлементСписка <> Неопределено Тогда
		СпособОтраженияВУчете = ЭлементСписка.Представление;
	КонецЕсли;
	
	УстановитьВидимостьОжиданияЗагрузки(Элементы, Истина);
	
	ПодключитьОбработчикОжидания("ЗагрузитьДокументПоПубличнойСсылке", 0.1, Истина);
	
КонецПроцедуры

&НаКлиенте
Процедура НайтиДокумент(Команда)
	
	Отказ = Ложь;
	ПроверитьВалидностьСсылкиНаДокумент(Отказ);
	Если Отказ Тогда
		Возврат;
	КонецЕсли;
	
	УстановитьВидимостьСтраницыПодвалаПоиска(Элементы, Истина);
	
	ПодключитьОбработчикОжидания("ПоискДокументаПоПубличнойСсылке", 0.1, Истина);
	
КонецПроцедуры

&НаКлиенте
Процедура Подключаемый_МасштабПлюс(Команда)

	Элементы[ИмяЭлементаДокументаPDFПоле()].Масштаб = Элементы[ИмяЭлементаДокументаPDFПоле()].Масштаб + 10;

КонецПроцедуры

&НаКлиенте
Процедура Подключаемый_МасштабМинус(Команда)
	
	Если Элементы[ИмяЭлементаДокументаPDFПоле()].Масштаб <= 10 Тогда
		Возврат;
	КонецЕсли;
	
	Элементы[ИмяЭлементаДокументаPDFПоле()].Масштаб = Элементы[ИмяЭлементаДокументаPDFПоле()].Масштаб - 10;
	
КонецПроцедуры

&НаКлиенте
Процедура Подключаемый_ПоворотЛево(Команда)
	
	Элементы[ИмяЭлементаДокументаPDFПоле()].Ориентация = Элементы[ИмяЭлементаДокументаPDFПоле()].Ориентация - 90;
	
КонецПроцедуры

&НаКлиенте
Процедура Подключаемый_ПоворотПраво(Команда)
	
	Элементы[ИмяЭлементаДокументаPDFПоле()].Ориентация = Элементы[ИмяЭлементаДокументаPDFПоле()].Ориентация + 90;
	
КонецПроцедуры

&НаКлиенте
Процедура Подключаемый_Печать(Команда)
	
	ЭтотОбъект[ИмяЭлементаДокументаPDFРеквизит()].Напечатать(РежимИспользованияДиалогаПечати.Использовать);
	
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьДокументВВебе(Команда)
	ОткрытьНавигационнуюСсылку(СсылкаДляСкачиванияДокумента);
КонецПроцедуры

&НаКлиенте
Процедура СкачатьФайл(Команда)
	
	ОчиститьСообщения();
	
	Если СписокФайлов.Количество() = 1 Тогда
		ТекущиеДанные = СписокФайлов[0];
	Иначе
		ТекущиеДанные = Элементы.СписокФайлов.ТекущиеДанные;
	КонецЕсли;
	
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ДанныеФайла = ДанныеФайлаСкачивания();
	ДанныеФайла.ИдентификаторФайла    = ТекущиеДанные.ИдентификаторФайла;
	ДанныеФайла.ИмяФайла              = ТекущиеДанные.ПредставлениеФайла;
	ДанныеФайла.СсылкаСкачиванияФайла = ТекущиеДанные.СсылкаСкачиванияИсходногоФайла;
	ДанныеФайла.ДвоичныеДанные        = ТекущиеДанные.ДвоичныеДанныеИсходногоФайла;
	ДанныеФайла.ТипФайла              = ТипыФайла().ИсходныйФайл;
	
	ЗагрузитьФайлДляСкачиванияИСохранить(ДанныеФайла);
	
КонецПроцедуры

&НаКлиенте
Процедура СкачатьВсеФайлы(Команда)
	
	ОчиститьСообщения();
	
	Если Не ЗначениеЗаполнено(ДанныеАрхиваВсехФайлов) Тогда
		Возврат;
	КонецЕсли;
	
	ДанныеФайла = ДанныеФайлаСкачивания();
	ДанныеФайла.ИдентификаторФайла    = ДанныеАрхиваВсехФайлов.Идентификатор;
	ДанныеФайла.ИмяФайла              = ДанныеАрхиваВсехФайлов.Представление;
	ДанныеФайла.СсылкаСкачиванияФайла = ДанныеАрхиваВсехФайлов.СсылкаСкачиванияФайлаВизуализации;
	ДанныеФайла.ДвоичныеДанные        = ДанныеАрхиваВсехФайлов.ДвоичныеДанныеФайлаВизуализации;
	ДанныеФайла.ТипФайла              = ТипыФайла().ФайлВизуализации;
	
	ЗагрузитьФайлДляСкачиванияИСохранить(ДанныеФайла);

КонецПроцедуры

&НаКлиенте
Процедура СкачатьПолныйПакет(Команда)
	
	ОчиститьСообщения();
	
	Если Не ЗначениеЗаполнено(ДанныеАрхиваВсехФайлов) Тогда
		Возврат;
	КонецЕсли;
	
	ДанныеФайла = ДанныеФайлаСкачивания();
	ДанныеФайла.ИдентификаторФайла    = ДанныеАрхиваВсехФайлов.Идентификатор;
	ДанныеФайла.ИмяФайла              = ДанныеАрхиваВсехФайлов.Представление;
	ДанныеФайла.СсылкаСкачиванияФайла = ДанныеАрхиваВсехФайлов.СсылкаСкачиванияИсходногоФайла;
	ДанныеФайла.ДвоичныеДанные        = ДанныеАрхиваВсехФайлов.ДвоичныеДанныеИсходногоФайла;
	ДанныеФайла.ТипФайла              = ТипыФайла().ИсходныйФайл;
	
	ЗагрузитьФайлДляСкачиванияИСохранить(ДанныеФайла);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

#Область ПоискДокумента

&НаКлиенте
Процедура ПоискДокументаПоПубличнойСсылке()
	
	ПоискДокументаПоПубличнойСсылкеНаСервере();
	
	Если Не ИспользоватьФормуЗагрузкиДокументаПоУмолчанию Тогда
		// Если в прикладном решении указали, что используется своя форма загрузки:
		//  - загружаем полные данные документа
		//  - открываем форму прикладного решения
		//  - текущую форму закрываем
		ЗагрузитьДокументПоПубличнойСсылке();
		Возврат;
	КонецЕсли;
	
	ОжидатьЗавершенияПолученияФайловВизуализацииВФоне();
	
КонецПроцедуры

&НаСервере
Процедура ПоискДокументаПоПубличнойСсылкеНаСервере()
	
	ТекстОшибки = "";
	
	Если ЭтоСсылкаОнлайнЗаказа Тогда
		СсылкаДляСкачиванияДокумента = ИнтеграцияShare.СсылкаДляСкачиванияВСервисеОнлайнЗаказы(
			СсылкаПоиска, ТекстОшибки);
		
		Если СсылкаДляСкачиванияДокумента = Неопределено Тогда
			УстановитьВидимостьРезультатаПоиска(Истина, ТекстОшибки);
			Возврат;
		КонецЕсли;
	Иначе
		СсылкаДляСкачиванияДокумента = СсылкаПоиска;
	КонецЕсли;
	
	Отказ = Ложь;
	РезультатПоиска = ИнтеграцияShare.РезультатПоискаДокументаПоПубличнойСсылке(СсылкаДляСкачиванияДокумента, Отказ,
		ТекстОшибки);
	
	ОчиститьДанныеФормыПоСсылке();
	ОчиститьКомандыВПодменюЗагрузитьКак();
	
	Если Отказ Тогда
		УстановитьВидимостьРезультатаПоиска(Истина, ТекстОшибки);
		Возврат;
	ИначеЕсли РезультатПоиска = Неопределено Тогда
		ДокументНеНайден = Истина;
		УстановитьВидимостьРезультатаПоиска(Истина, ТекстОшибки);
		Возврат;
	ИначеЕсли ЗначениеЗаполнено(ТекстОшибки) Тогда
		ОбщегоНазначения.СообщитьПользователю(ТекстОшибки);
	КонецЕсли;
	
	ИспользоватьФормуЗагрузкиДокументаПоУмолчанию = РезультатПоиска.НастройкиЗагрузки.ИспользоватьФормуЗагрузкиДокументаПоУмолчанию;
	
	ОписаниеЭлектронногоДокумента = РезультатПоиска.ОписаниеЭлектронногоДокумента;
	Если ОписаниеЭлектронногоДокумента.ДоступКДокументуЗакрыт Или ОписаниеЭлектронногоДокумента.ДокументНеНайден Тогда
		ДоступКДокументуЗакрыт = ОписаниеЭлектронногоДокумента.ДоступКДокументуЗакрыт;
		ДокументНеНайден = ОписаниеЭлектронногоДокумента.ДокументНеНайден;
		УстановитьВидимостьРезультатаПоиска(Истина);
		Возврат;
	КонецЕсли;
	
	Если Не ИспользоватьФормуЗагрузкиДокументаПоУмолчанию Тогда
		Возврат;
	КонецЕсли;
	
	ЗаполнитьСтраницуЗагрузкиДокумента(РезультатПоиска.НастройкиЗагрузки.ПараметрыОтраженияВУчете);
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьСтраницуЗагрузкиДокумента(ПараметрыОтраженияВУчете)
	
	ЕстьНесколькоСпособовОтражения = ПараметрыОтраженияВУчете.Количество() > 1;

	Для Каждого СтрокаПараметра Из ПараметрыОтраженияВУчете Цикл
		Если ЗначениеЗаполнено(СтрокаПараметра.СсылкаНаОбъектУчетаВБазе) Тогда
			СсылкаНаОбъектУчета = СтрокаПараметра.СсылкаНаОбъектУчетаВБазе;
		ИначеЕсли ЕстьНесколькоСпособовОтражения Тогда
			ИндексПараметра = ПараметрыОтраженияВУчете.Индекс(СтрокаПараметра);
			НаименованиеКоманды = СтрШаблон("ЗагрузитьКак_%1", ИндексПараметра);
			СоздатьКомандуВПодменюЗагрузитьКак(НаименованиеКоманды, СтрокаПараметра.ПредставлениеВПодменюЗагрузить,
				СтрокаПараметра.КартинкаВПодменюЗагрузить);

			СписокКомандЗагрузитьКак.Добавить(НаименованиеКоманды, СтрокаПараметра.ПредставлениеВПодменюЗагрузить);
			СпособОтраженияВУчетеПоКомандам.Добавить(СтрокаПараметра.ПредставлениеВПодменюЗагрузить,
				СтрокаПараметра.СпособОтраженияВУчете);
		Иначе
			Элементы.ЗагрузитьДокумент.Заголовок = СтрШаблон(НСтр("ru = 'Загрузить как ""%1""'",
				ОбщегоНазначения.КодОсновногоЯзыка()), СтрокаПараметра.СпособОтраженияВУчете);
			СпособОтраженияВУчете = СтрокаПараметра.СпособОтраженияВУчете;
		КонецЕсли;
		ПредставлениеДокумента = СтрокаПараметра.ПредставлениеДокумента;
	КонецЦикла;
	
	ТипДокументаНеПоддерживается = ПустаяСтрока(СпособОтраженияВУчете)
		И Не ЕстьНесколькоСпособовОтражения И Не ЗначениеЗаполнено(СсылкаНаОбъектУчета);

	ЗаполнитьСписокФайловВизуализации(ОписаниеЭлектронногоДокумента.ДанныеФайловДокумента);

	УстановитьВидимостьРезультатаПоиска();
	
КонецПроцедуры

&НаКлиенте
Процедура ПроверитьВалидностьСсылкиНаДокумент(Отказ)
	
	ОчиститьСообщения();
	
	Если ПустаяСтрока(СсылкаПоиска) Тогда
		ОбщегоНазначенияКлиент.СообщитьПользователю(НСтр("ru = 'Не заполнена ссылка на документ'",
			ОбщегоНазначенияКлиент.КодОсновногоЯзыка()), , , "СсылкаПоиска");
		Отказ = Истина;
	ИначеЕсли ИнтеграцияShareКлиентСервер.ЭтоДоменСервисаКороткихСсылокShare(СсылкаПоиска) Тогда
		// ссылка валидна
		Возврат;
	ИначеЕсли ИнтеграцияShareКлиент.ЭтоДоменСервисаОнлайнЗаказы(СсылкаПоиска) Тогда
		ЭтоСсылкаОнлайнЗаказа = Истина;
	Иначе
		ДокументНеНайден = Истина;
		УстановитьВидимостьОшибокПоискаДокумента(ЭтотОбъект, Элементы);
		Отказ = Истина;
	КонецЕсли;

КонецПроцедуры

&НаСервере
Процедура ОчиститьКомандыВПодменюЗагрузитьКак()
	
	Для Каждого ЭлементСписка Из СписокКомандЗагрузитьКак Цикл
		КнопкаЗагрузитьКак = Элементы.Найти(ЭлементСписка.Значение);
		
		Если КнопкаЗагрузитьКак <> Неопределено Тогда
			Элементы.Удалить(КнопкаЗагрузитьКак);
		КонецЕсли;
		
	КонецЦикла;
	
	СписокКомандЗагрузитьКак.Очистить();
	СпособОтраженияВУчетеПоКомандам.Очистить();
	
КонецПроцедуры

&НаСервере
Процедура ОчиститьДанныеФормыПоСсылке()
	
	ДокументНеНайден               = Ложь;
	ДоступКДокументуЗакрыт         = Ложь;
	ЕстьНесколькоСпособовОтражения = Ложь;
	СсылкаНаОбъектУчета            = Неопределено;
	СпособОтраженияВУчете          = "";
	
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьНавигационнуюСсылку(НавигационнаяСсылка)
	
	Если ПустаяСтрока(НавигационнаяСсылка) Тогда
		Возврат;
	КонецЕсли;
	
	ФайловаяСистемаКлиент.ОткрытьНавигационнуюСсылку(НавигационнаяСсылка);
	
КонецПроцедуры

#КонецОбласти

#Область ЗагрузкаДокумента

&НаКлиенте
Процедура ЗагрузитьДокументПоПубличнойСсылке()
	
	Оповещение = Новый ОписаниеОповещения("ОбработатьРезультатЗагрузкиДокументаПоПубличнойСсылке", ЭтотОбъект);
	
	ИнтеграцияShareКлиент.ЗагрузитьЭлектронныйДокументПоИдентификаторуВФоне(ОписаниеЭлектронногоДокумента, Оповещение,
		ЭтотОбъект);

КонецПроцедуры

&НаКлиенте
Процедура ОбработатьРезультатЗагрузкиДокументаПоПубличнойСсылке(Результат, ДополнительныеПараметры) Экспорт
	
	ДанныеДокумента = ИнтеграцияShareКлиент.РезультатОперацииВФоне(Результат);
	
	Если ДанныеДокумента = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ДанныеДокумента.СпособОтраженияВУчете = СпособОтраженияВУчете;
	
	СтандартнаяОбработка = Истина;
	ИнтеграцияShareКлиентПереопределяемый.ПриЗагрузкеДокументаПоСсылке(ДанныеДокумента, СтандартнаяОбработка);

	Если СтандартнаяОбработка = Ложь Тогда
		Если Открыта() Тогда
			Закрыть();
		КонецЕсли;
		
		Возврат;
	КонецЕсли;
	
	ДанныеЗагрузки = ДанныеДокумента.ДанныеЗагрузкиДокумента;
	Если ЗначениеЗаполнено(ДанныеЗагрузки)
		И ЗначениеЗаполнено(ДанныеЗагрузки.ОбъектУчета) Тогда
		СсылкаНаОбъектУчета = ДанныеЗагрузки.ОбъектУчета;
		УстановитьВидимостьОжиданияЗагрузки(Элементы, Ложь);
		УстановитьВидимостьСтраницыЗагрузки(ЭтотОбъект, Элементы);
		Возврат;
	КонецЕсли;
	
	Оповещение = Новый ОписаниеОповещения("ОбработатьРезультатЗагрузкиДокументаЗавершение", ЭтотОбъект);

	ИнтеграцияShareКлиент.ЗагрузитьЭлектронныйДокументВОбъектУчетаВФоне(ДанныеДокумента, Оповещение, ЭтотОбъект,
		УникальныйИдентификатор);

КонецПроцедуры

&НаКлиенте
Процедура ОбработатьРезультатЗагрузкиДокументаЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	ДанныеДокумента = ИнтеграцияShareКлиент.РезультатОперацииВФоне(Результат);
	
	Если ДанныеДокумента = Неопределено Тогда
		УстановитьВидимостьОжиданияЗагрузки(Элементы, Ложь);
		Возврат;
	КонецЕсли;
	
	ОповещениеПриЗавершении = Новый ОписаниеОповещения("ОбработатьРезультатЗагрузкиДокументаЗавершение", ЭтотОбъект);
	
	Если ДанныеДокумента.ТребуетсяСопоставлениеНоменклатуры Тогда
		
		ДанныеДокумента.ТребуетсяСопоставлениеНоменклатуры = Ложь;
		
		ДополнительныеПараметры = Новый Структура;
		ДополнительныеПараметры.Вставить("ДанныеДокумента", ДанныеДокумента);
		ДополнительныеПараметры.Вставить("ОповещениеПриЗавершении", ОповещениеПриЗавершении);
		ДополнительныеПараметры.Вставить("ЕстьФормаВладелец", Истина);

		Оповещение = Новый ОписаниеОповещения("ЗагрузитьЭлектронныйДокументПослеСопоставления", ИнтеграцияShareКлиент,
			ДополнительныеПараметры);

		ИнтеграцияShareКлиент.ОткрытьФормуСопоставленияНоменклатурыПриЗагрузкиДокумента(ДанныеДокумента, Оповещение);
		
		Возврат;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ДанныеДокумента.ДокументУчета) Тогда
		СсылкаНаОбъектУчета = ДанныеДокумента.ДокументУчета;
		УстановитьВидимостьСтраницыЗагрузки(ЭтотОбъект, Элементы);
		УстановитьВидимостьОжиданияЗагрузки(Элементы, Ложь);

		ИнтеграцияShareКлиент.ПослеЗагрузкиДокументаПоСсылке(ДанныеДокумента);
		Возврат;
	КонецЕсли;
	
	ИнтеграцияShareКлиент.СоздатьВУчетеЭлектронныйДокументВФоне(ДанныеДокумента,
		ОповещениеПриЗавершении, ЭтотОбъект, УникальныйИдентификатор);
	
КонецПроцедуры

#КонецОбласти

#Область РаботаСДокументомPDF

&НаСервере
Процедура ОтобразитьЭлементыДокументаPDF()
	
	Если ЭтоМобильныйКлиент Тогда
		// Для мобильного клиента не поддержана работа с PDF документом
		Элементы.ГруппаДокумент.Видимость = Ложь;
		Возврат;
	КонецЕсли;
	
	СведенияОДокументеPDF = НовыеСведенияОPDFДокументеНаФорме();
	СведенияОДокументеPDF.ИмяРеквизита = ИмяЭлементаДокументаPDFРеквизит();
	СведенияОДокументеPDF.ИмяЭлемента = ИмяЭлементаДокументаPDFПоле();
	СведенияОДокументеPDF.ИмяРодителяЭлемента = Элементы.ГруппаДокументPDF.Имя;
	СведенияОДокументеPDF.ИмяРодителяКоманды = Элементы.КоманднаяПанельPDF.Имя;
	
	ВывестиPDFДокументНаФорму(ЭтотОбъект, СведенияОДокументеPDF);

КонецПроцедуры

&НаСервереБезКонтекста
Функция ИмяЭлементаДокументаPDFРеквизит()
	
	Возврат "ДокументPdfРеквизит";
	
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Функция ИмяЭлементаДокументаPDFПоле()
	
	Возврат "ДокументPdfПоле";
	
КонецФункции

// Конструктор сведений о PDF документе.
//
// Возвращаемое значение:
//  Структура - Структура с ключами:
//   * ИмяРеквизита - Строка - Имя реквизита pdf
//   * ИмяЭлемента - Строка - Имя элемента
//   * ИмяРодителяЭлемента - Строка - Имя родителя элемента
//   * ИмяРодителяКоманды- Строка - Имя родителя команд
//
&НаСервереБезКонтекста
Функция НовыеСведенияОPDFДокументеНаФорме()
	
	СведенияОPDFДокументе = Новый Структура;
	СведенияОPDFДокументе.Вставить("ИмяРеквизита", "");
	СведенияОPDFДокументе.Вставить("ИмяЭлемента", "");
	СведенияОPDFДокументе.Вставить("ИмяРодителяЭлемента", "");
	СведенияОPDFДокументе.Вставить("ИмяРодителяКоманды", "");
	
	Возврат СведенияОPDFДокументе;
	
КонецФункции

// Проверяет и добавляет программно реквизит, поле ДокументPDF на форму 
// и команды для управления документом.
//
// Параметры:
//  Форма - Форма - Необходимая форма
//  СведенияОДокументеPDF - Структура - Сведения о документе pdf с ключами:
//   * ИмяРеквизита - Строка - Имя реквизита pdf
//   * ИмяЭлемента - Строка - Имя элемента
//   * ИмяРодителяЭлемента - Строка - Имя группы для документа PDF.
//   * ИмяРодителяКоманд - Строка - Имя группы с командами.
//
&НаСервереБезКонтекста
Процедура ВывестиPDFДокументНаФорму(Форма, СведенияОДокументеPDF)
	
	Если Не РеквизитСуществует(Форма, СведенияОДокументеPDF.ИмяРеквизита) Тогда
		РеквизитДокументPDF = Новый РеквизитФормы(СведенияОДокументеPDF.ИмяРеквизита,
			Новый ОписаниеТипов("ДокументPDF"));
		Форма.ИзменитьРеквизиты(ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(РеквизитДокументPDF));
	Иначе
		// Все элементы для отображения PDF документа уже созданы на форме.
		Возврат;
	КонецЕсли;
	
	ЭлементРодительПоляPDFДокумента = Форма.Элементы.Найти(СведенияОДокументеPDF.ИмяРодителяЭлемента);
	Если ЭлементРодительПоляPDFДокумента <> Неопределено Тогда
		ДобавитьПолеPDFДокумента(Форма,
			СведенияОДокументеPDF.ИмяЭлемента,
			ЭлементРодительПоляPDFДокумента,
			СведенияОДокументеPDF.ИмяРеквизита);
	КонецЕсли;
	
	ЭлементРодительКомандыМасштаб = Форма.Элементы.ГруппаКнопокМасштаб;
	ЭлементРодительКомандыПоворот = Форма.Элементы.ГруппаКнопокПоворот;
	ЭлементРодительПечать         = Форма.Элементы.ГруппКнопокПечать;
	
	// Добавление кнопки уменьшения масштаба
	
	ИмяКомандыФормы = "Подключаемый_МасштабМинус";
		
	СозданнаяКоманда = ДобавитьКоманду(
		Форма,
		ИмяКомандыФормы,
		НСтр("ru = 'Уменьшить'"),
		НСтр("ru = 'Уменьшить'"),
		БиблиотекаКартинок.УменьшитьМасштаб);
	СозданнаяКоманда.Действие = ИмяКомандыФормы;
	
	ДобавитьКнопку(Форма, "Уменьшить", ЭлементРодительКомандыМасштаб, ИмяКомандыФормы);
	
	// Добавление кнопки увеличения масштаба
	
	ИмяКомандыФормы = "Подключаемый_МасштабПлюс";
	
	СозданнаяКоманда = ДобавитьКоманду(
		Форма,
		ИмяКомандыФормы,
		НСтр("ru = 'Увеличить'"),
		НСтр("ru = 'Увеличить'"),
		БиблиотекаКартинок.УвеличитьМасштаб);
	СозданнаяКоманда.Действие = ИмяКомандыФормы;
	
	ДобавитьКнопку(Форма, "Увеличить", ЭлементРодительКомандыМасштаб, ИмяКомандыФормы);
	
	// Добавление кнопки поворота ориентации налево
	ИмяКомандыФормы = "Подключаемый_ПоворотЛево";
	
	СозданнаяКоманда = ДобавитьКоманду(
		Форма,
		ИмяКомандыФормы,
		НСтр("ru = 'Повернуть по часовой стрелке'"),
		НСтр("ru = 'Повернуть по часовой стрелке'"),
		БиблиотекаКартинок.ПовернутьПоЧасовойСтрелке);
	СозданнаяКоманда.Действие = ИмяКомандыФормы;
	
	ДобавитьКнопку(Форма, "ПоворотЛево", ЭлементРодительКомандыПоворот, ИмяКомандыФормы);
	
	// Добавление кнопки поворота ориентации направо
	ИмяКомандыФормы = "Подключаемый_ПоворотПраво";
		
	СозданнаяКоманда = ДобавитьКоманду(
		Форма,
		ИмяКомандыФормы,
		НСтр("ru = 'Повернуть против часовой стрелки'"),
		НСтр("ru = 'Повернуть против часовой стрелки'"),
		БиблиотекаКартинок.ПовернутьПротивЧасовойСтрелки);
	СозданнаяКоманда.Действие = ИмяКомандыФормы;
	
	ДобавитьКнопку(Форма, "ПоворотПраво", ЭлементРодительКомандыПоворот, ИмяКомандыФормы);
	
	// Добавление кнопки печать
	ИмяКомандыФормы = "Подключаемый_Печать";
		
	СозданнаяКоманда = ДобавитьКоманду(
		Форма,
		ИмяКомандыФормы,
		НСтр("ru = 'Печать'"),
		НСтр("ru = 'Печать'"),
		БиблиотекаКартинок.Печать);
	СозданнаяКоманда.Действие = ИмяКомандыФормы;
	
	ДобавитьКнопку(Форма, "Печать", ЭлементРодительПечать, ИмяКомандыФормы);
	
КонецПроцедуры

// Добавляет команду формы.
//
// Параметры:
//  Форма - ФормаКлиентскогоПриложения - Форма.
//  Имя - Строка - Уникальное имя добавляемой команды.
//  Заголовок - Строка - Заголовок добавляемой команды.
//  Подсказка - Строка - Подсказка добавляемой команды.
//  Картинка - Картинка, Неопределено - Картинка добавляемой команды.
// 
// Возвращаемое значение:
//  КомандыФормы - Команда формы.
//
&НаСервереБезКонтекста
Функция ДобавитьКоманду(Форма, Имя, Заголовок, Подсказка, Картинка = Неопределено)
	
	СозданнаяКоманда = Форма.Команды.Добавить(Имя);
	СозданнаяКоманда.Действие = "Подключаемый_Команда";
	СозданнаяКоманда.Заголовок = Заголовок;
	СозданнаяКоманда.Подсказка = Подсказка;
	Если Картинка <> Неопределено Тогда
		СозданнаяКоманда.Картинка = Картинка;
		СозданнаяКоманда.Отображение = ОтображениеКнопки.Картинка;
	КонецЕсли;
	
	Возврат СозданнаяКоманда;
	
КонецФункции

// Добавляет кнопку формы.
//
// Параметры:
//  Форма - ФормаКлиентскогоПриложения - Форма.
//  Имя - Строка - Уникальное имя добавляемой команды.
//  Родитель - ГруппаФормы, ТаблицаФормы, ФормаКлиентскогоПриложения - Родитель для добавляемого элемента.
//  ИмяКоманды - Строка - Имя команды.
//
// Возвращаемое значение:
//  КнопкаФормы - Кнопка формы.
//
&НаСервереБезКонтекста
Функция ДобавитьКнопку(Форма, Имя, Родитель, ИмяКоманды)
	
	СозданныйЭлемент = Форма.Элементы.Добавить(Имя, Тип("КнопкаФормы"), Родитель);
	СозданныйЭлемент.ИмяКоманды = ИмяКоманды;
	СозданныйЭлемент.ОтображениеФигуры = ОтображениеФигурыКнопки.Нет;
	
	Возврат СозданныйЭлемент;
	
КонецФункции

// Проверяет, существует ли реквизит формы.
//
// Параметры:
//  Форма - ФормаКлиентскогоПриложения - Форма.
//  Имя - Строка - имя реквизита формы.
//
// Возвращаемое значение:
//  Булево - признак существует ли реквизит на форме.
//
&НаСервереБезКонтекста
Функция РеквизитСуществует(Форма, Имя)
	
	Реквизиты = Форма.ПолучитьРеквизиты();
	
	Для Каждого Реквизит Из Реквизиты Цикл
		Если Реквизит.Имя = Имя Тогда
			Возврат Истина;
		КонецЕсли;
	КонецЦикла;
	
	Возврат Ложь;
	
КонецФункции

// Добавляет поле ввода формы.
//
// Параметры:
//  Форма - ФормаКлиентскогоПриложения - Форма.
//  Имя - Строка - Уникальное имя добавляемого элемента.
//  Родитель - ГруппаФормы, ТаблицаФормы, ФормаКлиентскогоПриложения - Родитель для добавляемого элемента.
//  ПутьКДанным - Строка - Путь к реквизиту формы.
// 
// Возвращаемое значение:
//  ПолеФормы - Поле ввода формы.
//
&НаСервереБезКонтекста
Функция ДобавитьПолеPDFДокумента(Форма, Имя, Родитель, ПутьКДанным)
	
	СозданныйЭлемент = Форма.Элементы.Добавить(Имя, Тип("ПолеФормы"), Родитель);
	СозданныйЭлемент.Вид = ВидПоляФормы.ПолеPDFДокумента;
	СозданныйЭлемент.ПутьКДанным = ПутьКДанным;
	СозданныйЭлемент.ПоложениеЗаголовка = ПоложениеЗаголовкаЭлементаФормы.Нет;
	СозданныйЭлемент.ОтображениеПодсказки = ОтображениеПодсказки.Нет;
	
	Возврат СозданныйЭлемент;
	
КонецФункции

#КонецОбласти

#Область УправлениеЭлементамиФормы

&НаСервере
Процедура СоздатьКомандуВПодменюЗагрузитьКак(НаименованиеКоманды, ЗаголовокКоманды, КартинкаКоманды)
	
	Если Команды.Найти(НаименованиеКоманды) = Неопределено Тогда
		НоваяКоманда = Команды.Добавить(НаименованиеКоманды);
		НоваяКоманда.Действие = "ЗагрузитьДокумент";
	КонецЕсли;
	
	Если Элементы.Найти(НаименованиеКоманды) <> Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	НовыйЭлемент = Элементы.Добавить(НаименованиеКоманды, Тип("КнопкаФормы"), Элементы.ЗагрузитьКак);
	НовыйЭлемент.ИмяКоманды                = НаименованиеКоманды;
	НовыйЭлемент.ПоложениеВКоманднойПанели = ПоложениеКнопкиВКоманднойПанели.ВКоманднойПанели;
	НовыйЭлемент.Заголовок                 = ЗаголовокКоманды;
	
	Если ЗначениеЗаполнено(КартинкаКоманды) Тогда
		НовыйЭлемент.Картинка = КартинкаКоманды;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Процедура УстановитьВидимостьОшибокПоискаДокумента(ОбъектФормы, ЭлементыФормы)
	
	ИмяЭлементаСтраницыСообщенийДляВнимания = ЭлементыФормы.СтраницыСообщенийДляВнимания.Имя;
	
	Если ОбъектФормы.ДокументНеНайден Тогда
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(ЭлементыФормы,
			ИмяЭлементаСтраницыСообщенийДляВнимания, "ТекущаяСтраница", ЭлементыФормы.СтраницаДокументНеНайден);
		ВидимостьСтраницаСообщенийДляВнимания = Истина;
	ИначеЕсли ОбъектФормы.ДоступКДокументуЗакрыт Тогда
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(ЭлементыФормы,
			ИмяЭлементаСтраницыСообщенийДляВнимания, "ТекущаяСтраница", ЭлементыФормы.СтраницаДоступЗакрыт);
		ВидимостьСтраницаСообщенийДляВнимания = Истина;
	Иначе
		ВидимостьСтраницаСообщенийДляВнимания = Ложь;
	КонецЕсли;
		
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(ЭлементыФормы,
			ИмяЭлементаСтраницыСообщенийДляВнимания, "Видимость", ВидимостьСтраницаСообщенийДляВнимания);
	
	УстановитьВидимостьСтраницыПодвалаПоиска(ЭлементыФормы, Ложь);
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Процедура УстановитьВидимостьФормыПриОткрытии(ЭлементыФормы)
		
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(ЭлементыФормы,
		ЭлементыФормы.СтраницыСообщенийДляВнимания.Имя, "Видимость", Ложь);
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(ЭлементыФормы,
		ЭлементыФормы.ФормаОткрытьДокументВВебе.Имя, "Видимость", Ложь);
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(ЭлементыФормы,
		ЭлементыФормы.ФормаСкачатьПолныйПакет.Имя, "Видимость", Ложь);
	
	УстановитьВидимостьСтраницыФормы(ЭлементыФормы);
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Процедура УстановитьВидимостьСтраницыФормы(ЭлементыФормы)
	
	УстановитьВидимостьСтраницы(ЭлементыФормы, ЭлементыФормы.СтраницыФормы);
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Процедура УстановитьВидимостьСтраницы(ЭлементыФормы, ЭлементыФормыСтраницы)
	
	Для Каждого Страница Из ЭлементыФормыСтраницы.ПодчиненныеЭлементы Цикл
		Видимость = Страница = ЭлементыФормыСтраницы.ТекущаяСтраница;
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(ЭлементыФормы, Страница.Имя, "Видимость",
			Видимость);
	КонецЦикла;
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Процедура УстановитьВидимостьОжиданияЗагрузки(ЭлементыФормы, Знач Видимость)
	
	Если Видимость Тогда
		ТекущаяСтраница = ЭлементыФормы.СтраницаОжидания;
	Иначе
		ТекущаяСтраница = ЭлементыФормы.СтраницаДокументСервиса;
	КонецЕсли;

	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(ЭлементыФормы,
		ЭлементыФормы.СтраницыОбработкиДокумента.Имя, "ТекущаяСтраница", ТекущаяСтраница);

	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(ЭлементыФормы,
		ЭлементыФормы.ФормаОткрытьДокументВВебе.Имя, "Видимость", Не Видимость);

	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(ЭлементыФормы,
		ЭлементыФормы.ФормаСкачатьПолныйПакет.Имя, "Видимость", Не Видимость);
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Процедура УстановитьВидимостьСтраницыПодвалаПоиска(ЭлементыФормы, Знач ОтобразитьОжидание)
	
	Если ОтобразитьОжидание Тогда
		ТекущаяСтраница = ЭлементыФормы.СтраницаОжиданияПоиска;
	Иначе
		ТекущаяСтраница = ЭлементыФормы.СтраницаПриОткрытии;
	КонецЕсли;

	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(ЭлементыФормы,
		ЭлементыФормы.СтраницыПодвалаПоискаПоСсылке.Имя, "ТекущаяСтраница", ТекущаяСтраница);

КонецПроцедуры

&НаСервере
Процедура УстановитьВидимостьРезультатаПоиска(Знач ЕстьОшибка = Ложь, Знач ТекстПричиныОшибки = "")
	
	Если ЕстьОшибка Или ДоступКДокументуЗакрыт Или ДокументНеНайден Тогда

		УстановитьВидимостьОшибокПоискаДокумента(ЭтотОбъект, Элементы);
		Если Не ПустаяСтрока(ТекстПричиныОшибки) Тогда
			ОбщегоНазначения.СообщитьПользователю(ТекстПричиныОшибки);
		КонецЕсли;

		Возврат;
	КонецЕсли;

	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, Элементы.ГруппаЭлектронныйДокумент.Имя,
		"Заголовок", СтрШаблон("""%1"" от ""%2""", ОписаниеЭлектронногоДокумента.ПредставлениеДокумента,
		ОписаниеЭлектронногоДокумента.НаименованиеОтправителя));

	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, Элементы.ФормаОткрытьДокументВВебе.Имя,
		"Видимость", Истина);

	ЕстьСсылкаДляСкачиванияПолногоПакета = ДанныеАрхиваВсехФайлов <> Неопределено И Не ПустаяСтрока(
		ДанныеАрхиваВсехФайлов.СсылкаСкачиванияИсходногоФайла);
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, Элементы.ФормаСкачатьПолныйПакет.Имя,
		"Видимость", ЕстьСсылкаДляСкачиванияПолногоПакета);

	Команды.ОткрытьДокументВВебе.Подсказка = СсылкаДляСкачиванияДокумента;

	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, Элементы.СтраницыФормы.Имя,
		"ТекущаяСтраница", Элементы.СтраницаДокумента);

	Заголовок = НСтр("ru = 'Электронный документ по ссылке'", ОбщегоНазначения.КодОсновногоЯзыка());
	
	Если ТипДокументаНеПоддерживается Тогда
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, Элементы.ГруппаВыбораЗагрузки.Имя,
			"Видимость", Ложь);
		ОбщегоНазначения.СообщитьПользователю(
			СтрШаблон(НСтр("ru = 'Загрузка документа с типом документа ""%1"" не поддерживается.'"),
			ОписаниеЭлектронногоДокумента.ТипЭлектронногоДокумента));
	КонецЕсли;
	
	УстановитьВидимостьСтраницыЗагрузки(ЭтотОбъект, Элементы);
	УстановитьВидимостьСтраницыФормы(Элементы);

КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Процедура УстановитьВидимостьСтраницыЗагрузки(ОбъектФормы, Элементы)
	
	ТекущаяСтраницаЗагрузки = Неопределено;
	Если ЗначениеЗаполнено(ОбъектФормы.СсылкаНаОбъектУчета) Тогда
		ТекущаяСтраницаЗагрузки = Элементы.СтраницаДокументЗагружен;
	ИначеЕсли ОбъектФормы.ЕстьНесколькоСпособовОтражения Тогда
		ТекущаяСтраницаЗагрузки = Элементы.СтраницаЗагрузитьКак;
	ИначеЕсли Не ПустаяСтрока(ОбъектФормы.СпособОтраженияВУчете) Тогда
		ТекущаяСтраницаЗагрузки = Элементы.СтраницаЗагрузить;
	Иначе
		Возврат;
	КонецЕсли;
	
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, Элементы.СтраницыЗагрузки.Имя,
		"ТекущаяСтраница", ТекущаяСтраницаЗагрузки);
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Процедура УстановитьВидимостьСтраницыПредставленияФайла(ЭлементыФормы, ТекущиеДанные)
	
	Если ПустаяСтрока(ТекущиеДанные.СсылкаСкачиванияФайлаВизуализации) Тогда
		ТекущаяСтраницаПредставления = ЭлементыФормы.СтраницаФайлБезПредставления;
	ИначеЕсли ЗначениеЗаполнено(ТекущиеДанные.ДвоичныеДанныеФайлаВизуализации) Тогда
		ТекущаяСтраницаПредставления = ЭлементыФормы.СтраницаДокументPDF;
	ИначеЕсли Не ПустаяСтрока(ТекущиеДанные.ТекстОшибкиФайлаВизуализации) Тогда
		ТекущаяСтраницаПредставления = ЭлементыФормы.СтраницаФайлОшибка;
	Иначе
		ТекущаяСтраницаПредставления = ЭлементыФормы.СтраницаОжиданияЗагрузкиФайла;
	КонецЕсли;
		
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(ЭлементыФормы,
			ЭлементыФормы.СтраницыПредставленияФайла.Имя, "ТекущаяСтраница", ТекущаяСтраницаПредставления);
	
КонецПроцедуры

#КонецОбласти

#Область РаботаСФайлами

&НаКлиентеНаСервереБезКонтекста
Функция ТипыФайла()
	
	ТипыФайлов = Новый Структура;
	ТипыФайлов.Вставить("ИсходныйФайл", "ИсходныйФайл");
	ТипыФайлов.Вставить("ФайлВизуализации", "ФайлВизуализации");
	Возврат ТипыФайлов;
	
КонецФункции

&НаСервере
Процедура ЗаполнитьСписокФайловВизуализации(ДанныеФайловДокумента)
	
	Если Не ЗначениеЗаполнено(ДанныеФайловДокумента) Тогда
		Элементы.ГруппаДанныеДокумента.Видимость = Ложь;
		Возврат;
	КонецЕсли;
	
	Для Каждого ДанныеФайла Из ДанныеФайловДокумента Цикл
		
		Если ДанныеФайла.ВидФайла = ИнтеграцияShareКлиентСервер.ВидыФайловДокумента().ФайлВизуализации Тогда
			НоваяСтрока = СписокФайлов.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, ДанныеФайла);
			НоваяСтрока.ИндексКартинкиФайла = ИнтеграцияShareКлиентСервер.ПолучитьИндексПиктограммыФайла(
				НоваяСтрока.РасширениеФайла);
			НоваяСтрока.ОсновнойФайл        = Истина;
			
			ЗапуститьПолучениеФайловВизуализацииПоВнешнейСсылкеВФоне(НоваяСтрока);
			
		ИначеЕсли ДанныеФайла.ВидФайла = ИнтеграцияShareКлиентСервер.ВидыФайловДокумента().ГлавныйФайл Тогда
			
			ДанныеАрхиваВсехФайлов = Новый Структура;
			ДанныеАрхиваВсехФайлов.Вставить("Идентификатор", ДанныеФайла.ИдентификаторФайла);
			ДанныеАрхиваВсехФайлов.Вставить("Представление", ДанныеФайла.ПредставлениеФайла);
			ДанныеАрхиваВсехФайлов.Вставить("СсылкаСкачиванияФайлаВизуализации", ДанныеФайла.СсылкаСкачиванияФайлаВизуализации);
			ДанныеАрхиваВсехФайлов.Вставить("СсылкаСкачиванияИсходногоФайла", ДанныеФайла.СсылкаСкачиванияИсходногоФайла);
			ДанныеАрхиваВсехФайлов.Вставить("ДвоичныеДанныеФайлаВизуализации", Неопределено);
			ДанныеАрхиваВсехФайлов.Вставить("ДвоичныеДанныеИсходногоФайла", Неопределено);
			
		Иначе
			НоваяСтрока = СписокФайлов.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, ДанныеФайла);
			НоваяСтрока.ИндексКартинкиФайла = ИнтеграцияShareКлиентСервер.ПолучитьИндексПиктограммыФайла(
				НоваяСтрока.РасширениеФайла);
		
			ЗапуститьПолучениеФайловВизуализацииПоВнешнейСсылкеВФоне(НоваяСтрока);
		КонецЕсли;
		
	КонецЦикла;
	
	ОтобразитьЭлементыДокументаPDF();
	
	Если СписокФайлов.Количество() = 1 Тогда
		Элементы.ГруппаСписокФайлов.Видимость = Ложь;
	Иначе
		СписокФайлов.Сортировать("ОсновнойФайл Убыв, ПредставлениеФайла Возр");
		Элементы.ГруппаКолонокСкачать.Видимость = Ложь;
		Элементы.СписокФайлов.ТекущаяСтрока = СписокФайлов[0].ПолучитьИдентификатор();
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ЗапуститьПолучениеФайловВизуализацииПоВнешнейСсылкеВФоне(ТекущиеДанныеСтроки)

	Если ЭтоМобильныйКлиент
		Или ПустаяСтрока(ТекущиеДанныеСтроки.СсылкаСкачиванияФайлаВизуализации) Тогда
		Возврат;
	КонецЕсли;

	ДлительнаяОперацияПолученияФайла = ДвоичныеДанныеФайлаПоВнешнейСсылкеВФоне(
		ТекущиеДанныеСтроки.СсылкаСкачиванияФайлаВизуализации, ТекущиеДанныеСтроки.ИдентификаторФайла,
		ТекущиеДанныеСтроки.ПредставлениеФайла);

	Если ДлительнаяОперацияПолученияФайла = Неопределено Тогда
		Возврат;
	КонецЕсли;

	ДлительныеОперацииПолученияФайловВизуализации.Добавить(ДлительнаяОперацияПолученияФайла,
		ТекущиеДанныеСтроки.ИдентификаторФайла);
	
КонецПроцедуры

&НаСервере
Функция ДвоичныеДанныеФайлаПоВнешнейСсылкеВФоне(Знач СсылкаНаФайл, Знач ИдентификаторФайла,
	Знач ПредставлениеФайла)
	
	НаименованиеЗадания = СтрШаблон(НСтр("ru = '1С:Share. Получение файла %1 электронного документа из сервиса.'",
		ОбщегоНазначения.КодОсновногоЯзыка()), ПредставлениеФайла);
	
	КлючФоновогоЗадания = СтрШаблон("Share_%1", ИдентификаторФайла);
	
	ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияФункции(УникальныйИдентификатор);
	ПараметрыВыполнения.ЗапуститьВФоне              = Истина;
	ПараметрыВыполнения.КлючФоновогоЗадания         = КлючФоновогоЗадания;
	ПараметрыВыполнения.НаименованиеФоновогоЗадания = НаименованиеЗадания;
	
	Возврат ДлительныеОперации.ВыполнитьФункцию(ПараметрыВыполнения,
		"ИнтеграцияShare.ДвоичныеДанныеФайлаПоВнешнейСсылке",
		СсылкаНаФайл,
		ПредставлениеФайла);
		
КонецФункции

&НаКлиенте
Процедура ОжидатьЗавершенияПолученияФайловВизуализацииВФоне()
	
	Если ДлительныеОперацииПолученияФайловВизуализации.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;

	ПараметрыОжидания = ДлительныеОперацииКлиент.ПараметрыОжидания(ЭтотОбъект);
	ПараметрыОжидания.ВыводитьОкноОжидания = Ложь;
	ПараметрыОжидания.ВыводитьСообщения    = Ложь;

	Для Каждого ЭлементДлительнаяОперация Из ДлительныеОперацииПолученияФайловВизуализации Цикл
		ОповещениеПриЗавершении = Новый ОписаниеОповещения("ОбработатьРезультатФайлаВизуализацииПоURLСсылке", ЭтотОбъект,
			ЭлементДлительнаяОперация.Представление);

		ДлительныеОперацииКлиент.ОжидатьЗавершение(ЭлементДлительнаяОперация.Значение, ОповещениеПриЗавершении,
			ПараметрыОжидания);
	КонецЦикла;

	ДлительныеОперацииПолученияФайловВизуализации.Очистить();

КонецПроцедуры

&НаКлиенте
Процедура ОбработатьРезультатФайлаВизуализацииПоURLСсылке(Результат, ИдентификаторФайла) Экспорт
	
	НайденныеСтроки = СписокФайлов.НайтиСтроки(Новый Структура("ИдентификаторФайла", ИдентификаторФайла));

	Если Не ЗначениеЗаполнено(НайденныеСтроки) Тогда
		Возврат;
	КонецЕсли;
	
	СтрокаФайла = НайденныеСтроки[0];

	РезультатПолученияФайла = РезультатПолученияФайлаВФоне(Результат);

	Если РезультатПолученияФайла = Неопределено Тогда
		Возврат;
	КонецЕсли;

	ДвоичныеДанныеФайла = РезультатПолученияФайла.ДвоичныеДанныеФайла;
	Если ДвоичныеДанныеФайла <> Неопределено Тогда
		СтрокаФайла.ДвоичныеДанныеФайлаВизуализации = ДвоичныеДанныеФайла;
		Если СтрокаФайла.СсылкаСкачиванияИсходногоФайла = СтрокаФайла.СсылкаСкачиванияФайлаВизуализации Тогда
			СтрокаФайла.ДвоичныеДанныеИсходногоФайла = ДвоичныеДанныеФайла;
		КонецЕсли;
	Иначе
		СтрокаФайла.ТекстОшибкиФайлаВизуализации = СтрШаблон(
			НСтр("ru = 'При получении файла для предпросмотра возникла ошибка:
				| %1'", ОбщегоНазначенияКлиент.КодОсновногоЯзыка()), 
				СтрСоединить(РезультатПолученияФайла.ОшибкиОбработкиФайла, Символы.ПС));
	КонецЕсли;

	Если Не (СписокФайлов.Количество() = 1
		Или Элементы.СписокФайлов.ТекущиеДанные.ИдентификаторФайла = ИдентификаторФайла) Тогда
		// Это не текущая строка списка файла, действие не требуется
		Возврат;
	КонецЕсли;

	УстановитьПредставлениеФайлаСписка(СтрокаФайла);
	
КонецПроцедуры

&НаКлиенте
Функция РезультатПолученияФайлаВФоне(Знач Результат)
	
	Если Результат = Неопределено Или ТипЗнч(Результат) <> Тип("Структура") Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	ОшибкиОбработкиФайла = Новый Массив;
	Если Результат.Статус = "Ошибка" Тогда
		ОшибкиОбработкиФайла.Добавить(ОбработкаОшибок.КраткоеПредставлениеОшибки(Результат.ИнформацияОбОшибке));
	КонецЕсли;
	
	Для Каждого Сообщение Из Результат.Сообщения Цикл
		ОшибкиОбработкиФайла.Добавить(Сообщение.Текст);
	КонецЦикла;

	ДвоичныеДанныеФайла = Неопределено;
	Если ЭтоАдресВременногоХранилища(Результат.АдресРезультата) Тогда
		ДвоичныеДанныеФайла = ПолучитьИзВременногоХранилища(Результат.АдресРезультата);
	КонецЕсли;
	
	РезультатПолученияФайла = Новый Структура();
	РезультатПолученияФайла.Вставить("ДвоичныеДанныеФайла", ДвоичныеДанныеФайла);
	РезультатПолученияФайла.Вставить("ОшибкиОбработкиФайла", ОшибкиОбработкиФайла);
	
	Возврат РезультатПолученияФайла;
	
КонецФункции

&НаКлиенте
Процедура УстановитьПредставлениеФайлаСписка(ТекущиеДанныеСтроки)
	
	Если Не ПустаяСтрока(ТекущиеДанныеСтроки.ТекстОшибкиФайлаВизуализации) Тогда
		ОбщегоНазначенияКлиент.СообщитьПользователю(
			ТекущиеДанныеСтроки.ТекстОшибкиФайлаВизуализации);
	КонецЕсли;
	
	ДвоичныеДанныеФайлаВизуализации = ТекущиеДанныеСтроки.ДвоичныеДанныеФайлаВизуализации;
	Если ЗначениеЗаполнено(ДвоичныеДанныеФайлаВизуализации) Тогда
		ПрочитатьДокументPDF(ДвоичныеДанныеФайлаВизуализации);
	КонецЕсли;
	
	УстановитьВидимостьСтраницыПредставленияФайла(Элементы, ТекущиеДанныеСтроки);
	
КонецПроцедуры

&НаСервере
Процедура ПрочитатьДокументPDF(ДвоичныеДанныеФайлаВизуализации)
	
	ПотокФайла = ДвоичныеДанныеФайлаВизуализации.ОткрытьПотокДляЧтения();
	ЭтотОбъект[ИмяЭлементаДокументаPDFРеквизит()].Прочитать(ПотокФайла);
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Функция ДанныеФайлаСкачивания()
	
	ДанныеФайла = Новый Структура;
	ДанныеФайла.Вставить("ИдентификаторФайла", "");
	ДанныеФайла.Вставить("ИмяФайла", "");
	ДанныеФайла.Вставить("СсылкаСкачиванияФайла", "");
	ДанныеФайла.Вставить("ОповещениеПриЗавершении", Неопределено);
	ДанныеФайла.Вставить("ДвоичныеДанные", Неопределено);
	ДанныеФайла.Вставить("ПолныйПутьСохранения", "");
	ДанныеФайла.Вставить("ТипФайла", "");
	
	Возврат ДанныеФайла;
	
КонецФункции

&НаКлиенте
Процедура ЗагрузитьФайлДляСкачиванияИСохранить(ДанныеФайла)
	
	ВыборФайла = Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.Сохранение);
	ВыборФайла.ПолноеИмяФайла = ДанныеФайла.ИмяФайла;
	
	ОписаниеОповещения = Новый ОписаниеОповещения(
		"ЗагрузитьФайлДляСкачиванияПослеВыбораФайла",
		ЭтотОбъект,
		ДанныеФайла);
	
	ФайловаяСистемаКлиент.ПоказатьДиалогВыбора(
		ОписаниеОповещения,
		ВыборФайла);
	
КонецПроцедуры

&НаКлиенте
Процедура ЗагрузитьФайлДляСкачиванияПослеВыбораФайла(РезультатВыбранногоФайла, ДанныеФайла) Экспорт
	
	Если РезультатВыбранногоФайла = Неопределено Тогда
		ОбщегоНазначенияКлиент.СообщитьПользователю(
			НСтр("ru = 'Не выбран каталог для сохранения файла'", ОбщегоНазначенияКлиент.КодОсновногоЯзыка()));
		Возврат;
	КонецЕсли;
	
	ДанныеФайла.ПолныйПутьСохранения = РезультатВыбранногоФайла[0];
	
	Если ЗначениеЗаполнено(ДанныеФайла.ДвоичныеДанные) Тогда
		СохранитьФайлНаДиск(ДанныеФайла);
		Возврат;
	КонецЕсли;
	
	ДлительнаяОперация = ДвоичныеДанныеФайлаПоВнешнейСсылкеВФоне(
		ДанныеФайла.СсылкаСкачиванияФайла,
		ДанныеФайла.ИдентификаторФайла,
		ДанныеФайла.ИмяФайла);
	
	Если ДлительнаяОперация = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ОповещениеПриЗавершении = Новый ОписаниеОповещения("ОбработатьРезультатЗагрузитьФайлДляСкачиванияИСохранить",
		ЭтотОбъект, ДанныеФайла);
	
	ПараметрыОжидания = ДлительныеОперацииКлиент.ПараметрыОжидания(ЭтотОбъект);
	ПараметрыОжидания.ВыводитьОкноОжидания = Истина;
	ПараметрыОжидания.ВыводитьСообщения    = Истина;
	
	ДлительныеОперацииКлиент.ОжидатьЗавершение(ДлительнаяОперация, ОповещениеПриЗавершении, ПараметрыОжидания);

КонецПроцедуры

&НаКлиенте
Процедура СохранитьФайлНаДиск(ДанныеФайла)

	Оповещение = Новый ОписаниеОповещения("РезультатСохраненияФайлаНаДиск", ЭтотОбъект, ДанныеФайла);
	ПараметрыСохранения = ФайловаяСистемаКлиент.ПараметрыСохраненияФайла();
	ПараметрыСохранения.Интерактивно = Ложь;
	АдресФайла = ПоместитьВоВременноеХранилище(ДанныеФайла.ДвоичныеДанные, УникальныйИдентификатор);

	ФайловаяСистемаКлиент.СохранитьФайл(Оповещение, АдресФайла, ДанныеФайла.ПолныйПутьСохранения, ПараметрыСохранения);

КонецПроцедуры

&НаКлиенте
Процедура РезультатСохраненияФайлаНаДиск(Результат, ДанныеФайла) Экспорт
	
	Если Не ЗначениеЗаполнено(Результат) Тогда
		ОбщегоНазначенияКлиент.СообщитьПользователю(
			СтрШаблон(НСтр("ru = 'Не удалось сохранить файл %1'", ОбщегоНазначенияКлиент.КодОсновногоЯзыка()),
				ДанныеФайла.ИмяФайла));
		Возврат;
	КонецЕсли;
	
	ОповеститьОбУспешномСохраненииФайла(Результат[0].ПолноеИмя);
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработатьРезультатЗагрузитьФайлДляСкачиванияИСохранить(Результат, ДанныеФайла) Экспорт
	
	РезультатПолученияФайла = РезультатПолученияФайлаВФоне(Результат);

	Если РезультатПолученияФайла = Неопределено Тогда
		Возврат;
	КонецЕсли;

	ДвоичныеДанныеФайла = РезультатПолученияФайла.ДвоичныеДанныеФайла;
	
	Если ДвоичныеДанныеФайла = Неопределено Тогда
		ТекстСообщения = СтрШаблон(НСтр("ru = 'Не удалось скачать файл %1 по причине:
										| %2'", ОбщегоНазначенияКлиент.КодОсновногоЯзыка()),
			СтрСоединить(РезультатПолученияФайла.ОшибкиОбработкиФайла, Символы.ПС), ДанныеФайла.ИмяФайла);
		ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения);
		Возврат;
	КонецЕсли;
	
	НайденныеСтроки = СписокФайлов.НайтиСтроки(Новый Структура("ИдентификаторФайла", ДанныеФайла.ИдентификаторФайла));
	
	Если ЗначениеЗаполнено(НайденныеСтроки) Тогда
		СтрокаФайла = НайденныеСтроки[0];
		Если СтрокаФайла <> Неопределено Тогда
			СтрокаФайла.ДвоичныеДанныеИсходногоФайла = ДвоичныеДанныеФайла;
		КонецЕсли;
	Иначе
		Если ДанныеФайла.ТипФайла = ТипыФайла().ФайлВизуализации Тогда
			ДанныеАрхиваВсехФайлов.ДвоичныеДанныеФайлаВизуализации = ДвоичныеДанныеФайла;
		Иначе
			ДанныеАрхиваВсехФайлов.ДвоичныеДанныеИсходногоФайла = ДвоичныеДанныеФайла;
		КонецЕсли;
	КонецЕсли;
	
	ДанныеФайла.ДвоичныеДанные = ДвоичныеДанныеФайла;
	СохранитьФайлНаДиск(ДанныеФайла);

	ОповеститьОбУспешномСохраненииФайла(ДанныеФайла.ПолныйПутьСохранения);
	
КонецПроцедуры

&НаКлиенте
Процедура ОповеститьОбУспешномСохраненииФайла(Знач ПолныйПутьСохраненияФайла)
	
	ПоказатьОповещениеПользователя(НСтр("ru = 'Файл успешно сохранен:'", ОбщегоНазначенияКлиент.КодОсновногоЯзыка()), ,
		ПолныйПутьСохраненияФайла, БиблиотекаКартинок.ДиалогИнформация);
	
КонецПроцедуры

#КонецОбласти

#КонецОбласти
