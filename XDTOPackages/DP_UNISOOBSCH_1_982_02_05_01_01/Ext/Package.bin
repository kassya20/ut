<package xmlns="http://v8.1c.ru/8.1/xdto" xmlns:xs="http://www.w3.org/2001/XMLSchema" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" targetNamespace="DP_UNISOOBSCH_1_982_02_05_01_01" elementFormQualified="true" attributeFormQualified="false">
	<property name="Файл">
		<typeDef xsi:type="ObjectType">
			<property name="ИдФайл" lowerBound="1" form="Attribute">
				<typeDef xsi:type="ValueType" base="xs:string" variety="Atomic" minLength="1" maxLength="255"/>
			</property>
			<property name="ВерсФорм" lowerBound="1" form="Attribute">
				<typeDef xsi:type="ValueType" base="xs:string" variety="Atomic" minLength="1" maxLength="5">
					<enumeration>5.01</enumeration>
				</typeDef>
			</property>
			<property name="ВерсПрог" lowerBound="1" form="Attribute">
				<typeDef xsi:type="ValueType" base="xs:string" variety="Atomic" minLength="1" maxLength="40"/>
			</property>
			<property name="Документ">
				<typeDef xsi:type="ObjectType">
					<property name="КНД" lowerBound="1" form="Attribute">
						<typeDef xmlns:d7p1="DP_UNISOOBSCH_1_982_02_05_01_01" xsi:type="ValueType" base="d7p1:КНДТип" variety="Atomic">
							<enumeration>1115144</enumeration>
						</typeDef>
					</property>
					<property name="СведУС">
						<typeDef xsi:type="ObjectType">
							<property xmlns:d8p1="DP_UNISOOBSCH_1_982_02_05_01_01" name="ДатаФорм" type="d8p1:ДатаТип" lowerBound="1" form="Attribute"/>
							<property xmlns:d8p1="DP_UNISOOBSCH_1_982_02_05_01_01" name="ВремФорм" type="d8p1:ВремяТип" lowerBound="1" form="Attribute"/>
							<property name="ИмяПолФайл" lowerBound="1" form="Attribute">
								<typeDef xsi:type="ValueType" base="xs:string" variety="Atomic" minLength="1" maxLength="255"/>
							</property>
						</typeDef>
					</property>
					<property name="СвСобытДок" upperBound="-1">
						<typeDef xsi:type="ObjectType">
							<property name="СтатусУС" lowerBound="1" form="Attribute">
								<typeDef xsi:type="ValueType" base="xs:string" variety="Atomic" length="4"/>
							</property>
							<property name="ТекстУС" lowerBound="0">
								<typeDef xsi:type="ValueType" base="xs:string" variety="Atomic" minLength="1" maxLength="10000"/>
							</property>
						</typeDef>
					</property>
					<property name="ОтпрУС">
						<typeDef xsi:type="ObjectType">
							<property name="ИдОтпрУС" lowerBound="1" form="Attribute">
								<typeDef xsi:type="ValueType" base="xs:string" variety="Atomic" minLength="4" maxLength="46"/>
							</property>
							<property xmlns:d8p1="DP_UNISOOBSCH_1_982_02_05_01_01" name="СвЛицОтпрУС" type="d8p1:СвЛицУСТип" lowerBound="0"/>
						</typeDef>
					</property>
					<property name="ПолучУС">
						<typeDef xsi:type="ObjectType">
							<property name="ИдПолучУС" lowerBound="1" form="Attribute">
								<typeDef xsi:type="ValueType" base="xs:string" variety="Atomic" minLength="4" maxLength="46"/>
							</property>
							<property xmlns:d8p1="DP_UNISOOBSCH_1_982_02_05_01_01" name="СвЛицПолучУС" type="d8p1:СвЛицУСТип" lowerBound="0"/>
						</typeDef>
					</property>
				</typeDef>
			</property>
		</typeDef>
	</property>
	<valueType name="ВремяТип" base="xs:string" variety="Atomic" length="8">
		<pattern>([0-1]{1}[0-9]{1}|2[0-3]{1})\.([0-5]{1}[0-9]{1})\.([0-5]{1}[0-9]{1})</pattern>
	</valueType>
	<valueType name="ДатаТип" base="xs:string" variety="Atomic" length="10">
		<pattern>((((0[1-9]{1}|1[0-9]{1}|2[0-8]{1})\.(0[1-9]{1}|1[0-2]{1}))|((29|30)\.(01|0[3-9]{1}|1[0-2]{1}))|(31\.(01|03|05|07|08|10|12)))\.((19|20)[0-9]{2}))|(29\.02\.((19|20)(((0|2|4|6|8)(0|4|8))|((1|3|5|7|9)(2|6)))))</pattern>
	</valueType>
	<valueType name="КНДТип" base="xs:string" variety="Atomic" length="7">
		<pattern>[0-9]{7}</pattern>
	</valueType>
	<objectType name="СвЛицУСТип">
		<property name="Должн" lowerBound="0" form="Attribute">
			<typeDef xsi:type="ValueType" base="xs:string" variety="Atomic" minLength="1" maxLength="255"/>
		</property>
		<property xmlns:d3p1="DP_UNISOOBSCH_1_982_02_05_01_01" name="ФИО" type="d3p1:ФИОТип"/>
		<property name="Контакт" lowerBound="0">
			<typeDef xsi:type="ObjectType">
				<property name="Тлф" lowerBound="0" upperBound="-1">
					<typeDef xsi:type="ValueType" base="xs:string" variety="Atomic" minLength="1" maxLength="20"/>
				</property>
				<property name="ЭлПочта" lowerBound="0" upperBound="-1">
					<typeDef xsi:type="ValueType" base="xs:string" variety="Atomic" minLength="1" maxLength="100"/>
				</property>
				<property name="ИнКонт" lowerBound="0">
					<typeDef xsi:type="ValueType" base="xs:string" variety="Atomic" minLength="1" maxLength="255"/>
				</property>
			</typeDef>
		</property>
	</objectType>
	<objectType name="ФИОТип">
		<property name="Фамилия" lowerBound="1" form="Attribute">
			<typeDef xsi:type="ValueType" base="xs:string" variety="Atomic" minLength="1" maxLength="60"/>
		</property>
		<property name="Имя" lowerBound="1" form="Attribute">
			<typeDef xsi:type="ValueType" base="xs:string" variety="Atomic" minLength="1" maxLength="60"/>
		</property>
		<property name="Отчество" lowerBound="0" form="Attribute">
			<typeDef xsi:type="ValueType" base="xs:string" variety="Atomic" minLength="1" maxLength="60"/>
		</property>
	</objectType>
</package>