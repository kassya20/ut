
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Если Параметры.Свойство("АвтоТест") Тогда
		Возврат;
	КонецЕсли;
	
	Параметры.ЗакрыватьПриВыборе            = Истина;
	Параметры.ЗакрыватьПриЗакрытииВладельца = Истина;
	
	Объект = Параметры.Объект;
	Организация = Объект.Организация;
	Параметры.Свойство("ЮрФизЛицо", ЮрФизЛицо);
	ПрочийРасход = Объект.ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.ПрочаяВыдачаДенежныхСредств;
	ЭтоПеречислениеВБюджет = Объект.ПеречислениеВБюджет;
	ЭтоПлательщик = Параметры.ЭтоПлательщик;
	ИНН = Параметры.ИНН;
	КПП = Параметры.КПП;
	ТекстКорреспондента = Параметры.Наименование;
	
	Элементы.Отмена.Видимость = ЭтоПлательщик;
	Элементы.ИНН.КнопкаВыпадающегоСписка = ЭтоПлательщик;
	Элементы.КПП.КнопкаВыпадающегоСписка = ЭтоПлательщик;
	Элементы.ИНН.РедактированиеТекста = ЭтоПлательщик;
	Элементы.КПП.РедактированиеТекста = ЭтоПлательщик;
	Элементы.ТекстКорреспондента.РедактированиеТекста = ЭтоПлательщик;
	
	Если ЭтоПлательщик Тогда
		
		Заголовок = НСтр("ru = 'Реквизиты плательщика'");
		
		АвтоЗначенияРеквизитов = ДенежныеСредстваСерверЛокализация.РеквизитыПлательщика(Объект, Параметры.Дата);
		
		Если ЗначениеЗаполнено(АвтоЗначенияРеквизитов.ИННПлательщика) Тогда
			Элементы.ИНН.СписокВыбора.Добавить(АвтоЗначенияРеквизитов.ИННПлательщика);
		КонецЕсли;
		
		ЗаполнитьКПП();
		
	Иначе
		
		Заголовок = НСтр("ru = 'Реквизиты получателя'");
		Элементы.КнопкаОК.Заголовок = НСтр("ru = 'Закрыть'");
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПередЗакрытием(Отказ, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	Если ЭтоПлательщик И Модифицированность И Не Готово Тогда
		
		Отказ = Истина;
		
		СписокКнопок = Новый СписокЗначений();
		СписокКнопок.Добавить("Закрыть", НСтр("ru = 'Закрыть'"));
		СписокКнопок.Добавить("НеЗакрывать", НСтр("ru = 'Не закрывать'"));
		
		ПоказатьВопрос(
			Новый ОписаниеОповещения("ПередЗакрытиемЗавершение", ЭтотОбъект), 
			НСтр("ru = 'Все измененные данные будут потеряны. Закрыть форму?'"), 
			СписокКнопок);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПередЗакрытиемЗавершение(РезультатВопроса, ДополнительныеПараметры) Экспорт
	
	Если РезультатВопроса = "Закрыть" Тогда
		Модифицированность = Ложь;
		Закрыть();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	Если ИмяСобытия = "ЗавершеноРедактированиеРегистраций" Тогда
		ЗаполнитьКПП();
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура ИННОкончаниеВводаТекста(Элемент, Текст, ДанныеВыбора, ПараметрыПолученияДанных, СтандартнаяОбработка)
	
	ПриОкончанииВводаИНН(Текст);
	ИНН = Текст;
	
КонецПроцедуры

&НаКлиенте
Процедура КППОкончаниеВводаТекста(Элемент, Текст, ДанныеВыбора, ПараметрыПолученияДанных, СтандартнаяОбработка)
	
	ПриОкончанииВводаКПП(Текст);
	
КонецПроцедуры

&НаКлиенте
Процедура КППОбработкаВыбора(Элемент, ВыбранноеЗначение, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	КэшЗначения = КПП;
	Если ТипЗнч(ВыбранноеЗначение) = Тип("Строка") Тогда
		КПП = ВыбранноеЗначение;
	Иначе
		РегистрацияВНалоговомОргане = ВыбранноеЗначение;
		Регистрация = СписокКПП.НайтиПоЗначению(ВыбранноеЗначение);
		Если Регистрация <> Неопределено Тогда
			КПП = Регистрация.Представление;
		КонецЕсли;
	КонецЕсли;
	
	Если Не КэшЗначения = КПП Тогда
		Модифицированность = Истина;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура КПППриИзменении(Элемент)
	
	РегистрацияВНалоговомОргане = Неопределено;
	Для каждого ЭлементСписка Из СписокКПП Цикл
		Если ЭлементСписка.Представление = КПП Тогда
			РегистрацияВНалоговомОргане = ЭлементСписка.Значение;
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
	УстановитьНулевоеЗначениеКПП();
	
КонецПроцедуры

&НаКлиенте
Процедура РегистрацияВНалоговомОрганеСоздание(Элемент, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	СтруктураПараметров = Новый Структура;
	СтруктураПараметров.Вставить("Организация", Организация);
	СтруктураПараметров.Вставить("ОсновнаяРегистрация", Неопределено);
	
	ОткрытьФорму("Справочник.РегистрацииВНалоговомОргане.Форма.ФормаНастройкиРегистраций", СтруктураПараметров, ЭтаФорма);
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура ОК(Команда)
	
	ОчиститьСообщения();
	
	Если Не ЭтоПлательщик Или Не Модифицированность Или ТолькоПросмотр Тогда
		Закрыть();
	Иначе
		СтруктураОбъекта = Новый Структура;
		СтруктураОбъекта.Вставить("ИННПлательщика",               СокрЛП(ИНН));
		СтруктураОбъекта.Вставить("КПППлательщика",               СокрЛП(КПП));
		СтруктураОбъекта.Вставить("ТекстПлательщика",             СокрЛП(ТекстКорреспондента));
		СтруктураОбъекта.Вставить("РегистрацияВНалоговомОргане",  РегистрацияВНалоговомОргане);
		
		Готово = Истина;
		ОповеститьОВыборе(СтруктураОбъекта);
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура ЗаполнитьКПП()
	
	СписокКПП.Очистить();
	
	СписокВыбораКПП = Элементы.КПП.СписокВыбора;
	СписокВыбораКПП.Очистить();
	
	СписокКППОрганизации = ДенежныеСредстваСерверЛокализация.СписокКППОрганизации(Организация);
	Для каждого КППОрганизации Из СписокКППОрганизации Цикл
		Представление = КППОрганизации.КПП + ?(ЗначениеЗаполнено(КППОрганизации.Подразделение), " (" + СокрЛП(КППОрганизации.Подразделение) + ")", "");
		СписокВыбораКПП.Добавить(КППОрганизации.РегистрацияСсылка, Представление);
		СписокКПП.Добавить(КППОрганизации.РегистрацияСсылка, КППОрганизации.КПП);
	КонецЦикла;
	
	Элементы.КПП.КнопкаСоздания = Ложь;
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОкончанииВводаИНН(ТекстРедактирования)
	
	Перем ТекстСообщения;
	
	Если Лев(СокрЛП(ТекстРедактирования), 2) = "00" Тогда
		ТекстРедактирования = "0";
	КонецЕсли;
	
	ЭтоЮрЛицо = (ЮрФизЛицо = ПредопределенноеЗначение("Перечисление.ЮрФизЛицо.ЮрЛицо")
			Или ЮрФизЛицо = ПредопределенноеЗначение("Перечисление.ЮрФизЛицо.ЮрЛицоНеРезидент"));
	
	ОчищатьКПП = СтрДлина(СокрЛП(ТекстРедактирования)) = 12
			Или ПустаяСтрока(ТекстРедактирования)
			Или СокрЛП(ТекстРедактирования) = "0";
	
	Если ЭтоПеречислениеВБюджет Тогда
		
		Если СокрЛП(ТекстРедактирования) = "" Тогда
			ТекстРедактирования = "0";
		КонецЕсли;
		
		Если ОчищатьКПП Тогда
			КПП = "0";
		КонецЕсли;
		
		ЭтоИнЛицо = (СтрДлина(СокрЛП(ТекстРедактирования)) = 5);
		ЭтоФизЛицо = (СтрДлина(СокрЛП(ТекстРедактирования)) = 12)
			Или Не ЭтоЮрЛицо;
		// Если указанный ИНН не соответствует длине ИНН физлица, а в документе выбран ИП,
		// то сообщение будет выведено для ИП
		// Если указанный ИНН не соответствует длине ИНН юрлица, а в документе выбрано юрлицо,
		// то сообщение будет выведено для юрлица
		ЭтоЮрЛицо = (СтрДлина(СокрЛП(ТекстРедактирования)) = 10)
			Или (ЭтоЮрЛицо И Не ЭтоИнЛицо И Не ЭтоФизЛицо);
		
		ВыполнитьПроверкуИНН = СокрЛП(ТекстРедактирования) <> "0" И Не ЭтоИнЛицо; 
		
	Иначе
		
		Если ОчищатьКПП Тогда
			КПП = "";
		КонецЕсли;
		
		ВыполнитьПроверкуИНН = Не ПустаяСтрока(ТекстРедактирования);
		
	КонецЕсли;
	
	ОчиститьСообщения();
	
	Если ВыполнитьПроверкуИНН
		И Не РегламентированныеДанныеКлиентСервер.ИННСоответствуетТребованиям(ТекстРедактирования, 
			ЭтоЮрЛицо,
			ТекстСообщения) Тогда
		
		ОбщегоНазначенияКлиент.СообщитьПользователю(
			ТекстСообщения,,
			"ИНН");
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОкончанииВводаКПП(ТекстРедактирования)
	
	Перем ТекстСообщения;
	ОчиститьСообщения();
	
	КПП = СокрЛП(ТекстРедактирования);
	
	Если Лев(КПП, 2) = "00" Тогда
		КПП = "0";
	КонецЕсли;
	
	Если ЭтоПеречислениеВБюджет Тогда
		
		Если КПП = "" Тогда
			КПП = "0";
		КонецЕсли;
		
		ЭтоИнЛицо = (СтрДлина(СокрЛП(ИНН)) = 5);
		ЭтоФизЛицо = (СтрДлина(СокрЛП(ИНН)) = 12);
		ЭтоЮрЛицо = (СтрДлина(СокрЛП(ИНН)) = 10);
		
		Если КПП <> "0" И ЭтоФизЛицо Тогда
			ТекстСообщения = НСтр("ru = 'КПП для физлица должен быть заполнен значением ""0""'");
			ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения, , "КПП");
		КонецЕсли;
		
		Если СокрЛП(ИНН) = "0" И КПП <> "0" Тогда
			ТекстСообщения = НСтр("ru = 'КПП должен быть заполнен значением ""0""'");
			ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения, , "КПП");
		КонецЕсли;
		
		ВыполнитьПроверкуКПП = КПП <> "0" И (ЭтоЮрЛицо Или ЭтоИнЛицо);
		
	Иначе
		ВыполнитьПроверкуКПП = Не ПустаяСтрока(КПП);
	КонецЕсли;
	
	Если ВыполнитьПроверкуКПП
		И Не РегламентированныеДанныеКлиентСервер.КППСоответствуетТребованиям(ТекстРедактирования, ТекстСообщения) Тогда
		
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(
			ТекстСообщения,,
			"КПП");
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура УстановитьНулевоеЗначениеКПП()

	Если СокрЛП(КПП) = ""
		И ЭтоПеречислениеВБюджет Тогда
		КПП = "0";
	КонецЕсли;

КонецПроцедуры

#КонецОбласти
