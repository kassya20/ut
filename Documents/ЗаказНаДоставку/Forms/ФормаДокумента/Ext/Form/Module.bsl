&НаКлиенте
Асинх Процедура ПодобратьДанные(Команда)
	
	ОчиститьСообщения();
	Отказ = Ложь;
	
	ПроверитьЗаполнениеПередПодбором(Отказ);
	
	Если Отказ Тогда
		Возврат;
	КонецЕсли;
	
	Если Модифицированность
	 ИЛИ ЭтоНовый Тогда
		
		РезультатЗаписи = Ждать РезультатЗаписиДокументаПередПодбором();
		
		Если НЕ РезультатЗаписи Тогда
			Отказ = Истина;
		КонецЕсли;
		
	КонецЕсли;
	
	Если НЕ Отказ Тогда
		
		ОценкаПроизводительностиКлиент.ЗамерВремени("Документ.ЗаказНаДоставку.ФормаДокумента.Команда.ПодобратьДанные");
		ОткрытьПодборДанных();
		
	КонецЕсли;
	
КонецПроцедуры

