&НаСервере
Процедура УстановитьУсловноеОформлениеСерий()
	
	СписокТиповДляСерий = Новый СписокЗначений; // СписокЗначений из ПеречислениеСсылка.ТипыНоменклатуры
	СписокТиповДляСерий.Добавить(Перечисления.ТипыНоменклатуры.Товар);
	СписокТиповДляСерий.Добавить(Перечисления.ТипыНоменклатуры.МногооборотнаяТара);
	
	ПутьКПолюСерии = "Объект.Товары.Серия";
	ПутьКПолюОтбораТипНоменклатуры = "Объект.Товары.ТипНоменклатуры";
	ИмяПоляФормыСерии = Элементы.ТоварыСерия.Имя; // ПолеФормы
	
	// Для товаров
	ЭлементУсловногоОформления = УсловноеОформление.Элементы.Добавить();
	
	ПолеЭлемента = ЭлементУсловногоОформления.Поля.Элементы.Добавить();
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(ИмяПоляФормыСерии);
	
	ОтборЭлемента = ЭлементУсловногоОформления.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ОтборЭлемента.ЛевоеЗначение = Новый ПолеКомпоновкиДанных(ПутьКПолюОтбораТипНоменклатуры);
	ОтборЭлемента.ВидСравнения = ВидСравненияКомпоновкиДанных.НеВСписке;
	ОтборЭлемента.ПравоеЗначение = СписокТиповДляСерий;
	
	ЭлементУсловногоОформления.Оформление.УстановитьЗначениеПараметра("ЦветТекста", ЦветаСтиля.ТекстЗапрещеннойЯчейкиЦвет);
	ЭлементУсловногоОформления.Оформление.УстановитьЗначениеПараметра("ОтметкаНезаполненного", Ложь);
	ЭлементУсловногоОформления.Оформление.УстановитьЗначениеПараметра("Текст", НСтр("ru = '<для товаров>'"));
	ЭлементУсловногоОформления.Оформление.УстановитьЗначениеПараметра("ТолькоПросмотр", Истина);
	
	// Серия не указывается
	ЭлементУсловногоОформления = УсловноеОформление.Элементы.Добавить();
	
	ПолеЭлемента = ЭлементУсловногоОформления.Поля.Элементы.Добавить();
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(ИмяПоляФормыСерии);
	
	ОтборЭлемента = ЭлементУсловногоОформления.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ОтборЭлемента.ЛевоеЗначение = Новый ПолеКомпоновкиДанных(ПутьКПолюСерии);
	ОтборЭлемента.ВидСравнения = ВидСравненияКомпоновкиДанных.НеЗаполнено;
	
	ОтборЭлемента = ЭлементУсловногоОформления.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ОтборЭлемента.ЛевоеЗначение = Новый ПолеКомпоновкиДанных(ПутьКПолюОтбораТипНоменклатуры);
	ОтборЭлемента.ВидСравнения = ВидСравненияКомпоновкиДанных.ВСписке;
	ОтборЭлемента.ПравоеЗначение = СписокТиповДляСерий;
	
	ЭлементУсловногоОформления.Оформление.УстановитьЗначениеПараметра("ЦветТекста", ЦветаСтиля.ТекстЗапрещеннойЯчейкиЦвет);
	ЭлементУсловногоОформления.Оформление.УстановитьЗначениеПараметра("ОтметкаНезаполненного", Ложь);
	ЭлементУсловногоОформления.Оформление.УстановитьЗначениеПараметра("Текст", НСтр("ru = '<серия не указывается>'"));
	ЭлементУсловногоОформления.Оформление.УстановитьЗначениеПараметра("ТолькоПросмотр", Истина);

КонецПроцедуры

&НаСервере
Процедура ПриСозданииЧтенииНаСервере()
	
	ТекущийОтправитель = Объект.Отправитель;
	ТекущийПолучатель = Объект.Получатель;
	ТекущийПеревозчик = Объект.Перевозчик;
	ТекущаяОрганизация = Объект.Организация;
	
	ТекущиеДанныеОтправителя = ДанныеОтправителя(Объект);
	ТекущиеДанныеПолучателя = ДанныеПолучателя(Объект);
	
	ЗаполнитьСлужебныеРеквизитыПоНоменклатуре();
	
	РаботаСТабличнымиЧастями.ИнициализироватьКэшСтрок(Элементы.Товары);
	
	НастроитьВидимостьДоступностьПолей();
	ОбновитьИтоги(Объект.Товары, ВесИтог, ВесНеттоИтог, ОбъемИтог);
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьСлужебныеРеквизитыПоНоменклатуре()
	
	СтруктураДействий = Новый Структура;
	СтруктураДействий = Новый Структура;
	СтруктураДействий.Вставить(
		"ЗаполнитьПризнакХарактеристикиИспользуются",
		Новый Структура("Номенклатура", "ХарактеристикиИспользуются"));
	СтруктураДействий.Вставить(
		"ЗаполнитьПризнакТипНоменклатуры",
		Новый Структура("Номенклатура", "ТипНоменклатуры"));
	
	ДобавитьДействияЗаполненияВесаОбъема(СтруктураДействий);
	
	НоменклатураСервер.ЗаполнитьСлужебныеРеквизитыПоНоменклатуреВКоллекции(Объект.Товары, СтруктураДействий);
	
	Для Каждого СтрокаТоваров Из Объект.Товары Цикл
		
		ЗаполнитьВесНеттоЕдиницы(СтрокаТоваров);
		ПересчитатьВесОбъемВОбщихЕдиницах(СтрокаТоваров);
		
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура НастроитьВидимостьДоступностьПолей()
	
	ИменаВидимыхЭлементов = Новый Массив; // Массив из Строка
	ИменаВсехЭлементов = Новый Массив; // Массив из Строка
	ИменаЭлементовВозможнойОбязательности = Новый Массив; // Массив из Строка
	ИменаОбязательныхЭлементов = Новый Массив; // Массив из Строка
	
	ИменаВсехЭлементов.Добавить(Элементы.ТочкаДоставкиОтправителя.Имя);
	ИменаВсехЭлементов.Добавить(Элементы.ЗонаОтправления.Имя);
	ИменаВсехЭлементов.Добавить(Элементы.ТочкаДоставкиПолучателя.Имя);
	ИменаВсехЭлементов.Добавить(Элементы.ЗонаДоставки.Имя);
	ИменаВсехЭлементов.Добавить(Элементы.ВремяДоставкиС.Имя);
	ИменаВсехЭлементов.Добавить(Элементы.ВремяДоставкиПо.Имя);
	ИменаВсехЭлементов.Добавить(Элементы.ДополнительнаяИнформация.Имя);
	ИменаВсехЭлементов.Добавить(Элементы.ОсобыеУсловияПеревозки.Имя);
	ИменаВсехЭлементов.Добавить(Элементы.ОсобыеУсловияПеревозкиОписание.Имя);
	ИменаВсехЭлементов.Добавить(Элементы.Перевозчик.Имя);
	ИменаВсехЭлементов.Добавить(Элементы.ДоставкаДоПеревозчика.Имя);
	ИменаВсехЭлементов.Добавить(Элементы.ТочкаДоставкиПеревозчика.Имя);
	ИменаВсехЭлементов.Добавить(Элементы.ЗонаДоставкиПеревозчика.Имя);
	ИменаВсехЭлементов.Добавить(Элементы.ТоварыСерия.Имя);
	
	ИменаЭлементовВозможнойОбязательности.Добавить(Элементы.ТочкаДоставкиПолучателя.Имя);
	ИменаЭлементовВозможнойОбязательности.Добавить(Элементы.ЗонаДоставки.Имя);
	ИменаЭлементовВозможнойОбязательности.Добавить(Элементы.Перевозчик.Имя);
	ИменаЭлементовВозможнойОбязательности.Добавить(Элементы.ТочкаДоставкиПеревозчика.Имя);
	ИменаЭлементовВозможнойОбязательности.Добавить(Элементы.ЗонаДоставкиПеревозчика.Имя);
	
	Если Объект.СпособДоставки <> Перечисления.СпособыДоставки25.Самовывоз Тогда
		
		ИменаВидимыхЭлементов.Добавить(Элементы.ТочкаДоставкиОтправителя.Имя);
		ИменаВидимыхЭлементов.Добавить(Элементы.ЗонаОтправления.Имя);
		ИменаВидимыхЭлементов.Добавить(Элементы.ТочкаДоставкиПолучателя.Имя);
		ИменаВидимыхЭлементов.Добавить(Элементы.ЗонаДоставки.Имя);
		ИменаВидимыхЭлементов.Добавить(Элементы.ВремяДоставкиС.Имя);
		ИменаВидимыхЭлементов.Добавить(Элементы.ВремяДоставкиПо.Имя);
		ИменаВидимыхЭлементов.Добавить(Элементы.ДополнительнаяИнформация.Имя);
		ИменаВидимыхЭлементов.Добавить(Элементы.ОсобыеУсловияПеревозки.Имя);
		ИменаВидимыхЭлементов.Добавить(Элементы.ОсобыеУсловияПеревозкиОписание.Имя);
		
	КонецЕсли;
	
	Если Объект.СпособДоставки = Перечисления.СпособыДоставки25.НашимиСилами Тогда
		
		ИменаВидимыхЭлементов.Добавить(Элементы.ДоставкаДоПеревозчика.Имя);
		ИменаВидимыхЭлементов.Добавить(Элементы.Перевозчик.Имя);
		ИменаВидимыхЭлементов.Добавить(Элементы.ТочкаДоставкиПеревозчика.Имя);
		ИменаВидимыхЭлементов.Добавить(Элементы.ЗонаДоставкиПеревозчика.Имя);
		
		ИменаОбязательныхЭлементов.Добавить(Элементы.ТочкаДоставкиПолучателя.Имя);
		ИменаОбязательныхЭлементов.Добавить(Элементы.ЗонаДоставки.Имя);
		
		Если Объект.ДоставкаДоПеревозчика Тогда
			
			ИменаОбязательныхЭлементов.Добавить(Элементы.Перевозчик.Имя);
			ИменаОбязательныхЭлементов.Добавить(Элементы.ТочкаДоставкиПеревозчика.Имя);
			ИменаОбязательныхЭлементов.Добавить(Элементы.ЗонаДоставкиПеревозчика.Имя);
			
		КонецЕсли;
		
	КонецЕсли;
	
	Если Объект.СпособДоставки = Перечисления.СпособыДоставки25.СиламиПеревозчика Тогда
		
		ИменаВидимыхЭлементов.Добавить(Элементы.Перевозчик.Имя);
		
		ИменаОбязательныхЭлементов.Добавить(Элементы.Перевозчик.Имя);
		
	КонецЕсли;
	
	ДоступныДанныеПеревозчика =
		((Объект.СпособДоставки = Перечисления.СпособыДоставки25.НашимиСилами
		  И Объект.ДоставкаДоПеревозчика)
		 ИЛИ Объект.СпособДоставки = Перечисления.СпособыДоставки25.СиламиПеревозчика);
	
	Элементы.Перевозчик.ТолькоПросмотр = НЕ ДоступныДанныеПеревозчика;
	Элементы.ТочкаДоставкиПеревозчика.ТолькоПросмотр = НЕ ДоступныДанныеПеревозчика;
	Элементы.ЗонаДоставкиПеревозчика.ТолькоПросмотр = НЕ ДоступныДанныеПеревозчика;
	
	Элементы.ОсобыеУсловияПеревозкиОписание.ТолькоПросмотр = НЕ Объект.ОсобыеУсловияПеревозки;
	
	ПараметрыСерийСкладаОтправитель = СкладыСервер.ИспользованиеСерийНаСкладе(Объект.Отправитель, Ложь);
	Если ПараметрыСерийСкладаОтправитель.ИспользоватьСерииНоменклатуры Тогда
		ИменаВидимыхЭлементов.Добавить(Элементы.ТоварыСерия.Имя);
	КонецЕсли;
	
	ОбщегоНазначенияУТКлиентСервер.УстановитьВидимостьЭлементовПоМассиву(
		Элементы,
		ИменаВсехЭлементов,
		ИменаВидимыхЭлементов);
	
	ИменаНеОбязательныхЭлементов = ОбщегоНазначенияКлиентСервер.РазностьМассивов(
		ИменаЭлементовВозможнойОбязательности,
		ИменаОбязательныхЭлементов);
	
	ОбщегоНазначенияУТКлиентСервер.УстановитьСвойствоЭлементовФормы(
		Элементы,
		ИменаНеОбязательныхЭлементов,
		"АвтоОтметкаНезаполненного",
		Ложь);
		
	ОбщегоНазначенияУТКлиентСервер.УстановитьСвойствоЭлементовФормы(
		Элементы,
		ИменаНеОбязательныхЭлементов,
		"ОтметкаНезаполненного",
		Ложь);
	
	ОбщегоНазначенияУТКлиентСервер.УстановитьСвойствоЭлементовФормы(
		Элементы,
		ИменаОбязательныхЭлементов,
		"АвтоОтметкаНезаполненного",
		Истина);
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьЗонуДоставкиПоПеревозчику()
	
	Если Объект.ТочкаДоставкиПеревозчика.Пустая() Тогда
		
		Объект.ЗонаДоставкиПеревозчика = Справочники.ЗоныДоставки.ПустаяСсылка();
		
	Иначе
		
		РеквизитыТочкиДоставкиПеревозчика = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(
			Объект.ТочкаДоставкиПеревозчика, "ЗонаДоставки");
		Объект.ЗонаДоставкиПеревозчика = РеквизитыТочкиДоставкиПеревозчика.ЗонаДоставки;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Процедура ПересчитатьВесОбъемВОбщихЕдиницах(СтрокаТоваров)
	
	// объем в кубических метрах
	Если СтрокаТоваров.МернаяЕдиница Тогда
		СтрокаТоваров.Объем = СтрокаТоваров.Количество * СтрокаТоваров.ОбъемЕдиницы;
	Иначе
		СтрокаТоваров.Объем = СтрокаТоваров.КоличествоУпаковок * СтрокаТоваров.ОбъемУпаковки;
	КонецЕсли;
	
	// вес нетто в кг
	СтрокаТоваров.ВесНетто = СтрокаТоваров.Количество * СтрокаТоваров.ВесНеттоЕдиницы;
	
	// вес брутто в кг
	Если СтрокаТоваров.МернаяЕдиница Тогда
		СтрокаТоваров.Вес = СтрокаТоваров.ВесНетто;
	Иначе
		СтрокаТоваров.Вес = СтрокаТоваров.КоличествоУпаковок * СтрокаТоваров.ВесУпаковки;
	КонецЕсли;
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция КоэффициентыВесОбъем(Знач Номенклатура, Знач Упаковка)
	
	ПустаяУпаковка = ПредопределенноеЗначение("Справочник.УпаковкиЕдиницыИзмерения.ПустаяСсылка");
	Результат = Справочники.УпаковкиЕдиницыИзмерения.КоэффициентВесОбъемПрочиеРеквизитыУпаковки(ПустаяУпаковка, Номенклатура,, Ложь);
	МернаяЕдиница = Справочники.УпаковкиЕдиницыИзмерения.ЭтоМернаяЕдиница(Упаковка);
	Результат.Вставить("МернаяЕдиница", МернаяЕдиница);
	Возврат Результат;
	
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Процедура ЗаполнитьВесНеттоЕдиницы(СтрокаТоваров)
	
	ДанныеНоменклатуры = КоэффициентыВесОбъем(СтрокаТоваров.Номенклатура, СтрокаТоваров.Упаковка);
	СтрокаТоваров.ВесНеттоЕдиницы = ДанныеНоменклатуры.ВесНетто; // Число
	СтрокаТоваров.ОбъемЕдиницы = ДанныеНоменклатуры.Объем; // Число
	СтрокаТоваров.МернаяЕдиница = ДанныеНоменклатуры.МернаяЕдиница;
	
КонецПроцедуры

&НаКлиенте
Асинх Функция ПоказатьВопросОбОчисткеСпискаТоваров()
	
	ТекстВопроса = НСтр("ru = 'Список товаров будет очищен. Продолжить?'");
	Обещание = ВопросАсинх(ТекстВопроса, РежимДиалогаВопрос.ДаНет);
	
	Возврат Обещание;
	
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Функция ДанныеОтправителя(Объект)
	
	ИменаПолей = "Отправитель, ТочкаДоставкиОтправителя, ЗонаОтправления";
	ТекущиеДанные = Новый Структура(ИменаПолей);
	ЗаполнитьЗначенияСвойств(ТекущиеДанные, Объект);
	
	ДанныеОтправителя = Новый ФиксированнаяСтруктура(ТекущиеДанные);
	Возврат ДанныеОтправителя;
	
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Функция ДанныеПолучателя(Объект)
	
	ИменаПолей = "Получатель, ТочкаДоставкиПолучателя, ЗонаДоставки";
	ТекущиеДанные = Новый Структура(ИменаПолей);
	ЗаполнитьЗначенияСвойств(ТекущиеДанные, Объект);
	
	ДанныеПолучателя = Новый ФиксированнаяСтруктура(ТекущиеДанные);
	Возврат ДанныеПолучателя;
	
КонецФункции

#Область ПодборДанных

&НаКлиенте
Процедура ПроверитьЗаполнениеПередПодбором(Отказ)
	
	Если НЕ ЗначениеЗаполнено(Объект.Организация) Тогда
		
		ТекстОшибки = НСтр("ru = 'Поле ""Организация"" не заполнено'");
		ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстОшибки,, "Организация", "Объект", Отказ);
		
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(Объект.Отправитель) Тогда
		
		ТекстОшибки = НСтр("ru = 'Поле ""Отправитель"" не заполнено'");
		ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстОшибки,, "Отправитель", "Объект", Отказ);
		
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(Объект.Получатель) Тогда
		
		ТекстОшибки = НСтр("ru = 'Поле ""Получатель"" не заполнено'");
		ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстОшибки,, "Получатель", "Объект", Отказ);
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Асинх Функция РезультатЗаписиДокументаПередПодбором()
	
	РезультатЗаписи = Ложь;
	
	Если Объект.Проведен Тогда
		ТекстВопроса = НСтр("ru = 'Документ был изменен. Провести?'");
	Иначе
		ТекстВопроса = НСтр("ru = 'Документ был изменен. Записать?'");
	КонецЕсли;
	Ответ = Ждать ВопросАсинх(ТекстВопроса, РежимДиалогаВопрос.ДаНет); // КодВозвратаДиалога
	
	Если Ответ <> КодВозвратаДиалога.Да Тогда
		Возврат РезультатЗаписи;
	КонецЕсли;
	
	Если Объект.Проведен Тогда
		
		ОчиститьСообщения();
		Если ПроверитьЗаполнение() Тогда
			РезультатЗаписи = Записать(Новый Структура("РежимЗаписи", РежимЗаписиДокумента.Проведение));
		КонецЕсли;
		
	Иначе
		
		РезультатЗаписи = Записать(Новый Структура("РежимЗаписи", РежимЗаписиДокумента.Запись));
		
	КонецЕсли;
	
	Возврат РезультатЗаписи;
	
КонецФункции

&НаКлиенте
Процедура ОткрытьПодборДанных()
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("Организация", Объект.Организация);
	ПараметрыФормы.Вставить("Склад", Объект.Отправитель);
	ПараметрыФормы.Вставить("Получатель", Объект.Получатель);
	ПараметрыФормы.Вставить("УчитыватьКоличествоВДокументе", НЕ Объект.Проведен);
	ПараметрыФормы.Вставить("ДокументДоставки", Объект.Ссылка);
	
	Если Объект.НаправлениеДоставки = ПредопределенноеЗначение("Перечисление.НаправленияДоставки.СкладПартнер") Тогда
		ПараметрыФормы.Вставить("ТипДоставки", ПредопределенноеЗначение("Перечисление.ТипыДоставки.Исходящая"));
	КонецЕсли;
	
	Если Объект.ДоставкаДоПеревозчика Тогда
		
		ТочкаДоставкиФиксированная = Объект.ТочкаДоставкиПеревозчика;
		ЗонаДоставкиФиксированная = Объект.ЗонаДоставкиПеревозчика;
		
	Иначе
		
		ТочкаДоставкиФиксированная = Объект.ТочкаДоставкиПолучателя;
		ЗонаДоставкиФиксированная = Объект.ЗонаДоставки;
		
	КонецЕсли;
	ПараметрыФормы.Вставить("ТочкаДоставкиФиксированная", ТочкаДоставкиФиксированная);
	ПараметрыФормы.Вставить("ЗонаДоставкиФиксированная", ЗонаДоставкиФиксированная);
	ПараметрыФормы.Вставить("ЗафиксироватьПараметрыДоставки", Истина);
	
	ОткрытьФорму("Обработка.ПодборТоваровВДокументДоставки.Форма.ФормаПодбора",
		ПараметрыФормы,
		ЭтотОбъект,
		УникальныйИдентификатор);
	
КонецПроцедуры

// Параметры:
//  ВыбранноеЗначение - Структура:
//   * АдресПодобранныхТоваров - Строка
//
&НаСервере
Процедура ОбработкаВыбораПодборНаСервере(Знач ВыбранноеЗначение)
	
	ПодобранныеТовары = ПодобранныеТовары(ВыбранноеЗначение);
	
	КэшированныеЗначения = ПакетнаяОбработкаТабличнойЧастиКлиентСервер.ПолучитьСтруктуруКэшируемыеЗначения();
	
	НовыеСтрокиТоваров = Новый Массив; // Массив Из ДанныеФормыЭлементКоллекции
	
	ОтборТовары = Новый Структура;
	ОтборТовары.Вставить("Распоряжение", Неопределено);
	ОтборТовары.Вставить("КодСтрокиДоставки", 0);
	
	СтруктураДействияПересчитатьКоличествоУпаковок = Новый Структура("ПересчитатьКоличествоУпаковок", Неопределено);
	
	Для Каждого СтрокаПодобрано Из ПодобранныеТовары Цикл
		
		ЗаполнитьЗначенияСвойств(ОтборТовары, СтрокаПодобрано);
		ОтборТовары.КодСтрокиДоставки = СтрокаПодобрано.КодСтроки;
		СтрокиСодержимогоПоТовару = Объект.Товары.НайтиСтроки(ОтборТовары);
		Если СтрокиСодержимогоПоТовару.Количество() > 0 Тогда
			
			ПодходящаяСтрока = СтрокиСодержимогоПоТовару[0];
			ПодходящаяСтрока.Количество = ПодходящаяСтрока.Количество + СтрокаПодобрано.Количество;
			
			ЭтоНоваяСтрока = Ложь;
			
		Иначе
			
			ПодходящаяСтрока = Объект.Товары.Добавить();
			ЗаполнитьЗначенияСвойств(ПодходящаяСтрока, СтрокаПодобрано);
			ПодходящаяСтрока.КодСтрокиДоставки = СтрокаПодобрано.КодСтроки;
			НовыеСтрокиТоваров.Добавить(ПодходящаяСтрока);
			
			ЭтоНоваяСтрока = Истина;
			
		КонецЕсли;
		
		ПакетнаяОбработкаТабличнойЧастиКлиентСервер.ПересчитатьКоличествоУпаковокВСтрокеТЧ(
			ПодходящаяСтрока, СтруктураДействияПересчитатьКоличествоУпаковок, КэшированныеЗначения);
		
		Если НЕ ЭтоНоваяСтрока Тогда
			
			ПересчитатьВесОбъемВОбщихЕдиницах(ПодходящаяСтрока);
			
		КонецЕсли;
		
	КонецЦикла;
	
	СтруктураДействий = Новый Структура;
	ЗаполнитьПризнакТипНоменклатуры = Новый Структура("Номенклатура", "ТипНоменклатуры");
	СтруктураДействий.Вставить("ЗаполнитьПризнакТипНоменклатуры", ЗаполнитьПризнакТипНоменклатуры);
	СтруктураДействий.Вставить("ПроверитьХарактеристикуПоВладельцу", Неопределено);
	СтруктураДействий.Вставить("ПроверитьЗаполнитьУпаковкуПоВладельцу", Неопределено);
	СтруктураДействий.Вставить("ПересчитатьКоличествоЕдиниц", Неопределено);
	ДобавитьДействияЗаполненияВесаОбъема(СтруктураДействий);
	СтруктураДействий.Вставить("ПересчитатьВесОбъем", Неопределено);
	
	ПакетнаяОбработкаТабличнойЧастиСервер.ОбработатьСтрокиТЧ(
		НовыеСтрокиТоваров, СтруктураДействий, Объект.Товары, КэшированныеЗначения);
	
	Для Каждого СтрокаТоваров Из НовыеСтрокиТоваров Цикл
		
		ЗаполнитьВесНеттоЕдиницы(СтрокаТоваров);
		ПересчитатьВесОбъемВОбщихЕдиницах(СтрокаТоваров);
		
	КонецЦикла;
	
	Документы.ЗаказНаДоставку.ОбновитьДополнительныеПараметры(Объект, НовыеСтрокиТоваров);
	
КонецПроцедуры

// Параметры:
//  ВыбранноеЗначение - Структура - Выбранное значение:
// * АдресПодобранныхТоваров - Строка - 
// 
// Возвращаемое значение:
//  ТаблицаЗначений - Таблица подобранных товаров:
//  * КодСтроки - Число
//  * ДоставкаДо - СправочникСсылка.Партнеры
//  * ТочкаДоставки - СправочникСсылка.ТочкиДоставки
//  * ЗонаДоставки - СправочникСсылка.ЗоныДоставки
//  * Количество - Число
//
&НаСервере
Функция ПодобранныеТовары(ВыбранноеЗначение)
	
	ПодобранныеТовары = ПолучитьИзВременногоХранилища(ВыбранноеЗначение.АдресПодобранныхТоваров); // ТаблицаЗначений
	УдалитьИзВременногоХранилища(ВыбранноеЗначение.АдресПодобранныхТоваров);
	Возврат ПодобранныеТовары;
	
КонецФункции

&НаСервере
Процедура УстановитьДоступностьКомандыПодбора()
	
	Элементы.ТоварыПодобратьДанные.Доступность = (НЕ ТолькоПросмотр);
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормыВспомогательные

&НаСервере
Процедура СпособДоставкиПриИзмененииСервер()
	
	Если Объект.СпособДоставки <> Перечисления.СпособыДоставки25.НашимиСилами
	   И Объект.СпособДоставки <> Перечисления.СпособыДоставки25.СиламиПеревозчика Тогда
		
		Объект.ДоставкаДоПеревозчика = Ложь;
		Объект.Перевозчик = Справочники.Партнеры.ПустаяСсылка();
		Объект.ТочкаДоставкиПеревозчика = Справочники.ТочкиДоставки.ПустаяСсылка();
		Объект.ЗонаДоставкиПеревозчика = Справочники.ЗоныДоставки.ПустаяСсылка();
		
	КонецЕсли;
	
	Если Объект.СпособДоставки = Перечисления.СпособыДоставки25.Самовывоз Тогда
		
		Объект.ТочкаДоставкиОтправителя = Справочники.ТочкиДоставки.ПустаяСсылка();
		Объект.ЗонаОтправления = Справочники.ЗоныДоставки.ПустаяСсылка();
		
		Объект.ТочкаДоставкиПолучателя = Справочники.ТочкиДоставки.ПустаяСсылка();
		Объект.ЗонаДоставки = Справочники.ЗоныДоставки.ПустаяСсылка();
		
		Объект.ВремяДоставкиС = Дата(1, 1, 1);
		Объект.ВремяДоставкиПо = Дата(1, 1, 1);
		
		Объект.ДополнительнаяИнформация = "";
		Объект.ОсобыеУсловияПеревозки = Ложь;
		Объект.ОсобыеУсловияПеревозкиОписание = "";
		
	КонецЕсли;
	
	НастроитьВидимостьДоступностьПолей();
	
КонецПроцедуры

&НаСервере
Процедура ОтправительПриИзмененииСервер()
	
	Если Объект.Отправитель = ТекущийОтправитель Тогда
		Возврат;
	КонецЕсли;
	
	ТекущийОтправитель = Объект.Отправитель;
	ТекущиеДанныеОтправителя = ДанныеОтправителя(Объект);
	ДанныеТочкиОтправителя = Справочники.ТочкиДоставки.СведенияТочкиДоставкиОсновная(Объект.Отправитель);
	Объект.ТочкаДоставкиОтправителя = ДанныеТочкиОтправителя.ТочкаДоставки;
	Объект.ЗонаОтправления = ДанныеТочкиОтправителя.ЗонаДоставки;
	
	НастроитьВидимостьДоступностьПолей();
	
КонецПроцедуры

&НаСервере
Процедура ПолучательПриИзмененииСервер()
	
	Если Объект.Получатель = ТекущийПолучатель Тогда
		Возврат;
	КонецЕсли;
	
	ТекущийПолучатель = Объект.Получатель;
	ТекущиеДанныеПолучателя = ДанныеПолучателя(Объект);
	ДанныеТочкиПолучателя = Справочники.ТочкиДоставки.СведенияТочкиДоставкиОсновная(Объект.Получатель);
	Объект.ТочкаДоставкиПолучателя = ДанныеТочкиПолучателя.ТочкаДоставки;
	Объект.ЗонаДоставки = ДанныеТочкиПолучателя.ЗонаДоставки;
	
	НастроитьВидимостьДоступностьПолей();
	
КонецПроцедуры

&НаСервере
Процедура ПеревозчикПриИзмененииСервер()
	
	Если Объект.Перевозчик = ТекущийПеревозчик Тогда
		Возврат;
	КонецЕсли;
	
	ТекущийПеревозчик = Объект.Перевозчик;
	
	Если Объект.ДоставкаДоПеревозчика Тогда
		
		ДанныеТочкиПеревозчика = Справочники.ТочкиДоставки.СведенияТочкиДоставкиОсновная(Объект.Перевозчик);
		Объект.ТочкаДоставкиПеревозчика = ДанныеТочкиПеревозчика.ТочкаДоставки;
		Объект.ЗонаДоставкиПеревозчика = ДанныеТочкиПеревозчика.ЗонаДоставки;
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ТочкаДоставкиПолучателяПриИзмененииСервер()
	
	Если Объект.ТочкаДоставкиПолучателя.Пустая() Тогда
		
		Объект.ЗонаДоставки = Справочники.ЗоныДоставки.ПустаяСсылка();
		
	Иначе
		
		РеквизитыТочкиДоставкиПолучателя = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(
			Объект.ТочкаДоставкиПолучателя, "ЗонаДоставки");
		Объект.ЗонаДоставки = РеквизитыТочкиДоставкиПолучателя.ЗонаДоставки;
		
	КонецЕсли;
	
	ТекущиеДанныеПолучателя = ДанныеПолучателя(Объект);
	
КонецПроцедуры

&НаСервере
Процедура ТочкаДоставкиОтправителяПриИзмененииСервер()
	
	Если ЗначениеЗаполнено(Объект.ТочкаДоставкиОтправителя) Тогда
		
		РеквизитыТочкиОтправления = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Объект.ТочкаДоставкиОтправителя, "ЗонаДоставки");
		Объект.ЗонаОтправления = РеквизитыТочкиОтправления.ЗонаДоставки;
		
	Иначе
		
		Объект.ЗонаОтправления = Справочники.ЗоныДоставки.ПустаяСсылка();
		
	КонецЕсли;
	
	ТекущиеДанныеОтправителя = ДанныеОтправителя(Объект);
	
КонецПроцедуры

&НаКлиенте
Процедура ПересчитатьСтрокиТоваров(ИмяСобытия, Источник)
	
	ОтборСтрок = Новый Структура;
	
	Если ИмяСобытия = "Запись_Номенклатура" Тогда
		
		ОтборСтрок.Вставить("Номенклатура", Источник);
		
	ИначеЕсли ИмяСобытия = "Запись_УпаковкиНоменклатуры" Тогда
		
		ОтборСтрок.Вставить("Упаковка", Источник);
		
	Иначе
		
		Возврат;
		
	КонецЕсли;
	
	СтрокиДляПересчета = Объект.Товары.НайтиСтроки(ОтборСтрок);
	Если СтрокиДляПересчета.Количество() > 0 Тогда
		
		ПересчитатьСтрокиТоваровСервер(ОтборСтрок);
		Модифицированность = Истина;
		
	КонецЕсли;
	
	РассчитатьИтогиВесОбъем();
	
КонецПроцедуры

&НаСервере
Процедура ПересчитатьСтрокиТоваровСервер(Знач ОтборСтрок)
	
	СтрокиДляПересчета = Объект.Товары.НайтиСтроки(ОтборСтрок);
	
	СтруктураДействий = Новый Структура;
	
	Если ОтборСтрок.Свойство("Номенклатура") Тогда
		
		ЗаполнитьПризнакТипНоменклатуры = Новый Структура("Номенклатура", "ТипНоменклатуры");
		СтруктураДействий.Вставить("ЗаполнитьПризнакТипНоменклатуры", ЗаполнитьПризнакТипНоменклатуры);
		СтруктураДействий.Вставить("ПроверитьХарактеристикуПоВладельцу", Неопределено);
		СтруктураДействий.Вставить("ПроверитьЗаполнитьУпаковкуПоВладельцу", Неопределено);
		
	КонецЕсли;
	
	ДобавитьДействияЗаполненияВесаОбъема(СтруктураДействий);
	СтруктураДействий.Вставить("ПересчитатьКоличествоЕдиниц", Неопределено);
	СтруктураДействий.Вставить("ПересчитатьВесОбъем", Неопределено);
	
	ПакетнаяОбработкаТабличнойЧастиСервер.ОбработатьСтрокиТЧ(СтрокиДляПересчета, СтруктураДействий, Объект.Товары);
	
	Для Каждого СтрокаТоваров Из СтрокиДляПересчета Цикл
		
		ЗаполнитьВесНеттоЕдиницы(СтрокаТоваров);
		ПересчитатьВесОбъемВОбщихЕдиницах(СтрокаТоваров);
		
	КонецЦикла;
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Процедура ДобавитьДействияЗаполненияВесаОбъема(СтруктураДействий)
	
	СтруктураДействий.Вставить(
		"ЗаполнитьВесУпаковки",
		Новый Структура("Номенклатура, Упаковка", "ВесУпаковки", Неопределено));
	СтруктураДействий.Вставить(
		"ЗаполнитьОбъемУпаковки",
		Новый Структура("Номенклатура, Упаковка", "ОбъемУпаковки", Неопределено));
	СтруктураДействий.Вставить(
		"ЗаполнитьЕдиницуИзмеренияВеса",
		Новый Структура("Номенклатура, Упаковка", "ЕдиницаИзмеренияВеса", Неопределено));
	СтруктураДействий.Вставить(
		"ЗаполнитьЕдиницуИзмеренияОбъема",
		Новый Структура("Номенклатура, Упаковка", "ЕдиницаИзмеренияОбъема", Неопределено));
	
КонецПроцедуры

&НаКлиенте
Процедура РассчитатьИтогиВесОбъем()
	
	ОбновитьИтоги(Объект.Товары, ВесИтог, ВесНеттоИтог, ОбъемИтог);
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Процедура ОбновитьИтоги(Товары, Вес, ВесНетто, Объем)
	
	Вес = Товары.Итог("Вес");
	ВесНетто = Товары.Итог("ВесНетто");
	Объем = Товары.Итог("Объем");
	
КонецПроцедуры

