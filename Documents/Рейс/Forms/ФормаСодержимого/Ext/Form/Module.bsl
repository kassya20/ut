КонецПроцедуры

// Параметры:
//  Результат - Структура:
//  * Получатель - СправочникСсылка.Партнеры, СправочникСсылка.Склады -
//  * ТочкаПолучателя - СправочникСсылка.ТочкиДоставки
//  * ЗонаПолучателя - СправочникСсылка.ЗоныДоставки
//  ДополнительныеПараметры - Неопределено
//
&НаКлиенте
Процедура ЗавершениеДоставкаНашимиСилами(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = КодВозвратаДиалога.Отмена
		ИЛИ Результат = Неопределено Тогда
		
		Возврат;
		
	КонецЕсли;
	
	ТекущиеДанные = Элементы.ДоставляемыеТовары.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ИдентификаторыСтрокТоваров = Новый Массив; // Массив из Число
	ИдентификаторыСтрокТоваров.Добавить(ТекущиеДанные.ПолучитьИдентификатор());
	
	ЗавершениеДоставкаНашимиСиламиСервер(Результат, ИдентификаторыСтрокТоваров);
	
	Модифицированность = Истина;
	
	ЗаголовокОповещения = НСтр("ru = 'Доставка нашими силами'");
	ШаблонЗаголовкаОповещения = НСтр("ru = '%1, %2'");
	ТекстПояснения =  СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
		ШаблонЗаголовкаОповещения,
		Строка(Результат.ТочкаПолучателя),
		Строка(Результат.ЗонаПолучателя));
	
	ПоказатьОповещениеПользователя(ЗаголовокОповещения,, ТекстПояснения);
	
КонецПроцедуры

&НаСервере
Процедура ЗавершениеДоставкаНашимиСиламиСервер(Знач Результат, Знач ИдентификаторыСтрокТоваров)
	
	СтрокиКУдалению = Новый Массив; // Массив из ДанныеФормыЭлементКоллекции
	
	Для Каждого ИдентификаторСтрокиТовара Из ИдентификаторыСтрокТоваров Цикл
		
		СтрокаТовара = ДоставляемыеТовары.НайтиПоИдентификатору(ИдентификаторСтрокиТовара);
		
		СтрокаИзменений = ДоставляемыеТоварыИзменения.Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаИзменений, СтрокаТовара);
		
		СтрокаИзменений.КонечныйПункт = Результат.Получатель;
		СтрокаИзменений.КонечнаяТочкаДоставки = Результат.ТочкаПолучателя;
		СтрокаИзменений.КонечнаяЗонаДоставки = Результат.ЗонаПолучателя;
		
		СтрокиКУдалению.Добавить(СтрокаТовара);
		
	КонецЦикла;
	
	ОбщегоНазначенияУТ.УдалитьСтрокиТаблицы(ДоставляемыеТовары, СтрокиКУдалению);
	
	ПересчитатьИтогиПоДокументамНаСервере();
	
КонецПроцедуры

&НаСервере
Процедура НастроитьДоступностьПолейПоСтатусу()
	
	Если ТолькоПросмотр Тогда
		Возврат;
	КонецЕсли;
	
	БлокируемыеПоля = Новый Массив; // Массив из Строка
	
	ЗапретитьИзменениеСоставаСтрок = Ложь;
	
	Если СтатусРейса = Перечисления.СтатусыРейсов.Сформирован
	 ИЛИ СтатусРейса = Перечисления.СтатусыРейсов.Отправлен Тогда
		
		ЗапретитьИзменениеСоставаСтрок = Истина;
		
	ИначеЕсли СтатусРейса = Перечисления.СтатусыРейсов.Завершен Тогда
		
		БлокируемыеПоля.Добавить(Элементы.ДоставляемыеТоварыВремяДоставки.Имя);
		БлокируемыеПоля.Добавить(Элементы.ДоставляемыеТоварыГруппаИнформация.Имя);
		
		ЗапретитьИзменениеСоставаСтрок = Истина;
		
	ИначеЕсли СтатусРейса = Перечисления.СтатусыРейсов.Отменен Тогда
		
		БлокируемыеПоля.Добавить(Элементы.ДоставляемыеТоварыВремяДоставки.Имя);
		БлокируемыеПоля.Добавить(Элементы.ДоставляемыеТоварыГруппаИнформация.Имя);
		БлокируемыеПоля.Добавить(Элементы.ДоставляемыеТоварыОтменено.Имя);
		
	Иначе
		
		КомандыИзмененияПараметровДоставкиДоступны = Истина;
		
	КонецЕсли;
	
	Если НЕ КомандыИзмененияПараметровДоставкиДоступны Тогда
		
		БлокируемыеПоля.Добавить(Элементы.ДокументыПодобратьДанные.Имя);
		БлокируемыеПоля.Добавить(Элементы.ДоставляемыеТоварыПодобратьДанные.Имя);
		БлокируемыеПоля.Добавить(Элементы.ДоставляемыеТоварыДоставитьДоПеревозчика.Имя);
		БлокируемыеПоля.Добавить(Элементы.ДоставляемыеТоварыИзменитьПеревозчика.Имя);
		БлокируемыеПоля.Добавить(Элементы.ДоставляемыеТоварыДоставитьНашимиСилами.Имя);
		
	КонецЕсли;
	
	Если ЗапретитьИзменениеСоставаСтрок Тогда
		
		Элементы.ТаблицаДокументы.ИзменятьСоставСтрок = Ложь;
		Элементы.ДоставляемыеТовары.ИзменятьСоставСтрок = Ложь;
		
	КонецЕсли;
	
	ОбщегоНазначенияУТКлиентСервер.УстановитьСвойствоЭлементовФормы(Элементы, БлокируемыеПоля, "ТолькоПросмотр", Истина);
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьДоступностьОтменыСтроки(ДанныеСтроки)
	
	Если ДанныеСтроки <> Неопределено Тогда
		
		Элементы.ДоставляемыеТоварыПричинаОтмены.ТолькоПросмотр = НЕ ДанныеСтроки.Отменено;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьДоступностьОсобыхУсловийПеревозки(ДанныеСтроки)
	
	Если ДанныеСтроки <> Неопределено Тогда
		
		Элементы.ДоставляемыеТоварыОсобыеУсловияПеревозкиОписание.ТолькоПросмотр = НЕ ДанныеСтроки.ОсобыеУсловияПеревозки;
		
	КонецЕсли;
	
КонецПроцедуры

#Область УсловноеОформление

&НаСервере
Процедура УстановитьУсловноеОформление()
	
	УсловноеОформление.Элементы.Очистить();
	
	УстановитьУсловноеОформлениеНезаполненныйВесУпаковки();
	УстановитьУсловноеОформлениеНезаполненныйОбъемУпаковки();
	УстановитьУсловноеОформлениеНезаполненныйВесНетто();
	
	НоменклатураСервер.УстановитьУсловноеОформлениеХарактеристикНоменклатуры(
		ЭтотОбъект, "ДоставляемыеТоварыХарактеристика", "ДоставляемыеТовары.ХарактеристикиИспользуются");
	
	УстановитьУсловноеОформлениеСерий();
	
	ПараметрыОформленияЕдиниц = НоменклатураСервер.НовыеПараметрыУсловногоОформленияЕдиницИзмерения();
	ПараметрыОформленияЕдиниц.ИмяПоляЕдиницаИзмерения = "ДоставляемыеТоварыНоменклатураЕдиницаИзмерения";
	ПараметрыОформленияЕдиниц.ПутьКПолюУпаковка = "ДоставляемыеТовары.Упаковка";
	НоменклатураСервер.УстановитьУсловноеОформлениеЕдиницИзмерения(ЭтотОбъект, ПараметрыОформленияЕдиниц);
	
	ЗаказыСервер.УстановитьОформлениеОтмененнойСтроки(
		УсловноеОформление,
		Элементы.ДоставляемыеТовары,
		Элементы.ДоставляемыеТоварыОтменено.Имя,
		Элементы.ДоставляемыеТоварыПричинаОтмены.Имя);
	
	УстановитьУсловноеОформлениеНезаполненныйВесОбъемПоДокументам();
	
КонецПроцедуры

&НаСервере
Процедура УстановитьУсловноеОформлениеСерий()
	
	СписокТиповДляСерий = Новый СписокЗначений; // СписокЗначений из ПеречислениеСсылка.ТипыНоменклатуры
	СписокТиповДляСерий.Добавить(Перечисления.ТипыНоменклатуры.Товар);
	СписокТиповДляСерий.Добавить(Перечисления.ТипыНоменклатуры.МногооборотнаяТара);
	
	ПутьКПолюСерии = "ДоставляемыеТовары.Серия";
	ПутьКПолюОтбораТипНоменклатуры = "ДоставляемыеТовары.ТипНоменклатуры";
	ИмяПоляФормыСерии = Элементы.ДоставляемыеТоварыСерия.Имя; // ПолеФормы
	
	// Для товаров
	ЭлементУсловногоОформления = УсловноеОформление.Элементы.Добавить();
	
	ПолеЭлемента = ЭлементУсловногоОформления.Поля.Элементы.Добавить();
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(ИмяПоляФормыСерии);
	
	ОтборЭлемента = ЭлементУсловногоОформления.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ОтборЭлемента.ЛевоеЗначение = Новый ПолеКомпоновкиДанных(ПутьКПолюОтбораТипНоменклатуры);
	ОтборЭлемента.ВидСравнения = ВидСравненияКомпоновкиДанных.НеВСписке;
	ОтборЭлемента.ПравоеЗначение = СписокТиповДляСерий;
	
	ЭлементУсловногоОформления.Оформление.УстановитьЗначениеПараметра("ЦветТекста", ЦветаСтиля.ТекстЗапрещеннойЯчейкиЦвет);
	ЭлементУсловногоОформления.Оформление.УстановитьЗначениеПараметра("ОтметкаНезаполненного", Ложь);
	ЭлементУсловногоОформления.Оформление.УстановитьЗначениеПараметра("Текст", НСтр("ru = '<для товаров>'"));
	ЭлементУсловногоОформления.Оформление.УстановитьЗначениеПараметра("ТолькоПросмотр", Истина);
	
	// Серия не указывается
	ЭлементУсловногоОформления = УсловноеОформление.Элементы.Добавить();
	
	ПолеЭлемента = ЭлементУсловногоОформления.Поля.Элементы.Добавить();
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(ИмяПоляФормыСерии);
	
	ОтборЭлемента = ЭлементУсловногоОформления.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ОтборЭлемента.ЛевоеЗначение = Новый ПолеКомпоновкиДанных(ПутьКПолюСерии);
	ОтборЭлемента.ВидСравнения = ВидСравненияКомпоновкиДанных.НеЗаполнено;
	
	ОтборЭлемента = ЭлементУсловногоОформления.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ОтборЭлемента.ЛевоеЗначение = Новый ПолеКомпоновкиДанных(ПутьКПолюОтбораТипНоменклатуры);
	ОтборЭлемента.ВидСравнения = ВидСравненияКомпоновкиДанных.ВСписке;
	ОтборЭлемента.ПравоеЗначение = СписокТиповДляСерий;
	
	ЭлементУсловногоОформления.Оформление.УстановитьЗначениеПараметра("ЦветТекста", ЦветаСтиля.ТекстЗапрещеннойЯчейкиЦвет);
	ЭлементУсловногоОформления.Оформление.УстановитьЗначениеПараметра("ОтметкаНезаполненного", Ложь);
	ЭлементУсловногоОформления.Оформление.УстановитьЗначениеПараметра("Текст", НСтр("ru = '<серия не указывается>'"));
	ЭлементУсловногоОформления.Оформление.УстановитьЗначениеПараметра("ТолькоПросмотр", Истина);

КонецПроцедуры

