// @strict-types

#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ЭтоНовый = Параметры.Ключ.Пустая();
	
	Если Не ЗначениеЗаполнено(Объект.Ссылка) Тогда
		
		ПриСозданииЧтенииНаСервере();
		
	КонецЕсли;
	
	ЭлементыДляЗаполненияВремени = Новый Массив; // Массив из ПолеФормы
	ЭлементыДляЗаполненияВремени.Добавить(Элементы.МаршрутВремяДоставкиС);
	ЭлементыДляЗаполненияВремени.Добавить(Элементы.МаршрутВремяДоставкиПо);
	ДоставкаТоваровКлиентСервер.ЗаполнитьСписокВыбораПоляВремени(ЭлементыДляЗаполненияВремени);
	
	АдресСодержимое = ПоместитьВоВременноеХранилище(Неопределено, УникальныйИдентификатор);
	
	УстановитьУсловноеОформление();
	
	// СтандартныеПодсистемы.РаботаСФайлами
	ПараметрыГиперссылки = РаботаСФайлами.ГиперссылкаФайлов();
	ПараметрыГиперссылки.Размещение = "КоманднаяПанель";
	РаботаСФайлами.ПриСозданииНаСервере(ЭтотОбъект, ПараметрыГиперссылки);
	// Конец СтандартныеПодсистемы.РаботаСФайлами
	
	// СтандартныеПодсистемы.Свойства
	ДополнительныеПараметры = Новый Структура;
	ДополнительныеПараметры.Вставить("ИмяЭлементаДляРазмещения", "ГруппаДополнительныеРеквизиты");
	УправлениеСвойствами.ПриСозданииНаСервере(ЭтотОбъект, ДополнительныеПараметры);
	// Конец СтандартныеПодсистемы.Свойства
	
	// СтандартныеПодсистемы.ПодключаемыеКоманды
	ПодключаемыеКоманды.ПриСозданииНаСервере(ЭтотОбъект);
	// Конец СтандартныеПодсистемы.ПодключаемыеКоманды
	
	// ИнтеграцияС1СДокументооборотом
	ИнтеграцияС1СДокументооборотБазоваяФункциональность.ПриСозданииНаСервере(ЭтотОбъект);
	// Конец ИнтеграцияС1СДокументооборотом
	
	СобытияФорм.ПриСозданииНаСервере(ЭтотОбъект, Отказ, СтандартнаяОбработка);
	
КонецПроцедуры

&НаСервере
Процедура ПриЧтенииНаСервере(ТекущийОбъект)
	
	// СтандартныеПодсистемы.УправлениеДоступом
	УправлениеДоступом.ПриЧтенииНаСервере(ЭтотОбъект, ТекущийОбъект);
	// Конец СтандартныеПодсистемы.УправлениеДоступом
	
	ДатыЗапретаИзменения.ОбъектПриЧтенииНаСервере(ЭтотОбъект, ТекущийОбъект);
	
	ПриСозданииЧтенииНаСервере();
	НастроитьДоступностьПолейПоСтатусу();
	УстановитьИспользованиеГиперссылкиСостояниеРейса();
	
	// СтандартныеПодсистемы.Свойства
	УправлениеСвойствами.ПриЧтенииНаСервере(ЭтотОбъект, ТекущийОбъект);
	// Конец СтандартныеПодсистемы.Свойств
	
	// СтандартныеПодсистемы.ПодключаемыеКоманды
	ПодключаемыеКомандыКлиентСервер.ОбновитьКоманды(ЭтотОбъект, Объект);
	// Конец СтандартныеПодсистемы.ПодключаемыеКоманды
	
	УстановитьДоступностьКомандыПодбора();
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	// СтандартныеПодсистемы.РаботаСФайлами
	РаботаСФайламиКлиент.ПриОткрытии(ЭтотОбъект, Отказ);
	// Конец СтандартныеПодсистемы.РаботаСФайлами
	
	// СтандартныеПодсистемы.Свойства
	УправлениеСвойствамиКлиент.ПослеЗагрузкиДополнительныхРеквизитов(ЭтотОбъект);
	// Конец СтандартныеПодсистемы.Свойства
	
	// СтандартныеПодсистемы.ПодключаемыеКоманды
	ПодключаемыеКомандыКлиент.НачатьОбновлениеКоманд(ЭтотОбъект);
	// Конец СтандартныеПодсистемы.ПодключаемыеКоманды
	
КонецПроцедуры

&НаСервере
Процедура ПередЗаписьюНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	
	// СтандартныеПодсистемы.Свойства
	УправлениеСвойствами.ПередЗаписьюНаСервере(ЭтотОбъект, ТекущийОбъект);
	// Конец СтандартныеПодсистемы.Свойства
	
	// ИнтеграцияС1СДокументооборотом
	ИнтеграцияС1СДокументооборотБазоваяФункциональность.ПередЗаписьюНаСервере(ЭтотОбъект, ТекущийОбъект, ПараметрыЗаписи);
	// Конец ИнтеграцияС1СДокументооборотом
	
	ПараметрыЗаписи.Вставить("ЗаписьНовогоДокумента", ЭтоНовый);
	
КонецПроцедуры

&НаКлиенте
Процедура ПослеЗаписи(ПараметрыЗаписи)
	
	Оповестить("Запись_Рейс", ПараметрыЗаписи, Объект.Ссылка);
	
	// СтандартныеПодсистемы.ПодключаемыеКоманды
	ПодключаемыеКомандыКлиент.ПослеЗаписи(ЭтотОбъект, Объект, ПараметрыЗаписи);
	// Конец СтандартныеПодсистемы.ПодключаемыеКоманды
	
КонецПроцедуры

&НаСервере
Процедура ПослеЗаписиНаСервере(ТекущийОбъект, ПараметрыЗаписи)
	
	// СтандартныеПодсистемы.УправлениеДоступом
	УправлениеДоступом.ПослеЗаписиНаСервере(ЭтотОбъект, ТекущийОбъект, ПараметрыЗаписи);
	// Конец СтандартныеПодсистемы.УправлениеДоступом
	
	ЭтоНовый = Ложь;
	
	АктуализироватьСостояниеРейса();
	НастроитьДоступностьПолейПоСтатусу();
	УстановитьИспользованиеГиперссылкиСостояниеРейса();
	ТекущийСтатус = ТекущийОбъект.Статус;
	
	УстановитьДоступностьКомандыПодбора();
	ЗаполнитьДополнительныеПоляМаршрута();
	
	Если ПараметрыЗаписи.ЗаписьНовогоДокумента Тогда
		
		УстановитьОтборОрдеров();
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	// СтандартныеПодсистемы.РаботаСФайлами
	РаботаСФайламиКлиент.ОбработкаОповещения(ЭтотОбъект, ИмяСобытия);
	// Конец СтандартныеПодсистемы.РаботаСФайлами
	
	// СтандартныеПодсистемы.Свойства 
	Если УправлениеСвойствамиКлиент.ОбрабатыватьОповещения(ЭтотОбъект, ИмяСобытия, Параметр) Тогда
		
		ОбновитьЭлементыДополнительныхРеквизитов();
		УправлениеСвойствамиКлиент.ПослеЗагрузкиДополнительныхРеквизитов(ЭтотОбъект);
		
	КонецЕсли;
	// Конец СтандартныеПодсистемы.Свойства
	
КонецПроцедуры

&НаСервере
Процедура ОбработкаПроверкиЗаполненияНаСервере(Отказ, ПроверяемыеРеквизиты)
	
	// СтандартныеПодсистемы.Свойства
	УправлениеСвойствами.ОбработкаПроверкиЗаполнения(ЭтотОбъект, Отказ, ПроверяемыеРеквизиты);
	// Конец СтандартныеПодсистемы.Свойства
	
КонецПроцедуры

&НаКлиенте
Процедура ПередЗакрытием(Отказ, ЗавершениеРаботы, ТекстПредупреждения, СтандартнаяОбработка)
	
	// СтандартныеПодсистемы.РаботаСФайлами
	
	РаботаСФайламиКлиент.ПоказатьПодтверждениеЗакрытияФормыСФайлами(ЭтотОбъект, Отказ, ЗавершениеРаботы, Объект.Ссылка);
	Если Отказ Тогда
		Возврат;
	КонецЕсли;
	
	// Конец СтандартныеПодсистемы.РаботаСФайлами
	
КонецПроцедуры

// Параметры:
//  ВыбранноеЗначение - Структура, Произвольный -
//  ИсточникВыбора - ФормаКлиентскогоПриложения -
//
&НаКлиенте
Процедура ОбработкаВыбора(ВыбранноеЗначение, ИсточникВыбора)
	
	Если ИсточникВыбора.ИмяФормы = "Обработка.ПодборТоваровВДокументДоставки.Форма.ФормаПодбора" Тогда
		
		Модифицированность = Истина;
		ОбработкаВыбораПодборНаСервере(ВыбранноеЗначение);
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Асинх Процедура СпособДоставкиПриИзменении(Элемент)
	
	Результат = КодВозвратаДиалога.Да;
	
	// Есть строки сверх начальной
	Если Объект.Маршрут.Количество() > 1 Тогда
		
		Если Объект.СпособДоставки = ПредопределенноеЗначение("Перечисление.СпособыДоставки25.СиламиПеревозчика") Тогда
		
			ТекстВопроса = НСтр("ru = 'При доставке силами перевозчика пункты доставки маршрута будут перепланированы на получателя. Продолжить?'");
			Результат = Ждать ВопросАсинх(ТекстВопроса, РежимДиалогаВопрос.ДаНет); // КодВозвратаДиалога
			
			Если Результат = КодВозвратаДиалога.Нет Тогда
				Объект.СпособДоставки = ПредопределенноеЗначение("Перечисление.СпособыДоставки25.НашимиСилами");
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЕсли;
	
	Если Результат = КодВозвратаДиалога.Да Тогда
		СпособДоставкиПриИзмененииСервер();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПеревозчикПриИзменении(Элемент)
	
	ПеревозчикПриИзмененииСервер();
	
КонецПроцедуры

&НаКлиенте
Асинх Процедура СкладОтправленияПриИзменении(Элемент)
	
	СкладОтправленияИзменен = (Объект.СкладОтправления <> ТекущийСкладОтправления);
	
	Если СкладОтправленияИзменен
		И МаршрутЗаполнен() Тогда
		
		Ответ = Ждать ПоказатьВопросОбОчисткеПунктовМаршрута(); // КодВозвратаДиалога
		
		Если Ответ <> КодВозвратаДиалога.Да Тогда
			
			Объект.СкладОтправления = ТекущийСкладОтправления;
			Объект.ТочкаОтправления = ТекущаяТочкаОтправления;
			СкладОтправленияИзменен = Ложь;
			
		КонецЕсли;
		
	КонецЕсли;
	
	Если СкладОтправленияИзменен Тогда
		
		ОчиститьПунктыМаршрута();
		ТекущийСкладОтправления = Объект.СкладОтправления;
		СкладОтправленияПриИзмененииСервер();
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ТочкаОтправленияПриИзменении(Элемент)
	
	ТочкаОтправленияПриИзмененииСервер();
	
КонецПроцедуры

&НаКлиенте
Процедура СтатусПриИзменении(Элемент)
	
	СтатусДоИзменения = ТекущийСтатус;
	ТекущийСтатус = Объект.Статус;
	Если Объект.Статус <> ПредопределенноеЗначение("Перечисление.СтатусыРейсов.Отменен")
		Или ВсеСтрокиСодержимогоОтменены() Тогда
		
		СтатусПриИзмененииСервер();
		
		// СтандартныеПодсистемы.ПодключаемыеКоманды
		ПодключаемыеКомандыКлиент.НачатьОбновлениеКоманд(ЭтотОбъект);
		// Конец СтандартныеПодсистемы.ПодключаемыеКоманды
		
	Иначе
		
		ОповещениеОВыборе = Новый ОписаниеОповещения("ЗавершитьВыборПричиныОтмены", ЭтотОбъект, СтатусДоИзменения);
		ОткрытьФорму("Документ.Рейс.Форма.ФормаВыбораПричиныОтмены",
			,
			ЭтотОбъект,
			УникальныйИдентификатор,
			,
			,
			ОповещениеОВыборе);
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ЗонаОтправленияПриИзменении(Элемент)
	
	ЗонаОтправленияПриИзмененииСервер();
	
КонецПроцедуры

&НаКлиенте
Процедура СтатусОчистка(Элемент, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
КонецПроцедуры

&НаКлиенте
Асинх Процедура ОрганизацияПриИзменении(Элемент)
	
	ОрганизацияИзменена = (Объект.Организация <> ТекущаяОрганизация);
	
	Если ОрганизацияИзменена
	   И МаршрутЗаполнен() Тогда
		
		Ответ = Ждать ПоказатьВопросОбОчисткеПунктовМаршрута(); // КодВозвратаДиалога
		
		Если Ответ <> КодВозвратаДиалога.Да Тогда
			
			Объект.Организация = ТекущаяОрганизация;
			Объект.Договор = ТекущийДоговор;
			ОрганизацияИзменена = Ложь;
			
		КонецЕсли;
		
	КонецЕсли;
	
	Если ОрганизацияИзменена Тогда
		
		ОчиститьПунктыМаршрута();
		ТекущаяОрганизация = Объект.Организация;
		ТекущийДоговор = Объект.Договор;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ДоговорПриИзменении(Элемент)
	
	ТекущийДоговор = Объект.Договор;
	
КонецПроцедуры

&НаКлиенте
Процедура ДекорацияСостояниеРейсаНажатие(Элемент)
	
	ВариантОтчета = ВариантОтчетаСборкаПоРаспоряжениямРейса(Объект.Ссылка);
	
	ПараметрыОткрытия = Новый Структура;
	ПараметрыОткрытия.Вставить("ПараметрКоманды", Объект.Ссылка);
	ПараметрыОткрытия.Вставить("ВидимостьКомандВариантовОтчетов", Ложь);
	
	Если ЗначениеЗаполнено(ВариантОтчета) Тогда
		
		ВариантыОтчетовКлиент.ОткрытьФормуОтчета(ЭтотОбъект, ВариантОтчета, ПараметрыОткрытия);
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыМаршрут

&НаКлиенте
Процедура МаршрутПередНачаломДобавления(Элемент, Отказ, Копирование, Родитель, ЭтоГруппа, Параметр)
	
	Отказ = Истина;
	
КонецПроцедуры

&НаКлиенте
Процедура МаршрутПередУдалением(Элемент, Отказ)
	
	ТекущиеДанные = Элементы.Маршрут.ТекущиеДанные;
	Если ТекущиеДанные.КлючСвязи = КлючСвязиНачалаМаршрута Тогда
		Отказ = Истина;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура МаршрутПриАктивизацииСтроки(Элемент)
	
	Если Элементы.Маршрут.ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ПодключитьОбработчикОжидания("УстановитьДоступностьКомандТаблицыМаршруты", 0.1, Истина);
	
КонецПроцедуры

// Параметры:
//  Элемент - ТаблицаФормы -
//  ВыбраннаяСтрока - Число -
//  Поле - ПолеФормы -
//  СтандартнаяОбработка - Булево -
//
&НаКлиенте
Процедура МаршрутВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	Если Поле = Элементы.МаршрутСостав
	   И Объект.Маршрут.НайтиПоИдентификатору(ВыбраннаяСтрока).КлючСвязи <> КлючСвязиНачалаМаршрута Тогда
		
		ОткрытьСодержимоеСтрокиМаршрута(ВыбраннаяСтрока);
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура МаршрутПослеУдаления(Элемент)
	
	МаршрутПослеУдаленияСервер();
	
КонецПроцедуры

&НаКлиенте
Процедура МаршрутНачалоПеретаскивания(Элемент, ПараметрыПеретаскивания, Выполнение)
	
	ТекущиеДанные = Элементы.Маршрут.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если ТекущиеДанные.КлючСвязи = КлючСвязиНачалаМаршрута Тогда
		Выполнение = Ложь;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура МаршрутПроверкаПеретаскивания(Элемент, ПараметрыПеретаскивания, СтандартнаяОбработка, Строка, Поле)
	
	Если Строка = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если Объект.Маршрут.НайтиПоИдентификатору(Строка).КлючСвязи = КлючСвязиНачалаМаршрута Тогда
		ПараметрыПеретаскивания.ДопустимыеДействия = ДопустимыеДействияПеретаскивания.НеОбрабатывать;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура МаршрутТочкаДоставкиПриИзменении(Элемент)
	
	ТекущиеДанные = Элементы.Маршрут.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ТочкаДоставки = ТекущиеДанные.ТочкаДоставки;
	
	Если ТочкаДоставки.Пустая() Тогда
		НоваяЗонаДоставки = ПредопределенноеЗначение("Справочник.ЗоныДоставки.ПустаяСсылка");
	Иначе
		НоваяЗонаДоставки = ЗонаТочкиДоставки(ТочкаДоставки);
	КонецЕсли;
	ТекущиеДанные.ЗонаДоставки = НоваяЗонаДоставки;
	
