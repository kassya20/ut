&НаКлиенте
Асинх Процедура ПодобратьДанные(Команда)
	
	Если ТолькоПросмотр Тогда
		Возврат;
	КонецЕсли;
	
	ОчиститьСообщения();
	Отказ = Ложь;
	ПроверитьЗаполнениеПередПодбором(Отказ);
	Если Отказ Тогда
		Возврат;
	КонецЕсли;
	
	Если Модифицированность
		Или ЭтоНовый Тогда
		
		РезультатЗаписи = Ждать РезультатЗаписиДокументПередПодбором();
		
		Если НЕ РезультатЗаписи Тогда
			Отказ = Истина;
		КонецЕсли;
		
	КонецЕсли;
	
	Если НЕ Отказ Тогда
		
		ОценкаПроизводительностиКлиент.ЗамерВремени("Документ.Рейс.ФормаДокумента.Команда.ПодобратьДанные");
		ОткрытьПодборДанных();
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Асинх Процедура ОбновитьДатуОтгрузкиОрдеров(Команда)
	
	ОчиститьСообщения();
	
	Если Модифицированность Тогда
		
		ТекстПредупреждения = НСтр("ru = 'Перед выполнение команды требуется записать документ'");
		ПоказатьПредупреждение(, ТекстПредупреждения);
		
		Возврат;
		
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(Объект.ДатаВыезда) Тогда
		
		ИмяПоля = НСтр("ru = 'Дата выезда'");
		ТекстОшибки = ОбщегоНазначенияКлиентСервер.ТекстОшибкиЗаполнения(,, ИмяПоля);
		ОбщегоНазначенияКлиент.СообщитьПользователю(
			ТекстОшибки,, "Объект.ДатаВыезда");
		
		Возврат;
		
	КонецЕсли;
	
	ОрдераКОбработке = ОбщегоНазначенияУТКлиент.ПроверитьПолучитьВыделенныеВСпискеСсылки(Элементы.СписокОрдеров);
	Если ОрдераКОбработке.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	ШаблонВопроса = НСтр("ru = 'Установить дату отгрузки по дате выезда %1 в выделенных строках?'");
	ТекстВопроса = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
		ШаблонВопроса,
		Формат(Объект.ДатаВыезда, "ДЛФ=D"));
	Ответ = Ждать ВопросАсинх(ТекстВопроса, РежимДиалогаВопрос.ДаНет); // КодВозвратаДиалога
	
	Если Ответ = КодВозвратаДиалога.Да Тогда
		
		ОперацияВыполнена = Ложь;
		ОбновитьДатуОтгрузкиОрдеровСервер(ОрдераКОбработке, ОперацияВыполнена);
		
		Если ОперацияВыполнена Тогда
			ОповеститьОбИзменении(Тип("ДокументСсылка.РасходныйОрдерНаТовары"));
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

