&НаКлиенте
Процедура МаршрутПереместитьВверх(Команда)
	
	ВыделенныеСтроки = Элементы.Маршрут.ВыделенныеСтроки;
	Если ВыделенныеСтроки.Количество() = 0
		Или ВыделенныеСтроки.Количество() = Объект.Маршрут.Количество() Тогда
		
		Возврат;
		
	КонецЕсли;
	
	НомераСтрок = НомераВыделенныхСтрокМаршрута();
	
	НеПеремещены = Новый Массив; // Массив из Число
	
	Для Каждого НомерСтроки Из НомераСтрок Цикл
		
		Если НомерСтроки <> 1 Тогда
			
			НомерСтрокиПеред = НомерСтроки - 1;
			ИндексТекущейСтроки = НомерСтроки - 1;
			ИндексСтрокиПеред = НомерСтрокиПеред - 1;
			СтрокаПеред = Объект.Маршрут[ИндексСтрокиПеред];
			
			Если НеПеремещены.Найти(НомерСтрокиПеред) = Неопределено
				И Не ЭтоСтрокаНачалаМаршрута(СтрокаПеред) Тогда
				
				Объект.Маршрут.Сдвинуть(ИндексТекущейСтроки, -1);
				
			Иначе
				
				НеПеремещены.Добавить(НомерСтроки);
				
			КонецЕсли;
			
		Иначе
			
			НеПеремещены.Добавить(НомерСтроки);
			
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура МаршрутПереместитьВниз(Команда)
	
	ВыделенныеСтроки = Элементы.Маршрут.ВыделенныеСтроки;
	Если ВыделенныеСтроки.Количество() = 0
		Или ВыделенныеСтроки.Количество() = Объект.Маршрут.Количество() Тогда
		
		Возврат;
		
	КонецЕсли;
	
	НомераСтрок = НомераВыделенныхСтрокМаршрута(Ложь);
	
	НеПеремещены = Новый Массив; // Массив из Число
	
	Для Каждого НомерСтроки Из НомераСтрок Цикл
		
		Если НомерСтроки <> Объект.Маршрут.Количество() Тогда
			
			НомерСрокиПосле = НомерСтроки + 1;
			ИндексТекущейСтроки = НомерСтроки - 1;
			ИндексСтрокиПосле = НомерСрокиПосле - 1;
			СтрокаПосле = Объект.Маршрут[ИндексСтрокиПосле];
			
			Если НеПеремещены.Найти(НомерСрокиПосле) = Неопределено
				И Не ЭтоСтрокаНачалаМаршрута(СтрокаПосле) Тогда
				
				Объект.Маршрут.Сдвинуть(ИндексТекущейСтроки, 1);
				
			Иначе
				
				НеПеремещены.Добавить(НомерСтроки);
				
			КонецЕсли;
			
		Иначе
			
			НеПеремещены.Добавить(НомерСтроки);
			
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

