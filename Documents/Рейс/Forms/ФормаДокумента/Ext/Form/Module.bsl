&НаСервере
Процедура УстановитьУсловноеОформление()
	
	УсловноеОформление.Элементы.Очистить();
	
	// Цвет текста пункта строки начала маршрута
	
	Элемент = УсловноеОформление.Элементы.Добавить();
	
	ПолеЭлемента = Элемент.Поля.Элементы.Добавить();
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(Элементы.МаршрутПункт.Имя);
	
	ОтборЭлемента = Элемент.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ОтборЭлемента.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("Объект.Маршрут.КлючСвязи");
	ОтборЭлемента.ВидСравнения = ВидСравненияКомпоновкиДанных.Равно;
	ОтборЭлемента.ПравоеЗначение = Новый ПолеКомпоновкиДанных("КлючСвязиНачалаМаршрута");
	
	Элемент.Оформление.УстановитьЗначениеПараметра("ЦветТекста", ЦветаСтиля.ЦветТекстаОтмененнойСтрокиДокумента);
	
	// Ограничение редактирования полей строки начала маршрута
	
	Элемент = УсловноеОформление.Элементы.Добавить();
	
	ПолеЭлемента = Элемент.Поля.Элементы.Добавить();
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(Элементы.МаршрутПункт.Имя);
	ПолеЭлемента = Элемент.Поля.Элементы.Добавить();
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(Элементы.МаршрутТочкаДоставки.Имя);
	ПолеЭлемента = Элемент.Поля.Элементы.Добавить();
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(Элементы.МаршрутОперация.Имя);
	ПолеЭлемента = Элемент.Поля.Элементы.Добавить();
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(Элементы.МаршрутЗонаДоставки.Имя);
	ПолеЭлемента = Элемент.Поля.Элементы.Добавить();
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(Элементы.МаршрутВремяДоставкиС.Имя);
	ПолеЭлемента = Элемент.Поля.Элементы.Добавить();
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(Элементы.МаршрутВремяДоставкиПо.Имя);
	ПолеЭлемента = Элемент.Поля.Элементы.Добавить();
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(Элементы.МаршрутСостав.Имя);
	ПолеЭлемента = Элемент.Поля.Элементы.Добавить();
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(Элементы.МаршрутОтменено.Имя);
	
	ОтборЭлемента = Элемент.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ОтборЭлемента.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("Объект.Маршрут.КлючСвязи");
	ОтборЭлемента.ВидСравнения = ВидСравненияКомпоновкиДанных.Равно;
	ОтборЭлемента.ПравоеЗначение = Новый ПолеКомпоновкиДанных("КлючСвязиНачалаМаршрута");
	
	Элемент.Оформление.УстановитьЗначениеПараметра("ТолькоПросмотр", Истина);
	Элемент.Оформление.УстановитьЗначениеПараметра("ОтметкаНезаполненного", Ложь);
	
	// Текст гиперссылки содержимого маршрута
	
	Элемент = УсловноеОформление.Элементы.Добавить();
	
	ПолеЭлемента = Элемент.Поля.Элементы.Добавить();
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(Элементы.МаршрутСостав.Имя);
	
	ОтборЭлемента = Элемент.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ОтборЭлемента.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("Объект.Маршрут.КлючСвязи");
	ОтборЭлемента.ВидСравнения = ВидСравненияКомпоновкиДанных.НеРавно;
	ОтборЭлемента.ПравоеЗначение = Новый ПолеКомпоновкиДанных("КлючСвязиНачалаМаршрута");
	
	Элемент.Оформление.УстановитьЗначениеПараметра("Текст", НСтр("ru = 'Содержимое'"));
	
	// Разделитель полей времени
	
	Элемент = УсловноеОформление.Элементы.Добавить();
	
	ПолеЭлемента = Элемент.Поля.Элементы.Добавить();
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(Элементы.МаршрутРазделительВремени.Имя);
	
	ГруппаОтбораИли = Элемент.Отбор.Элементы.Добавить(Тип("ГруппаЭлементовОтбораКомпоновкиДанных"));
	ГруппаОтбораИли.ТипГруппы = ТипГруппыЭлементовОтбораКомпоновкиДанных.ГруппаИли;
	
	ОтборЭлемента = ГруппаОтбораИли.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ОтборЭлемента.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("Объект.Маршрут.ВремяДоставкиС");
	ОтборЭлемента.ВидСравнения = ВидСравненияКомпоновкиДанных.Заполнено;
	
	ОтборЭлемента = ГруппаОтбораИли.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ОтборЭлемента.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("Объект.Маршрут.ВремяДоставкиПо");
	ОтборЭлемента.ВидСравнения = ВидСравненияКомпоновкиДанных.Заполнено;
	
	Элемент.Оформление.УстановитьЗначениеПараметра("Текст", "-");
	
	УстановитьУсловноеОформлениеГруппыОтмены();
	
КонецПроцедуры

&НаСервере
Процедура УстановитьУсловноеОформлениеГруппыОтмены()
	
	// Вывод признака частичной отмены
	
	Элемент = УсловноеОформление.Элементы.Добавить();
	
	ПолеЭлемента = Элемент.Поля.Элементы.Добавить();
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(Элементы.МаршрутОтмененоЧастичноНадпись.Имя);
	
	ОтборЭлемента = Элемент.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ОтборЭлемента.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("Объект.Маршрут.ОтмененоЧастично");
	ОтборЭлемента.ВидСравнения = ВидСравненияКомпоновкиДанных.Равно;
	ОтборЭлемента.ПравоеЗначение = Истина;
	
	ТекстОформления = НСтр("ru = 'Частично'");
	Элемент.Оформление.УстановитьЗначениеПараметра("Текст", ТекстОформления);
	
	// Скрытие признака частичной отмены
	
	Элемент = УсловноеОформление.Элементы.Добавить();
	
	ПолеЭлемента = Элемент.Поля.Элементы.Добавить();
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(Элементы.МаршрутОтменено.Имя);
	
	ОтборЭлемента = Элемент.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ОтборЭлемента.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("Объект.Маршрут.ОтмененоЧастично");
	ОтборЭлемента.ВидСравнения = ВидСравненияКомпоновкиДанных.Равно;
	ОтборЭлемента.ПравоеЗначение = Истина;
	
	Элемент.Оформление.УстановитьЗначениеПараметра("Видимость", Ложь);
	
	// Скрытие признака полной отмены
	
	Элемент = УсловноеОформление.Элементы.Добавить();
	
	ПолеЭлемента = Элемент.Поля.Элементы.Добавить();
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(Элементы.МаршрутОтмененоЧастичноНадпись.Имя);
	
	ОтборЭлемента = Элемент.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ОтборЭлемента.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("Объект.Маршрут.ОтмененоЧастично");
	ОтборЭлемента.ВидСравнения = ВидСравненияКомпоновкиДанных.Равно;
	ОтборЭлемента.ПравоеЗначение = Ложь;
	
	Элемент.Оформление.УстановитьЗначениеПараметра("Видимость", Ложь);
	
КонецПроцедуры

&НаСервере
Процедура НастроитьВидимостьДоступностьПолей()
	
	Элементы.Перевозчик.Видимость = (Объект.СпособДоставки = Перечисления.СпособыДоставки25.СиламиПеревозчика);
	Элементы.Договор.Видимость = (Объект.СпособДоставки = Перечисления.СпособыДоставки25.СиламиПеревозчика);
	
	СтатусФормируется = (Объект.Статус = Перечисления.СтатусыРейсов.Подготовлен);
	
	Элементы.Водитель.АвтоОтметкаНезаполненного = НЕ СтатусФормируется;
	
	Если СтатусФормируется Тогда
		
		Элементы.Водитель.ОтметкаНезаполненного = Ложь;
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура НастроитьДоступностьПолейПоСтатусу()
	
	Если ТолькоПросмотр Тогда
		Возврат;
	КонецЕсли;
	
	ПоляКБлокировке = Новый Массив; // Массив из Строка
	ПоляКБлокировке.Добавить(Элементы.СкладОтправления.Имя);
	ПоляКБлокировке.Добавить(Элементы.ТочкаОтправления.Имя);
	ПоляКБлокировке.Добавить(Элементы.ЗонаОтправления.Имя);
	ПоляКБлокировке.Добавить(Элементы.СпособДоставки.Имя);
	ПоляКБлокировке.Добавить(Элементы.Перевозчик.Имя);
	ПоляКБлокировке.Добавить(Элементы.Договор.Имя);
	ПоляКБлокировке.Добавить(Элементы.Организация.Имя);
	ПоляКБлокировке.Добавить(Элементы.ДатаВыезда.Имя);
	ПоляКБлокировке.Добавить(Элементы.ВремяВыезда.Имя);
	ПоляКБлокировке.Добавить(Элементы.ТранспортноеСредство.Имя);
	ПоляКБлокировке.Добавить(Элементы.Водитель.Имя);
	ПоляКБлокировке.Добавить(Элементы.МаршрутПодобратьДанные.Имя);
	ПоляКБлокировке.Добавить(Элементы.МаршрутЗонаДоставки.Имя);
	ПоляКБлокировке.Добавить(Элементы.МаршрутТочкаДоставки.Имя);
	
	БлокируемыеПоля = Новый Массив; // Массив из Строка
	
	Если Объект.Статус = Перечисления.СтатусыРейсов.Сформирован
	 ИЛИ Объект.Статус = Перечисления.СтатусыРейсов.Отменен Тогда
		
		БлокируемыеПоля.Добавить(Элементы.МаршрутПодобратьДанные.Имя);
		
	ИначеЕсли Объект.Статус = Перечисления.СтатусыРейсов.Отправлен Тогда 
		
		БлокируемыеПоля.Добавить(Элементы.СкладОтправления.Имя);
		БлокируемыеПоля.Добавить(Элементы.СпособДоставки.Имя);
		БлокируемыеПоля.Добавить(Элементы.Перевозчик.Имя);
		БлокируемыеПоля.Добавить(Элементы.Договор.Имя);
		БлокируемыеПоля.Добавить(Элементы.Организация.Имя);
		БлокируемыеПоля.Добавить(Элементы.МаршрутПодобратьДанные.Имя);
		
	ИначеЕсли Объект.Статус = Перечисления.СтатусыРейсов.Завершен Тогда
		
		БлокируемыеПоля = ОбщегоНазначения.СкопироватьРекурсивно(ПоляКБлокировке);
		
	КонецЕсли;
	
	НеблокируемыеПоля = ОбщегоНазначенияКлиентСервер.РазностьМассивов(ПоляКБлокировке, БлокируемыеПоля);
	
	ОбщегоНазначенияУТКлиентСервер.УстановитьСвойствоЭлементовФормы(Элементы, БлокируемыеПоля, "ТолькоПросмотр", Истина);
	ОбщегоНазначенияУТКлиентСервер.УстановитьСвойствоЭлементовФормы(Элементы, НеблокируемыеПоля, "ТолькоПросмотр", Ложь);
	
	Элементы.Маршрут.ИзменятьСоставСтрок = ДоступноИзменениеСоставаМаршрута();
	
КонецПроцедуры

&НаСервере
Процедура СпособДоставкиПриИзмененииСервер()
	
	Если Объект.СпособДоставки = Перечисления.СпособыДоставки25.НашимиСилами Тогда
		
		Объект.Перевозчик = Справочники.Партнеры.ПустаяСсылка();
		Объект.Договор = Справочники.ДоговорыКонтрагентов.ПустаяСсылка();
		ТекущийДоговор = Объект.Договор;
		
	Иначе
		
		КонечныеТочки = Новый Массив; // Массив из СправочникСсылка.ТочкиДоставки
		Для каждого СтрокаСодержимого Из Объект.Содержимое Цикл
			
			Если СтрокаСодержимого.КонечнаяТочкаДоставки.Пустая() Тогда
				Продолжить;
			КонецЕсли;
			
			КонечныеТочки.Добавить(СтрокаСодержимого.КонечнаяТочкаДоставки);
			
		КонецЦикла;
		
		ВладельцыТочек = ОбщегоНазначения.ЗначениеРеквизитаОбъектов(КонечныеТочки, "Владелец");
		
		Для каждого СтрокаСодержимого Из Объект.Содержимое Цикл
			
			Если СтрокаСодержимого.КонечнаяТочкаДоставки.Пустая() Тогда
				
				Продолжить;
				
			Иначе
				
				ВладелецКонечнойТочки = ВладельцыТочек[СтрокаСодержимого.КонечнаяТочкаДоставки];
				
				ПараметрыОтбораМаршрута = Новый Структура;
				ПараметрыОтбораМаршрута.Вставить("Пункт", ВладелецКонечнойТочки);
				ПараметрыОтбораМаршрута.Вставить("ТочкаДоставки", СтрокаСодержимого.КонечнаяТочкаДоставки);
				ПараметрыОтбораМаршрута.Вставить("Операция", Перечисления.ОперацииРейсов.Разгрузка);
				СтрокиМаршрутаПоПараметрам = Объект.Маршрут.НайтиСтроки(ПараметрыОтбораМаршрута);
				Если СтрокиМаршрутаПоПараметрам.Количество() > 0 Тогда
					
					КлючСвязиМаршрута = СтрокиМаршрутаПоПараметрам[0].КлючСвязи;
					
				Иначе
					
					КлючСвязиМаршрута = Новый УникальныйИдентификатор();
					
					НоваяСтрокаМаршрута = Объект.Маршрут.Добавить();
					НоваяСтрокаМаршрута.КлючСвязи = КлючСвязиМаршрута;
					НоваяСтрокаМаршрута.Операция = Перечисления.ОперацииРейсов.Разгрузка;
					НоваяСтрокаМаршрута.Пункт = ВладелецКонечнойТочки;
					НоваяСтрокаМаршрута.ТочкаДоставки = СтрокаСодержимого.КонечнаяТочкаДоставки;
					НоваяСтрокаМаршрута.ЗонаДоставки = СтрокаСодержимого.КонечнаяЗонаДоставки;
					НоваяСтрокаМаршрута.ВремяДоставкиС = СтрокаСодержимого.ВремяДоставкиС;
					НоваяСтрокаМаршрута.ВремяДоставкиПо = СтрокаСодержимого.ВремяДоставкиПо;
					
				КонецЕсли;
				
				СтрокаСодержимого.КлючСвязи = КлючСвязиМаршрута;
				СтрокаСодержимого.КонечнаяТочкаДоставки = Справочники.ТочкиДоставки.ПустаяСсылка();
				СтрокаСодержимого.КонечнаяЗонаДоставки = Справочники.ЗоныДоставки.ПустаяСсылка();
				
			КонецЕсли;
			
		КонецЦикла;
		
		СтрокиКУдалению = Новый Массив; // Массив из ДанныеФормыЭлементКоллекции
		Для Каждого СтрокаМаршрута Из Объект.Маршрут Цикл
			
			Если СтрокаМаршрута.КлючСвязи = КлючСвязиНачалаМаршрута Тогда
				Продолжить;
			КонецЕсли;
			
			ПараметрыОтбораСодержимого = Новый Структура;
			ПараметрыОтбораСодержимого.Вставить("КлючСвязи", СтрокаМаршрута.КлючСвязи);
			СтрокиСодержимого = Объект.Содержимое.НайтиСтроки(ПараметрыОтбораСодержимого);
			Если СтрокиСодержимого.Количество() = 0 Тогда
				СтрокиКУдалению.Добавить(СтрокаМаршрута);
			КонецЕсли;
			
		КонецЦикла;
		ОбщегоНазначенияУТ.УдалитьСтрокиТаблицы(Объект.Маршрут, СтрокиКУдалению);
		
		ЗаполнитьДополнительныеПоляМаршрута(Истина);
		
	КонецЕсли;
	
	НастроитьВидимостьДоступностьПолей();
	
КонецПроцедуры

&НаСервере
Процедура ПеревозчикПриИзмененииСервер()
	
	Если Объект.Перевозчик = ТекущийПеревозчик Тогда
		Возврат;
	КонецЕсли;
	
	ТекущийПеревозчик = Объект.Перевозчик;
	
	НастроитьВидимостьДоступностьПолей();
	
КонецПроцедуры

&НаСервере
Процедура СкладОтправленияПриИзмененииСервер()
	
	РейсОбъект = РеквизитФормыВЗначение("Объект");
	
	СтараяСтрокаНачалаМаршрута = РейсОбъект.Маршрут.Найти(КлючСвязиНачалаМаршрута, "КлючСвязи");
	Если СтараяСтрокаНачалаМаршрута <> Неопределено Тогда
		
		РейсОбъект.Маршрут.Удалить(СтараяСтрокаНачалаМаршрута);
		
	КонецЕсли;
	
	ДанныеТочкиОтправителя = Справочники.ТочкиДоставки.СведенияТочкиДоставкиОсновная(Объект.СкладОтправления);
	РейсОбъект.ТочкаОтправления = ДанныеТочкиОтправителя.ТочкаДоставки;
	РейсОбъект.ЗонаОтправления = ДанныеТочкиОтправителя.ЗонаДоставки;
	
	РейсОбъект.ДобавитьНачальнуюСтрокуМаршрута();
	
	ЗначениеВРеквизитФормы(РейсОбъект, "Объект");
	
	ОбновитьКлючСвязиНачалаМаршрута();
	
	ЗаполнитьПризнакОтгрузкаПослеФормированияРейса();
	ОбновитьОтображениеСпискаОрдеров();
	УстановитьОтборОрдеров();
	
КонецПроцедуры

&НаСервере
Процедура ТочкаОтправленияПриИзмененииСервер()
	
	Если Объект.ТочкаОтправления = ТекущаяТочкаОтправления Тогда
		Возврат;
	КонецЕсли;
	
	ТекущаяТочкаОтправления = Объект.ТочкаОтправления;
	
	РейсОбъект = РеквизитФормыВЗначение("Объект");
	
	Если ЗначениеЗаполнено(РейсОбъект.ТочкаОтправления) Тогда
		
		РейсОбъект.ЗонаОтправления = ЗонаТочкиДоставки(РейсОбъект.ТочкаОтправления);
		
	Иначе
		
		РейсОбъект.ЗонаОтправления = Справочники.ЗоныДоставки.ПустаяСсылка();
		
	КонецЕсли;
	
	СтрокаНачалаМаршрута = РейсОбъект.Маршрут.Найти(КлючСвязиНачалаМаршрута, "КлючСвязи");
	Если СтрокаНачалаМаршрута = Неопределено Тогда
		
		РейсОбъект.ДобавитьНачальнуюСтрокуМаршрута();
		СтрокаНачалаМаршрута = РейсОбъект.Маршрут[0];
		
	КонецЕсли;
	
	СтрокаНачалаМаршрута.ТочкаДоставки = РейсОбъект.ТочкаОтправления;
	СтрокаНачалаМаршрута.ЗонаДоставки = РейсОбъект.ЗонаОтправления;
	
	ЗначениеВРеквизитФормы(РейсОбъект, "Объект");
	
	ОбновитьКлючСвязиНачалаМаршрута();
	
КонецПроцедуры

&НаСервере
Процедура ЗонаОтправленияПриИзмененииСервер()
	
	Если Объект.ЗонаОтправления = ТекущаяЗонаОтправления Тогда
		Возврат;
	КонецЕсли;
	
	ТекущаяЗонаОтправления = Объект.ЗонаОтправления;
	
	РейсОбъект = РеквизитФормыВЗначение("Объект");
	
	СтрокаНачалаМаршрута = РейсОбъект.Маршрут.Найти(КлючСвязиНачалаМаршрута, "КлючСвязи");
	Если СтрокаНачалаМаршрута = Неопределено Тогда
		
		РейсОбъект.ДобавитьНачальнуюСтрокуМаршрута();
		СтрокаНачалаМаршрута = РейсОбъект.Маршрут[0];
		
	КонецЕсли;
	
	СтрокаНачалаМаршрута.ТочкаДоставки = РейсОбъект.ТочкаОтправления;
	СтрокаНачалаМаршрута.ЗонаДоставки = РейсОбъект.ЗонаОтправления;
	
	ЗначениеВРеквизитФормы(РейсОбъект, "Объект");
	
	ОбновитьКлючСвязиНачалаМаршрута();
	
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьСодержимоеСтрокиМаршрута(ВыбраннаяСтрока)
	
	ДанныеСтроки = Объект.Маршрут.НайтиПоИдентификатору(ВыбраннаяСтрока);
	ПоместитьСодержимоеВоВременноеХранилище(ДанныеСтроки.КлючСвязи);
	
	ПараметрыФормы = Новый Структура();
	ПараметрыФормы.Вставить("ТолькоПросмотр", ТолькоПросмотр);
	ПараметрыФормы.Вставить("Получатель", ДанныеСтроки.Пункт);
	ПараметрыФормы.Вставить("ТочкаДоставки", ДанныеСтроки.ТочкаДоставки);
	ПараметрыФормы.Вставить("ЗонаДоставки", ДанныеСтроки.ЗонаДоставки);
	ПараметрыФормы.Вставить("АдресСодержимое", АдресСодержимое);
	ПараметрыФормы.Вставить("КлючСвязи", ДанныеСтроки.КлючСвязи);
	ПараметрыФормы.Вставить("Операция", ДанныеСтроки.Операция);
	ПараметрыФормы.Вставить("Склад", Объект.СкладОтправления);
	ПараметрыФормы.Вставить("Организация", Объект.Организация);
	ПараметрыФормы.Вставить("СпособДоставки", Объект.СпособДоставки);
	ПараметрыФормы.Вставить("Перевозчик", Объект.Перевозчик);
	ПараметрыФормы.Вставить("ДатаВыезда", Объект.ДатаВыезда);
	ПараметрыФормы.Вставить("Статус", ТекущийСтатус);
	ПараметрыФормы.Вставить("РейсПроведен", Объект.Проведен);
	ПараметрыФормы.Вставить("РейсСсылка", Объект.Ссылка);
	РейсМодифицирован = (Модифицированность Или ЭтоНовый);
	ПараметрыФормы.Вставить("РейсМодифицирован", РейсМодифицирован);
	
	Оповещение = Новый ОписаниеОповещения("ОткрытьСодержимоеСтрокиМаршрутаЗавершение", ЭтотОбъект);
	
	ОткрытьФорму("Документ.Рейс.Форма.ФормаСодержимого",
		ПараметрыФормы,
		ЭтотОбъект,
		УникальныйИдентификатор,
		,
		,
		Оповещение);
	
КонецПроцедуры

&НаСервере
Процедура ПоместитьСодержимоеВоВременноеХранилище(Знач КлючСвязи = Неопределено)
	
	ОтборСтрок = Новый Структура;
	Если ЗначениеЗаполнено(КлючСвязи) Тогда
		ОтборСтрок.Вставить("КлючСвязи", КлючСвязи);
	КонецЕсли;
	ТаблицаСодержимое = Объект.Содержимое.Выгрузить(ОтборСтрок);
	
	ТипТочкаДоставки = Новый ОписаниеТипов("СправочникСсылка.ТочкиДоставки");
	ТипЗонаДоставки = Новый ОписаниеТипов("СправочникСсылка.ЗоныДоставки");
	
	ТаблицаСодержимое.Колонки.Добавить("ТочкаДоставки", ТипТочкаДоставки);
	ТаблицаСодержимое.Колонки.Добавить("ЗонаДоставки", ТипЗонаДоставки);
	
	АдресСодержимое = ПоместитьВоВременноеХранилище(ТаблицаСодержимое, АдресСодержимое);
	
КонецПроцедуры

// Параметры:
//  Результат - Структура:
//   * КлючСвязи - УникальныйИдентификатор
//   * АдресДоставляемыеТовары - Строка
//   * АдресДоставляемыеТоварыИзменения - Строка
//   * Модифицированность - Булево
//  ДополнительныеПараметры - Неопределено
//
&НаКлиенте
Процедура ОткрытьСодержимоеСтрокиМаршрутаЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат <> Неопределено
	   И Результат.Модифицированность Тогда
		
		ПеренестиСодержимоеВОбъект(Результат);
		Модифицированность = Истина;
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ПеренестиСодержимоеВОбъект(Знач Результат)
	
	// Обновим данные по пункту
	ТаблицаСодержимое = ПолучитьИзВременногоХранилища(Результат.АдресДоставляемыеТовары); // ТаблицаЗначений
	УдалитьИзВременногоХранилища(Результат.АдресДоставляемыеТовары);
	ТаблицаСодержимое.ЗаполнитьЗначения(Результат.КлючСвязи, "КлючСвязи");
	
	ОтборСтрок = Новый Структура("КлючСвязи", Результат.КлючСвязи);
	СтарыеСтрокиСодержимого = Объект.Содержимое.НайтиСтроки(ОтборСтрок);
	ОбщегоНазначенияУТ.УдалитьСтрокиТаблицы(Объект.Содержимое, СтарыеСтрокиСодержимого);
	
	Если ТаблицаСодержимое.Количество() > 0 Тогда
		
		ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(ТаблицаСодержимое, Объект.Содержимое);
		
	Иначе
		
		СтрокиПоКлючуСвязи = Объект.Маршрут.НайтиСтроки(ОтборСтрок);
		ОбщегоНазначенияУТ.УдалитьСтрокиТаблицы(Объект.Маршрут, СтрокиПоКлючуСвязи);
		
	КонецЕсли;
	
	// Распределим по другим пунктам изменения
	ТаблицаИзменения = ПолучитьИзВременногоХранилища(Результат.АдресДоставляемыеТоварыИзменения); // ТаблицаЗначений
	УдалитьИзВременногоХранилища(Результат.АдресДоставляемыеТоварыИзменения);
	
	СтруктураПоиска = Новый Структура;
	СтруктураПоиска.Вставить("Пункт", Неопределено);
	СтруктураПоиска.Вставить("ТочкаДоставки", Справочники.ТочкиДоставки.ПустаяСсылка());
	СтруктураПоиска.Вставить("ЗонаДоставки", Справочники.ЗоныДоставки.ПустаяСсылка());
	
	Для Каждого СтрокаИзменения Из ТаблицаИзменения Цикл
		
		ДоставкаДоПеревозчика = Ложь;
		Если СтрокаИзменения.Перевозчик.Пустая() Тогда
			
			СтруктураПоиска.Пункт = СтрокаИзменения.КонечныйПункт;
			СтруктураПоиска.ТочкаДоставки = СтрокаИзменения.КонечнаяТочкаДоставки;
			СтруктураПоиска.ЗонаДоставки = СтрокаИзменения.КонечнаяЗонаДоставки;
			
		Иначе
			
			ДоставкаДоПеревозчика = Истина;
			
			СтруктураПоиска.Пункт = СтрокаИзменения.Перевозчик;
			СтруктураПоиска.ТочкаДоставки = СтрокаИзменения.ТочкаДоставки;
			СтруктураПоиска.ЗонаДоставки = СтрокаИзменения.ЗонаДоставки;
			
		КонецЕсли;
		
		СтрокиМаршрутов = Объект.Маршрут.НайтиСтроки(СтруктураПоиска);
		Если СтрокиМаршрутов.Количество() > 0 Тогда
			
			// Анализируется только первое совпадение, т.к. иное - это только если ошибка
			СтрокаМаршрута = СтрокиМаршрутов[0];
			
		Иначе
			
			СтрокаМаршрута = Объект.Маршрут.Добавить();
			СтрокаМаршрута.Операция = Перечисления.ОперацииРейсов.Разгрузка;
			СтрокаМаршрута.КлючСвязи = Новый УникальныйИдентификатор();
			
			ЗаполнитьЗначенияСвойств(СтрокаМаршрута, СтруктураПоиска);
			
		КонецЕсли;
		
		СтрокаСодержимого = Объект.Содержимое.Добавить();
		СтрокаСодержимого.КлючСвязи = СтрокаМаршрута.КлючСвязи;
		СтрокаСодержимого.Распоряжение = СтрокаИзменения.Распоряжение;
		СтрокаСодержимого.ДокументПланирования = СтрокаИзменения.ДокументПланирования;
		СтрокаСодержимого.КодСтроки = СтрокаИзменения.КодСтроки;
		СтрокаСодержимого.Номенклатура = СтрокаИзменения.Номенклатура;
		СтрокаСодержимого.Характеристика = СтрокаИзменения.Характеристика;
		СтрокаСодержимого.Серия = СтрокаИзменения.Серия;
		СтрокаСодержимого.Количество = СтрокаИзменения.Количество;
		СтрокаСодержимого.КоличествоУпаковок = СтрокаИзменения.КоличествоУпаковок;
		СтрокаСодержимого.Упаковка = СтрокаИзменения.Упаковка;
		СтрокаСодержимого.ВесНетто = СтрокаИзменения.ВесНетто;
		СтрокаСодержимого.Вес = СтрокаИзменения.Вес;
		СтрокаСодержимого.Объем = СтрокаИзменения.Объем;
		СтрокаСодержимого.ВремяДоставкиС = СтрокаИзменения.ВремяДоставкиС;
		СтрокаСодержимого.ВремяДоставкиПо = СтрокаИзменения.ВремяДоставкиПо;
		СтрокаСодержимого.ДополнительнаяИнформацияПоДоставке = СтрокаИзменения.ДополнительнаяИнформацияПоДоставке;
		СтрокаСодержимого.ОсобыеУсловияПеревозки = СтрокаИзменения.ОсобыеУсловияПеревозки;
		СтрокаСодержимого.ОсобыеУсловияПеревозкиОписание = СтрокаИзменения.ОсобыеУсловияПеревозкиОписание;
		СтрокаСодержимого.Отменено = СтрокаИзменения.Отменено;
		СтрокаСодержимого.ПричинаОтмены = СтрокаИзменения.ПричинаОтмены;
		
		Если ДоставкаДоПеревозчика Тогда
			
			СтрокаСодержимого.КонечнаяТочкаДоставки = СтрокаИзменения.КонечнаяТочкаДоставки;
			СтрокаСодержимого.КонечнаяЗонаДоставки = СтрокаИзменения.КонечнаяЗонаДоставки;
			
		Иначе
			
			СтрокаСодержимого.КонечнаяТочкаДоставки = Справочники.ТочкиДоставки.ПустаяСсылка();
			СтрокаСодержимого.КонечнаяЗонаДоставки = Справочники.ЗоныДоставки.ПустаяСсылка();
			
		КонецЕсли;
		
	КонецЦикла;
	
	ЗаполнитьДополнительныеПоляМаршрута(Истина, Истина);
	
КонецПроцедуры

&НаСервере
Процедура МаршрутПослеУдаленияСервер()
	
	Отбор = Новый Структура;
	Отбор.Вставить("КлючСвязи", КлючСвязиНачалаМаршрута);
	
	ВосстановитьНачалоМаршрута = (Объект.Маршрут.НайтиСтроки(Отбор).Количество() = 0);
	
	РейсОбъект = РеквизитФормыВЗначение("Объект");
	РейсОбъект.УдалитьНеактуальныеСтрокиСодержимого();
	
	Если ВосстановитьНачалоМаршрута Тогда
		
		РейсОбъект.ДобавитьНачальнуюСтрокуМаршрута();
		Если РейсОбъект.Маршрут.Количество() > 0 Тогда
			
			РейсОбъект.Маршрут[0].КлючСвязи = КлючСвязиНачалаМаршрута;
			
		КонецЕсли;
		
	КонецЕсли;
	
	ЗначениеВРеквизитФормы(РейсОбъект, "Объект");
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьКлючСвязиНачалаМаршрута()
	
	Отбор = Новый Структура;
	Отбор.Вставить("Пункт", Объект.СкладОтправления);
	Отбор.Вставить("ТочкаДоставки", Объект.ТочкаОтправления);
	Отбор.Вставить("Операция", Перечисления.ОперацииРейсов.Погрузка);
	Строки = Объект.Маршрут.НайтиСтроки(Отбор);
	
	Если Строки.Количество() > 0 Тогда
		КлючСвязиНачалаМаршрута = Строки[0].КлючСвязи;
	Иначе
		КлючСвязиНачалаМаршрута = ОбщегоНазначенияКлиентСервер.ПустойУникальныйИдентификатор();
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура СтатусПриИзмененииСервер()
	
	НастроитьВидимостьДоступностьПолей();
	
	Если Объект.Статус = Перечисления.СтатусыРейсов.Отменен Тогда
		
		ЗаполнитьДополнительныеПоляМаршрута(Истина);
		
	КонецЕсли;
	
	ОбновитьДоступностьКомандСпискаОрдеров();
	
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьПодборДанных()
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("Организация", Объект.Организация);
	ПараметрыФормы.Вставить("Склад", Объект.СкладОтправления);
	ПараметрыФормы.Вставить("СпособДоставки", Объект.СпособДоставки);
	ПараметрыФормы.Вставить("Перевозчик", Объект.Перевозчик);
	ПараметрыФормы.Вставить("ДатаОтгрузки", Объект.ДатаВыезда);
	ПараметрыФормы.Вставить("УчитыватьКоличествоВДокументе", НЕ Объект.Проведен);
	ПараметрыФормы.Вставить("ДокументДоставки", Объект.Ссылка);
	
	ОткрытьФорму("Обработка.ПодборТоваровВДокументДоставки.Форма.ФормаПодбора",
		ПараметрыФормы,
		ЭтотОбъект,
		УникальныйИдентификатор);
	
КонецПроцедуры

// Параметры:
//  ВыбранноеЗначение - Структура:
//   * АдресПодобранныхТоваров - Строка
//
&НаСервере
Процедура ОбработкаВыбораПодборНаСервере(Знач ВыбранноеЗначение)
	
	ПодобранныеТовары = ПодобранныеТовары(ВыбранноеЗначение);
	
	КэшированныеЗначения = ПакетнаяОбработкаТабличнойЧастиКлиентСервер.ПолучитьСтруктуруКэшируемыеЗначения();
	
	ОтборСодержимое = Новый Структура;
	ОтборСодержимое.Вставить("Распоряжение", Неопределено);
	ОтборСодержимое.Вставить("ДокументПланирования", Неопределено);
	ОтборСодержимое.Вставить("КодСтроки", 0);
	ОтборСодержимое.Вставить("Упаковка", Справочники.УпаковкиЕдиницыИзмерения.ПустаяСсылка());
	ОтборСодержимое.Вставить("Отменено", Ложь);
	
	ОтборМаршрут = Новый Структура;
	ОтборМаршрут.Вставить("Пункт", Неопределено);
	ОтборМаршрут.Вставить("ТочкаДоставки", Справочники.ТочкиДоставки.ПустаяСсылка());
	ОтборМаршрут.Вставить("ЗонаДоставки", Справочники.ЗоныДоставки.ПустаяСсылка());
	
	ОтборПоКлючуСвязи = Новый Структура;
	ОтборПоКлючуСвязи.Вставить("КлючСвязи", ОбщегоНазначенияКлиентСервер.ПустойУникальныйИдентификатор());
	
	ИзмененныеСтроки = Новый Массив; // Массив Из ДанныеФормыЭлементКоллекции
	
	Для Каждого СтрокаПодобрано Из ПодобранныеТовары Цикл
		
		ЗаполнитьЗначенияСвойств(ОтборСодержимое, СтрокаПодобрано);
		СтрокиСодержимогоПоТовару = Объект.Содержимое.НайтиСтроки(ОтборСодержимое);
		
		Если СтрокаПодобрано.ТипДоставки = Перечисления.ТипыДоставки.Исходящая Тогда
			
			Операция = Перечисления.ОперацииРейсов.Разгрузка;
			
		Иначе
			
			Операция = Перечисления.ОперацииРейсов.Погрузка;
			
		КонецЕсли;
		
		Пункт = СтрокаПодобрано.ДоставкаДо;
		ПодходящаяСтрокаСодержимого = Неопределено;
		ПодходящаяСтрокаМаршрута = Неопределено;
		
		Для Каждого СтрокаСодержимогоПоТовару Из СтрокиСодержимогоПоТовару Цикл
			
			ОтборПоКлючуСвязи.КлючСвязи = СтрокаСодержимогоПоТовару.КлючСвязи;
			СтрокиМаршрута = Объект.Маршрут.НайтиСтроки(ОтборПоКлючуСвязи);
			СтрокаМаршрута = СтрокиМаршрута[0];
			
			Если СтрокаМаршрута.Пункт = Пункт
				И СтрокаМаршрута.ТочкаДоставки = СтрокаПодобрано.ТочкаДоставки
				И СтрокаМаршрута.ЗонаДоставки = СтрокаПодобрано.ЗонаДоставки Тогда
				
				ПодходящаяСтрокаМаршрута = СтрокаМаршрута;
				ПодходящаяСтрокаСодержимого = СтрокаСодержимогоПоТовару;
				Прервать;
				
			КонецЕсли;
			
		КонецЦикла;
		
		Если ПодходящаяСтрокаМаршрута = Неопределено Тогда
			
			ЗаполнитьЗначенияСвойств(ОтборМаршрут, СтрокаПодобрано);
			ОтборМаршрут.Пункт = Пункт;
			
			СтрокиМаршрута = Объект.Маршрут.НайтиСтроки(ОтборМаршрут);
			Если СтрокиМаршрута.Количество() > 0 Тогда
				ПодходящаяСтрокаМаршрута = СтрокиМаршрута[0];
			КонецЕсли;
			
		КонецЕсли;
		
		Если ПодходящаяСтрокаМаршрута = Неопределено Тогда
			
			ПодходящаяСтрокаМаршрута = Объект.Маршрут.Добавить();
			ЗаполнитьЗначенияСвойств(ПодходящаяСтрокаМаршрута, СтрокаПодобрано);
			ПодходящаяСтрокаМаршрута.Пункт = Пункт;
			ПодходящаяСтрокаМаршрута.КлючСвязи = Новый УникальныйИдентификатор();
			ПодходящаяСтрокаМаршрута.Операция = Операция;
			
		КонецЕсли;
		
		Если ПодходящаяСтрокаСодержимого = Неопределено Тогда
			
			ПодходящаяСтрокаСодержимого = Объект.Содержимое.Добавить();
			ЗаполнитьЗначенияСвойств(ПодходящаяСтрокаСодержимого, СтрокаПодобрано);
			ПодходящаяСтрокаСодержимого.КлючСвязи = ПодходящаяСтрокаМаршрута.КлючСвязи;
			
		Иначе
			
			ПодходящаяСтрокаСодержимого.Количество = ПодходящаяСтрокаСодержимого.Количество + СтрокаПодобрано.Количество;
			
		КонецЕсли;
		
		СтруктураДействия = Новый Структура("ПересчитатьКоличествоУпаковок", Неопределено);
		ПакетнаяОбработкаТабличнойЧастиКлиентСервер.ПересчитатьКоличествоУпаковокВСтрокеТЧ(
			ПодходящаяСтрокаСодержимого, СтруктураДействия, КэшированныеЗначения);
		
		ИзмененныеСтроки.Добавить(ПодходящаяСтрокаСодержимого);
		
	КонецЦикла;
	
	ЗаполнитьВесОбъемСтрокТоваров(ИзмененныеСтроки);
	
	Документы.Рейс.ЗаполнитьДополнительныеПараметрыСодержимого(ИзмененныеСтроки);
	
	ЗаполнитьДополнительныеПоляМаршрута(, Истина);
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьВесОбъемСтрокТоваров(ИзмененныеСтроки)
	
	КопияТовары = Объект.Содержимое.Выгрузить(
		ИзмененныеСтроки, "НомерСтроки, Номенклатура, Количество, КоличествоУпаковок, Упаковка, ВесНетто, Вес, Объем");
	КопияТовары.Колонки.Добавить("ТипНоменклатуры", Новый ОписаниеТипов("ПеречислениеСсылка.ТипыНоменклатуры"));
	КопияТовары.Колонки.Добавить("ВесУпаковки", ОбщегоНазначения.ОписаниеТипаЧисло(15, 3));
	КопияТовары.Колонки.Добавить("ОбъемУпаковки", ОбщегоНазначения.ОписаниеТипаЧисло(15, 3));
	КопияТовары.Колонки.Добавить("ЕдиницаИзмеренияВеса", Новый ОписаниеТипов("СправочникСсылка.УпаковкиЕдиницыИзмерения"));
	КопияТовары.Колонки.Добавить("ЕдиницаИзмеренияОбъема", Новый ОписаниеТипов("СправочникСсылка.УпаковкиЕдиницыИзмерения"));
	КопияТовары.Колонки.Добавить("ВесНеттоЕдиницы", ОбщегоНазначения.ОписаниеТипаЧисло(15, 3));
	
	КопияТовары.Колонки.Найти("НомерСтроки").Имя = "НомерСтрокиИсходный";
	ОбщегоНазначенияУТ.ПронумероватьТаблицуЗначений(КопияТовары, "НомерСтроки");
	
	СтруктураДействий = Новый Структура;
	СтруктураДействий.Вставить("ЗаполнитьВесУпаковки",
		Новый Структура("Номенклатура, Упаковка", "ВесУпаковки", Неопределено));
	СтруктураДействий.Вставить("ЗаполнитьОбъемУпаковки",
		Новый Структура("Номенклатура, Упаковка", "ОбъемУпаковки", Неопределено));
	СтруктураДействий.Вставить("ЗаполнитьЕдиницуИзмеренияВеса",
		Новый Структура("Номенклатура, Упаковка", "ЕдиницаИзмеренияВеса", Неопределено));
	СтруктураДействий.Вставить("ЗаполнитьЕдиницуИзмеренияОбъема",
		Новый Структура("Номенклатура, Упаковка", "ЕдиницаИзмеренияОбъема", Неопределено));
	СтруктураДействий.Вставить("ПересчитатьВесОбъем", Неопределено);
	
	НоменклатураСервер.ЗаполнитьСлужебныеРеквизитыПоНоменклатуреВКоллекции(КопияТовары, СтруктураДействий);
	
	ОтборСтрок = Новый Структура;
	ОтборСтрок.Вставить("НомерСтроки", 0);
	
	Для Каждого СтрокаКопии Из КопияТовары Цикл
		
		ПустаяУпаковка = ПредопределенноеЗначение("Справочник.УпаковкиЕдиницыИзмерения.ПустаяСсылка");
		ДанныеНоменклатуры = Справочники.УпаковкиЕдиницыИзмерения.КоэффициентВесОбъемПрочиеРеквизитыУпаковки(
			ПустаяУпаковка, СтрокаКопии.Номенклатура,, Ложь);
		СтрокаКопии.ВесНеттоЕдиницы = ДанныеНоменклатуры.ВесНетто; // Число
		ОбъемЕдиницы = ДанныеНоменклатуры.Объем; // Число
		МернаяЕдиница = Справочники.УпаковкиЕдиницыИзмерения.ЭтоМернаяЕдиница(СтрокаКопии.Упаковка);
		
		// объем в кубических метрах
		Если МернаяЕдиница Тогда
			СтрокаКопии.Объем = СтрокаКопии.Количество * ОбъемЕдиницы;
		Иначе
			СтрокаКопии.Объем = СтрокаКопии.КоличествоУпаковок * СтрокаКопии.ОбъемУпаковки;
		КонецЕсли;
		
		// вес нетто в кг
		СтрокаКопии.ВесНетто = СтрокаКопии.Количество * СтрокаКопии.ВесНеттоЕдиницы;
		
		// вес брутто в кг
		Если МернаяЕдиница Тогда
			СтрокаКопии.Вес = СтрокаКопии.ВесНетто;
		Иначе
			СтрокаКопии.Вес = СтрокаКопии.КоличествоУпаковок * СтрокаКопии.ВесУпаковки;
		КонецЕсли;
		
		ОтборСтрок.НомерСтроки = СтрокаКопии.НомерСтрокиИсходный;
		ИсходныеСтрокиТЧ = Объект.Содержимое.НайтиСтроки(ОтборСтрок);
		ЗаполнитьЗначенияСвойств(ИсходныеСтрокиТЧ[0], СтрокаКопии, "КоличествоУпаковок, ВесНетто, Вес, Объем");
		
	КонецЦикла;
	
КонецПроцедуры

// Параметры:
//  ВыбранноеЗначение - Структура - Выбранное значение:
// * АдресПодобранныхТоваров - Строка - 
// 
// Возвращаемое значение:
//  ТаблицаЗначений - Таблица подобранных товаров:
//  * ДоставкаДо - СправочникСсылка.Партнеры
//  * ТочкаДоставки - СправочникСсылка.ТочкиДоставки
//  * ЗонаДоставки - СправочникСсылка.ЗоныДоставки
//  * Количество - Число
//  * ТипДоставки - ПеречислениеСсылка.ТипыДоставки
//  * Упаковка - СправочникСсылка.УпаковкиЕдиницыИзмерения
//
&НаСервере
Функция ПодобранныеТовары(ВыбранноеЗначение)
	
	ПодобранныеТовары = ПолучитьИзВременногоХранилища(ВыбранноеЗначение.АдресПодобранныхТоваров); // ТаблицаЗначений
	УдалитьИзВременногоХранилища(ВыбранноеЗначение.АдресПодобранныхТоваров);
	Возврат ПодобранныеТовары;
	
КонецФункции

&НаСервере
Процедура АктуализироватьСостояниеРейса()
	
	Элементы.ДекорацияСостояниеРейса.Видимость = Объект.Проведен;
	
	Если Объект.Проведен Тогда
		Элементы.ДекорацияСостояниеРейса.Заголовок = Документы.Рейс.СостояниеРейса(Объект);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПроверитьЗаполнениеПередПодбором(Отказ)
	
	Если НЕ ЗначениеЗаполнено(Объект.Организация) Тогда
		
		ТекстОшибки = НСтр("ru = 'Поле ""Организация"" не заполнено'");
		ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстОшибки,, "Организация", "Объект", Отказ);
		
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(Объект.СкладОтправления) Тогда
		
		ТекстОшибки = НСтр("ru = 'Поле ""Склад"" не заполнено'");
		ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстОшибки,, "СкладОтправления", "Объект", Отказ);
		
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(Объект.СпособДоставки) Тогда
		
		ТекстОшибки = НСтр("ru = 'Поле ""Способ доставки"" не заполнено'");
		ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстОшибки,, "СпособДоставки", "Объект", Отказ);
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Асинх Функция РезультатЗаписиДокументПередПодбором()
	
	РезультатЗаписи = Ложь;
	
	Если Объект.Проведен Тогда
		ТекстВопроса = НСтр("ru = 'Документ был изменен. Провести?'");
	Иначе
		ТекстВопроса = НСтр("ru = 'Документ был изменен. Записать?'");
	КонецЕсли;
	Ответ = Ждать ВопросАсинх(ТекстВопроса, РежимДиалогаВопрос.ДаНет); // КодВозвратаДиалога
	
	Если Ответ <> КодВозвратаДиалога.Да Тогда
		Возврат РезультатЗаписи;
	КонецЕсли;
	
	Если Объект.Проведен Тогда
		
		ОчиститьСообщения();
		Если ПроверитьЗаполнение() Тогда
			РезультатЗаписи = Записать(Новый Структура("РежимЗаписи", РежимЗаписиДокумента.Проведение));
		КонецЕсли;
		
	Иначе
		
		РезультатЗаписи = Записать(Новый Структура("РежимЗаписи", РежимЗаписиДокумента.Запись));
		
	КонецЕсли;
	
	Возврат РезультатЗаписи;
	
КонецФункции

&НаСервереБезКонтекста
Функция ЗонаТочкиДоставки(Знач ТочкаДоставки)
	
	Возврат ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ТочкаДоставки, "ЗонаДоставки");
	
КонецФункции

&НаСервере
Процедура УстановитьДоступностьКомандыПодбора()
	
	Если ТолькоПросмотр Тогда
		
		Элементы.МаршрутПодобратьДанные.Доступность = Ложь;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Функция МаршрутЗаполнен()
	
	МаршрутПустой = Объект.Маршрут.Количество() = 0
				ИЛИ (Объект.Маршрут.Количество() = 1
					И ЗначениеЗаполнено(КлючСвязиНачалаМаршрута));
	
	Возврат НЕ МаршрутПустой;
	
КонецФункции

&НаКлиенте
Процедура ОчиститьПунктыМаршрута()
	
	Если НЕ МаршрутЗаполнен() Тогда
		Возврат;
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(КлючСвязиНачалаМаршрута) Тогда
		
		Объект.Маршрут.Очистить();
		
	Иначе
		
		СтрокиКУдалению = Новый Массив; // Массив из СтрокаТабличнойЧасти
		Для Каждого ТекущаяСтрока Из Объект.Маршрут Цикл
			
			Если ТекущаяСтрока.КлючСвязи <> КлючСвязиНачалаМаршрута Тогда
				
				СтрокиКУдалению.Добавить(ТекущаяСтрока);
				
			КонецЕсли;
			
		КонецЦикла;
		
		Для Каждого СтрокаТЧ Из СтрокиКУдалению Цикл
			
			Объект.Маршрут.Удалить(СтрокаТЧ);
			
		КонецЦикла;
		
	КонецЕсли;
	
	МаршрутПослеУдаленияСервер();
	
КонецПроцедуры

&НаКлиенте
Асинх Функция ПоказатьВопросОбОчисткеПунктовМаршрута()
	
	ТекстВопроса = НСтр("ru = 'Список пунктов маршрута будет очищен. Продолжить?'");
	Обещание = ВопросАсинх(ТекстВопроса, РежимДиалогаВопрос.ДаНет);
	
	Возврат Обещание;
	
КонецФункции

&НаСервереБезКонтекста
Функция ВариантОтчетаСборкаПоРаспоряжениямРейса(Знач Рейс)
	
	Вариант = Отчеты.СборкаПоРейсу.ВариантОтчетаПоРейсу(Рейс);
	Возврат Вариант;
	
КонецФункции

&НаСервере
Процедура УстановитьИспользованиеГиперссылкиСостояниеРейса()
	
	ПараметрыВариантаОтчета = Отчеты.СборкаПоРейсу.ПараметрыВариантаОтчетаПоРейсу(Объект.Ссылка);
	Элементы.ДекорацияСостояниеРейса.Гиперссылка = ПараметрыВариантаОтчета.СкладИспользуетОрдернуюСхему;
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьДополнительныеПоляМаршрута(Знач ОбновитьФлагОтмены = Ложь, Знач ОбновитьВремяДоставки = Ложь)
	
	КешВспомогательныхДанных = Новый Соответствие;
	
	Для каждого СтрокаСодержимого Из Объект.Содержимое Цикл
		
		ВспомогательныеДанные = КешВспомогательныхДанных[СтрокаСодержимого.КлючСвязи];
		
		Если ВспомогательныеДанные = Неопределено Тогда
			
			Если СтрокаСодержимого.Отменено Тогда
				КоличествоСтрокОтменено = 1;
			Иначе
				КоличествоСтрокОтменено = 0;
			КонецЕсли;
			
			ВспомогательныеДанные = Новый Структура;
			ВспомогательныеДанные.Вставить("КоличествоСтрокВсего", 1);
			ВспомогательныеДанные.Вставить("КоличествоСтрокОтменено", КоличествоСтрокОтменено);
			ВспомогательныеДанные.Вставить("ВремяДоставкиС", СтрокаСодержимого.ВремяДоставкиС);
			ВспомогательныеДанные.Вставить("ВремяДоставкиПо", СтрокаСодержимого.ВремяДоставкиПо);
			ВспомогательныеДанные.Вставить("ВремяДоставкиОтличается", Ложь);
			
		Иначе
			
			ВспомогательныеДанные.КоличествоСтрокВсего = ВспомогательныеДанные.КоличествоСтрокВсего + 1;
			Если СтрокаСодержимого.Отменено Тогда
				ВспомогательныеДанные.КоличествоСтрокОтменено = ВспомогательныеДанные.КоличествоСтрокОтменено + 1;
			КонецЕсли;
			
			Если СтрокаСодержимого.ВремяДоставкиС > ВспомогательныеДанные.ВремяДоставкиС Тогда
				
				Если ЗначениеЗаполнено(ВспомогательныеДанные.ВремяДоставкиС) Тогда
					ВспомогательныеДанные.ВремяДоставкиОтличается = Истина;
				КонецЕсли;
				ВспомогательныеДанные.ВремяДоставкиС = СтрокаСодержимого.ВремяДоставкиС;
				
			КонецЕсли;
			
			Если СтрокаСодержимого.ВремяДоставкиПо < ВспомогательныеДанные.ВремяДоставкиПо
				И ЗначениеЗаполнено(СтрокаСодержимого.ВремяДоставкиПо) Тогда
				
				ВспомогательныеДанные.ВремяДоставкиОтличается = Истина;
				ВспомогательныеДанные.ВремяДоставкиПо = СтрокаСодержимого.ВремяДоставкиПо;
				
			КонецЕсли;
			
			Если НЕ ЗначениеЗаполнено(ВспомогательныеДанные.ВремяДоставкиПо)
				И ЗначениеЗаполнено(СтрокаСодержимого.ВремяДоставкиПо) Тогда
				
				ВспомогательныеДанные.ВремяДоставкиПо = СтрокаСодержимого.ВремяДоставкиПо;
				
			КонецЕсли;
			
			Если ЗначениеЗаполнено(СтрокаСодержимого.ВремяДоставкиС)
				И ЗначениеЗаполнено(ВспомогательныеДанные.ВремяДоставкиС)
				И СтрокаСодержимого.ВремяДоставкиС <> ВспомогательныеДанные.ВремяДоставкиС Тогда
				
				ВспомогательныеДанные.ВремяДоставкиОтличается = Истина;
				
			КонецЕсли;
			
			Если ЗначениеЗаполнено(СтрокаСодержимого.ВремяДоставкиПо)
				И ЗначениеЗаполнено(ВспомогательныеДанные.ВремяДоставкиПо)
				И СтрокаСодержимого.ВремяДоставкиПо <> ВспомогательныеДанные.ВремяДоставкиПо Тогда
				
				ВспомогательныеДанные.ВремяДоставкиОтличается = Истина;
				
			КонецЕсли;
			
		КонецЕсли;
		
		КешВспомогательныхДанных[СтрокаСодержимого.КлючСвязи] = ВспомогательныеДанные;
		
	КонецЦикла;
	
	Для каждого СтрокаМаршрута Из Объект.Маршрут Цикл
		
		ВспомогательныеДанные = КешВспомогательныхДанных[СтрокаМаршрута.КлючСвязи];
		
		СтрокаМаршрута.ОтмененоЧастично = Ложь;
		
		Если ВспомогательныеДанные = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		СтрокаМаршрутаОтменена = Ложь;
		
		Если ВспомогательныеДанные.КоличествоСтрокОтменено > 0 Тогда
			
			Если ВспомогательныеДанные.КоличествоСтрокВсего <> ВспомогательныеДанные.КоличествоСтрокОтменено Тогда
				
				СтрокаМаршрута.ОтмененоЧастично = Истина;
				
			Иначе
				
				СтрокаМаршрутаОтменена = Истина;
				
			КонецЕсли;
			
		КонецЕсли;
		
		Если ОбновитьФлагОтмены Тогда
			СтрокаМаршрута.Отменено = СтрокаМаршрутаОтменена;
		КонецЕсли;
		
		Если ВспомогательныеДанные.ВремяДоставкиС > ВспомогательныеДанные.ВремяДоставкиПо Тогда
			
			ПустоеВремя = '00010101';
			ВспомогательныеДанные.ВремяДоставкиС = ПустоеВремя;
			ВспомогательныеДанные.ВремяДоставкиПо = ПустоеВремя;
			ВспомогательныеДанные.ВремяДоставкиОтличается = Ложь;
			
		КонецЕсли;
		
		Если ОбновитьВремяДоставки
			И Не ЗначениеЗаполнено(СтрокаМаршрута.ВремяДоставкиС)
			И Не ЗначениеЗаполнено(СтрокаМаршрута.ВремяДоставкиПо) Тогда
			
			СтрокаМаршрута.ВремяДоставкиС = ВспомогательныеДанные.ВремяДоставкиС;
			СтрокаМаршрута.ВремяДоставкиПо = ВспомогательныеДанные.ВремяДоставкиПо;
			
		КонецЕсли;
		
		Если ЗначениеЗаполнено(СтрокаМаршрута.ВремяДоставкиС)
			И ЗначениеЗаполнено(ВспомогательныеДанные.ВремяДоставкиС)
			И СтрокаМаршрута.ВремяДоставкиС <> ВспомогательныеДанные.ВремяДоставкиС Тогда
			
			ВспомогательныеДанные.ВремяДоставкиОтличается = Истина;
			
		КонецЕсли;
		
		Если ЗначениеЗаполнено(СтрокаМаршрута.ВремяДоставкиПо)
			И ЗначениеЗаполнено(ВспомогательныеДанные.ВремяДоставкиПо)
			И СтрокаМаршрута.ВремяДоставкиПо <> ВспомогательныеДанные.ВремяДоставкиПо Тогда
			
			ВспомогательныеДанные.ВремяДоставкиОтличается = Истина;
			
		КонецЕсли;
		
		СтрокаМаршрута.ВремяДоставкиОтличается = ВспомогательныеДанные.ВремяДоставкиОтличается;
		
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура ОтменитьСтрокиСодержимого(ПричинаОтмены)
	
	Для Каждого СтрокаПункта Из Объект.Содержимое Цикл
		
		Если СтрокаПункта.КлючСвязи <> КлючСвязиНачалаМаршрута
		   И НЕ ЗначениеЗаполнено(СтрокаПункта.ПричинаОтмены) Тогда
			
			СтрокаПункта.Отменено = Истина;
			СтрокаПункта.ПричинаОтмены = ПричинаОтмены;
			
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Функция ВсеСтрокиСодержимогоОтменены()
	
	ВсеСтрокиОтменены = Истина;
	
	Для Каждого СтрокаПункта Из Объект.Содержимое Цикл
		
		Если СтрокаПункта.КлючСвязи <> КлючСвязиНачалаМаршрута
		   И НЕ ЗначениеЗаполнено(СтрокаПункта.ПричинаОтмены) Тогда
			
			ВсеСтрокиОтменены = Ложь;
			Прервать;
			
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат ВсеСтрокиОтменены;
	
КонецФункции

// Параметры:
//  РезультатЗакрытия - СправочникСсылка.ПричиныОтменыДоставки, Неопределено - 
//  ДополнительныеПараметры - ПеречислениеСсылка.СтатусыРейсов -
//
&НаКлиенте
Процедура ЗавершитьВыборПричиныОтмены(РезультатЗакрытия, ДополнительныеПараметры) Экспорт
	
	Если ЗначениеЗаполнено(РезультатЗакрытия) Тогда
		
		ОтменитьСтрокиСодержимого(РезультатЗакрытия);
		СтатусПриИзмененииСервер();
		
		// СтандартныеПодсистемы.ПодключаемыеКоманды
		ПодключаемыеКомандыКлиент.НачатьОбновлениеКоманд(ЭтотОбъект);
		// Конец СтандартныеПодсистемы.ПодключаемыеКоманды
		
	Иначе
		
		СтатусДоИзменения = ДополнительныеПараметры;
		ТекущийСтатус = СтатусДоИзменения;
		Объект.Статус = СтатусДоИзменения;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Функция ЭтоСтрокаНачалаМаршрута(ДанныеСтроки)
	
	ЭтоНачалоМаршрута = (ДанныеСтроки.КлючСвязи = КлючСвязиНачалаМаршрута);
	Возврат ЭтоНачалоМаршрута;
	
КонецФункции

// Параметры:
//  ПеремещениеВверх - Булево -
// 
// Возвращаемое значение:
//  Массив из Число -
//
&НаКлиенте
Функция НомераВыделенныхСтрокМаршрута(ПеремещениеВверх = Истина)
	
	ИдентификаторыСтрок = Элементы.Маршрут.ВыделенныеСтроки;
	ДанныеСтрок = Новый Массив; // Массив из Структура
	НомераСтрок = Новый Массив; // Массив из Число
	
	Для Каждого Идентификатор Из ИдентификаторыСтрок Цикл
		
		ДанныеСтроки = Объект.Маршрут.НайтиПоИдентификатору(Идентификатор);
		Если НЕ ЭтоСтрокаНачалаМаршрута(ДанныеСтроки) Тогда
			
			НомерСтроки = ДанныеСтроки.НомерСтроки;
			НомераСтрок.Добавить(НомерСтроки);
			
			ДанныеНомера = Новый Структура;
			ДанныеНомера.Вставить("Идентификатор", Идентификатор);
			ДанныеНомера.Вставить("НомерСтроки", НомерСтроки);
			ДанныеСтрок.Добавить(ДанныеНомера);
			
		КонецЕсли;
		
	КонецЦикла;
	
	Если ПеремещениеВверх Тогда
		
		НомераСтрок = ОбщегоНазначенияУТКлиентСервер.СортированныйМассив(НомераСтрок, НаправлениеСортировки.Возр);
		
	Иначе
		
		НомераСтрок = ОбщегоНазначенияУТКлиентСервер.СортированныйМассив(НомераСтрок, НаправлениеСортировки.Убыв);
		
	КонецЕсли;
	
	Возврат НомераСтрок;
	
КонецФункции

&НаКлиенте
Процедура УстановитьДоступностьКомандТаблицыМаршруты()
	
	ЭтоНачальнаяСтрокаМаршрута = ЭтоСтрокаНачалаМаршрута(Элементы.Маршрут.ТекущиеДанные);
	УстановитьДоступностьКомандТаблицыМаршрутыСервер(ЭтоНачальнаяСтрокаМаршрута);
	
КонецПроцедуры

&НаСервере
Процедура УстановитьДоступностьКомандТаблицыМаршрутыСервер(Знач НачальнаяСтрокаМаршрута)
	
	ДоступноИзменениеСтрок = ДоступноИзменениеСоставаМаршрута();
	
	Элементы.Маршрут.ИзменятьПорядокСтрок = Не НачальнаяСтрокаМаршрута;
	Элементы.Маршрут.ИзменятьСоставСтрок =
		(Не НачальнаяСтрокаМаршрута
			И ДоступноИзменениеСтрок);
	Элементы.Маршрут.РазрешитьНачалоПеретаскивания = Не НачальнаяСтрокаМаршрута;
	
	ЭлементыПеремещения = Новый Массив; // Массив из Строка
	ЭлементыПеремещения.Добавить(Элементы.МаршрутПереместитьВверх.Имя);
	ЭлементыПеремещения.Добавить(Элементы.МаршрутПереместитьВниз.Имя);
	
	ОбщегоНазначенияУТКлиентСервер.УстановитьСвойствоЭлементовФормы(
		Элементы,
		ЭлементыПеремещения,
		"Доступность",
		Не НачальнаяСтрокаМаршрута);
	
КонецПроцедуры

&НаСервере
Функция ДоступноИзменениеСоставаМаршрута()
	
	Результат =
		НЕ (Объект.Статус = Перечисления.СтатусыРейсов.Сформирован
			ИЛИ Объект.Статус = Перечисления.СтатусыРейсов.Отправлен
			ИЛИ Объект.Статус = Перечисления.СтатусыРейсов.Завершен);

	Возврат Результат;
	
КонецФункции

&НаСервере
Процедура ЗаполнитьПризнакОтгрузкаПослеФормированияРейса()
	
	ОтгрузкаПослеФормированияРейса = Ложь;
	Если Не Объект.СкладОтправления.Пустая() Тогда
		
		ОтгрузкаПослеФормированияРейса = СкладыСервер.НачинатьОтгрузкуПослеФормированияЗаданияНаПеревозку(Объект.СкладОтправления);
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьДоступностьКомандСпискаОрдеров()
	
	ОрдераБезИзменений =
		(Объект.Статус = Перечисления.СтатусыРейсов.Отправлен
			Или Объект.Статус = Перечисления.СтатусыРейсов.Завершен
			Или Объект.Статус = Перечисления.СтатусыРейсов.Отменен);
		
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(
		Элементы,
		"СписокОрдеровОбновитьДатуОтгрузкиОрдеров",
		"Доступность",
		Не ОрдераБезИзменений И Не ТолькоПросмотр);
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьОтображениеСпискаОрдеров()
	
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(
		Элементы,
		"СписокОрдеров",
		"Видимость",
		ОтгрузкаПослеФормированияРейса);
	
КонецПроцедуры

&НаСервере
Процедура УстановитьОтборОрдеров()
	
	Если ОтгрузкаПослеФормированияРейса
		И Не Объект.Ссылка.Пустая() Тогда
		
		ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(
			СписокОрдеров, "ЗаданиеНаПеревозку", Объект.Ссылка,,, Истина);
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьДатуОтгрузкиОрдеровСервер(Знач ОрдераКОбработке, ОперацияВыполнена)
	
	ШаблонСообщения = НСтр("ru = 'Не удалось обработать %1 по причине: %2'");
	
	Запрос = Новый Запрос;
	ТекстЗапроса =
	"ВЫБРАТЬ
	|	РасходныйОрдер.Ссылка КАК Ссылка,
	|	РасходныйОрдер.Представление КАК Представление
	|ИЗ
	|	Документ.РасходныйОрдерНаТовары КАК РасходныйОрдер
	|ГДЕ
	|	РасходныйОрдер.Ссылка В(&ОрдераКОбработке)
	|	И РасходныйОрдер.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыРасходныхОрдеров.Подготовлен)
	|	И (РасходныйОрдер.ДатаОтгрузки < &НачалоДняВыезда
	|			ИЛИ РасходныйОрдер.ДатаОтгрузки > &КонецДняВыезда)
	|	И РасходныйОрдер.ОтгрузкаПоЗаданиюНаПеревозку
	|	И РасходныйОрдер.ЗаданиеНаПеревозку = &Рейс
	|	И НЕ РасходныйОрдер.ПометкаУдаления";
	Запрос.Текст = ТекстЗапроса;
	
	Запрос.УстановитьПараметр("ОрдераКОбработке", ОрдераКОбработке);
	Запрос.УстановитьПараметр("Рейс", Объект.Ссылка);
	Запрос.УстановитьПараметр("НачалоДняВыезда", НачалоДня(Объект.ДатаВыезда));
	Запрос.УстановитьПараметр("КонецДняВыезда", КонецДня(Объект.ДатаВыезда));
	
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		
		ДокументПредставление = Выборка.Представление; // Строка
		РасходныйОрдерСсылка = Выборка.Ссылка; // ДокументСсылка.РасходныйОрдерНаТовары
		
		НачатьТранзакцию();
		
		Попытка
			
			Блокировка = Новый БлокировкаДанных;
			
			ЭлементБлокировки = Блокировка.Добавить("Документ.РасходныйОрдерНаТовары");
			ЭлементБлокировки.УстановитьЗначение("Ссылка", РасходныйОрдерСсылка);
			Блокировка.Заблокировать();
			
			РасходныйОрдерОбъект = РасходныйОрдерСсылка.ПолучитьОбъект();
			
			РасходныйОрдерОбъект.ДатаОтгрузки = Объект.ДатаВыезда;
			
			РасходныйОрдерОбъект.ДатаОтгрузки = Объект.ДатаВыезда;
			
			СтрокаЗапретаИзменения = "";
			ИзмененияЗапрещены = ДатыЗапретаИзменения.ИзменениеЗапрещено(РасходныйОрдерОбъект, РасходныйОрдерСсылка, СтрокаЗапретаИзменения);
			
			Если ИзмененияЗапрещены Тогда
				
				ОтменитьТранзакцию();
				
				ОбщегоНазначения.СообщитьПользователю(СтрокаЗапретаИзменения);
				Продолжить;
				
			КонецЕсли;
			
			Если РасходныйОрдерОбъект.Проведен Тогда
				РасходныйОрдерОбъект.Записать(РежимЗаписиДокумента.Проведение, РежимПроведенияДокумента.Неоперативный);
			Иначе
				РасходныйОрдерОбъект.Записать(РежимЗаписиДокумента.Запись);
			КонецЕсли;
			
			ЗафиксироватьТранзакцию();
			
		Исключение
			
			ОтменитьТранзакцию();
			
			Причина = ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
			ТекстСообщения = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
				ШаблонСообщения,
				ДокументПредставление,
				Причина);
				
			ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);
			
			Продолжить;
			
		КонецПопытки;
		
		ОперацияВыполнена = Истина;
		
	КонецЦикла;
	
КонецПроцедуры

