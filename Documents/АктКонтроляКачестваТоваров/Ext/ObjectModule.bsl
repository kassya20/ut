#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ОбработчикиСобытий

Процедура ОбработкаПроверкиЗаполнения(Отказ, ПроверяемыеРеквизиты)
	
	МассивНепроверяемыхРеквизитов = Новый Массив();
	
	// Товары.Действие.
	Если Статус = Перечисления.СтатусыАктовКонтроляКачества.ВРаботе
			Или Статус = Перечисления.СтатусыАктовКонтроляКачества.ОжидаетРешения Тогда
		МассивНепроверяемыхРеквизитов.Добавить("Товары.Действие");
	КонецЕсли;
	
	// Товары.РезультатПроверкиКачества.
	Если Статус = Перечисления.СтатусыАктовКонтроляКачества.ВРаботе Тогда
		МассивНепроверяемыхРеквизитов.Добавить("Товары.РезультатПроверкиКачества");
	КонецЕсли;
	
	// Товары.Характеристика.
	// Товары.ХарактеристикаОприходование.
	ПараметрыПроверки = НоменклатураСервер.ПараметрыПроверкиЗаполненияХарактеристик();
	ПараметрыПроверки.ИменаПолейССуффиксом.Вставить("Номенклатура", "НоменклатураОприходование");
	ПараметрыПроверки.ИменаПолейССуффиксом.Вставить("Характеристика", "ХарактеристикаОприходование");
	НоменклатураСервер.ПроверитьЗаполнениеХарактеристик(
		ЭтотОбъект,
		МассивНепроверяемыхРеквизитов,
		Отказ,
		ПараметрыПроверки);
	
	// Товары.Серия.
	НоменклатураСервер.ПроверитьЗаполнениеСерий(
		ЭтотОбъект,
		НоменклатураСервер.ПараметрыУказанияСерий(ЭтотОбъект, Документы.АктКонтроляКачестваТоваров),
		Отказ,
		МассивНепроверяемыхРеквизитов);
		
	// Товары.Помещение.
	// Товары.Ячейка.
	СкладыСервер.ПроверитьЗаполнениеПомещений(ЭтотОбъект, МассивНепроверяемыхРеквизитов, Отказ);
	СкладыСервер.ПроверитьЗаполнениеЯчеек(ЭтотОбъект, МассивНепроверяемыхРеквизитов, Отказ);
	
	ПараметрыПроверки = НоменклатураСервер.ПараметрыПроверкиЗаполненияКоличества();
	ПараметрыПроверки.ПроверитьКомплектностьТоварныхМест = Истина;
	ПараметрыПроверки.ПоляГруппировкиПроверкиКомплектности = "Действие,Назначение,Склад,Помещение";
	НоменклатураСервер.ПроверитьЗаполнениеКоличества(ЭтотОбъект, ПроверяемыеРеквизиты, Отказ, ПараметрыПроверки);
	
	// Проверка заполнения упаковок номенклатуры на адресных складах
	ВыборкаСкладПомещение = КонтрольКачества.ВыборкаСкладПомещение(Товары.Выгрузить(,"Склад,Помещение"), Дата);
	Пока ВыборкаСкладПомещение.Следующий() Цикл
		ПараметрыПроверки = НоменклатураСервер.ПараметрыПроверкиЗаполненияУпаковок();
		ПараметрыПроверки.ОтборПроверяемыхСтрок.Вставить("Склад", ВыборкаСкладПомещение.Склад);
		ПараметрыПроверки.ОтборПроверяемыхСтрок.Вставить("Помещение", ВыборкаСкладПомещение.Помещение);
		ИменаПолейССуффиксом = Новый Структура();
		ИменаПолейССуффиксом.Вставить("Номенклатура", "НоменклатураОприходование");
		ИменаПолейССуффиксом.Вставить("Упаковка", "УпаковкаОприходование");
		ПараметрыПроверки.ИменаПолейССуффиксом = ИменаПолейССуффиксом;
		НоменклатураСервер.ПроверитьЗаполнениеУпаковок(
			ЭтотОбъект,
			МассивНепроверяемыхРеквизитов,
			Отказ,
			ПараметрыПроверки);
	КонецЦикла;
	Если МассивНепроверяемыхРеквизитов.Найти("Товары.Упаковка") = Неопределено Тогда
		МассивНепроверяемыхРеквизитов.Добавить("Товары.Упаковка");
	КонецЕсли;
	Если МассивНепроверяемыхРеквизитов.Найти("Товары.УпаковкаОприходование") = Неопределено Тогда
		МассивНепроверяемыхРеквизитов.Добавить("Товары.УпаковкаОприходование");
	КонецЕсли;
	
	МассивНепроверяемыхРеквизитов.Добавить("Товары.НоменклатураОприходование");
	МассивНепроверяемыхРеквизитов.Добавить("Товары.ПодНазначение");
	
	
	ШаблонСообщенияНеЗаполнено = НСтр("ru='Не заполнена колонка Номенклатура (оприходование) в строке %1 списка ""Товары"".'");
	ШаблонСообщенияОдинаковые = НСтр("ru='В строке %1 списка ""Товары"" товар исходного качества совпадает с товаром другого качества'");
	ШаблонКоличествоОприходование = НСтр("ru = 'Количество номенклатуры исходного качества ""%НоменклатураСписания%"" в строке ""%НомерСтроки%"" списка ""Товары"" отличается от количества номенклатуры другого качества ""%НоменклатураОприходования%"" на ""%Количество%"" единиц хранения'");

	Для Индекс = 0 По Товары.Количество() - 1 Цикл
		
		СтрокаТаблицы = Товары[Индекс];
		Поле = СтрШаблон("Товары[%1].НоменклатураОприходование", Индекс);
		
		// Товары.НоменклатураОприходование
		Если (СтрокаТаблицы.Действие = Перечисления.ДействияПоТоварамВАктеКонтроляКачества.ИзменитьКачество
				Или СтрокаТаблицы.Действие = Перечисления.ДействияПоТоварамВАктеКонтроляКачества.ОформитьПорчу) Тогда
				
			Если Не ЗначениеЗаполнено(СтрокаТаблицы.НоменклатураОприходование) Тогда
				
				ПутьКТабЧасти = ОбщегоНазначенияКлиентСервер.ПутьКТабличнойЧасти(
					"Товары",
					СтрокаТаблицы.НомерСтроки,
					"НоменклатураОприходование");
				
				ОбщегоНазначения.СообщитьПользователю(
					СтрШаблон(ШаблонСообщенияНеЗаполнено, Индекс + 1),
					ЭтотОбъект,
					ПутьКТабЧасти,
					,
					Отказ);
			КонецЕсли;
			
			Если ЗначениеЗаполнено(СтрокаТаблицы.Номенклатура)
					И СтрокаТаблицы.Номенклатура = СтрокаТаблицы.НоменклатураОприходование Тогда
					
				ПутьКТабЧасти = ОбщегоНазначенияКлиентСервер.ПутьКТабличнойЧасти(
					"Товары",
					СтрокаТаблицы.НомерСтроки,
					"НоменклатураОприходование");
					
				ОбщегоНазначения.СообщитьПользователю(
					СтрШаблон(ШаблонСообщенияОдинаковые, Индекс + 1),
					ЭтотОбъект,
					ПутьКТабЧасти,
					,
					Отказ);
					
			КонецЕсли;
			
	
			// Товары.КоличествоОприходование
			Если СтрокаТаблицы.Количество <> СтрокаТаблицы.КоличествоОприходование
					И ЗначениеЗаполнено(СтрокаТаблицы.НоменклатураОприходование) Тогда
					
				КоличествоРасхождение = СтрокаТаблицы.Количество - СтрокаТаблицы.КоличествоОприходование;
				КоличествоРасхождение = Макс(КоличествоРасхождение, -КоличествоРасхождение);
				
				ПредставлениеНоменклатурыСписания = НоменклатураКлиентСервер.ПредставлениеНоменклатуры(
					СтрокаТаблицы.Номенклатура,
					СтрокаТаблицы.Характеристика,
					СтрокаТаблицы.Упаковка,
					СтрокаТаблицы.Серия,
					СтрокаТаблицы.Назначение);
				ПредставлениеНоменклатурыОприходования = НоменклатураКлиентСервер.ПредставлениеНоменклатуры(
					СтрокаТаблицы.НоменклатураОприходование,
					СтрокаТаблицы.ХарактеристикаОприходование,
					СтрокаТаблицы.УпаковкаОприходование);
				
				ТекстСообщения = СтрЗаменить(ШаблонКоличествоОприходование, "%НомерСтроки%", Индекс + 1);
				ТекстСообщения = СтрЗаменить(ТекстСообщения, "%НоменклатураСписания%", ПредставлениеНоменклатурыСписания);
				ТекстСообщения = СтрЗаменить(ТекстСообщения, "%НоменклатураОприходования%", ПредставлениеНоменклатурыОприходования);
				ТекстСообщения = СтрЗаменить(ТекстСообщения, "%Количество%", КоличествоРасхождение);
				
				Поле = ОбщегоНазначенияКлиентСервер.ПутьКТабличнойЧасти("Товары", Индекс + 1, "КоличествоУпаковок");
				ОбщегоНазначения.СообщитьПользователю(
					ТекстСообщения,
					ЭтотОбъект,
					Поле,
					"Объект",
					Отказ);
					
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЦикла;
	
	Если ПолучитьФункциональнуюОпцию("ИспользоватьМногооборотнуюТару") Тогда
		
		Запрос = Новый Запрос;
		Запрос.Текст =
		"ВЫБРАТЬ
		|	ТаблицаТоваров.Номенклатура,
		|	ТаблицаТоваров.НоменклатураОприходование,
		|	ТаблицаТоваров.НомерСтроки
		|ПОМЕСТИТЬ ТаблицаТоваров
		|ИЗ
		|	&ТаблицаТоваров КАК ТаблицаТоваров
		|ИНДЕКСИРОВАТЬ ПО
		|	Номенклатура
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ТаблицаТоваров.НомерСтроки КАК НомерСтроки,
		|	ВЫРАЗИТЬ(ТаблицаТоваров.Номенклатура КАК Справочник.Номенклатура).ТипНоменклатуры КАК НоменклатураТипНоменклатуры,
		|	ВЫРАЗИТЬ(ТаблицаТоваров.НоменклатураОприходование КАК Справочник.Номенклатура).ТипНоменклатуры КАК НоменклатураОприходованиеТипНоменклатуры
		|ИЗ
		|	ТаблицаТоваров КАК ТаблицаТоваров
		|ГДЕ
		|	ВЫРАЗИТЬ(ТаблицаТоваров.Номенклатура КАК Справочник.Номенклатура).ТипНоменклатуры <> ВЫРАЗИТЬ(ТаблицаТоваров.НоменклатураОприходование КАК Справочник.Номенклатура).ТипНоменклатуры
		|
		|УПОРЯДОЧИТЬ ПО
		|	НомерСтроки";
		
		ТаблицаТоваров = Товары.Выгрузить(Новый Массив(), "НомерСтроки,Номенклатура,НоменклатураОприходование");
		Для Каждого СтрокаТаблицы Из Товары Цикл
			
			Если СтрокаТаблицы.Действие = Перечисления.ДействияПоТоварамВАктеКонтроляКачества.ИзменитьКачество
					Или СтрокаТаблицы.Действие = Перечисления.ДействияПоТоварамВАктеКонтроляКачества.ОформитьПорчу Тогда
				
				ЗаполнитьЗначенияСвойств(ТаблицаТоваров.Добавить(), СтрокаТаблицы);
				
			КонецЕсли;
			
		КонецЦикла;
		Запрос.УстановитьПараметр("ТаблицаТоваров", ТаблицаТоваров);
		
		Выборка = Запрос.Выполнить().Выбрать();
		
		ТекстОшибки = НСтр("ru='В строке %НомерСтроки% списка ""Товары"" не совпадают типы номенклатуры. У номенклатуры исходного качества тип %НоменклатураТипНоменклатуры%, другого качества - %НоменклатураОприходованиеТипНоменклатуры%.'");
		
		Пока Выборка.Следующий() Цикл
			СообщениеОбОшибке = СтрЗаменить(ТекстОшибки, "%НомерСтроки%", Выборка.НомерСтроки); 
			СообщениеОбОшибке = СтрЗаменить(СообщениеОбОшибке, "%НоменклатураТипНоменклатуры%", Выборка.НоменклатураТипНоменклатуры); 
			СообщениеОбОшибке = СтрЗаменить(СообщениеОбОшибке, "%НоменклатураОприходованиеТипНоменклатуры%", Выборка.НоменклатураОприходованиеТипНоменклатуры); 
			
			Поле = ОбщегоНазначенияКлиентСервер.ПутьКТабличнойЧасти("Товары", Выборка.НомерСтроки, "НоменклатураОприходование");
			ОбщегоНазначения.СообщитьПользователю(
				СообщениеОбОшибке,
				ЭтотОбъект,
				Поле,
				,
				Отказ);
		КонецЦикла;
		
	КонецЕсли;
	
	// Вид номенклатуры оприходование.
	ТаблицаДляПроверки = Товары.Выгрузить(, "Номенклатура,НоменклатураОприходование");
	ТаблицаДляПроверки.Колонки.Добавить("НомерСтроки", ОбщегоНазначения.ОписаниеТипаЧисло(15));
	Для Индекс = 0 По Товары.Количество() - 1 Цикл
		СтрокаТаблицы = Товары[Индекс];
		Если СтрокаТаблицы.Действие = Перечисления.ДействияПоТоварамВАктеКонтроляКачества.ИзменитьКачество
				Или СтрокаТаблицы.Действие = Перечисления.ДействияПоТоварамВАктеКонтроляКачества.ОформитьПорчу Тогда
			НоваяСтрока = ТаблицаДляПроверки.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТаблицы);
			НоваяСтрока.НомерСтроки = Индекс + 1;
		КонецЕсли;
	КонецЦикла;
	
	НоменклатураСервер.ПроверитьВидНоменклатурыОприходования(ЭтотОбъект, Отказ, "Товары", ТаблицаДляПроверки);
	
	ОбщегоНазначения.УдалитьНепроверяемыеРеквизитыИзМассива(ПроверяемыеРеквизиты, МассивНепроверяемыхРеквизитов);
	
КонецПроцедуры

Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)
	
	Если ОбменДанными.Загрузка Тогда
		Возврат;
	КонецЕсли;
	
	ОбновлениеИнформационнойБазы.ПроверитьОбъектОбработан(ЭтотОбъект);
	
	ПроведениеДокументов.ПередЗаписьюДокумента(ЭтотОбъект, РежимЗаписи, РежимПроведения);
	
КонецПроцедуры

Процедура ПриЗаписи(Отказ)
	
	Если ОбменДанными.Загрузка Тогда
		Возврат;
	КонецЕсли;
	
	ПроведениеДокументов.ПриЗаписиДокумента(ЭтотОбъект, Отказ);
	
КонецПроцедуры

Процедура ОбработкаПроведения(Отказ, РежимПроведения)
	
	ПроведениеДокументов.ОбработкаПроведенияДокумента(ЭтотОбъект, Отказ);
	
КонецПроцедуры

Процедура ОбработкаУдаленияПроведения(Отказ)
	
	ПроведениеДокументов.ОбработкаУдаленияПроведенияДокумента(ЭтотОбъект, Отказ);
	
КонецПроцедуры

Процедура ПриКопировании(ОбъектКопирования)
	
	ДокументОснование = Неопределено;
	ИнициализироватьДокумент();
	
КонецПроцедуры

Процедура ОбработкаЗаполнения(ДанныеЗаполнения, ТекстЗаполнения, СтандартнаяОбработка)
	
	Если ТипЗнч(ДанныеЗаполнения) = Тип("ДокументСсылка.ПриобретениеТоваровУслуг") Тогда
		ЗаполнитьНаОснованииПриобретенияТоваровУслуг(ДанныеЗаполнения);
	ИначеЕсли ТипЗнч(ДанныеЗаполнения) = Тип("ДокументСсылка.ПоступлениеТоваровНаСклад") Тогда
		ЗаполнитьНаОснованииПоступленияТоваровНаСклад(ДанныеЗаполнения);
	ИначеЕсли ТипЗнч(ДанныеЗаполнения) = Тип("ДокументСсылка.ПоступлениеТоваровОтКлиента") Тогда
		ЗаполнитьНаОснованииПоступленияТоваровОтКлиента(ДанныеЗаполнения);
	ИначеЕсли ТипЗнч(ДанныеЗаполнения) = Тип("ДокументСсылка.ПоступлениеТоваровОтХранителя") Тогда
		ЗаполнитьНаОснованииПоступленияТоваровОтХранителя(ДанныеЗаполнения);
	ИначеЕсли ТипЗнч(ДанныеЗаполнения) = Тип("ДокументСсылка.ВозвратТоваровОтКлиента") Тогда
		ЗаполнитьНаОснованииВозвратаТоваровОтКлиента(ДанныеЗаполнения);
	ИначеЕсли ТипЗнч(ДанныеЗаполнения) = Тип("ДокументСсылка.СборкаТоваров") Тогда
		ЗаполнитьНаОснованииСборкиТоваров(ДанныеЗаполнения);
	ИначеЕсли ТипЗнч(ДанныеЗаполнения) = Тип("ДокументСсылка.ПриемкаТоваровНаХранение") Тогда
		ЗаполнитьНаОснованииПриемкиТоваровНаХранение(ДанныеЗаполнения);
	ИначеЕсли ТипЗнч(ДанныеЗаполнения) = Тип("ДокументСсылка.ПрочееОприходованиеТоваров") Тогда
		ЗаполнитьНаОснованииПрочегоОприходованияТоваров(ДанныеЗаполнения);
	ИначеЕсли ТипЗнч(ДанныеЗаполнения) = Тип("ДокументСсылка.ПеремещениеТоваров") Тогда
		ЗаполнитьНаОснованииПеремещенияТоваров(ДанныеЗаполнения);
	ИначеЕсли ТипЗнч(ДанныеЗаполнения) = Тип("ДокументСсылка.ЗаявкаНаКонтрольКачестваТоваров") Тогда
		ЗаполнитьНаОснованииЗаявкиНаКонтрольКачестваТоваров(ДанныеЗаполнения);
	КонецЕсли;
	
	ИнициализироватьДокумент(ДанныеЗаполнения);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныйПрограммныйИнтерфейс

#Область ВстраиваемыеМеханизмы

// Устанавливает статус для объекта документа
//
// Параметры:
//	НовыйСтатус - Строка - Имя статуса, который будет установлен у заказов
//	ДополнительныеПараметры - Структура - Структура дополнительных параметров установки статуса.
//
// Возвращаемое значение:
//	Булево - Истина, в случае успешной установки нового статуса.
//
Функция УстановитьСтатус(НовыйСтатус, ДополнительныеПараметры) Экспорт
	
	Статус = Перечисления.СтатусыАктовКонтроляКачества[НовыйСтатус];
	
	Возврат ПроверитьЗаполнение();
	
КонецФункции

