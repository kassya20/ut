Функция ТекстЗапросаТаблицаРеестрДокументов(Запрос, ТекстыЗапроса, Регистры, ПакетныйРежим = Ложь)
	
	ИмяРегистра = "РеестрДокументов";
	
	Если НЕ ПроведениеДокументов.ТребуетсяТаблицаДляДвижений(ИмяРегистра, Регистры) Тогда
		Возврат "";
	КонецЕсли;
	
	ТекстЗапроса =
		"ВЫБРАТЬ
		|	ДанныеДокумента.Ссылка КАК Ссылка,
		|	ДанныеДокумента.Дата КАК ДатаДокументаИБ,
		|	ДанныеДокумента.Номер КАК НомерДокументаИБ,
		|	&ИдентификаторМетаданных КАК ТипСсылки,
		|	ДанныеДокумента.Организация КАК Организация,
		|	ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.КонтрольКачестваТоваров) КАК ХозяйственнаяОперация,
		|	ДанныеДокумента.КонтролируемаяПартияКонтрагент КАК Контрагент,
		|	ДанныеДокумента.КонтролируемаяПартияПартнер КАК Партнер,
		|	ДанныеДокумента.КонтролируемаяПартияДоговор КАК Договор,
		|	ДанныеДокумента.КонтролируемаяПартияНаправлениеДеятельности КАК НаправлениеДеятельности,
		|	ДанныеДокумента.Склад КАК МестоХранения,
		|	ДанныеДокумента.Подразделение КАК Подразделение,
		|	ДанныеДокумента.Ответственный КАК Ответственный,
		|	ДанныеДокумента.Автор КАК Автор,
		|	ДанныеДокумента.Комментарий КАК Комментарий,
		|	ЗНАЧЕНИЕ(Справочник.Валюты.ПустаяСсылка) КАК Валюта,
		|	0 КАК Сумма,
		|	ДанныеДокумента.Статус КАК Статус,
		|	ДанныеДокумента.Проведен КАК Проведен,
		|	ДанныеДокумента.ПометкаУдаления КАК ПометкаУдаления,
		|	ЛОЖЬ КАК ДополнительнаяЗапись,
		|	"""" КАК Дополнительно,
		|	ДанныеДокумента.Дата КАК ДатаПервичногоДокумента,
		|	"""" КАК НаименованиеПервичногоДокумента,
		|	&НомерНаПечать КАК НомерПервичногоДокумента,
		|	ДанныеДокумента.Дата КАК ДатаОтраженияВУчете,
		|	НЕОПРЕДЕЛЕНО КАК Приоритет
		|ИЗ
		|	ДанныеДокументаШапка КАК ДанныеДокумента";
		
	Если ПакетныйРежим Тогда
		
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&НомерНаПечать", "ДанныеДокумента.Номер");
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "ДанныеДокумента.Комментарий", "ВЫРАЗИТЬ(ДанныеДокумента.Комментарий КАК Строка (100))");
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "КонтролируемаяПартияКонтрагент", "КонтролируемаяПартия.Контрагент");
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "КонтролируемаяПартияПартнер", "КонтролируемаяПартия.Партнер");
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "КонтролируемаяПартияДоговор", "КонтролируемаяПартия.Договор");
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "КонтролируемаяПартияНаправлениеДеятельности", "КонтролируемаяПартия.НаправлениеДеятельности");
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "ДанныеДокументаШапка", "Документ.АктКонтроляКачестваТоваров");
		Возврат ТекстЗапроса;
		
	КонецЕсли;
	
	ТекстыЗапроса.Добавить(ТекстЗапроса, ИмяРегистра);
	
	Возврат ТекстЗапроса;
	
КонецФункции


Процедура ОтразитьРаспределениеЗапасовДвижения(Запрос, ТекстыЗапроса, Регистры)
	
	// ДВИЖЕНИЕ (А-): Снять блокировку на складе и в обеспечении с товара.
	// ДВИЖЕНИЕ (В-) Отмена приходного ордера в части остатка.
	ТекстЗапросаТабЧасть =
		"ВЫБРАТЬ
		|	Товары.Ссылка КАК Ссылка,
		|	Шапка.Дата КАК Период,
		|	Товары.Номенклатура КАК Номенклатура,
		|	Товары.Характеристика КАК Характеристика,
		|	Товары.Склад КАК Склад,
		|	Товары.Назначение КАК Назначение,
		|	Шапка.КонтролируемаяПартия КАК КонтролируемаяПартия,
		|	Товары.Количество КАК Количество,
		|	НЕОПРЕДЕЛЕНО КАК ЗапланированныйРасходРаспределенногоЗапаса,
		|	ИСТИНА КАК КонтрольСвободногоОстатка
		|ИЗ
		|	ДанныеДокументаШапка КАК Шапка
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ДанныеДокументаТаблицаТоварыСвернутьТоварныеМеста КАК Товары
		|		ПО Шапка.Ссылка = Товары.Ссылка
		|ГДЕ
		|	Шапка.Статус В(
		|			ЗНАЧЕНИЕ(Перечисление.СтатусыАктовКонтроляКачества.ОжидаетРешения),
		|			ЗНАЧЕНИЕ(Перечисление.СтатусыАктовКонтроляКачества.Отработан))
		|	И (Товары.Действие В(
		|			ЗНАЧЕНИЕ(Перечисление.ДействияПоТоварамВАктеКонтроляКачества.Разблокировать),
		|			ЗНАЧЕНИЕ(Перечисление.ДействияПоТоварамВАктеКонтроляКачества.ОформитьВозврат),
		|			ЗНАЧЕНИЕ(Перечисление.ДействияПоТоварамВАктеКонтроляКачества.ОформитьПеремещение))
		|		ИЛИ Товары.СкладИспользоватьОрдернуюСхемуПриПоступлении
		|			И Шапка.Дата >= Товары.СкладДатаНачалаОрдернойСхемыПриПоступлении
		|			И Товары.Действие В(
		|				ЗНАЧЕНИЕ(Перечисление.ДействияПоТоварамВАктеКонтроляКачества.НеПриходовать),
		|				ЗНАЧЕНИЕ(Перечисление.ДействияПоТоварамВАктеКонтроляКачества.ВернутьПоставщику),
		|			ЗНАЧЕНИЕ(Перечисление.ДействияПоТоварамВАктеКонтроляКачества.ИзменитьКачество)))";
	РаспределениеЗапасовДвижения.РасходЗапаса(Запрос, ТекстыЗапроса, Регистры, ТекстЗапросаТабЧасть, Истина);
	
	// ДВИЖЕНИЕ (А+): Снять блокировку на складе и в обеспечении с товара.
	ТекстЗапросаТабЧасть =
		"ВЫБРАТЬ
		|	Товары.Ссылка КАК Ссылка,
		|	Шапка.Дата КАК Период,
		|	Товары.Номенклатура КАК Номенклатура,
		|	Товары.Характеристика КАК Характеристика,
		|	Товары.Склад КАК Склад,
		|	Товары.Назначение КАК Назначение,
		|	ЗНАЧЕНИЕ(Справочник.КонтролируемыеПартии.ПустаяСсылка) КАК КонтролируемаяПартия,
		|	ЛОЖЬ КАК ПроконтролироватьКачество,
		|	ЛОЖЬ КАК ПодлежитРазблокировке,
