#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ПрограммныйИнтерфейс

#Область Проведение

// Описывает учетные механизмы используемые в документе для регистрации в механизме проведения.
// 
// Параметры:
//  МеханизмыДокумента - Массив Из Строка - список имен учетных механизмов, для которых будет выполнена
//              регистрация в механизме проведения.
//
Процедура ЗарегистрироватьУчетныеМеханизмы(МеханизмыДокумента) Экспорт
	
	МеханизмыДокумента.Добавить("Обеспечение");
	МеханизмыДокумента.Добавить("РеестрДокументов");
	МеханизмыДокумента.Добавить("АдресныйСклад");
	
КонецПроцедуры

// Возвращает таблицы для движений, необходимые для проведения документа по регистрам учетных механизмов.
//
// Параметры:
//  Документ - ДокументОбъект.АктКонтроляКачестваТоваров, ДокументСсылка.АктКонтроляКачестваТоваров - ссылка на документ или объект, по которому необходимо получить данные
//  Регистры - Структура - список имен регистров, для которых необходимо получить таблицы
//  ДопПараметры - Структура - дополнительные параметры для получения данных, определяющие контекст проведения.
//
// Возвращаемое значение:
//  см. ПроведениеДокументов.ИнициализироватьДанныеДокументаДляПроведения
Функция ДанныеДокументаДляПроведения(Документ, Регистры, ДопПараметры = Неопределено) Экспорт
	
	Если ДопПараметры = Неопределено Тогда
		ДопПараметры = ПроведениеДокументов.ДопПараметрыИнициализироватьДанныеДокументаДляПроведения();
	КонецЕсли;
	
	Если ТипЗнч(Документ) = Тип("ДокументОбъект.АктКонтроляКачестваТоваров") Тогда
		ДокументСсылка = Документ.Ссылка;
	Иначе
		ДокументСсылка = Документ;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	ТекстыЗапроса = Новый СписокЗначений();
	
	ПолучитьДанныеДокумента(Запрос, ДокументСсылка);
	
	Если Не ДопПараметры.ПолучитьТекстыЗапроса Тогда
		
		////////////////////////////////////////////////////////////////////////////
		// Создадим запрос инициализации движений
		
		ЗаполнитьПараметрыИнициализации(Запрос, ДокументСсылка);
		
		////////////////////////////////////////////////////////////////////////////
		// Сформируем текст запроса
		ТекстЗапросаТаблицаРеестрДокументов(Запрос, ТекстыЗапроса, Регистры);
		
	КонецЕсли;
	
	////////////////////////////////////////////////////
	// Действие Разблокировать:
	// ДВИЖЕНИЕ (А): Снять блокировку на складе и в обеспечении с товара.
	
	////////////////////////////////////////////////////
	// Действие ОформитьВозврат:
	// ДВИЖЕНИЕ (А): Снять блокировку на складе и в обеспечении с товара.
	// Далее штатно будет оформляться "Возврат товаров поставщику", который отгрузит разблокированный товар.
	
	////////////////////////////////////////////////////
	// Действие ОформитьПеремещение:
	// ДВИЖЕНИЕ (А): Снять блокировку на складе и в обеспечении с товара.
	// Далее штатно будет оформляться будет оформлен документ "Перемещение товаров".
	
	////////////////////////////////////////////////////
	// Действие ОформитьСписание:
	// 1) Если схема отражения излишков недостач - ордерная:
	// ДВИЖЕНИЕ (Б): Отражение недостачи по контролируемой партии на складе (аналогично документу Ордер на отражение недостач).
	// Далее штатно будет оформляться "Списание недостач", без указания контролируемой партии.
	// 2) Если схема отражения излишков недостач - неордерная:
	// ДВИЖЕНИЙ НЕТ.
	// Далее штатно будет оформляться "Списание недостач", с указанием контролируемой партии.
	// Если документ создается на основании Акта, то партия заполняется автоматически,
	// Если же списание оформляют как результат инвентаризации, то партию заполняют на основании данных документа "Пересчет товаров".
	
	////////////////////////////////////////////////////
	// Действие ОформитьПорчу:
	// 1) Если схема отражения излишков недостач - ордерная:
	// ДВИЖЕНИЕ (-Б): Отражение недостачи по контролируемой партии на складе
	// ДВИЖЕНИЕ (+Б): Отражение излишка товара другого качества без партии
	// Далее штатно будет оформляться "Порча товаров" (чисто фин. документ).
	// 2) Если схема отражения излишков недостач - неордерная:
	// ДВИЖЕНИЙ НЕТ.
	// Далее на основании акта будет оформляться "Порча товаров", с особенностью движений.
	// Особенность в том, что по исходному товару она будет списывать товар партии, а приходовать товар без партии.
	
	// Дальше действия запрещены для раздельного оформления закупок.
	////////////////////////////////////////////////////
	// Действие НеПриходовать:
	// 1) Если схема приемки ордерная:
	// ДВИЖЕНИЕ (В): Отмена приходного ордера по исходной позиции номенклатуры.
	// Далее штатно нужно оформить акт о расхождениях и выполнить его заполнение по фактической приемке,
	// После чего оформить расхождение:
	// - либо уменьшить первичные документы поступления (накладную на приобретение), либо исправительный документ
	// - либо оформить корректировку первичного документа
	//        Оформление акта о расхождениях в этом случае обязательно
	// - либо оформить недопоставку за наш счет, штатно оформив документ "Списание недостач"
	//        Оформление акта о расхождениях обязательно
	//        Если схема отражения недостач неордерная, то в документе "Списание недостач" необходимо указать контролируемую партию.
	// 2) Если схема приемки не ордерная:
	// ДВИЖЕНИЙ НЕТ.
	// Далее нужно оформить акт о расхождениях на основании акта контроля качества, иначе не откуда взять исходные данные о расхождениях.
	// После чего оформить расхождение:
	// - либо уменьшить первичные документы поступления (накладную на приобретение), либо исправительный документ
	// - либо оформить корректировку первичного документа
	//        Если акт о расхождениях не оформляли, то нужно оформить "Ордер на отражение недостач"
	//        и указать контролируемую партию.
	// - либо оформить недопоставку за наш счет, штатно оформив документ "Списание недостач"
	//        Если акт о расхождениях не оформляли, то нужно оформить "Ордер на отражение недостач" и указать в нем контролируемую партию.
	//        Если схема отражения недостач неордерная, то в документе "Списание недостач" необходимо указать контролируемую партию.
	
	////////////////////////////////////////////////////
	// Действие ВернутьПоставщику:
	// 1) Если схема приемки ордерная:
	// ДВИЖЕНИЕ (В): Отмена приходного ордера по исходной позиции номенклатуры.
	// Далее штатные действия по оформлению расхождений, как и для действия НеПриходовать
	// 2) Если схема приемки не ордерная:
	// ДВИЖЕНИЙ НЕТ.
	// Далее штатные действия по оформлению расхождений, как и для действия НеПриходовать
	// 3) Не важно ордерная ли схема приемки, если схема отгрузки ордерная, то дополнительно
	// ДВИЖЕНИЕ (Г): Приход исходной позиции номенклатуры без распоряжения заблокированной по партии (на склад и в обеспечение)
	// ДВИЖЕНИЕ (Д): Выдача распоряжения на отгрузку (на возврат) исходной позиции номенклатуры по партии (на складе и в обеспечении), спишет товар из обеспечения
	// Далее штатно оформляется расходный ордер на товар партии по распоряжению - акту контроля качества, спишет товар со склада.
	
	////////////////////////////////////////////////////
	// Действие ИзменитьКачество:
	// 1) Если схема приемки ордерная:
	// ДВИЖЕНИЕ (-В): Отмена приходного ордера по исходной позиции номенклатуры по партии.
	// ДВИЖЕНИЕ (+В): Ввод приходного ордера по товару другого качества ПО ПАРТИИ (по настройкам номенклатуры)!
	// Далее штатные действия по оформлению расхождений, как и для действия НеПриходовать (на перепоставку товара другого качества и недопоставку исходного товара)
	// ДВИЖЕНИЕ (А): Снять блокировку на складе и в обеспечении с товара другого качества.
	// 2) Если схема приемки не ордерная:
	// ДВИЖЕНИЙ НЕТ. Действие указать в документе нельзя.
	
	ОтразитьРаспределениеЗапасовДвижения(Запрос, ТекстыЗапроса, Регистры);
	ОтразитьПоПодсистемеСклад(Запрос, ТекстыЗапроса, Регистры);
	
	////////////////////////////////////////////////////////////////////////////
	// Получим таблицы для движений
	
	Возврат ПроведениеДокументов.ИнициализироватьДанныеДокументаДляПроведения(Запрос, ТекстыЗапроса, ДопПараметры);
	
КонецФункции

#КонецОбласти

#Область Прочее

// Получает остаток фактически принятого товара.
// Параметры:
//  АктОснование - ДокументСсылка.АктКонтроляКачестваТоваров - акт. 
//  Склад - см. РегистрНакопления.ТоварыКПоступлению
// Возвращаемое значение:
//  ТаблицаЗначений - Таблица с полями:
//	* Распоряжение - см. РегистрНакопления.ТоварыКПоступлению.ДокументПоступления
//	* ДокументОснование - см. РегистрНакопления.ТоварыКПоступлению.ДокументПоступления
//	* Номенклатура - см. РегистрНакопления.ТоварыКПоступлению.Номенклатура
//	* Характеристика - см. РегистрНакопления.ТоварыКПоступлению.Характеристика
//	* Назначение - см. РегистрНакопления.ТоварыКПоступлению.Назначение
//	* Склад - см. РегистрНакопления.ТоварыКПоступлению.Склад
//	* Серия - см. РегистрНакопления.ТоварыКПоступлению.Серия
//	* Количество - Число - принятое количество.
//
Функция Принято(АктОснование, Склад) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	КонтролируемаяПартия = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(АктОснование, "КонтролируемаяПартия");
	Распоряжение = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(КонтролируемаяПартия, "Партия");
	УстановитьПривилегированныйРежим(Ложь);
	
	Запрос = Новый Запрос();
	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	ВсеДействия = Новый Массив();
	Для Каждого ДействиеПоТоварам Из Перечисления.ДействияПоТоварамВАктеКонтроляКачества Цикл
		ВсеДействия.Добавить(ДействиеПоТоварам);
	КонецЦикла;
	// Для излишков на неордерном складе оставляем действие пустым,
	// оформляем акты о расхождениях, корректируем первичные документы, далее ставим окончательное действие в акте контроля качества.
	ВсеДействия.Добавить(Перечисления.ДействияПоТоварамВАктеКонтроляКачества.ПустаяСсылка());
	
	ТоварыДляСозданияНаОсновании(
		Запрос,
		АктОснование,
		Склад,
		ВсеДействия);
		
	Запрос.УстановитьПараметр("Распоряжение", Распоряжение);
	Запрос.Текст =
		"ВЫБРАТЬ
		|	&Распоряжение КАК Распоряжение,
		|	&Распоряжение КАК ДокументОснование,
		|	Товары.Номенклатура КАК Номенклатура,
		|	Товары.Характеристика КАК Характеристика,
		|	Товары.Назначение КАК Назначение,
		|	Товары.Склад КАК Склад,
		|	Товары.Серия КАК Серия,
		|	СУММА(Товары.Количество) КАК Количество
		|ИЗ
		|	Товары КАК Товары
		|ГДЕ
		|	НЕ Товары.Действие В(
		|		ЗНАЧЕНИЕ(Перечисление.ДействияПоТоварамВАктеКонтроляКачества.ВернутьПоставщику),
		|		ЗНАЧЕНИЕ(Перечисление.ДействияПоТоварамВАктеКонтроляКачества.НеПриходовать),
		|		ЗНАЧЕНИЕ(Перечисление.ДействияПоТоварамВАктеКонтроляКачества.ИзменитьКачество))
		|СГРУППИРОВАТЬ ПО
		|	Товары.Номенклатура,
		|	Товары.Характеристика,
		|	Товары.Назначение,
		|	Товары.Склад,
		|	Товары.Серия
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	&Распоряжение КАК Распоряжение,
		|	&Распоряжение КАК ДокументОснование,
		|	Товары.НоменклатураОприходование КАК Номенклатура,
		|	Товары.ХарактеристикаОприходование КАК Характеристика,
		|	ВЫБОР
		|		КОГДА Товары.ПодНазначение
		|			ТОГДА Товары.Назначение
		|		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.Назначения.ПустаяСсылка)
		|	КОНЕЦ КАК Назначение,
		|	Товары.Склад КАК Склад,
		|	Товары.Серия КАК Серия,
		|	СУММА(Товары.Количество) КАК Количество
		|ИЗ
		|	Товары КАК Товары
		|ГДЕ
		|	Товары.Действие = ЗНАЧЕНИЕ(Перечисление.ДействияПоТоварамВАктеКонтроляКачества.ИзменитьКачество)
		|СГРУППИРОВАТЬ ПО
		|	Товары.НоменклатураОприходование,
		|	Товары.ХарактеристикаОприходование,
		|	ВЫБОР
		|		КОГДА Товары.ПодНазначение
		|			ТОГДА Товары.Назначение
		|		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.Назначения.ПустаяСсылка)
		|	КОНЕЦ,
		|	Товары.Склад,
		|	Товары.Серия";
	
	ДанныеФакта = Запрос.Выполнить().Выгрузить();
	Возврат ДанныеФакта;
	
КонецФункции

// Используется для получения данных документа, для заполнения документов на основании.
// Группирует данные документа для избавления от упаковок товарных мест.
// 
// Параметры:
//  Запрос - Запрос - запрос, в менеджер временных таблиц которого будет добавлена таблица Товары с полученными данными.
//  Основание - ДокументСсылка.АктКонтроляКачестваТоваров - акт контроля качества, данные которого необходимо получить.
//  Склад - СправочникСсылка.Склады,
//          Массив Из СправочникСсылка.Склады - получать товары только указанных складов.
//  Действие - ПеречислениеСсылка.ДействияПоТоварамВАктеКонтроляКачества,
//             Массив Из ПеречислениеСсылка.ДействияПоТоварамВАктеКонтроляКачества - получать товары только указанных действий.
Процедура ТоварыДляСозданияНаОсновании(Запрос, Основание, Склад, Действие) Экспорт
	
	Запрос.УстановитьПараметр("ДокументОснование", Основание);
	Запрос.УстановитьПараметр("Склад", Склад);
	Запрос.УстановитьПараметр("Действие", Действие);
	Запрос.УстановитьПараметр("ДатаДокумента", НачалоДня(ТекущаяДатаСеанса()));
	
	Запрос.Текст =
		"ВЫБРАТЬ
		|	Товары.Номенклатура КАК Номенклатура,
		|	Товары.Характеристика КАК Характеристика,
		|	Товары.НоменклатураОприходование КАК НоменклатураОприходование,
		|	Товары.ХарактеристикаОприходование КАК ХарактеристикаОприходование,
		|	Товары.Назначение КАК Назначение,
		|	Товары.ПодНазначение КАК ПодНазначение,
		|	Товары.УпаковкаОприходование КАК УпаковкаОприходование,
		|	Товары.Серия КАК Серия,
		|	Товары.СтатусУказанияСерий КАК СтатусУказанияСерий,
		|	Товары.Склад КАК Склад,
		|	Товары.Помещение КАК Помещение,
		|	Товары.Упаковка КАК Упаковка,
		|	Товары.Действие КАК Действие,
		|	Товары.Количество КАК Количество,
		|	Товары.КоличествоУпаковок КАК КоличествоУпаковок
		|ПОМЕСТИТЬ ТоварыИТоварныеМеста
		|ИЗ
		|	Документ.АктКонтроляКачестваТоваров.Товары КАК Товары
		|ГДЕ
		|	Товары.Ссылка = &ДокументОснование
		|	И Товары.Склад В(&Склад)
		|	И Товары.Действие В(&Действие)
		|;
		|
		|////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Набор.Номенклатура КАК Номенклатура,
		|	Набор.Характеристика КАК Характеристика,
		|	Набор.НоменклатураОприходование КАК НоменклатураОприходование,
		|	Набор.ХарактеристикаОприходование КАК ХарактеристикаОприходование,
		|	Набор.ПодНазначение КАК ПодНазначение,
		|	Набор.УпаковкаОприходование КАК УпаковкаОприходование,
		|	Набор.Назначение КАК Назначение,
		|	Набор.Склад КАК Склад,
		|	Набор.Серия КАК Серия,
		|	Набор.Упаковка КАК Упаковка,
		|	Набор.Действие КАК Действие,
		|	МАКСИМУМ(Набор.СтатусУказанияСерий) КАК СтатусУказанияСерий,
		|	СУММА(Набор.Количество) КАК Количество,
		|	СУММА(Набор.КоличествоУпаковок) КАК КоличествоУпаковок
		|ПОМЕСТИТЬ Товары
		|ИЗ(
		|	ВЫБРАТЬ
		|		Товары.Номенклатура КАК Номенклатура,
		|		Товары.Характеристика КАК Характеристика,
		|		Товары.НоменклатураОприходование КАК НоменклатураОприходование,
		|		Товары.ХарактеристикаОприходование КАК ХарактеристикаОприходование,
		|		Товары.ПодНазначение КАК ПодНазначение,
		|		Товары.УпаковкаОприходование КАК УпаковкаОприходование,
		|		Товары.Назначение КАК Назначение,
		|		Товары.Склад КАК Склад,
		|		Товары.Серия КАК Серия,
		|		Товары.СтатусУказанияСерий КАК СтатусУказанияСерий,
		|		Товары.Упаковка КАК Упаковка,
		|		Товары.Действие КАК Действие,
		|		Товары.Количество КАК Количество,
		|		Товары.КоличествоУпаковок КАК КоличествоУпаковок
		|	ИЗ
		|		ТоварыИТоварныеМеста КАК Товары
		|	ГДЕ
		|		ЕСТЬNULL(ВЫРАЗИТЬ(Товары.Упаковка КАК Справочник.УпаковкиЕдиницыИзмерения).ТипУпаковки,
		|			НЕОПРЕДЕЛЕНО) <> ЗНАЧЕНИЕ(Перечисление.ТипыУпаковокНоменклатуры.ТоварноеМесто)
		|	
		|	ОБЪЕДИНИТЬ ВСЕ
		|	
		|	ВЫБРАТЬ
		|		Комплектующие.Номенклатура КАК Номенклатура,
		|		Комплектующие.Характеристика КАК Характеристика,
		|		Комплектующие.НоменклатураОприходование КАК НоменклатураОприходование,
		|		Комплектующие.ХарактеристикаОприходование КАК ХарактеристикаОприходование,
		|		Комплектующие.ПодНазначение КАК ПодНазначение,
		|		Комплектующие.УпаковкаОприходование КАК УпаковкаОприходование,
		|		Комплектующие.Назначение КАК Назначение,
		|		Комплектующие.Склад КАК Склад,
		|		Комплектующие.Серия КАК Серия,
		|		Комплектующие.СтатусУказанияСерий КАК СтатусУказанияСерий,
		|		ЗНАЧЕНИЕ(Справочник.УпаковкиЕдиницыИзмерения.ПустаяСсылка) КАК Упаковка,
		|		Комплектующие.Действие КАК Действие,
		|		МИНИМУМ(Комплектующие.Количество) КАК Количество,
		|		МИНИМУМ(Комплектующие.Количество) КАК КоличествоУпаковок
		|	ИЗ(
		|		ВЫБРАТЬ
		|			Товары.Номенклатура КАК Номенклатура,
		|			Товары.Характеристика КАК Характеристика,
		|			Товары.НоменклатураОприходование КАК НоменклатураОприходование,
		|			Товары.ХарактеристикаОприходование КАК ХарактеристикаОприходование,
		|			Товары.Назначение КАК Назначение,
		|			Товары.ПодНазначение КАК ПодНазначение,
		|			Товары.УпаковкаОприходование КАК УпаковкаОприходование,
		|			Товары.Серия КАК Серия,
		|			Товары.СтатусУказанияСерий КАК СтатусУказанияСерий,
		|			Товары.Склад КАК Склад,
		|			Товары.Помещение КАК Помещение,
		|			Товары.Упаковка КАК Упаковка,
		|			Товары.Действие КАК Действие,
		|			СУММА(Товары.Количество) КАК Количество
		|		ИЗ
		|			ТоварыИТоварныеМеста КАК Товары
		|		ГДЕ
		|			ВЫРАЗИТЬ(Товары.Упаковка КАК Справочник.УпаковкиЕдиницыИзмерения).ТипУпаковки
		|				= ЗНАЧЕНИЕ(Перечисление.ТипыУпаковокНоменклатуры.ТоварноеМесто)
		|		СГРУППИРОВАТЬ ПО
		|			Товары.Номенклатура,
		|			Товары.Характеристика,
		|			Товары.НоменклатураОприходование,
		|			Товары.ХарактеристикаОприходование,
		|			Товары.Назначение,
		|			Товары.ПодНазначение,
		|			Товары.УпаковкаОприходование,
		|			Товары.Серия,
		|			Товары.СтатусУказанияСерий,
		|			Товары.Склад,
		|			Товары.Помещение,
		|			Товары.Упаковка,
		|			Товары.Действие) КАК Комплектующие
		|	СГРУППИРОВАТЬ ПО
		|		Комплектующие.Номенклатура,
		|		Комплектующие.Характеристика,
		|		Комплектующие.НоменклатураОприходование,
		|		Комплектующие.ХарактеристикаОприходование,
		|		Комплектующие.Назначение,
		|		Комплектующие.ПодНазначение,
		|		Комплектующие.УпаковкаОприходование,
		|		Комплектующие.Серия,
		|		Комплектующие.СтатусУказанияСерий,
		|		Комплектующие.Склад,
		|		Комплектующие.Помещение,
		|		Комплектующие.Действие) КАК Набор
		|СГРУППИРОВАТЬ ПО
		|	Набор.Номенклатура,
		|	Набор.Характеристика,
		|	Набор.НоменклатураОприходование,
		|	Набор.ХарактеристикаОприходование,
		|	Набор.ПодНазначение,
		|	Набор.УпаковкаОприходование,
		|	Набор.Назначение,
		|	Набор.Склад,
		|	Набор.Серия,
		|	Набор.Упаковка,
		|	Набор.Действие";
		
	Запрос.Выполнить();
	
КонецПроцедуры

// Возвращает Организацию, исходя из контролируемой партии документа.
// Параметры:
//  Объект - ДокументОбъект.АктКонтроляКачестваТоваров - документ
// Возвращаемое значение:
//  СправочникСсылка.Организации - Организация.
Функция ОрганизацияИзКонтролируемойПартии(Объект) Экспорт
	
	Организация = Справочники.Организации.ПустаяСсылка();
	УстановитьПривилегированныйРежим(Истина);
	Если ЗначениеЗаполнено(Объект.КонтролируемаяПартия) Тогда
		Организация = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.КонтролируемаяПартия, "Организация");
	КонецЕсли;
	Возврат Организация;
	
КонецФункции

// Добавляет команду создания документа "Акт контроля качества товаров".
// Параметры:
//  КомандыСозданияНаОсновании - см. СозданиеНаОснованииПереопределяемый.ПередДобавлениемКомандСозданияНаОсновании.КомандыСозданияНаОсновании
// Возвращаемое значение:
//  Неопределено -
//  СтрокаТаблицыЗначений -
Функция ДобавитьКомандуСоздатьНаОсновании(КомандыСозданияНаОсновании) Экспорт

	Если ПравоДоступа("Добавление", Метаданные.Документы.АктКонтроляКачестваТоваров) Тогда
		КомандаСоздатьНаОсновании = СозданиеНаОсновании.ДобавитьКомандуСозданияНаОсновании(
				КомандыСозданияНаОсновании, Метаданные.Документы.АктКонтроляКачестваТоваров);
		КомандаСоздатьНаОсновании.РежимЗаписи = "Проводить";
		КомандаСоздатьНаОсновании.ФункциональныеОпции = "ИспользоватьКонтрольКачестваТоваров";
		Возврат КомандаСоздатьНаОсновании;
	КонецЕсли;
	Возврат Неопределено;

КонецФункции

#КонецОбласти

#КонецОбласти

#Область СлужебныйПрограммныйИнтерфейс

#Область СтандартныеПодсистемы

