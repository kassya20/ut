		|	Товары.Серия КАК Серия,
		|	Товары.СтатусУказанияСерий КАК СтатусУказанияСерий,
		|	Товары.Количество КАК Количество,
		|	ЛОЖЬ КАК СверхЗаказа,
		|	ЛОЖЬ КАК Отменено,
		|	ИСТИНА КАК ЭтоНакладная,
		|	ЛОЖЬ КАК ОтгрузкаПоЗаказу
		|ИЗ
		|	ДанныеДокументаШапка КАК Шапка
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ДанныеДокументаТаблицаТоварыСвернутьТоварныеМеста КАК Товары
		|		ПО Шапка.Ссылка = Товары.Ссылка
		|ГДЕ
		|	Шапка.Статус В(
		|			ЗНАЧЕНИЕ(Перечисление.СтатусыАктовКонтроляКачества.ОжидаетРешения),
		|			ЗНАЧЕНИЕ(Перечисление.СтатусыАктовКонтроляКачества.Отработан))
		|		И Товары.СкладИспользоватьОрдернуюСхемуПриОтгрузке
		|		И Товары.СкладДатаНачалаОрдернойСхемыПриОтгрузке <= Шапка.Дата
		|		И Товары.Действие = ЗНАЧЕНИЕ(Перечисление.ДействияПоТоварамВАктеКонтроляКачества.ВернутьПоставщику)";
	
	ПараметрыМодульногоПроведения = СкладыСервер.ПараметрыМодульногоПроведения();
	ПараметрыМодульногоПроведения.СинонимТаблицыДокумента = "Товары";
	ПараметрыМодульногоПроведения.ОбъектМетаданных = Документы.АктКонтроляКачестваТоваров.ПустаяСсылка().Метаданные();
	
	СкладыСервер.ОформитьОтгрузкуТоваровСНастройкойСоединенияСерий(
		Запрос,
		ТекстыЗапроса,
		Регистры,
		ТекстЗапросаДокумента,
		ПараметрыМодульногоПроведения);
		
КонецПроцедуры

Функция АдаптированныйТекстЗапросаДвиженийПоРегистру(ИмяРегистра) Экспорт
	
	ПолноеИмяДокумента = "Документ.АктКонтроляКачестваТоваров";
	ЗначенияПараметров = Новый Структура();
	ЗначенияПараметров.Вставить("ИдентификаторМетаданных",
		ОбщегоНазначения.ИдентификаторОбъектаМетаданных(ПолноеИмяДокумента));
	
	Если ИмяРегистра <> "РеестрДокументов" Тогда
		ТекстИсключения = НСтр("ru = 'В документе %ПолноеИмяДокумента% не реализована адаптация текста запроса формирования движений по регистру %ИмяРегистра%.'");
		ТекстИсключения = СтрЗаменить(ТекстИсключения, "%ПолноеИмяДокумента%", ПолноеИмяДокумента);
		ТекстИсключения = СтрЗаменить(ТекстИсключения, "%ИмяРегистра%", ИмяРегистра);
		
		ВызватьИсключение ТекстИсключения;
	КонецЕсли;
	
	Если ИмяРегистра = "РеестрДокументов" Тогда
		
		ТекстЗапроса = ТекстЗапросаТаблицаРеестрДокументов(Неопределено, Неопределено, "РеестрДокументов", Истина);
		
	КонецЕсли;
	
	Результат = ОбновлениеИнформационнойБазыУТ.РезультатАдаптацииЗапроса();
	Результат.ЗначенияПараметров = ЗначенияПараметров;
	Результат.ТекстЗапроса = ТекстЗапроса;
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти


Функция ИсследованияТоваровВключены()
	
	ИспользоватьИсследования = Ложь;
	Возврат ИспользоватьИсследования;
	
КонецФункции

Функция СформироватьПечатнуюФормуАктКонтроляКачестваТоваров(МассивОбъектов, ОбъектыПечати, ПараметрыПечати)
	
	УстановитьПривилегированныйРежим(Истина);
	
	МетаданныеДокумента = Документы.АктКонтроляКачестваТоваров.ПустаяСсылка().Метаданные();
	Если Не ЗначениеЗаполнено(МетаданныеДокумента.ПредставлениеОбъекта) Тогда
		СинонимДокумента = МетаданныеДокумента.Синоним;
	Иначе
		СинонимДокумента = МетаданныеДокумента.ПредставлениеОбъекта;
	КонецЕсли;
	
	ТабличныйДокумент = Новый ТабличныйДокумент;
	ТабличныйДокумент.ИмяПараметровПечати = "ПАРАМЕТРЫ_ПЕЧАТИ_АктКонтроляКачестваТоваров_ПечатнаяФормаДокумента";
	
	КолонкаКодов = ФормированиеПечатныхФорм.ДополнительнаяКолонкаПечатныхФормДокументов();
	ИмяКолонкиКодов = КолонкаКодов.ИмяКолонки;
	ПредставлениеКолонкиКодов = КолонкаКодов.ПредставлениеКолонки;
	ВыводитьКоды = ЗначениеЗаполнено(ИмяКолонкиКодов);
	ВыводитьСерии = ПолучитьФункциональнуюОпцию("ИспользоватьСерииНоменклатуры");
	ВыводитьИсследование = ИсследованияТоваровВключены();
	
	
	Запрос = Новый Запрос();
	Текст =
		"ВЫБРАТЬ
		|	Товары.Ссылка КАК Ссылка,
		|	ВЫБОР
		|		КОГДА МИНИМУМ(Товары.Склад) = МАКСИМУМ(Товары.Склад)
		|			ТОГДА МИНИМУМ(Товары.Склад)
		|		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.Склады.ПустаяСсылка)
		|	КОНЕЦ КАК Склад,
		|	ВЫБОР
		|		КОГДА МИНИМУМ(Товары.Помещение) = МАКСИМУМ(Товары.Помещение)
		|			ТОГДА МИНИМУМ(Товары.Помещение)
		|		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.СкладскиеПомещения.ПустаяСсылка)
		|	КОНЕЦ КАК Помещение
		|ПОМЕСТИТЬ ТоварыСводно
		|ИЗ
		|	Документ.АктКонтроляКачестваТоваров.Товары КАК Товары
		|ГДЕ
		|	Товары.Ссылка В(&МассивОбъектов)
		|СГРУППИРОВАТЬ ПО
		|	Товары.Ссылка
		|ИНДЕКСИРОВАТЬ ПО
		|	Ссылка
		|;
		|
		|/////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Шапка.Ссылка КАК Ссылка,
		|	Шапка.Дата КАК Дата,
		|	Шапка.Номер КАК Номер,
		|	ПРЕДСТАВЛЕНИЕ(Шапка.Организация) КАК ОрганизацияПредставление,
		|	Шапка.Ответственный.ФизическоеЛицо КАК Ответственный,
		|	ТоварыСводно.Склад КАК Склад,
		|	ТоварыСводно.Помещение КАК Помещение,
		|	Шапка.КонтролируемаяПартия.Партия КАК Партия,
		|	ПРЕДСТАВЛЕНИЕ(ТоварыСводно.Склад) КАК СкладПредставление,
		|	ПРЕДСТАВЛЕНИЕ(ТоварыСводно.Помещение) КАК ПомещениеПредставление,
		|	ВЫБОР
		|		КОГДА Шапка.КонтролируемаяПартия.Партия ЕСТЬ NULL
		|			ТОГДА """"
		|		ИНАЧЕ ПРЕДСТАВЛЕНИЕ(Шапка.КонтролируемаяПартия.Партия)
		|	КОНЕЦ КАК ПартияПредставление
		|ИЗ
		|	Документ.АктКонтроляКачестваТоваров КАК Шапка
		|		
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ТоварыСводно КАК ТоварыСводно
		|		ПО ТоварыСводно.Ссылка = Шапка.Ссылка
		|ГДЕ
		|	Шапка.Ссылка В(&МассивОбъектов)
		|УПОРЯДОЧИТЬ ПО
		|	Ссылка
		|;
		|
		|/////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Товары.Ссылка КАК Ссылка,
		|	МИНИМУМ(Товары.НомерСтроки) КАК НомерСтроки,
		|	Товары.Номенклатура КАК Номенклатура,
		|	Товары.Характеристика КАК Характеристика,
		|	Товары.Серия КАК Серия,
		|	Товары.Упаковка КАК Упаковка,
		|	Товары.РезультатПроверкиКачества КАК РезультатПроверкиКачества,
		|	СУММА(Товары.КоличествоУпаковок) КАК КоличествоУпаковок
		|ПОМЕСТИТЬ ТоварыСгруппированные
		|ИЗ
		|	Документ.АктКонтроляКачестваТоваров.Товары КАК Товары
		|ГДЕ
		|	Товары.Ссылка В(&МассивОбъектов)
		|СГРУППИРОВАТЬ ПО
		|	Товары.Ссылка,
		|	Товары.Номенклатура,
		|	Товары.Характеристика,
		|	Товары.Серия,
		|	Товары.Упаковка,
		|	Товары.РезультатПроверкиКачества
		|ИНДЕКСИРОВАТЬ ПО
		|	Номенклатура
		|;
		|
		|//////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Товары.Ссылка КАК Ссылка,
		|	Товары.НомерСтроки КАК НомерСтроки,
		|	Товары.КоличествоУпаковок КАК КоличествоУпаковок,
		|	&ВыводитьКоды КАК Артикул,
		|	Товары.Номенклатура.НаименованиеПолное КАК ПредставлениеНоменклатуры,
		|	Товары.Характеристика.НаименованиеПолное КАК ПредставлениеХарактеристики,
		|	Товары.Серия.Наименование КАК ПредставлениеСерии,
		|	ВЫБОР
		|		КОГДА Товары.Упаковка = ЗНАЧЕНИЕ(Справочник.УпаковкиЕдиницыИзмерения.ПустаяСсылка)
		|			ТОГДА ПРЕДСТАВЛЕНИЕССЫЛКИ(Товары.Номенклатура.ЕдиницаИзмерения)
		|		ИНАЧЕ ПРЕДСТАВЛЕНИЕССЫЛКИ(Товары.Упаковка)
		|	КОНЕЦ КАК ПредставлениеЕдиницыИзмеренияУпаковки,
		|	Товары.РезультатПроверкиКачества КАК РезультатПроверкиКачества
		|ИЗ
		|	ТоварыСгруппированные КАК Товары
		|ГДЕ
		|	Товары.Ссылка В(&МассивОбъектов)
		|УПОРЯДОЧИТЬ ПО
		|	Ссылка, НомерСтроки
		|ИТОГИ ПО
		|	Ссылка";
		
	
	ПодстановкаВыводитьКоды = ?(ВыводитьКоды, "Товары.Номенклатура." + ИмяКолонкиКодов, """""");
	Текст = СтрЗаменить(Текст, "&ВыводитьКоды", ПодстановкаВыводитьКоды);

	Запрос.Текст = Текст;
	Запрос.УстановитьПараметр("МассивОбъектов", МассивОбъектов);
	Результаты = Запрос.ВыполнитьПакет(); 
	
	ВыборкаПоДокументам = Результаты[1].Выбрать();
	Если ВыводитьИсследование Тогда
		ВыборкаПоТабличнымЧастям = Результаты[4].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	Иначе
		ВыборкаПоТабличнымЧастям = Результаты[3].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	КонецЕсли;
	
	ПервыйДокумент = Истина;
	
	РеквизитыДокумента = Новый Структура("Номер,Дата,Префикс");
	
	ДопПараметрыПредставлениеНоменклатуры = НоменклатураКлиентСервер.ДополнительныеПараметрыПредставлениеНоменклатурыДляПечати();
	ДопПараметрыПредставлениеНоменклатуры.КодОсновногоЯзыка = ОбщегоНазначения.КодОсновногоЯзыка();
	Пока ВыборкаПоДокументам.Следующий() Цикл
		
		Если Не ВыборкаПоТабличнымЧастям.НайтиСледующий(Новый Структура("Ссылка", ВыборкаПоДокументам.Ссылка)) Тогда
			Продолжить;
		КонецЕсли;
		
		ЕстьСклад = ЗначениеЗаполнено(ВыборкаПоДокументам.Склад);
		
		// Макет получаем в цикле,т.к. ширина колонок зависит от склада и помещения в документе.
		Макет = УправлениеПечатью.МакетПечатнойФормы("Документ.АктКонтроляКачестваТоваров.ПФ_MXL_АктКонтроляКачестваТоваров");
		
		ОбластьЗаголовок = Макет.ПолучитьОбласть("Заголовок");
		ОбластьПодписей = Макет.ПолучитьОбласть("Подписи");
		
		Если ЕстьСклад Тогда
			ИмяОбластиШапка = "ШапкаИСкладИПартия";
		Иначе
			ИмяОбластиШапка = "ШапкаБезСкладаИПартия";
		КонецЕсли;
		ОбластьШапка = Макет.ПолучитьОбласть(ИмяОбластиШапка);
		
		ОбластьТаблицы = Новый Массив();
		
		Шапка = Макет.ПолучитьОбласть("ШапкаТаблицы|НачалоСтроки");
		Строка = Макет.ПолучитьОбласть("СтрокаТаблицы|НачалоСтроки");
		Подвал = Макет.ПолучитьОбласть("ПодвалТаблицы|НачалоСтроки");
		
		ОбластьТаблицы.Добавить(Новый Структура("Шапка,Строка,Подвал", Шапка, Строка, Подвал));
		
		СкрытаяШирина = 0;
		
		Если ВыводитьКоды Тогда
			
			Шапка = Макет.ПолучитьОбласть("ШапкаТаблицы|КолонкаКодов");
			Строка = Макет.ПолучитьОбласть("СтрокаТаблицы|КолонкаКодов");
			Подвал = Макет.ПолучитьОбласть("ПодвалТаблицы|КолонкаКодов");
			
			ОбластьТаблицы.Добавить(Новый Структура("Шапка,Строка,Подвал", Шапка, Строка, Подвал));
			Шапка.Параметры.ИмяКолонкиКодов = ПредставлениеКолонкиКодов; 
			
		Иначе
			СкрытаяШирина = Макет.Область("КолонкаКодов").ШиринаКолонки;
		КонецЕсли;
		
		Шапка = Макет.ПолучитьОбласть("ШапкаТаблицы|Товар");
		Строка = Макет.ПолучитьОбласть("СтрокаТаблицы|Товар");
		Подвал = Макет.ПолучитьОбласть("ПодвалТаблицы|Товар");
		
		ОбластьТаблицы.Добавить(Новый Структура("Шапка,Строка,Подвал", Шапка, Строка, Подвал));
		
		Шапка = Макет.ПолучитьОбласть("ШапкаТаблицы|Количество");
		Строка = Макет.ПолучитьОбласть("СтрокаТаблицы|Количество");
		Подвал = Макет.ПолучитьОбласть("ПодвалТаблицы|Количество");
		
		ОбластьТаблицы.Добавить(Новый Структура("Шапка,Строка,Подвал", Шапка, Строка, Подвал));
		
		Макет.Область("Товар").ШиринаКолонки = Макет.Область("Товар").ШиринаКолонки + СкрытаяШирина;
		СкрытаяШирина = 0;
		
		Если ВыводитьИсследование Тогда
			
			Шапка = Макет.ПолучитьОбласть("ШапкаТаблицы|Исследование");
			Строка = Макет.ПолучитьОбласть("СтрокаТаблицы|Исследование");
			Подвал = Макет.ПолучитьОбласть("ПодвалТаблицы|Исследование");
			
			ОбластьТаблицы.Добавить(Новый Структура("Шапка,Строка,Подвал", Шапка, Строка, Подвал));
			
		Иначе
			СкрытаяШирина = СкрытаяШирина + Макет.Область("Исследование").ШиринаКолонки;
		КонецЕсли;
		
		Макет.Область("Результат").ШиринаКолонки = Макет.Область("Результат").ШиринаКолонки + СкрытаяШирина;
		
		Шапка = Макет.ПолучитьОбласть("ШапкаТаблицы|Результат");
		Строка = Макет.ПолучитьОбласть("СтрокаТаблицы|Результат");
		Подвал = Макет.ПолучитьОбласть("ПодвалТаблицы|Результат");
		
		ОбластьТаблицы.Добавить(Новый Структура("Шапка,Строка,Подвал", Шапка, Строка, Подвал));
		
		ВсегоОбластейТаблицы = ОбластьТаблицы.Количество() - 1;
		
		ВыборкаПоСтрокамТЧ = ВыборкаПоТабличнымЧастям.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		
		Если Не ПервыйДокумент Тогда
			ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();
		КонецЕсли;
		
		ПервыйДокумент = Ложь;
		НомерСтрокиНачало = ТабличныйДокумент.ВысотаТаблицы + 1;
		
		ЗаполнитьЗначенияСвойств(РеквизитыДокумента,ВыборкаПоДокументам);
		
		ТекстЗаголовка = ОбщегоНазначенияУТКлиентСервер.СформироватьЗаголовокДокумента(РеквизитыДокумента, СинонимДокумента);
		СтруктураДанныхЗаголовка = Новый Структура();
		СтруктураДанныхЗаголовка.Вставить("ТекстЗаголовка", ТекстЗаголовка);
		
		ОбластьЗаголовок.Параметры.Заполнить(СтруктураДанныхЗаголовка);
		
		ШтрихкодированиеПечатныхФорм.ВывестиШтрихкодВТабличныйДокумент(
			ТабличныйДокумент, Макет, ОбластьЗаголовок, ВыборкаПоДокументам.Ссылка);
		ТабличныйДокумент.Вывести(ОбластьЗаголовок);
		
		ОбластьШапка.Параметры.Заполнить(ВыборкаПоДокументам);
		
		Если ЕстьСклад Тогда
			
			ОбластьШапка.Параметры.СкладПредставление = СкладыСервер.ПолучитьПредставлениеСклада(
				ВыборкаПоДокументам.СкладПредставление,
				ВыборкаПоДокументам.ПомещениеПредставление);
				
		КонецЕсли;
		
		ТабличныйДокумент.Вывести(ОбластьШапка);
		
		Для ИндексОбласти = 0 По ВсегоОбластейТаблицы Цикл
			ОписаниеОбласти = ОбластьТаблицы[ИндексОбласти]; // Структура
			ТекущаяОбласть = ОписаниеОбласти.Шапка; // ТабличныйДокумент
			Если ИндексОбласти = 0 Тогда
				ТабличныйДокумент.Вывести(ТекущаяОбласть);
			Иначе
				ТабличныйДокумент.Присоединить(ТекущаяОбласть);
			КонецЕсли;
		КонецЦикла;
		
		Пока ВыборкаПоСтрокамТЧ.Следующий() Цикл
			
			Товар = НоменклатураКлиентСервер.ПредставлениеНоменклатурыДляПечати(
				ВыборкаПоСтрокамТЧ.ПредставлениеНоменклатуры,
				ВыборкаПоСтрокамТЧ.ПредставлениеХарактеристики,
				, // Упаковка
				ВыборкаПоСтрокамТЧ.ПредставлениеСерии,
				ДопПараметрыПредставлениеНоменклатуры);
			СтруктураПараметров = Новый Структура("Товар", Товар);
			
			Для ИндексОбласти = 0 По ВсегоОбластейТаблицы Цикл
				ОписаниеОбласти = ОбластьТаблицы[ИндексОбласти]; // Структура
				ТекущаяОбласть = ОписаниеОбласти.Строка; // ТабличныйДокумент
				ТекущаяОбласть.Параметры.Заполнить(ВыборкаПоСтрокамТЧ);
				ТекущаяОбласть.Параметры.Заполнить(СтруктураПараметров);
				Если ИндексОбласти = 0 Тогда
					ТабличныйДокумент.Вывести(ТекущаяОбласть);
				Иначе
					ТабличныйДокумент.Присоединить(ТекущаяОбласть);
				КонецЕсли;
			КонецЦикла;
			
		КонецЦикла;
		
		Для ИндексОбласти = 0 По ВсегоОбластейТаблицы Цикл
			ОписаниеОбласти = ОбластьТаблицы[ИндексОбласти]; // Структура
			ТекущаяОбласть = ОписаниеОбласти.Подвал; // ТабличныйДокумент
			Если ИндексОбласти = 0 Тогда
				ТабличныйДокумент.Вывести(ТекущаяОбласть);
			Иначе
				ТабличныйДокумент.Присоединить(ТекущаяОбласть);
			КонецЕсли;
		КонецЦикла;
		
		ОбластьПодписей.Параметры.Ответственный = ФизическиеЛицаУТ.ФамилияИнициалыФизЛица(
			ВыборкаПоДокументам.Ответственный, ВыборкаПоДокументам.Дата);
		ТабличныйДокумент.Вывести(ОбластьПодписей);
		
		УправлениеПечатью.ЗадатьОбластьПечатиДокумента(
			ТабличныйДокумент, НомерСтрокиНачало, ОбъектыПечати, ВыборкаПоДокументам.Ссылка);
		
	КонецЦикла;
	
	ТабличныйДокумент.АвтоМасштаб = Истина;
	Возврат ТабличныйДокумент;
	
КонецФункции

#Область ОбновлениеИнформационнойБазы

// См. ОбновлениеИнформационнойБазыБСП.ПриДобавленииОбработчиковОбновления
//
Процедура ПриДобавленииОбработчиковОбновления(Обработчики) Экспорт
	
	Обработчик = Обработчики.Добавить();
	Обработчик.Процедура = "Документы.АктКонтроляКачестваТоваров.ОбработатьДанныеДляПереходаНаНовуюВерсию";
	Обработчик.Версия = "11.5.27.26";
	Обработчик.РежимВыполнения = "Отложенно";
	Обработчик.Идентификатор = Новый УникальныйИдентификатор("35b8a3c9-6cc3-45e3-a782-4f74b1899f6d");
	Обработчик.Многопоточный = Истина;
	Обработчик.ПроцедураЗаполненияДанныхОбновления = "Документы.АктКонтроляКачестваТоваров.ЗарегистрироватьДанныеКОбработкеДляПереходаНаНовуюВерсию";
	Обработчик.ПроцедураПроверки = "ОбновлениеИнформационнойБазы.ДанныеОбновленыНаНовуюВерсиюПрограммы";
	Обработчик.Порядок = Перечисления.ПорядокОбработчиковОбновления.Некритичный;
	СписокОписаний = Новый Массив;
	СписокОписаний.Добавить(НСтр("ru = 'Обновление документов ""Акт контроля качества"":'"));
	СписокОписаний.Добавить(НСтр("ru = '- заполняет новые служебные реквизиты ""Партнер партии"" и ""Подразделение партии"" значениями из реквизита ""Контролируемая партия"".'"));
	
	Обработчик.Комментарий = СтрСоединить(СписокОписаний, Символы.ПС);
	
	Читаемые = Новый Массив;
	Читаемые.Добавить(Метаданные.Справочники.КонтролируемыеПартии.ПолноеИмя());
	Обработчик.ЧитаемыеОбъекты = СтрСоединить(Читаемые, ",");
	
	Изменяемые = Новый Массив;
	Изменяемые.Добавить(Метаданные.Документы.АктКонтроляКачестваТоваров.ПолноеИмя());
	Обработчик.ИзменяемыеОбъекты = СтрСоединить(Изменяемые, ",");
	
	Блокируемые = Новый Массив;
	Обработчик.БлокируемыеОбъекты = СтрСоединить(Блокируемые, ",");
	
КонецПроцедуры

// Параметры:
// 	Параметры - см. ОбновлениеИнформационнойБазы.ОсновныеПараметрыОтметкиКОбработке
//
Процедура ЗарегистрироватьДанныеКОбработкеДляПереходаНаНовуюВерсию(Параметры) Экспорт
	
	ПараметрыВыборки = Параметры.ПараметрыВыборки;
	ПараметрыВыборки.ПолныеИменаОбъектов = "Документ.АктКонтроляКачестваТоваров";
	ПараметрыВыборки.ПоляУпорядочиванияПриРаботеПользователей.Добавить("Дата УБЫВ");
	ПараметрыВыборки.ПоляУпорядочиванияПриОбработкеДанных.Добавить("Дата УБЫВ");
	ПараметрыВыборки.СпособВыборки = ОбновлениеИнформационнойБазы.СпособВыборкиСсылки();
	ПараметрыВыборки.ДополнительныеИсточникиДанных.Вставить("КонтролируемаяПартия");
	
	Запрос = Новый Запрос();
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Акты.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.АктКонтроляКачестваТоваров КАК Акты
	|ГДЕ
	|	НЕ ЕСТЬNULL(Акты.КонтролируемаяПартия.УдалитьПодразделениеОбработано, ИСТИНА)";
	
	ОбновлениеИнформационнойБазы.ОтметитьКОбработке(Параметры, Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Ссылка"));
	
КонецПроцедуры

// Обработчик обновления
// 
// Параметры:
// 	Параметры - См. ОбновлениеИнформационнойБазы.ДополнительныеПараметрыВыборкиДанныхДляМногопоточнойОбработки 
//
Процедура ОбработатьДанныеДляПереходаНаНовуюВерсию(Параметры) Экспорт
	
	ПолноеИмяОбъекта = "Документ.АктКонтроляКачестваТоваров";
	
	ОбновляемыеДанные = ОбновлениеИнформационнойБазы.ДанныеДляОбновленияВМногопоточномОбработчике(Параметры);
	
	Если ОбновляемыеДанные.Количество() = 0 Тогда
		Параметры.ОбработкаЗавершена =
			ОбновлениеИнформационнойБазы.ОбработкаДанныхЗавершена(Параметры.Очередь, ПолноеИмяОбъекта);
		Возврат;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ОбновляемыеДанные.Ссылка КАК Ссылка
	|ПОМЕСТИТЬ ОбновляемыеДанные
	|ИЗ
	|	&ОбновляемыеДанные КАК ОбновляемыеДанные
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ОбновляемыеДанные.Ссылка КАК Ссылка,
	|	РеквизитыДокумента.ВерсияДанных КАК ВерсияДанных,
	|	РеквизитыДокумента.КонтролируемаяПартия КАК КонтролируемаяПартия
	|ИЗ
	|	ОбновляемыеДанные КАК ОбновляемыеДанные
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.АктКонтроляКачестваТоваров КАК РеквизитыДокумента
	|		ПО ОбновляемыеДанные.Ссылка = РеквизитыДокумента.Ссылка";
	
	Запрос.УстановитьПараметр("ОбновляемыеДанные", ОбновляемыеДанные);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	ИсключенияПриОбновлении = Новый Массив();
	Пока Выборка.Следующий() Цикл
		
		ПричинаИсключения = "";
		
		НачатьТранзакцию();
		
		Попытка
			
			ПричинаИсключения = "БЛОКИРОВКА";
			
			Блокировка = Новый БлокировкаДанных;
			ЭлементБлокировки = Блокировка.Добавить(ПолноеИмяОбъекта);
			ЭлементБлокировки.УстановитьЗначение("Ссылка", Выборка.Ссылка);
			ЭлементБлокировки.Режим = РежимБлокировкиДанных.Исключительный;
			
			ЭлементБлокировки = Блокировка.Добавить("Справочник.КонтролируемыеПартии");
			ЭлементБлокировки.УстановитьЗначение("Ссылка", Выборка.КонтролируемаяПартия);
			ЭлементБлокировки.Режим = РежимБлокировкиДанных.Разделяемый;
			Блокировка.Заблокировать();
			
			ДокументОбъект = ОбновлениеИнформационнойБазыУТ.ПроверитьПолучитьОбъект(Выборка.Ссылка, Выборка.ВерсияДанных, Параметры.Очередь);
			
			ПричинаИсключения = "ПЛОХИЕ_ДАННЫЕ";
			
			РеквизитыПартии = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Выборка.КонтролируемаяПартия,
				"Партнер,Подразделение");
			
			ОбъектИзменен = Ложь;
			
			Если ДокументОбъект <> Неопределено Тогда
				ДокументОбъект.ПодразделениеПартии = РеквизитыПартии.Подразделение;
				ДокументОбъект.ПартнерПартии = РеквизитыПартии.Партнер;
				ОбъектИзменен = Истина;
			КонецЕсли;
			
			ПричинаИсключения = "ЗАПИСЬ";
			
			Если ОбъектИзменен Тогда
				ОбновлениеИнформационнойБазы.ЗаписатьДанные(ДокументОбъект);
			Иначе
				ОбновлениеИнформационнойБазы.ОтметитьВыполнениеОбработки(Выборка.Ссылка);
			КонецЕсли;
			
			ЗафиксироватьТранзакцию();
			
		Исключение
			
			ОтменитьТранзакцию();
			
			ОбновлениеИнформационнойБазыУТ.СообщитьОНеудачнойОбработке(ИнформацияОбОшибке(), Выборка.Ссылка);
			
			Если ПричинаИсключения = "ПЛОХИЕ_ДАННЫЕ" Тогда
				
				Рекомендация = НСтр("ru = 'Проверьте данные документа вручную.'");
				ОписаниеПроблемы = ОбновлениеИнформационнойБазыУТ.ПроблемаСДанными(
					Выборка.Ссылка, Рекомендация, ИнформацияОбОшибке());
				ИсключенияПриОбновлении.Добавить(ОписаниеПроблемы);
				
			ИначеЕсли ПричинаИсключения = "ЗАПИСЬ" Тогда
				
				ОбновлениеИнформационнойБазыУТ.ЗаписатьПлохиеДанные(ИсключенияПриОбновлении, 1, Параметры);
				ТекстИсключения = НСтр("ru = 'Не удалось обработать документ ""Акт контроля качества товаров"".'");
				ВызватьИсключение СтрСоединить(ТекстИсключения, Символы.ПС);
				
			КонецЕсли;
			
		КонецПопытки;
		
	КонецЦикла;
	ОбновлениеИнформационнойБазыУТ.ЗаписатьПлохиеДанные(ИсключенияПриОбновлении, 1, Параметры);
	
	Параметры.ОбработкаЗавершена = ОбновлениеИнформационнойБазы.ОбработкаДанныхЗавершена(Параметры.Очередь, ПолноеИмяОбъекта);
	
КонецПроцедуры

#КонецОбласти

#КонецОбласти

#КонецЕсли
