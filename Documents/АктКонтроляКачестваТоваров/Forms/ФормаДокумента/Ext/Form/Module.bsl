&НаКлиенте
Процедура ЗадатьВопросИОформитьДокумент(КлючКоманды, ИмяКоманды)
	
	Если Объект.Статус = ПредопределенноеЗначение("Перечисление.СтатусыАктовКонтроляКачества.ВРаботе") Тогда
		
		ТекстОшибки = СтрШаблон(НСтр("ru = 'Для выполнения команды ""%1"" необходимо установить статус ""%2"" или ""%3"".'"),
			ИмяКоманды,
			Строка(ПредопределенноеЗначение("Перечисление.СтатусыАктовКонтроляКачества.ОжидаетРешения")),
			Строка(ПредопределенноеЗначение("Перечисление.СтатусыАктовКонтроляКачества.Отработан")));
		ПоказатьПредупреждение(, ТекстОшибки);
		
	ИначеЕсли Не Объект.Проведен Или Модифицированность Тогда
		ДополнительныеПараметры = Новый Структура();
		ДополнительныеПараметры.Вставить("КлючКоманды", КлючКоманды);
		
		ТекстВопроса =  СтрШаблон(НСтр("ru = 'Для выполнения команды ""%1"" документ будет проведен. Продолжить?'"), ИмяКоманды);
		ПоказатьВопрос(
			Новый ОписаниеОповещения("ОтветОНеобходимостиПроведенияПолучен", ЭтотОбъект, ДополнительныеПараметры), 
				ТекстВопроса, РежимДиалогаВопрос.ДаНет);
	Иначе
		
		ОформитьДокумент(КлючКоманды);
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОтветОНеобходимостиПроведенияПолучен(РезультатВопроса, ДополнительныеПараметры) Экспорт
	
	Ответ = РезультатВопроса;
	Если Ответ = КодВозвратаДиалога.Нет Тогда
		Возврат;
	Иначе
		ОчиститьСообщения();
		ПараметрыЗаписи = Новый Структура("РежимЗаписи", РежимЗаписиДокумента.Проведение);
		ПараметрыЗаписи.Вставить("КлючКоманды", ДополнительныеПараметры.КлючКоманды);
		Записать(ПараметрыЗаписи);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОформитьДокумент(КлючКоманды)
	
	ПараметрыВыполнения = ПодключаемыеКомандыКлиент.ПараметрыВыполненияКоманды();
	ПараметрыВыполнения.ОписаниеКоманды = Новый Структура("МножественныйВыбор", Ложь);
	ПараметрыВыполнения.МассивСсылок = ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(Объект.Ссылка);
	ПараметрыВыполнения.Форма = ЭтотОбъект;
	
	Если КлючКоманды = КлючОформитьПеремещение() Тогда
		СозданиеНаОснованииУТКлиент.СоздатьПеремещениеТоваровНаОснованииПоГруппеСкладов(Объект.Ссылка, ПараметрыВыполнения);
	ИначеЕсли КлючКоманды = КлючОформитьСписание() Тогда
		СозданиеНаОснованииУТКлиент.СоздатьСписаниеНедостачТоваровНаОснованииПоГруппеСкладов(Объект.Ссылка, ПараметрыВыполнения);
	ИначеЕсли КлючКоманды = КлючОформитьПорчу() Тогда
		СозданиеНаОснованииУТКлиент.СоздатьПорчуТоваровНаОснованииПоГруппеСкладов(Объект.Ссылка, ПараметрыВыполнения);
	ИначеЕсли КлючКоманды = КлючОформитьВозврат() Тогда
		Если ДоступноОформлениеВозвратаТоваровПоставщику(Объект.ХозяйственнаяОперацияПартии) Тогда
			СозданиеНаОснованииУТКлиент.СоздатьВозвратТоваровПоставщикуНаОснованииПоГруппеСкладов(Объект.Ссылка, ПараметрыВыполнения);
		ИначеЕсли ДоступноОформлениеОтгрузкиТоваровСХранения(Объект.ХозяйственнаяОперацияПартии) Тогда
			СозданиеНаОснованииУТКлиент.СоздатьОтгрузкуТоваровСХраненияНаОснованииПоГруппеСкладов(Объект.Ссылка, ПараметрыВыполнения);
		Иначе
			Текст = СтрШаблон(
				НСтр("ru='Для операции ""%1"", по которой поступил товар, не предполагается создание возврата товаров. Ввод на основании документа запрещен.'"),
				Объект.ХозяйственнаяОперацияПартии);
			ПоказатьПредупреждение(, Текст);
		КонецЕсли;
	ИначеЕсли КлючКоманды = КлючОформитьАктОРасхождениях() Тогда
		
		Если ОформлятьАктПоПриобретению Тогда
			
			Если ИспользоватьАктыРасхожденийПослеПриемки Тогда
				
				ОткрытьФорму(
					"Документ.АктОРасхожденияхПослеПриемки.Форма.ФормаДокумента",
					Новый Структура("Основание", Объект.Ссылка),
					ЭтотОбъект,
					Истина);
					
			Иначе
				Текст = НСтр("ru = 'Функциональная возможность использования актов о расхождениях после приемки от поставщика / клиента отключена, обратитесь к администратору.'");
				ПоказатьПредупреждение(, Текст);
			КонецЕсли;
			
		ИначеЕсли ОформлятьАктПоПереработкеНаСтороне Тогда
			
			Если ИспользоватьАктыРасхожденийПослеПриемкиПоПоступлениямОтПереработчика2_5 Тогда
				
				ОткрытьФорму(
					"Документ.АктОРасхожденияхПослеПриемки.Форма.ФормаДокумента",
					Новый Структура("Основание", Объект.Ссылка),
					ЭтотОбъект,
					Истина);
					
			Иначе
				Текст = НСтр("ru = 'Функциональная возможность использования актов о расхождениях после приемки/возврата от переработчика отключена, обратитесь к администратору.'");
				ПоказатьПредупреждение(, Текст);
			КонецЕсли;
			
		ИначеЕсли ОформлятьАктПоПереработкеДавальческогоСырья Тогда
			
			Если ИспользоватьАктыРасхожденийПослеПриемкиПоПриемкамТоваровДавальца2_5 Тогда
				
				ОткрытьФорму(
					"Документ.АктОРасхожденияхПослеПриемки.Форма.ФормаДокумента",
					Новый Структура("Основание", Объект.Ссылка),
					ЭтотОбъект,
					Истина);
					
			Иначе
				Текст = НСтр("ru = 'Функциональная возможность использования актов о расхождениях после приемки от давальца отключена, обратитесь к администратору.'");
				ПоказатьПредупреждение(, Текст);
			КонецЕсли;
			
			ИначеЕсли ОформлятьАктПоПеремещению Тогда
			
			Если ИспользоватьАктыРасхожденийПослеПеремещения Тогда
				
				ОткрытьФорму(
					"Документ.АктОРасхожденияхПослеПеремещения.Форма.ФормаДокумента",
					Новый Структура("Основание", Объект.Ссылка),
					ЭтотОбъект,
					Истина);
					
			Иначе
				
				Текст = НСтр("ru = 'Функциональная возможность использования актов о расхождениях после перемещения отключена, обратитесь к администратору.'");
				ПоказатьПредупреждение(, Текст);
				
			КонецЕсли;
			
		ИначеЕсли ТипЗнч(Партия) = Тип("СправочникСсылка.ДоговорыКонтрагентов") Тогда
			
			Текст = НСтр("ru = 'Создание Акта о расхождениях, когда приемка товаров на склад осуществлялась по договорам, не поддерживается. Ввод на основании документа запрещен.'");
			ПоказатьПредупреждение(, Текст);
			
		ИначеЕсли ТипЗнч(Партия) = Тип("СправочникСсылка.СоглашенияСПоставщиками") Тогда
			
			Текст = НСтр("ru = 'Создание Акта о расхождениях, когда приемка товаров на склад осуществлялась по соглашениям, не поддерживается. Ввод на основании документа запрещен.'");
			ПоказатьПредупреждение(, Текст);
			
		ИначеЕсли ТипЗнч(Партия) = Тип("ДокументСсылка.ЗаявкаНаКонтрольКачестваТоваров") Тогда
			
			Текст = НСтр("ru = 'Создание Акта о расхождениях, при контроле качества по заявкам на контроль, не поддерживается. Ввод на основании документа запрещен.'");
			ПоказатьПредупреждение(, Текст);
			
		ИначеЕсли ТипЗнч(Партия) = Тип("ДокументСсылка.ЗаказПоставщику")
					Или ТипЗнч(Партия) = Тип("ДокументСсылка.ЗаказКлиента")
					Или ТипЗнч(Партия) = Тип("ДокументСсылка.ЗаявкаНаВозвратТоваровОтКлиента")
					
					
					
					Или ТипЗнч(Партия) = Тип("ДокументСсылка.ЗаказНаПеремещение") Тогда
			
			Текст = НСтр("ru = 'Создание Акта о расхождениях, когда приемка товаров на склад осуществлялась по заказам, не поддерживается. Ввод на основании документа запрещен.'");
			ПоказатьПредупреждение(, Текст);
			
		ИначеЕсли ТипЗнч(Партия) = Тип("ДокументСсылка.ПоступлениеТоваровНаСклад") Тогда
			
			Текст = НСтр("ru = 'Создание Акта о расхождениях по контролируемой партии, связанной с документом ""Поступление товаров на склад"", не поддерживается. Ввод на основании документа запрещен.'");
			ПоказатьПредупреждение(, Текст);
			
		Иначе
			
			Текст = СтрШаблон(
				НСтр("ru = 'Для операции ""%1"", по которой поступил товар, не предполагается создание Акта о расхождениях. Ввод на основании документа запрещен.'"),
				Объект.ХозяйственнаяОперацияПартии);
			ПоказатьПредупреждение(, Текст);
			
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьРеквизитыФормыЗависимыеОтКонтролируемойПартии()
	
	УстановитьПривилегированныйРежим(Истина);
	Партия = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.КонтролируемаяПартия, "Партия");
	УстановитьПривилегированныйРежим(Ложь);
	
	ОформлятьАктПоПриобретению = ТипЗнч(Партия) = Тип("ДокументСсылка.ПриобретениеТоваровУслуг")
		Или ТипЗнч(Партия) = Тип("ДокументСсылка.ВозвратТоваровОтКлиента")
		Или ТипЗнч(Партия) = Тип("ДокументСсылка.ПоступлениеТоваровОтХранителя")
			И (Объект.ХозяйственнаяОперацияПартии = ПредопределенноеЗначение("Перечисление.ХозяйственныеОперации.ВозвратОтХранителя")
		Или Объект.ХозяйственнаяОперацияПартии = ПредопределенноеЗначение("Перечисление.ХозяйственныеОперации.ВозвратОтКомиссионера"))
			Или ТипЗнч(Партия) = Тип("ДокументСсылка.ПриемкаТоваровНаХранение")
			И Объект.ХозяйственнаяОперацияПартии = ПредопределенноеЗначение("Перечисление.ХозяйственныеОперации.ПриемНаХранениеСПравомПродажи");
			
	ОформлятьАктПоПереработкеНаСтороне = Ложь;
	
	
	ОформлятьАктПоПереработкеДавальческогоСырья = Ложь;
	
	
	ОформлятьАктПоПеремещению = ТипЗнч(Партия) = Тип("ДокументСсылка.ПеремещениеТоваров");
	
КонецПроцедуры

