&НаКлиенте
Процедура ОткрытьПодборСерийПриСканированииШтрихкодаНоменклатуры()
	
	Если ТекущиеДанныеИдентификатор = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ТекущиеДанные = Объект.Товары.НайтиПоИдентификатору(ТекущиеДанныеИдентификатор);
	ОткрытьПодборСерий(,ТекущиеДанные);
	
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьПодборСерий(Текст = "", ТекущиеДанные = Неопределено)
	
	НуженСерверныйВызов = НоменклатураКлиент.ДляУказанияСерийНуженСерверныйВызов(
		ЭтотОбъект,
		ПараметрыУказанияСерий,
		Текст,
		ТекущиеДанные);
		
	Если НуженСерверныйВызов Тогда
		
		Если ТекущиеДанные = Неопределено Тогда
			ТекущиеДанныеИдентификатор = Элементы.Товары.ТекущиеДанные.ПолучитьИдентификатор();
		Иначе
			ТекущиеДанныеИдентификатор = ТекущиеДанные.ПолучитьИдентификатор();
		КонецЕсли;
		
		ПараметрыФормыУказанияСерий = ПараметрыФормыУказанияСерий(ТекущиеДанныеИдентификатор);
		
		ТекущиеПараметрыУказанияСерий = Новый Структура("ПараметрыФормыУказанияСерий", ПараметрыФормыУказанияСерий);
		
		ОписаниеОповещения = Новый ОписаниеОповещения(
			"ОткрытьПодборСерийЗавершение",
			ЭтотОбъект,
			ТекущиеПараметрыУказанияСерий);
		
		ОткрытьФорму(
			ПараметрыФормыУказанияСерий.ИмяФормы,
			ПараметрыФормыУказанияСерий,
			ЭтотОбъект,
			,
			,
			,
			ОписаниеОповещения,
			РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
			
	КонецЕсли;
		
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьПодборСерийЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	ЗначениеВозврата = Результат;
	Если ЗначениеВозврата <> Неопределено Тогда
		ОбработатьУказаниеСерийСервер(ДополнительныеПараметры.ПараметрыФормыУказанияСерий, КэшированныеЗначения);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ОбработатьУказаниеСерийСервер(ПараметрыФормыУказанияСерий, КэшированныеЗначения)
	
	ПроверитьСериюРассчитатьСтатус = Новый Структура("Склад, ПараметрыУказанияСерий", Объект.Склад, ПараметрыУказанияСерий);
	
	СтруктураДействий = Новый Структура();
	СтруктураДействий.Вставить("ПроверитьСериюРассчитатьСтатус", ПроверитьСериюРассчитатьСтатус);
	
	НоменклатураСервер.ОбработатьУказаниеСерий(
		Объект,
		ПараметрыУказанияСерий,
		ПараметрыФормыУказанияСерий,
		СтруктураДействий,
		КэшированныеЗначения);
	
КонецПроцедуры

&НаСервере
Функция ПараметрыФормыУказанияСерий(ТекущиеДанныеИдентификатор)
	
	Возврат НоменклатураСервер.ПараметрыФормыУказанияСерий(
		Объект,
		ПараметрыУказанияСерий,
		ТекущиеДанныеИдентификатор,
		ЭтотОбъект);
	
КонецФункции

#КонецОбласти

#Область ИзменениеРеквизитовДокумента

&НаСервере
Процедура ПриИзмененииСкладаСервер()
	
	// Очистка склада означает только, что он и помещения теперь указываются в таблице.
	Если ЗначениеЗаполнено(Объект.Склад) Тогда
		
		ПустоеПомещение = Справочники.СкладскиеПомещения.ПустаяСсылка();
		Объект.Помещение = ПустоеПомещение;
		
		ПроверитьЗаполнитьСклад = ПроверитьЗаполнитьСкладПараметрыДействия(Объект.Склад);
		ЗаполнитьПризнакИспользованияПомещений = Новый Структура("Дата", Объект.Дата);
		ЗаполнитьПризнакАдресногоХранения = Новый Структура("Дата", Объект.Дата);
		ПроверитьСериюРассчитатьСтатус = Новый Структура("Склад, ПараметрыУказанияСерий", Объект.Склад, ПараметрыУказанияСерий);
		
		СтруктураДействий = Новый Структура();
		СтруктураДействий.Вставить("ПроверитьЗаполнитьСклад", ПроверитьЗаполнитьСклад);
		СтруктураДействий.Вставить("ЗаполнитьПомещениеВСтрокеТЧ", Объект.Помещение);
		СтруктураДействий.Вставить("ЗаполнитьПризнакИспользованияПомещений", ЗаполнитьПризнакИспользованияПомещений);
		СтруктураДействий.Вставить("ЗаполнитьПризнакАдресногоХранения", ЗаполнитьПризнакАдресногоХранения);
		СтруктураДействий.Вставить("ПроверитьСериюРассчитатьСтатус", ПроверитьСериюРассчитатьСтатус);
		ПакетнаяОбработкаТабличнойЧастиСервер.ОбработатьТЧ(Объект.Товары, СтруктураДействий);
		ОчиститьУпаковкуДляСтрокБезАдресногоХранения();
		
	КонецЕсли;
	
	УстановитьВидимостьСкладаИПомещения();
	НастроитьДействия();
	ОчиститьНедопустимыеДействия();
	
КонецПроцедуры

&НаСервере
Процедура ПриИзмененииДатыСервер()
	
	ЗаполнитьПризнакИспользованияПомещений = Новый Структура("Дата", Объект.Дата);
	ЗаполнитьПризнакАдресногоХранения = Новый Структура("Дата", Объект.Дата);
	
	СтруктураДействий = Новый Структура();
	СтруктураДействий.Вставить("ЗаполнитьПризнакИспользованияПомещений", ЗаполнитьПризнакИспользованияПомещений);
	СтруктураДействий.Вставить("ЗаполнитьПризнакАдресногоХранения", ЗаполнитьПризнакАдресногоХранения);
	
	ПакетнаяОбработкаТабличнойЧастиСервер.ОбработатьТЧ(Объект.Товары, СтруктураДействий);
	
	ВидимостьПомещенияДоИзменения = Элементы.Помещение.Видимость;
	УстановитьВидимостьСкладаИПомещения();
	ОчиститьПомещение = ВидимостьПомещенияДоИзменения И Не Элементы.Помещение.Видимость;
	
	Если ОчиститьПомещение Тогда
		ПустоеПомещение = Справочники.СкладскиеПомещения.ПустаяСсылка();
		Объект.Помещение = ПустоеПомещение;
		Для Каждого Строка Из Объект.Товары Цикл
			Строка.Помещение = ПустоеПомещение;
		КонецЦикла;
		ОчиститьУпаковкуДляСтрокБезАдресногоХранения();
	КонецЕсли;
	
	НоменклатураСервер.ЗаполнитьСтатусыУказанияСерий(Объект, ПараметрыУказанияСерий);
	
	НастроитьДействия();
	ОчиститьНедопустимыеДействия();
	
КонецПроцедуры

&НаСервере
Процедура ПриИзмененииПомещенияСервер()
	
	// Очистка помещения означает только, что оно теперь указывается в таблице.
	Если ЗначениеЗаполнено(Объект.Помещение) Тогда
		Для Каждого Строка Из Объект.Товары Цикл
			Строка.Помещение = Объект.Помещение;
		КонецЦикла;
		СтруктураДействий = Новый Структура();
		ЗаполнитьПризнакАдресногоХранения = Новый Структура("Дата", Объект.Дата);
		СтруктураДействий.Вставить("ЗаполнитьПризнакАдресногоХранения", ЗаполнитьПризнакАдресногоХранения);
		ПакетнаяОбработкаТабличнойЧастиСервер.ОбработатьТЧ(Объект.Товары, СтруктураДействий);
		ОчиститьУпаковкуДляСтрокБезАдресногоХранения();
	КонецЕсли;
	УстановитьВидимостьСкладаИПомещения();
	
КонецПроцедуры

&НаСервере
Процедура ПриИзмененииКонтролируемойПартииСервер()
	
	УстановитьПривилегированныйРежим(Истина);
	Документы.АктКонтроляКачестваТоваров.ЗаполнитьРеквизитыИзПартии(Объект);
	УстановитьПривилегированныйРежим(Ложь);
	
	ЗаполнитьРеквизитыФормыЗависимыеОтКонтролируемойПартии();
	НастроитьДействия();
	ОчиститьНедопустимыеДействия();
	
КонецПроцедуры

&НаСервере
Процедура ОчиститьНедопустимыеДействия()
	
	Склады = Объект.Товары.Выгрузить(, "Склад").ВыгрузитьКолонку("Склад");
	УстановитьПривилегированныйРежим(Истина);
	РеквизитыСкладов = ОбщегоНазначения.ЗначенияРеквизитовОбъектов(Склады,
		"ИспользоватьОрдернуюСхемуПриПоступлении,ДатаНачалаОрдернойСхемыПриПоступлении");
	УстановитьПривилегированныйРежим(Ложь);
	
	ПустоеДействие = Перечисления.ДействияПоТоварамВАктеКонтроляКачества.ПустаяСсылка();
	ДейсвтиеИзменитьКачество = Перечисления.ДействияПоТоварамВАктеКонтроляКачества.ИзменитьКачество;
	ДатаДокумента = ?(ЗначениеЗаполнено(Объект.Дата), Объект.Дата, НачалоДня(ТекущаяДатаСеанса()));
	Для Каждого СтрокаТаблицы Из Объект.Товары Цикл
		
		Если Действия.НайтиПоЗначению(СтрокаТаблицы.Действие) = Неопределено
				Или СтрокаТаблицы.Действие = ДейсвтиеИзменитьКачество
					И ЗначениеЗаполнено(СтрокаТаблицы.Склад)
					И (Не РеквизитыСкладов[СтрокаТаблицы.Склад].ИспользоватьОрдернуюСхемуПриПоступлении
						Или РеквизитыСкладов[СтрокаТаблицы.Склад].ДатаНачалаОрдернойСхемыПриПоступлении > ДатаДокумента) Тогда
			СтрокаТаблицы.Действие = ПустоеДействие;
			ПроверитьОчиститьРеквизитыОприходования(СтрокаТаблицы);
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти

&НаСервере
Процедура УстановитьВидимостьСкладаИПомещения()
	
	ИспользоватьСкладскиеПомещения = СкладыСервер.ИспользоватьСкладскиеПомещения(Объект.Склад, Объект.Дата)
		И ЗначениеЗаполнено(Объект.Склад);
	Элементы.Помещение.Видимость = ИспользоватьСкладскиеПомещения;
	Элементы.ТоварыСклад.Видимость = Не ЗначениеЗаполнено(Объект.Склад);
	Элементы.ТоварыПомещение.Видимость = Не ЗначениеЗаполнено(Объект.Склад)
		Или Не ЗначениеЗаполнено(Объект.Помещение) И ИспользоватьСкладскиеПомещения;
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ДанныеВыбораДействия(ПараметрыМетода)
	
	Действия = Перечисления.ДействияПоТоварамВАктеКонтроляКачества.ПолучитьДанныеВыбора(ПараметрыМетода);
	Возврат Действия;
	
КонецФункции

&НаСервере
Процедура НастроитьДействия()
	
	ПараметрыМетода = Новый Структура();
	ПараметрыМетода.Вставить("КонтролируемаяПартия", Объект.КонтролируемаяПартия);
	ПараметрыМетода.Вставить("Склад", Объект.Склад);
	ПараметрыМетода.Вставить("Дата", Объект.Дата);
	Действия = Перечисления.ДействияПоТоварамВАктеКонтроляКачества.ПолучитьДанныеВыбора(ПараметрыМетода);
	
	ВсеДействия = Перечисления.ДействияПоТоварамВАктеКонтроляКачества;
	КомандыИДействия = Новый Соответствие();
	КомандыИДействия.Вставить(ВсеДействия.ИзменитьКачество, Элементы.ЗаполнитьДействиеИзменитьКачество);
	КомандыИДействия.Вставить(ВсеДействия.ВернутьПоставщику, Элементы.ЗаполнитьДействиеВернутьПоставщику);
	КомандыИДействия.Вставить(ВсеДействия.НеПриходовать, Элементы.ЗаполнитьДействиеНеПриходовать);
	КомандыИДействия.Вставить(ВсеДействия.ОформитьПорчу, Элементы.ЗаполнитьДействиеОформитьПорчу);
	КомандыИДействия.Вставить(ВсеДействия.ОформитьВозврат, Элементы.ЗаполнитьДействиеОформитьВозврат);
	КомандыИДействия.Вставить(ВсеДействия.ОформитьПеремещение, Элементы.ЗаполнитьДействиеОформитьПеремещение);
	КомандыИДействия.Вставить(ВсеДействия.ОформитьСписание, Элементы.ЗаполнитьДействиеОформитьСписание);
	
	Для Каждого Элемент Из КомандыИДействия Цикл
		НайденноеЗначение = Действия.НайтиПоЗначению(Элемент.Ключ);
		Элемент.Значение.Видимость = НайденноеЗначение <> Неопределено;
		Если НайденноеЗначение <> Неопределено Тогда
			Элемент.Значение.Заголовок = НайденноеЗначение.Представление;
		КонецЕсли;
	КонецЦикла;
	
	Элементы.ОформитьАктОРасхождениях.Видимость =
		Действия.НайтиПоЗначению(ВсеДействия.ИзменитьКачество) <> Неопределено
			Или Действия.НайтиПоЗначению(ВсеДействия.ВернутьПоставщику) <> Неопределено
			Или Действия.НайтиПоЗначению(ВсеДействия.НеПриходовать) <> Неопределено;
			
	Элементы.ОформитьПорчу.Видимость = Действия.НайтиПоЗначению(ВсеДействия.ОформитьПорчу) <> Неопределено;
	Элементы.ОформитьВозврат.Видимость = Действия.НайтиПоЗначению(ВсеДействия.ОформитьВозврат) <> Неопределено;
	Элементы.ОформитьПеремещение.Видимость = Действия.НайтиПоЗначению(ВсеДействия.ОформитьПеремещение) <> Неопределено;
	Элементы.ОформитьСписание.Видимость = Действия.НайтиПоЗначению(ВсеДействия.ОформитьСписание) <> Неопределено;
	ИмяПрава = "Добавление"; // @Access-right-1
	Элементы.ОформитьАктОРасхождениях.Доступность =
		ПравоДоступа(ИмяПрава, Метаданные.Документы.АктОРасхожденияхПослеПриемки)
				И (ОформлятьАктПоПриобретению
					Или ОформлятьАктПоПереработкеНаСтороне
					Или ОформлятьАктПоПереработкеДавальческогоСырья)
			Или ПравоДоступа(ИмяПрава, Метаданные.Документы.АктОРасхожденияхПослеПеремещения)
				И ОформлятьАктПоПеремещению
			Или (ПравоДоступа(ИмяПрава, Метаданные.Документы.АктОРасхожденияхПослеПриемки)
					Или ПравоДоступа(ИмяПрава, Метаданные.Документы.АктОРасхожденияхПослеПеремещения))
				И Не ОформлятьАктПоПриобретению
				И Не ОформлятьАктПоПереработкеНаСтороне
				И Не ОформлятьАктПоПереработкеДавальческогоСырья
				И Не ОформлятьАктПоПеремещению;
	
	ИмяПрава = "Добавление"; // @Access-right-1
	Элементы.ОформитьПорчу.Доступность = ПравоДоступа(ИмяПрава, Метаданные.Документы.ПорчаТоваров);
	Элементы.ОформитьВозврат.Доступность = ПравоДоступа(ИмяПрава, Метаданные.Документы.ВозвратТоваровПоставщику)
		Или ПравоДоступа(ИмяПрава, Метаданные.Документы.ОтгрузкаТоваровСХранения);
	Элементы.ОформитьПеремещение.Доступность = ПравоДоступа(ИмяПрава, Метаданные.Документы.ПеремещениеТоваров);
	Элементы.ОформитьСписание.Доступность = ПравоДоступа(ИмяПрава, Метаданные.Документы.СписаниеНедостачТоваров);
	
	ВидимостьПолей = Действия.НайтиПоЗначению(ВсеДействия.ИзменитьКачество) <> Неопределено
		Или Действия.НайтиПоЗначению(ВсеДействия.ОформитьПорчу) <> Неопределено;
	НастроитьПоляИзмененияКачества(ВидимостьПолей);
	УстановитьУсловноеОформление();
	
КонецПроцедуры

&НаСервере
Процедура НастроитьПоляИзмененияКачества(Видимость);
	
	Элементы.ГруппаИспорченныйТовар.Видимость = Видимость;
	Элементы.ТоварыНоменклатураОприходованиеКод.Видимость = Видимость;
	Элементы.ТоварыНоменклатураОприходованиеАртикул.Видимость = Видимость;
	Элементы.ТоварыНоменклатураОприходование.Видимость = Видимость;
	Элементы.ТоварыХарактеристикаОприходование.Видимость = Видимость;
	Элементы.ТоварыПодНазначение.Видимость = Видимость;
	Элементы.ТоварыГруппаОприходованиеУпаковкаЕдиницаИзмерения.Видимость = Видимость;
	Элементы.ТоварыУпаковкаОприходование.Видимость = Видимость;
	Элементы.ТоварыНоменклатураОприходованиеЕдиницаИзмерения.Видимость = Видимость;
	Элементы.ГруппаТоварИсходногоКачества.ОтображатьВШапке = Видимость;
	
КонецПроцедуры

&НаСервере
Процедура ОчиститьУпаковкуДляСтрокБезАдресногоХранения()
	
	Для Каждого Строка Из Объект.Товары Цикл
		
		Если Не Строка.ИспользоватьАдресноеХранение Тогда
			Строка.Упаковка = Справочники.УпаковкиЕдиницыИзмерения.ПустаяСсылка();
			Строка.Количество = Строка.КоличествоУпаковок;
		КонецЕсли;
		
	КонецЦикла;

КонецПроцедуры

&НаКлиенте
Процедура ОчиститьУпаковкуДляСтрокБезАдресногоХраненияВСтроке(СтрокаТаблицы)
	
	Если Не СтрокаТаблицы.ИспользоватьАдресноеХранение Тогда
		СтрокаТаблицы.Упаковка = ПредопределенноеЗначение("Справочник.УпаковкиЕдиницыИзмерения.ПустаяСсылка");
		СтрокаТаблицы.Количество = СтрокаТаблицы.КоличествоУпаковок;
	КонецЕсли;

КонецПроцедуры


&НаКлиенте
Процедура ОповеститьОПроведенииДокумента(ПараметрыЗаписи)
	
	ПараметрОбработкиОповещения = ОбщегоНазначенияКлиент.СкопироватьРекурсивно(ПараметрыЗаписи);
	Если ТипЗнч(ВладелецФормы) = Тип("ФормаКлиентскогоПриложения") Тогда
		ИдентификаторФормыВладельца = ВладелецФормы.УникальныйИдентификатор;
	Иначе
		ИдентификаторФормыВладельца = Неопределено;
	КонецЕсли;
	КлючиДокументаОповещение = РаботаСЖурналамиДокументовКлиент.ПолучитьПараметрыКлючаПоДокументу(
		Объект.Ссылка, Объект.Дата, Неопределено);
	ПараметрОбработкиОповещения.Вставить("ИдентификаторФормыВладельца", ИдентификаторФормыВладельца);
	ПараметрОбработкиОповещения.Вставить("КлючиДокументаОповещение", КлючиДокументаОповещение);
	Оповестить("Запись_АктКонтроляКачестваТоваров", ПараметрОбработкиОповещения, Объект.Ссылка);
	
КонецПроцедуры

&НаСервере
Процедура ПриЧтенииСозданииНаСервере()
	
	ИспользоватьАктыРасхожденийПослеПеремещения = ПолучитьФункциональнуюОпцию("ИспользоватьАктыРасхожденийПослеПеремещения");
	ИспользоватьАктыРасхожденийПослеПриемки = ПолучитьФункциональнуюОпцию("ИспользоватьАктыРасхожденийПослеПриемки");
	ИспользоватьАктыРасхожденийПослеПриемкиПоПриемкамТоваровДавальца2_5 = Ложь;
	ИспользоватьАктыРасхожденийПослеПриемкиПоПоступлениямОтПереработчика2_5 = Ложь;
	
	ТекущиеПараметрыУказанияСерий = НоменклатураСервер.ПараметрыУказанияСерий(
		Объект,
		Документы.АктКонтроляКачестваТоваров);
	ПараметрыУказанияСерий = Новый ФиксированнаяСтруктура(ТекущиеПараметрыУказанияСерий);
	
	ЗаполнитьРеквизитыФормыЗависимыеОтКонтролируемойПартии();
	НастроитьДействия();
	
	УстановитьВидимостьСкладаИПомещения();
	ЗаполнитьСлужебныеРеквизитыПриЗаполненииТабличнойЧасти();
	Элементы.ГруппаОснование.Видимость = ЗначениеЗаполнено(Объект.ДокументОснование);
	Элементы.ГруппаТоварыИсследования.Видимость = ПолучитьФункциональнуюОпцию("ИспользоватьИсследованиеКачестваТоваров");
	
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьСлужебныеРеквизитыПриЗаполненииТабличнойЧасти()
	
	ЗаполнитьПризнакАртикул = Новый Структура("Номенклатура,НоменклатураОприходование",
		"Артикул",
		"АртикулОприходование");
	ЗаполнитьПризнакТипНоменклатуры = Новый Структура("Номенклатура,НоменклатураОприходование",
		"ТипНоменклатуры", 
		"ТипНоменклатурыОприходование");
	ЗаполнитьПризнакТипИзмеряемойВеличины = Новый Структура("Номенклатура,НоменклатураОприходование",
		"ТипИзмеряемойВеличины",
		"ТипИзмеряемойВеличиныОприходование");
	ЗаполнитьПризнакХарактеристикиИспользуются = Новый Структура("Номенклатура,НоменклатураОприходование",
		"ХарактеристикиИспользуются",
		"ХарактеристикиИспользуютсяОприходование");
	
	ЗаполнитьПризнакИспользованияПомещений = Новый Структура("Дата", Объект.Дата);
	ЗаполнитьПризнакАдресногоХранения = Новый Структура("Дата", Объект.Дата);
	
	СтруктураДействий = Новый Структура();
	СтруктураДействий.Вставить("ЗаполнитьПризнакАртикул", ЗаполнитьПризнакАртикул);
	СтруктураДействий.Вставить("ЗаполнитьПризнакТипНоменклатуры", ЗаполнитьПризнакТипНоменклатуры);
	СтруктураДействий.Вставить("ЗаполнитьПризнакТипИзмеряемойВеличины", ЗаполнитьПризнакТипИзмеряемойВеличины);
	СтруктураДействий.Вставить("ЗаполнитьПризнакХарактеристикиИспользуются", ЗаполнитьПризнакХарактеристикиИспользуются);
	СтруктураДействий.Вставить("ЗаполнитьПризнакИспользованияПомещений", ЗаполнитьПризнакИспользованияПомещений);
	СтруктураДействий.Вставить("ЗаполнитьПризнакАдресногоХранения", ЗаполнитьПризнакАдресногоХранения);
	
	
	ПакетнаяОбработкаТабличнойЧастиСервер.ОбработатьТЧ(Объект.Товары, СтруктураДействий);
	
КонецПроцедуры

&НаКлиенте
Процедура ПересчитатьКоличествоОприходование(ТекущиеДанные)
	
	ТекущаяСтрока = Новый Структура;
	ТекущаяСтрока.Вставить("Номенклатура",       ТекущиеДанные.НоменклатураОприходование);
	ТекущаяСтрока.Вставить("Упаковка",           ТекущиеДанные.УпаковкаОприходование);
	ТекущаяСтрока.Вставить("Количество",         ТекущиеДанные.КоличествоОприходование);
	ТекущаяСтрока.Вставить("КоличествоУпаковок", ТекущиеДанные.КоличествоУпаковок);
	
	СтруктураДействий = Новый Структура("ПересчитатьКоличествоЕдиниц");
	
	ПакетнаяОбработкаТабличнойЧастиКлиент.ОбработатьСтрокуТЧ(ТекущаяСтрока, СтруктураДействий, КэшированныеЗначения);
	
	ТекущиеДанные.КоличествоОприходование = ТекущаяСтрока.Количество;
	
КонецПроцедуры

&НаКлиенте
Процедура ТоварыНоменклатураОприходованиеНачалоВыбораЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	Модифицированность = Истина;
	
	ЗаполнитьСлужебныеРеквизитыНоменклатурыОприходование(Результат);
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьСлужебныеРеквизитыНоменклатурыОприходование(ТекущиеДанные)

	ТекущаяСтрока = Новый Структура;
	ТекущаяСтрока.Вставить("Номенклатура", ТекущиеДанные.НоменклатураОприходование);
	ТекущаяСтрока.Вставить("ХарактеристикиИспользуются");
	ТекущаяСтрока.Вставить("Характеристика", ТекущиеДанные.ХарактеристикаОприходование);
	ТекущаяСтрока.Вставить("ТипНоменклатуры", ТекущиеДанные.ТипНоменклатурыОприходование);
	ТекущаяСтрока.Вставить("ТипИзмеряемойВеличины", ТекущиеДанные.ТипИзмеряемойВеличиныОприходование);
	ТекущаяСтрока.Вставить("Артикул", ТекущиеДанные.АртикулОприходование);
	
	СтруктураДействий = Новый Структура;
	СтруктураДействий.Вставить("ПроверитьХарактеристикуПоВладельцу", ТекущиеДанные.Характеристика);
	СтруктураДействий.Вставить("ЗаполнитьПризнакАртикул", Новый Структура("Номенклатура", "Артикул"));
	СтруктураДействий.Вставить("ЗаполнитьПризнакТипИзмеряемойВеличины", Новый Структура("Номенклатура", "ТипИзмеряемойВеличины"));
	СтруктураДействий.Вставить("ЗаполнитьПризнакТипНоменклатуры", Новый Структура("Номенклатура", "ТипНоменклатуры"));
	СтруктураДействий.Вставить("ЗаполнитьПризнакХарактеристикиИспользуются", Новый Структура("Номенклатура", "ХарактеристикиИспользуются"));
	
	ПакетнаяОбработкаТабличнойЧастиКлиент.ОбработатьСтрокуТЧ(ТекущаяСтрока, СтруктураДействий, Неопределено);
	
	ТекущиеДанные.ХарактеристикиИспользуютсяОприходование = ТекущаяСтрока.ХарактеристикиИспользуются;
	ТекущиеДанные.ХарактеристикаОприходование = ТекущаяСтрока.Характеристика;
	ТекущиеДанные.АртикулОприходование = ТекущаяСтрока.Артикул;
	ТекущиеДанные.ТипНоменклатурыОприходование = ТекущаяСтрока.ТипНоменклатуры;
	ТекущиеДанные.ТипИзмеряемойВеличиныОприходование = ТекущаяСтрока.ТипИзмеряемойВеличины;
	ТекущиеДанные.ХарактеристикиИспользуютсяОприходование = ТекущаяСтрока.ХарактеристикиИспользуются;
	
	ПересчитатьКоличествоОприходование(ТекущиеДанные);
	
КонецПроцедуры


&НаСервереБезКонтекста
Функция ЕстьТоварДругогоКачества(ТоварИсходногоКачества, ТоварДругогоКачества)
	
	Возврат РегистрыСведений.ТоварыДругогоКачества.ПроверитьНаличиеГрадации(ТоварИсходногоКачества, ТоварДругогоКачества);
	
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Процедура ПроверитьОчиститьРеквизитыОприходования(СтрокаТаблицы)
	
	Если СтрокаТаблицы.Действие <> ПредопределенноеЗначение("Перечисление.ДействияПоТоварамВАктеКонтроляКачества.ИзменитьКачество")
			И СтрокаТаблицы.Действие <> ПредопределенноеЗначение("Перечисление.ДействияПоТоварамВАктеКонтроляКачества.ОформитьПорчу") Тогда
		СтрокаТаблицы.НоменклатураОприходование = ПредопределенноеЗначение("Справочник.Номенклатура.ПустаяСсылка");
		СтрокаТаблицы.ХарактеристикаОприходование = ПредопределенноеЗначение("Справочник.ХарактеристикиНоменклатуры.ПустаяСсылка");
		СтрокаТаблицы.ПодНазначение = Ложь;
		СтрокаТаблицы.УпаковкаОприходование = ПредопределенноеЗначение("Справочник.УпаковкиЕдиницыИзмерения.ПустаяСсылка");
		СтрокаТаблицы.КоличествоОприходование = 0;
	КонецЕсли;
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ДоступноОформлениеВозвратаТоваровПоставщику(ХозяйственнаяОперацияПоступления)
	
	ХозяйственнаяОперация = ЗакупкиСервер.ПолучитьХозяйственнуюОперациюВозвратаПоПоступлению(
		ХозяйственнаяОперацияПоступления);
	ВсеОперацииДокумента = Новый СписокЗначений();
	Документы.ВозвратТоваровПоставщику.ЗаполнитьСписокХозяйственныхОпераций(ВсеОперацииДокумента);
	Возврат ВсеОперацииДокумента.НайтиПоЗначению(ХозяйственнаяОперация) <> Неопределено;
	
КонецФункции

&НаСервереБезКонтекста
Функция ДоступноОформлениеОтгрузкиТоваровСХранения(ХозяйственнаяОперацияПоступления)
	
	ХозяйственнаяОперация = ЗакупкиСервер.ПолучитьХозяйственнуюОперациюВозвратаПоПоступлению(
		ХозяйственнаяОперацияПоступления);
	ВсеОперацииДокумента = Новый СписокЗначений();
	Документы.ОтгрузкаТоваровСХранения.ЗаполнитьСписокХозяйственныхОпераций(ВсеОперацииДокумента);
	Возврат ВсеОперацииДокумента.НайтиПоЗначению(ХозяйственнаяОперация) <> Неопределено;
	
КонецФункции

#КонецОбласти
