Процедура ТоварыСерияНачалоВыбора(Элемент, ДанныеВыбора, ВыборДобавлением, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	ОткрытьПодборСерий(Элемент.ТекстРедактирования);
	
КонецПроцедуры

&НаКлиенте
Процедура ТоварыУпаковкаПриИзменении(Элемент)
	
	СтрокаТаблицы = Элементы.Товары.ТекущиеДанные;
	СтруктураДействий = Новый Структура();
	СтруктураДействий.Вставить("ПересчитатьКоличествоУпаковок");
	
	ПакетнаяОбработкаТабличнойЧастиКлиент.ОбработатьСтрокуТЧ(СтрокаТаблицы, СтруктураДействий, КэшированныеЗначения);
	
	Если ЗначениеЗаполнено(СтрокаТаблицы.НоменклатураОприходование) Тогда
		
		ДанныеНекачественногоТовара = Новый Структура("НоменклатураИсходногоКачества, Номенклатура, Упаковка", 
			СтрокаТаблицы.Номенклатура, СтрокаТаблицы.НоменклатураОприходование, СтрокаТаблицы.Упаковка);
		
		СтруктураДействийСНекачественнымТоваром = Новый Структура;
		СтруктураДействийСНекачественнымТоваром.Вставить("ПроверитьЗаполнитьУпаковкуПоВладельцу", СтрокаТаблицы.Упаковка);
		СтруктураДействийСНекачественнымТоваром.Вставить("ЗаполнитьУпаковкуНекачественногоТовара", СтрокаТаблицы.Упаковка);
		
		ПакетнаяОбработкаТабличнойЧастиКлиент.ОбработатьСтрокуТЧ(
			ДанныеНекачественногоТовара,
			СтруктураДействийСНекачественнымТоваром,
			Неопределено);
		СтрокаТаблицы.УпаковкаОприходование = ДанныеНекачественногоТовара.Упаковка;
		
	КонецЕсли;
	
	ПересчитатьКоличествоОприходование(СтрокаТаблицы);
	
КонецПроцедуры

&НаКлиенте
Процедура ТоварыДействиеАвтоПодбор(Элемент, Текст, ДанныеВыбора, ПараметрыПолученияДанных, Ожидание, СтандартнаяОбработка)
	
	ТекущиеДанные = Элементы.Товары.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	СтандартнаяОбработка = Ложь;
	ПараметрыМетода = Новый Структура();
	ПараметрыМетода.Вставить("КонтролируемаяПартия", Объект.КонтролируемаяПартия);
	ПараметрыМетода.Вставить("Склад", ТекущиеДанные.Склад);
	ПараметрыМетода.Вставить("Дата", Объект.Дата);
	ДанныеВыбора = ДанныеВыбораДействия(ПараметрыМетода);
	
КонецПроцедуры

&НаКлиенте
Процедура ТоварыДействиеПриИзменении(Элемент)
	
	СтрокаТаблицы = Элементы.Товары.ТекущиеДанные;
	ПроверитьОчиститьРеквизитыОприходования(СтрокаТаблицы);
	
КонецПроцедуры

&НаКлиенте
Процедура ТоварыКоличествоУпаковокПриИзменении(Элемент)
	
	СтрокаТаблицы = Элементы.Товары.ТекущиеДанные;
	СтруктураДействий = Новый Структура();
	СтруктураДействий.Вставить("ПересчитатьКоличествоЕдиниц");
	
	ПакетнаяОбработкаТабличнойЧастиКлиент.ОбработатьСтрокуТЧ(СтрокаТаблицы, СтруктураДействий, КэшированныеЗначения);
	
	ПересчитатьКоличествоОприходование(СтрокаТаблицы);
	
КонецПроцедуры

&НаКлиенте
Процедура ТоварыСкладПриИзменении(Элемент)
	
	СтрокаТаблицы = Элементы.Товары.ТекущиеДанные;
	
	ПроверитьСериюРассчитатьСтатус = Новый Структура("Склад, ПараметрыУказанияСерий", СтрокаТаблицы.Склад, ПараметрыУказанияСерий);
	ЗаполнитьПризнакИспользованияПомещений = Новый Структура("Дата", Объект.Дата);
	ЗаполнитьПризнакАдресногоХранения = Новый Структура("Дата", Объект.Дата);
	
	СтруктураДействий = Новый Структура();
	СтруктураДействий.Вставить("ЗаполнитьПризнакИспользованияПомещений", ЗаполнитьПризнакИспользованияПомещений);
	СтруктураДействий.Вставить("ЗаполнитьПризнакАдресногоХранения", ЗаполнитьПризнакАдресногоХранения);
	СтруктураДействий.Вставить("ПроверитьСериюРассчитатьСтатус", ПроверитьСериюРассчитатьСтатус);
	ПакетнаяОбработкаТабличнойЧастиКлиент.ОбработатьСтрокуТЧ(СтрокаТаблицы, СтруктураДействий, КэшированныеЗначения);
	ОчиститьУпаковкуДляСтрокБезАдресногоХраненияВСтроке(СтрокаТаблицы);
	
	ПараметрыМетода = Новый Структура();
	ПараметрыМетода.Вставить("КонтролируемаяПартия", Объект.КонтролируемаяПартия);
	ПараметрыМетода.Вставить("Склад", СтрокаТаблицы.Склад);
	ПараметрыМетода.Вставить("Дата", Объект.Дата);
	ДанныеВыбора = ДанныеВыбораДействия(ПараметрыМетода);
	Если ДанныеВыбора.НайтиПоЗначению(СтрокаТаблицы.Действие) = Неопределено Тогда
		СтрокаТаблицы.Действие = ПредопределенноеЗначение("Перечисление.ДействияПоТоварамВАктеКонтроляКачества.ПустаяСсылка");
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ТоварыПомещениеПриИзменении(Элемент)
	
	СтрокаТаблицы = Элементы.Товары.ТекущиеДанные;
	
	ЗаполнитьПризнакАдресногоХранения = Новый Структура("Дата", Объект.Дата);
	
	СтруктураДействий = Новый Структура();
	СтруктураДействий.Вставить("ЗаполнитьПризнакАдресногоХранения", ЗаполнитьПризнакАдресногоХранения);
	ПакетнаяОбработкаТабличнойЧастиКлиент.ОбработатьСтрокуТЧ(СтрокаТаблицы, СтруктураДействий, КэшированныеЗначения);
	ОчиститьУпаковкуДляСтрокБезАдресногоХраненияВСтроке(СтрокаТаблицы);
	
КонецПроцедуры

&НаКлиенте
Процедура ТоварыУпаковкаОприходованиеПриИзменении(Элемент)
	
	СтрокаТаблицы = Элементы.Товары.ТекущиеДанные;
	ПересчитатьКоличествоОприходование(СтрокаТаблицы);
	
