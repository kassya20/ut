	Элемент = УсловноеОформление.Элементы.Добавить();

	ПолеЭлемента = Элемент.Поля.Элементы.Добавить();
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(Элементы.ТоварыПодНазначение.Имя);

	ОтборЭлемента = Элемент.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ОтборЭлемента.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("Объект.Товары.Назначение");
	ОтборЭлемента.ВидСравнения = ВидСравненияКомпоновкиДанных.НеЗаполнено;

	Элемент.Оформление.УстановитьЗначениеПараметра("Отображать", Ложь);
	
	
	// Все поля товара другого качества.
	
	Элемент = УсловноеОформление.Элементы.Добавить();
	
	ПолеЭлемента = Элемент.Поля.Элементы.Добавить();
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(Элементы.ТоварыНоменклатураОприходование.Имя);
	ПолеЭлемента = Элемент.Поля.Элементы.Добавить();
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(Элементы.ТоварыХарактеристикаОприходование.Имя);
	ПолеЭлемента = Элемент.Поля.Элементы.Добавить();
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(Элементы.ТоварыУпаковкаОприходование.Имя);
	ПолеЭлемента = Элемент.Поля.Элементы.Добавить();
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(Элементы.ТоварыНоменклатураОприходованиеКод.Имя);
	ПолеЭлемента = Элемент.Поля.Элементы.Добавить();
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(Элементы.ТоварыНоменклатураОприходованиеАртикул.Имя);
	ПолеЭлемента = Элемент.Поля.Элементы.Добавить();
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(Элементы.ТоварыПодНазначение.Имя);
	
	СписокИзменитьКачество = Новый СписокЗначений();
	СписокИзменитьКачество.Добавить(Перечисления.ДействияПоТоварамВАктеКонтроляКачества.ИзменитьКачество);
	СписокИзменитьКачество.Добавить(Перечисления.ДействияПоТоварамВАктеКонтроляКачества.ОформитьПорчу);
	ОтборЭлемента = Элемент.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ОтборЭлемента.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("Объект.Товары.Действие");
	ОтборЭлемента.ВидСравнения = ВидСравненияКомпоновкиДанных.НеВСписке;
	ОтборЭлемента.ПравоеЗначение = СписокИзменитьКачество;
	
	Элемент.Оформление.УстановитьЗначениеПараметра("Текст", НСтр("ru = '<только для изменения качества>'"));
	Элемент.Оформление.УстановитьЗначениеПараметра("ЦветТекста", ЦветаСтиля.ЦветТекстаОтмененнойСтрокиДокумента);
	Элемент.Оформление.УстановитьЗначениеПараметра("ТолькоПросмотр", Истина);
	Элемент.Оформление.УстановитьЗначениеПараметра("ОтметкаНезаполненного", Ложь);
	
	Для Каждого Действие Из Действия Цикл
		
		Элемент = УсловноеОформление.Элементы.Добавить();
		
		ПолеЭлемента = Элемент.Поля.Элементы.Добавить();
		ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(Элементы.ТоварыДействие.Имя);
		
		ОтборЭлемента = Элемент.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
		ОтборЭлемента.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("Объект.Товары.Действие");
		ОтборЭлемента.ВидСравнения = ВидСравненияКомпоновкиДанных.Равно;
		ОтборЭлемента.ПравоеЗначение = Действие.Значение;
		
		Элемент.Оформление.УстановитьЗначениеПараметра("Текст", Действие.Представление);
		
	КонецЦикла;
	
	
КонецПроцедуры

#КонецОбласти

#Область ОбслуживаниеКоманд

&НаКлиентеНаСервереБезКонтекста
Функция ПроверитьЗаполнитьСкладПараметрыДействия(СкладШапки)
	
	Если ЗначениеЗаполнено(СкладШапки) Тогда
		ПараметрыДействия = Новый Структура("СкладПоУмолчанию", СкладШапки);
	Иначе
		ПараметрыДействия = Новый Структура("СкладПоУмолчаниюИзТекущейСтроки");
	КонецЕсли;
	Возврат ПараметрыДействия;
	
КонецФункции

#Область РаботаСБуферомОбмена

&НаСервере
Процедура СкопироватьСтрокиНаСервере(ВыделенныеСтроки)
	
	РаботаСТабличнымиЧастями.СкопироватьСтрокиВБуферОбмена(Объект.Товары, ВыделенныеСтроки);
	
КонецПроцедуры

&НаСервере
Процедура ПолучитьСтрокиИзБуфераОбмена()
	
	ПараметрыОтбора = Новый Соответствие;
	ПараметрыОтбора.Вставить("Номенклатура.ТипНоменклатуры",
		НоменклатураКлиентСервер.ОтборПоТоваруМногооборотнойТаре(Ложь));
	
	Колонки =
		"Номенклатура,
		|Характеристика,
		|Назначение,
		|Серия,
		|Склад,
		|Помещение,
		|Ячейка,
		|Действие,
		|Упаковка,
		|КоличествоУпаковок,
		|РезультатПроверкиКачества,
		|НоменклатураОприходование,
		|УпаковкаОприходование,
		|КоличествоОприходование,
		|ПодНазначение,
		|ХарактеристикаОприходование";
	
	ТаблицаТоваров = РаботаСТабличнымиЧастями.СтрокиИзБуфераОбмена(ПараметрыОтбора, Колонки);
	
	Если Не ЗначениеЗаполнено(ТаблицаТоваров) Тогда
		Возврат;
	КонецЕсли;
	
	ОбрабатываемыеСтроки = Новый Массив();
	Для Каждого СтрокаТовара Из ТаблицаТоваров Цикл
		
		СтрокаТаблицы = Объект.Товары.Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаТаблицы, СтрокаТовара);
		Если ЗначениеЗаполнено(Объект.Помещение) Тогда
			СтрокаТаблицы.Помещение = Объект.Помещение;
		КонецЕсли;
		ПроверитьОчиститьРеквизитыОприходования(СтрокаТаблицы);
		ОбрабатываемыеСтроки.Добавить(СтрокаТаблицы);
		
	КонецЦикла;
	
	ЗаполнитьПризнакАртикул = Новый Структура("Номенклатура,НоменклатураОприходование",
		"Артикул",
		"АртикулОприходование");
	ЗаполнитьПризнакТипНоменклатуры = Новый Структура("Номенклатура,НоменклатураОприходование",
		"ТипНоменклатуры", 
		"ТипНоменклатурыОприходование");
	ЗаполнитьПризнакТипИзмеряемойВеличины = Новый Структура("Номенклатура,НоменклатураОприходование",
		"ТипИзмеряемойВеличины",
		"ТипИзмеряемойВеличиныОприходование");
	ЗаполнитьПризнакХарактеристикиИспользуются = Новый Структура("Номенклатура,НоменклатураОприходование",
		"ХарактеристикиИспользуются",
		"ХарактеристикиИспользуютсяОприходование");
	ЗаполнитьПризнакИспользованияПомещений = Новый Структура("Дата", Объект.Дата);
	ЗаполнитьПризнакАдресногоХранения = Новый Структура("Дата", Объект.Дата);
	ПроверитьЗаполнитьСклад = ПроверитьЗаполнитьСкладПараметрыДействия(Объект.Склад);
	НоменклатураПриИзмененииПереопределяемый = Новый Структура("ИмяФормы, ИмяТабличнойЧасти",
		ИмяФормы, "Товары");
	
	СтруктураДействий = Новый Структура();
	СтруктураДействий.Вставить("ЗаполнитьПризнакАртикул", ЗаполнитьПризнакАртикул);
	СтруктураДействий.Вставить("ЗаполнитьПризнакТипНоменклатуры", ЗаполнитьПризнакТипНоменклатуры);
	СтруктураДействий.Вставить("ЗаполнитьПризнакТипИзмеряемойВеличины", ЗаполнитьПризнакТипИзмеряемойВеличины);
	СтруктураДействий.Вставить("ЗаполнитьПризнакХарактеристикиИспользуются", ЗаполнитьПризнакХарактеристикиИспользуются);
	СтруктураДействий.Вставить("НоменклатураПриИзмененииПереопределяемый", НоменклатураПриИзмененииПереопределяемый);
	СтруктураДействий.Вставить("ПересчитатьКоличествоЕдиниц");
	СтруктураДействий.Вставить("ЗаполнитьПризнакИспользованияПомещений", ЗаполнитьПризнакИспользованияПомещений);
	СтруктураДействий.Вставить("ЗаполнитьПризнакАдресногоХранения", ЗаполнитьПризнакАдресногоХранения);
	СтруктураДействий.Вставить("ПроверитьЗаполнитьСклад", ПроверитьЗаполнитьСклад);
	КэшированныеЗначения = ПакетнаяОбработкаТабличнойЧастиКлиентСервер.ПолучитьСтруктуруКэшируемыеЗначения();
	ПакетнаяОбработкаТабличнойЧастиСервер.ОбработатьСтрокиТЧ(
		ОбрабатываемыеСтроки,
		СтруктураДействий,
		Объект.Товары,
		КэшированныеЗначения);
	
	ПустоеПомещение = Справочники.СкладскиеПомещения.ПустаяСсылка();
	ПустаяЯчейка = Справочники.СкладскиеЯчейки.ПустаяСсылка();
	Для Каждого СтрокаТаблицы Из ОбрабатываемыеСтроки Цикл
		
		Если Не СтрокаТаблицы.ИспользоватьСкладскиеПомещения Тогда
			СтрокаТаблицы.Помещение = ПустоеПомещение;
			СтрокаТаблицы.Ячейка = ПустаяЯчейка;
		КонецЕсли;
		
		Если Не СтрокаТаблицы.ИспользоватьАдресноеХранение Тогда
			СтрокаТаблицы.Ячейка = ПустаяЯчейка;
		КонецЕсли;
		
	КонецЦикла;
	
	НоменклатураСервер.ЗаполнитьСтатусыУказанияСерий(Объект, ПараметрыУказанияСерий, ОбрабатываемыеСтроки);
	
КонецПроцедуры

&НаСервере
Процедура УстановитьДоступностьКомандБуфераОбмена()
	
	МассивЭлементов = Новый Массив();
	МассивЭлементов.Добавить("ВставитьСтроки");
	МассивЭлементов.Добавить("ТоварыКонтекстноеМенюВставитьСтроки");
	
	ОбщегоНазначенияУТКлиентСервер.УстановитьСвойствоЭлементовФормы(Элементы, МассивЭлементов, "Доступность",
		РаботаСТабличнымиЧастями.ЕстьСтрокиВБуфереОбмена());
	
КонецПроцедуры

&НаКлиенте
Процедура УстановитьДоступностьКомандБуфераОбменаНаКлиенте()
	
	МассивЭлементов = Новый Массив();
	МассивЭлементов.Добавить("ВставитьСтроки");
	МассивЭлементов.Добавить("ТоварыКонтекстноеМенюВставитьСтроки");
	
	ОбщегоНазначенияУТКлиентСервер.УстановитьСвойствоЭлементовФормы(Элементы, МассивЭлементов, "Доступность", Истина);
	
КонецПроцедуры

#КонецОбласти

&НаКлиенте
Процедура РазбитьСтрокуЗавершение(НоваяСтрока, ДополнительныеПараметры) Экспорт 
	
	ТекущаяСтрока = Элементы.Товары.ТекущиеДанные;
	
	Если НоваяСтрока <> Неопределено Тогда
		
		СтруктураДействий = Новый Структура();
		СтруктураДействий.Вставить("ПересчитатьКоличествоЕдиниц");
		ПакетнаяОбработкаТабличнойЧастиКлиент.ОбработатьСтрокуТЧ(ТекущаяСтрока, СтруктураДействий, КэшированныеЗначения);
		ПакетнаяОбработкаТабличнойЧастиКлиент.ОбработатьСтрокуТЧ(НоваяСтрока, СтруктураДействий, КэшированныеЗначения);
		ПересчитатьКоличествоОприходование(ТекущаяСтрока);
		ПересчитатьКоличествоОприходование(НоваяСтрока);
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьРезультатПроверкиКачестваПослеВыбора(ВыбранноеЗначение, ДополнительныеПараметры) Экспорт
	
	Если ВыбранноеЗначение = Неопределено Тогда
		Возврат;
	КонецЕсли;
	ЗаполнитьРезультатПроверкиКачестваПослеВыбораСервер(ВыбранноеЗначение);
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьРезультатПроверкиКачестваПослеВыбораСервер(ВыбранноеЗначение)
	
	Для Каждого Идентификатор Из Элементы.Товары.ВыделенныеСтроки Цикл
		
		Объект.Товары.НайтиПоИдентификатору(Идентификатор).РезультатПроверкиКачества = ВыбранноеЗначение;
		
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ИнициализацияНастройкиЗаполненияПоОстаткам(СхемаИмя, Адрес, Настройки)
	
	Схема = Документы.АктКонтроляКачестваТоваров.ПолучитьМакет(СхемаИмя);
	Адрес = ПоместитьВоВременноеХранилище(Схема, УникальныйИдентификатор);
	Настройки.Инициализировать(Новый ИсточникДоступныхНастроекКомпоновкиДанных(Адрес));
	Настройки.ЗагрузитьНастройки(Схема.НастройкиПоУмолчанию);
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьПоОстаткамСервер(Знач КомпоновщикНастроек)
	
	СхемаИмя = "СхемаЗаполненияПоОстаткамПартий";
	Настройки = НастройкиЗаполненияПоОстаткамПартий;
	
	Объект.Товары.Очистить();
	Настройки.ЗагрузитьНастройки(КомпоновщикНастроек.ПолучитьНастройки());
	Настройки.ЗагрузитьПользовательскиеНастройки(КомпоновщикНастроек.ПользовательскиеНастройки);
	
	СхемаКомпоновкиДанных = Документы.АктКонтроляКачестваТоваров.ПолучитьМакет(СхемаИмя);
	НастройкиКомпоновки = Настройки.ПолучитьНастройки();
	НастройкиКомпоновки.ПараметрыДанных.Элементы.Найти("КонтролируемаяПартия").Значение = Объект.КонтролируемаяПартия;
	НастройкиКомпоновки.ПараметрыДанных.Элементы.Найти("Регистратор").Значение = Объект.Ссылка;
	КомпоновщикМакета = Новый КомпоновщикМакетаКомпоновкиДанных;
	МакетКомпоновки = КомпоновщикМакета.Выполнить(СхемаКомпоновкиДанных,
		НастройкиКомпоновки, , , Тип("ГенераторМакетаКомпоновкиДанныхДляКоллекцииЗначений"));
	ПроцессорКомпоновки = Новый ПроцессорКомпоновкиДанных;
	ПроцессорКомпоновки.Инициализировать(МакетКомпоновки);
	ПроцессорВывода = Новый ПроцессорВыводаРезультатаКомпоновкиДанныхВКоллекциюЗначений;
	Аналитики = ПроцессорВывода.Вывести(ПроцессорКомпоновки);
	КонтрольКачества.ДополнитьТаблицуАналитикКолонкамиОтключеннымиПоФО(Аналитики);
	Объект.Товары.Загрузить(КонтрольКачества.ОстаткиПоАналитикам(Аналитики, Ложь, Объект.Дата, Объект.Ссылка));
	НоменклатураСервер.ЗаполнитьСтатусыУказанияСерий(Объект, ПараметрыУказанияСерий);
	ОчиститьСкладПомещениеЕслиИхНесколько();
	ЗаполнитьСлужебныеРеквизитыПриЗаполненииТабличнойЧасти();
	УстановитьВидимостьСкладаИПомещения();
	
КонецПроцедуры

&НаКлиенте
Процедура НастройкаЗаполненияПоОстаткамЗавершение(РезультатЗакрытия, ДополнительныеПараметры) Экспорт

	Если ТипЗнч(РезультатЗакрытия) = Тип("КомпоновщикНастроекКомпоновкиДанных") Тогда
		ЗаполнитьПоОстаткамСервер(РезультатЗакрытия);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ОбработкаВыбораПодборНаСервере(ВыбранноеЗначение)
	
	ТаблицаТоваров = ПолучитьИзВременногоХранилища(ВыбранноеЗначение.АдресТоваровВХранилище);
	
	ОбрабатываемыеСтроки = Новый Массив();
	Для каждого СтрокаТовара Из ТаблицаТоваров Цикл
		
		СтрокаТаблицы = Объект.Товары.Добавить();
		ОбрабатываемыеСтроки.Добавить(СтрокаТаблицы);
		ЗаполнитьЗначенияСвойств(СтрокаТаблицы, СтрокаТовара,
			"Номенклатура,Характеристика,Упаковка,КоличествоУпаковок,Серия");
		
	КонецЦикла;
	
	ЗаполнитьПризнакАртикул = Новый Структура("Номенклатура", "Артикул");
	ЗаполнитьПризнакТипНоменклатуры = Новый Структура("Номенклатура", "ТипНоменклатуры");
	ЗаполнитьПризнакТипИзмеряемойВеличины = Новый Структура("Номенклатура", "ТипИзмеряемойВеличины");
	ЗаполнитьПризнакХарактеристикиИспользуются = Новый Структура("Номенклатура", "ХарактеристикиИспользуются");
	ЗаполнитьПризнакИспользованияПомещений = Новый Структура("Дата", Объект.Дата);
	ЗаполнитьПризнакАдресногоХранения = Новый Структура("Дата", Объект.Дата);
	ПроверитьЗаполнитьСклад = ПроверитьЗаполнитьСкладПараметрыДействия(Объект.Склад);
	НоменклатураПриИзмененииПереопределяемый = Новый Структура("ИмяФормы, ИмяТабличнойЧасти",
		ИмяФормы, "Товары");
	
	СтруктураДействий = Новый Структура();
	СтруктураДействий.Вставить("ЗаполнитьПризнакАртикул", ЗаполнитьПризнакАртикул);
	СтруктураДействий.Вставить("ЗаполнитьПризнакТипНоменклатуры", ЗаполнитьПризнакТипНоменклатуры);
	СтруктураДействий.Вставить("ЗаполнитьПризнакТипИзмеряемойВеличины", ЗаполнитьПризнакТипИзмеряемойВеличины);
	СтруктураДействий.Вставить("ЗаполнитьПризнакХарактеристикиИспользуются", ЗаполнитьПризнакХарактеристикиИспользуются);
	СтруктураДействий.Вставить("НоменклатураПриИзмененииПереопределяемый", НоменклатураПриИзмененииПереопределяемый);
	СтруктураДействий.Вставить("ПересчитатьКоличествоЕдиниц");
	СтруктураДействий.Вставить("ПроверитьЗаполнитьСклад", ПроверитьЗаполнитьСклад);
	СтруктураДействий.Вставить("ЗаполнитьПомещениеВСтрокеТЧ", Объект.Помещение);
	СтруктураДействий.Вставить("ЗаполнитьПризнакИспользованияПомещений", ЗаполнитьПризнакИспользованияПомещений);
	СтруктураДействий.Вставить("ЗаполнитьПризнакАдресногоХранения", ЗаполнитьПризнакАдресногоХранения);
	
	КэшированныеЗначения = ПакетнаяОбработкаТабличнойЧастиКлиентСервер.ПолучитьСтруктуруКэшируемыеЗначения();
	ПакетнаяОбработкаТабличнойЧастиСервер.ОбработатьСтрокиТЧ(
		ОбрабатываемыеСтроки,
		СтруктураДействий,
		Объект.Товары,
		КэшированныеЗначения);
		
	НоменклатураСервер.ЗаполнитьСтатусыУказанияСерий(Объект, ПараметрыУказанияСерий, ОбрабатываемыеСтроки);
	
КонецПроцедуры

&НаКлиенте
Процедура ТоварыПоискПоШтрихкодуЗавершение(ДанныхШтрихкода, ДополнительныеПараметры) Экспорт
	
	ОбработатьШтрихкоды(ДанныхШтрихкода);
	
КонецПроцедуры

&НаКлиенте
Процедура ЗагрузитьИзТСДЗавершение(Результат, Параметры) Экспорт
	
	Если Результат.Результат Тогда
		ОбработатьШтрихкоды(Результат.ТаблицаТоваров);
	Иначе
		МенеджерОборудованияУТКлиент.СообщитьОбОшибке(Результат);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработатьШтрихкоды(ДанныеШтрихкодов)
	
	ОчиститьСообщения();
	
	Если Не ШтрихкодированиеНоменклатурыКлиент.ШтрихкодыВалидны(ДанныеШтрихкодов) Тогда
		Возврат;
	КонецЕсли;
	
	ЗаполнитьПризнакАртикул = Новый Структура("Номенклатура", "Артикул");
	ЗаполнитьПризнакТипНоменклатуры = Новый Структура("Номенклатура", "ТипНоменклатуры");
	ЗаполнитьПризнакТипИзмеряемойВеличины = Новый Структура("Номенклатура", "ТипИзмеряемойВеличины");
	ЗаполнитьПризнакХарактеристикиИспользуются = Новый Структура("Номенклатура", "ХарактеристикиИспользуются");
	ЗаполнитьПризнакИспользованияПомещений = Новый Структура("Дата", Объект.Дата);
	ЗаполнитьПризнакАдресногоХранения = Новый Структура("Дата", Объект.Дата);
	НоменклатураПриИзмененииПереопределяемый = Новый Структура("ИмяФормы, ИмяТабличнойЧасти",
		ИмяФормы, "Товары");
	ПроверитьЗаполнитьСклад = ПроверитьЗаполнитьСкладПараметрыДействия(Объект.Склад);
	ПроверитьСериюРассчитатьСтатус = Новый Структура("Склад, ПараметрыУказанияСерий", Объект.Склад, ПараметрыУказанияСерий);
	
	СтруктураДействийСДобавленнымиСтроками = Новый Структура();
	СтруктураДействийСДобавленнымиСтроками.Вставить("ЗаполнитьПризнакАртикул", ЗаполнитьПризнакАртикул);
	СтруктураДействийСДобавленнымиСтроками.Вставить("ЗаполнитьПризнакТипНоменклатуры", ЗаполнитьПризнакТипНоменклатуры);
	СтруктураДействийСДобавленнымиСтроками.Вставить("ЗаполнитьПризнакТипИзмеряемойВеличины", ЗаполнитьПризнакТипИзмеряемойВеличины);
	СтруктураДействийСДобавленнымиСтроками.Вставить("ЗаполнитьПризнакХарактеристикиИспользуются", ЗаполнитьПризнакХарактеристикиИспользуются);
	СтруктураДействийСДобавленнымиСтроками.Вставить("НоменклатураПриИзмененииПереопределяемый", НоменклатураПриИзмененииПереопределяемый);
	СтруктураДействийСДобавленнымиСтроками.Вставить("ПересчитатьКоличествоЕдиниц");
	СтруктураДействийСДобавленнымиСтроками.Вставить("ПроверитьЗаполнитьСклад", ПроверитьЗаполнитьСклад);
	СтруктураДействийСДобавленнымиСтроками.Вставить("ЗаполнитьПомещениеВСтрокеТЧ", Объект.Помещение);
	СтруктураДействийСДобавленнымиСтроками.Вставить("ЗаполнитьПризнакИспользованияПомещений", ЗаполнитьПризнакИспользованияПомещений);
	СтруктураДействийСДобавленнымиСтроками.Вставить("ЗаполнитьПризнакАдресногоХранения", ЗаполнитьПризнакАдресногоХранения);
	СтруктураДействийСДобавленнымиСтроками.Вставить("ПроверитьСериюРассчитатьСтатус", ПроверитьСериюРассчитатьСтатус);
	
	СтруктураДействийСИзмененнымиСтроками = Новый Структура();
	СтруктураДействийСИзмененнымиСтроками.Вставить("ПересчитатьКоличествоЕдиниц");
	
	ПараметрыОбработкиШтрихкодов = ШтрихкодированиеНоменклатурыКлиент.ПараметрыОбработкиШтрихкодов();
	
	ПараметрыОбработкиШтрихкодов.Штрихкоды = ДанныеШтрихкодов;
	ПараметрыОбработкиШтрихкодов.СтруктураДействийСДобавленнымиСтроками = СтруктураДействийСДобавленнымиСтроками;
	ПараметрыОбработкиШтрихкодов.СтруктураДействийСИзмененнымиСтроками = СтруктураДействийСИзмененнымиСтроками;
	ПараметрыОбработкиШтрихкодов.ПараметрыУказанияСерий = ПараметрыУказанияСерий;
	ПараметрыОбработкиШтрихкодов.ИзменятьКоличество = Истина;
	ПараметрыОбработкиШтрихкодов.ТолькоТовары = Истина;
	ПараметрыОбработкиШтрихкодов.ИмяТЧ = "Товары";
	
	ОбработатьШтрихкодыСервер(ПараметрыОбработкиШтрихкодов, КэшированныеЗначения);
	
	ШтрихкодированиеНоменклатурыКлиент.ОбработатьНеизвестныеШтрихкоды(ПараметрыОбработкиШтрихкодов,
		КэшированныеЗначения, ЭтотОбъект);
	
	Если ШтрихкодированиеНоменклатурыКлиент.НужноОткрытьФормуУказанияСерийПослеОбработкиШтрихкодов(ПараметрыОбработкиШтрихкодов) Тогда
		ТекущиеДанныеИдентификатор = ПараметрыОбработкиШтрихкодов.МассивСтрокССериями[0];
		
		ПодключитьОбработчикОжидания("ОткрытьПодборСерийПриСканированииШтрихкодаНоменклатуры", 0.1, Истина);
	КонецЕсли;
	
	Если ПараметрыОбработкиШтрихкодов.ТекущаяСтрока <> Неопределено Тогда
		Элементы.Товары.ТекущаяСтрока = ПараметрыОбработкиШтрихкодов.ТекущаяСтрока;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ОбработатьШтрихкодыСервер(СтруктураПараметровДействия, КэшированныеЗначения)
	
	ТипыНоменклатуры = НоменклатураСервер.ДопустимыеТипыНоменклатурыДляВыбора(
		Перечисления.ХозяйственныеОперации.КонтрольКачестваТоваров);
	
	ЕстьРаботы = ТипыНоменклатуры.Найти(Перечисления.ТипыНоменклатуры.Работа) <> Неопределено;
	ЕстьУслуги = ТипыНоменклатуры.Найти(Перечисления.ТипыНоменклатуры.Услуга) <> Неопределено;
	
	СтруктураПараметровДействия.ТолькоТовары = Не (ЕстьРаботы Или ЕстьУслуги);
	СтруктураПараметровДействия.ТолькоТоварыИРабота = ЕстьРаботы И Не ЕстьУслуги;
	СтруктураПараметровДействия.ТолькоТоварыИУслуги = ЕстьУслуги И Не ЕстьРаботы;
	
	ШтрихкодированиеНоменклатурыСервер.ОбработатьШтрихкоды(ЭтотОбъект,
		Объект, СтруктураПараметровДействия, КэшированныеЗначения);
	
КонецПроцедуры

// Параметры:
//  ЗначениеЗаполнения - ПеречислениеСсылка.ДействияПоТоварамВАктеКонтроляКачества - действие которым заполнять
// Возвращаемое значение:
//  Число - количество обработанных строк
&НаСервере
Функция ЗаполнитьКолонкуДействие(ЗначениеЗаполнения)
	
	ИдентификаторыСтрок = Элементы.Товары.ВыделенныеСтроки;
	Если Действия.НайтиПоЗначению(ЗначениеЗаполнения) = Неопределено Тогда
		Возврат 0;
	КонецЕсли;
	
	ПроверятьОрдерностьСклада = Ложь;
	Если ЗначениеЗаполнения = Перечисления.ДействияПоТоварамВАктеКонтроляКачества.ИзменитьКачество Тогда
		ПроверятьОрдерностьСклада = Истина;
		Склады = Объект.Товары.Выгрузить(, "Склад").ВыгрузитьКолонку("Склад");
		УстановитьПривилегированныйРежим(Истина);
		РеквизитыСкладов = ОбщегоНазначения.ЗначенияРеквизитовОбъектов(Склады,
			"ИспользоватьОрдернуюСхемуПриПоступлении,ДатаНачалаОрдернойСхемыПриПоступлении");
		УстановитьПривилегированныйРежим(Ложь);
		ДатаДокумента = ?(ЗначениеЗаполнено(Объект.Дата), Объект.Дата, НачалоДня(ТекущаяДатаСеанса()));
	КонецЕсли;
	
	Для Каждого ИдентификаторСтроки Из ИдентификаторыСтрок Цикл
		СтрокаТаблицы = Объект.Товары.НайтиПоИдентификатору(ИдентификаторСтроки);
		Если Не (ПроверятьОрдерностьСклада
					И ЗначениеЗаполнено(СтрокаТаблицы.Склад)
					И (Не РеквизитыСкладов[СтрокаТаблицы.Склад].ИспользоватьОрдернуюСхемуПриПоступлении
						Или РеквизитыСкладов[СтрокаТаблицы.Склад].ДатаНачалаОрдернойСхемыПриПоступлении > ДатаДокумента)) Тогда
			СтрокаТаблицы.Действие = ЗначениеЗаполнения;
			ПроверитьОчиститьРеквизитыОприходования(СтрокаТаблицы);
		КонецЕсли;
	КонецЦикла;
	
	Возврат ИдентификаторыСтрок.Количество();
	
КонецФункции

&НаКлиенте
Функция ЕстьСтрокиДляВыполненияКоманды(Поле)
	
	Если Объект.Товары.Количество() = 0 Тогда
		
		Текст = НСтр("ru='В документе не заполнен список ""Товары"". Поле %1 не может быть заполнено.'");
		ПоказатьПредупреждение(, СтрШаблон(Текст, Поле));
		Возврат Ложь;
		
	ИначеЕсли Элементы.Товары.ВыделенныеСтроки.Количество() = 0 Тогда
		
		Текст = НСтр("ru='В документе отсутствуют выделенные строки товаров. Выделите строки для заполнения поля %1.'");
		ПоказатьПредупреждение(, СтрШаблон(Текст, Поле));
		Возврат Ложь;
		
	КонецЕсли;
	Возврат Истина;
	
КонецФункции

&НаСервере
Процедура ОчиститьСкладПомещениеЕслиИхНесколько()
	
	Если ЗначениеЗаполнено(Объект.Склад) Или ЗначениеЗаполнено(Объект.Помещение) Тогда
		Для Каждого СтрокаТовары Из Объект.Товары Цикл
			Если ЗначениеЗаполнено(Объект.Склад) И СтрокаТовары.Склад <> Объект.Склад Тогда
				Объект.Склад = Справочники.Склады.ПустаяСсылка();
			КонецЕсли;
			Если ЗначениеЗаполнено(Объект.Помещение) И СтрокаТовары.Помещение <> Объект.Помещение Тогда
				Объект.Помещение = Справочники.СкладскиеПомещения.ПустаяСсылка();
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
КонецПроцедуры

