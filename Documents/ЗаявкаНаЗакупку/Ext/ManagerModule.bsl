#Область ЗаказыПоставщикам

// Формирует описание заказов поставщику к созданию на основании заявки на закупку.
//
// Параметры:
//   ЗаявкаНаЗакупку - ДокументСсылка.ЗаявкаНаЗакупку - ссылка на документ Заявка на закупку
//   НомераСтрок - Массив из Число - номера строк табличной части Товары.
//
// Возвращаемое значение:
//   Массив Из Структура - массив структур с описанием заказов к созданию
Функция ОписаниеЗаказовКСозданию(ЗаявкаНаЗакупку, НомераСтрок)
	
	#Область ТекстЗапроса
	ТекстЗапроса =
	"ВЫБРАТЬ
	|	Остатки.ЗаявкаНаЗакупку КАК ЗаявкаНаЗакупку,
	|	Остатки.НомерСтроки КАК НомерСтроки,
	|	Остатки.Количество КАК Количество
	|ПОМЕСТИТЬ Остатки
	|ИЗ
	|	&Остатки КАК Остатки
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Шапка.Ссылка                                     КАК Основание,
	|	ТабличнаяЧасть.Номенклатура                      КАК Номенклатура,
	|	ТабличнаяЧасть.Характеристика                    КАК Характеристика,
	|	ТабличнаяЧасть.Назначение                        КАК Назначение,
	|	Шапка.Организация                                КАК Организация,
	|	ТабличнаяЧасть.Склад                             КАК Склад,
	|	ТабличнаяЧасть.Подразделение                     КАК Подразделение,
	|	Шапка.Валюта                                     КАК Валюта,
	|	Шапка.ЦенаВключаетНДС                            КАК ЦенаВключаетНДС,
	|	ТабличнаяЧасть.Партнер                           КАК Партнер,
	|	ТабличнаяЧасть.Контрагент                        КАК Контрагент,
	|	ТабличнаяЧасть.Соглашение                        КАК Соглашение,
	|	ТабличнаяЧасть.Договор                           КАК Договор,
	|	ТабличнаяЧасть.НоменклатураПартнера              КАК НоменклатураПартнера,
	|	ТабличнаяЧасть.ВидЦеныПоставщика                 КАК ВидЦеныПоставщика,
	|	ТабличнаяЧасть.Цена                              КАК Цена,
	|	ТабличнаяЧасть.СтавкаНДС                         КАК СтавкаНДС,
	|	ТабличнаяЧасть.НомерСтроки                       КАК НомерСтроки,
	|	Остатки.Количество                               КАК Количество,
	|	ТабличнаяЧасть.Упаковка                          КАК Упаковка,
	|	Шапка.Подразделение                              КАК ПодразделениеШапки,
	|	Шапка.Склад                                      КАК СкладШапки,
	|	ТабличнаяЧасть.Сумма                             КАК Сумма,
	|	ТабличнаяЧасть.СуммаНДС                          КАК СуммаНДС,
	|	ТабличнаяЧасть.СуммаСНДС                         КАК СуммаСНДС,
	|	ТабличнаяЧасть.КоличествоУпаковок                КАК КоличествоУпаковок,
	|	Остатки.Количество <> ТабличнаяЧасть.Количество  КАК ТребуетсяПересчет,
	|	
	|	// Договоры с порядком расчетов ""ПоДоговорамКонтрагентов"" устанавливают Н.Д. в заказе, не позволяют его изменить и используют его в качестве отбора по назначениям.
	|	// В остальных случаях Н.Д. в заказе не используется, либо может быть очищено для выбора любого назначения.
	|	ВЫБОР КОГДА ЕСТЬNULL(ДоговорыКонтрагентов.ПорядокРасчетов,
	|				ЗНАЧЕНИЕ(Перечисление.ПорядокРасчетов.ПустаяСсылка)) = ЗНАЧЕНИЕ(Перечисление.ПорядокРасчетов.ПоДоговорамКонтрагентов) ТОГДА
	|		ДоговорыКонтрагентов.НаправлениеДеятельности
	|	ИНАЧЕ
	|		ЗНАЧЕНИЕ(Справочник.НаправленияДеятельности.ПустаяСсылка)
	|	КОНЕЦ                                            КАК НаправлениеДеятельности,
	|	
	|	&ИспользоватьУчетПрочихДоходовРасходов И ТабличнаяЧасть.Номенклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Услуга)
	|                                                    КАК СписатьНаРасходы
	|ИЗ
	|	Документ.ЗаявкаНаЗакупку.Товары КАК ТабличнаяЧасть
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ЗаявкаНаЗакупку КАК Шапка
	|		ПО ТабличнаяЧасть.Ссылка = Шапка.Ссылка
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Остатки КАК Остатки
	|		ПО ТабличнаяЧасть.Ссылка = Остатки.ЗаявкаНаЗакупку
	|			И ТабличнаяЧасть.НомерСтроки = Остатки.НомерСтроки
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ДоговорыКонтрагентов КАК ДоговорыКонтрагентов
	|		ПО ТабличнаяЧасть.Договор = ДоговорыКонтрагентов.Ссылка
	|ГДЕ
	|	ТабличнаяЧасть.Ссылка = &ЗаявкаНаЗакупку
	|	И ТабличнаяЧасть.НомерСтроки В(&НомераСтрок)";
	#КонецОбласти

	ПоляШапки = Новый Массив;
	ПоляШапки.Добавить("Основание");
	ПоляШапки.Добавить("Организация");
	ПоляШапки.Добавить("СкладШапки");
	ПоляШапки.Добавить("ПодразделениеШапки");
	ПоляШапки.Добавить("Валюта");
	ПоляШапки.Добавить("ЦенаВключаетНДС");
	ПоляШапки.Добавить("Партнер");
	ПоляШапки.Добавить("Контрагент");
	ПоляШапки.Добавить("Соглашение");
	ПоляШапки.Добавить("Договор");
	ПоляШапки.Добавить("НаправлениеДеятельности");
	
	ИсключаемыеКолонкиТаблицы = Новый Массив;
	ИсключаемыеКолонкиТаблицы.Добавить("НомерСтроки");
	ИсключаемыеКолонкиТаблицы.Добавить("ТребуетсяПересчет");
	ОбщегоНазначенияКлиентСервер.ДополнитьМассив(ИсключаемыеКолонкиТаблицы, ПоляШапки);
	
	Запрос = Новый Запрос;
	Запрос.Текст = ТекстЗапроса + "
	|УПОРЯДОЧИТЬ ПО
	|	" + СтрСоединить(ПоляШапки, ",
	|	") + ",
	|	НомерСтроки"; // Для получение минимальной строки, попавшей в заказ.
	
	Запрос.УстановитьПараметр("Остатки", ТаблицаОстатковЗаявокПострочно(ЗаявкаНаЗакупку));
	Запрос.УстановитьПараметр("ЗаявкаНаЗакупку", ЗаявкаНаЗакупку);
	Запрос.УстановитьПараметр("НомераСтрок", НомераСтрок);
	Запрос.УстановитьПараметр("ИспользоватьУчетПрочихДоходовРасходов", ПолучитьФункциональнуюОпцию("ИспользоватьУчетПрочихДоходовРасходов"));
	
	ИсходныеДанные = Запрос.Выполнить().Выгрузить();
	КэшируемыеЗначения = ПакетнаяОбработкаТабличнойЧастиКлиентСервер.ПолучитьСтруктуруКэшируемыеЗначения();
	
	СтруктураПоиска = Новый Структура;
	СтруктураПоиска.Вставить("ТребуетсяПересчет", Истина);
	СтруктураПоиска.Вставить("ЦенаВключаетНДС", Ложь);
	
	ЗначенияЦенаВключаетНДС = Новый Массив;
	ЗначенияЦенаВключаетНДС.Добавить(Ложь);
	ЗначенияЦенаВключаетНДС.Добавить(Истина);
	
	Для Каждого ЦенаВключаетНДС Из ЗначенияЦенаВключаетНДС Цикл
		
		СтруктураПоиска.ЦенаВключаетНДС = ЦенаВключаетНДС;
		НайденныеСтроки = ИсходныеДанные.НайтиСтроки(СтруктураПоиска);
		
		Действия = Новый Структура;
		Действия.Вставить("ПересчитатьКоличествоУпаковок", ПакетнаяОбработкаТабличнойЧастиКлиентСервер.СтруктураПересчетаКоличестваУпаковок());
		ОбщегоНазначенияКлиентСервер.ДополнитьСтруктуру(Действия, ЗаявкаНаЗакупкуКлиентСервер.ДействияПересчетаСуммы(ЦенаВключаетНДС), Истина);
		
		ПакетнаяОбработкаТабличнойЧастиСервер.ОбработатьСтрокиТЧ(
			НайденныеСтроки,
			Действия,
			ИсходныеДанные,
			КэшируемыеЗначения);
		
	КонецЦикла;
	
	Переименования = Новый Структура;
	Переименования.Вставить("СкладШапки", "Склад");
	Переименования.Вставить("ПодразделениеШапки", "Подразделение");
	
	ДанныеЗаказов = ОбеспечениеСервер.РазбитьТаблицуПоЗначениюКлюча(ИсходныеДанные, СтрСоединить(ПоляШапки, ", "));
	ОписаниеЗаказов = Новый Массив;
	Для Каждого КлючИТаблица Из ДанныеЗаказов Цикл
		
		ДанныеЗаказа = Новый Структура;
		Для Каждого ПолеКлюча Из КлючИТаблица.Ключ Цикл
			
			ИмяПоля = ПолеКлюча.Ключ;
			ИмяПоля = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(Переименования, ИмяПоля, ИмяПоля);
			
			ДанныеЗаказа.Вставить(ИмяПоля, ПолеКлюча.Значение);
			
		КонецЦикла;
		
		Товары = КлючИТаблица.Таблица;
		ДанныеЗаказа.Вставить("Товары", Товары);
		
		ОписаниеЗаказа = Новый Структура;
		ОписаниеЗаказа.Вставить("ДанныеЗаказа", ДанныеЗаказа);
		ОписаниеЗаказа.Вставить("МинимальныйНомерИсходнойСтроки", Товары[0].НомерСтроки);
		Товары.Колонки.Удалить("НомерСтроки");
		
		ОписаниеЗаказа.Вставить("ОбработаноИсходныхСтрок", Товары.Количество());
		
		ОписаниеЗаказов.Добавить(ОписаниеЗаказа);
		
	КонецЦикла;
	
	Возврат ОписаниеЗаказов;
	
КонецФункции

// Описание связи между заявками на закупку и заказами поставщикам.
// 
// Параметры:
// Отборы - См. НовыеОтборыПредставленийЗаявокНаЗакупку
//  ПомещатьВоВременнуюТаблицу - Булево - Определяет необходимость создания временной таблицы "ЗаказыЗаявок"
// 
// Возвращаемое значение:
//  Строка - Текст запроса
Функция ТекстЗапросаЗаказыЗаявок(Отборы, ПомещатьВоВременнуюТаблицу = Истина)
		
	ТекстЗапроса = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ДокументЗаказПоставщику.Ссылка КАК ЗаказПоставщику,
	|	ДокументЗаказПоставщику.ДокументОснование КАК ЗаявкаНаЗакупку
	|ПОМЕСТИТЬ ЗаказыЗаявок
	|ИЗ
	|	Документ.ЗаказПоставщику КАК ДокументЗаказПоставщику
	|ГДЕ
	|	&ДоступныеОтборы";
	
	Если Не ПомещатьВоВременнуюТаблицу Тогда
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса,
			"ПОМЕСТИТЬ ЗаказыЗаявок",
			"");
	КонецЕсли;
	
	ДоступныеОтборы = НовыеДоступныеОтборыЗаявокНаЗакупку();
	ДоступныеОтборы.ЗаявкаНаЗакупку = "ДокументЗаказПоставщику.ДокументОснование";
	ДоступныеОтборы.ЗаказПоставщику = "ДокументЗаказПоставщику.Ссылка";
	ДоступныеОтборы.ЗаказСозданПоЗаявке = "ДокументЗаказПоставщику.ДокументОснование ССЫЛКА Документ.ЗаявкаНаЗакупку";
	ДоступныеОтборы.ЗаказПроведен = "ДокументЗаказПоставщику.Проведен";
	ТекстЗапроса = УстановитьОтборыЗаявокНаЗакупкуВТекстеЗапроса(ТекстЗапроса, Отборы, ДоступныеОтборы);
	
	ДоступныеОтборы = НовыеДоступныеОтборыЗаявокНаЗакупку();
	ЗаявкаНаЗакупкуЛокализация.ДополнитьТекстЗапросаЗаказыЗаявок(ТекстЗапроса, ДоступныеОтборы);
	ТекстЗапроса = УстановитьОтборыЗаявокНаЗакупкуВТекстеЗапроса(ТекстЗапроса, Отборы, ДоступныеОтборы);
	
	Возврат ТекстЗапроса;
	
КонецФункции

// Потребность в закупке, сформированная заявками на закупку.
// 
// Возвращаемое значение:
//  Строка - Текст запроса
Функция ТекстЗапросаЗаявкиНаЗакупкуПриходДетально(Отборы, НазначениеИспользования = "", ОписаниеИсточника = Неопределено)
	
	ТекстЗапроса = 
	"ВЫБРАТЬ
	|	ЗаявкаНаЗакупкуТовары.Ссылка               КАК ЗаявкаНаЗакупку,
	|	ЗаявкаНаЗакупкуТовары.Номенклатура         КАК Номенклатура,
	|	ЗаявкаНаЗакупкуТовары.Характеристика       КАК Характеристика,
	|	ЗаявкаНаЗакупкуТовары.Назначение           КАК Назначение,
	|	ЗаявкаНаЗакупкуШапка.Организация           КАК Организация,
	|	ЗаявкаНаЗакупкуТовары.Склад                КАК Склад,
	|	ЗаявкаНаЗакупкуТовары.Подразделение        КАК Подразделение,
	|	ЗаявкаНаЗакупкуТовары.Партнер              КАК Партнер,
	|	ЗаявкаНаЗакупкуТовары.Соглашение           КАК Соглашение,
	|	ЗаявкаНаЗакупкуТовары.Контрагент           КАК Контрагент,
	|	ЗаявкаНаЗакупкуТовары.Договор              КАК Договор,
	|	ЗаявкаНаЗакупкуШапка.Валюта                КАК Валюта,
	|	ЗаявкаНаЗакупкуШапка.ЦенаВключаетНДС       КАК ЦенаВключаетНДС,
	|	ЗаявкаНаЗакупкуТовары.НоменклатураПартнера КАК НоменклатураПартнера,
	|	ЗаявкаНаЗакупкуТовары.ВидЦеныПоставщика    КАК ВидЦеныПоставщика,
	|	ЗаявкаНаЗакупкуТовары.Цена                 КАК Цена,
	|	ЗаявкаНаЗакупкуТовары.СтавкаНДС            КАК СтавкаНДС,
	|	ЗаявкаНаЗакупкуТовары.НомерСтроки          КАК НомерСтроки,
	|	ЗаявкаНаЗакупкуТовары.Количество           КАК Количество,
	|	ЗаявкаНаЗакупкуТовары.Упаковка             КАК Упаковка,
	|	ЗаявкаНаЗакупкуШапка.Подразделение         КАК ПодразделениеШапки,
	|	ЗаявкаНаЗакупкуШапка.Склад                 КАК СкладШапки,
	|	ВЫБОР
	|		КОГДА ЗаявкаНаЗакупкуТовары.ЖелаемаяДатаПоступления = ДАТАВРЕМЯ(1, 1, 1)
	|			ТОГДА ЗаявкаНаЗакупкуШапка.Дата
	|		ИНАЧЕ ЗаявкаНаЗакупкуТовары.ЖелаемаяДатаПоступления
	|	КОНЕЦ                                  КАК ДатаПоступления
	|ПОМЕСТИТЬ ЗаявкиНаЗакупкуПриходДетально
	|ИЗ
	|	Документ.ЗаявкаНаЗакупку.Товары КАК ЗаявкаНаЗакупкуТовары
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ЗаявкаНаЗакупку КАК ЗаявкаНаЗакупкуШапка
	|		ПО ЗаявкаНаЗакупкуТовары.Ссылка = ЗаявкаНаЗакупкуШапка.Ссылка
	|			И (&СвязьСТаблицейОтборов)
	|ГДЕ
	|	НЕ ЗаявкаНаЗакупкуТовары.Отменено
	|	И &ДоступныеОтборы";
	
	ДоступныеОтборы = НовыеДоступныеОтборыЗаявокНаЗакупку();
	ДоступныеОтборы.ЗаявкаНаЗакупку = "ЗаявкаНаЗакупкуТовары.Ссылка";
	ДоступныеОтборы.ЗаявкаПроведена = "ЗаявкаНаЗакупкуШапка.Проведен";
	ТекстЗапроса = УстановитьОтборыЗаявокНаЗакупкуВТекстеЗапроса(ТекстЗапроса, Отборы, ДоступныеОтборы);
	
	ТекстСвязиСТаблицейОтборов = "";
	Если НазначениеИспользования = "ОстаткиЗаявокНаЗакупкуПоПланам" Тогда
		
		ИмяТаблицыОтбора = ОписаниеИсточника; // Имя временной таблицей с жестким ключом.
		ТекстСвязиСТаблицейОтборов = СтрЗаменить(
		"ВНУТРЕННЕЕ СОЕДИНЕНИЕ ИмяТаблицыОтбора КАК ИмяТаблицыОтбора
		|		ПО ЗаявкаНаЗакупкуТовары.Номенклатура      = ИмяТаблицыОтбора.Номенклатура
		|			И ЗаявкаНаЗакупкуТовары.Характеристика = ИмяТаблицыОтбора.Характеристика
		|			И ЗаявкаНаЗакупкуТовары.Склад          = ИмяТаблицыОтбора.Склад
		|			И ЗаявкаНаЗакупкуТовары.Назначение     = ИмяТаблицыОтбора.Назначение
		|			И ЗаявкаНаЗакупкуТовары.Подразделение  = ИмяТаблицыОтбора.Подразделение
		|			И ИмяТаблицыОтбора.Партнер В (ЗаявкаНаЗакупкуТовары.Партнер,
		|			                                   ЗНАЧЕНИЕ(Справочник.Партнеры.ПустаяСсылка)) 
		|			И ИмяТаблицыОтбора.Соглашение В (ЗаявкаНаЗакупкуТовары.Соглашение,
		|			                                      ЗНАЧЕНИЕ(Справочник.СоглашенияСПоставщиками.ПустаяСсылка))",
		"ИмяТаблицыОтбора",
		ИмяТаблицыОтбора);
		
		// Пустой в плане -- > Нет отбора
		// Заполненный в плане --> 
		
	ИначеЕсли НазначениеИспользования = "ПоОбъекту" Тогда
		
		// Заменяем получение данных "по ссылке" на передачу данных через параметры:
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "Документ.ЗаявкаНаЗакупку.Товары", "&Товары");
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "ЗаявкаНаЗакупкуШапка.", "&");
		
		// Удаляем лишние связи, оставляя только таблицу товаров:
		СхемаЗапроса = Новый СхемаЗапроса;
		СхемаЗапроса.УстановитьТекстЗапроса(ТекстЗапроса);
		ЗапросПакета = СхемыЗапросов.ЗапросПакетаЗапросов(СхемаЗапроса);
		
		Для Каждого ОператорВыбора Из ЗапросПакета.Операторы Цикл
			
			Для ОбратныйИндекс = -ОператорВыбора.Источники.Количество() + 1 По 0 Цикл
				
				Индекс = -ОбратныйИндекс;
				ОписаниеИсточника = ОператорВыбора.Источники.Получить(Индекс);
				
				Если ТипЗнч(ОписаниеИсточника) <> Тип("ИсточникСхемыЗапроса")
					Или ОписаниеИсточника.Источник.ИмяТаблицы  <> "&Товары" Тогда
					ОператорВыбора.Источники.Удалить(Индекс);
				КонецЕсли;
				
			КонецЦикла;
			
		КонецЦикла;
		
		ТекстЗапроса = СхемаЗапроса.ПолучитьТекстЗапроса();
		
	ИначеЕсли НазначениеИспользования <> "" Тогда
		
		ТекстОшибки = НСтр("ru = 'Недопустимое значение ""%1"" для параметра %2 в методе %3'");
		
		ТекстОшибки = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
			ТекстОшибки,
			НазначениеИспользования,
			"НазначениеИспользования",
			"Документ.ЗаявкаНаЗакупку.ТекстЗапросаЗаявкиНаЗакупкуПриходДетально");
		
		ВызватьИсключение ТекстОшибки;
		
	КонецЕсли;
	
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "И (&СвязьСТаблицейОтборов)", ТекстСвязиСТаблицейОтборов);
	
	Возврат ТекстЗапроса;
	
КонецФункции

// Обеспечение потребности в закупке (заказы поставщикам, "закрывающие" заявки на закупку).
// 
// Возвращаемое значение:
//  Строка - Текст запроса
Функция ТекстЗапросаЗаявкиНаЗакупкуРасходДетально()
	
	ТекстЗапроса = 
	"ВЫБРАТЬ
	|	ЗаказыЗаявок.ЗаявкаНаЗакупку                                    КАК ЗаявкаНаЗакупку,
	|	ЗаказыПоставщикам.Номенклатура                                  КАК Номенклатура,
	|	ЗаказыПоставщикам.Характеристика                                КАК Характеристика,
	|	ЕСТЬNULL(ЗаказПоставщикуТовары.Назначение,
	|		ЗНАЧЕНИЕ(Справочник.Назначения.ПустаяСсылка))               КАК Назначение,
	|	ЗаказПоставщикуШапка.Организация                                КАК Организация,
	|	ЗаказыПоставщикам.Склад                                         КАК Склад,
	|	ЕСТЬNULL(ЗаказПоставщикуТовары.Подразделение,
	|		ЗНАЧЕНИЕ(Справочник.СтруктураПредприятия.ПустаяСсылка))     КАК Подразделение,
	|	ЗаказПоставщикуШапка.Партнер                                    КАК Партнер,
	|	ЗаказПоставщикуШапка.Соглашение                                 КАК Соглашение,
	|	ЗаказПоставщикуШапка.Контрагент                                 КАК Контрагент,
	|	ЗаказПоставщикуШапка.Договор                                    КАК Договор,
	|	ЗаказПоставщикуШапка.Валюта                                     КАК Валюта,
	|	ЗаказПоставщикуШапка.ЦенаВключаетНДС                            КАК ЦенаВключаетНДС,
	|	ЕСТЬNULL(ЗаказПоставщикуТовары.НоменклатураПартнера,
	|		ЗНАЧЕНИЕ(Справочник.НоменклатураКонтрагентов.ПустаяСсылка)) КАК НоменклатураПартнера,
	|	ЕСТЬNULL(ЗаказПоставщикуТовары.ВидЦеныПоставщика,
	|		ЗНАЧЕНИЕ(Справочник.ВидыЦенПоставщиков.ПустаяСсылка))       КАК ВидЦеныПоставщика,
	|	ЕСТЬNULL(ЗаказПоставщикуТовары.Цена, 0)                         КАК Цена,
	|	ЕСТЬNULL(ЗаказПоставщикуТовары.СтавкаНДС,
	|		ЗНАЧЕНИЕ(Справочник.СтавкиНДС.ПустаяСсылка))                КАК СтавкаНДС,
	|	ВЫБОР
	|		КОГДА ЗаказыПоставщикам.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход)
	|			ТОГДА ЗаказыПоставщикам.КОформлению
	|		ИНАЧЕ 0
	|	КОНЕЦ                                                           КАК Поступило,
	|	ВЫБОР
	|		КОГДА ЗаказыПоставщикам.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход)
	|			ТОГДА ЗаказыПоставщикам.Заказано
	|		ИНАЧЕ 0
	|	КОНЕЦ                                                           КАК Заказано,
	|	АВТОНОМЕРЗАПИСИ()                                               КАК НомерЗаписи
	|ПОМЕСТИТЬ ЗаявкиНаЗакупкуРасходДетально
	|ИЗ
	|	РегистрНакопления.ЗаказыПоставщикам КАК ЗаказыПоставщикам
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ЗаказыЗаявок КАК ЗаказыЗаявок
	|		ПО ЗаказыПоставщикам.ЗаказПоставщику = ЗаказыЗаявок.ЗаказПоставщику
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ЗаказПоставщику.Товары КАК ЗаказПоставщикуТовары
	|		ПО ЗаказыПоставщикам.ЗаказПоставщику   = ЗаказПоставщикуТовары.Ссылка
	|			И ЗаказыПоставщикам.Номенклатура   = ЗаказПоставщикуТовары.Номенклатура
	|			И ЗаказыПоставщикам.Характеристика = ЗаказПоставщикуТовары.Характеристика
	|			И ЗаказыПоставщикам.КодСтроки      = ЗаказПоставщикуТовары.КодСтроки
	|			И ЗаказыПоставщикам.Склад          = ЗаказПоставщикуТовары.Склад
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ЗаказПоставщику КАК ЗаказПоставщикуШапка
	|		ПО ЗаказыПоставщикам.ЗаказПоставщику = ЗаказПоставщикуШапка.Ссылка";
	
	Возврат ТекстЗапроса;
	
КонецФункции

// Правила распределения заказов по заявкам на закупку.
// 
// Возвращаемое значение:
//  Строка - Текст запроса
Функция ТекстЗапросаЗаявкиНаЗакупкуДанныеРасчетаПострочногоОстатка()
	
	ТекстЗапроса = 
	"ВЫБРАТЬ
	|	ЗаявкиНаЗакупкуПриходДетально.ЗаявкаНаЗакупку КАК ЗаявкаНаЗакупку,
	|	ЗаявкиНаЗакупкуПриходДетально.НомерСтроки КАК НомерСтроки,
	|	ЗаявкиНаЗакупкуРасходДетально.НомерЗаписи КАК НомерЗаписиРасхода,
	|	ЗаявкиНаЗакупкуПриходДетально.Партнер <> ЗНАЧЕНИЕ(Справочник.Партнеры.ПустаяСсылка) КАК ПартнерЗаполнен,
	|	ЗаявкиНаЗакупкуПриходДетально.Партнер <> ЗНАЧЕНИЕ(Справочник.Партнеры.ПустаяСсылка)
	|		И ЗаявкиНаЗакупкуПриходДетально.Соглашение <> ЗНАЧЕНИЕ(Справочник.СоглашенияСПоставщиками.ПустаяСсылка) КАК СоглашениеЗаполнено,
	|	ЗаявкиНаЗакупкуПриходДетально.Контрагент = ЗаявкиНаЗакупкуРасходДетально.Контрагент
	|		И ЗаявкиНаЗакупкуПриходДетально.Договор = ЗаявкиНаЗакупкуРасходДетально.Договор
	|		И ЗаявкиНаЗакупкуПриходДетально.Валюта = ЗаявкиНаЗакупкуРасходДетально.Валюта
	|		И ЗаявкиНаЗакупкуПриходДетально.ЦенаВключаетНДС = ЗаявкиНаЗакупкуРасходДетально.ЦенаВключаетНДС
	|		И ЗаявкиНаЗакупкуПриходДетально.НоменклатураПартнера = ЗаявкиНаЗакупкуРасходДетально.НоменклатураПартнера
	|		И ЗаявкиНаЗакупкуПриходДетально.ВидЦеныПоставщика = ЗаявкиНаЗакупкуРасходДетально.ВидЦеныПоставщика
	|		И ЗаявкиНаЗакупкуПриходДетально.Цена = ЗаявкиНаЗакупкуРасходДетально.Цена
	|		И ЗаявкиНаЗакупкуПриходДетально.СтавкаНДС = ЗаявкиНаЗакупкуРасходДетально.СтавкаНДС КАК МягкийКлючСовпадает
	|ИЗ
	|	ЗаявкиНаЗакупкуПриходДетально КАК ЗаявкиНаЗакупкуПриходДетально
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ЗаявкиНаЗакупкуРасходДетально КАК ЗаявкиНаЗакупкуРасходДетально
	|		ПО ЗаявкиНаЗакупкуПриходДетально.ЗаявкаНаЗакупку = ЗаявкиНаЗакупкуРасходДетально.ЗаявкаНаЗакупку
	|			И ЗаявкиНаЗакупкуПриходДетально.Номенклатура = ЗаявкиНаЗакупкуРасходДетально.Номенклатура
	|			И ЗаявкиНаЗакупкуПриходДетально.Характеристика = ЗаявкиНаЗакупкуРасходДетально.Характеристика
	|			И ЗаявкиНаЗакупкуПриходДетально.Назначение = ЗаявкиНаЗакупкуРасходДетально.Назначение
	|			И ЗаявкиНаЗакупкуПриходДетально.Организация = ЗаявкиНаЗакупкуРасходДетально.Организация
	|			И ЗаявкиНаЗакупкуПриходДетально.Склад = ЗаявкиНаЗакупкуРасходДетально.Склад
	|			И ЗаявкиНаЗакупкуПриходДетально.Подразделение = ЗаявкиНаЗакупкуРасходДетально.Подразделение
	|			И (ЗаявкиНаЗакупкуПриходДетально.Партнер = ЗаявкиНаЗакупкуРасходДетально.Партнер
	|				ИЛИ ЗаявкиНаЗакупкуПриходДетально.Партнер = ЗНАЧЕНИЕ(Справочник.Партнеры.ПустаяСсылка))
	|			И (ЗаявкиНаЗакупкуПриходДетально.Соглашение = ЗаявкиНаЗакупкуРасходДетально.Соглашение
	|				ИЛИ ЗаявкиНаЗакупкуПриходДетально.Соглашение = ЗНАЧЕНИЕ(Справочник.СоглашенияСПоставщиками.ПустаяСсылка))
	|
	|УПОРЯДОЧИТЬ ПО
	|	ЗаявкаНаЗакупку,
	|	ПартнерЗаполнен УБЫВ,
	|	СоглашениеЗаполнено УБЫВ,
	|	МягкийКлючСовпадает УБЫВ,
	|	ЗаявкиНаЗакупкуПриходДетально.НомерСтроки
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЗаявкиНаЗакупкуПриходДетально.ЗаявкаНаЗакупку КАК ЗаявкаНаЗакупку,
	|	ЗаявкиНаЗакупкуПриходДетально.НомерСтроки КАК НомерСтроки,
	|	ЗаявкиНаЗакупкуПриходДетально.Количество КАК Количество
	|ИЗ
	|	ЗаявкиНаЗакупкуПриходДетально КАК ЗаявкиНаЗакупкуПриходДетально
	|
	|УПОРЯДОЧИТЬ ПО
	|	ЗаявкаНаЗакупку
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЗаявкиНаЗакупкуРасходДетально.НомерЗаписи КАК НомерЗаписи,
	|	ЗаявкиНаЗакупкуРасходДетально.ЗаявкаНаЗакупку КАК ЗаявкаНаЗакупку,
	|	ЗаявкиНаЗакупкуРасходДетально.Заказано КАК Количество
	|ИЗ
	|	ЗаявкиНаЗакупкуРасходДетально КАК ЗаявкиНаЗакупкуРасходДетально
	|
	|УПОРЯДОЧИТЬ ПО
	|	НомерЗаписи";
	
	Возврат ТекстЗапроса;
	
КонецФункции

// Формирует таблицу остатков заявок построчно.
//
// Параметры:
//   ЗаявкаНаЗакупку - ДокументСсылка.ЗаявкаНаЗакупку - Заявка на закупку
//
// Возвращаемое значение:
//   ТаблицаЗначений - ТаблицаЗначений:
//     * ЗаявкаНаЗакупку - ДокументСсылка.ЗаявкаНаЗакупку - По которой получен остаток.
//     * НомерСтроки - Число - Номер строки заявки на закупку.
//     * Количество - Число - остаток по строке.
Функция ТаблицаОстатковЗаявокПострочно(ЗаявкаНаЗакупку)
	
	ВозвращаемоеЗначение = Новый ТаблицаЗначений;
	ВозвращаемоеЗначение.Колонки.Добавить("ЗаявкаНаЗакупку", Новый ОписаниеТипов("ДокументСсылка.ЗаявкаНаЗакупку"));
	ВозвращаемоеЗначение.Колонки.Добавить("НомерСтроки", ОбщегоНазначения.ОписаниеТипаЧисло(15, 0));
	ВозвращаемоеЗначение.Колонки.Добавить("Количество", ОбщегоНазначенияУТ.ОписаниеТипаКоличественногоПоля());
	
	Для Каждого ОписаниеЗаявки Из ОстаткиЗаявокПострочно(ЗаявкаНаЗакупку) Цикл
		
		Для Каждого КлючИЗначение Из ОписаниеЗаявки.Значение Цикл
			
			СтрокаТаблицы = ВозвращаемоеЗначение.Добавить();
			СтрокаТаблицы.ЗаявкаНаЗакупку = ОписаниеЗаявки.Ключ;
			СтрокаТаблицы.НомерСтроки = КлючИЗначение.Ключ;
			СтрокаТаблицы.Количество = КлючИЗначение.Значение;
			
		КонецЦикла;
		
	КонецЦикла;
	
	Возврат ВозвращаемоеЗначение;
	
КонецФункции

// Возвращает остатки заявок построчно.
//
// Параметры:
//   ЗаявкаНаЗакупку - Массив из ДокументСсылка.ЗаявкаНаЗакупку, ДокументОбъект.ЗаявкаНаЗакупку, ДанныеФормыСтруктура - Заявки для расчета остатка
//
// Возвращаемое значение:
//   Соответствие из КлючИЗначение:
//      * Ключ - ДокументСсылка.ЗаявкаНаЗакупку
//      * Значение - Соответствие из КлючИЗначение:
//          ** Ключ - Число - Номер строки заявки на закупку.
//          ** Значение - Число - Количество-остаток по строке.
Функция ОстаткиЗаявокПострочно(ЗаявкаНаЗакупку)
	
	ЭтоОстаткиПоОбъекту = ТипЗнч(ЗаявкаНаЗакупку) = Тип("ДокументОбъект.ЗаявкаНаЗакупку")
		Или ТипЗнч(ЗаявкаНаЗакупку) = Тип("ДанныеФормыСтруктура");
		
	Отборы = НовыеОтборыПредставленийЗаявокНаЗакупку();
	УстановитьОтборПредставленийЗаявокНаЗакупку(Отборы.ЗаказПроведен, Истина);
	
	ТекстыЗапросов = Новый Массив;
	Если ЭтоОстаткиПоОбъекту Тогда
		УстановитьОтборПредставленийЗаявокНаЗакупку(Отборы.ЗаявкаНаЗакупку, ЗаявкаНаЗакупку.Ссылка);
		ТекстыЗапросов.Добавить(ТекстЗапросаЗаявкиНаЗакупкуПриходДетально(Отборы, "ПоОбъекту"));
	Иначе
		УстановитьОтборПредставленийЗаявокНаЗакупку(Отборы.ЗаявкаНаЗакупку, ЗаявкаНаЗакупку);
		ТекстыЗапросов.Добавить(ТекстЗапросаЗаявкиНаЗакупкуПриходДетально(Отборы));
	КонецЕсли;
	
	ТекстыЗапросов.Добавить(ТекстЗапросаЗаказыЗаявок(Отборы));
	ТекстыЗапросов.Добавить(ТекстЗапросаЗаявкиНаЗакупкуРасходДетально());
	ТекстыЗапросов.Добавить(ТекстЗапросаЗаявкиНаЗакупкуДанныеРасчетаПострочногоОстатка());
	
	ТекстЗапроса = СтрСоединить(ТекстыЗапросов, ОбщегоНазначения.РазделительПакетаЗапросов());
	Запрос = Новый Запрос(ТекстЗапроса);
	УстановитьОтборыЗаявокНаЗакупкуВПараметрыЗапроса(Запрос, Отборы);
	
	Если ЭтоОстаткиПоОбъекту Тогда
		
		Товары = ЗаявкаНаЗакупку.Товары.Выгрузить();
		Товары.Колонки.Добавить("Ссылка", Новый ОписаниеТипов("ДокументСсылка.ЗаявкаНаЗакупку"));
		Товары.ЗаполнитьЗначения(ЗаявкаНаЗакупку.Ссылка, "Ссылка");
		Запрос.УстановитьПараметр("Товары", Товары);
		
		// Все поля шапки заменены одноименными параметрами. Установим их значения:
		НайденныеПараметры = Новый Структура(
			СтрСоединить(
				ОбщегоНазначения.ВыгрузитьКолонку(
					Запрос.НайтиПараметры(),
					"Имя"),
				", "));
		ЗаполнитьЗначенияСвойств(НайденныеПараметры, ЗаявкаНаЗакупку);
		ОбщегоНазначенияКлиентСервер.ДополнитьСтруктуру(Запрос.Параметры, НайденныеПараметры, Ложь);
		
	КонецЕсли;
	
	РезультатПакета = Запрос.ВыполнитьПакет();
	Выборка = РезультатПакета[РезультатПакета.Количество() - 3].Выбрать();
	ВыборкаПрихода = РезультатПакета[РезультатПакета.Количество() - 2].Выбрать();
	ДанныеРасхода = РезультатПакета[РезультатПакета.Количество() - 1].Выгрузить();
	
	ТекущаяЗаявка = ПустаяСсылка();
	ОписаниеЗаявок = Новый Соответствие;
	ОписаниеЗаявки = Неопределено;
	Пока ВыборкаПрихода.Следующий() Цикл
		
		Если ТекущаяЗаявка <> ВыборкаПрихода.ЗаявкаНаЗакупку Тогда
			
			ТекущаяЗаявка = ВыборкаПрихода.ЗаявкаНаЗакупку;
			
			ОписаниеЗаявки = Новый Соответствие;
			ОписаниеЗаявок.Вставить(ТекущаяЗаявка, ОписаниеЗаявки);
			
		КонецЕсли;
		
		ОписаниеЗаявки.Вставить(ВыборкаПрихода.НомерСтроки, ВыборкаПрихода.Количество);
		
	КонецЦикла;
	
	СдвигИндексаОтНомераЗаписи = ?(ЗначениеЗаполнено(ДанныеРасхода),
		ДанныеРасхода[0].НомерЗаписи,
		0);
		
	ТекущаяЗаявка = ПустаяСсылка();
	Пока Выборка.Следующий() Цикл
		
		Если ТекущаяЗаявка <> Выборка.ЗаявкаНаЗакупку Тогда 
			ОписаниеЗаявки = ОписаниеЗаявок[Выборка.ЗаявкаНаЗакупку];
		КонецЕсли;
		
		Остаток = ОписаниеЗаявки[Выборка.НомерСтроки];
		Если Остаток = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		СтрокаРасхода = ДанныеРасхода.Получить(Выборка.НомерЗаписиРасхода - СдвигИндексаОтНомераЗаписи);
		Если СтрокаРасхода.Количество = 0 Тогда
			Продолжить;
		КонецЕсли;
		
		КСписанию = Мин(Остаток, СтрокаРасхода.Количество);
		СтрокаРасхода.Количество = СтрокаРасхода.Количество - КСписанию;
		Остаток = Остаток - КСписанию;
		
		Если Остаток = 0 Тогда
			ОписаниеЗаявки.Удалить(Выборка.НомерСтроки);
		Иначе
			ОписаниеЗаявки[Выборка.НомерСтроки] = Остаток;
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат ОписаниеЗаявок;
	
КонецФункции

// Свертка приходов и расходов.
Функция ТекстЗапросаЗаявкиНаЗакупкуОстаткиПоЖесткомуКлючу()
	
	ТекстЗапроса = 
	"ВЫБРАТЬ
	|	ОстаткиПоЖесткомуКлючу.ЗаявкаНаЗакупку              КАК ЗаявкаНаЗакупку,
	|	ОстаткиПоЖесткомуКлючу.Номенклатура                 КАК Номенклатура,
	|	ОстаткиПоЖесткомуКлючу.Характеристика               КАК Характеристика,
	|	ОстаткиПоЖесткомуКлючу.Назначение                   КАК Назначение,
	|	ОстаткиПоЖесткомуКлючу.Организация                  КАК Организация,
	|	ОстаткиПоЖесткомуКлючу.Склад                        КАК Склад,
	|	ОстаткиПоЖесткомуКлючу.Подразделение                КАК Подразделение,
	|	ОстаткиПоЖесткомуКлючу.Партнер                      КАК Партнер,
	|	ОстаткиПоЖесткомуКлючу.Соглашение                   КАК Соглашение,
	|	СУММА(ОстаткиПоЖесткомуКлючу.ВЗаявке)               КАК ВЗаявке,
	|	СУММА(ОстаткиПоЖесткомуКлючу.Заказано)              КАК Заказано,
	|	СУММА(ОстаткиПоЖесткомуКлючу.Количество)            КАК Количество,
	|	СУММА(ОстаткиПоЖесткомуКлючу.Поступило)             КАК Поступило,
	|	МАКСИМУМ(ОстаткиПоЖесткомуКлючу.УпаковкаВЗаявке)    КАК УпаковкаВЗаявке,
