	|	ОстаткиПоЖесткомуКлючу.УпаковкаВЗаявке    КАК УпаковкаВЗаявке,
	|	ОстаткиПоЖесткомуКлючу.ДатаПоступления    КАК ДатаПоступления,
	|	ОстаткиПоЖесткомуКлючу.ПодразделениеШапки КАК ПодразделениеШапки
	|ПОМЕСТИТЬ ЗаявкиНаЗакупкуОстаткиОбобщенно
	|ИЗ
	|	ЗаявкиНаЗакупкуОстаткиПоЖесткомуКлючу КАК ОстаткиПоЖесткомуКлючу
	|ГДЕ
	|	ОстаткиПоЖесткомуКлючу.Партнер <> ЗНАЧЕНИЕ(Справочник.Партнеры.ПустаяСсылка)
	|	И ОстаткиПоЖесткомуКлючу.Соглашение <> ЗНАЧЕНИЕ(Справочник.СоглашенияСПоставщиками.ПустаяСсылка)
	|	И (ОстаткиПоЖесткомуКлючу.Количество > 0
	|		ИЛИ &ИспользуетсяПоступление И ОстаткиПоЖесткомуКлючу.ВЗаявке - ОстаткиПоЖесткомуКлючу.Поступило > 0)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ОстаткиБезСоглашений.ЗаявкаНаЗакупку    КАК ЗаявкаНаЗакупку,
	|	ОстаткиБезСоглашений.Номенклатура       КАК Номенклатура,
	|	ОстаткиБезСоглашений.Характеристика     КАК Характеристика,
	|	ОстаткиБезСоглашений.Назначение         КАК Назначение,
	|	ОстаткиБезСоглашений.Организация        КАК Организация,
	|	ОстаткиБезСоглашений.Склад              КАК Склад,
	|	ОстаткиБезСоглашений.Подразделение      КАК Подразделение,
	|	ОстаткиБезСоглашений.Партнер            КАК Партнер,
	|	ОстаткиБезСоглашений.Соглашение         КАК Соглашение,
	|	ОстаткиБезСоглашений.ВЗаявке            КАК ВЗаявке,
	|	ОстаткиБезСоглашений.Заказано           КАК Заказано,
	|	ОстаткиБезСоглашений.Количество         КАК Количество,
	|	ОстаткиБезСоглашений.Поступило          КАК Поступило,
	|	ОстаткиБезСоглашений.УпаковкаВЗаявке    КАК УпаковкаВЗаявке,
	|	ОстаткиБезСоглашений.ДатаПоступления    КАК ДатаПоступления,
	|	ОстаткиБезСоглашений.ПодразделениеШапки КАК ПодразделениеШапки
	|ИЗ
	|	ЗаявкиНаЗакупкуОстаткиБезСоглашений КАК ОстаткиБезСоглашений
	|ГДЕ
	|	ОстаткиБезСоглашений.Партнер <> ЗНАЧЕНИЕ(Справочник.Партнеры.ПустаяСсылка)
	|	И (ОстаткиБезСоглашений.Количество > 0
	|		ИЛИ &ИспользуетсяПоступление И ОстаткиБезСоглашений.ВЗаявке - ОстаткиБезСоглашений.Поступило > 0)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ОстаткиБезПартнеров.ЗаявкаНаЗакупку    КАК ЗаявкаНаЗакупку,
	|	ОстаткиБезПартнеров.Номенклатура       КАК Номенклатура,
	|	ОстаткиБезПартнеров.Характеристика     КАК Характеристика,
	|	ОстаткиБезПартнеров.Назначение         КАК Назначение,
	|	ОстаткиБезПартнеров.Организация        КАК Организация,
	|	ОстаткиБезПартнеров.Склад              КАК Склад,
	|	ОстаткиБезПартнеров.Подразделение      КАК Подразделение,
	|	ОстаткиБезПартнеров.Партнер            КАК Партнер,
	|	ОстаткиБезПартнеров.Соглашение         КАК Соглашение,
	|	ОстаткиБезПартнеров.ВЗаявке            КАК ВЗаявке,
	|	ОстаткиБезПартнеров.Заказано           КАК Заказано,
	|	ОстаткиБезПартнеров.Количество         КАК Количество,
	|	ОстаткиБезПартнеров.Поступило          КАК Поступило,
	|	ОстаткиБезПартнеров.УпаковкаВЗаявке    КАК УпаковкаВЗаявке,
	|	ОстаткиБезПартнеров.ДатаПоступления    КАК ДатаПоступления,
	|	ОстаткиБезПартнеров.ПодразделениеШапки КАК ПодразделениеШапки
	|ИЗ
	|	ЗаявкиНаЗакупкуОстаткиБезПартнеров КАК ОстаткиБезПартнеров
	|ГДЕ
	|	ОстаткиБезПартнеров.Количество > 0
	|	И (ОстаткиБезПартнеров.Количество > 0
	|		ИЛИ &ИспользуетсяПоступление И ОстаткиБезПартнеров.ВЗаявке - ОстаткиБезПартнеров.Поступило > 0)";
	
	ИспользованиеПоступленияВЗапросе = Формат(ИспользуетсяПоступление, "БЛ=ЛОЖЬ; БИ=ИСТИНА");
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&ИспользуетсяПоступление", ИспользованиеПоступленияВЗапросе);
	
	ТекстЗапроса = СтрЗаменить(
		ТекстЗапроса, 
		"ПОМЕСТИТЬ ЗаявкиНаЗакупкуОстаткиОбобщенно",
		"ПОМЕСТИТЬ " + ИмяВременнойТаблицы);
		
	Возврат ТекстЗапроса;
	
КонецФункции

// Данные для вывода таблицы "КЗаказу" в отчете "СостояниеВыполненияДокументов"
// 
// Возвращаемое значение:
//  Строка - Текст запроса
Функция ТекстЗапросаТаблицаКЗаказу()
	
	ТекстЗапроса = 
	"ВЫБРАТЬ
	|	ЗаявкиНаЗакупкуОстаткиОбобщенно.ЗаявкаНаЗакупку               КАК Документ,
	|	ПРЕДСТАВЛЕНИЕ(ЗаявкиНаЗакупкуОстаткиОбобщенно.Номенклатура)   КАК НоменклатураПредставление,
	|	ПРЕДСТАВЛЕНИЕ(ЗаявкиНаЗакупкуОстаткиОбобщенно.Характеристика) КАК ХарактеристикаПредставление,
	|	ПРЕДСТАВЛЕНИЕ(ЗаявкиНаЗакупкуОстаткиОбобщенно.Назначение)     КАК НазначениеПредставление,
	|	ПРЕДСТАВЛЕНИЕ(ЗаявкиНаЗакупкуОстаткиОбобщенно.Склад)          КАК СкладПредставление,
	|	ПРЕДСТАВЛЕНИЕ(ЗаявкиНаЗакупкуОстаткиОбобщенно.Подразделение)  КАК ПодразделениеПредставление,
	|	ПРЕДСТАВЛЕНИЕ(ЗаявкиНаЗакупкуОстаткиОбобщенно.Партнер)        КАК ПартнерПредставление,
	|	ПРЕДСТАВЛЕНИЕ(ЗаявкиНаЗакупкуОстаткиОбобщенно.Соглашение)     КАК СоглашениеПредставление,
	|	ВЫБОР
	|		КОГДА ЗаявкиНаЗакупкуОстаткиОбобщенно.УпаковкаВЗаявке = ЗНАЧЕНИЕ(Справочник.УпаковкиЕдиницыИзмерения.ПустаяСсылка)
	|			ТОГДА ПРЕДСТАВЛЕНИЕ(ЗаявкиНаЗакупкуОстаткиОбобщенно.Номенклатура.ЕдиницаИзмерения)
	|		ИНАЧЕ ПРЕДСТАВЛЕНИЕ(ЗаявкиНаЗакупкуОстаткиОбобщенно.УпаковкаВЗаявке)
	|	КОНЕЦ КАК УпаковкаПредставление,
	|	ВЫБОР
	|		КОГДА ЗаявкиНаЗакупкуОстаткиОбобщенно.УпаковкаВЗаявке = ЗНАЧЕНИЕ(Справочник.УпаковкиЕдиницыИзмерения.ПустаяСсылка)
	|			ТОГДА ПРЕДСТАВЛЕНИЕ(ЗаявкиНаЗакупкуОстаткиОбобщенно.Номенклатура.ЕдиницаИзмерения)
	|		ИНАЧЕ ПРЕДСТАВЛЕНИЕ(ЗаявкиНаЗакупкуОстаткиОбобщенно.УпаковкаВЗаявке)
	|	КОНЕЦ КАК Упаковка,
	|	ЗаявкиНаЗакупкуОстаткиОбобщенно.ВЗаявке   / &ТекстЗапросаКоэффициентаУпаковки  КАК ВЗаявке,
	|	ЗаявкиНаЗакупкуОстаткиОбобщенно.Заказано  / &ТекстЗапросаКоэффициентаУпаковки  КАК Заказано,
	|	ЗаявкиНаЗакупкуОстаткиОбобщенно.Поступило / &ТекстЗапросаКоэффициентаУпаковки  КАК Поступило,
	|	ЗаявкиНаЗакупкуОстаткиОбобщенно.Количество / &ТекстЗапросаКоэффициентаУпаковки КАК КЗаказу,
	|
	|	ВЫБОР
	|		КОГДА ЗаявкиНаЗакупкуОстаткиОбобщенно.Заказано = 0
	|			ТОГДА 0
	|		КОГДА ЗаявкиНаЗакупкуОстаткиОбобщенно.Заказано < ЗаявкиНаЗакупкуОстаткиОбобщенно.ВЗаявке
	|			ТОГДА 1
	|		КОГДА ЗаявкиНаЗакупкуОстаткиОбобщенно.Поступило < ЗаявкиНаЗакупкуОстаткиОбобщенно.ВЗаявке
	|			ТОГДА 2
	|		ИНАЧЕ 3
	|	КОНЕЦ КАК ПриоритетВывода
	| 
	|
	|ИЗ
	|	ЗаявкиНаЗакупкуОстаткиОбобщенно КАК ЗаявкиНаЗакупкуОстаткиОбобщенно
	|
	|УПОРЯДОЧИТЬ ПО
	|	ПриоритетВывода,
	|	ЗаявкиНаЗакупкуОстаткиОбобщенно.Номенклатура,
	|	ЗаявкиНаЗакупкуОстаткиОбобщенно.Характеристика,
	|	ЗаявкиНаЗакупкуОстаткиОбобщенно.Назначение,
	|	ЗаявкиНаЗакупкуОстаткиОбобщенно.Склад,
	|	ЗаявкиНаЗакупкуОстаткиОбобщенно.Подразделение
	|ИТОГИ ПО
	|	Документ";
	
	ТекстЗапросаКоэффициентаУпаковки = СтрШаблон("ЕСТЬNULL(%1, 1)",
			Справочники.УпаковкиЕдиницыИзмерения.ТекстЗапросаКоэффициентаУпаковки(
				"ЗаявкиНаЗакупкуОстаткиОбобщенно.УпаковкаВЗаявке",
				"ЗаявкиНаЗакупкуОстаткиОбобщенно.Номенклатура"));
			
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса,
		"&ТекстЗапросаКоэффициентаУпаковки",
		ТекстЗапросаКоэффициентаУпаковки);
	
	Возврат ТекстЗапроса;
	
КонецФункции

#Область ОтборыПредставленийЗаявокНаЗакупку
// Аналог отборов построителя запроса для работы с временными таблицами, таблицами значений и возможностью подстановки текстов запросов вместо значений отборов.
// Для использования:
// 1. Инициализировать описание отборов для текущего запроса: НовыеОтборыПредставленийЗаявокНаЗакупку().
// 2. Установить необходимые отборы с помощью метода: "УстановитьОтборПредставленийЗаявокНаЗакупку()". Например:
//    УстановитьОтборПредставленийЗаявокНаЗакупку(НовыеОтборыПредставленийЗаявокНаЗакупку.ЗаявкаНаЗакупку, Документы.ЗаявкаНаЗакупку.НайтиПоНомеру("1"));
//    В результате, если текст запроса поддерживает отбор по заявке на закупку, то будет добавлено соответствующее условие.
// 3. Добавить в текст запроса ключевое слово "&ДоступныеОтборы" в секцию "ГДЕ". Например:
//    ТекстЗапроса = "Выбрать т.Ссылка Из т ГДЕ &ДоступныеОтборы"
// 4. Описать левые части отборов, доступные в тексте запроса с помощью метода: "НовыеДоступныеОтборыЗаявокНаЗакупку". Например:
//     НовыеДоступныеОтборыЗаявокНаЗакупку.ЗаявкаНаЗакупку = "т.Ссылка";
// 5. Изменить текст запроса с помощью вызова метода: "УстановитьОтборыЗаявокНаЗакупкуВТекстеЗапроса".
//     В примере, т.к. установлен отбор по заявке на закупку (п.2) и текст запроса его поддерживает (п.3. + п.4) будет получен текст:
//     "Выбрать т.Ссылка Из т ГДЕ т.ссылка = &Параметр"
// 6. Установить параметры запроса с помощью метода: "УстановитьОтборыЗаявокНаЗакупкуВПараметрыЗапроса".

// Конструктор для описания значений отборов в текущем запросе.
// 
// Возвращаемое значение:
//  Структура
Функция НовыеОтборыПредставленийЗаявокНаЗакупку()
	
	ШаблонОтбора = Новый Структура;
	ШаблонОтбора.Вставить("Использование", Ложь);
	ШаблонОтбора.Вставить("ЭтоТекстЗапроса", Ложь);
	ШаблонОтбора.Вставить("Значение", Неопределено);
	ШаблонОтбора.Вставить("ИдентификаторВЗапросе", "");
	
	ВозвращаемоеЗначение = Новый Структура(
		ИменаОтборовПредставленийЗаявокНаЗакупку());
	
	Для Каждого КлючИЗначение Из ВозвращаемоеЗначение Цикл
		
		ИмяОтбора = КлючИЗначение.Ключ;
		ЭлементОтбора = ОбщегоНазначения.СкопироватьРекурсивно(ШаблонОтбора);
		ЭлементОтбора.ИдентификаторВЗапросе = ИмяОтбора;
		
		ВозвращаемоеЗначение[ИмяОтбора] = ЭлементОтбора;
		
	КонецЦикла;
	
	Возврат ВозвращаемоеЗначение;
	
КонецФункции

// Конструктор для описания отборов, которые поддерживает текущий текст запроса.
// 
// Возвращаемое значение:
//  Структура
Функция НовыеДоступныеОтборыЗаявокНаЗакупку()
	
	ВозвращаемоеЗначение = Новый Структура(
		ИменаОтборовПредставленийЗаявокНаЗакупку());
	
	Для Каждого КлючИЗначение Из ВозвращаемоеЗначение Цикл
		
		ИмяОтбора = КлючИЗначение.Ключ;
		ВозвращаемоеЗначение[ИмяОтбора] = "";
		
	КонецЦикла;
	
	Возврат ВозвращаемоеЗначение;
	
КонецФункции

// Имена всех доступных отборов в представлениях заявок на закупку. 
// 
// Возвращаемое значение:
//  Строка - Имена отборов представлений заявок на закупку
Функция ИменаОтборовПредставленийЗаявокНаЗакупку()
	
	ВозвращаемоеЗначение = 
	"ЗаявкаНаЗакупку,
	|ЗаявкаПроведена,
	|
	|ЗаказПоставщику,
	|ЗаказПроведен,
	|ЗаказСозданПоЗаявке";
	
	Возврат ВозвращаемоеЗначение;
	
КонецФункции

// Добавляет описания отбора в запросе.
//
// Параметры:
//   ЭлементОтбора - Структура - Указывает на какое поле будет накладываться отбор в запросе:
//       Например, НовыеДоступныеОтборыЗаявокНаЗакупку().ЗаявкаНаЗакупку.
//       Имена доступных полей см в "ИменаОтборовПредставленийЗаявокНаЗакупку()". 
//   ЗначениеОтбора - Произвольный - Значение отбора, которое будет установлено в параметр запроса.
//   ЭтоТекстЗапроса - Булево - Если Истина, то вместо установки параметра запроса будет подставлен текст из значения.
Процедура УстановитьОтборПредставленийЗаявокНаЗакупку(ЭлементОтбора, ЗначениеОтбора, ЭтоТекстЗапроса = Ложь)

	ЭлементОтбора.Использование = Истина;
	ЭлементОтбора.ЭтоТекстЗапроса = ЭтоТекстЗапроса;
	Если ЭтоТекстЗапроса Тогда
		ЭлементОтбора.ИдентификаторВЗапросе = ЗначениеОтбора;
	Иначе
		ЭлементОтбора.Значение = ЗначениеОтбора;
	КонецЕсли;
	
КонецПроцедуры

// Устанавливает описанные отборы в качестве параметров запроса. 
// 
// Параметры:
//  Запрос - Запрос - Запрос в который необходимо установить параметры.
//  Отборы - Структура - см. НовыеОтборыПредставленийЗаявокНаЗакупку()
Процедура УстановитьОтборыЗаявокНаЗакупкуВПараметрыЗапроса(Запрос, Отборы)
	
	Для Каждого КлючИЗначение Из Отборы Цикл
		
		ЭлементОтбора = КлючИЗначение.Значение;
		
		Если Не ЭлементОтбора.Использование
			Или ЭлементОтбора.ЭтоТекстЗапроса Тогда
			Продолжить;
		КонецЕсли;
		
		Запрос.УстановитьПараметр(ЭлементОтбора.ИдентификаторВЗапросе, ЭлементОтбора.Значение);
		
	КонецЦикла;
	
КонецПроцедуры

// Устанавливает отборы в тексте запроса по описанным значениям.
// 
// Параметры:
//  ТекстЗапроса - Строка - с ключевым словом "&ДоступныеОтборы" в секции "ГДЕ".
//  Отборы - Структура - см. НовыеОтборыПредставленийЗаявокНаЗакупку()
//  ДоступныеОтборы - Структура - см. НовыеДоступныеОтборыЗаявокНаЗакупку()
// 
// Возвращаемое значение:
//  Строка - Установить отборы заявок на закупку в тексте запроса
Функция УстановитьОтборыЗаявокНаЗакупкуВТекстеЗапроса(Знач ТекстЗапроса, Отборы, ДоступныеОтборы)
	
	ТекстОтборов = Новый Массив;
	ТекстОтборов.Добавить("ИСТИНА");
	Для Каждого КлючИЗначение Из ДоступныеОтборы Цикл
		
		ЭлементОтбора = Отборы[КлючИЗначение.Ключ];
		Если Не ЭлементОтбора.Использование Тогда
			Продолжить;
		КонецЕсли;
		
		ЛеваяЧасть = КлючИЗначение.Значение;
		Если ПустаяСтрока(ЛеваяЧасть) Тогда
			Продолжить;
		КонецЕсли;
		
		ТипЗначения = ТипЗнч(ЭлементОтбора.Значение);
		Если ЭлементОтбора.ЭтоТекстЗапроса Тогда
			
			ШаблонУсловия = "%1 В (%2)";  //@query-part
			
		ИначеЕсли ТипЗначения = Тип("Массив") Тогда
			
			ШаблонУсловия = СтрШаблон("%1 В (&%2)");
			
		ИначеЕсли ТипЗначения = Тип("Булево") Тогда
			
			Если ЭлементОтбора.Значение Тогда
				ШаблонУсловия = "%1";  //@query-part
			Иначе
				ШаблонУсловия = "НЕ %1";  //@query-part
			КонецЕсли;
			
		Иначе
			
			ШаблонУсловия = "%1 = &%2"; //@query-part
			
		КонецЕсли;
		
		ТекстОтборов.Добавить(СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
			ШаблонУсловия,
			ЛеваяЧасть,
			ЭлементОтбора.ИдентификаторВЗапросе));
		
	КонецЦикла;
	
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&ДоступныеОтборы", СтрСоединить(ТекстОтборов, "
	|	И "));  //@query-part
	
	Возврат ТекстЗапроса;
	
КонецФункции

