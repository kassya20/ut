#Область СлужебныйПрограммныйИнтерфейс

// Содержит методы, описывающие взаимодействие заявок на закупку с заказами поставщикам
#Область ЗаказыПоставщикам

// Получает заявку на основании которой создан заказ поставщику.
// 
// Параметры:
//  ЗаказПоставщику - ДокументСсылка.ЗаказПоставщику, ДокументОбъект.ЗаказПоставщику, ДанныеФормыСтруктура - Заказ, Основание которого необходимо получить.
// 
// Возвращаемое значение:
//  ДокументСсылка.ЗаявкаНаЗакупку - Заявка-основание заказа поставщику
Функция ЗаявкаОснованиеЗаказаПоставщику(Знач ЗаказПоставщику) Экспорт
	
	ВозвращаемоеЗначение = ПустаяСсылка();
	
	Если ТипЗнч(ЗаказПоставщику) <> Тип("ДокументСсылка.ЗаказПоставщику") Тогда
		
		Если ЗначениеЗаполнено(ЗаказПоставщику.ДокументОснование)
			И ТипЗнч(ЗаказПоставщику.ДокументОснование) = Тип("ДокументСсылка.ЗаявкаНаЗакупку") Тогда
			
			// Для случаев, когда создан новый объект на основании заявки.
			Возврат ЗаказПоставщику.ДокументОснование;
		
		ИначеЕсли ЗначениеЗаполнено(ЗаказПоставщику.Ссылка) Тогда
			
			// Выполнение стандартной логики поиска по запросам коммерческих предложений.
			ЗаказПоставщику = ЗаказПоставщику.Ссылка;
			
		Иначе // Новый объект, созданный не на основании заявки.
			
			Возврат ВозвращаемоеЗначение;
			
		КонецЕсли;
		
	КонецЕсли;
	
	УстановитьПривилегированныйРежим(Истина);
	
	Отборы = НовыеОтборыПредставленийЗаявокНаЗакупку();
	УстановитьОтборПредставленийЗаявокНаЗакупку(Отборы.ЗаказПоставщику, ЗаказПоставщику);
	УстановитьОтборПредставленийЗаявокНаЗакупку(Отборы.ЗаказСозданПоЗаявке, Истина);
	
	Запрос = Новый Запрос;
	Запрос.Текст = ТекстЗапросаЗаказыЗаявок(Отборы, Ложь);
	УстановитьОтборыЗаявокНаЗакупкуВПараметрыЗапроса(Запрос, Отборы);
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда
		ВозвращаемоеЗначение = Выборка.ЗаявкаНаЗакупку;
	КонецЕсли;
	
	Возврат ВозвращаемоеЗначение;
	
КонецФункции

// Дополнить список значений с текстами запросов 
// для формирования таблицы "КЗаказу" отчета "СостояниеВыполненияДокументов".
// 
// Параметры:
//  ТекстыЗапросов - СписокЗначений из Строка - Дополняемый список текстов запросов
//  ИмяПараметраОтбораЗаявок - Строка - Имя параметра, в котором передается массив заявок на закупку в дополняемом запросе.
Процедура ДополнитьТекстЗапросаТаблицыКЗаказу(ТекстыЗапросов, ИмяПараметраОтбораЗаявок) Экспорт
	
	Отборы = НовыеОтборыПредставленийЗаявокНаЗакупку();
	УстановитьОтборПредставленийЗаявокНаЗакупку(Отборы.ЗаявкаНаЗакупку, "&" + ИмяПараметраОтбораЗаявок, Истина);
	УстановитьОтборПредставленийЗаявокНаЗакупку(Отборы.ЗаказПроведен, Истина);
	
	РазделительПакетаЗапросов = ОбщегоНазначения.РазделительПакетаЗапросов();
	
	ТекстЗапросаЗаказыЗаявок = ТекстЗапросаЗаказыЗаявок(Отборы) + РазделительПакетаЗапросов;
	ТекстЗапросаЗаявкиНаЗакупкуПриходДетально = ТекстЗапросаЗаявкиНаЗакупкуПриходДетально(Отборы) + РазделительПакетаЗапросов;
	ТекстЗапросаЗаявкиНаЗакупкуРасходДетально = ТекстЗапросаЗаявкиНаЗакупкуРасходДетально() + РазделительПакетаЗапросов;
	ТекстЗапросаЗаявкиНаЗакупкуОстаткиПоЖесткомуКлючу = ТекстЗапросаЗаявкиНаЗакупкуОстаткиПоЖесткомуКлючу() + РазделительПакетаЗапросов;
	ТекстЗапросаЗаявкиНаЗакупкуОстаткиБезСоглашений = ТекстЗапросаЗаявкиНаЗакупкуОстаткиБезСоглашений() + РазделительПакетаЗапросов;
	ТекстЗапросаЗаявкиНаЗакупкуОстаткиБезПартнеров = ТекстЗапросаЗаявкиНаЗакупкуОстаткиБезПартнеров() + РазделительПакетаЗапросов;
	ТекстЗапросаЗаявкиНаЗакупкуОстаткиОбобщенно = ТекстЗапросаЗаявкиНаЗакупкуОстаткиОбобщенно(
		"ЗаявкиНаЗакупкуОстаткиОбобщенно",
		Истина) + РазделительПакетаЗапросов;
	ТекстЗапросаТаблицаКЗаказу = ТекстЗапросаТаблицаКЗаказу() + РазделительПакетаЗапросов;
	
	ТекстыЗапросов.Добавить(ТекстЗапросаЗаказыЗаявок,                          "ЗаказыЗаявокНаЗакупку");
	ТекстыЗапросов.Добавить(ТекстЗапросаЗаявкиНаЗакупкуПриходДетально,         "ЗаявкиНаЗакупкуПриходДетально");
	ТекстыЗапросов.Добавить(ТекстЗапросаЗаявкиНаЗакупкуРасходДетально,         "ЗаявкиНаЗакупкуРасходДетально");
	ТекстыЗапросов.Добавить(ТекстЗапросаЗаявкиНаЗакупкуОстаткиПоЖесткомуКлючу, "ЗаявкиНаЗакупкуОстаткиПоЖесткомуКлючу");
	ТекстыЗапросов.Добавить(ТекстЗапросаЗаявкиНаЗакупкуОстаткиБезСоглашений,   "ЗаявкиНаЗакупкуОстаткиБезСоглашений");
	ТекстыЗапросов.Добавить(ТекстЗапросаЗаявкиНаЗакупкуОстаткиБезПартнеров,    "ЗаявкиНаЗакупкуОстаткиБезПартнеров");
	ТекстыЗапросов.Добавить(ТекстЗапросаЗаявкиНаЗакупкуОстаткиОбобщенно,       "ЗаявкиНаЗакупкуОстаткиОбобщенно");
	ТекстыЗапросов.Добавить(ТекстЗапросаТаблицаКЗаказу,                        "ТаблицаКЗаказу");
	
КонецПроцедуры

// Описывает заказ, который необходимо ввести по указанным строкам заявки на закупку.
// 
// Параметры:
//  ЗаявкаНаЗакупку - ДокументСсылка.ЗаявкаНаЗакупку - Основание для создаваемого заказа поставщику
//  НомераСтрок - Массив из Число - Номера строк заявки на закупку, по которым выполняется формирование заказа поставщику.
// 
// Возвращаемое значение:
//  Структура - Описание заказа к созданию:
// * ДанныеЗаказа - 
//   - Неопределено
//   - Структура:
//   ** Основание - ДокументСсылка.ЗаявкаНаЗакупку - По которой создается заказ.
//   ** Организация - СправочникСсылка.Организации
//   ** Склад - СправочникСсылка.Склады
//   ** Подразделение - СправочникСсылка.СтруктураПредприятия
//   ** Валюта - СправочникСсылка.Валюты
//   ** ЦенаВключаетНДС - Булево
//   ** Партнер - СправочникСсылка.Партнеры
//   ** Контрагент - СправочникСсылка.Контрагенты
//   ** Соглашение - СправочникСсылка.СоглашенияСПоставщиками
//   ** Договор - СправочникСсылка.ДоговорыКонтрагентов
//   ** Товары - ТаблицаЗначений:
//     *** Номенклатура - СправочникСсылка.Номенклатура
//     *** Характеристика - СправочникСсылка.ХарактеристикиНоменклатуры
//     *** Назначение - СправочникСсылка.Назначения
//     *** НоменклатураПартнера - СправочникСсылка.НоменклатураКонтрагентов
//     *** ВидЦеныПоставщика - СправочникСсылка.ВидыЦенПоставщиков
//     *** Цена -Число
//     *** СтавкаНДС - СправочникСсылка.СтавкиНДС
//     *** Количество - Число
//     *** КоличествоУпаковок - Число
//     *** Упаковка - СправочникСсылка.УпаковкиЕдиницыИзмерения
//     *** Склад - СправочникСсылка.Склады
//     *** Подразделение - СправочникСсылка.СтруктураПредприятия
//     *** Сумма - Число
//     *** СуммаНДС - Число
//     *** СуммаСНДС - Число
// * ОбработаноИсходныхСтрок - Число - Количество исходных строк заявки на закупку, которые будут заказаны в созданном заказе.
// * НеОбработаноИсходныхСтрок - Число - Количество исходных строк заявки на закупку, которые требуют создания заказа поставщику,
//    но не могут быть добавлены в заказ, т.к. имеют другие значения реквизитов, формирующих шапку заказа.
//
Функция ОписаниеЗаказаКСозданию(ЗаявкаНаЗакупку, НомераСтрок) Экспорт
	
	ОписаниеЗаказаКСозданию = Неопределено;
	МинимальныйНомерИсходнойСтроки = Неопределено;
	НеОбработаноСтрок = 0;
	Для Каждого ОписаниеЗаказа Из ОписаниеЗаказовКСозданию(ЗаявкаНаЗакупку, НомераСтрок) Цикл
		
		НеОбработаноСтрок = НеОбработаноСтрок + ОписаниеЗаказа.ОбработаноИсходныхСтрок;
		
		Если МинимальныйНомерИсходнойСтроки = Неопределено
			Или МинимальныйНомерИсходнойСтроки > ОписаниеЗаказа.МинимальныйНомерИсходнойСтроки Тогда
			МинимальныйНомерИсходнойСтроки = ОписаниеЗаказа.МинимальныйНомерИсходнойСтроки;
			ОписаниеЗаказаКСозданию = ОписаниеЗаказа;
		КонецЕсли;
		
	КонецЦикла;
	
	ДанныеЗаказа = Неопределено;
	ОбработаноИсходныхСтрок = 0;
	Если ОписаниеЗаказаКСозданию <> Неопределено Тогда
		ОбработаноИсходныхСтрок = ОписаниеЗаказаКСозданию.ОбработаноИсходныхСтрок;
		НеОбработаноСтрок = НеОбработаноСтрок - ОбработаноИсходныхСтрок;
		ДанныеЗаказа = ОписаниеЗаказаКСозданию.ДанныеЗаказа;
	КонецЕсли;
	
	ВозвращаемоеЗначение = Новый Структура;
	ВозвращаемоеЗначение.Вставить("ДанныеЗаказа", ДанныеЗаказа);
	ВозвращаемоеЗначение.Вставить("ОбработаноИсходныхСтрок", ОбработаноИсходныхСтрок);
	ВозвращаемоеЗначение.Вставить("НеОбработаноИсходныхСтрок", НеОбработаноСтрок);
	
	Возврат ВозвращаемоеЗначение;
	
КонецФункции

// Формирует текст запроса "остатка" по заявкам на закупку, которые обеспечивают планы закупок
// Параметры:
//  ИмяТаблицыПланов - Строка - Имя временной таблицы планов на закупку по которой выполняется поиск заявок на закупку.
//  ИмяТаблицыОстатков - Строка - Имя временной таблицы с "остатками" заявок на закупку, которая будет сформирована при выполнении возвращаемого текста запроса.
// Возвращаемое значение:
//  Строка - Текст запроса, формирующий временную таблицу с именем <ИмяТаблицыОстатков>.
Функция ТекстЗапросаОстаткиЗаявокНаЗакупкуПоПланам(ИмяТаблицыПланов, ИмяТаблицыОстатков) Экспорт
	
	НазначениеИспользования = "ОстаткиЗаявокНаЗакупкуПоПланам";
	ТекстыЗапросов = Новый Массив;
	
	// Поиск заявок выполняется с отбором по "жесткому ключу" и дате, чтобы максимально ограничить количество данных к расчету.
	// При этом дальнейший расчет остатка выполняется без учета даты, т.к. может быть ситуация когда:
	// - В месяце x-2 в заявке y1 штук
	// - В месяце x-1 в заявке y2 штук
	// - В месяце x заказе поставщику y3 штук.
	// В этом случае, если план по месяцу х-1, то остаток должен рассчитаться как y1 + y2 - y3
	// Примечание: в разрезе "жесткого ключа" используется максимальная дата в разрезе заявки.
	// Таблица сворачивается, т.к. в плане может быть несколько строк с одинаковым "жестким ключом".
	ТекстЗапросаЖесткийКлючПоПланамЗакупок = СтрЗаменить(
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ЗаявкаНаЗакупкуТовары.Ссылка         КАК ЗаявкаНаЗакупку,
	|	ЗаявкаНаЗакупкуТовары.Номенклатура   КАК Номенклатура,
	|	ЗаявкаНаЗакупкуТовары.Характеристика КАК Характеристика,
	|	ЗаявкаНаЗакупкуТовары.Склад          КАК Склад,
	|	ЗаявкаНаЗакупкуТовары.Назначение     КАК Назначение,
	|	ЗаявкаНаЗакупкуТовары.Подразделение  КАК Подразделение,
	|	ЗаявкаНаЗакупкуТовары.Партнер        КАК Партнер,
	|	ЗаявкаНаЗакупкуТовары.Соглашение     КАК Соглашение
	|ПОМЕСТИТЬ ОтборПоЖесткомуКлючу
	|ИЗ
	|	Документ.ЗаявкаНаЗакупку.Товары КАК ЗаявкаНаЗакупкуТовары
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ИмяТаблицыПланов КАК ИмяТаблицыПланов
	|		ПО (ЗаявкаНаЗакупкуТовары.ЖелаемаяДатаПоступления МЕЖДУ ИмяТаблицыПланов.ДатаПоступления И ИмяТаблицыПланов.ОкончаниеПериодаПоступления)
	|			И ЗаявкаНаЗакупкуТовары.Номенклатура = ИмяТаблицыПланов.Номенклатура
	|			И ЗаявкаНаЗакупкуТовары.Характеристика = ИмяТаблицыПланов.Характеристика
	|			И (НЕ &ПланированиеПоНазначениям
	|				ИЛИ ИмяТаблицыПланов.Назначение = ЗаявкаНаЗакупкуТовары.Назначение)
	|			И (ИмяТаблицыПланов.Склад В (ЗНАЧЕНИЕ(Справочник.Склады.ПустаяСсылка), ЗаявкаНаЗакупкуТовары.Склад))
	|			И (ИмяТаблицыПланов.ПартнерПлан В (ЗНАЧЕНИЕ(Справочник.Партнеры.ПустаяСсылка), ЗаявкаНаЗакупкуТовары.Партнер))
	|			И (ИмяТаблицыПланов.СоглашениеПлан = ЗНАЧЕНИЕ(Справочник.СоглашенияСПоставщиками.ПустаяСсылка)
	|				ИЛИ ИмяТаблицыПланов.Соглашение = ЗаявкаНаЗакупкуТовары.Соглашение)
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЗаявкаНаЗакупку КАК ЗаявкаНаЗакупку
	|		ПО ЗаявкаНаЗакупкуТовары.Ссылка = ЗаявкаНаЗакупку.Ссылка
	|ГДЕ
	|	ИмяТаблицыПланов.Подразделение В (ЗНАЧЕНИЕ(Справочник.СтруктураПредприятия.ПустаяСсылка), ЗаявкаНаЗакупку.Подразделение)
	|	И ЗаявкаНаЗакупку.Проведен
	|	И НЕ ЗаявкаНаЗакупкуТовары.Отменено",
	"ИмяТаблицыПланов",
	ИмяТаблицыПланов);
	
	ТекстыЗапросов.Добавить(ТекстЗапросаЖесткийКлючПоПланамЗакупок);
	
	Отборы = НовыеОтборыПредставленийЗаявокНаЗакупку();
	УстановитьОтборПредставленийЗаявокНаЗакупку(Отборы.ЗаявкаПроведена, Истина);
	ТекстыЗапросов.Добавить(ТекстЗапросаЗаявкиНаЗакупкуПриходДетально(
		Отборы,
		НазначениеИспользования,
		"ОтборПоЖесткомуКлючу")); // Основные отборы накладываются по входной таблице.
		
	Отборы = НовыеОтборыПредставленийЗаявокНаЗакупку();
	УстановитьОтборПредставленийЗаявокНаЗакупку(Отборы.ЗаявкаНаЗакупку,
		"ВЫБРАТЬ т.ЗаявкаНаЗакупку ИЗ ЗаявкиНаЗакупкуПриходДетально КАК т", // Работа с заявками, найденными по планам.
		Истина);
	УстановитьОтборПредставленийЗаявокНаЗакупку(Отборы.ЗаказПроведен, Истина);
	
	ТекстыЗапросов.Добавить(ТекстЗапросаЗаказыЗаявок(Отборы));
	ТекстыЗапросов.Добавить(ТекстЗапросаЗаявкиНаЗакупкуРасходДетально());
	ТекстыЗапросов.Добавить(ТекстЗапросаЗаявкиНаЗакупкуОстаткиПоЖесткомуКлючу());
	ТекстыЗапросов.Добавить(ТекстЗапросаЗаявкиНаЗакупкуОстаткиБезСоглашений());
	ТекстыЗапросов.Добавить(ТекстЗапросаЗаявкиНаЗакупкуОстаткиБезПартнеров());
	ТекстыЗапросов.Добавить(ТекстЗапросаЗаявкиНаЗакупкуОстаткиОбобщенно(ИмяТаблицыОстатков));
	
	ТекстЗапроса = СтрСоединить(
		ТекстыЗапросов,
		ОбщегоНазначения.РазделительПакетаЗапросов());
	
	Возврат ТекстЗапроса;
	
КонецФункции

// Формирует текст, который необходимо подставить в результирующий запрос схемы компоновки данных в качестве используемой таблицы,
// чтобы при расчете остатка с помощью "ТекстЗапросаОстаткиЗаявокНаЗакупкуПоПланам" сохранить корректные группировки, т.к.
// СКД оптимизирует запрос и ссылка на документ не попадает в группировки промежуточных ВТ.
// В результате максимальная дата вычисляется не в разрезе заявки, а в менее детальном разрезе.
// Добавляем использование поля для отключения этой оптимизации.
// 
// Параметры:
//   ИмяТаблицыОстатков - Строка - См. ТекстЗапросаОстаткиЗаявокНаЗакупкуПоПланам.ИмяТаблицыОстатков
//
// Возвращаемое значение:
//  Строка - Текст запроса
Функция ТекстИспользованияПромежуточныхПолейФормированияОстатка(ИмяТаблицыОстатков) Экспорт
	
	Возврат СтрЗаменить(
	"(ВЫБРАТЬ
	|СУММА(0) КАК НеиспользуемоеПоле
	|ИЗ
	|	ИмяТаблицыОстатков КАК ИмяТаблицыОстатков
	|ГДЕ
	|	ЛОЖЬ
	|	И ИмяТаблицыОстатков.ЗаявкаНаЗакупку = NULL)",
	"ИмяТаблицыОстатков",
	ИмяТаблицыОстатков);
	
КонецФункции

// Проверяет наличие незаказанных строк в заявке на закупку.
//
// Параметры:
//   Объект - ДокументОбъект.ЗаявкаНаЗакупку, ДанныеФормыСтруктура - объект заявки на закупку
//
// Возвращаемое значение:
//   Булево - признак наличия незаказанных строк
Функция ЕстьНезаказанныеСтроки(Объект) Экспорт
	
	ОстаткиПострочно = Неопределено;
	Если ЗначениеЗаполнено(Объект.Ссылка) И Объект.Проведен Тогда
		ОстаткиПострочно = ОстаткиЗаявокПострочно(Объект).Получить(Объект.Ссылка);
	КонецЕсли;
	
	Возврат ЗначениеЗаполнено(ОстаткиПострочно);
	
КонецФункции

// Отменяет незаказанные строки в заявке на закупку.
//
// Параметры:
//   Объект - ДокументОбъект.ЗаявкаНаЗакупку, ДанныеФормыСтруктура - объект заявки на закупку
//
// Возвращаемое значение:
//   Структура:
//    * СтрокиСИзменениемКоличества - Массив Из ДокументТабличнаяЧастьСтрока.ЗаявкаНаЗакупку.Товары - Строки товаров, в которых изменилось количество.
//    * ОтмененныеСтроки - Массив Из ДокументТабличнаяЧастьСтрока.ЗаявкаНаЗакупку.Товары - Строки товаров, в которых установлен флаг "отменено"
//    * ИзмененныеСтроки - Массив Из ДокументТабличнаяЧастьСтрока.ЗаявкаНаЗакупку.Товары - Содержит "СтрокиСИзменениемКоличества" и "ОтмененныеСтроки".
Функция ОтменитьНезаказанныеСтроки(Объект) Экспорт
	
	ОстаткиПострочно = Неопределено;
	Если ЗначениеЗаполнено(Объект.Ссылка) Тогда
		ОстаткиПострочно = ОстаткиЗаявокПострочно(Объект).Получить(Объект.Ссылка);
	КонецЕсли;
	
	ВозвращаемоеЗначение = Новый Структура;
	ВозвращаемоеЗначение.Вставить("СтрокиСИзменениемКоличества", Новый Массив);
	ВозвращаемоеЗначение.Вставить("ОтмененныеСтроки", Новый Массив);
	ВозвращаемоеЗначение.Вставить("ИзмененныеСтроки", Новый Массив);
	
	Для ОбратныйИндекс = -Объект.Товары.Количество() + 1 По 0 Цикл
		
		СтрокаТоваров = Объект.Товары[-ОбратныйИндекс];
		
		Если ОстаткиПострочно = Неопределено Тогда
			
			// Ссылка не создана, значит заказов нет и остаток = текущему значению.
			Остаток = СтрокаТоваров.Количество;
			
		Иначе
			
			Остаток = ОстаткиПострочно.Получить(СтрокаТоваров.НомерСтроки);
			Если Остаток = Неопределено Тогда
				// По строке оформлены заказы, действия не требуются.
				Продолжить;
			КонецЕсли;
			
		КонецЕсли;
		
		Если Остаток = СтрокаТоваров.Количество Тогда
			
			СтрокаТоваров.Отменено = Истина;
			
			ВозвращаемоеЗначение.ОтмененныеСтроки.Добавить(СтрокаТоваров);
			ВозвращаемоеЗначение.ИзмененныеСтроки.Добавить(СтрокаТоваров);
			
		Иначе // Разбивка строки на две:
			
			СтрокаТоваров.Количество = СтрокаТоваров.Количество - Остаток;
			
			ВозвращаемоеЗначение.СтрокиСИзменениемКоличества.Добавить(СтрокаТоваров);
			ВозвращаемоеЗначение.ИзмененныеСтроки.Добавить(СтрокаТоваров);
			
			ОтмененнаяСтрока = Объект.Товары.Вставить(СтрокаТоваров.НомерСтроки);
			ЗаполнитьЗначенияСвойств(ОтмененнаяСтрока, СтрокаТоваров);
			ОтмененнаяСтрока.Отменено = Истина;
			ОтмененнаяСтрока.Количество = Остаток;
			
			ВозвращаемоеЗначение.СтрокиСИзменениемКоличества.Добавить(ОтмененнаяСтрока);
			ВозвращаемоеЗначение.ОтмененныеСтроки.Добавить(ОтмененнаяСтрока);
			ВозвращаемоеЗначение.ИзмененныеСтроки.Добавить(ОтмененнаяСтрока);
			
		КонецЕсли;
		
	КонецЦикла;
	
	Действия = Новый Структура;
	Действия.Вставить("ПересчитатьКоличествоУпаковок", ПакетнаяОбработкаТабличнойЧастиКлиентСервер.СтруктураПересчетаКоличестваУпаковок());
	ОбщегоНазначенияКлиентСервер.ДополнитьСтруктуру(Действия, ЗаявкаНаЗакупкуКлиентСервер.ДействияПересчетаСуммы(Объект.ЦенаВключаетНДС), Истина);
	
	ПакетнаяОбработкаТабличнойЧастиСервер.ОбработатьСтрокиТЧ(
		ВозвращаемоеЗначение.СтрокиСИзменениемКоличества,
		Действия,
		Объект.Товары,
		ПакетнаяОбработкаТабличнойЧастиКлиентСервер.ПолучитьСтруктуруКэшируемыеЗначения());
		
	Возврат ВозвращаемоеЗначение;
	
КонецФункции

