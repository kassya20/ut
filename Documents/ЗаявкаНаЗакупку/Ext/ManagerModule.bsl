#Область ЗаполнитьНалогообложениеНДСЗакупки

// Возвращает параметры заполнения реквизита "НалогообложениеНДС" для строки табличной части.
// ВАЖНО! В строку должен быть добавлен реквизит "ХозяйственнаяОперация".
// 
// Параметры:
//  СтрокаТоваров - ДанныеФормыЭлементКоллекции, СтрокаТаблицыЗначений - Строка табличной части 
//  ПараметрыДействия - Структура:
//   * Дата - Дата - Дата документа.
// 
// Возвращаемое значение:
// см. УчетНДСУПКлиентСервер.ПараметрыЗаполненияНалогообложенияНДСЗакупки
Функция ПараметрыНалогообложенияНДС(СтрокаТоваров, ПараметрыДействия) Экспорт
	
	ПараметрыЗаполнения = УчетНДСУПКлиентСервер.ПараметрыЗаполненияНалогообложенияНДСЗакупки();
	
	ПараметрыЗаполнения.Период     = ПараметрыДействия.Дата;
	ПараметрыЗаполнения.Контрагент = СтрокаТоваров.Контрагент;
	ПараметрыЗаполнения.Договор    = СтрокаТоваров.Договор;
	 
	ХозОперацииЗакупкаУПоставщика = ЗакупкиСервер.ХозяйственныеОперацииПоОсновной(
		Перечисления.ХозяйственныеОперации.ЗакупкаУПоставщика);
	
	ХозОперацииЗакупкаВСтранахЕАЭС = ЗакупкиСервер.ХозяйственныеОперацииПоОсновной(
		Перечисления.ХозяйственныеОперации.ЗакупкаВСтранахЕАЭС);
	
	ХозОперацииЗакупкаПоИмпорту = ЗакупкиСервер.ХозяйственныеОперацииПоОсновной(
		Перечисления.ХозяйственныеОперации.ЗакупкаПоИмпорту);
		
	Если ХозОперацииЗакупкаУПоставщика.Найти(СтрокаТоваров.ХозяйственнаяОперация) <> Неопределено Тогда
		
		ПараметрыЗаполнения.ПриобретениеТоваров = Истина;
		ПараметрыЗаполнения.ПриобретениеРабот = Истина;
		ПараметрыЗаполнения.ПриобретениеНаСтатьи = Истина;
		
	ИначеЕсли ХозОперацииЗакупкаВСтранахЕАЭС.Найти(СтрокаТоваров.ХозяйственнаяОперация) <> Неопределено Тогда
		
		ПараметрыЗаполнения.ВвозТоваровИзТаможенногоСоюза = Истина;
		
	ИначеЕсли ХозОперацииЗакупкаПоИмпорту.Найти(СтрокаТоваров.ХозяйственнаяОперация) <> Неопределено Тогда
		
		ПараметрыЗаполнения.ИмпортТоваров = Истина;
		
	ИначеЕсли  СтрокаТоваров.ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.ПриемНаХранениеСПравомПродажи Тогда
		
		ПараметрыЗаполнения.ПриемНаХранение = Истина;
		
	ИначеЕсли СтрокаТоваров.ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.ПриемНаКомиссию Тогда
		
		ПараметрыЗаполнения.ПриемНаКомиссию = Истина;
		
	КонецЕсли;
	
	Возврат ПараметрыЗаполнения;
	
КонецФункции

