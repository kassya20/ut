#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ОбработчикиСобытий

Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)
	
	Если ОбменДанными.Загрузка Тогда
		Возврат;
	КонецЕсли;
	
	ОбновлениеИнформационнойБазы.ПроверитьОбъектОбработан(ЭтотОбъект);
	
	Если Не Согласован
		И Перечисления.СтатусыЗаявокНаЗакупку.Согласована(Статус)
		И ПраваПользователяПовтИсп.СогласованиеЗаявокНаЗакупку() // Автор может закрыть заявку, но это не будет согласованием.
		И РежимЗаписи = РежимЗаписиДокумента.Проведение Тогда
		// Проверки заполнения пройдены, устанавливается статус "согласования".
		Согласован = Истина;
	КонецЕсли;
	
	ЗаполнитьПустыеЖелаемыеДатыПоступления();
	
	РаботаСПротоколомДокумента.ПередЗаписью(ЭтотОбъект, Отказ, РежимЗаписи, РежимПроведения);
	ПроведениеДокументов.ПередЗаписьюДокумента(ЭтотОбъект, РежимЗаписи, РежимПроведения);
	
	НоменклатураСервер.ОкруглитьКоличествоШтучныхТоваров(ЭтотОбъект, РежимЗаписи);
	
	СуммаДокумента = Товары.Выгрузить(Новый Структура("Отменено", Ложь)).Итог("СуммаСНДС");
	
	Если Не ЗначениеЗаполнено(Номер) Тогда
		УстановитьНовыйНомер();
	КонецЕсли;
		
	Если Не ЗначениеЗаполнено(Автор) И ЭтоНовый() Тогда
		Автор = Пользователи.ТекущийПользователь();
	КонецЕсли;
	
КонецПроцедуры

Процедура ПриЗаписи(Отказ)
	
	Если ОбменДанными.Загрузка Тогда
		Возврат;
	КонецЕсли;
	
	ПроведениеДокументов.ПриЗаписиДокумента(ЭтотОбъект, Отказ);
	
КонецПроцедуры

Процедура ОбработкаПроведения(Отказ, РежимПроведения)
	ПроведениеДокументов.ОбработкаПроведенияДокумента(ЭтотОбъект, Отказ);
КонецПроцедуры

Процедура ОбработкаУдаленияПроведения(Отказ)
	
	ПроведениеДокументов.ОбработкаУдаленияПроведенияДокумента(ЭтотОбъект, Отказ);
	
КонецПроцедуры

Процедура ОбработкаПроверкиЗаполнения(Отказ, ПроверяемыеРеквизиты)
	
	НепроверяемыеРеквизиты = Новый Массив;

	НоменклатураСервер.ПроверитьЗаполнениеКоличества(ЭтотОбъект, ПроверяемыеРеквизиты, Отказ);
	НоменклатураСервер.ПроверитьЗаполнениеХарактеристик(ЭтотОбъект,НепроверяемыеРеквизиты,Отказ);
	
	// Склады проверяются только при наличии товаров / тары
	НепроверяемыеРеквизиты.Добавить("Товары.Склад");
	НепроверяемыеРеквизиты.Добавить("Склад");
	ЗакупкиСервер.ПроверитьКорректностьЗаполненияДокументаЗакупки(ЭтотОбъект, Отказ);
	
	НепроверяемыеРеквизиты.Добавить("Товары.Подразделение");
	ОписаниеПроверокПодразделений = Новый Соответствие;
	ОписаниеПроверокПодразделений.Вставить(
		Перечисления.ТипыНоменклатуры.Услуга, 
		НСтр("ru = 'Не указан получатель услуг в строке %1 списка Товары'"));
		
	ОписаниеПроверокПодразделений.Вставить(
		Перечисления.ТипыНоменклатуры.Работа, 
		НСтр("ru = 'Не указан получатель работ в строке %1 списка Товары'"));
		
	Для Каждого КлючиИЗначение Из ОписаниеПроверокПодразделений Цикл
		ЗапасыСервер.ПроверитьЗаполнениеПодразделенияВТабличнойЧасти(
			ЭтотОбъект,
			ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(КлючиИЗначение.Ключ),
			КлючиИЗначение.Значение,
			Отказ);
	КонецЦикла;
	
	ИспользоватьЛимитыБДР = Документы.ЗаявкаНаЗакупку.ИспользоватьЛимитыБДР();
	КонтролироватьЛимитыБДР = ИспользоватьЛимитыБДР
		И Перечисления.СтатусыЗаявокНаЗакупку.Согласована(Статус) // Заявка согласована
		И ЦельЗакупки = Перечисления.ЦелиЗакупки.СобственныеНужды;
	
	Если Не ИспользоватьЛимитыБДР Тогда
		НепроверяемыеРеквизиты.Добавить("ЦельЗакупки");
	КонецЕсли;
	
	Если Не КонтролироватьЛимитыБДР Тогда
		ИменаРеквизитовАналитикЛимитирования = Документы.ЗаявкаНаЗакупку.ИменаРеквизитовАналитикЛимитирования();
		ОбщегоНазначенияКлиентСервер.ДополнитьМассив(НепроверяемыеРеквизиты, ИменаРеквизитовАналитикЛимитирования);
	КонецЕсли;
	
	ОбщегоНазначения.УдалитьНепроверяемыеРеквизитыИзМассива(ПроверяемыеРеквизиты, НепроверяемыеРеквизиты);
	
	ПараметрыВыбораСтатейИАналитик = Документы.ЗаявкаНаЗакупку.ПараметрыВыбораСтатейИАналитик(ЦельЗакупки);
	ДоходыИРасходыСервер.ОбработкаПроверкиЗаполнения(ЭтотОбъект, Отказ, ПроверяемыеРеквизиты, ПараметрыВыбораСтатейИАналитик);
	
	
КонецПроцедуры

Процедура ПриКопировании(ОбъектКопирования)
	
	Дата = ТекущаяДатаСеанса();
	Протокол.Очистить();
	Комментарий = Неопределено;
	Статус = Перечисления.СтатусыЗаявокНаЗакупку.НаСогласовании;
	ИнициализироватьДокумент(ОбъектКопирования);
	
КонецПроцедуры

Процедура ОбработкаЗаполнения(ДанныеЗаполнения, ТекстЗаполнения, СтандартнаяОбработка)
	
	ТипДанныхЗаполнения = ТипЗнч(ДанныеЗаполнения);
	ТребуетсяЗаполнениеПоСтатистике = Истина;
	
	Если ТипДанныхЗаполнения = Тип("Структура") Тогда
		ЗаполнитьДокументПоОтбору(ДанныеЗаполнения);
		ТребуетсяЗаполнениеПоСтатистике = Ложь;
	КонецЕсли;
	
	Если ТребуетсяЗаполнениеПоСтатистике Тогда
		ЗаполнениеОбъектовПоСтатистике.ЗаполнитьРеквизитыОбъекта(ЭтотОбъект, ДанныеЗаполнения);
	КонецЕсли;
	ИнициализироватьДокумент(ДанныеЗаполнения);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

#Область ИнициализацияИЗаполнение

Процедура ЗаполнитьДокументПоОтбору(Знач ДанныеЗаполнения)
	
	// Перечень реквизитов, которые нельзя копировать из отбора:
	НезаполняемыеРеквизиты = Новый Массив;
	НезаполняемыеРеквизиты.Добавить("Проведен");
	НезаполняемыеРеквизиты.Добавить("ПометкаУдаления");
	НезаполняемыеРеквизиты.Добавить("Автор");
	НезаполняемыеРеквизиты.Добавить("Статус");
	НезаполняемыеРеквизиты.Добавить("Исполнитель");
	
	ИсключаемыеРеквизиты = Новый Массив;
	Для Каждого НезаполняемыйРеквизит Из НезаполняемыеРеквизиты Цикл
		Если Не ДанныеЗаполнения.Свойство(НезаполняемыйРеквизит) Тогда
			Продолжить;
		КонецЕсли;
		
		ИсключаемыеРеквизиты.Добавить(НезаполняемыйРеквизит);
		
	КонецЦикла;
	
	Если ЗначениеЗаполнено(ИсключаемыеРеквизиты) Тогда
		ИсключаемыеРеквизиты = СтрСоединить(ИсключаемыеРеквизиты, ", ");
	Иначе
		ИсключаемыеРеквизиты = Неопределено;
	КонецЕсли;
	
	ЗаполнитьЗначенияСвойств(ЭтотОбъект, ДанныеЗаполнения,, ИсключаемыеРеквизиты);
	ЗаполнениеОбъектовПоСтатистике.ЗаполнитьРеквизитыОбъекта(ЭтотОбъект, ДанныеЗаполнения);
	
	Если ДанныеЗаполнения.Свойство("Товары") Тогда
		Товары.Загрузить(ДанныеЗаполнения.Товары);
	КонецЕсли;
	
	ПроверитьЗаполнитьПоступлениеОднойДатой();
	
	Если ДанныеЗаполнения.Свойство("Товары") Тогда //Заполнение из обработки "Обеспечение потребностей".
		
		Если Не ЗначениеЗаполнено(Валюта) Тогда
			Валюта = ДоходыИРасходыСервер.ПолучитьВалютуУправленческогоУчета(Валюта);
		КонецЕсли;
		
		Если ДанныеЗаполнения.Свойство("Исполнитель") Тогда
			Исполнитель = ДанныеЗаполнения.Исполнитель;
		КонецЕсли;
		
		Действия = Новый Структура;
		Действия.Вставить("ЗаполнитьКонтрагентаПартнераПоУмолчанию", Истина);
		
		ПараметрыЗаполненияДоговора = ПакетнаяОбработкаТабличнойЧастиКлиентСервер.ПараметрыЗаполненияДоговораПоУмолчанию();
		ПараметрыЗаполненияДоговора.Организация = Организация;
		ПараметрыЗаполненияДоговора.ВалютаВзаиморасчетов = Валюта;
		ПараметрыЗаполненияДоговора.ТипДоговора = Документы.ЗаявкаНаЗакупку.ДоступныеТипыДоговоров();
		Действия.Вставить("ЗаполнитьДоговорПоУмолчанию", ПараметрыЗаполненияДоговора);
		
		Действия.Вставить("ЗаполнитьНоменклатуруПартнераПоНоменклатуре", Неопределено);
		
		ОбщегоНазначенияКлиентСервер.ДополнитьСтруктуру(
			Действия,
			ЗаявкаНаЗакупкуКлиентСервер.ДействияЗаполненияНалогообложенияНДС(ЭтотОбъект),
			Истина);
		
		ТоварыИсточника = ДанныеЗаполнения.Товары; // ТаблицаЗначений
		ПересчитатьСуммыПоСкорректированнымСтавкамНДС = Истина;
		Если ТоварыИсточника.Колонки.Найти("Цена") = Неопределено Тогда
			ОбщегоНазначенияКлиентСервер.ДополнитьСтруктуру(Действия, ЗаявкаНаЗакупкуКлиентСервер.ДействияЗаполненияЦены(ЭтотОбъект), Истина);
			ПересчитатьСуммыПоСкорректированнымСтавкамНДС = Ложь; // Расчет цен инициализирует расчет сумм.
		Иначе
			ПересчитатьСуммыПоСкорректированнымСтавкамНДС = Истина;
		КонецЕсли;
		
		// Инициализируем промежуточную таблица с гарантированным составом колонок
		//   и дополняем ее промежуточными колонками расчетов.
		ТаблицаТоваров = Товары.Выгрузить(); 
		ТаблицаТоваров.Колонки.Добавить("ХозяйственнаяОперация", Новый ОписаниеТипов("ПеречислениеСсылка.ХозяйственныеОперации"));
		
		КэшированныеЗначения = ПакетнаяОбработкаТабличнойЧастиКлиентСервер.ПолучитьСтруктуруКэшируемыеЗначения();
		ПакетнаяОбработкаТабличнойЧастиСервер.ОбработатьТЧ(ТаблицаТоваров, Действия, КэшированныеЗначения);
		
		Если ПересчитатьСуммыПоСкорректированнымСтавкамНДС
			И ЗначениеЗаполнено(КэшированныеЗначения.ОбработанныеСтроки) Тогда
			
			ПакетнаяОбработкаТабличнойЧастиСервер.ОбработатьСтрокиТЧ(
				КэшированныеЗначения.ОбработанныеСтроки,
				ЗаявкаНаЗакупкуКлиентСервер.ДействияПересчетаСуммы(ЦенаВключаетНДС, Ложь, Истина),
				ТаблицаТоваров,
				КэшированныеЗначения);
			
		КонецЕсли;
		
		Товары.Загрузить(ТаблицаТоваров);
		
	КонецЕсли;
	
КонецПроцедуры

Процедура ИнициализироватьДокумент(ДанныеЗаполнения)
	
	Автор = Пользователи.ТекущийПользователь();
	
	Если Не ЗначениеЗаполнено(Исполнитель) Тогда
		Исполнитель = Автор;
	КонецЕсли;
	
	Организация = ЗначениеНастроекПовтИсп.ПолучитьОрганизациюПоУмолчанию(Организация);
	Подразделение = ЗначениеНастроекПовтИсп.ПодразделениеПользователя(Автор, Подразделение);
	Склад = ЗначениеНастроекПовтИсп.ПолучитьСкладПоУмолчанию(Склад);
	
	Если Не ЗначениеЗаполнено(Валюта) Тогда
		Валюта = ЗначениеНастроекПовтИсп.ВалютаРегламентированногоУчетаОрганизации(Организация);
	КонецЕсли;
	
	Если ДанныеЗаполнения = Неопределено
		Или ТипЗнч(ДанныеЗаполнения) = Тип("Структура") И Не ДанныеЗаполнения.Свойство("Товары") Тогда
		// Документ вводится без предзаполнения ТЧ.
		ПоступлениеОднойДатой = Истина;
	КонецЕсли;
		
	Если Не Документы.ЗаявкаНаЗакупку.ИспользоватьЛимитыБДР() Тогда
		ЦельЗакупки = ЗаявкаНаЗакупкуКлиентСервер.ЦельЗакупкиПоУмолчанию();
	КонецЕсли;
	
КонецПроцедуры

Процедура ПроверитьЗаполнитьПоступлениеОднойДатой()

	ПоступлениеОднойДатой = Истина;
	Если Товары.Количество() > 0 Тогда

		ДатаПоступления = Товары[0].ЖелаемаяДатаПоступления;
		
		Для Каждого Строка Из Товары Цикл

			Если Строка.ЖелаемаяДатаПоступления <> ДатаПоступления Тогда
				ПоступлениеОднойДатой = Ложь;
			КонецЕсли;
			
		КонецЦикла;

		Если ПоступлениеОднойДатой Тогда
			ЖелаемаяДатаПоступления = ДатаПоступления;
		КонецЕсли;

	КонецЕсли;

КонецПроцедуры

// По желаемым датам поступления выполняются поиски документов, например, исполнение планов закупки.
Процедура ЗаполнитьПустыеЖелаемыеДатыПоступления()
	
	ТекстыЗапросов = Новый СписокЗначений;
	Запрос = Новый Запрос;
	
	ТекстЗапроса = 
	"ВЫБРАТЬ
	|	Товары.НомерСтроки КАК НомерСтроки,
	|	&ДатаНачала КАК ДатаНачала,
	|	Товары.Соглашение КАК Соглашение
	|ПОМЕСТИТЬ Товары
	|ИЗ
	|	&Товары КАК Товары
	|ГДЕ
	|	Товары.ЖелаемаяДатаПоступления = ДАТАВРЕМЯ(1, 1, 1)";
	Запрос.УстановитьПараметр("Товары", Товары.Выгрузить(, "НомерСтроки, Соглашение, ЖелаемаяДатаПоступления"));
	Запрос.УстановитьПараметр("ДатаНачала", НачалоДня(ТекущаяДатаСеанса()));
	ТекстыЗапросов.Добавить(ТекстЗапроса, "Товары");
	
	ТекстЗапроса =
	"ВЫБРАТЬ
	|	Товары.НомерСтроки КАК НомерСтроки,
	|	Товары.ДатаНачала КАК ДатаНачала,
	|	ЕСТЬNULL(Соглашения.СрокОтгрузки, 0) + ЕСТЬNULL(Соглашения.СрокДоставки, 0) КАК СрокОтгрузки
	|ПОМЕСТИТЬ ПараметрыПоиска
	|ИЗ
	|	Товары КАК Товары
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.СоглашенияСПоставщиками КАК Соглашения
	|		ПО Товары.Соглашение = Соглашения.Ссылка";
	ТекстыЗапросов.Добавить(ТекстЗапроса, "ПараметрыПоиска");
	
	ТекстЗапроса = ОбеспечениеВДокументахСервер.ВременнаяТаблицаГодыГрафикаПредприятия();
	ТекстыЗапросов.Добавить(ТекстЗапроса, "ГодыГрафикаПредприятия");
	
	ТекстЗапроса = 
	"ВЫБРАТЬ
	|	ПараметрыПоиска.НомерСтроки КАК НомерСтроки,
	|	&ЖелаемаяДатаПоступленияПереопределеяемый КАК ЖелаемаяДатаПоступления
	|ИЗ
	|	ПараметрыПоиска КАК ПараметрыПоиска
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЗаявкаНаЗакупку КАК ЗаявкаНаЗакупку
	|		ПО (ИСТИНА)";
	
	Подстановки = ОбеспечениеВДокументахСервер.ДобавитьКДатеПоКалендарюПредприятия(
		"ПараметрыПоиска.ДатаНачала", "ПараметрыПоиска.СрокОтгрузки");
	
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса,
		"&ЖелаемаяДатаПоступленияПереопределеяемый",
		Подстановки.Поле);
		
	ТекстЗапроса = ТекстЗапроса + "
	|		" + Подстановки.Соединения;
		
	ТекстыЗапросов.Добавить(ТекстЗапроса, "Результат");
	
	РезультатПакета = ОбщегоНазначенияУТ.ПолучитьРезультатыЗапроса(Запрос, ТекстыЗапросов);
	РезультатЗапроса = РезультатПакета.Результат; // РезультатЗапроса
	Выборка = РезультатЗапроса.Выбрать();
	
	Пока Выборка.Следующий() Цикл
		СтрокаТоваров = Товары.Получить(Выборка.НомерСтроки - 1);
		ЗаполнитьЗначенияСвойств(СтрокаТоваров, Выборка);
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти

#КонецОбласти

#КонецЕсли
