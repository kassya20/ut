&НаКлиентеНаСервереБезКонтекста
Функция ПараметрыПроверкиАссортимента(Объект)
	
	ВозвращаемоеЗначение = АссортиментКлиентСервер.ПараметрыПроверкиАссортимента();
	ВозвращаемоеЗначение.Ссылка = Объект.Ссылка;
	ВозвращаемоеЗначение.Склад = Объект.Склад;
	ВозвращаемоеЗначение.Дата = ?(ЗначениеЗаполнено(Объект.ЖелаемаяДатаПоступления), Объект.ЖелаемаяДатаПоступления, Объект.Дата);
	ВозвращаемоеЗначение.ТекстСообщения = НСтр("ru = 'Товар %1 не включен в ассортимент магазина. Заказывать его не рекомендуется.'");
	ВозвращаемоеЗначение.ИмяРесурсаАссортимента = "РазрешеныЗакупки";
	ВозвращаемоеЗначение.ПровереноМожноДобавлять = Истина;
	ВозвращаемоеЗначение.РазрешатьДобавление = Истина;
	
	Возврат ВозвращаемоеЗначение;
	
КонецФункции

