#Область ОбработчикиКомандФормы

#Область УсловияЗакупки

&НаКлиенте
Процедура СкопироватьУсловияЗакупки(Команда)
	
	Если Не ПроверитьНаличиеВыделенныхСтрок(Ложь) Тогда
		Возврат;
	КонецЕсли;
	
	БуферПараметровЗакупки = Новый Структура;
	БуферПараметровЗакупки.Вставить("Партнер");
	БуферПараметровЗакупки.Вставить("Контрагент");
	БуферПараметровЗакупки.Вставить("Соглашение");
	БуферПараметровЗакупки.Вставить("Договор");
	БуферПараметровЗакупки.Вставить("ВидЦеныПоставщика");
	БуферПараметровЗакупки.Вставить("Валюта");
	БуферПараметровЗакупки.Вставить("НалогообложениеНДС");
	БуферПараметровЗакупки.Вставить("СтавкаНДС");
	
	Элементы.ТоварыВставитьУсловияЗакупки.Доступность = Истина;
	
	ТекущиеДанные = Элементы.Товары.ТекущиеДанные;
	ЗаполнитьЗначенияСвойств(БуферПараметровЗакупки, ТекущиеДанные);

КонецПроцедуры

&НаКлиенте
Процедура ВставитьУсловияЗакупки(Команда)
	
	Если Не ЗначениеЗаполнено(БуферПараметровЗакупки)
		Или Не ПроверитьНаличиеВыделенныхСтрок() Тогда
		Возврат;
	КонецЕсли;
	
	ВставитьУсловияЗакупкиНаСервере(Элементы.Товары.ВыделенныеСтроки);
	РассчитатьИтоговыеПоказателиЗаявки(ЭтотОбъект);
	УправлениеСтрокойТоваров();
	
КонецПроцедуры

#КонецОбласти

#Область КоммерческиеПредложения

&НаКлиенте
Процедура НачатьЗаполнениеУсловийЗакупкиПоКоммерческимПредложениям(Команда)
	
	ОчиститьСообщения();
	
	Если Не ПроверитьНаличиеВыделенныхСтрок() Тогда
		Возврат;
	КонецЕсли;
	
	РезультатЗаполнения = ЗаполнитьУсловияЗакупкиПоКоммерческимПредложениям(Элементы.Товары.ВыделенныеСтроки);
	
	Для Каждого НомерСтрокиТоваров Из РезультатЗаполнения.НомераСтрокСНезаполненнымиУсловиямиЗакупки Цикл
		
		ТекстОшибки = СтрШаблон(
			НСтр("ru = 'Для строки %1 списка ""Товары"" не найдены условия закупки в выбранных коммерческих предложениях.'"),
			НомерСтрокиТоваров);
		
		ПутьКЭлементу = ОбщегоНазначенияКлиентСервер.ПутьКТабличнойЧасти(
			"Объект.Товары",
			НомерСтрокиТоваров,
			"ПредставлениеУсловийЗакупки");
		
		ОбщегоНазначенияКлиент.СообщитьПользователю(
			ТекстОшибки,
			,
			ПутьКЭлементу);
			
	КонецЦикла;
	
	Если РезультатЗаполнения.Отказ Тогда
		
		ПоказатьПредупреждение(, РезультатЗаполнения.ТекстОшибки);
		
	Иначе
		
		КоличествоНеобработанныхСтрок = РезультатЗаполнения.НомераСтрокСНезаполненнымиУсловиямиЗакупки.Количество();
		
		ЕстьЗаполненныеСтроки = Элементы.Товары.ВыделенныеСтроки.Количество() > КоличествоНеобработанныхСтрок;
		Если ЕстьЗаполненныеСтроки Тогда
			ТекстСообщения = НСтр("ru = 'Условия закупки заполнены.'");
		Иначе
			ТекстСообщения = НСтр("ru = 'Не удалось заполнить условия закупки.'");
		КонецЕсли;
		
		ТекстПояснения = СтрШаблон(НСтр("ru = 'Условия закупки заполнены в %1 из %2 строк.'"),
			Элементы.Товары.ВыделенныеСтроки.Количество() - КоличествоНеобработанныхСтрок,
			Элементы.Товары.ВыделенныеСтроки.Количество());
			
		ПоказатьОповещениеПользователя(ТекстСообщения,, ТекстПояснения, БиблиотекаКартинок.Информация32);
		
		РассчитатьИтоговыеПоказателиЗаявки(ЭтотОбъект);
		УправлениеСтрокойТоваров();
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОтменаСтрок

&НаКлиенте
Процедура СкрыватьОтмененныеСтроки(Команда)
	
	СкрыватьОтмененныеСтроки = Не СкрыватьОтмененныеСтроки;
	
	ТоварыОбновитьОтборСтрокПоОтмененным(ЭтотОбъект, СкрыватьОтмененныеСтроки, Истина);
	
КонецПроцедуры

&НаКлиенте
Процедура ОтменитьВыделенныеСтроки(Команда)
	
	Если Не ПроверитьНаличиеВыделенныхСтрок() Тогда
		Возврат;
	КонецЕсли;
	
	Действия = Новый Структура;
	Действия.Вставить("ПриИзмененииТипаНоменклатуры",
		Новый Структура("ЕстьРаботы, ЕстьОтменено", Истина, Истина));
		
	ОбщегоНазначенияКлиентСервер.ДополнитьСтруктуру(Действия, ДействияЗаполненияСуммовыхРеквизитовФормы(), Истина);
	
	Для Каждого ИдентификаторСтроки Из Элементы.Товары.ВыделенныеСтроки Цикл
		
		СтрокаТоваров = Объект.Товары.НайтиПоИдентификатору(ИдентификаторСтроки);
		
		Если Не СтрокаТоваров.Отменено Тогда
			СтрокаТоваров.Отменено = Истина;
			ПакетнаяОбработкаТабличнойЧастиКлиент.ОбработатьСтрокуТЧ(СтрокаТоваров, Действия, КэшированныеЗначения);
		КонецЕсли;
		
	КонецЦикла;
	
	ОбновитьКартинкуГруппыСкладов();
	РассчитатьИтоговыеПоказателиЗаявки(ЭтотОбъект);
	УстановитьПризнакЗаполненияСклада(ЭтотОбъект);
	
	ПоказатьОповещениеПользователя(
		НСтр("ru = 'Выделенные строки отменены'"),
		,
		НСтр("ru='Выделенные строки заказа отменены.'"),
		БиблиотекаКартинок.Информация32);
	
КонецПроцедуры

&НаКлиенте
Процедура ОтменитьНезаказанныеСтроки(Команда)
	
	Результат = ОтменитьНезаказанныеСтрокиСервер();
	Если Не ПустаяСтрока(Результат.ТекстПредупреждения) Тогда
		ПоказатьПредупреждение(, Результат.ТекстПредупреждения);
		Возврат;
	КонецЕсли;
	
	Если Результат.ЕстьОтмененныеСтроки = 0 Тогда
		
		ПоказатьОповещениеПользователя(
			НСтр("ru = 'Строки не отменены'"),
			,
			НСтр("ru='По всем строкам заявки оформлены заказы. Строки не могут быть отменены.'"),
			БиблиотекаКартинок.Информация32);
			
	Иначе
		
		ПоказатьОповещениеПользователя(
			НСтр("ru = 'Строки отменены'"),
			,
			НСтр("ru='Все незаказанные строки заявки отменены.'"),
			БиблиотекаКартинок.Информация32);
		
	КонецЕсли;
	
КонецПроцедуры

