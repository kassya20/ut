// Обработчики событий переназначаются на "подписку", затем выполняется вызов исходного обработчика.
#Область КонтрольНесогласованныхИзменений

&НаСервере
Процедура УстановитьДоступностьЭлементовПоСтатусуСервер()
	
	ИменаЭлементов = Новый Массив;
	
	// Шапка:
	ИменаЭлементов.Добавить(Элементы.Дата.Имя);
	ИменаЭлементов.Добавить(Элементы.Организация.Имя);
	ИменаЭлементов.Добавить(Элементы.Подразделение.Имя);
	ИменаЭлементов.Добавить(Элементы.Склад.Имя);
	
	ИменаЭлементов.Добавить(Элементы.Валюта.Имя);
	ИменаЭлементов.Добавить(Элементы.ЦенаВключаетНДС.Имя);
	ИменаЭлементов.Добавить(Элементы.ПоступлениеОднойДатой.Имя);
	ИменаЭлементов.Добавить(Элементы.ЖелаемаяДатаПоступления.Имя);
	
	// Товары:
	ИменаЭлементов.Добавить("Товары;ПередНачаломДобавления,ПередУдалением");
	ИменаЭлементов.Добавить(Элементы.ТоварыНоменклатура.Имя);
	ИменаЭлементов.Добавить(Элементы.ТоварыХарактеристика.Имя);
	ИменаЭлементов.Добавить(Элементы.ТоварыКоличествоУпаковок.Имя);
	ИменаЭлементов.Добавить(Элементы.ТоварыУпаковка.Имя);
	ИменаЭлементов.Добавить(Элементы.ТоварыСклад.Имя);
	ИменаЭлементов.Добавить(Элементы.ТоварыОтменено.Имя);
	ИменаЭлементов.Добавить(Элементы.ТоварыЖелаемаяДатаПоступления.Имя);
	
	Для Каждого ИмяРеквизита Из ЗначениеИзКэша(КэшФормы, "ИменаРеквизитовУсловийЗакупки") Цикл
		
		ИменаЭлементов.Добавить(Элементы[ИмяРеквизита].Имя);
		ИменаЭлементов.Добавить(Элементы["Товары" + ИмяРеквизита].Имя);
		
	КонецЦикла;
	
	// Команды (товары):
	ИменаЭлементов.Добавить(Элементы.ТоварыВставитьСтроки.Имя);
	ИменаЭлементов.Добавить(Элементы.ТоварыПоискПоШтрихкоду.Имя);
	ИменаЭлементов.Добавить(Элементы.ТоварыЗагрузитьДанныеИзТСД.Имя);
	ИменаЭлементов.Добавить(Элементы.ТоварыВставитьУсловияЗакупки.Имя);
	ИменаЭлементов.Добавить(Элементы.ТоварыЗаполнитьУсловияЗакупкиПоКоммерческимПредложениям.Имя);
	ИменаЭлементов.Добавить(Элементы.ТоварыПодобратьНоменклатуру.Имя);
	ИменаЭлементов.Добавить(Элементы.ТоварыПодобратьАналоги.Имя);
	ИменаЭлементов.Добавить(Элементы.ТоварыЗагрузитьИзВнешнегоФайла.Имя);
	
	ИменаЭлементов.Добавить(Элементы.ТоварыОтменитьВыделенныеСтроки.Имя);
	ИменаЭлементов.Добавить(Элементы.ТоварыОтменитьНезаказанныеСтроки.Имя);
	
	ИменаЭлементов.Добавить(Элементы.ТоварыЗаполнитьСкладВВыделенныхСтроках.Имя);
	
	ОбщегоНазначенияУТ.УстановитьПодпискуНаСобытияИзмененияЭлементовФормы(
		ЭтотОбъект,
		ИменаЭлементов);
	
КонецПроцедуры

// Параметры:
//	Элемент - ГруппаФормы, ТаблицаФормы, ПолеФормы, КнопкаФормы - ЭлементФормы
&НаКлиенте
Процедура КонтрольНеСогласованныхИзмененийОбработатьСобытиеПриИзменении(Элемент)
	
	ИмяЭлемента = Элемент.Имя;
	
	Если ЗначениеИзКэша(КэшФормы, "ИменаРеквизитовУсловийЗакупки").Найти(ИмяЭлемента) <> Неопределено Тогда
		// Изменение префикса элемента расположенного в "подвале":
		ИмяЭлемента = "Товары" + ИмяЭлемента;
	КонецЕсли;
	
	Если ИмяЭлемента = Элементы.Дата.Имя Тогда
		ДатаПриИзменении(Элемент);
	ИначеЕсли ИмяЭлемента = Элементы.Организация.Имя Тогда
		ОрганизацияПриИзменении(Элемент);
	ИначеЕсли ИмяЭлемента = Элементы.Склад.Имя Тогда
		СкладПриИзменении(Элемент);
	ИначеЕсли ИмяЭлемента = Элементы.Валюта.Имя Тогда
		ВалютаПриИзменении(Элемент);
	ИначеЕсли ИмяЭлемента = Элементы.ЦенаВключаетНДС.Имя Тогда
		ЦенаВключаетНДСПриИзменении(Элемент);
	ИначеЕсли ИмяЭлемента = Элементы.ПоступлениеОднойДатой.Имя Тогда
		ПоступлениеОднойДатойПриИзменении(Элемент);
	ИначеЕсли ИмяЭлемента = Элементы.ЖелаемаяДатаПоступления.Имя Тогда
		ЖелаемаяДатаПоступленияПриИзменении(Элемент);
	// Товары:
	ИначеЕсли ИмяЭлемента = Элементы.ТоварыНоменклатура.Имя Тогда
		ТоварыНоменклатураПриИзменении(Элемент);
	ИначеЕсли ИмяЭлемента = Элементы.ТоварыХарактеристика.Имя Тогда
		ТоварыХарактеристикаПриИзменении(Элемент);
	ИначеЕсли ИмяЭлемента = Элементы.ТоварыКоличествоУпаковок.Имя Тогда
		ТоварыКоличествоУпаковокПриИзменении(Элемент);
	ИначеЕсли ИмяЭлемента = Элементы.ТоварыУпаковка.Имя Тогда
		ТоварыУпаковкаПриИзменении(Элемент);
	ИначеЕсли ИмяЭлемента = Элементы.ТоварыОтменено.Имя Тогда
		ТоварыОтмененоПриИзменении(Элемент);
	ИначеЕсли ИмяЭлемента = Элементы.ТоварыПартнер.Имя Тогда
		ТоварыПартнерПриИзменении(Элемент);
	ИначеЕсли ИмяЭлемента = Элементы.ТоварыКонтрагент.Имя Тогда
		ТоварыКонтрагентПриИзменении(Элемент);
	ИначеЕсли ИмяЭлемента = Элементы.ТоварыСоглашение.Имя Тогда
		ТоварыСоглашениеПриИзменении(Элемент);
	ИначеЕсли ИмяЭлемента = Элементы.ТоварыДоговор.Имя Тогда
		ТоварыДоговорПриИзменении(Элемент);
	ИначеЕсли ИмяЭлемента = Элементы.ТоварыВидЦеныПоставщика.Имя Тогда
		ТоварыВидЦеныПоставщикаПриИзменении(Элемент);
	ИначеЕсли ИмяЭлемента = Элементы.ТоварыНоменклатураПартнера.Имя Тогда
		ТоварыНоменклатураПартнераПриИзменении(Элемент);
	ИначеЕсли ИмяЭлемента = Элементы.ТоварыЦена.Имя Тогда
		ТоварыЦенаПриИзменении(Элемент);
	ИначеЕсли ИмяЭлемента = Элементы.ТоварыСумма.Имя Тогда
		ТоварыСуммаПриИзменении(Элемент);
	ИначеЕсли ИмяЭлемента = Элементы.ТоварыСтавкаНДС.Имя Тогда
		ТоварыСтавкаНДСПриИзменении(Элемент);
	ИначеЕсли ИмяЭлемента = Элементы.ТоварыСуммаНДС.Имя Тогда
		ТоварыСуммаНДСПриИзменении(Элемент);
	ИначеЕсли ИмяЭлемента = Элементы.ТоварыНазначение.Имя Тогда
		ТоварыНазначениеПриИзменении(Элемент);
	Иначе
		ОбщегоНазначенияУТКлиент.КонтрольНеСогласованныхИзмененийВызватьИсключение(ЭтотОбъект, Элемент);
	КонецЕсли;
	
КонецПроцедуры

// Параметры:
//	Команда - КомандаФормы - 
&НаКлиенте
Процедура КонтрольНеСогласованныхИзмененийОбработатьСобытиеКоманды(Команда)

	Если Команда.Имя = Команды.ВставитьСтроки.Имя Тогда
		ВставитьСтроки(Команда);
	ИначеЕсли Команда.Имя = Команды.ПоискПоШтрихкоду.Имя Тогда
		ПоискПоШтрихкодуВыполнить(Команда);
	ИначеЕсли Команда.Имя = Команды.ЗагрузитьДанныеИзТСД.Имя Тогда
		ЗагрузитьДанныеИзТСД(Команда);
	ИначеЕсли Команда.Имя = Команды.ВставитьУсловияЗакупки.Имя Тогда
		ВставитьУсловияЗакупки(Команда);
	ИначеЕсли Команда.Имя = Команды.ЗаполнитьУсловияЗакупкиПоКоммерческимПредложениям.Имя Тогда
		НачатьЗаполнениеУсловийЗакупкиПоКоммерческимПредложениям(Команда);
	ИначеЕсли Команда.Имя = Команды.ПодобратьТовары.Имя Тогда
		ПодобратьТовары(Команда);
	ИначеЕсли Команда.Имя = Команды.ПодобратьАналоги.Имя Тогда
		ПодобратьАналоги(Команда);
	ИначеЕсли Команда.Имя = Команды.ЗагрузитьИзВнешнегоФайла.Имя Тогда
		ЗагрузитьИзВнешнегоФайла(Команда);
	ИначеЕсли Команда.Имя = Команды.ОтменитьВыделенныеСтроки.Имя Тогда
		ОтменитьВыделенныеСтроки(Команда);
	ИначеЕсли Команда.Имя = Команды.ОтменитьНезаказанныеСтроки.Имя Тогда
		 ОтменитьНезаказанныеСтроки(Команда);
	ИначеЕсли Команда.Имя = Команды.ЗаполнитьСкладВВыделенныхСтроках.Имя Тогда
		ЗаполнитьСкладВВыделенныхСтроках(Команда);
	Иначе
		ОбщегоНазначенияУТКлиент.КонтрольНеСогласованныхИзмененийВызватьИсключение(ЭтотОбъект, Команда);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура КонтрольНеСогласованныхИзмененийОбработатьСобытиеНажатие(Элемент)
	ОбщегоНазначенияУТКлиент.КонтрольНеСогласованныхИзмененийВызватьИсключение(ЭтотОбъект, Элемент);
