// Параметры:
//	Элемент - ГруппаФормы, ТаблицаФормы, ПолеФормы, КнопкаФормы - ЭлементФормы
// Отказ - Булево - Одноименный параметр события.
&НаКлиенте
Процедура Подключаемый_ПередНачаломИзменения_УстановитьДоступностьЭлементовПоСтатусуСервер(Элемент, Отказ)
	
	Если ОбщегоНазначенияУТКлиент.ПриДействииСЭлементомЗависящимОтСтатуса(ЭтотОбъект) Тогда
		Возврат;
	КонецЕсли;
	
	Если СтруктураДействийКонтрольНеСогласованныхИзменений.ПередНачаломИзменения.Свойство(Элемент.Имя) Тогда
		КонтрольНеСогласованныхИзмененийОбработатьСобытиеПередНачаломИзменения(Элемент, Отказ);
	КонецЕсли;
	
КонецПроцедуры

// Параметры:
//	Элемент - ГруппаФормы, ТаблицаФормы, ПолеФормы, КнопкаФормы - ЭлементФормы
// Отказ - Булево - Одноименный параметр события.
&НаКлиенте
Процедура Подключаемый_ПередУдалением_УстановитьДоступностьЭлементовПоСтатусуСервер(Элемент, Отказ)
	
	Если ОбщегоНазначенияУТКлиент.ПриДействииСЭлементомЗависящимОтСтатуса(ЭтотОбъект) Тогда
		Возврат;
	КонецЕсли;
	
	Имя = Элемент.Имя;
	Если СтруктураДействийКонтрольНеСогласованныхИзменений.ПередУдалением.Свойство(Имя) Тогда
		КонтрольНеСогласованныхИзмененийОбработатьСобытиеПередУдалением(Элемент, Отказ);
	КонецЕсли;

КонецПроцедуры

// Параметры:
//	Элемент - ГруппаФормы, ТаблицаФормы, ПолеФормы, КнопкаФормы - ЭлементФормы
// Отказ - Булево - Одноименный параметр события.
// Копирование - Булево - Одноименный параметр события.
// Родитель - Неопределено - Одноименный параметр события.
// Группа - Булево - Одноименный параметр события.
&НаКлиенте
Процедура Подключаемый_ПередНачаломДобавления_УстановитьДоступностьЭлементовПоСтатусуСервер(Элемент, Отказ, Копирование, Родитель, Группа)
	
	Если ОбщегоНазначенияУТКлиент.ПриДействииСЭлементомЗависящимОтСтатуса(ЭтотОбъект) Тогда
		Возврат;
	КонецЕсли;
	
	Имя = Элемент.Имя;
	Если СтруктураДействийКонтрольНеСогласованныхИзменений.ПередНачаломДобавления.Свойство(Имя) Тогда
		КонтрольНеСогласованныхИзмененийОбработатьСобытиеПередНачаломДобавления(Элемент, Отказ, Копирование, Родитель, Группа);
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура Подключаемый_ПриИзмененииРеквизитаЗависящегоОтСтатуса()
	
	УстановитьДоступностьЭлементовПоСтатусуСервер();
	ОбщегоНазначенияУТКлиент.ПослеИзмененияРеквизитаЗависящегоОтСтатуса(ЭтотОбъект);
	
КонецПроцедуры

#КонецОбласти


#Область РаботаСБуферомОбмена

&НаСервере
Процедура СкопироватьСтрокиНаСервере()
	
	РаботаСТабличнымиЧастями.СкопироватьСтрокиВБуферОбмена(Объект.Товары, Элементы.Товары.ВыделенныеСтроки);
	
КонецПроцедуры

&НаСервере
Процедура ПолучитьСтрокиИзБуфераОбмена()
	
	ПараметрыОтбора = Новый Соответствие;
	ПараметрыОтбора.Вставить("Номенклатура.ТипНоменклатуры", НоменклатураКлиентСервер.ОтборПоТоваруМногооборотнойТареУслугеРаботе(Ложь));
	
	Колонки = Новый Массив;
	Колонки.Добавить("Номенклатура");
	Колонки.Добавить("Характеристика");
	Колонки.Добавить("Упаковка");
	Колонки.Добавить("КоличествоУпаковок");
	Колонки.Добавить("Цена");
	Колонки.Добавить("Подразделение");
	Колонки.Добавить("Склад");
	Колонки.Добавить("Партнер");
	Колонки.Добавить("Контрагент");
	Колонки.Добавить("Соглашение");
	Колонки.Добавить("Договор");
	
	СтрокиИзБуфераОбмена = РаботаСТабличнымиЧастями.СтрокиИзБуфераОбмена(ПараметрыОтбора, Колонки);
	
	Если Не ЗначениеЗаполнено(СтрокиИзБуфераОбмена) Тогда
		Возврат;
	КонецЕсли;
	
	Действия = Новый Структура;
	Действия.Вставить("ЗаполнитьПризнакТипНоменклатуры", Новый Структура("Номенклатура", "ТипНоменклатуры"));
	Действия.Вставить("ПриИзмененииТипаНоменклатуры", Новый Структура("ЕстьРаботы, ЕстьОтменено", Истина, Истина));
	Действия.Вставить("ЗаполнитьПризнакАртикул", Новый Структура("Номенклатура", "Артикул"));
	Действия.Вставить("ЗаполнитьПризнакХарактеристикиИспользуются", Новый Структура("Номенклатура", "ХарактеристикиИспользуются"));
	
	Действия.Вставить("ЗаполнитьСлужебныеРеквизитыПоНазначению", Новый Структура("ТолькоТипНазначения", Истина));
	
	Действия.Вставить(
		"ПроверитьЗаполнитьСклад",
		ПакетнаяОбработкаТабличнойЧастиКлиентСервер.ПолучитьСтруктуруЗаполненияСкладаВСтрокеТЧ(Объект, СкладГруппа));
	
	ОбщегоНазначенияКлиентСервер.ДополнитьСтруктуру(Действия, ДействияПриИзмененииКоличества(Объект.ЦенаВключаетНДС), Истина);
	ОбщегоНазначенияКлиентСервер.ДополнитьСтруктуру(Действия, ДействияЗаполненияНалогообложенияНДС(Объект, КэшФормы), Истина);
	
	ОбрабатываемыеСтроки = Новый Массив;
	Для Каждого СтрокаИзБуфера Из СтрокиИзБуфераОбмена Цикл
		
		СтрокаТоваров = Объект.Товары.Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаТоваров, СтрокаИзБуфера);
		ОбрабатываемыеСтроки.Добавить(СтрокаТоваров);
		
	КонецЦикла;
	
	ПакетнаяОбработкаТабличнойЧастиСервер.ОбработатьСтрокиТЧ(
		ОбрабатываемыеСтроки,
		Действия,
		Объект.Товары);
	
	ЗаполнитьСлужебныеРеквизитыСоглашений(ОбрабатываемыеСтроки);
		
	Для Каждого СтрокаТоваров Из ОбрабатываемыеСтроки Цикл
		
		Если Объект.ПоступлениеОднойДатой Тогда
			СтрокаТоваров.ЖелаемаяДатаПоступления = Объект.ЖелаемаяДатаПоступления;
		КонецЕсли;
		
		АктуализироватьПодразделениеСтрокиТоваров(СтрокаТоваров, Объект.Подразделение);
		
	КонецЦикла;
	
	РассчитатьИтоговыеПоказателиЗаявки(ЭтотОбъект);
	ОбновитьКартинкуГруппыСкладов();

КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Процедура УстановитьДоступностьКомандБуфераОбмена(Форма, ЗначениеДоступности)
	
	ИменаЭлементов = Новый Массив;
	ИменаЭлементов.Добавить("ТоварыВставитьСтроки");
	ИменаЭлементов.Добавить("ТоварыКонтекстноеМенюВставитьСтроки");
	
	ОбщегоНазначенияУТКлиентСервер.УстановитьСвойствоЭлементовФормы(
		Форма.Элементы,
		ИменаЭлементов,
		"Доступность",
		ЗначениеДоступности);
	
КонецПроцедуры

#КонецОбласти

#КонецОбласти

#Область ОбщиеПроцедурыИФункции

&НаКлиенте
Функция ПроверитьНаличиеВыделенныхСтрок(МножественныйРежимВыделения = Истина)
	
	ТекстПредупреждения = "";
	
	Если Объект.Товары.Количество() = 0 Тогда
		
		ТекстПредупреждения = НСтр("ru='Таблица товаров не заполнена.'");
		
	ИначеЕсли Элементы.Товары.ВыделенныеСтроки.Количество() = 0 Тогда
		
		Если МножественныйРежимВыделения Тогда
			ТекстПредупреждения = НСтр("ru='В таблице товаров отсутствуют выделенные строки.'");
		Иначе
			ТекстПредупреждения = НСтр("ru='Необходимо выделить строку товаров.'");
		КонецЕсли;
		
	КонецЕсли;
	
	ПроверкаПройдена = ПустаяСтрока(ТекстПредупреждения);
	Если Не ПроверкаПройдена Тогда
		ПоказатьПредупреждение(Неопределено, ТекстПредупреждения);
	КонецЕсли;
	
	Возврат ПроверкаПройдена;
	
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Процедура АктуализироватьПодразделениеСтрокиТоваров(СтрокаТоваров, Подразделение, Перезаполнять = Ложь)
	
	Если СтрокаТоваров.ТипНоменклатуры = ПредопределенноеЗначение("Перечисление.ТипыНоменклатуры.Товар")
		Или СтрокаТоваров.ТипНоменклатуры = ПредопределенноеЗначение("Перечисление.ТипыНоменклатуры.МногооборотнаяТара")
		Или СтрокаТоваров.ТипНоменклатуры = ПредопределенноеЗначение("Перечисление.ТипыНоменклатуры.Набор") Тогда

		СтрокаТоваров.Подразделение = Неопределено;

	ИначеЕсли (Перезаполнять Или Не ЗначениеЗаполнено(СтрокаТоваров.Подразделение)) 
		И (СтрокаТоваров.ТипНоменклатуры = ПредопределенноеЗначение("Перечисление.ТипыНоменклатуры.Услуга")
			Или СтрокаТоваров.ТипНоменклатуры = ПредопределенноеЗначение("Перечисление.ТипыНоменклатуры.Работа")) Тогда
			
		СтрокаТоваров.Подразделение = Подразделение;
	
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ЗаказыПоставщикам

&НаСервере
Функция ОписаниеЗаказаКСозданию(Знач ВыделенныеСтроки)
	
	НомераСтрок = Новый Массив;
	Для Каждого ИдентификаторСтроки Из ВыделенныеСтроки Цикл
		НомераСтрок.Добавить(Объект.Товары.НайтиПоИдентификатору(ИдентификаторСтроки).НомерСтроки);
	КонецЦикла;
	
	ОписаниеЗаказаКСозданию = Документы.ЗаявкаНаЗакупку.ОписаниеЗаказаКСозданию(Объект.Ссылка, НомераСтрок);
	
	Если ОписаниеЗаказаКСозданию.ДанныеЗаказа <> Неопределено Тогда
		
		ОписаниеЗаказаКСозданию.ДанныеЗаказа.Товары = ПоместитьВоВременноеХранилище(
			ОписаниеЗаказаКСозданию.ДанныеЗаказа.Товары,
			УникальныйИдентификатор);
		
	КонецЕсли;
	
	Возврат ОписаниеЗаказаКСозданию;
	
КонецФункции

&НаСервере
Функция ЕстьНезаказанныеСтроки()
	Возврат Документы.ЗаявкаНаЗакупку.ЕстьНезаказанныеСтроки(Объект);
КонецФункции

&НаСервере
Функция ОтменитьНезаказанныеСтрокиСервер()
	
	ВозвращаемоеЗначение = Новый Структура;
	ВозвращаемоеЗначение.Вставить("ТекстПредупреждения", "");
	ВозвращаемоеЗначение.Вставить("ЕстьОтмененныеСтроки", Ложь);
	
	Если Не Объект.Проведен Тогда
		ВозвращаемоеЗначение.ТекстПредупреждения = НСтр("ru = 'Невозможно рассчитать незаказанное количество для непроведенного документа.'");
	ИначеЕсли Не ЗначениеЗаполнено(Объект.Товары) Тогда
		ВозвращаемоеЗначение.ТекстПредупреждения = НСтр("ru = 'Таблица товаров не заполнена.'");
	ИначеЕсли ВсеСтрокиОтменены() Тогда
		ВозвращаемоеЗначение.ТекстПредупреждения = НСтр("ru = 'Все строки отменены.'");
	КонецЕсли;
	
	Если Не ПустаяСтрока(ВозвращаемоеЗначение.ТекстПредупреждения) Тогда
		Возврат ВозвращаемоеЗначение;
	КонецЕсли;
	
	Результат = Документы.ЗаявкаНаЗакупку.ОтменитьНезаказанныеСтроки(Объект);
	ВозвращаемоеЗначение.ЕстьОтмененныеСтроки = ЗначениеЗаполнено(Результат.ОтмененныеСтроки);
	
	Действия = Новый Структура;
	Действия.Вставить("ПриИзмененииТипаНоменклатуры", // Заполнение обязательности склада
		Новый Структура("ЕстьРаботы, ЕстьОтменено", Истина, Истина));
	ОбщегоНазначенияКлиентСервер.ДополнитьСтруктуру(Действия, ДействияЗаполненияСуммовыхРеквизитовФормы(), Истина);
	
	ПакетнаяОбработкаТабличнойЧастиСервер.ОбработатьСтрокиТЧ(Результат.ИзмененныеСтроки, Действия, Объект.Товары);
	
	РассчитатьИтоговыеПоказателиЗаявки(ЭтотОбъект);
	ТоварыОбновитьОтборСтрокПоОтмененным(ЭтотОбъект, СкрыватьОтмененныеСтроки, Ложь);
	УстановитьПризнакЗаполненияСклада(ЭтотОбъект);
	ОбновитьКартинкуГруппыСкладов();
	
	Возврат ВозвращаемоеЗначение;
	
КонецФункции

#КонецОбласти

#КонецОбласти
