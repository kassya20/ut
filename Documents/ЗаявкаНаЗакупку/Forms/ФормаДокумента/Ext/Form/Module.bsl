КонецФункции

&НаКлиентеНаСервереБезКонтекста
Функция ДействияЗаполненияНалогообложенияНДС(Объект, КэшФормы)
	
	УказаннаяСтавкаНДС = УказаннаяСтавкаНДС(КэшФормы);
	Действия = ЗаявкаНаЗакупкуКлиентСервер.ДействияЗаполненияНалогообложенияНДС(Объект, УказаннаяСтавкаНДС);
	
	// Т.к. налогообложение может изменить ставку НДС необходимо пересчитывать суммы.
	ОбщегоНазначенияКлиентСервер.ДополнитьСтруктуру(Действия, ДействияЗаполненияСуммовыхРеквизитовФормы(), Истина);
	
	Возврат Действия; 
	
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Функция ДействияЗаполненияСтавкиНДС(Объект, КэшФормы)

	УказаннаяСтавкаНДС = УказаннаяСтавкаНДС(КэшФормы);
	Действия = ЗаявкаНаЗакупкуКлиентСервер.ДействияЗаполненияСтавкиНДС(Объект, УказаннаяСтавкаНДС);
	ОбщегоНазначенияКлиентСервер.ДополнитьСтруктуру(Действия, ДействияЗаполненияСуммовыхРеквизитовФормы(), Истина);
	
	Возврат Действия;
		
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Функция ДействияПересчетаСуммы(ЦенаВключаетНДС, ПересчитатьСумму = Истина, ПересчитатьСуммуНДС = Истина)
	
	Действия = ЗаявкаНаЗакупкуКлиентСервер.ДействияПересчетаСуммы(ЦенаВключаетНДС, ПересчитатьСумму, ПересчитатьСуммуНДС);
	ОбщегоНазначенияКлиентСервер.ДополнитьСтруктуру(Действия, ДействияЗаполненияСуммовыхРеквизитовФормы(), Истина);
	
	Возврат Действия;
	
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Функция ДействияЗаполненияСуммовыхРеквизитовФормы()
	
	ОписаниеДубликатов = Новый Структура("Отменено", "СуммаНДС, СуммаСНДС");
	Действия = Новый Структура;
	Действия.Вставить("ЗаполнитьДубликатыЗависимыхРеквизитов", ОписаниеДубликатов);
	Действия.Вставить("ЗаполнитьПредставлениеУсловийЗакупки");
	
	Возврат Действия
	
КонецФункции

&НаСервере
Процедура ЗаполнитьСлужебныеРеквизитыСоглашений(СтрокиТоваров = Неопределено)
	
	Действия = Новый Структура;
	
	ПараметрыЗаполненияСоглашения = ПакетнаяОбработкаТабличнойЧастиКлиентСервер.ПараметрыЗаполненияСоглашенийПоставщика();
	
	// Заполняемые реквизиты используются только для интерактивной работы, не участвуют в пакетной обработке.
	Действия.Вставить("ЗаполнитьРеквизитыПоСоглашениюПоставщика"); 
	
	// Заполняется в привилегированном режиме. Нельзя добавлять в общий пакет запросов.
	Действия.Вставить("ЗаполнитьКоличествоСоглашенийПоставщика", ПараметрыЗаполненияСоглашения); 
	
	КэшированныеЗначения = ПакетнаяОбработкаТабличнойЧастиКлиентСервер.ПолучитьСтруктуруКэшируемыеЗначения();
	Если СтрокиТоваров = Неопределено Тогда
		
		ПакетнаяОбработкаТабличнойЧастиСервер.ОбработатьТЧ(Объект.Товары,
			Действия,
			КэшированныеЗначения);
	
	ИначеЕсли ТипЗнч(СтрокиТоваров) = Тип("Массив") Тогда
		
		ПакетнаяОбработкаТабличнойЧастиСервер.ОбработатьСтрокиТЧ(СтрокиТоваров,
			Действия,
			Объект.Товары,
			КэшированныеЗначения);
		
	Иначе
		
		ПакетнаяОбработкаТабличнойЧастиСервер.ОбработатьСтрокуТЧ(СтрокиТоваров,
			Действия,
			КэшированныеЗначения);
	
	КонецЕсли;
	
КонецПроцедуры

// Пересчитывает сумму НДС в строках табличной части для строк, 
// в которых была изменена ставка НДС после вызова действия "СкорректироватьСтавкуНДС" обработки табличной части.
// Параметры:
//  КэшированныеЗначения - См. ПакетнаяОбработкаТабличнойЧастиКлиентСервер.ПолучитьСтруктуруКэшируемыеЗначения
&НаСервере
Процедура ПересчитатьСуммуНДСПоСкорректированнымСтавкам(КэшированныеЗначения)
	
	Если КэшированныеЗначения = Неопределено Тогда
		Возврат; // Пакетная обработка не инициализировалась, т.к. нет строк к обработке.
	КонецЕсли;
	
	Действия = ДействияПересчетаСуммы(Объект.ЦенаВключаетНДС, Ложь, Истина);
	ПакетнаяОбработкаТабличнойЧастиСервер.ОбработатьСтрокиТЧ(КэшированныеЗначения.ОбработанныеСтроки,
		Действия,
		Объект.Товары,
		КэшированныеЗначения);
	КэшированныеЗначения.ОбработанныеСтроки.Очистить();
	
	РассчитатьИтоговыеПоказателиЗаявки(ЭтотОбъект);
	
КонецПроцедуры

#КонецОбласти

#Область ИнтегрируемыеПодсистемы

#Область Протокол

&НаКлиенте
Процедура Подключаемый_ПриИзмененииПротокола(ОписаниеИзменений, ДополнительныеПараметры = Неопределено) Экспорт
	
	Если Не ОписаниеИзменений.ИзмененныеСвойства.Свойство("Статус") Тогда
		Возврат;
	КонецЕсли;
	
	ОписаниеОповещения = Новый ОписаниеОповещения("ПриИзмененииСтатусаПослеВопроса", ЭтотОбъект);
	
	Если Объект.Статус = ПредопределенноеЗначение("Перечисление.СтатусыЗаявокНаЗакупку.Закрыта")
		И ЕстьНезаказанныеСтроки() Тогда
		
		ТекстВопроса = НСтр("ru = 'В документе присутствуют строки, по которым не сформированы заказы поставщикам. Отменить незаказанные товары?'");
		ПоказатьВопрос(ОписаниеОповещения, ТекстВопроса, РежимДиалогаВопрос.ДаНет);
		
	Иначе
		
		ВыполнитьОбработкуОповещения(ОписаниеОповещения, КодВозвратаДиалога.Нет);
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПриИзмененииСтатусаПослеВопроса(ОтветОтменитьНезаказанныеСтроки, ДополнительныеПараметры = Неопределено) Экспорт
	
	ОтменитьНезаказанныеСтроки = ОтветОтменитьНезаказанныеСтроки = КодВозвратаДиалога.Да;
	ПриИзмененииСтатусаНаСервере(ОтменитьНезаказанныеСтроки);
	
КонецПроцедуры

&НаСервере
Процедура ПриИзмененииСтатусаНаСервере(ОтменитьНезаказанныеСтроки)
	
	Если ОтменитьНезаказанныеСтроки Тогда
		ОтменитьНезаказанныеСтрокиСервер();
	КонецЕсли;
	
	Если Не Перечисления.СтатусыЗаявокНаЗакупку.Согласована(Объект.Статус) Тогда
		// Заявку можно закрыть или вернуть в работу без повторного согласования
		Объект.Согласован = Ложь;
	КонецЕсли;
	
	УправлениеФормой();
	ПодключаемыеКомандыКлиентСервер.ОбновитьКоманды(ЭтотОбъект, Объект);
	
КонецПроцедуры

#КонецОбласти

#Область ЗагрузкаИзФайла

&НаКлиенте
Процедура ЗагрузитьИзВнешнегоФайлаЗавершение(АдресЗагруженныхДанных, ДополнительныеПараметры) Экспорт
	
	Если ЗначениеЗаполнено(АдресЗагруженныхДанных) Тогда
		ПолучитьЗагруженныеТоварыИзХранилища(АдресЗагруженныхДанных);
		УстановитьПризнакЗаполненияСклада(ЭтотОбъект);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ПолучитьЗагруженныеТоварыИзХранилища(АдресТоваровВХранилище)
	
	Действия = Новый Структура;
	Действия.Вставить("ЗаполнитьСлужебныеРеквизитыПоНазначению", Новый Структура("ТолькоТипНазначения", Истина));
	Действия.Вставить(
		"ПроверитьЗаполнитьСклад",
		ПакетнаяОбработкаТабличнойЧастиКлиентСервер.ПолучитьСтруктуруЗаполненияСкладаВСтрокеТЧ(Объект, СкладГруппа));
	Действия.Вставить("ПриИзмененииТипаНоменклатуры",
		Новый Структура("ЕстьРаботы, ЕстьОтменено", Истина, Истина));
	
	ОбщегоНазначенияКлиентСервер.ДополнитьСтруктуру(Действия, ДействияЗаполненияНалогообложенияНДС(Объект, КэшФормы), Истина);
	ОбщегоНазначенияКлиентСервер.ДополнитьСтруктуру(Действия, ДействияПриИзмененииКоличества(Объект.ЦенаВключаетНДС), Истина);
	
	ОбрабатываемыеСтроки = Новый Массив;
	ТоварыИзХранилища = ПолучитьИзВременногоХранилища(АдресТоваровВХранилище);
	
	Для Каждого СтрокаИсточник Из ТоварыИзХранилища Цикл
		СтрокаТоваров = Объект.Товары.Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаТоваров, СтрокаИсточник);
		ОбрабатываемыеСтроки.Добавить(СтрокаТоваров);
	КонецЦикла;
	
	ПакетнаяОбработкаТабличнойЧастиСервер.ОбработатьСтрокиТЧ(
		ОбрабатываемыеСтроки,
		Действия,
		Объект.Товары);
	
	Для Каждого СтрокаТоваров Из ОбрабатываемыеСтроки Цикл
		АктуализироватьПодразделениеСтрокиТоваров(СтрокаТоваров, Объект.Подразделение);
	КонецЦикла;
	
	РассчитатьИтоговыеПоказателиЗаявки(ЭтотОбъект);
	ОбновитьКартинкуГруппыСкладов();
	
КонецПроцедуры

#КонецОбласти

#Область ПодключаемыеКоманды

// СтандартныеПодсистемы.ПодключаемыеКоманды
&НаКлиенте
Процедура Подключаемый_ВыполнитьКоманду(Команда)
	ПодключаемыеКомандыКлиент.НачатьВыполнениеКоманды(ЭтотОбъект, Команда, Объект);
КонецПроцедуры

&НаКлиенте
Процедура Подключаемый_ОбновитьКоманды()
	ПодключаемыеКомандыКлиентСервер.ОбновитьКоманды(ЭтотОбъект, Объект);
КонецПроцедуры
// Конец СтандартныеПодсистемы.ПодключаемыеКоманды

// СтандартныеПодсистемы.ПодключаемыеКоманды
