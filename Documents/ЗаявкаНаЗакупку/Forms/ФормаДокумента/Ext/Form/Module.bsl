#Область Заполнение

&НаКлиенте
Процедура ЗаполнитьСкладВВыделенныхСтроках(Команда)
	
	ВыделенныеСтроки = Элементы.Товары.ВыделенныеСтроки;
	
	Если Не СкладыКлиент.ПроверитьВозможностьЗаполненияСкладовВТабличнойЧасти(
		Объект,
		Объект.Товары,
		НСтр("ru='Товары'"),
		ВыделенныеСтроки) Тогда
			
		Возврат;
	КонецЕсли;
		
	ВыборГруппы = Новый Массив;
	ВыборГруппы.Добавить(ПредопределенноеЗначение("Перечисление.ВыборГруппыСкладов.РазрешитьВЗаказах"));
	ВыборГруппы.Добавить(ПредопределенноеЗначение("Перечисление.ВыборГруппыСкладов.РазрешитьВЗаказахИНакладных"));
	
	Отбор = Новый Структура;
	Отбор.Вставить("ВыборГруппы", ВыборГруппы);
	Отбор.Вставить("ЭтоГруппа",    Ложь);
	
	ПараметрыОткрытия = Новый Структура;
	ПараметрыОткрытия.Вставить("Отбор", Отбор);
	ПараметрыОткрытия.Вставить("ГруппаСкладов", Объект.Склад);

	ОткрытьФорму(
		"Справочник.Склады.ФормаВыбора",
		ПараметрыОткрытия,
		ЭтотОбъект,,,,
		Новый ОписаниеОповещения("ЗаполнитьСкладВВыделенныхСтрокахЗавершение", ЭтотОбъект),
		РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
КонецПроцедуры

#КонецОбласти

#Область ЗаказыПоставщикам

&НаКлиенте
Асинх Процедура СоздатьЗаказПоставщику(Команда)
	
	ОчиститьСообщения();
	
	Если Не ПроверитьНаличиеВыделенныхСтрок() Тогда
		Возврат;
	КонецЕсли;
	
	Если Модифицированность
		Или Объект.Ссылка.Пустая()
		Или Не Объект.Проведен Тогда
		
		Кнопки = Новый СписокЗначений;
		Кнопки.Добавить(КодВозвратаДиалога.ОК, НСтр("ru = 'Провести и продолжить'"));
		Кнопки.Добавить(КодВозвратаДиалога.Отмена);
		
		ТекстВопроса = НСтр("ru = 'Для создания заказа поставщику документ будет проведен. Продолжить?'");
		Ответ = Ждать ВопросАсинх(ТекстВопроса, Кнопки);
		
		Если Ответ <> КодВозвратаДиалога.ОК Тогда
			Возврат;
		КонецЕсли;
		
		ПараметрыЗаписи = Новый Структура;
		ПараметрыЗаписи.Вставить("РежимЗаписи", РежимЗаписиДокумента.Проведение);
		Если Не Записать(ПараметрыЗаписи) Тогда
			Возврат;
		КонецЕсли;
		
	КонецЕсли;
	
	ОценкаПроизводительностиКлиент.ЗамерВремени("Документ.ЗаявкаНаЗакупку.ФормаДокумента.Команда.СоздатьЗаказПоставщику");
	
	ВыделенныеСтроки = Элементы.Товары.ВыделенныеСтроки;
	ОписаниеЗаказаКСозданию = ОписаниеЗаказаКСозданию(ВыделенныеСтроки);
	
	Если ОписаниеЗаказаКСозданию.ДанныеЗаказа = Неопределено Тогда
		ПоказатьПредупреждение(, НСтр("ru = 'По выделенным строкам не требуется ввод новых заказов.'"));
		Возврат;
	КонецЕсли;
	
	ОткрытьФорму("Документ.ЗаказПоставщику.ФормаОбъекта",
		Новый Структура("ЗначенияЗаполнения", ОписаниеЗаказаКСозданию.ДанныеЗаказа),
		ЭтотОбъект,
		Истина);
		
	Если ЗначениеЗаполнено(ОписаниеЗаказаКСозданию.НеОбработаноИсходныхСтрок) Тогда
		
		ТекстСообщения = НСтр("ru = 'Невозможно разместить выделенные строки в одном заказе.'");
		ТекстПояснения = СтрШаблон(НСтр("ru = 'Выделено строк: %1. Обработано: %2. Требуют формирования заказов: %3'"),
			ВыделенныеСтроки.Количество(),
			ОписаниеЗаказаКСозданию.ОбработаноИсходныхСтрок,
			ОписаниеЗаказаКСозданию.НеОбработаноИсходныхСтрок);
		
		ПоказатьОповещениеПользователя(ТекстСообщения,, ТекстПояснения, БиблиотекаКартинок.Информация32);
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура ПриЧтенииСозданииНаСервере()
	ЗаполнитьДанныеФормы();
	УправлениеФормой();
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьДанныеФормы()
	
	// Используется как предыдущее значение и выводится даже при выключенной Ф.О. "ИспользоватьНесколькоВалют": 
	ВалютаДокумента = Объект.Валюта;
	
	РаботаСПротоколомДокумента.ЗаполнитьДанныеФормы(ЭтотОбъект);
	ИнициализироватьКэшФормы();
		
	Действия = Новый Структура;
	Действия.Вставить("ЗаполнитьПризнакХарактеристикиИспользуются", Новый Структура("Номенклатура", "ХарактеристикиИспользуются"));
	Действия.Вставить("ЗаполнитьПризнакТипНоменклатуры", Новый Структура("Номенклатура", "ТипНоменклатуры"));
	Действия.Вставить("ЗаполнитьПризнакАртикул", Новый Структура("Номенклатура", "Артикул"));
	
	Действия.Вставить("ПриИзмененииТипаНоменклатуры",
		Новый Структура("ЕстьРаботы, ЕстьОтменено", Истина, Истина));
	
	Действия.Вставить("ЗаполнитьСлужебныеРеквизитыПоНазначению",
		Новый Структура("ТолькоТипНазначения", Истина));
		
	ОбщегоНазначенияКлиентСервер.ДополнитьСтруктуру(Действия,
		ЗаявкаНаЗакупкуКлиентСервер.ДействияЗаполненияХозяйственнойОперации(),
		Истина);
	
	ОбщегоНазначенияКлиентСервер.ДополнитьСтруктуру(Действия, ДействияЗаполненияСуммовыхРеквизитовФормы(), Истина);
	
	ПакетнаяОбработкаТабличнойЧастиСервер.ОбработатьТЧ(Объект.Товары, Действия);
	
	ЗаполнитьСлужебныеРеквизитыСоглашений();
	
	СкладГруппа = Справочники.Склады.ЭтоГруппаИСкладыИспользуютсяВТЧДокументовЗакупки(Объект.Склад);
	ОбновитьКартинкуГруппыСкладов();
	РассчитатьИтоговыеПоказателиЗаявки(ЭтотОбъект);
	УстановитьПризнакЗаполненияСклада(ЭтотОбъект);
	
КонецПроцедуры

#Область УсловияЗакупки

&НаКлиентеНаСервереБезКонтекста
Процедура РассчитатьИтоговыеПоказателиЗаявки(Форма)
	
	// Заполнение итогов по таблице "Товары"
	КоллекцияТовары = Форма.Объект.Товары;
	Форма.СуммаВсегоСНДС = КоллекцияТовары.Итог("СуммаСНДС") - КоллекцияТовары.Итог("СуммаСНДСОтменено");
	Форма.СуммаВсегоНДС = КоллекцияТовары.Итог("СуммаНДС") - КоллекцияТовары.Итог("СуммаНДСОтменено");
		
КонецПроцедуры

&НаСервере
Процедура ВставитьУсловияЗакупкиНаСервере(Знач ВыделенныеСтроки)
	
	СтрокиКОбработке = Новый Массив;
	Для Каждого ИдентификаторСтроки Из ВыделенныеСтроки Цикл
		СтрокаТоваров = Объект.Товары.НайтиПоИдентификатору(ИдентификаторСтроки);
		ЗаполнитьЗначенияСвойств(СтрокаТоваров, БуферПараметровЗакупки);
		СтрокиКОбработке.Добавить(СтрокаТоваров);
	КонецЦикла;
	
	Действия = Новый Структура;
	ПараметрыЗаполненияСоглашения = ПакетнаяОбработкаТабличнойЧастиКлиентСервер.ПараметрыЗаполненияСоглашенийПоставщика();
	Действия.Вставить("ЗаполнитьКоличествоСоглашенийПоставщика", ПараметрыЗаполненияСоглашения);
	Действия.Вставить("ЗаполнитьРеквизитыПоСоглашениюПоставщика");
	
	Если ЗначениеЗаполнено(БуферПараметровЗакупки.ВидЦеныПоставщика) Тогда
		ОбщегоНазначенияКлиентСервер.ДополнитьСтруктуру(Действия, ДействияЗаполненияЦены(Объект), Истина);
	Иначе
		ОбщегоНазначенияКлиентСервер.ДополнитьСтруктуру(Действия, ДействияПересчетаСуммы(Объект.ЦенаВключаетНДС));
	КонецЕсли;
	
	ПакетнаяОбработкаТабличнойЧастиСервер.ОбработатьСтрокиТЧ(
		СтрокиКОбработке,
		Действия,
		Объект.Товары,
		ПакетнаяОбработкаТабличнойЧастиКлиентСервер.ПолучитьСтруктуруКэшируемыеЗначения());
	
КонецПроцедуры

&НаСервере
Процедура УстановитьПараметрыВыбораСоглашений()
	
	ДоступныеОперации = Документы.ЗаявкаНаЗакупку.ДоступныеОперацииСоглашений();
	
	ОбщегоНазначенияУТКлиентСервер.ДобавитьПараметрВыбора(
		Элементы.Соглашение, "ХозяйственнаяОперация",
		ДоступныеОперации);
		
	ОбщегоНазначенияУТКлиентСервер.ДобавитьПараметрВыбора(
		Элементы.ТоварыСоглашение, "ХозяйственнаяОперация",
		ДоступныеОперации);
	
КонецПроцедуры

&НаСервере
Процедура УстановитьПараметрыВыбораДоговоров()

	ОбщегоНазначенияУТКлиентСервер.ДобавитьПараметрВыбора(
		Элементы.Договор, "ТипДоговора",
		ДоступныеТипыДоговоров(КэшФормы));
		
	ОбщегоНазначенияУТКлиентСервер.ДобавитьПараметрВыбора(
		Элементы.ТоварыДоговор, "ТипДоговора",
		ДоступныеТипыДоговоров(КэшФормы));
	
КонецПроцедуры

#КонецОбласти

#Область ДополнительныеОбработчикиСобытийЭлементов

#Область Дата_
// Использование "Дата" "недопустимо в данном контексте"

&НаКлиенте
Процедура ДатаПриИзмененииЗавершение(ПересчитыватьЦены, ДополнительныеПараметры) Экспорт 
	
	Если Не ПересчитыватьЦены Тогда
		Возврат;
	КонецЕсли;
	
	ДатаПриИзмененииНаСервере();
	УправлениеСтрокойТоваров();
	
КонецПроцедуры

&НаСервере
Процедура ДатаПриИзмененииНаСервере()
	
	СохранитьКонтрольАссортимента(КэшФормы, Объект.Склад, Объект.Дата);
	Действия = Новый Структура;
	ОбщегоНазначенияКлиентСервер.ДополнитьСтруктуру(Действия, ДействияЗаполненияЦены(Объект), Истина);
	ОбщегоНазначенияКлиентСервер.ДополнитьСтруктуру(Действия, ДействияЗаполненияСтавкиНДС(Объект, КэшФормы), Истина);
	ПакетнаяОбработкаТабличнойЧастиСервер.ОбработатьТЧ(Объект.Товары, Действия);
	
	Если КонтролироватьАссортимент(КэшФормы) Тогда
		АссортиментСервер.ПроверитьАссортиментТаблицыПодобранныхТоваров(Объект, "Склад");
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область Организация

&НаСервере
Процедура ОрганизацияПриИзмененииНаСервере(КэшированныеЗначения)
	
	Действия = Новый Структура;
		
	ПараметрыЗаполненияДоговора = ПакетнаяОбработкаТабличнойЧастиКлиентСервер.ПараметрыЗаполненияДоговораПоУмолчанию();
	ПараметрыЗаполненияДоговора.Организация = Объект.Организация;
	ПараметрыЗаполненияДоговора.ВалютаВзаиморасчетов = Объект.Валюта;
	ПараметрыЗаполненияДоговора.ТипДоговора = ДоступныеТипыДоговоров(КэшФормы);
	Действия.Вставить("ЗаполнитьДоговорПоУмолчанию", ПараметрыЗаполненияДоговора);
	ОбщегоНазначенияКлиентСервер.ДополнитьСтруктуру(Действия, ДействияЗаполненияНалогообложенияНДС(Объект, КэшФормы), Истина);
	
	ПакетнаяОбработкаТабличнойЧастиСервер.ОбработатьТЧ(Объект.Товары, Действия, КэшированныеЗначения);
	
	ПересчитатьСуммуНДСПоСкорректированнымСтавкам(КэшированныеЗначения);
	
КонецПроцедуры

#КонецОбласти

#Область Склад

&НаКлиенте
Процедура ЗаполнитьСкладВВыделенныхСтрокахЗавершение(ВыбранныйСклад, ДополнительныеПараметры) Экспорт

	Если Не ЗначениеЗаполнено(ВыбранныйСклад) Тогда
		Возврат;
	КонецЕсли;
	
	ВыделенныеСтроки = Элементы.Товары.ВыделенныеСтроки;
	ЗаполненоСтрок = ЗаполнитьСкладВВыделенныхСтрокахНаСервере(ВыделенныеСтроки, ВыбранныйСклад);
	СкладыКлиент.ПоказатьОповещениеОЗаполненииСкладаВТабличнойЧасти(
		ВыбранныйСклад,
		ЗаполненоСтрок,
		ВыделенныеСтроки.Количество());

КонецПроцедуры

&НаСервере
Функция ЗаполнитьСкладВВыделенныхСтрокахНаСервере(Знач ВыделенныеСтроки, ВыбранныйСклад)
	
	ЗаполненоСтрок = СкладыСервер.ЗаполнитьСкладыВВыделенныхСтроках(
		Объект.Товары,
		ВыделенныеСтроки,
		ВыбранныйСклад);
	
	Если ЗаполненоСтрок > 0 Тогда
		ОбновитьКартинкуГруппыСкладов();
	КонецЕсли;
	
	Возврат ЗаполненоСтрок;
	
КонецФункции

&НаСервере
Процедура СкладПриИзмененииСервер()
	
	СкладГруппа = Справочники.Склады.ЭтоГруппаИСкладыИспользуютсяВТЧДокументовЗакупки(Объект.Склад);
	СкладыСервер.ЗаполнитьСкладыВТабличнойЧасти(Объект.Склад, СкладГруппа, Объект.Товары, Ложь);
	
	СохранитьКонтрольАссортимента(КэшФормы, Объект.Склад, Объект.Дата);
	
	Если КонтролироватьАссортимент(КэшФормы) Тогда
		АссортиментСервер.ПроверитьАссортиментТаблицыПодобранныхТоваров(Объект, "Склад");
	КонецЕсли;
	
	УправлениеФормойПоСкладу();
	
КонецПроцедуры

&НаСервере
Процедура УправлениеФормойПоСкладу()
	
	Элементы.ТоварыЗаполнитьСкладВВыделенныхСтроках.Доступность = СкладГруппа;
	ОбновитьКартинкуГруппыСкладов();
	УстановитьПараметрыВыбораТоварыСклад();
	
	Если Не СкладГруппа Тогда
		Элементы.ТоварыГруппаПолучатель.Заголовок = НСтр("ru = 'Подразделение-получатель'");
	Иначе
		Элементы.ТоварыГруппаПолучатель.Заголовок = НСтр("ru = 'Получатель'");
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьКартинкуГруппыСкладов()
	
	СкладыСервер.ПриИзмененииСкладаВТабличнойЧасти(Объект.Товары, ТаблицаСкладов, СкладГруппа);
	ВсегоСкладов = ТаблицаСкладов.Количество();
	СкладыКлиентСервер.ОбновитьКартинкуГруппыСкладов(НадписьНесколькоСкладов, Элементы.КартинкаНесколькоСкладов, ВсегоСкладов);
	
КонецПроцедуры

#КонецОбласти

#Область Назначение

&НаСервере
Процедура ТоварыНазначениеПриИзмененииНаСервере(КэшированныеЗначения)
	
	СтрокаТоваров = Объект.Товары.НайтиПоИдентификатору(Элементы.Товары.ТекущаяСтрока);
	
	Действия = Новый Структура;
	Действия.Вставить("ЗаполнитьСлужебныеРеквизитыПоНазначению", Новый Структура("ТолькоТипНазначения", Истина));
	
	ПараметрыЗаполненияДоговора = ПакетнаяОбработкаТабличнойЧастиКлиентСервер.ПараметрыЗаполненияДоговораПоУмолчанию();
	ПараметрыЗаполненияДоговора.Организация = Объект.Организация;
	ПараметрыЗаполненияДоговора.ВалютаВзаиморасчетов = Объект.Валюта;
	ПараметрыЗаполненияДоговора.ТипДоговора = ДоступныеТипыДоговоров(КэшФормы);
	Действия.Вставить("ЗаполнитьДоговорПоУмолчанию", ПараметрыЗаполненияДоговора);
	ОбщегоНазначенияКлиентСервер.ДополнитьСтруктуру(Действия, ДействияЗаполненияНалогообложенияНДС(Объект, КэшФормы), Истина);
	
	ПакетнаяОбработкаТабличнойЧастиСервер.ОбработатьСтрокуТЧ(СтрокаТоваров, Действия, КэшированныеЗначения);
	
	ПересчитатьСуммуНДСПоСкорректированнымСтавкам(КэшированныеЗначения);
	
КонецПроцедуры

#КонецОбласти

#Область Валюта

&НаСервере
Процедура ПриИзмененииВалютыСервер(КэшированныеЗначения) 
	
	Действия = Новый Структура;
	
	ПараметрыЗаполненияДоговора = ПакетнаяОбработкаТабличнойЧастиКлиентСервер.ПараметрыЗаполненияДоговораПоУмолчанию();
	ПараметрыЗаполненияДоговора.Организация = Объект.Организация;
	ПараметрыЗаполненияДоговора.ВалютаВзаиморасчетов = Объект.Валюта;
	ПараметрыЗаполненияДоговора.ТипДоговора = ДоступныеТипыДоговоров(КэшФормы);
	Действия.Вставить("ЗаполнитьДоговорПоУмолчанию", ПараметрыЗаполненияДоговора);
	ОбщегоНазначенияКлиентСервер.ДополнитьСтруктуру(Действия, ДействияЗаполненияНалогообложенияНДС(Объект, КэшФормы), Истина);
	ОбщегоНазначенияКлиентСервер.ДополнитьСтруктуру(
		Действия,
		ДействияЗаполненияСуммовыхРеквизитовФормы(),
		Истина);
	
	ПараметрыПересчета = Ценообразование.ПараметрыПересчетаСуммТаблицыВВалюту(
		Объект.ЦенаВключаетНДС,
		ВалютаДокумента,
		Объект.Валюта,
		?(ЗначениеЗаполнено(Объект.Дата), Объект.Дата, ТекущаяДатаСеанса()));
		
	Ценообразование.ПересчитатьСуммыТаблицыВВалюту(Объект.Товары, ПараметрыПересчета);
	
	ПакетнаяОбработкаТабличнойЧастиСервер.ОбработатьТЧ(Объект.Товары, Действия, КэшированныеЗначения);
	ПересчитатьСуммуНДСПоСкорректированнымСтавкам(КэшированныеЗначения);
	
КонецПроцедуры

#КонецОбласти

#Область ЦенаВключаетНДС

&НаСервере
Процедура ЦенаВключаетНДСПриИзмененииНаСервере()
	
	Действия = ДействияПересчетаСуммы(Объект.ЦенаВключаетНДС, Ложь, Истина);
	ПакетнаяОбработкаТабличнойЧастиСервер.ОбработатьТЧ(Объект.Товары, Действия);
	УстановитьДоступностьТоварыСНДС();
	РассчитатьИтоговыеПоказателиЗаявки(ЭтотОбъект);
	
КонецПроцедуры
#КонецОбласти

#Область Партнер

&НаСервере
Процедура ТоварыПартнерПриИзмененииНаСервере(КэшированныеЗначения)

	СтрокаТоваров = Объект.Товары.НайтиПоИдентификатору(Элементы.Товары.ТекущаяСтрока);
	
	Действия = Новый Структура;
	
	ПараметрыЗаполненияСоглашения = ПакетнаяОбработкаТабличнойЧастиКлиентСервер.ПараметрыЗаполненияСоглашенийПоставщика();
	ПараметрыЗаполненияСоглашения.ХозяйственнаяОперация = Документы.ЗаявкаНаЗакупку.ДоступныеОперацииСоглашений();
	Действия.Вставить("ЗаполнитьСоглашениеПоставщикаПоУмолчанию", ПараметрыЗаполненияСоглашения);
	
	Действия.Вставить("ЗаполнитьКонтрагентаПартнераПоУмолчанию", Истина);
	
	ПараметрыЗаполненияДоговора = ПакетнаяОбработкаТабличнойЧастиКлиентСервер.ПараметрыЗаполненияДоговораПоУмолчанию();
	ПараметрыЗаполненияДоговора.Организация = Объект.Организация;
	ПараметрыЗаполненияДоговора.ВалютаВзаиморасчетов = Объект.Валюта;
	ПараметрыЗаполненияДоговора.ТипДоговора = ДоступныеТипыДоговоров(КэшФормы);
	Действия.Вставить("ЗаполнитьДоговорПоУмолчанию", ПараметрыЗаполненияДоговора);
	ОбщегоНазначенияКлиентСервер.ДополнитьСтруктуру(Действия, ДействияЗаполненияНалогообложенияНДС(Объект, КэшФормы), Истина);
	
	ОбщегоНазначенияКлиентСервер.ДополнитьСтруктуру(Действия, ДействияЗаполненияВидаЦены(Объект), Истина);
	
	Действия.Вставить("ЗаполнитьНоменклатуруПартнераПоНоменклатуре", Истина);
	
	ПакетнаяОбработкаТабличнойЧастиСервер.ОбработатьСтрокуТЧ(СтрокаТоваров, Действия, КэшированныеЗначения);
	
	ЗаполнитьСлужебныеРеквизитыСоглашений(СтрокаТоваров);
	ПересчитатьСуммуНДСПоСкорректированнымСтавкам(КэшированныеЗначения);
	РассчитатьИтоговыеПоказателиЗаявки(ЭтотОбъект);

КонецПроцедуры

#КонецОбласти

#Область Контрагент

&НаСервере
Процедура ТоварыКонтрагентПриИзмененииНаСервере(КэшированныеЗначения)
	
	СтрокаТоваров = Объект.Товары.НайтиПоИдентификатору(Элементы.Товары.ТекущаяСтрока);
	
	Действия = Новый Структура;
	
	ПараметрыЗаполненияДоговора = ПакетнаяОбработкаТабличнойЧастиКлиентСервер.ПараметрыЗаполненияДоговораПоУмолчанию();
	ПараметрыЗаполненияДоговора.Организация = Объект.Организация;
	ПараметрыЗаполненияДоговора.ВалютаВзаиморасчетов = Объект.Валюта;
	ПараметрыЗаполненияДоговора.ТипДоговора = ДоступныеТипыДоговоров(КэшФормы);
	Действия.Вставить("ЗаполнитьДоговорПоУмолчанию", ПараметрыЗаполненияДоговора);
	ОбщегоНазначенияКлиентСервер.ДополнитьСтруктуру(Действия, ДействияЗаполненияНалогообложенияНДС(Объект, КэшФормы), Истина);
	ПакетнаяОбработкаТабличнойЧастиСервер.ОбработатьСтрокуТЧ(СтрокаТоваров, Действия, КэшированныеЗначения);
	
	ПересчитатьСуммуНДСПоСкорректированнымСтавкам(КэшированныеЗначения);
	
КонецПроцедуры

#КонецОбласти

#Область Соглашение

&НаСервере
Процедура ТоварыСоглашениеПриИзмененииНаСервере(КэшированныеЗначения)
	
	СтрокаТоваров = Объект.Товары.НайтиПоИдентификатору(Элементы.Товары.ТекущаяСтрока);
	
	Действия = Новый Структура;
	
	Действия.Вставить("ЗаполнитьКонтрагентаПартнераПоУмолчанию", Истина);
	
	ПараметрыЗаполненияДоговора = ПакетнаяОбработкаТабличнойЧастиКлиентСервер.ПараметрыЗаполненияДоговораПоУмолчанию();
	ПараметрыЗаполненияДоговора.Организация = Объект.Организация;
	ПараметрыЗаполненияДоговора.ВалютаВзаиморасчетов = Объект.Валюта;
	ПараметрыЗаполненияДоговора.ТипДоговора = ДоступныеТипыДоговоров(КэшФормы);
	Действия.Вставить("ЗаполнитьДоговорПоУмолчанию", ПараметрыЗаполненияДоговора);
	ОбщегоНазначенияКлиентСервер.ДополнитьСтруктуру(Действия, ДействияЗаполненияНалогообложенияНДС(Объект, КэшФормы), Истина);
	ОбщегоНазначенияКлиентСервер.ДополнитьСтруктуру(Действия, ДействияЗаполненияВидаЦены(Объект), Истина);
	
	Действия.Вставить("ЗаполнитьНоменклатуруПартнераПоНоменклатуре", Истина);
	
	ПакетнаяОбработкаТабличнойЧастиСервер.ОбработатьСтрокуТЧ(СтрокаТоваров, Действия, КэшированныеЗначения);
	
	КэшированныеЗначения.ОбработанныеСтроки.Очистить(); // Очистка строк с корректированной ставкой НДС
	
	ЗаполнитьСлужебныеРеквизитыСоглашений(СтрокаТоваров);
	РассчитатьИтоговыеПоказателиЗаявки(ЭтотОбъект);
	
КонецПроцедуры

#КонецОбласти

#Область Договор

&НаСервере
Процедура ТоварыДоговорПриИзмененииНаСервере(КэшированныеЗначения)
	
	СтрокаТоваров = Объект.Товары.НайтиПоИдентификатору(Элементы.Товары.ТекущаяСтрока);
	
	Действия = ДействияЗаполненияНалогообложенияНДС(Объект, КэшФормы);
	ПакетнаяОбработкаТабличнойЧастиСервер.ОбработатьСтрокуТЧ(СтрокаТоваров, Действия, КэшированныеЗначения);
	ПересчитатьСуммуНДСПоСкорректированнымСтавкам(КэшированныеЗначения);
	
КонецПроцедуры

#КонецОбласти

#Область НалогообложениеНДС

&НаСервере
Процедура ТоварыНалогообложениеНДСПриИзмененииНаСервере(КэшированныеЗначения)
	
	СтрокаТоваров = Объект.Товары.НайтиПоИдентификатору(Элементы.Товары.ТекущаяСтрока);
	
	Действия = ЗаявкаНаЗакупкуКлиентСервер.ДействияКорректировкиСтавкиНДС(Объект, УказаннаяСтавкаНДС(КэшФормы));
	ПакетнаяОбработкаТабличнойЧастиСервер.ОбработатьСтрокуТЧ(СтрокаТоваров, Действия, КэшированныеЗначения);
	ПересчитатьСуммуНДСПоСкорректированнымСтавкам(КэшированныеЗначения);
	
КонецПроцедуры

#КонецОбласти

#Область НоменклатураПартнера

&НаКлиенте
Процедура ОбработатьВыборНоменклатурыПартнера(ВыбранноеЗначение, ДополнительныеПараметры) Экспорт
	
	Если ВыбранноеЗначение = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Элементы.Товары.ТекущиеДанные.НоменклатураПартнера = ВыбранноеЗначение;
	Подключаемый_ПриИзменении_УстановитьДоступностьЭлементовПоСтатусуСервер(ДополнительныеПараметры.ЭлементФормы);
	ОбработатьИзменениеНоменклатурыПартнера();
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработатьИзменениеНоменклатурыПартнера()
	
	СтрокаТоваров = Элементы.Товары.ТекущиеДанные;
	
	НоменклатураПартнеровКлиент.УстановитьПараметрыВыбораУпаковки(Элементы.ТоварыНоменклатураПартнера.ПараметрыВыбора, СтрокаТоваров);
	НоменклатураПартнеровКлиент.УстановитьПараметрыВыбораУпаковки(Элементы.НоменклатураПартнера.ПараметрыВыбора, СтрокаТоваров);
	
	Действия = Новый Структура;
	
	Действия.Вставить("ЗаполнитьНоменклатуруПоНоменклатуреПартнера");
	
	Действия.Вставить("ПроверитьХарактеристикуПоВладельцу", СтрокаТоваров.Характеристика);
	Действия.Вставить("ЗаполнитьПризнакАртикул", Новый Структура("Номенклатура", "Артикул"));
	Действия.Вставить("ПроверитьЗаполнитьУпаковкуПоВладельцу", СтрокаТоваров.Упаковка);
	Действия.Вставить("ЗаполнитьПризнакТипНоменклатуры", Новый Структура("Номенклатура", "ТипНоменклатуры"));
	Действия.Вставить("ПриИзмененииТипаНоменклатуры",
		Новый Структура("ЕстьРаботы, ЕстьОтменено", Истина, Истина));
	
	Действия.Вставить(
		"ПроверитьЗаполнитьСклад",
		ПакетнаяОбработкаТабличнойЧастиКлиентСервер.ПолучитьСтруктуруЗаполненияСкладаВСтрокеТЧ(Объект, СкладГруппа));
		
	Действия.Вставить("ПересчитатьКоличествоЕдиниц");
	
	ОбщегоНазначенияКлиентСервер.ДополнитьСтруктуру(Действия, ДействияЗаполненияЦены(Объект), Истина);
	
	ПакетнаяОбработкаТабличнойЧастиКлиент.ОбработатьСтрокуТЧ(СтрокаТоваров, Действия, КэшированныеЗначения);
	
	АктуализироватьПодразделениеСтрокиТоваров(СтрокаТоваров, Объект.Подразделение);

	РассчитатьИтоговыеПоказателиЗаявки(ЭтотОбъект);
	УстановитьПризнакЗаполненияСклада(ЭтотОбъект);
	ОбновитьКартинкуГруппыСкладов();

КонецПроцедуры

#КонецОбласти

#Область ЖелаемаяДатаПоступления

&НаСервере
Процедура УстановитьЖелаемуюДатуПоступленияВШапке()
	Объект.ЖелаемаяДатаПоступления = МаксимальнаяЖелаемаяДатаПоступления();	
	УстановитьЖелаемуюДатуПоступленияВТаблице();
КонецПроцедуры

&НаСервере
Функция МаксимальнаяЖелаемаяДатаПоступления()
	
	ВозвращаемоеЗначение = '00010101';
	Для Каждого СтрокаТоваров Из Объект.Товары Цикл
		ВозвращаемоеЗначение = Макс(ВозвращаемоеЗначение, СтрокаТоваров.ЖелаемаяДатаПоступления);
	КонецЦикла;
	
	Возврат ВозвращаемоеЗначение;
	
КонецФункции

&НаСервере
Процедура УстановитьЖелаемуюДатуПоступленияВТаблице()
	
	Для Каждого СтрокаТоваров Из Объект.Товары Цикл
		СтрокаТоваров.ЖелаемаяДатаПоступления = Объект.ЖелаемаяДатаПоступления;
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти

&НаСервере
Процедура ЦельЗакупкиПриИзмененииНаСервере()
	
	ПараметрыВыбораСтатей = Документы.ЗаявкаНаЗакупку.ПараметрыВыбораСтатейИАналитик(Объект.ЦельЗакупки);
	ДоходыИРасходыСервер.ПриИзмененииПараметровВыбораСтатей(ЭтотОбъект, ПараметрыВыбораСтатей);
	
	ПодключаемыеКомандыКлиентСервер.ОбновитьКоманды(ЭтотОбъект, Объект);
	
	Если Не Документы.ЗаявкаНаЗакупку.КонтролироватьЛимитыБДР(Объект) Тогда
		Объект.НаправлениеДеятельности = Неопределено;
		Для Каждого СтрокаТЧ Из Объект.Товары Цикл
			СтрокаТЧ.СтатьяБюджетов = Неопределено;
		КонецЦикла;
	КонецЕсли;
	
	УправлениеФормой();
	
КонецПроцедуры

#КонецОбласти

#Область РазбивкаСтрок

&НаКлиенте
Процедура РазбитьСтрокуЗавершение(НоваяСтрока, ДополнительныеПараметры) Экспорт 
	
	Если НоваяСтрока = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ТекущаяСтрока = Элементы.Товары.ТекущиеДанные;
	
	Действия = ДействияПриИзмененииКоличества(Объект.ЦенаВключаетНДС);
	ПакетнаяОбработкаТабличнойЧастиКлиент.ОбработатьСтрокуТЧ(ТекущаяСтрока, Действия, КэшированныеЗначения);
	ПакетнаяОбработкаТабличнойЧастиКлиент.ОбработатьСтрокуТЧ(НоваяСтрока,   Действия, КэшированныеЗначения);
	
	ОбновитьКартинкуГруппыСкладов();
	
КонецПроцедуры

#КонецОбласти

#Область КоммерческиеПредложения

&НаСервере
Функция ЗаполнитьУсловияЗакупкиПоКоммерческимПредложениям(Знач ИдентификаторыСтрок)
	
	НомераСтрок = Новый Массив;
	Для Каждого ИдентификаторСтроки Из ИдентификаторыСтрок Цикл
		СтрокаТоваров = Объект.Товары.НайтиПоИдентификатору(ИдентификаторСтроки);
		НомераСтрок.Добавить(СтрокаТоваров.НомерСтроки);
	КонецЦикла;
	
	ПараметрыЗаполнения = КоммерческиеПредложенияДокументыУТ.ПараметрыЗаполненияУсловийЗакупкиПоКоммерческимПредложениям();
	ПараметрыЗаполнения.Документ = Объект.Ссылка;
	ПараметрыЗаполнения.ДатаКурса = ?(ЗначениеЗаполнено(Объект.Дата), Объект.Дата, ТекущаяДатаСеанса());
	ПараметрыЗаполнения.Валюта = Объект.Валюта;
	ПараметрыЗаполнения.ЦенаВключаетНДС = Объект.ЦенаВключаетНДС;
	
	ПараметрыЗаполнения.ЕстьПартнер = Истина;
	ПараметрыЗаполнения.ЕстьКонтрагент = Истина;
	ПараметрыЗаполнения.НомераСтрок = НомераСтрок;
	
	ОбщегоНазначенияКлиентСервер.ДополнитьСтруктуру(ПараметрыЗаполнения.ДействияСИзмененнымиСтроками, ДействияПересчетаСуммы(Объект.ЦенаВключаетНДС), Истина);
	ПараметрыЗаполнения.ДействияСИзмененнымиСтроками.Вставить("ЗаполнитьНоменклатуруПартнераПоНоменклатуре", Истина);
	
	// Соглашение в запросах КП не заполняется, заполняем значением по умолчанию:
	ПараметрыЗаполненияСоглашения = ПакетнаяОбработкаТабличнойЧастиКлиентСервер.ПараметрыЗаполненияСоглашенийПоставщика();
	ПараметрыЗаполненияСоглашения.ХозяйственнаяОперация = Документы.ЗаявкаНаЗакупку.ДоступныеОперацииСоглашений();
	ПараметрыЗаполнения.ДействияСИзмененнымиСтроками.Вставить("ЗаполнитьСоглашениеПоставщикаПоУмолчанию", ПараметрыЗаполненияСоглашения);
	
	ПараметрыЗаполненияДоговора = ПакетнаяОбработкаТабличнойЧастиКлиентСервер.ПараметрыЗаполненияДоговораПоУмолчанию();
	ПараметрыЗаполненияДоговора.Организация = Объект.Организация;
	ПараметрыЗаполненияДоговора.ВалютаВзаиморасчетов = Объект.Валюта;
	ПараметрыЗаполненияДоговора.ТипДоговора = ДоступныеТипыДоговоров(КэшФормы);
	ПараметрыЗаполнения.ДействияСИзмененнымиСтроками.Вставить("ЗаполнитьДоговорПоУмолчанию", ПараметрыЗаполненияДоговора);
	ОбщегоНазначенияКлиентСервер.ДополнитьСтруктуру(
		ПараметрыЗаполнения.ДействияСИзмененнымиСтроками,
		ДействияЗаполненияНалогообложенияНДС(Объект, КэшФормы),
		Истина);
	
	РезультатЗаполнения = КоммерческиеПредложенияДокументыУТ.ЗаполнитьУсловияЗакупкиПоКоммерческимПредложениям(Объект.Товары, ПараметрыЗаполнения);
	ЗаполнитьСлужебныеРеквизитыСоглашений(РезультатЗаполнения.ИзмененныеСтроки);
	
	ВозвращаемоеЗначение = Новый Структура;
	ВозвращаемоеЗначение.Вставить("Отказ", РезультатЗаполнения.Отказ);
	ВозвращаемоеЗначение.Вставить("ТекстОшибки", РезультатЗаполнения.ТекстОшибки);
	ВозвращаемоеЗначение.Вставить("НомераСтрокСНезаполненнымиУсловиямиЗакупки", РезультатЗаполнения.НомераСтрокСНезаполненнымиУсловиямиЗакупки);
	
	Возврат ВозвращаемоеЗначение;
	
КонецФункции

#КонецОбласти

#Область ОтменаСтрок

&НаКлиентеНаСервереБезКонтекста
Процедура ТоварыОбновитьОтборСтрокПоОтмененным(Форма, СкрытьОтмененныеСтроки, УстановитьПометкуТоварыСкрыватьОтмененныеСтроки = Истина)
	
	Если СкрытьОтмененныеСтроки Тогда
		Форма.Элементы.Товары.ОтборСтрок = Новый ФиксированнаяСтруктура("Отменено", Ложь);
	Иначе
		Форма.Элементы.Товары.ОтборСтрок = Неопределено;
	КонецЕсли;
	
	Если УстановитьПометкуТоварыСкрыватьОтмененныеСтроки Тогда
		Форма.Элементы.ТоварыСкрыватьОтмененныеСтроки.Пометка = СкрытьОтмененныеСтроки;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция ВсеСтрокиОтменены()
	
	Для Каждого СтрокаТоваров Из Объект.Товары Цикл
		
		Если Не СтрокаТоваров.Отменено Тогда
			Возврат Ложь;
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Истина;
	
КонецФункции

#КонецОбласти

#Область ЗаписьДокумента

&НаКлиенте
Процедура Подключаемый_ОбработатьЗаписьОбъекта()
	
	ОбщегоНазначенияУТКлиент.ОбработатьЗаписьОбъектаВФорме(ЭтотОбъект, ПараметрыДляЗаписи);
	
КонецПроцедуры

&НаКлиенте
Процедура Подключаемый_ЗакрытьФорму()
	
	Если Открыта() Тогда
		Закрыть();
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область УправлениеФормой

&НаСервере
Процедура УправлениеФормой()

	УправлениеФормойПоСкладу();
	УстановитьДоступностьТоварыСНДС();
	УстановитьДоступностьЭлементовПоСтатусуСервер();
	Элементы.ЖелаемаяДатаПоступления.Видимость = Объект.ПоступлениеОднойДатой;
	Элементы.ТоварыСоздатьЗаказПоставщику.Видимость =
		Перечисления.СтатусыЗаявокНаЗакупку.Согласована(Объект.Статус)
		И ЗначениеИзКэша(КэшФормы, "ПравоДобавленияЗаказаПоставщику");
	
	ВидимостьПолейАналитикЛимитирования = Документы.ЗаявкаНаЗакупку.КонтролироватьЛимитыБДР(Объект);
	Элементы.НаправлениеДеятельности.Видимость = ВидимостьПолейАналитикЛимитирования;
	Элементы.ТоварыСтатьяБюджетов.Видимость = ВидимостьПолейАналитикЛимитирования;
	
КонецПроцедуры

&НаСервере
Процедура УстановитьУсловноеОформление()
	
	УсловноеОформлениеСписковКлиентСервер.НовыйЭлементОформления(ЭтотОбъект,
		Элементы.ТоварыЖелаемаяДатаПоступления.Имя,
		"Видимость",
		Ложь,
		"Объект.ПоступлениеОднойДатой",
		Истина);
		
	ЦеныПредприятияЗаполнениеСервер.УстановитьУсловноеОформлениеЦенаВключаетНДС(ЭтотОбъект);
	НоменклатураСервер.УстановитьУсловноеОформлениеЕдиницИзмерения(ЭтотОбъект);
	НоменклатураСервер.УстановитьУсловноеОформлениеХарактеристикНоменклатуры(ЭтотОбъект);
	УстановитьУсловноеОформлениеСклада();
	НоменклатураСервер.УстановитьУсловноеОформлениеНазначенияНоменклатуры(ЭтотОбъект,,, Ложь);
	УстановитьУсловноеОформлениеПодразделения();
	УстановитьУсловноеОформлениеСоглашения();
	УстановитьУсловноеОформлениеДоговора();
	
	ЭлементыЗависимыеОтПоставщика = Новый Массив;
	ЭлементыЗависимыеОтПоставщика.Добавить(Элементы.ТоварыКонтрагент.Имя);
	ЭлементыЗависимыеОтПоставщика.Добавить(Элементы.ТоварыНоменклатураПартнера.Имя);
	ЭлементыЗависимыеОтПоставщика.Добавить(Элементы.ТоварыВидЦеныПоставщика.Имя);
	
	УсловноеОформлениеСписковКлиентСервер.НовыйЭлементОформленияНедоступногоПоля(ЭтотОбъект,
		ЭлементыЗависимыеОтПоставщика,
		ЦветаСтиля.ЦветНедоступногоТекста,
		ТекстВыберитеПоставщика(),
		"Объект.Товары.Партнер",
		Истина,
		ВидСравненияКомпоновкиДанных.НеЗаполнено);
	
	УсловноеОформлениеСписковКлиентСервер.НовыйЭлементОформленияНедоступногоПоля(ЭтотОбъект,
		Элементы.ТоварыПредставлениеУсловийЗакупки.Имя,
		ЦветаСтиля.ЦветНедоступногоТекста,
		НСтр("ru = '<Не заполнены>'"),
		"Объект.Товары.ПредставлениеУсловийЗакупки",
		Истина,
		ВидСравненияКомпоновкиДанных.НеЗаполнено);
	
	ЗаказыСервер.УстановитьОформлениеОтмененнойСтроки(УсловноеОформление,
		Элементы.Товары,
		Элементы.ТоварыОтменено.Имя,,
		Элементы.ТоварыЦена.Имя,
		Элементы.ТоварыСумма.Имя);
	
	УчетНДСУП.УстановитьУсловноеОформлениеСуммНДСПоНалогообложениюЗакупки(ЭтотОбъект,
		Элементы.ТоварыСтавкаНДС.Имя,
		Элементы.ТоварыСуммаНДС.Имя,
		Элементы.ТоварыСуммаСНДС.Имя,
		"Объект.Товары.НалогообложениеНДС");
	
КонецПроцедуры

&НаСервере
Процедура УстановитьУсловноеОформлениеСклада()
	
	// Скрыт, если указан в шапке (не группа):
	СкладыСервер.УстановитьУсловноеОформлениеСкладаВТЧ(ЭтотОбъект);
	
	ТоварМногооборотнаяТара = Новый СписокЗначений;
	ТоварМногооборотнаяТара.Добавить(Перечисления.ТипыНоменклатуры.Товар);
	ТоварМногооборотнаяТара.Добавить(Перечисления.ТипыНоменклатуры.МногооборотнаяТара);
	
	// Скрыт, если тип номенклатуры не хранится на складе:
	ЭлементОформления = УсловноеОформлениеСписковКлиентСервер.НовыйЭлементОформления(
		ЭтотОбъект,
		Элементы.ТоварыСклад.Имя,
		"Видимость",
		Ложь,
		"Объект.Товары.ТипНоменклатуры",
		ТоварМногооборотнаяТара,
		ВидСравненияКомпоновкиДанных.НеВСписке);
		
	КомпоновкаДанныхКлиентСервер.ДобавитьОтбор(ЭлементОформления.Отбор,
		"Объект.Товары.Склад",
		Истина,
		ВидСравненияКомпоновкиДанных.НеЗаполнено);
	
	// Запрет редактирования, если тип номенклатуры не хранится на складе:
	ПараметрыУсловногоОформления = СкладыСервер.ПараметрыУсловногоОформленияСкладаВТЧПоТипуНоменклатуры();
	ПараметрыУсловногоОформления.Форма = ЭтотОбъект;
	ПараметрыУсловногоОформления.ПроверятьЗаполненностьСклада = Истина;
	СкладыСервер.УстановитьУсловноеОформлениеСкладаВТЧПоТипуНоменклатуры(ПараметрыУсловногоОформления);
	
	// Отметка незаполненного:
	ЭлементОформления = УсловноеОформлениеСписковКлиентСервер.НовыйПростойЭлементОформленияСПараметромОформления(
		ЭтотОбъект,
		Элементы.ТоварыСклад.Имя,
		"ОтметкаНезаполненного",
		Истина);
		
	КомпоновкаДанныхКлиентСервер.ДобавитьОтбор(ЭлементОформления.Отбор,
		"Объект.Товары.Склад",
		Истина,
		ВидСравненияКомпоновкиДанных.НеЗаполнено);
		
	КомпоновкаДанныхКлиентСервер.ДобавитьОтбор(ЭлементОформления.Отбор,
		"Объект.Товары.ТипНоменклатуры",
		ТоварМногооборотнаяТара,
		ВидСравненияКомпоновкиДанных.ВСписке);
	
	ОбщегоНазначенияУТ.УстановитьСнятьОтметкуНезаполненного(
		УсловноеОформление, "ТоварыСклад", "Объект.Товары.Склад", "Объект.Товары.СкладОбязателен");
	
	ОбщегоНазначенияУТ.УстановитьСнятьОтметкуНезаполненного(
		УсловноеОформление, "Склад", "Объект.Склад", "СкладОбязателен");
КонецПроцедуры

&НаСервере
Процедура УстановитьУсловноеОформлениеПодразделения()
	
	ТоварМногооборотнаяТара = Новый СписокЗначений;
	ТоварМногооборотнаяТара.Добавить(Перечисления.ТипыНоменклатуры.Товар);
	ТоварМногооборотнаяТара.Добавить(Перечисления.ТипыНоменклатуры.МногооборотнаяТара);
	
	// Отключение видимости, если в таблице указывается склад:
	ЭлементОформления = УсловноеОформлениеСписковКлиентСервер.НовыйПростойЭлементОформленияСПараметромОформления(
		ЭтотОбъект,
		Элементы.ТоварыПодразделение.Имя,
		"Видимость",
		Ложь);
	 
	КомпоновкаДанныхКлиентСервер.ДобавитьОтбор(
		ЭлементОформления.Отбор,
		"Объект.Товары.ТипНоменклатуры",
		ТоварМногооборотнаяТара,
		ВидСравненияКомпоновкиДанных.ВСписке);
		
	КомпоновкаДанныхКлиентСервер.ДобавитьОтбор(
		ЭлементОформления.Отбор,
		"СкладГруппа",
		Истина);
		
	// Поясняющая надпись, если склады не в табличной части:
	ЭлементОформления = УсловноеОформлениеСписковКлиентСервер.НовыйПростойЭлементОформления(
		ЭтотОбъект,
		Элементы.ТоварыПодразделение.Имя);
		
	ЭлементОформления.Оформление.УстановитьЗначениеПараметра("ТолькоПросмотр", Истина);
	ЭлементОформления.Оформление.УстановитьЗначениеПараметра("Текст", НСтр("ru = '<для услуг и работ>'"));
	ЭлементОформления.Оформление.УстановитьЗначениеПараметра("ЦветТекста", ЦветаСтиля.ТекстЗапрещеннойЯчейкиЦвет);
	ЭлементОформления.Оформление.УстановитьЗначениеПараметра("ОтметкаНезаполненного", Ложь);
		
	КомпоновкаДанныхКлиентСервер.ДобавитьОтбор(ЭлементОформления.Отбор,
		"Объект.Товары.ТипНоменклатуры",
		ТоварМногооборотнаяТара,
		ВидСравненияКомпоновкиДанных.ВСписке);
	
	КомпоновкаДанныхКлиентСервер.ДобавитьОтбор(
		ЭлементОформления.Отбор,
		"СкладГруппа",
		Ложь);
	
	// Отключение проверки для работ по агентской закупке:
	ЭлементОформления = УсловноеОформлениеСписковКлиентСервер.НовыйПростойЭлементОформленияСПараметромОформления(
		ЭтотОбъект,
		Элементы.ТоварыПодразделение.Имя,
		"ОтметкаНезаполненного",
		Ложь);
		
	КомпоновкаДанныхКлиентСервер.ДобавитьОтбор(ЭлементОформления.Отбор,
		"Объект.Товары.ТипНоменклатуры",
		Перечисления.ТипыНоменклатуры.Работа);
		
	КомпоновкаДанныхКлиентСервер.ДобавитьОтбор(ЭлементОформления.Отбор,
		"Объект.Товары.ТипНазначения",
		Перечисления.ТипыНазначений.ПоставкаПодПринципала);
		
КонецПроцедуры

&НаСервере
Процедура УстановитьПараметрыВыбораТоварыСклад()
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	Склады.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.Склады КАК Склады
	|ГДЕ
	|	Склады.Ссылка В ИЕРАРХИИ(&ГруппаСкладов)
	|	И Склады.ЭтоГруппа = ЛОЖЬ
	|	И Склады.ВыборГруппы <> ЗНАЧЕНИЕ(Перечисление.ВыборГруппыСкладов.Запретить)");

	Запрос.УстановитьПараметр("ГруппаСкладов", Объект.Склад);
	ДоступныеСклады = Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Ссылка");
	
	Элементы.ТоварыСклад.ПараметрыВыбора = Новый ФиксированныйМассив(Новый Массив);
	ОбщегоНазначенияУТКлиентСервер.ДобавитьПараметрВыбора(Элементы.ТоварыСклад, "Ссылка", ДоступныеСклады);

КонецПроцедуры

&НаКлиенте
Процедура УстановитьОтборНоменклатурыПартнера()
	
	КлючИзменен = Ложь;
	ТекущиеДанные = Элементы.Товары.ТекущиеДанные;
	ОтборНоменклатурыПартнера = ЗначениеИзКэша(КэшФормы, "ОтборНоменклатурыПартнера");
	
	Для Каждого КлючИЗначение Из ОтборНоменклатурыПартнера Цикл
		
		Если ТекущиеДанные[КлючИЗначение.Ключ] <> КлючИЗначение.Значение Тогда
			КлючИзменен = Истина;
			Прервать;
		КонецЕсли;
		
	КонецЦикла;
	
	Если Не КлючИзменен Тогда
		Возврат;
	КонецЕсли;
	
	ЗаполнитьЗначенияСвойств(ОтборНоменклатурыПартнера, ТекущиеДанные);
	
	НоменклатураПартнеровКлиент.ЗаполнитьСписокВыбораНоменклатурыПартнера(
		ОтборНоменклатурыПартнера.Партнер,
		ТекущиеДанные,
		Элементы.ТоварыНоменклатураПартнера.СписокВыбора);
		
	Элементы.НоменклатураПартнера.СписокВыбора.Очистить();
	ОбщегоНазначенияКлиентСервер.ДополнитьСписок(
		Элементы.НоменклатураПартнера.СписокВыбора,
		Элементы.ТоварыНоменклатураПартнера.СписокВыбора,
		Ложь);
		
	НоменклатураПартнеровКлиент.УстановитьПараметрыВыбораУпаковки(
		Элементы.ТоварыНоменклатураПартнера.ПараметрыВыбора,
		ТекущиеДанные);
		
	НоменклатураПартнеровКлиент.УстановитьПараметрыВыбораУпаковки(
		Элементы.НоменклатураПартнера.ПараметрыВыбора,
		ТекущиеДанные);
		
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Процедура УстановитьПризнакЗаполненияСклада(Форма)
	
	Форма.СкладОбязателен = ?(Форма.Объект.Товары.Итог("СкладОбязателен") = 0, 0, 1);
	
КонецПроцедуры

#КонецОбласти

#Область УправлениеСтрокойТоваров

&НаКлиенте
Процедура УправлениеСтрокойТоваров()
	
	СтрокаТоваров = Элементы.Товары.ТекущиеДанные;
	
	УстановитьДоступностьСоглашения(СтрокаТоваров);
	УстановитьДоступностьДоговора(СтрокаТоваров);
	
	ДоступныЭлементыЗависимыеОтПоставщика = Ложь;
	ПодсказкаВводаЭлементовЗависимыхОтПоставщика = "";
	СтрокаВыделена = Истина;
	
	Если СтрокаТоваров = Неопределено Тогда
		// Элементы недоступны
		СтрокаВыделена = Ложь;
	ИначеЕсли Не ЗначениеЗаполнено(СтрокаТоваров.Партнер) Тогда
		ПодсказкаВводаЭлементовЗависимыхОтПоставщика = ТекстВыберитеПоставщика();
	Иначе
		ДоступныЭлементыЗависимыеОтПоставщика = Истина;
	КонецЕсли;
		
	ЭлементыЗависимыеОтПоставщика = Новый Массив;
	ЭлементыЗависимыеОтПоставщика.Добавить(Элементы.Контрагент);
	ЭлементыЗависимыеОтПоставщика.Добавить(Элементы.НоменклатураПартнера);
	ЭлементыЗависимыеОтПоставщика.Добавить(Элементы.ВидЦеныПоставщика);
	
	Для Каждого ЭлементФормы // ПолеФормы
		Из ЭлементыЗависимыеОтПоставщика Цикл 
		
		ЭлементФормы.Доступность    = ДоступныЭлементыЗависимыеОтПоставщика;
		ЭлементФормы.ПодсказкаВвода = ПодсказкаВводаЭлементовЗависимыхОтПоставщика;
		 
	КонецЦикла;
	
	ПараметрыАктивизацииНаКлиенте = Новый Структура;
	ДанныеШапки = Новый Структура;
	ДанныеШапки.Вставить("Дата", Объект.Дата);
	ДанныеШапки.Вставить("Ссылка", Объект.Ссылка);
	ПараметрыАктивизацииНаКлиенте.Вставить("ДанныеШапки", ДанныеШапки);
	
	ДанныеСтроки = Новый Структура;
	ДанныеСтроки.Вставить("Контрагент", ПредопределенноеЗначение("Справочник.Контрагенты.ПустаяСсылка"));
	ДанныеСтроки.Вставить("Договор", ПредопределенноеЗначение("Справочник.ДоговорыКонтрагентов.ПустаяСсылка"));
	ДанныеСтроки.Вставить("ХозяйственнаяОперация", ПредопределенноеЗначение("Перечисление.ХозяйственныеОперации.ПустаяСсылка"));
	ДанныеСтроки.Вставить("НалогообложениеНДС", ПредопределенноеЗначение("Перечисление.ТипыНалогообложенияНДС.ПустаяСсылка"));
	ДанныеСтроки.Вставить("СтавкаНДС", ПредопределенноеЗначение("Справочник.СтавкиНДС.ПустаяСсылка"));
	ПараметрыАктивизацииНаКлиенте.Вставить("ДанныеСтроки", ДанныеСтроки);
	Если СтрокаВыделена Тогда
		ЗаполнитьЗначенияСвойств(ДанныеСтроки, СтрокаТоваров);
	КонецЕсли;
	
	ПараметрыАктивизации = ПараметрыАктивизацииСтроки(ПараметрыАктивизацииНаКлиенте);
	
	Элементы.НалогообложениеНДС.Доступность = ПараметрыАктивизации.ДоступностьНалогообложения;
	Элементы.НалогообложениеНДС.СписокВыбора.Очистить();
	ОбщегоНазначенияКлиентСервер.ДополнитьСписок(
		Элементы.НалогообложениеНДС.СписокВыбора,
		ПараметрыАктивизации.СписокВыбораНалогообложения,
		Ложь);
	
	Элементы.ТоварыНалогообложениеНДС.ТолькоПросмотр = Не ПараметрыАктивизации.ДоступностьНалогообложения;
	Элементы.ТоварыНалогообложениеНДС.СписокВыбора.Очистить();
	ОбщегоНазначенияКлиентСервер.ДополнитьСписок(
		Элементы.ТоварыНалогообложениеНДС.СписокВыбора,
		ПараметрыАктивизации.СписокВыбораНалогообложения,
		Ложь);
	
	ТипыНалогообложенияБезНДС = УчетНДСУПКлиентСервер.ТипыНалогообложенияСкрывающиеРеквизитыНДС(Элементы.ТоварыСтавкаНДС);
	БлокироватьРеквизитыНДС = Не СтрокаВыделена
		Или ТипыНалогообложенияБезНДС.Найти(ДанныеСтроки.НалогообложениеНДС) <> Неопределено;
		
	БлокироватьСуммуНДС = БлокироватьРеквизитыНДС
		Или Не ЗначениеЗаполнено(ДанныеСтроки.СтавкаНДС)
		Или ПараметрыАктивизации.СтавкаНДС0;
	
	// При недоступной строке элементы должны быть оформлены в одном стиле:
	Элементы.Партнер.Доступность   = СтрокаВыделена;
	Элементы.СтавкаНДС.Доступность = Не БлокироватьРеквизитыНДС;
	Элементы.Цена.Доступность      = СтрокаВыделена;
	Элементы.Сумма.Доступность     = СтрокаВыделена;
	Элементы.СуммаНДС.Доступность  = Не БлокироватьСуммуНДС;
	Элементы.СуммаСНДС.Доступность = СтрокаВыделена;
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ПараметрыАктивизацииСтроки(ПараметрыАктивизацииНаКлиенте)
	
	// Элемент нельзя передавать с клиента на сервер,
	//    а также модификация значения в таблице отличается от модификации в шапке.
	//    Поэтому используем структуру как адаптер для получения необходимых свойств.
	ОписаниеЭлементаФормы = Новый Структура;
	ОписаниеЭлементаФормы.Вставить("СписокВыбора", Новый СписокЗначений);
	ОписаниеЭлементаФормы.Вставить("Видимость",    Истина);
	ОписаниеЭлементаФормы.Вставить("Заголовок",    "");
	
	ПараметрыЗаполнения          = УчетНДСУПКлиентСервер.ПараметрыПакетногоЗаполненияНалогообложенияНДСЗакупки();
	ПараметрыЗаполнения.Дата     = ПараметрыАктивизацииНаКлиенте.ДанныеШапки.Дата;
	ПараметрыЗаполнения.Документ = ПараметрыАктивизацииНаКлиенте.ДанныеШапки.Ссылка;
	
	ПараметрыНалогообложенияНДС = Документы.ЗаявкаНаЗакупку.ПараметрыНалогообложенияНДС(
		ПараметрыАктивизацииНаКлиенте.ДанныеСтроки,
		ПараметрыЗаполнения);
	
	УчетНДСУП.ЗаполнитьСписокВыбораНалогообложенияНДСЗакупки(
		ОписаниеЭлементаФормы,
		ПараметрыАктивизацииНаКлиенте.ДанныеСтроки.НалогообложениеНДС,
		ПараметрыНалогообложенияНДС);
	
	СтавкаНДС0 = Не ЗначениеЗаполнено(ПараметрыАктивизацииНаКлиенте.ДанныеСтроки.СтавкаНДС)
		Или УчетНДСУП.НезначащаяСтавка(ПараметрыАктивизацииНаКлиенте.ДанныеСтроки.СтавкаНДС);
	
	ВозвращаемоеЗначение = Новый Структура;
	ВозвращаемоеЗначение.Вставить("СписокВыбораНалогообложения", ОписаниеЭлементаФормы.СписокВыбора);
	ВозвращаемоеЗначение.Вставить("ДоступностьНалогообложения", ОписаниеЭлементаФормы.Видимость);
	ВозвращаемоеЗначение.Вставить("СтавкаНДС0", СтавкаНДС0);
	
	Возврат ВозвращаемоеЗначение;
	
КонецФункции

#Область Соглашение

&НаКлиенте
Процедура УстановитьДоступностьСоглашения(СтрокаТоваров)
	
	ЭлементФормы = Элементы.Найти("Соглашение");
	Если ЭлементФормы = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ЭлементДоступен = Ложь;
	ПодсказкаВвода = "";
	
	Если СтрокаТоваров = Неопределено Тогда
		// Элемент не доступен
	ИначеЕсли ЗначениеЗаполнено(СтрокаТоваров.Соглашение) Тогда
		ЭлементДоступен = Истина; // Недействующее соглашение должно быть доступно
	ИначеЕсли Не ЗначениеЗаполнено(СтрокаТоваров.Партнер) Тогда
		ПодсказкаВвода = ТекстВыберитеПоставщика();
	ИначеЕсли СтрокаТоваров.КоличествоСоглашений = 0 Тогда
		ПодсказкаВвода = НСтр("ru = '<соглашения отсутствуют>'");
	Иначе
		ЭлементДоступен = Истина;
	КонецЕсли;

	ЭлементФормы.Доступность    = ЭлементДоступен;
	ЭлементФормы.ПодсказкаВвода = ПодсказкаВвода;
	
КонецПроцедуры

&НаСервере
Процедура УстановитьУсловноеОформлениеСоглашения()
	
	ИмяЭлемента = Элементы.ТоварыСоглашение.Имя;
	
	ЭлементОформления = УсловноеОформлениеСписковКлиентСервер.НовыйЭлементОформленияНедоступногоПоля(ЭтотОбъект,
		ИмяЭлемента,
		ЦветаСтиля.ЦветНедоступногоТекста,
		НСтр("ru = '<соглашения отсутствуют>'"),
		"Объект.Товары.КоличествоСоглашений",
		Истина,
		ВидСравненияКомпоновкиДанных.НеЗаполнено);
		
	// Недействующее соглашение должно быть доступно
	КомпоновкаДанныхКлиентСервер.ДобавитьОтбор(ЭлементОформления.Отбор,
		"Объект.Товары.Соглашение",
		Истина,
		ВидСравненияКомпоновкиДанных.НеЗаполнено);
		
	УсловноеОформлениеСписковКлиентСервер.НовыйЭлементОформленияНедоступногоПоля(ЭтотОбъект,
		ИмяЭлемента,
		ЦветаСтиля.ЦветНедоступногоТекста,
		ТекстВыберитеПоставщика(),
		"Объект.Товары.Партнер",
		Истина,
		ВидСравненияКомпоновкиДанных.НеЗаполнено);
	
КонецПроцедуры

#КонецОбласти

#Область Договор

&НаКлиенте
Процедура УстановитьДоступностьДоговора(СтрокаТоваров)
	
	ЭлементФормы = Элементы.Найти("Договор");
	Если ЭлементФормы = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ЭлементДоступен = Ложь;
	ПодсказкаВвода = "";
	Если СтрокаТоваров = Неопределено Тогда
		// Элемент не доступен
	ИначеЕсли Не ЗначениеЗаполнено(Объект.Организация) Тогда
		ПодсказкаВвода = НСтр("ru = '<выберите организацию>'");
	ИначеЕсли Не ЗначениеЗаполнено(СтрокаТоваров.Партнер) Тогда
		ПодсказкаВвода = ТекстВыберитеПоставщика();
	ИначеЕсли Не ЗначениеЗаполнено(СтрокаТоваров.Контрагент) Тогда
		ПодсказкаВвода = НСтр("ru = '<выберите контрагента>'");
	ИначеЕсли Не СтрокаТоваров.ИспользуютсяДоговорыКонтрагентов Тогда
		ПодсказкаВвода = НСтр("ru = '<не используется>'");
	Иначе
		ЭлементДоступен = Истина;
	КонецЕсли;
	
	ЭлементФормы.Доступность    = ЭлементДоступен;
	ЭлементФормы.ПодсказкаВвода = ПодсказкаВвода;
	
