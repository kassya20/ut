&НаКлиенте
Процедура ТоварыПриАктивизацииЯчейки(Элемент)
	
	Если Элемент.ТекущийЭлемент = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если Элемент.ТекущийЭлемент.Имя = "ТоварыНоменклатураПартнера" Тогда
		УстановитьОтборНоменклатурыПартнера();
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ТоварыПередУдалением(Элемент, Отказ)
	РаботаСТабличнымиЧастямиКлиент.КэшироватьТекущуюСтроку(Элементы.Товары, ЭтотОбъект);
КонецПроцедуры

&НаКлиенте
Процедура ТоварыПриНачалеРедактирования(Элемент, НоваяСтрока, Копирование)
	
	РаботаСТабличнымиЧастямиКлиент.КэшироватьТекущуюСтроку(Элементы.Товары, ЭтотОбъект);
	
	СтрокаТоваров = Элементы.Товары.ТекущиеДанные;
	Если НоваяСтрока И Не Копирование Тогда
		
		СтрокаТоваров.Подразделение = Объект.Подразделение;
		
		Если Объект.ПоступлениеОднойДатой Тогда
			СтрокаТоваров.ЖелаемаяДатаПоступления = Объект.ЖелаемаяДатаПоступления;
		КонецЕсли;
		
		СтрокаТоваров.НалогообложениеНДС = ПредопределенноеЗначение("Перечисление.ТипыНалогообложенияНДС.ПродажаОблагаетсяНДС");
		
		Действия = Новый Структура;
		Действия.Вставить("ЗаполнитьПредставлениеУсловийЗакупки"); // Заполнение "пустым значением"
		ПакетнаяОбработкаТабличнойЧастиКлиент.ОбработатьСтрокуТЧ(СтрокаТоваров, Действия, КэшированныеЗначения);
		
	КонецЕсли;
	
	Если НоваяСтрока Тогда
		// Активизация выполнятся перед заполнением данных в строке
		//   Поэтому вызываем для расчета по заполненным данным:
		УправлениеСтрокойТоваров();
	КонецЕсли;
	
	РассчитатьИтоговыеПоказателиЗаявки(ЭтотОбъект);
	
КонецПроцедуры

&НаКлиенте
Процедура ТоварыПриОкончанииРедактирования(Элемент, НоваяСтрока, ОтменаРедактирования)
	
	СтрокаТоваров = Элементы.Товары.ТекущиеДанные;
	
	Если Не ОтменаРедактирования Тогда
		
		КэшСтроки = ?(НоваяСтрока, Неопределено, РаботаСТабличнымиЧастямиКлиентСервер.КэшСтроки(Элементы.Товары, ЭтотОбъект));
		СкладыКлиент.ОбновитьТаблицуСкладов(ТаблицаСкладов, СтрокаТоваров, КэшСтроки, СкладГруппа);
		ВсегоСкладов = ТаблицаСкладов.Количество();
		СкладыКлиентСервер.ОбновитьКартинкуГруппыСкладов(НадписьНесколькоСкладов, Элементы.КартинкаНесколькоСкладов, ВсегоСкладов);
	
	КонецЕсли;
	
	УстановитьПризнакЗаполненияСклада(ЭтотОбъект);
	
КонецПроцедуры

&НаКлиенте
Процедура ТоварыПослеУдаления(Элемент)
	РассчитатьИтоговыеПоказателиЗаявки(ЭтотОбъект);
	ОбновитьКартинкуГруппыСкладов();
	УстановитьПризнакЗаполненияСклада(ЭтотОбъект);
КонецПроцедуры

#КонецОбласти

&НаКлиенте
Процедура ТоварыНоменклатураПриИзменении(Элемент)
	
	ОчиститьСообщения();
	
	СтрокаТоваров = Элементы.Товары.ТекущиеДанные;
	
	Действия = Новый Структура;
	Действия.Вставить("ЗаполнитьПризнакТипНоменклатуры", Новый Структура("Номенклатура", "ТипНоменклатуры"));
	Действия.Вставить("ПриИзмененииТипаНоменклатуры", Новый Структура("ЕстьРаботы, ЕстьОтменено", Истина, Истина));
	Действия.Вставить("ПроверитьХарактеристикуПоВладельцу", СтрокаТоваров.Характеристика);
	Действия.Вставить("ЗаполнитьПризнакАртикул", Новый Структура("Номенклатура", "Артикул"));
	Действия.Вставить("ПроверитьЗаполнитьУпаковкуПоВладельцу", СтрокаТоваров.Упаковка);
	Действия.Вставить("ПересчитатьКоличествоЕдиниц");
	Действия.Вставить(
		"ПроверитьЗаполнитьСклад",
		ПакетнаяОбработкаТабличнойЧастиКлиентСервер.ПолучитьСтруктуруЗаполненияСкладаВСтрокеТЧ(Объект, СкладГруппа));
	
	Действия.Вставить("ЗаполнитьНоменклатуруПартнераПоНоменклатуре", Истина);
	
	ОбщегоНазначенияКлиентСервер.ДополнитьСтруктуру(Действия, ДействияЗаполненияЦены(Объект), Истина);
	ОбщегоНазначенияКлиентСервер.ДополнитьСтруктуру(Действия, ДействияЗаполненияСтавкиНДС(Объект, КэшФормы), Истина);
		
	Если КонтролироватьАссортимент(КэшФормы) Тогда
		Действия.Вставить("ПроверитьАссортиментСтроки", ПараметрыПроверкиАссортимента(Объект));
	КонецЕсли;
	
	ПакетнаяОбработкаТабличнойЧастиКлиент.ОбработатьСтрокуТЧ(СтрокаТоваров, Действия, КэшированныеЗначения);
	
	АктуализироватьПодразделениеСтрокиТоваров(СтрокаТоваров, Объект.Подразделение);
	УстановитьПризнакЗаполненияСклада(ЭтотОбъект);
	РассчитатьИтоговыеПоказателиЗаявки(ЭтотОбъект);
	УправлениеСтрокойТоваров();
	
КонецПроцедуры

&НаКлиенте
Процедура ТоварыХарактеристикаПриИзменении(Элемент)
	
	СтрокаТоваров = Элементы.Товары.ТекущиеДанные;
	
	Действия = Новый Структура;
	Действия.Вставить("ЗаполнитьНоменклатуруПартнераПоНоменклатуре", Истина);
	ОбщегоНазначенияКлиентСервер.ДополнитьСтруктуру(Действия, ДействияЗаполненияЦены(Объект), Истина);
	ОбщегоНазначенияКлиентСервер.ДополнитьСтруктуру(Действия, ДействияЗаполненияСтавкиНДС(Объект, КэшФормы), Истина);
	Действия.Вставить("ХарактеристикаПриИзмененииПереопределяемый", Новый Структура("ИмяФормы, ИмяТабличнойЧасти",
		ИмяФормы, "Товары"));

	ПакетнаяОбработкаТабличнойЧастиКлиент.ОбработатьСтрокуТЧ(СтрокаТоваров, Действия, КэшированныеЗначения);

	РассчитатьИтоговыеПоказателиЗаявки(ЭтотОбъект);
	УправлениеСтрокойТоваров();
	
КонецПроцедуры

