#Область ПодборыИОбработкаПроверкиКоличества

&НаКлиенте
Процедура СообщитьОбОшибкахОткрытияПодбора(Отказ) 
	
	Если Не ЗначениеЗаполнено(Объект.Валюта) Тогда
		ОбщегоНазначенияКлиент.СообщитьПользователю(НСтр("ru = 'Поле ""Валюта"" не заполнено'"), Объект.Ссылка, "Объект.Валюта",,Отказ);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ОбработкаВыбораПодборНаСервере(ВыбранноеЗначение)

	ПодобранныеТовары = ПолучитьИзВременногоХранилища(ВыбранноеЗначение.АдресТоваровВХранилище);
	
	Действия = Новый Структура;
	Действия.Вставить("ЗаполнитьПризнакТипНоменклатуры", Новый Структура("Номенклатура", "ТипНоменклатуры"));
	Действия.Вставить("ЗаполнитьПризнакАртикул", Новый Структура("Номенклатура", "Артикул"));
	Действия.Вставить("ПриИзмененииТипаНоменклатуры", Новый Структура("ЕстьРаботы, ЕстьОтменено", Истина, Истина));
	Действия.Вставить("ЗаполнитьПризнакХарактеристикиИспользуются", Новый Структура("Номенклатура", "ХарактеристикиИспользуются"));
	
	Действия.Вставить("ЗаполнитьСлужебныеРеквизитыПоНазначению", Новый Структура("ТолькоТипНазначения", Истина));
	
	ОбщегоНазначенияКлиентСервер.ДополнитьСтруктуру(Действия, ДействияЗаполненияНалогообложенияНДС(Объект, КэшФормы), Истина);
	ОбщегоНазначенияКлиентСервер.ДополнитьСтруктуру(Действия, ДействияПересчетаСуммы(Объект.ЦенаВключаетНДС), Истина);
	
	ОбрабатываемыеСтроки = Новый Массив;
	
	Для Каждого ПодобраннаяСтрока Из ПодобранныеТовары Цикл
		
		СтрокаТоваров = Объект.Товары.Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаТоваров, ПодобраннаяСтрока, 
			"НоменклатураПартнера, Номенклатура, Характеристика, Упаковка, Склад, 
			|ВидЦеныПоставщика, Цена, КоличествоУпаковок, Количество, Сумма");
		
		Если Объект.ПоступлениеОднойДатой Тогда
			СтрокаТоваров.ЖелаемаяДатаПоступления = Объект.ЖелаемаяДатаПоступления;
		КонецЕсли;
		
		ОбрабатываемыеСтроки.Добавить(СтрокаТоваров);
		
	КонецЦикла;
	
	ПакетнаяОбработкаТабличнойЧастиСервер.ОбработатьСтрокиТЧ(
		ОбрабатываемыеСтроки,
		Действия,
		Объект.Товары);
	
	Для Каждого СтрокаТоваров Из ОбрабатываемыеСтроки Цикл
		АктуализироватьПодразделениеСтрокиТоваров(СтрокаТоваров, Объект.Подразделение);
	КонецЦикла;
		
	Если КонтролироватьАссортимент(КэшФормы) Тогда
		АссортиментСервер.ПроверитьАссортиментТаблицыПодобранныхТоваров(Объект, "Склад", ПодобранныеТовары);
	КонецЕсли;

	РассчитатьИтоговыеПоказателиЗаявки(ЭтотОбъект);
	ОбновитьКартинкуГруппыСкладов();

КонецПроцедуры

#КонецОбласти

#Область КэшФормы

&НаСервере
Процедура ИнициализироватьКэшФормы()

	КэшФормы = Новый Структура;
		
	УстановитьЗначениеВКэше(КэшФормы,
		"КонечныеСтатусы",
		Перечисления.СтатусыЗаявокНаЗакупку.КонечныеСтатусы());
	
	УстановитьЗначениеВКэше(КэшФормы,
		"ДоступныеТипыДоговоров",
		Документы.ЗаявкаНаЗакупку.ДоступныеТипыДоговоров());
		
	СохранитьУказаннуюСтавкуНДС(КэшФормы, Справочники.СтавкиНДС.ПустаяСсылка());
	СохранитьКонтрольАссортимента(КэшФормы, Объект.Склад, Объект.Дата);
	
	УстановитьЗначениеВКэше(КэшФормы,
		"ИменаРеквизитовУсловийЗакупки",
		Документы.ЗаявкаНаЗакупку.ИменаРеквизитовУсловийЗакупки());
	
	РаботаСТабличнымиЧастями.ИнициализироватьКэшСтрок(Элементы.Товары);
	
	ОтборНоменклатурыПартнера = Новый Структура;
	ОтборНоменклатурыПартнера.Вставить("Партнер");
	ОтборНоменклатурыПартнера.Вставить("Номенклатура");
	ОтборНоменклатурыПартнера.Вставить("Характеристика");
	ОтборНоменклатурыПартнера.Вставить("Упаковка");
	УстановитьЗначениеВКэше(КэшФормы,
		"ОтборНоменклатурыПартнера",
		ОтборНоменклатурыПартнера);
	
	УстановитьЗначениеВКэше(КэшФормы,
		"ПравоДобавленияЗаказаПоставщику",
		ПравоДоступа("Добавление", Метаданные.Документы.ЗаказПоставщику));
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Процедура УстановитьЗначениеВКэше(КэшФормы, ИмяСвойства, ЗначениеСвойства)
	
	Если Не КэшФормы.Свойство(ИмяСвойства) Тогда
		
		КэшФормы.Вставить(ИмяСвойства);
		
	КонецЕсли;
	
	КэшФормы[ИмяСвойства] = ЗначениеСвойства;
	
КонецПроцедуры

// Значение из кэша.
// 
// Параметры:
//  КэшФормы - Структура - Одноименный реквизит формы
//  ИмяСвойства - Строка - Имя свойства в кэше, установленное через "УстановитьЗначениеВКэше"
// 
// Возвращаемое значение:
//  Произвольный - Ранее сохраненное значение
&НаКлиентеНаСервереБезКонтекста
Функция ЗначениеИзКэша(КэшФормы, ИмяСвойства)
	
	Возврат КэшФормы[ИмяСвойства];
	
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Функция ДоступныеТипыДоговоров(КэшФормы)
	Возврат ЗначениеИзКэша(КэшФормы, "ДоступныеТипыДоговоров");
КонецФункции

