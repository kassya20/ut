#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура ОбеспечиваетсяЗакупкойПриИзмененииНаСервере()
	
	ОтображатьРеквизитыЗакупки = Документы.ЗаявкаНаОбеспечение.ОтображатьРеквизитыЗакупки(Объект);
	
	УстановитьЗначениеВКэше(КэшФормы,
		"ОтображатьРеквизитыЗакупки",
		ОтображатьРеквизитыЗакупки);
	
	
	ПараметрыВыбораСтатей = Документы.ЗаявкаНаОбеспечение.ПараметрыВыбораСтатейИАналитик(Объект.ОбеспечиваетсяЗакупкой);
	ДоходыИРасходыСервер.ПриИзмененииПараметровВыбораСтатей(ЭтотОбъект, ПараметрыВыбораСтатей);
	
	Если ОтображатьРеквизитыЗакупки И Не ЗначениеЗаполнено(Объект.Валюта) Тогда
		// Не перезаполняем, если раннее пользователь уже указал значение при работе с формой и перевыбирает значение флага.
		Объект.Валюта = ЗначениеНастроекПовтИсп.ВалютаРегламентированногоУчетаОрганизации(Объект.Организация);
	КонецЕсли;
	
	Если ОтображатьРеквизитыЗакупки И Не ЗначениеЗаполнено(Объект.Валюта) Тогда
		// Повторная попытка заполнения валюты, в случае, если организация не заполнена.
		Объект.Валюта = ЗначениеНастроекПовтИсп.БазоваяВалютаПоУмолчанию();
	КонецЕсли;
	
	ВалютаДокумента = Объект.Валюта;
	
	ОформитьПоляОбеспеченияЗакупкой();
	ПодключаемыеКомандыКлиентСервер.ОбновитьКоманды(ЭтотОбъект, Объект);
	
КонецПроцедуры

&НаСервере
Процедура ВалютаПриИзмененииНаСервере(НоваяВалюта, ПересчитатьСуммы)
	
	Если ПересчитатьСуммы Тогда
		ВыполнитьПересчетСуммДокумента(ВалютаДокумента, НоваяВалюта);
	КонецЕсли;
	
	ВалютаДокумента = Объект.Валюта;
	
КонецПроцедуры

&НаСервере
Процедура ВыполнитьПересчетСуммДокумента(СтараяВалюта, НоваяВалюта)
	
	Если СтараяВалюта <> НоваяВалюта Тогда
		
		СтруктураДействий = Новый Структура;
		СтруктураДействий.Вставить("ПересчитатьСумму");
		
		ДатаДокумента = ?(ЗначениеЗаполнено(Объект.Дата), Объект.Дата, ТекущаяДатаСеанса());
		БазоваяВалюта = ЗначениеНастроекПовтИсп.ВалютаРегламентированногоУчетаОрганизации(Объект.Организация);
		СтруктураКурсовСтаройВалюты = РаботаСКурсамиВалютУТ.ПолучитьКурсВалюты(СтараяВалюта, ДатаДокумента, БазоваяВалюта);
		СтруктураКурсовНовойВалюты  = РаботаСКурсамиВалютУТ.ПолучитьКурсВалюты(НоваяВалюта,  ДатаДокумента, БазоваяВалюта);
		
		Для Каждого ТекСтрока Из Объект.Товары Цикл
			
			ТекСтрока.Цена = РаботаСКурсамиВалютУТ.ПересчитатьПоКурсу(
				ТекСтрока.Цена,
				СтруктураКурсовСтаройВалюты,
				СтруктураКурсовНовойВалюты);
			
		КонецЦикла;
		
		ПакетнаяОбработкаТабличнойЧастиСервер.ОбработатьТЧ(
			Объект.Товары,
			СтруктураДействий);
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура АктивироватьСтрокуЕдинственнойПозиции()
	
	Если Элементы.ГруппаСтраницы.ТекущаяСтраница <> Элементы.СтраницаТовар Тогда 
		Возврат;
	КонецЕсли;
	
	Если Элементы.Товары.ТекущаяСтрока <> Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(Объект.Товары) Тогда
		Возврат;
	КонецЕсли;
	
	Элементы.Товары.ТекущаяСтрока = Объект.Товары.Получить(0).ПолучитьИдентификатор();
		
КонецПроцедуры

&НаКлиенте
Функция ПроверитьНаличиеВыделенныхСтрок(МножественныйРежимВыделения = Истина)
	
	ТекстПредупреждения = "";
	
	Если Объект.Товары.Количество() = 0 Тогда
		
		ТекстПредупреждения = НСтр("ru='Таблица товаров не заполнена.'");
		
	ИначеЕсли Элементы.Товары.ВыделенныеСтроки.Количество() = 0 Тогда
		
		Если МножественныйРежимВыделения Тогда
			ТекстПредупреждения = НСтр("ru='В таблице товаров отсутствуют выделенные строки.'");
		Иначе
			ТекстПредупреждения = НСтр("ru='Необходимо выделить строку товаров.'");
		КонецЕсли;
		
	КонецЕсли;
	
	ПроверкаПройдена = ПустаяСтрока(ТекстПредупреждения);
	Если Не ПроверкаПройдена Тогда
		ПоказатьПредупреждение(Неопределено, ТекстПредупреждения);
	КонецЕсли;
	
	Возврат ПроверкаПройдена;
	
КонецФункции

&НаКлиенте
Функция ВЕдинственнойПозицииЗаполненаНоменклатура()
	
	Возврат Не ОднаПозиция(ЭтотОбъект)
		Или ЗначениеЗаполнено(Элементы.Товары.ТекущиеДанные.Номенклатура);
	
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Функция ОднаПозиция(Форма)
	
	Возврат Форма.Элементы.ГруппаСтраницы.ТекущаяСтраница = Форма.Элементы.СтраницаТовар;
	
КонецФункции

#Область ВидыЦен

&НаКлиенте
Функция ОписаниеОповещенияОВыбореВидаЦены(ЭтоЗакупочныеЦены)
	Возврат Новый ОписаниеОповещения("ЗаполнитьЦеныПоВидуЦенЗавершение", ЭтотОбъект, ЭтоЗакупочныеЦены);
КонецФункции

&НаКлиенте
Процедура ЗаполнитьЦеныПоВидуЦенЗавершение(ВидЦены, ЭтоЗакупочныеЦены) Экспорт
	
	Если Не ЗначениеЗаполнено(ВидЦены) Тогда
		Возврат;
	КонецЕсли;
	
	ОчиститьСообщения();
	
	ЦеныРассчитаны = Истина;
	ЗаполнитьЦеныПоВидуЦенСервер(ВидЦены, ЭтоЗакупочныеЦены);
	
	Если ЭтоЗакупочныеЦены Тогда
		ЦеныПартнеровЗаполнениеКлиент.ОповеститьОбОкончанииЗаполненияЦенПоВидуЦеныПоставщика(ЦеныРассчитаны, ВидЦены);
	Иначе
		ПродажиКлиент.ОповеститьОбОкончанииЗаполненияЦенПоВидуЦен(ЦеныРассчитаны, ВидЦены);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьЦеныПоВидуЦенСервер(ВидЦены, ЭтоЗакупочныеЦены)
	
	ВыделенныеСтроки = Новый Массив;
	Для Каждого ИдентификаторСтроки Из Элементы.Товары.ВыделенныеСтроки Цикл
		СтрокаТоваров = Объект.Товары.НайтиПоИдентификатору(ИдентификаторСтроки);
		ВыделенныеСтроки.Добавить(СтрокаТоваров);
	КонецЦикла;
	
	ОбъектСВидомЦены = Новый Структура;
	ОбъектСВидомЦены.Вставить("Дата", Объект.Дата);
	ОбъектСВидомЦены.Вставить("Организация", Объект.Организация);
	ОбъектСВидомЦены.Вставить("Валюта", Объект.Валюта);
	ОбъектСВидомЦены.Вставить("ВидЦены", ВидЦены);
	ОбъектСВидомЦены.Вставить("Партнер", Справочники.Партнеры.ПустаяСсылка());
	
	СтруктураДействий = Новый Структура;
	
	Если ЭтоЗакупочныеЦены Тогда
		
		ОбъектСВидомЦены.Партнер = Справочники.ВидыЦенПоставщиков.ВладелецВидаЦены(ВидЦены);
		ПараметрыЗаполнения = ПакетнаяОбработкаТабличнойЧастиКлиентСервер.ПолучитьСтруктуруЗаполненияЦеныЗакупкиВСтрокеТЧ(
			ОбъектСВидомЦены,
			"ВидЦены");
			
		СтруктураДействий.Вставить("ЗаполнитьЦенуЗакупки", ПараметрыЗаполнения);
		
	Иначе
		
		ПараметрыЗаполнения = ПакетнаяОбработкаТабличнойЧастиКлиентСервер.ПараметрыЗаполненияЦеныВСтрокеТЧ(
			ОбъектСВидомЦены,
			Истина);
		
		СтруктураДействий.Вставить("ЗаполнитьЦенуПродажи", ПараметрыЗаполнения);
		
	КонецЕсли;
	
	СтруктураДействий.Вставить("ПересчитатьСумму");
	ПакетнаяОбработкаТабличнойЧастиСервер.ОбработатьСтрокиТЧ(ВыделенныеСтроки, СтруктураДействий, Объект.Товары);
	
КонецПроцедуры

#КонецОбласти

#Область КоммерческиеПредложения

&НаСервере
Функция ЗаполнитьЦеныПоКоммерческимПредложениям(Знач ИдентификаторыСтрок)
	
	НомераСтрок = Новый Массив;
	Для Каждого ИдентификаторСтроки Из ИдентификаторыСтрок Цикл
		СтрокаТоваров = Объект.Товары.НайтиПоИдентификатору(ИдентификаторСтроки);
		НомераСтрок.Добавить(СтрокаТоваров.НомерСтроки);
	КонецЦикла;
	
	ПараметрыЗаполнения = КоммерческиеПредложенияДокументыУТ.ПараметрыЗаполненияУсловийЗакупкиПоКоммерческимПредложениям();
	ПараметрыЗаполнения.Документ = Объект.Ссылка;
	ПараметрыЗаполнения.ДатаКурса = ?(ЗначениеЗаполнено(Объект.Дата), Объект.Дата, ТекущаяДатаСеанса());
	ПараметрыЗаполнения.Валюта = Объект.Валюта;
	
	ПараметрыЗаполнения.ЕстьНоменклатураСтрокой = Истина;
	ПараметрыЗаполнения.НомераСтрок = НомераСтрок;
	
	ПараметрыЗаполнения.ДействияСИзмененнымиСтроками.Вставить("ПересчитатьСумму");
	
	РезультатЗаполнения = КоммерческиеПредложенияДокументыУТ.ЗаполнитьУсловияЗакупкиПоКоммерческимПредложениям(Объект.Товары, ПараметрыЗаполнения);
	
	// Переключение страницы, если были добавлены новые строки:
	ЗаполнитьЗначениеПереключателяТоваров();
	УстановитьСтраницуТоваров(ЭтотОбъект);
	
	ВозвращаемоеЗначение = Новый Структура;
	ВозвращаемоеЗначение.Вставить("Отказ", РезультатЗаполнения.Отказ);
	ВозвращаемоеЗначение.Вставить("ТекстОшибки", РезультатЗаполнения.ТекстОшибки);
	ВозвращаемоеЗначение.Вставить("НомераСтрокСНезаполненнымиУсловиямиЗакупки", РезультатЗаполнения.НомераСтрокСНезаполненнымиУсловиямиЗакупки);
	
	Возврат ВозвращаемоеЗначение;
	
КонецФункции

