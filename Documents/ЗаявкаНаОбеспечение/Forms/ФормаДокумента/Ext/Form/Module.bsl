#Область УправлениеФормой

&НаСервере
Процедура ПриЧтенииСозданииНаСервере()
	
	ЗаполнитьЗначениеПереключателяТоваров(); // Не вызывается после записи, чтобы не переключать форму.
	ЗаполнитьДанныеФормы();
	УправлениеФормой();

КонецПроцедуры

&НаСервере
Процедура ЗаполнитьДанныеФормы()
	
	// Используется как предыдущее значение и выводится даже при выключенной Ф.О. "ИспользоватьНесколькоВалют": 
	ВалютаДокумента = Объект.Валюта; 
	
	РаботаСПротоколомДокумента.ЗаполнитьДанныеФормы(ЭтотОбъект);
	
	ИнициализироватьКэшФормы();
	ОтметитьУказаннуюНоменклатуру();
	
	СтруктураДействий = Новый Структура;
	СтруктураДействий.Вставить("ЗаполнитьПризнакХарактеристикиИспользуются",
		Новый Структура("Номенклатура", "ХарактеристикиИспользуются"));
	ПакетнаяОбработкаТабличнойЧастиСервер.ОбработатьТЧ(Объект.Товары, СтруктураДействий);
	
КонецПроцедуры

&НаСервере
Процедура УстановитьУсловноеОформление()
	
	НоменклатураСервер.УстановитьУсловноеОформлениеХарактеристикНоменклатуры(ЭтотОбъект);
	НоменклатураСервер.УстановитьУсловноеОформлениеЕдиницИзмерения(ЭтотОбъект);
	
КонецПроцедуры

&НаСервере
Процедура УправлениеФормой()
	
	ОформитьХарактеристикуТовара(ЭтотОбъект);
	ОформитьПоляЛимитов();
	ОформитьПоляОбеспеченияЗакупкой();
	УстановитьСтраницуТоваров(ЭтотОбъект);
	
	ПроверятьШапку = Перечисления.СтатусыЗаявокНаОбеспечение.Согласована(Объект.Статус);
	СвойстваШапки = Новый Структура;
	СвойстваШапки.Вставить("АвтоОтметкаНезаполненного", ПроверятьШапку);
	Если Не СвойстваШапки.АвтоОтметкаНезаполненного Тогда
		СвойстваШапки.Вставить("ОтметкаНезаполненного", Ложь);
	КонецЕсли;
	
	Для Каждого ИмяРеквизита Из Документы.ЗаявкаНаОбеспечение.ИменаРеквизитовШапки() Цикл
		УстановитьСвойстваРеквизита(ИмяРеквизита, СвойстваШапки);
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура УстановитьСвойстваРеквизита(ИмяРеквизита, Свойства)
	
	ИменаЭлементов = Новый Массив;
	ПрефиксРеквизитаТабличнойЧасти = "Товары.";
	Если СтрНачинаетсяС(ИмяРеквизита, ПрефиксРеквизитаТабличнойЧасти) Тогда
		
		ИменаЭлементов.Добавить(СтрЗаменить(ИмяРеквизита, ПрефиксРеквизитаТабличнойЧасти, "Товар"));
		ИменаЭлементов.Добавить(СтрЗаменить(ИмяРеквизита, ПрефиксРеквизитаТабличнойЧасти, "Товары"));
		
	Иначе 
		
		ИменаЭлементов.Добавить(ИмяРеквизита);
		
	КонецЕсли;
	
	// Дубли элементов:
	Если ИмяРеквизита = "Валюта" Тогда
		ИменаЭлементов.Добавить(Элементы.ВалютаЛимиты.Имя);
	КонецЕсли;
	
	Для Каждого ИмяЭлемента Из ИменаЭлементов Цикл
		
		Элемент = Элементы.Найти(ИмяЭлемента);
		Если Элемент = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		ЗаполнитьЗначенияСвойств(Элемент, Свойства);
		
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ОформитьПоляОбеспеченияЗакупкой()
	
	Если Документы.ЗаявкаНаОбеспечение.ИспользоватьЛимитыБДР() Тогда
		// Валюта всегда отображается.
		Элементы.СтраницыОбеспечиваетсяЗакупкой.ТекущаяСтраница = Элементы.СтраницаОбеспечиваетсяЗакупкойЛимиты;
	Иначе
		Элементы.СтраницыОбеспечиваетсяЗакупкой.ТекущаяСтраница = Элементы.СтраницаОбеспечиваетсяЗакупкой;
	КонецЕсли;
	ИспользоватьЛимитыБДР = ЗначениеИзКэша(КэшФормы, "ИспользоватьЛимитыБДР");
	Элементы.НаправлениеДеятельности.Видимость = ИспользоватьЛимитыБДР;
	Элементы.ТоварСтатьяБюджетов.Видимость = ИспользоватьЛимитыБДР;
	Элементы.ТоварыСтатьяБюджетов.Видимость = ИспользоватьЛимитыБДР;
	
	Элементы.ОбеспечиваетсяЗакупкой.Заголовок = 
		?(Объект.ОбеспечиваетсяЗакупкой И ЗначениеИзКэша(КэшФормы, "ИспользоватьНесколькоВалют"),
		НСтр("ru = 'Обеспечивается закупкой в валюте:'"),
		НСтр("ru = 'Обеспечивается закупкой'"));
	
	СтатусыВидимостиКомандыЗаполнитьЦены = Новый Массив;
	СтатусыВидимостиКомандыЗаполнитьЦены.Добавить(Перечисления.СтатусыЗаявокНаОбеспечение.НаСогласовании);
	СтатусыВидимостиКомандыЗаполнитьЦены.Добавить(Перечисления.СтатусыЗаявокНаОбеспечение.НаВыполнении);
	
	ВидимостьЭлемента =
		ЗначениеИзКэша(КэшФормы, "ИспользоватьЗапросыКоммерческихПредложенийПоставщиков")
		И СтатусыВидимостиКомандыЗаполнитьЦены.Найти(Объект.Статус) <> Неопределено
		И Объект.ОбеспечиваетсяЗакупкой;
	
	Элементы.ТоварыЗаполнитьЦеныПоКоммерческимПредложениям.Видимость = ВидимостьЭлемента;
	Элементы.ТоварЗаполнитьЦеныПоКоммерческимПредложениям.Видимость = ВидимостьЭлемента;
	
	ПроверятьРеквизиты = Документы.ЗаявкаНаОбеспечение.ПроверятьРеквизитыЗакупки(Объект);
	ОтображатьРеквизиты = ЗначениеИзКэша(КэшФормы, "ОтображатьРеквизитыЗакупки");
	
	Элементы.ТоварЗаполнитьЦеныПоВидуЦен.Видимость = ОтображатьРеквизиты;
	Элементы.ТоварыЗаполнитьЦеныПоВидуЦен.Видимость = ОтображатьРеквизиты;
	Элементы.ТоварЗаполнитьЦеныПоВидуЦенПоставщика.Видимость = ОтображатьРеквизиты;
	Элементы.ТоварыЗаполнитьЦеныПоВидуЦенПоставщика.Видимость = ОтображатьРеквизиты;
	
	ИзменяемыеСвойства = Новый Структура;
	ИзменяемыеСвойства.Вставить("Видимость", ОтображатьРеквизиты); 
	ИзменяемыеСвойства.Вставить("АвтоОтметкаНезаполненного", ПроверятьРеквизиты);
	Если Не ИзменяемыеСвойства.АвтоОтметкаНезаполненного Тогда
		ИзменяемыеСвойства.Вставить("ОтметкаНезаполненного", Ложь);
	КонецЕсли;

	Для Каждого ИмяРеквизита Из Документы.ЗаявкаНаОбеспечение.ИменаРеквизитовЗакупки() Цикл
		УстановитьСвойстваРеквизита(ИмяРеквизита, ИзменяемыеСвойства);
	КонецЦикла;
	
	УстановитьВидимостьИтогов(ЭтотОбъект);
	
КонецПроцедуры

&НаСервере
Процедура ОформитьПоляЛимитов()
	
	// Видимость полей регулируется функциональной опцией, изменяем только проверку значений:
	ПроверятьРеквизиты = Документы.ЗаявкаНаОбеспечение.ПроверятьРеквизитыАналитикЛимитирования(Объект);
	ИзменяемыеСвойства = Новый Структура; 
	ИзменяемыеСвойства.Вставить("АвтоОтметкаНезаполненного", ПроверятьРеквизиты);
	Если Не ИзменяемыеСвойства.АвтоОтметкаНезаполненного Тогда
		ИзменяемыеСвойства.Вставить("ОтметкаНезаполненного", Ложь);
	КонецЕсли;
	
	Для Каждого ИмяРеквизита Из Документы.ЗаявкаНаОбеспечение.ИменаРеквизитовАналитикЛимитирования() Цикл
		УстановитьСвойстваРеквизита(ИмяРеквизита, ИзменяемыеСвойства);
	КонецЦикла;
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Процедура ОформитьХарактеристикуТовара(Форма)
	
	ХарактеристикиИспользуются = Ложь;
	Если ЗначениеЗаполнено(Форма.Объект.Товары) Тогда
		ХарактеристикиИспользуются = Форма.Объект.Товары[0].ХарактеристикиИспользуются;
	КонецЕсли;
	
	Элементы = Форма.Элементы;
	Элементы.ТоварХарактеристика.АвтоОтметкаНезаполненного = ХарактеристикиИспользуются;
	Элементы.ТоварХарактеристика.ТолькоПросмотр = Не ХарактеристикиИспользуются;
	Если ХарактеристикиИспользуются Тогда
		Элементы.ТоварХарактеристика.ПодсказкаВвода = "";
	Иначе
		Элементы.ТоварХарактеристика.ПодсказкаВвода = НСтр("ru ='<характеристики не используются>'");
		Элементы.ТоварХарактеристика.ОтметкаНезаполненного = Ложь;
	КонецЕсли;

КонецПроцедуры

#Область ЕдиницаИзмерения

&НаКлиентеНаСервереБезКонтекста
// Есть серверный вызов!
Процедура ЗаполнитьПодсказкуЕдиницыИзмеренияТовара(Форма)
	
	Элементы = Форма.Элементы;
	Если Элементы.ГруппаСтраницы.ТекущаяСтраница = Элементы.СтраницаТовар Тогда
		Элементы.ТоварУпаковка.ПодсказкаВвода = ПодсказкаЕдиницыИзмеренияТовара(Форма.Объект.Товары[0].Номенклатура);
	КонецЕсли;
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ПодсказкаЕдиницыИзмеренияТовара(Номенклатура)
	
	Если Не ЗначениеЗаполнено(Номенклатура) Тогда
		Возврат "";
	КонецЕсли;
	
	Возврат ОбщегоНазначения.ЗначенияРеквизитовОбъекта(
		Номенклатура,
		Новый Структура("ЕдиницаИзмерения", "ЕдиницаИзмерения.Представление")).ЕдиницаИзмерения;
	
КонецФункции

#КонецОбласти

&НаКлиентеНаСервереБезКонтекста
Процедура УстановитьСтраницуТоваров(Форма)
	
	Элементы = Форма.Элементы;
	Элементы.ГруппаСтраницы.ТекущаяСтраница = Элементы.Найти(Форма.ПереключательТоваров);
	УстановитьВидимостьИтогов(Форма);
	ЗаполнитьПодсказкуЕдиницыИзмеренияТовара(Форма);
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Процедура УстановитьВидимостьИтогов(Форма)
	
	Элементы = Форма.Элементы;
	ОтображатьСуммовыеИтоги = ЗначениеИзКэша(Форма.КэшФормы, "ОтображатьРеквизитыЗакупки")
		// Для одной строки итогом является сама строка:
		И Элементы.ГруппаСтраницы.ТекущаяСтраница = Элементы.СтраницаТоварыТаблица; 
		
	Элементы.ИтогСумма.Видимость = ОтображатьСуммовыеИтоги;
	Элементы.ВалютаНадпись.Видимость = ОтображатьСуммовыеИтоги;
	
КонецПроцедуры

#Область СтраницыТоваров

&НаСервере
Процедура ЗаполнитьЗначениеПереключателяТоваров()
	
	ПереключательТоваров = ?(Объект.Товары.Количество() = 1,
		Элементы.СтраницаТовар.Имя,
		Элементы.СтраницаТоварыТаблица.Имя);
	
КонецПроцедуры

#КонецОбласти

#КонецОбласти

#Область КэшФормы

&НаСервере
Процедура ИнициализироватьКэшФормы()

	КэшФормы = Новый Структура;
	
	УстановитьЗначениеВКэше(КэшФормы,
		"ИспользоватьНесколькоВалют",
		ПолучитьФункциональнуюОпцию("ИспользоватьНесколькоВалют"));
	
	УстановитьЗначениеВКэше(КэшФормы,
		"НоменклатураДобавление",
		ПравоДоступа("Добавление", Метаданные.Справочники.Номенклатура));
		
	УстановитьЗначениеВКэше(КэшФормы,
		"ИмяСобытияИзмененияНоменклатуры",
		"");
		
	УстановитьКонтрольАссортиментаВКэше(КэшФормы,
		Объект.Дата,
		Объект.Склад);
	
	ИспользоватьЛимитыБДР = Ложь; // Значение по умолчанию для УТ.
			
	УстановитьЗначениеВКэше(КэшФормы,
		"ИспользоватьЛимитыБДР",
		ИспользоватьЛимитыБДР);
	
	УстановитьЗначениеВКэше(КэшФормы,
		"ОтображатьРеквизитыЗакупки",
		Документы.ЗаявкаНаОбеспечение.ОтображатьРеквизитыЗакупки(Объект));
	
	УстановитьЗначениеВКэше(КэшФормы,
		"ИспользоватьЗапросыКоммерческихПредложенийПоставщиков",
		КоммерческиеПредложенияДокументыУТ.ИспользоватьЗапросыКоммерческихПредложенийПоставщиков());
	
	УстановитьРежимЗаписиВКэше();
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Процедура УстановитьЗначениеВКэше(КэшФормы, ИмяСвойства, ЗначениеСвойства)
	
	Если Не КэшФормы.Свойство(ИмяСвойства) Тогда
		
		КэшФормы.Вставить(ИмяСвойства);
		
	КонецЕсли;
	
	КэшФормы[ИмяСвойства] = ЗначениеСвойства;
	
КонецПроцедуры

// Значение из кэша.
// 
// Параметры:
//  КэшФормы - Структура - Одноименный реквизит формы
//  ИмяСвойства - Строка - Имя свойства в кэше, установленное через "УстановитьЗначениеВКэше"
// 
// Возвращаемое значение:
//  Произвольный - Ранее сохраненное значение
&НаКлиентеНаСервереБезКонтекста
Функция ЗначениеИзКэша(КэшФормы, ИмяСвойства)
	
	Возврат КэшФормы[ИмяСвойства];
	
КонецФункции

&НаСервереБезКонтекста
Процедура УстановитьКонтрольАссортиментаВКэше(КэшФормы, Дата, Склад)
	
	УстановитьЗначениеВКэше(КэшФормы,
		"КонтролироватьАссортимент",
		АссортиментСерверПовтИсп.КонтролироватьАссортимент(Склад, Дата));
	
КонецПроцедуры

#КонецОбласти

#Область ИнтегрируемыеПодсистемы

#Область ШтрихкодыИТорговоеОборудование

&НаКлиенте
Процедура ПоискПоШтрихкодуЗавершение(ДанныхШтрихкода, ДополнительныеПараметры) Экспорт
	
	ОбработатьШтрихкоды(ДанныхШтрихкода);
	
КонецПроцедуры

&НаКлиенте
Процедура ЗагрузитьИзТСДЗавершение(Результат, Параметры) Экспорт
	
	Если Результат.Результат Тогда
		ОбработатьШтрихкоды(Результат.ТаблицаТоваров);
	Иначе
		МенеджерОборудованияУТКлиент.СообщитьОбОшибке(Результат);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработатьШтрихкоды(ДанныеШтрихкодов)
	
	ОчиститьСообщения();
	
	Если Не ШтрихкодированиеНоменклатурыКлиент.ШтрихкодыВалидны(ДанныеШтрихкодов) Тогда
		Возврат;
	КонецЕсли;
	
	СтруктураДействийСДобавленнымиСтроками = Новый Структура;
	СтруктураДействийСДобавленнымиСтроками.Вставить("ЗаполнитьПризнакХарактеристикиИспользуются", 
		Новый Структура("Номенклатура", "ХарактеристикиИспользуются"));
	ДобавитьДействияПриИзмененииКоличестваУпаковок(СтруктураДействийСДобавленнымиСтроками, ЭтотОбъект);
	
	СтруктураДействийСИзмененнымиСтроками = Новый Структура;
	ДобавитьДействияПриИзмененииКоличестваУпаковок(СтруктураДействийСИзмененнымиСтроками, ЭтотОбъект);
	
	СтруктураДействий = ШтрихкодированиеНоменклатурыКлиент.ПараметрыОбработкиШтрихкодов();
	СтруктураДействий.Штрихкоды                              = ДанныеШтрихкодов;
	СтруктураДействий.СтруктураДействийСДобавленнымиСтроками = СтруктураДействийСДобавленнымиСтроками;
	СтруктураДействий.СтруктураДействийСИзмененнымиСтроками  = СтруктураДействийСИзмененнымиСтроками;
	
	Если ЗначениеИзКэша(КэшФормы, "КонтролироватьАссортимент") Тогда
		ПараметрыПроверкиАссортимента = АссортиментКлиентСервер.ПараметрыПроверкиАссортимента();
		ПараметрыПроверкиАссортимента.Ссылка                  = Объект.Ссылка;
		ПараметрыПроверкиАссортимента.Склад                   = Объект.Склад;
		ПараметрыПроверкиАссортимента.Дата                    = Объект.Дата;
		ПараметрыПроверкиАссортимента.ИмяРесурсаАссортимента  = "РазрешеныЗакупки";
		ПараметрыПроверкиАссортимента.ПровереноМожноДобавлять = Истина;
		ПараметрыПроверкиАссортимента.РазрешатьДобавление     = Истина;
		ПараметрыПроверкиАссортимента.ТекстСообщения =
			НСтр("ru = 'Товар %1 не включен в ассортимент магазина. Заказывать его не рекомендуется.'");
		
		СтруктураДействий.ПараметрыПроверкиАссортимента = ПараметрыПроверкиАссортимента;
	КонецЕсли;
	
	ОбработатьШтрихкодыСервер(СтруктураДействий, КэшированныеЗначения);
	
	ШтрихкодированиеНоменклатурыКлиент.ОбработатьНеизвестныеШтрихкоды(СтруктураДействий,
		КэшированныеЗначения,
		ЭтотОбъект);
	
КонецПроцедуры

&НаСервере
Процедура ОбработатьШтрихкодыСервер(СтруктураПараметровДействия, КэшированныеЗначения)
	
	ИдентификаторыСтрокТоваров = ИдентификаторыСтрокТоваров();
	
	ШтрихкодированиеНоменклатурыСервер.ОбработатьШтрихкоды(
		ЭтотОбъект,
		Объект,
		СтруктураПараметровДействия,
		КэшированныеЗначения);
	
	ИдентификаторыДобавленныхСтрок = ОбщегоНазначенияКлиентСервер.РазностьМассивов(
		ИдентификаторыСтрокТоваров(),
		ИдентификаторыСтрокТоваров);
	
	ДобавленныеСтроки = Новый Массив;
	Для Каждого ИдентификаторДобавленнойСтроки Из ИдентификаторыДобавленныхСтрок Цикл
		
		СтрокаТоваров = Объект.Товары.НайтиПоИдентификатору(ИдентификаторДобавленнойСтроки);
		ДобавленныеСтроки.Добавить(СтрокаТоваров);
		ЗаполнитьПризнакНоменклатураУказана(СтрокаТоваров);
		
	КонецЦикла;
	
	ЗаполнитьНоменклатуруСтрокой(ДобавленныеСтроки);
	
КонецПроцедуры

&НаСервере
Функция ИдентификаторыСтрокТоваров()
	
	ВозвращаемоеЗначение = Новый Массив;
	Для Каждого СтрокаТоваров Из Объект.Товары Цикл
		ВозвращаемоеЗначение.Добавить(СтрокаТоваров.ПолучитьИдентификатор());
	КонецЦикла;
	Возврат ВозвращаемоеЗначение;
	
КонецФункции

