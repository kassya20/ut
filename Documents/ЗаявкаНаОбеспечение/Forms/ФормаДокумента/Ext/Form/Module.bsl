		ЭтотОбъект,
		НавигационнаяСсылкаФорматированнойСтроки,
		СтандартнаяОбработка);
	
КонецПроцедуры

&НаКлиенте
Процедура ПредставлениеИсполнителяОбработкаНавигационнойСсылки(Элемент, НавигационнаяСсылкаФорматированнойСтроки, СтандартнаяОбработка)
	
	РаботаСПротоколомДокументаКлиент.ОбработатьНавигационнуюСсылкуПротокола(
		ЭтотОбъект,
		НавигационнаяСсылкаФорматированнойСтроки,
		СтандартнаяОбработка);
	
КонецПроцедуры

#КонецОбласти

#КонецОбласти

//@skip-check module-structure-form-event-regions -- Обработчики едины как для одного товара, так и для перечня
#Область ОбработчикиСобытийЭлементовТаблицыФормыТовары

&НаКлиенте
Процедура ТоварыКоличествоУпаковокПриИзменении(Элемент)
	
	ТекущиеДанные = Элементы.Товары.ТекущиеДанные;
	СтруктураДействий = Новый Структура;
	ДобавитьДействияПриИзмененииКоличестваУпаковок(СтруктураДействий, ЭтотОбъект);
	
	ПакетнаяОбработкаТабличнойЧастиКлиент.ОбработатьСтрокуТЧ(ТекущиеДанные, СтруктураДействий, КэшированныеЗначения);
	
КонецПроцедуры

&НаКлиенте
Процедура ТоварыЦенаПриИзменении(Элемент)
	
	ТекущиеДанные = Элементы.Товары.ТекущиеДанные;
	
	СтруктураДействий = Новый Структура;
	СтруктураДействий.Вставить("ПересчитатьСумму");
	ПакетнаяОбработкаТабличнойЧастиКлиент.ОбработатьСтрокуТЧ(ТекущиеДанные, СтруктураДействий, КэшированныеЗначения);

КонецПроцедуры

&НаКлиенте
Процедура ТоварыУпаковкаПриИзменении(Элемент)
	
	ТекущиеДанные = Элементы.Товары.ТекущиеДанные;
	
	СтруктураДействий = Новый Структура;
	СтруктураДействий.Вставить("ПересчитатьКоличествоЕдиниц");
	СтруктураДействий.Вставить("ПересчитатьЦенуЗаУпаковку", ТекущиеДанные.Количество);
	СтруктураДействий.Вставить("ПересчитатьСумму");
	
	ПакетнаяОбработкаТабличнойЧастиКлиент.ОбработатьСтрокуТЧ(ТекущиеДанные, СтруктураДействий, КэшированныеЗначения);
	
КонецПроцедуры

&НаКлиенте
Процедура ТоварыСуммаПриИзменении(Элемент)
	
	ТекущиеДанные = Элементы.Товары.ТекущиеДанные;
	
	СтруктураДействий = Новый Структура;
	ПараметрыРасчетаЦены = ПакетнаяОбработкаТабличнойЧастиКлиентСервер.ПолучитьСтруктуруПересчетаЦеныСкидкиВЗакупкахВТЧ(
		Объект,
		Истина); // Отключение ручных скидок
	СтруктураДействий.Вставить("ПересчитатьЦенуСкидкуПоСуммеВЗакупках", ПараметрыРасчетаЦены);
	
	ПакетнаяОбработкаТабличнойЧастиКлиент.ОбработатьСтрокуТЧ(ТекущиеДанные, СтруктураДействий, КэшированныеЗначения);

КонецПроцедуры

&НаКлиенте
Процедура ТоварыСтатьяРасходовПриИзменении(Элемент)
	
	// Выбор статей и аналитик.
	ДоходыИРасходыКлиентСервер.СтатьяПриИзменении(ЭтотОбъект, Элемент);
	
КонецПроцедуры

&НаКлиенте
Процедура ТоварыСтатьяРасходовНачалоВыбора(Элемент, ДанныеВыбора, ВыборДобавлением, СтандартнаяОбработка)
	
	// Выбор статей и аналитик.
	ДоходыИРасходыКлиент.НачалоВыбораСтатьи(ЭтотОбъект, Элемент, СтандартнаяОбработка);
	
КонецПроцедуры

#Область НоменклатураСтрокой

&НаКлиенте
Процедура ТоварыНоменклатураСтрокойАвтоПодбор(Элемент, Текст, ДанныеВыбора, ПараметрыПолученияДанных, Ожидание, СтандартнаяОбработка)
	
	Если Ожидание = 0 Тогда
		Возврат; // Не выводим весь список или сообщение <"" не найдено> (если уже что-то введено)
	КонецЕсли;
	
	// Имитация ввода текста в поле ввода с типом "СправочникСсылка.Номенклатура":
	ДанныеВыбора = ДанныеВыбораНоменклатуры(ПараметрыПолученияДанных.СтрокаПоиска);
	
	// Если данных нет, то не сбрасываем стандартную обработку, чтобы не выводить пользователю "не найдено".
	Если ЗначениеЗаполнено(ДанныеВыбора) Тогда
		СтандартнаяОбработка = Ложь;
	КонецЕсли; 
	
КонецПроцедуры

&НаКлиенте
Процедура ТоварыНоменклатураСтрокойНачалоВыбора(Элемент, ДанныеВыбора, ВыборДобавлением, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	ПараметрыОткрытия = Новый Структура;
	ПараметрыОткрытия.Вставить("Отбор", ОтборНоменклатуры());
	ПараметрыОткрытия.Вставить("ТекущаяСтрока", Элементы.Товары.ТекущиеДанные.Номенклатура);
	
	ОткрытьФорму("Справочник.Номенклатура.Форма.ФормаВыбора",
		ПараметрыОткрытия,
		Элемент);
		
КонецПроцедуры

&НаКлиенте
Процедура ТоварыНоменклатураСтрокойОкончаниеВводаТекста(Элемент, Текст, ДанныеВыбора, ПараметрыПолученияДанных, СтандартнаяОбработка)
		
	УстановитьЗначениеВКэше(КэшФормы, "ИмяСобытияИзмененияНоменклатуры", "ОкончаниеВводаТекста");
	Элементы.Товары.ТекущиеДанные.НоменклатураСтрокой = Текст; // Для поля ввода единственного товара необходимо явно устанавливать значение.

КонецПроцедуры

&НаКлиенте
Процедура ТоварыНоменклатураСтрокойОткрытие(Элемент, СтандартнаяОбработка)
	
	ТекущиеДанные = Элементы.Товары.ТекущиеДанные;
	
	Если ЗначениеЗаполнено(ТекущиеДанные.Номенклатура) Тогда
		
		СтандартнаяОбработка = Ложь;
		ПоказатьЗначение(, ТекущиеДанные.Номенклатура);
		
	ИначеЕсли ПустаяСтрока(Элемент.ТекстРедактирования) Тогда
		
		СтандартнаяОбработка = Ложь;
		
	ИначеЕсли ЗначениеИзКэша(КэшФормы, "НоменклатураДобавление") Тогда
		
		СтандартнаяОбработка = Ложь;
		
		ПараметрыОткрытия = Новый Структура;
		ПараметрыОткрытия.Вставить("ТекстЗаполнения", Элемент.ТекстРедактирования);
		ПараметрыОткрытия.Вставить("ЗначенияЗаполнения", ОтборНоменклатуры());
		ПараметрыОткрытия.Вставить("РежимВыбора", Истина);
		
		ОткрытьФорму("Справочник.Номенклатура.ФормаОбъекта", ПараметрыОткрытия, Элемент);
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ТоварыНоменклатураСтрокойОбработкаВыбора(Элемент, ВыбранноеЗначение, ДополнительныеДанные, ВыборДобавлением, СтандартнаяОбработка)
	
	// Пользователь выбрал значение из списка / формы выбора / создал новый элемент:
	Если Не НоменклатураСоответствуетПараметрамВыбора(ВыбранноеЗначение) Тогда
		СтандартнаяОбработка = Ложь;
		ПоказатьПредупреждение(, НСтр("ru = 'Выбранное значение не соответствует условиям выбора'"));
		Возврат;
	КонецЕсли;
	
	ТекущиеДанные = Элементы.Товары.ТекущиеДанные;
	ТекущиеДанные.Номенклатура = ВыбранноеЗначение;
	УстановитьЗначениеВКэше(КэшФормы, "ИмяСобытияИзмененияНоменклатуры", "ОбработкаВыбора");
	
КонецПроцедуры

&НаКлиенте
Процедура ТоварыНоменклатураСтрокойПриИзменении(Элемент)
	
	ТекущиеДанные = Элементы.Товары.ТекущиеДанные;
	
	// Обрабатываем события, которые не допускают серверных вызовов:
	ИмяСобытияИзмененияНоменклатуры = ЗначениеИзКэша(КэшФормы, "ИмяСобытияИзмененияНоменклатуры");
	Если ИмяСобытияИзмененияНоменклатуры = "ОкончаниеВводаТекста" Тогда

		УстанавливаемаяНоменклатура = Неопределено;
		ДанныеВыбораНоменклатуры = ДанныеВыбораНоменклатуры(ТекущиеДанные.НоменклатураСтрокой);
		Если ДанныеВыбораНоменклатуры.Количество() = 1 Тогда
			// Возможно, текст совпадает с наименованием номенклатуры:
			Номенклатура = ДанныеВыбораНоменклатуры[0].Значение.Значение;
			ПредставлениеНоменклатуры = НоменклатураСтрокой(
				ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(Номенклатура)).Получить(Номенклатура);
			
			Если Врег(ПредставлениеНоменклатуры) = ВРег(ТекущиеДанные.НоменклатураСтрокой) Тогда
				
				УстанавливаемаяНоменклатура = Номенклатура;
				
			КонецЕсли;
			
		КонецЕсли;
		
		ТекущиеДанные.Номенклатура = УстанавливаемаяНоменклатура;
		
	КонецЕсли;
	
	ПриИзмененииНоменклатуры(ТекущиеДанные);
	УстановитьЗначениеВКэше(КэшФормы, "ИмяСобытияИзмененияНоменклатуры", "");
	
КонецПроцедуры

