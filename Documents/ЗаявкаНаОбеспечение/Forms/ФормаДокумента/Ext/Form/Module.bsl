#Область РаботаСБуферомОбмена

&НаСервере
Процедура СкопироватьСтрокиНаСервере()
	
	РаботаСТабличнымиЧастями.СкопироватьСтрокиВБуферОбмена(Объект.Товары, Элементы.Товары.ВыделенныеСтроки);
	
КонецПроцедуры

&НаСервере
Процедура ПолучитьСтрокиИзБуфераОбмена()
	
	ПараметрыОтбора = Новый Соответствие;
	
	КолонкиБуфера = Новый Массив;
	КолонкиБуфера.Добавить("Номенклатура");
	КолонкиБуфера.Добавить("Характеристика");
	КолонкиБуфера.Добавить("Упаковка");
	КолонкиБуфера.Добавить("КоличествоУпаковок");
	КолонкиБуфера.Добавить("Цена");
	
	ТаблицаТоваров = РаботаСТабличнымиЧастями.СтрокиИзБуфераОбмена(ПараметрыОтбора, КолонкиБуфера);
	
	Если Не ЗначениеЗаполнено(ТаблицаТоваров) Тогда
		Возврат;
	КонецЕсли;
	
	ОбрабатываемыеСтроки = Новый Массив;
	Для Каждого СтрокаИсточник Из ТаблицаТоваров Цикл
		
		СтрокаТоваров = Объект.Товары.Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаТоваров, СтрокаИсточник);
		ЗаполнитьПризнакНоменклатураУказана(СтрокаТоваров);
		ОбрабатываемыеСтроки.Добавить(СтрокаТоваров);
		
	КонецЦикла;
	
	ЗаполнитьНоменклатуруСтрокой(ОбрабатываемыеСтроки);
	
	СтруктураДействий = Новый Структура;
	СтруктураДействий.Вставить("ЗаполнитьПризнакХарактеристикиИспользуются", 
		Новый Структура("Номенклатура", "ХарактеристикиИспользуются"));
	ДобавитьДействияПриИзмененииКоличестваУпаковок(СтруктураДействий, ЭтотОбъект);
	
	ПакетнаяОбработкаТабличнойЧастиСервер.ОбработатьСтрокиТЧ(
		ОбрабатываемыеСтроки,
		СтруктураДействий,
		Объект.Товары);
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Процедура УстановитьДоступностьКомандБуфераОбмена(Форма, ЗначениеДоступности)
	
	ИменаЭлементов = Новый Массив;
	ИменаЭлементов.Добавить("ТоварыВставитьСтроки");
	ИменаЭлементов.Добавить("ТоварыКонтекстноеМенюВставитьСтроки");
	
	ОбщегоНазначенияУТКлиентСервер.УстановитьСвойствоЭлементовФормы(
		Форма.Элементы,
		ИменаЭлементов,
		"Доступность",
		ЗначениеДоступности);
	
КонецПроцедуры

