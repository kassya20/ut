#Область ВидыЦен
 
&НаКлиенте
Процедура ЗаполнитьЦеныПоВидуЦен(Команда)

	Если Не ПроверитьНаличиеВыделенныхСтрок() Тогда
		Возврат;
	КонецЕсли;

	Если Не ВЕдинственнойПозицииЗаполненаНоменклатура() Тогда
		ПоказатьПредупреждение(, НСтр("ru = 'Для заполнения цены необходимо выбрать номенклатуру из справочника'"));
		Возврат;
	КонецЕсли;
	
	Если Не ЦеныПредприятияЗаполнениеКлиент.НеобходимоЗаполнениеЦенПоВидуЦен(Объект, "Товары", НСтр("ru='Товары'")) Тогда
		Возврат;
	КонецЕсли;
		
	ПараметрыВыбораЦен = ЦеныПредприятияЗаполнениеКлиент.НовыйПараметрыЗаполненияВыбратьВидЦен();
	ПараметрыВыбораЦен.ОписаниеОповещения = ОписаниеОповещенияОВыбореВидаЦены(Ложь);
		
	ЦеныПредприятияЗаполнениеКлиент.ВыбратьВидЦен(ПараметрыВыбораЦен);
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьЦеныПоВидуЦеныПоставщика(Команда)
	
	Если Не ПроверитьНаличиеВыделенныхСтрок() Тогда
		Возврат;
	КонецЕсли;
	
	Если Не ВЕдинственнойПозицииЗаполненаНоменклатура() Тогда
		ПоказатьПредупреждение(, НСтр("ru = 'Для заполнения цены необходимо выбрать номенклатуру из справочника'"));
		Возврат;
	КонецЕсли;
	
	Если Не ЦеныПартнеровЗаполнениеКлиент.НеобходимоЗаполнениеЦенПоВидуЦенПоставщика(Объект, "Товары", НСтр("ru='Товары'")) Тогда
		Возврат;
	КонецЕсли;
	
	ОписаниеОповещения = ОписаниеОповещенияОВыбореВидаЦены(Истина);
	
	ЦеныПартнеровЗаполнениеКлиент.ВыбратьВидЦеныПоставщика(ОписаниеОповещения);
	
КонецПроцедуры

#КонецОбласти
 
#Область КоммерческиеПредложения

&НаКлиенте
Процедура НачатьЗаполнениеЦенПоКоммерческимПредложениям(Команда)
	
	ОчиститьСообщения();
	
	Если Не ПроверитьНаличиеВыделенныхСтрок() Тогда
		Возврат;
	КонецЕсли;
	
	РезультатЗаполнения = ЗаполнитьЦеныПоКоммерческимПредложениям(Элементы.Товары.ВыделенныеСтроки);
	
	ОднаПозиция = ОднаПозиция(ЭтотОбъект);
	
	Для Каждого НомерСтрокиТоваров Из РезультатЗаполнения.НомераСтрокСНезаполненнымиУсловиямиЗакупки Цикл
		
		Если ОднаПозиция Тогда
			
			ТекстОшибки = НСтр("ru = 'Не удалось заполнить цену. Проверьте соответствие номенклатуры в заявке и запросе коммерческого предложения'");
			
			ПутьКЭлементу = ОбщегоНазначенияУТКлиентСервер.ПутьКЭлементуТекущейСтрокиТаблицыФормы(
				"Товары",
				"Цена");
				
			ОбщегоНазначенияКлиент.СообщитьПользователю(
				ТекстОшибки,
				,// При выводе ошибки в "элемент" нельзя указать объект.
				ПутьКЭлементу);
				
		Иначе
			
			ТекстОшибки = СтрШаблон(
				НСтр("ru = 'Для строки %1 списка ""Товары"" не найдена цена в выбранных коммерческих предложениях.'"),
				НомерСтрокиТоваров);
				
			ПутьКЭлементу = ОбщегоНазначенияКлиентСервер.ПутьКТабличнойЧасти(
				"Объект.Товары",
				НомерСтрокиТоваров,
				"Цена");
				
			ОбщегоНазначенияКлиент.СообщитьПользователю(
				ТекстОшибки,
				,
				ПутьКЭлементу);
			
		КонецЕсли;
		
	КонецЦикла;
	
	Если РезультатЗаполнения.Отказ Тогда
		
		ПоказатьПредупреждение(, РезультатЗаполнения.ТекстОшибки);
		
	ИначеЕсли Не ОднаПозиция(ЭтотОбъект) Тогда
		
		КоличествоНеобработанныхСтрок = РезультатЗаполнения.НомераСтрокСНезаполненнымиУсловиямиЗакупки.Количество();
		
		ЕстьЗаполненныеСтроки = Элементы.Товары.ВыделенныеСтроки.Количество() > КоличествоНеобработанныхСтрок;
		Если ЕстьЗаполненныеСтроки Тогда
			ТекстСообщения = НСтр("ru = 'Цены заполнены.'");
		Иначе
			ТекстСообщения = НСтр("ru = 'Не удалось заполнить цены.'");
		КонецЕсли;
		
		ТекстПояснения = СтрШаблон(НСтр("ru = 'Цены заполнены в %1 из %2 строк.'"),
			Элементы.Товары.ВыделенныеСтроки.Количество() - КоличествоНеобработанныхСтрок,
			Элементы.Товары.ВыделенныеСтроки.Количество());
			
		ПоказатьОповещениеПользователя(ТекстСообщения,, ТекстПояснения, БиблиотекаКартинок.Информация32);
		
	КонецЕсли;
	
КонецПроцедуры

