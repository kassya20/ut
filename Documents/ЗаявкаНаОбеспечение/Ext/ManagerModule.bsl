//    * Значение - Строка - Описание
Функция ДополнительныеИсточникиДанныхДляДвижений(ИмяРегистра) Экспорт

	ИсточникиДанных = Новый Соответствие;

	Возврат ИсточникиДанных; 

КонецФункции

// Возвращает таблицы для движений, необходимые для проведения документа по регистрам учетных механизмов.
//
// Параметры:
//  Документ - ДокументОбъект.ЗаявкаНаОбеспечение, ДокументСсылка.ЗаявкаНаОбеспечение - ссылка на документ или объект, по которому необходимо получить данные
//  Регистры - Структура - список имен регистров, для которых необходимо получить таблицы
//  ДопПараметры - Структура - дополнительные параметры для получения данных, определяющие контекст проведения.
//
// Возвращаемое значение:
//	Структура Из КлючИЗначение - Таблицы проведения:
//			* Ключ - Строка - Имя таблицы
//			* Значение - ТаблицаЗначений - Таблица данных проведения.
//	СписокЗначений Из Строка - список значений, содержащий тексты запросов и их имена.
//						Возвращается в случае, если свойство 'ПолучитьТекстыЗапроса' параметра ДопПараметры
//						имеет значение Истина.
//@skip-check function-return-types -- Структура таблиц динамическая, не описывается
Функция ДанныеДокументаДляПроведения(Документ, Регистры, ДопПараметры = Неопределено) Экспорт
	
	Если ДопПараметры = Неопределено Тогда
		ДопПараметры = ПроведениеДокументов.ДопПараметрыИнициализироватьДанныеДокументаДляПроведения();
	КонецЕсли;

	Если ТипЗнч(Документ) = Тип("ДокументОбъект.ЗаявкаНаОбеспечение") Тогда
		ДокументСсылка = Документ.Ссылка;
	Иначе
		ДокументСсылка = Документ;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Ссылка", ДокументСсылка);
	Запрос.УстановитьПараметр("СтатусыПрошедшиеСогласование", 
		Перечисления.СтатусыЗаявокНаОбеспечение.СтатусыПрошедшиеСогласование());
	
	ТекстыЗапроса = Новый СписокЗначений;
	
	//@skip-check constructor-function-return-section
	Возврат ПроведениеДокументов.ИнициализироватьДанныеДокументаДляПроведения(Запрос, ТекстыЗапроса, ДопПараметры);
	
КонецФункции

// Возвращает параметры выбора статей в документе.
//
// Параметры:
//  ОбеспечиваетсяЗакупкой - Булево - Истина, если заявка обеспечивается закупкой
// 
// Возвращаемое значение:
// См. ДоходыИРасходыСервер.ПараметрыВыбораСтатьиИАналитики
//
Функция ПараметрыВыбораСтатейИАналитик(ОбеспечиваетсяЗакупкой) Экспорт
	
	ПараметрыВыбора = ДоходыИРасходыСервер.ПараметрыВыбораСтатьиИАналитики();
	ПараметрыВыбора.ПутьКДанным =    "Объект.Товары";
	ПараметрыВыбора.Статья = "СтатьяРасходов";
	ПараметрыВыбора.ВыборСтатьиРасходов = Истина;
	ПараметрыВыбора.АналитикаРасходов = "АналитикаРасходов";
	
	ПараметрыВыбора.ДоступностьПоОперации = Ложь;
	
	ПараметрыВыбора.ЭлементыФормы.Статья.Добавить("ТоварСтатьяРасходов");
	ПараметрыВыбора.ЭлементыФормы.Статья.Добавить("ТоварыСтатьяРасходов");
	
	ПараметрыВыбора.ЭлементыФормы.АналитикаРасходов.Добавить("ТоварАналитикаРасходов");
	ПараметрыВыбора.ЭлементыФормы.АналитикаРасходов.Добавить("ТоварыАналитикаРасходов");
	
	Возврат ПараметрыВыбора;
	
КонецФункции

#КонецОбласти

#Область СозданиеНаОсновании

// Добавляет команду создания документа "Заявка на обеспечение".
//
// Параметры:
//  КомандыСозданияНаОсновании - ТаблицаЗначений - таблица команд.
// Возвращаемое значение:
//  СтрокаТаблицыЗначений, Неопределено - Добавленная строка таблицы, если команда доступна
//@skip-check function-return-types
Функция ДобавитьКомандуСоздатьНаОсновании(КомандыСозданияНаОсновании) Экспорт
	
	КомандаСоздатьНаОсновании = Неопределено;
	
	МетаданныеДокумента = Метаданные.Документы.ЗаявкаНаОбеспечение;
	Если ПравоДоступа("Добавление", МетаданныеДокумента) Тогда
		
		КомандаСоздатьНаОсновании = КомандыСозданияНаОсновании.Добавить();
		КомандаСоздатьНаОсновании.Менеджер = МетаданныеДокумента.ПолноеИмя();
		КомандаСоздатьНаОсновании.Представление = ОбщегоНазначенияУТ.ПредставлениеОбъекта(МетаданныеДокумента);
		КомандаСоздатьНаОсновании.РежимЗаписи = "Проводить";
		КомандаСоздатьНаОсновании.ФункциональныеОпции = "ИспользоватьЗаявкиНаОбеспечение";
		
	КонецЕсли;
	
	Возврат КомандаСоздатьНаОсновании;
	
КонецФункции

// Определяет список команд создания на основании.
//
// Параметры:
//  КомандыСозданияНаОсновании - см. СозданиеНаОснованииПереопределяемый.ПередДобавлениемКомандСозданияНаОсновании.КомандыСозданияНаОсновании
//  Параметры - см. СозданиеНаОснованииПереопределяемый.ПередДобавлениемКомандСозданияНаОсновании.Параметры
//
Процедура ДобавитьКомандыСозданияНаОсновании(КомандыСозданияНаОсновании, Параметры) Экспорт
	
	КомандыОбеспечения = Новый Массив; // Доступны только в состоянии "На выполнении"
	КомандыЗакупки = Новый Массив; // Доступны только при обеспечении закупкой
	
	// Потребность в обеспечении заказов:
	КомандыОбеспечения.Добавить(Документы.ЗаказНаВнутреннееПотребление.ДобавитьКомандуСоздатьНаОсновании(КомандыСозданияНаОсновании));
	
	// Внутренний источник обеспечения:
	КомандыОбеспечения.Добавить(Документы.ЗаказНаПеремещение.ДобавитьКомандуСоздатьНаОсновании(КомандыСозданияНаОсновании));
	КомандыОбеспечения.Добавить(Документы.ПеремещениеТоваров.ДобавитьКомандуСоздатьНаОсновании(КомандыСозданияНаОсновании));
	КомандыОбеспечения.Добавить(Документы.ВнутреннееПотребление.ДобавитьКомандуСоздатьНаОсновании(КомандыСозданияНаОсновании));
	
	// Внешний источник обеспечения:
	КомандыЗакупки.Добавить(Документы.ЗаказПоставщику.ДобавитьКомандуСоздатьНаОсновании(КомандыСозданияНаОсновании));
	КомандыЗакупки.Добавить(Документы.ПриобретениеТоваровУслуг.ДобавитьКомандуСоздатьНаОсновании(КомандыСозданияНаОсновании));
	КомандыЗакупки.Добавить(Документы.ПриобретениеУслугПрочихАктивов.ДобавитьКомандуСоздатьНаОсновании(КомандыСозданияНаОсновании));
	
	// Документы оплаты:
	КомандыЗакупки.Добавить(Документы.ЗаявкаНаРасходованиеДенежныхСредств.ДобавитьКомандуСоздатьНаОсновании(КомандыСозданияНаОсновании));
	КомандыЗакупки.Добавить(Документы.СписаниеБезналичныхДенежныхСредств.ДобавитьКомандуСоздатьНаОсновании(КомандыСозданияНаОсновании));
	КомандыЗакупки.Добавить(Документы.РасходныйКассовыйОрдер.ДобавитьКомандуСоздатьНаОсновании(КомандыСозданияНаОсновании));
	
	ОбщегоНазначенияКлиентСервер.ДополнитьМассив(КомандыОбеспечения, КомандыЗакупки);
	
	Для Каждого Команда Из КомандыОбеспечения Цикл
		
		Если Команда = Неопределено Тогда
			Продолжить; // Нет прав на создаваемый объект, команда не создается
		КонецЕсли;
		
		ПодключаемыеКоманды.ДобавитьУсловиеВидимостиКоманды(Команда, "Статус", Перечисления.СтатусыЗаявокНаОбеспечение.НаВыполнении);
	КонецЦикла;
	
	Для Каждого Команда Из КомандыЗакупки Цикл
		
		Если Команда = Неопределено Тогда
			Продолжить; // Нет прав на создаваемый объект, команда не создается 
		КонецЕсли;
		
		ПодключаемыеКоманды.ДобавитьУсловиеВидимостиКоманды(Команда, "ОбеспечиваетсяЗакупкой", Истина);
	КонецЦикла;
	
	ЗаявкаНаОбеспечениеЛокализация.ДобавитьКомандыСозданияНаОсновании(КомандыСозданияНаОсновании, Параметры);
	
КонецПроцедуры

