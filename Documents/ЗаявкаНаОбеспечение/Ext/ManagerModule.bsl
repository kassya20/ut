// * Ответственный - СписокЗначений Из СправочникСсылка.Пользователи 
// * Статус - СписокЗначений  Из ПеречислениеСсылка.СтатусыЗаявокНаОбеспечение 
// * Автор - СписокЗначений Из СправочникСсылка.Пользователи 
Функция НовыйОтборСписка() Экспорт
	
	ВозвращаемоеЗначение = Новый Структура;
	ВозвращаемоеЗначение.Вставить("Исполнитель", Новый СписокЗначений);
	ВозвращаемоеЗначение.Вставить("Ответственный", Новый СписокЗначений);
	ВозвращаемоеЗначение.Вставить("Статус", Новый СписокЗначений);
	ВозвращаемоеЗначение.Вставить("Автор", Новый СписокЗначений);
	
	Возврат ВозвращаемоеЗначение;
	
КонецФункции

