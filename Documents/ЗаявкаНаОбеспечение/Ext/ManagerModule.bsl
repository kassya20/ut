#Область ТекущиеДела

// Заполняет список текущих дел пользователя.
// Параметры:
//   ТекущиеДела - см. ТекущиеДелаСервер.ТекущиеДела.
//
Процедура ПриЗаполненииСпискаТекущихДел(ТекущиеДела) Экспорт
	
	ОбщиеПараметрыЗапросов = ТекущиеДелаСервер.ОбщиеПараметрыЗапросов();
	
	Если Не ПравоДоступа("Редактирование", Метаданные.Документы.ЗаявкаНаОбеспечение)
		Или Не ПолучитьФункциональнуюОпцию("ИспользоватьЗаявкиНаОбеспечение") Тогда
		Возврат;
	КонецЕсли;
	
	Исполнитель = ОбщиеПараметрыЗапросов.Пользователь;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
	|	ЕСТЬNULL(КОЛИЧЕСТВО(ЗаявкаНаОбеспечение.Ссылка), 0) КАК КоличествоЗаявок
	|ИЗ
	|	Документ.ЗаявкаНаОбеспечение КАК ЗаявкаНаОбеспечение
	|ГДЕ
	|	ЗаявкаНаОбеспечение.Исполнитель = &Исполнитель
	|	И НЕ ЗаявкаНаОбеспечение.ПометкаУдаления"; // Черновик тоже требует отработки
	
	Запрос.УстановитьПараметр("Исполнитель", Исполнитель);
	
	Выборка = Запрос.Выполнить().Выбрать();
	Выборка.Следующий();
	КоличествоЗаявокКОбработке = Выборка.КоличествоЗаявок;
	ЕстьДела = ЗначениеЗаполнено(КоличествоЗаявокКОбработке);
		
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("СтруктураБыстрогоОтбора", ОтборЗаявкиКОтработке(Исполнитель));
	ПараметрыФормы.Вставить("КлючНазначенияИспользования", "ЗаявкиКОтработке");
	ПараметрыФормы.Вставить("Отбор", Новый Структура("ПометкаУдаления", Ложь));
		
	ИдентификаторРодителя = "ВнутреннееТовародвижение";
	
	ДелоРодитель = ТекущиеДела.Найти(ИдентификаторРодителя, "Идентификатор");
	Если ДелоРодитель = Неопределено Тогда
		ДелоРодитель = ТекущиеДела.Добавить();
		ДелоРодитель.Идентификатор  = ИдентификаторРодителя;
		ДелоРодитель.Представление  = НСтр("ru = 'Внутреннее товародвижение'");
		ДелоРодитель.Владелец       = Метаданные.Подсистемы.Склад;
	КонецЕсли;
	ДелоРодитель.ЕстьДела = ДелоРодитель.ЕстьДела Или ЕстьДела;
	
	ТекущееДело = ТекущиеДела.Добавить();
	ТекущееДело.Идентификатор = "ДокументыЗаявокНаОбеспечение";
	ТекущееДело.Представление = НСтр("ru = 'Заявки на обеспечение к отработке'");
	ТекущееДело.Количество = КоличествоЗаявокКОбработке;
	ТекущееДело.Форма = "Документ.ЗаявкаНаОбеспечение.ФормаСписка";
	ТекущееДело.ПараметрыФормы = ПараметрыФормы;
	ТекущееДело.Владелец = ИдентификаторРодителя;
	ТекущееДело.ЕстьДела = ЕстьДела;
		
КонецПроцедуры

