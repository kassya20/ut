// Параметры получения данных заполнения на основании.
// 
// Возвращаемое значение:
//  Структура - Параметры получения данных заполнения на основании:
// * ПоддерживаетсяРаботаСоСтроками - Булево - В заполняемом документе можно указывать номенклатуру строкой
// * ТипНоменклатуры - Массив Из ПеречислениеСсылка.ТипыНоменклатуры
Функция ПараметрыПолученияДанныхЗаполненияНаОсновании() Экспорт

	ВозвращаемоеЗначение = Новый Структура;
	ВозвращаемоеЗначение.Вставить("ПоддерживаетсяРаботаСоСтроками", Ложь);
	ВозвращаемоеЗначение.Вставить("ТипНоменклатуры", НоменклатураКлиентСервер.ОтборПоТоваруМногооборотнойТареУслугеРаботе(Ложь));
	
	Возврат ВозвращаемоеЗначение;
	
КонецФункции

// Возвращает данные для заполнения документа на основании Заявки на обеспечение.
//
// Параметры:
//   Ссылка - ДокументСсылка.ЗаявкаНаОбеспечение - Документ-основание
//   ПараметрыПолучения - См. ПараметрыПолученияДанныхЗаполненияНаОсновании
//
// Возвращаемое значение:
//   Структура:
//     * Шапка - Структура:
//         ** Организация - СправочникСсылка.Организации
//         ** Подразделение - СправочникСсылка.СтруктураПредприятия
//         ** Склад - СправочникСсылка.Склады
//         ** НаправлениеДеятельности - СправочникСсылка.НаправленияДеятельности
//      * Товары - ТаблицаЗначений:
//         ** НоменклатураСтрокой - Строка
//         ** Номенклатура - СправочникСсылка.Номенклатура
//         ** Характеристика - СправочникСсылка.ХарактеристикиНоменклатуры
//         ** Упаковка - СправочникСсылка.УпаковкиЕдиницыИзмерения
//         ** Количество - Число
//         ** КоличествоУпаковок - Число
//         ** Сумма - Число
//         ** СтатьяРасходов - ПланВидовХарактеристикСсылка.СтатьиРасходов
//         ** АналитикаРасходов - Характеристика.СтатьиРасходов
//         ** СтатьяБюджетов - СправочникСсылка.СтатьиБюджетов
//         ** СписатьНаРасходы - Булево
Функция ДанныеЗаполненияНаОсновании(Ссылка, Знач ПараметрыПолучения = Неопределено) Экспорт
	
	Если ПараметрыПолучения = Неопределено Тогда
		ПараметрыПолучения = ПараметрыПолученияДанныхЗаполненияНаОсновании();
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	ОбщегоНазначенияКлиентСервер.ДополнитьСтруктуру(Запрос.Параметры, ПараметрыПолучения);
	ТекстыЗапроса = Новый СписокЗначений;
	
	ТекстыЗапроса.Добавить(
		"ВЫБРАТЬ
		|	ЗаявкаНаОбеспечение.Организация             КАК Организация,
		|	ЗаявкаНаОбеспечение.Подразделение           КАК Подразделение,
		|	ЗаявкаНаОбеспечение.Склад                   КАК Склад,
		|	ЗаявкаНаОбеспечение.Валюта                  КАК Валюта,
		|	ЗаявкаНаОбеспечение.НаправлениеДеятельности КАК НаправлениеДеятельности
		|ИЗ
		|	Документ.ЗаявкаНаОбеспечение КАК ЗаявкаНаОбеспечение
		|ГДЕ
		|	ЗаявкаНаОбеспечение.Ссылка = &Ссылка",
		"Шапка");
	
	ТекстыЗапроса.Добавить(
		"ВЫБРАТЬ
		|	ТаблицаТовары.НоменклатураСтрокой КАК НоменклатураСтрокой,
		|	ТаблицаТовары.Номенклатура        КАК Номенклатура,
		|	ТаблицаТовары.Характеристика      КАК Характеристика,
		|	ТаблицаТовары.Упаковка            КАК Упаковка,
		|	ТаблицаТовары.Количество          КАК Количество,
		|	ТаблицаТовары.КоличествоУпаковок  КАК КоличествоУпаковок,
		|	ТаблицаТовары.Сумма               КАК Сумма,
		|	ИСТИНА                            КАК СписатьНаРасходы,
		|	ТаблицаТовары.АналитикаРасходов   КАК АналитикаРасходов,
		|	ТаблицаТовары.СтатьяРасходов      КАК СтатьяРасходов,
		|	Шапка.НаправлениеДеятельности     КАК НаправлениеДеятельности
		|ИЗ
		|	Документ.ЗаявкаНаОбеспечение.Товары КАК ТаблицаТовары
		|	ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЗаявкаНаОбеспечение КАК Шапка
		|		ПО ТаблицаТовары.Ссылка = Шапка.Ссылка
		|ГДЕ
		|	ТаблицаТовары.Ссылка = &Ссылка
		|	И (ТаблицаТовары.Номенклатура.ТипНоменклатуры В (&ТипНоменклатуры)
		|		ИЛИ ТаблицаТовары.Номенклатура = ЗНАЧЕНИЕ(Справочник.Номенклатура.ПустаяСсылка)
		| 			И &ПоддерживаетсяРаботаСоСтроками)",
		"Товары");

	РезультатПакета = ОбщегоНазначенияУТ.ПолучитьРезультатыЗапроса(Запрос, ТекстыЗапроса);
	
	РезультатЗапроса = РезультатПакета.Шапка; // РезультатЗапроса
	Выборка = РезультатЗапроса.Выбрать();
	Выборка.Следующий();
	
	Шапка = Новый Структура;
	Для Каждого Колонка Из Выборка.Владелец().Колонки Цикл
		Шапка.Вставить(Колонка.Имя, Выборка[Колонка.Имя]);
	КонецЦикла;
	
	Товары = РезультатПакета.Товары.Выгрузить(); // ТаблицаЗначений
	
	ВозвращаемоеЗначение = Новый Структура;
	ВозвращаемоеЗначение.Вставить("Шапка", Шапка);
	ВозвращаемоеЗначение.Вставить("Товары", Товары);
	
	Возврат ВозвращаемоеЗначение;
	
КонецФункции

// Возвращает данные, используемые в обработках заполнения платежных документов.
//
// Параметры:
//   Ссылка - ДокументСсылка.ЗаявкаНаОбеспечение - ссылка на документ "Заявка на обеспечение"
//
// Возвращаемое значение:
//   Структура:
//     * РезультатЗапросаШапки - РезультатЗапроса - Данные для шапки документов
Функция ДанныеДляОплаты(Ссылка) Экспорт

	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	Шапка.Организация                                             КАК Организация,
	|	Шапка.Подразделение                                           КАК Подразделение,
	|	Шапка.СуммаДокумента                                          КАК Сумма,
	|	Шапка.Валюта                                                  КАК Валюта,
	|	Шапка.Валюта                                                  КАК ВалютаВзаиморасчетов,
	|	Шапка.НаправлениеДеятельности                                 КАК НаправлениеДеятельности,
	|	&Ссылка                                                       КАК ДокументОснование,
	|	&Период                                                       КАК ЖелательнаяДатаПлатежа,
	|	
	|	ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.ОплатаПоставщику) КАК ХозяйственнаяОперация,
	|
	|	// Обязательные реквизиты методов ""ЗаполнитьРеквизитыПоРезультатуЗапроса"":
	|	ЗНАЧЕНИЕ(Справочник.Партнеры.ПустаяСсылка)                    КАК Партнер,
	|	ЗНАЧЕНИЕ(Справочник.Контрагенты.ПустаяСсылка)                 КАК Контрагент,
	|	ЗНАЧЕНИЕ(Справочник.ДоговорыКонтрагентов.ПустаяСсылка)        КАК Договор,
	|	ЗНАЧЕНИЕ(Справочник.БанковскиеСчетаОрганизаций.ПустаяСсылка)  КАК БанковскийСчет,
	|	ЗНАЧЕНИЕ(Справочник.БанковскиеСчетаКонтрагентов.ПустаяСсылка) КАК БанковскийСчетКонтрагента,
	|	ЗНАЧЕНИЕ(Перечисление.ФормыОплаты.ПустаяСсылка)               КАК ФормаОплатыЗаявки,
	|	ЛОЖЬ                                                          КАК ФормаОплатыНаличная,    // Устанавливается в истину, если ФормаОплатыЗаявки не заполнена
	|	ЛОЖЬ                                                          КАК ФормаОплатыБезналичная  // Устанавливается в истину, если ФормаОплатыЗаявки не заполнена
	|ИЗ
	|	Документ.ЗаявкаНаОбеспечение КАК Шапка
	|ГДЕ
	|	Шапка.Ссылка = &Ссылка";

	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	Запрос.УстановитьПараметр("Период", ТекущаяДатаСеанса());
	
	РезультатЗапросаШапки = Запрос.Выполнить();
	
	ВозвращаемоеЗначение = Новый Структура;
	ВозвращаемоеЗначение.Вставить("РезультатЗапросаШапки", РезультатЗапросаШапки);
	
	Возврат ВозвращаемоеЗначение;
	
КонецФункции

// Заполняет табличную часть "Расшифровка платежа" платежного документа на основании заявки на обеспечение.
// Параметры:
//  ПлатежныйДокумент - ДокументОбъект.ЗаявкаНаРасходованиеДенежныхСредств, ДокументОбъект.РасходныйКассовыйОрдер, ДокументОбъект.СписаниеБезналичныхДенежныхСредств - Заполняемый документ.
//  ДанныеДляОплаты - См. ДанныеДляОплаты
Процедура ЗаполнитьРасшифровкуПлатежа(ПлатежныйДокумент, ДанныеДляОплаты) Экспорт
	
	// Для заполнения расшифровки не используются данные табличной части, т.к. в них нет информации для разбивки.
	// Переиспользуем данные для заполнения шапки
	Выборка = ДанныеДляОплаты.РезультатЗапросаШапки.Выбрать();
	Выборка.Следующий();
	
	ПлатежныйДокумент.РасшифровкаПлатежа.Очистить();
	СтрокаРасшифровки = ПлатежныйДокумент.РасшифровкаПлатежа.Добавить();
	
	СтрокаРасшифровки.Организация = Выборка.Организация;
	СтрокаРасшифровки.СтатьяДвиженияДенежныхСредств = Справочники.СтатьиДвиженияДенежныхСредств.СтатьяДвиженияДенежныхСредствПоХозяйственнойОперации(Перечисления.ХозяйственныеОперации.ОплатаПоставщику);
	СтрокаРасшифровки.Сумма = Выборка.Сумма;
	СтрокаРасшифровки.СуммаВзаиморасчетов = Выборка.Сумма;
	СтрокаРасшифровки.ВалютаВзаиморасчетов = Выборка.Валюта;
	
	ПлатежныйДокумент.СуммаДокумента = ПлатежныйДокумент.РасшифровкаПлатежа.Итог("Сумма");
	
КонецПроцедуры

