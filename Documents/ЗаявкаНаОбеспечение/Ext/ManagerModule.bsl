#Область Проведение

// Пользовательский интерфейс документа упрощен. Режим записи документа определяется по его статусу.
// 
// Параметры:
//  Объект - ДокументОбъект.ЗаявкаНаОбеспечение, ДанныеФормыСтруктура - Для которого необходимо определить режим записи.
// 
// Возвращаемое значение:
//  РежимЗаписиДокумента
Функция РежимЗаписи(Объект) Экспорт
	
	ВозвращаемоеЗначение = РежимЗаписиДокумента.Запись;
	
	ПредыдущееСостояние = Новый Структура;
	ПредыдущееСостояние.Вставить("Проведен", Ложь);
	ПредыдущееСостояние.Вставить("ПометкаУдаления", Ложь);
	
	Если ЗначениеЗаполнено(Объект.Ссылка) Тогда
		ПредыдущееСостояние = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(
			Объект.Ссылка,
			ОбщегоНазначенияКлиентСервер.КлючиСтруктурыВСтроку(ПредыдущееСостояние));
	КонецЕсли;
	
	Проводить = Перечисления.СтатусыЗаявокНаОбеспечение.Проводить(Объект.Статус);
	
	Если Объект.ПометкаУдаления  
		И Не ПредыдущееСостояние.ПометкаУдаления
		И ПредыдущееСостояние.Проведен Тогда
		
		// Устанавливается пометка удаления у проведенного документа. Отменяем проведение.
		ВозвращаемоеЗначение = РежимЗаписиДокумента.ОтменаПроведения; 
		
	ИначеЕсли Не Проводить И ПредыдущееСостояние.Проведен Тогда
		
		// Установлен статус не требующий проведение.
		ВозвращаемоеЗначение = РежимЗаписиДокумента.ОтменаПроведения;
		
	ИначеЕсли Проводить Тогда
		
		// В том числе для помеченного на удаление (будет вызвано исключение)
		ВозвращаемоеЗначение = РежимЗаписиДокумента.Проведение;
		
	КонецЕсли;
	
	Возврат ВозвращаемоеЗначение;
	
КонецФункции

#КонецОбласти


#КонецОбласти

#КонецЕсли
