
#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ОбработчикиСобытий

Процедура ОбработкаЗаполнения(ДанныеЗаполнения, ТекстЗаполнения, СтандартнаяОбработка)
	
	ЗаполнениеОбъектовПоСтатистике.ЗаполнитьРеквизитыОбъекта(ЭтотОбъект, ДанныеЗаполнения);
	ИнициализироватьДокумент();
	Товары.Добавить(); // Чтобы была возможность редактирования в упрощенном интерфейсе.
	
КонецПроцедуры

Процедура ПриКопировании(ОбъектКопирования)
	
	Дата = ТекущаяДатаСеанса();
	Протокол.Очистить();
	Статус = Перечисления.СтатусыЗаявокНаОбеспечение.Черновик;
	ИнициализироватьДокумент();
	
КонецПроцедуры

Процедура ОбработкаПроверкиЗаполнения(Отказ, ПроверяемыеРеквизиты)
	
	НепроверяемыеРеквизиты = Новый Массив;
		
	ОднаПозиция = Ложь; // Для программной обработки считаем, что всегда таблица, чтобы была привязка к объекту.
	Если ДополнительныеСвойства.Свойство("ОднаПозиция") Тогда
		ОднаПозиция = ДополнительныеСвойства.ОднаПозиция;
	КонецЕсли;
	
	ИспользоватьЛимитыБДР = Ложь; // Значение по умолчанию для УТ.
			
	
	ЗаявкаСогласована = Перечисления.СтатусыЗаявокНаОбеспечение.Согласована(Статус);
	
	ИменаРеквизитовЗакупки = Документы.ЗаявкаНаОбеспечение.ИменаРеквизитовЗакупки();
	ИменаРеквизитовАналитикЛимитирования = Документы.ЗаявкаНаОбеспечение.ИменаРеквизитовАналитикЛимитирования();
	ИменаРеквизитовРучнойПроверки = Новый Массив;
	
	Если ИспользоватьЛимитыБДР И ЗаявкаСогласована Тогда
		ОбщегоНазначенияКлиентСервер.ДополнитьМассив(ИменаРеквизитовРучнойПроверки, ИменаРеквизитовАналитикЛимитирования);
	Иначе
		ОбщегоНазначенияКлиентСервер.ДополнитьМассив(НепроверяемыеРеквизиты, ИменаРеквизитовАналитикЛимитирования);
	КонецЕсли;
	
	Если Документы.ЗаявкаНаОбеспечение.ПроверятьРеквизитыЗакупки(ЭтотОбъект) Тогда
		ОбщегоНазначенияКлиентСервер.ДополнитьМассив(ИменаРеквизитовРучнойПроверки, ИменаРеквизитовЗакупки);
	Иначе
		ОбщегоНазначенияКлиентСервер.ДополнитьМассив(НепроверяемыеРеквизиты, ИменаРеквизитовЗакупки);
	КонецЕсли;
	
	Если ОднаПозиция Тогда
		
		ИменаРеквизитовРучнойПроверки.Добавить("Товары.НоменклатураСтрокой");
		
		ПроверитьЗаполнениеРеквизитовЕдинственнойПозиции(
			ИменаРеквизитовРучнойПроверки,
			ПредставленияРеквизитовТоваров(),
			НепроверяемыеРеквизиты,
			Отказ);
		
	КонецЕсли;
	
	Если Не ЗаявкаСогласована Тогда
		ОбщегоНазначенияКлиентСервер.ДополнитьМассив(НепроверяемыеРеквизиты, Документы.ЗаявкаНаОбеспечение.ИменаРеквизитовШапки());
	КонецЕсли;
	
	ПараметрыПроверкиЗаполненияКоличества = НоменклатураСервер.ПараметрыПроверкиЗаполненияКоличества();
	ПараметрыПроверкиЗаполненияКоличества.ЭтоПроверкаТекущейСтроки = ОднаПозиция;
	НоменклатураСервер.ПроверитьЗаполнениеКоличества(
		ЭтотОбъект,
		ПроверяемыеРеквизиты,
		Отказ,
		ПараметрыПроверкиЗаполненияКоличества);
	
	ПараметрыПроверкиЗаполненияХарактеристик = НоменклатураСервер.ПараметрыПроверкиЗаполненияХарактеристик();
	ПараметрыПроверкиЗаполненияХарактеристик.ЭтоПроверкаТекущейСтроки = ОднаПозиция;
	НоменклатураСервер.ПроверитьЗаполнениеХарактеристик(
		ЭтотОбъект,
		НепроверяемыеРеквизиты,
		Отказ,
		ПараметрыПроверкиЗаполненияХарактеристик);
	
	ОбщегоНазначения.УдалитьНепроверяемыеРеквизитыИзМассива(ПроверяемыеРеквизиты, НепроверяемыеРеквизиты);
	
	ПараметрыВыбораСтатейИАналитик = Документы.ЗаявкаНаОбеспечение.ПараметрыВыбораСтатейИАналитик(ОбеспечиваетсяЗакупкой);
	ДоходыИРасходыСервер.ОбработкаПроверкиЗаполнения(ЭтотОбъект, Отказ, ПроверяемыеРеквизиты, ПараметрыВыбораСтатейИАналитик);
	
	
КонецПроцедуры

Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)
	
	Если ОбменДанными.Загрузка Тогда
		Возврат;
	КонецЕсли;
	
	ОбновлениеИнформационнойБазы.ПроверитьОбъектОбработан(ЭтотОбъект);
	
	УстанавливаемыйРежимЗаписи = Документы.ЗаявкаНаОбеспечение.РежимЗаписи(ЭтотОбъект);
	Если УстанавливаемыйРежимЗаписи = РежимЗаписиДокумента.Проведение
		И УстанавливаемыйРежимЗаписи <> РежимЗаписи
		И Не ДополнительныеСвойства.Свойство("ПропуститьПроверкуЗаполнения") 
		И Не ПроверитьЗаполнение() Тогда
		Отказ = Истина;
		Возврат;
	КонецЕсли;
	
	РежимЗаписи = УстанавливаемыйРежимЗаписи;
	ПроведениеДокументов.ПередЗаписьюДокумента(ЭтотОбъект, РежимЗаписи, РежимПроведения);
	НоменклатураСервер.ОкруглитьКоличествоШтучныхТоваров(ЭтотОбъект, РежимЗаписи);
	РаботаСПротоколомДокумента.ПередЗаписью(ЭтотОбъект, Отказ, РежимЗаписи, РежимПроведения);
	ОчиститьРеквизитыЗакупки();
	
	СуммаДокумента = Товары.Итог("Сумма");
	
	Если Не ЗначениеЗаполнено(Номер) Тогда
		УстановитьНовыйНомер();
	КонецЕсли;
	
КонецПроцедуры

Процедура ПриЗаписи(Отказ)
	
	Если ОбменДанными.Загрузка Тогда
		Возврат;
	КонецЕсли;
	
	ПроведениеДокументов.ПриЗаписиДокумента(ЭтотОбъект, Отказ);
	
КонецПроцедуры

Процедура ОбработкаПроведения(Отказ, РежимПроведения)
	ПроведениеДокументов.ОбработкаПроведенияДокумента(ЭтотОбъект, Отказ);
КонецПроцедуры

Процедура ОбработкаУдаленияПроведения(Отказ)
	
	ПроведениеДокументов.ОбработкаУдаленияПроведенияДокумента(ЭтотОбъект, Отказ);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

#Область ИнициализацияИЗаполнение

Процедура ИнициализироватьДокумент(ДанныеЗаполнения = Неопределено)
	
	Автор = Пользователи.ТекущийПользователь();
	
	Если Не ЗначениеЗаполнено(Исполнитель) Тогда
		Исполнитель = Автор;
	КонецЕсли;
	
	Организация = ЗначениеНастроекПовтИсп.ПолучитьОрганизациюПоУмолчанию(Организация);
	Подразделение = ЗначениеНастроекПовтИсп.ПодразделениеПользователя(Автор, Подразделение);
	Склад = ЗначениеНастроекПовтИсп.ПолучитьСкладПоУмолчанию(Склад);
	
	ОтображатьРеквизитыЗакупки = Документы.ЗаявкаНаОбеспечение.ОтображатьРеквизитыЗакупки(ЭтотОбъект);
	
	Если Не ЗначениеЗаполнено(Валюта)
		И ОтображатьРеквизитыЗакупки Тогда
		Валюта = ЗначениеНастроекПовтИсп.ВалютаРегламентированногоУчетаОрганизации(Организация);
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(Валюта)
		И ОтображатьРеквизитыЗакупки Тогда
		// Повторная попытка заполнения валюты, в случае, если организация не заполнена.
		Валюта = ЗначениеНастроекПовтИсп.БазоваяВалютаПоУмолчанию();
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбеспечениеЗакупкой

Процедура ОчиститьРеквизитыЗакупки()
	
	Если Документы.ЗаявкаНаОбеспечение.ОтображатьРеквизитыЗакупки(ЭтотОбъект) Тогда
		Возврат;
	КонецЕсли;
	
	ДанныеШапки = Новый Структура;
	ДанныеСтроки = Новый Структура;
	
	Для Каждого ИсходноеИмяРеквизита Из Документы.ЗаявкаНаОбеспечение.ИменаРеквизитовЗакупки() Цикл
		
		ИмяРеквизита = СтрЗаменить(ИсходноеИмяРеквизита, "Товары.", "");
		
		Если ИмяРеквизита = ИсходноеИмяРеквизита Тогда
			ДанныеШапки.Вставить(ИмяРеквизита);
		Иначе
			ДанныеСтроки.Вставить(ИмяРеквизита);
		КонецЕсли;
		
	КонецЦикла;
	
	ЗаполнитьЗначенияСвойств(ЭтотОбъект, ДанныеШапки);
	Для Каждого СтрокаТовара Из Товары Цикл
		ЗаполнитьЗначенияСвойств(СтрокаТовара, ДанныеСтроки);
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти

#Область ОднаПозиция

Функция ПредставленияРеквизитовТоваров()
	
	ВозвращаемоеЗначение = Новый Структура;
	
	Реквизиты = Ссылка.Метаданные().ТабличныеЧасти.Товары.Реквизиты;
	Для Каждого Реквизит Из Реквизиты Цикл
		
		ПредставлениеРеквизита = Реквизит.Представление();
		ВозвращаемоеЗначение.Вставить(Реквизит.Имя, ПредставлениеРеквизита);
		
	КонецЦикла;
	
	Возврат ВозвращаемоеЗначение;
	
КонецФункции

Процедура ПроверитьЗаполнениеРеквизитовЕдинственнойПозиции(ИменаРеквизитов, ПредставленияРеквизитов, НепроверяемыеРеквизиты, Отказ)
	
	ПрефиксТоваров = "Товары.";
	СтрокаТоваров = Товары[0]; // Проверка наличия строки до вызова
	Для Каждого ИмяРеквизита Из ИменаРеквизитов Цикл
		
		ИмяРеквизитаТаблицы = СтрЗаменить(ИмяРеквизита, ПрефиксТоваров, "");
		
		Если ИмяРеквизитаТаблицы = ИмяРеквизита Тогда
			Продолжить;
		КонецЕсли;
		
		НепроверяемыеРеквизиты.Добавить(ИмяРеквизита);
		
		Если Не ЗначениеЗаполнено(СтрокаТоваров[ИмяРеквизитаТаблицы]) Тогда
			
			ТекстОшибки = ОбщегоНазначенияКлиентСервер.ТекстОшибкиЗаполнения(
				"Поле",
				"Заполнение",
				ПредставленияРеквизитов[ИмяРеквизитаТаблицы]);
				
			ПутьКЭлементу = ОбщегоНазначенияУТКлиентСервер.ПутьКЭлементуТекущейСтрокиТаблицыФормы(
				"Товары",
				ИмяРеквизитаТаблицы);
				
			ОбщегоНазначения.СообщитьПользователю(
				ТекстОшибки,
				,// При выводе ошибки в "элемент" нельзя указать объект.
				ПутьКЭлементу,,
				Отказ);
				
		КонецЕсли;
			
	КонецЦикла;
	
КонецПроцедуры
#КонецОбласти

#КонецОбласти

#КонецЕсли