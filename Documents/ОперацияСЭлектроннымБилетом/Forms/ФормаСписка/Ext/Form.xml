	<Attributes>
		<Attribute name="Список" id="1">
			<Type>
				<v8:Type>cfg:DynamicList</v8:Type>
			</Type>
			<MainAttribute>true</MainAttribute>
			<UseAlways>
				<Field>Список.Ссылка</Field>
				<Field>Список.ЭтоЭлектронныйБилет</Field>
			</UseAlways>
			<Settings xsi:type="DynamicList">
				<ManualQuery>true</ManualQuery>
				<DynamicDataRead>false</DynamicDataRead>
				<QueryText>ВЫБРАТЬ
	ДанныеДокумента.ТипУслуги КАК ТипУслуги,
	ВЫБОР
		КОГДА ДанныеДокумента.ТипОперации = ЗНАЧЕНИЕ(Перечисление.ТипыОперацийСБилетами.ПустаяСсылка)
			ТОГДА &amp;ТипДокументаЭлектронныйБилет
		ИНАЧЕ ДанныеДокумента.ТипОперации
	КОНЕЦ КАК ТипДокумента,
	ДанныеДокумента.ТипОперации = ЗНАЧЕНИЕ(Перечисление.ТипыОперацийСБилетами.ПустаяСсылка) КАК ЭтоЭлектронныйБилет,
	ДанныеДокумента.НомерБилета КАК НомерБилета,
	ДанныеДокумента.Номер КАК Номер,
	ДанныеДокумента.Дата КАК Дата,
	ДанныеДокумента.Сотрудник КАК Сотрудник,
	ВЫБОР
