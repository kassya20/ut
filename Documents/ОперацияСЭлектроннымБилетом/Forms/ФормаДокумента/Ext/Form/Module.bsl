Процедура ОперацииБилетаПослеУстановкиПометкиНаУдаление(Результат, ДополнительныеСвойства) Экспорт
	
	ОбновитьОперацииБилета(ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(ДополнительныеСвойства.Операция));
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьСтрокуОпераций(Источник, ПоляИсточника)
	
	ИзменяемыеСтроки =
		Объект.Операции.НайтиСтроки(Новый Структура("ИдентификаторСтроки", Источник.ИдентификаторСтроки));
	Если ИзменяемыеСтроки.Количество() Тогда
		ЗаполнитьЗначенияСвойств(ИзменяемыеСтроки[0], Источник, ПоляИсточника);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура СоздатьОперациюСЭлектроннымБилетом(ТипОперации, ЭтоПолныйВозврат = Ложь)
	
	ОписаниеОперации = Новый Структура;
	ОписаниеОперации.Вставить("ТипОперации", ТипОперации);
	ОписаниеОперации.Вставить("ЭтоПолныйВозврат", ЭтоПолныйВозврат);
	
	ДанныеДляСозданияОперацииБилета = Новый Структура;
	ДанныеДляСозданияОперацииБилета.Вставить("ДанныеЭлектронногоБилета", Объект);
	ДанныеДляСозданияОперацииБилета.Вставить("ОписаниеОперации", ОписаниеОперации);
	ДанныеДляСозданияОперацииБилета.Вставить("ЭтоРазделениеБилета", Ложь);
	
	ПараметрыОснования = Новый Структура();
	ПараметрыОснования.Вставить("ЭлектронныйБилет", Объект.Ссылка);
	ПараметрыОснования.Вставить("ДанныеДляСозданияОперацииБилета", ДанныеДляСозданияОперацииБилета);
	
	ДополнительныеПараметры = Новый Структура;
	ДополнительныеПараметры.Вставить("ПараметрыОснования", ПараметрыОснования);
	ДополнительныеПараметры.Вставить("ТребуетсяЗаписьБилета", Ложь);
	ОписаниеОповещения = Новый ОписаниеОповещения("СоздатьОперациюСЭлектроннымБилетомПродолжение", ЭтотОбъект, ДополнительныеПараметры);
	
	Если Не ЗначениеЗаполнено(Объект.Ссылка) Или Модифицированность Тогда
		ОписаниеОповещения.ДополнительныеПараметры.ТребуетсяЗаписьБилета = Истина;
		ПоказатьВопрос(ОписаниеОповещения,
			НСтр("ru = 'Перед созданием операции необходимо записать электронный билет. Выполнить запись?'"), РежимДиалогаВопрос.ДаНет);
	Иначе
		ВыполнитьОбработкуОповещения(ОписаниеОповещения, КодВозвратаДиалога.Да);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура СоздатьОперациюСЭлектроннымБилетомПродолжение(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = КодВозвратаДиалога.Да Тогда
		
		Если ДополнительныеПараметры.ТребуетсяЗаписьБилета Тогда
			БилетЗаписан = Записать();
		Иначе
			БилетЗаписан = Истина;
		КонецЕсли;
		
		Если БилетЗаписан Тогда
			ДополнительныеПараметры.ПараметрыОснования.ЭлектронныйБилет = Объект.Ссылка;
			ОткрытьФорму(
				"Документ.ОперацияСЭлектроннымБилетом.Форма.ФормаОперацииЭлектронногоБилета",
				Новый Структура("Основание", ДополнительныеПараметры.ПараметрыОснования));
		КонецЕсли;
			
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьОперацииБилета(СсылкиНаОперации = Неопределено)
	
	ТаблицаОпераций = Документы.ОперацияСЭлектроннымБилетом.ОперацииЭлектронногоБилета(Объект.Ссылка, СсылкиНаОперации);
	
	Если Не ЗначениеЗаполнено(СсылкиНаОперации) Тогда
		ОперацииБилета.Загрузить(ТаблицаОпераций);
	Иначе
		
		СтрокиКУдалению = Новый Массив;
		Для Каждого ОперацияЭлектронногоБилета Из СсылкиНаОперации Цикл
			СтрокиОперации = ОперацииБилета.НайтиСтроки(Новый Структура("Ссылка", ОперацияЭлектронногоБилета));
			Для Каждого СтрокаОперации Из СтрокиОперации Цикл
				СтрокиКУдалению.Добавить(СтрокаОперации);
			КонецЦикла;
		КонецЦикла;
		
		Для Каждого УдаляемаяСтрока Из СтрокиКУдалению Цикл
			ОперацииБилета.Удалить(УдаляемаяСтрока);
		КонецЦикла;
		
		Для Каждого НоваяСтрокаОпераций Из ТаблицаОпераций Цикл
			ЗаполнитьЗначенияСвойств(ОперацииБилета.Добавить(), НоваяСтрокаОпераций);
		КонецЦикла;
		
	КонецЕсли;
	
	ОперацииБилета.Сортировать("Дата,ПорядокОперации");
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьДоговорПоУмолчанию()
	
	Если Объект.ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.БронированиеЧерезПодотчетноеЛицо Тогда
		Возврат;
	КонецЕсли;
	
	ДопПараметры = ЗакупкиСервер.ДополнительныеПараметрыОтбораДоговоров();
	ДопПараметры.ВалютаВзаиморасчетов = Объект.Валюта;
	ДопПараметры.ПорядокРасчетов = Перечисления.ПорядокРасчетов.ПоДоговорамКонтрагентов;
	
	ПараметрыДоговора = Новый Структура;
	ПараметрыДоговора.Вставить("Организация", Объект.Организация);
	ПараметрыДоговора.Вставить("Договор",     Объект.Договор);
	
	Если Объект.ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.БронированиеУПоставщика Тогда
		ПараметрыДоговора.Вставить("Партнер",     Объект.Перевозчик);
		ПараметрыДоговора.Вставить("Контрагент",  Объект.КонтрагентПеревозчик);
	ИначеЕсли Объект.ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.БронированиеЧерезАгента Тогда
		ПараметрыДоговора.Вставить("Партнер",     Объект.Агент);
		ПараметрыДоговора.Вставить("Контрагент",  Объект.КонтрагентАгент);
	КонецЕсли;
		
	Объект.Договор = ЗакупкиСервер.ПолучитьДоговорПоУмолчанию(
		ПараметрыДоговора, Перечисления.ХозяйственныеОперации.ЗакупкаУПоставщика, ДопПараметры);
	
КонецПроцедуры

&НаКлиенте
Функция ПокупкаПолностьюВозвращена()
	
	СуммаПокупок = 0;
	СуммаВозвратов = 0;
		
	ОперацияВозврата = ПредопределенноеЗначение("Перечисление.ТипыОперацийСБилетами.Возврат");
	ОперацияПокупки = ПредопределенноеЗначение("Перечисление.ТипыОперацийСБилетами.Покупка");
		
	Для Каждого СтрокаОперации Из Объект.Операции Цикл
		Если СтрокаОперации.ТипОперации = ОперацияПокупки Тогда
			СуммаПокупок = СуммаПокупок + СтрокаОперации.Сумма;
		КонецЕсли;
	КонецЦикла;
		
	СтрокиАктивныхОпераций = ОперацииБилета.НайтиСтроки(Новый Структура("ПометкаУдаления", Ложь));
	Для Каждого СтрокаОперации Из СтрокиАктивныхОпераций Цикл
		
		Если СтрокаОперации.ТипОперации = ОперацияВозврата Тогда
			СуммаВозвратов = СуммаВозвратов + СтрокаОперации.Сумма;
		Иначе
			СуммаПокупок = СуммаПокупок + СтрокаОперации.Сумма;
		КонецЕсли;
		
	КонецЦикла;
		
	Возврат СуммаВозвратов >= СуммаПокупок;
	
КонецФункции

&НаКлиенте
Процедура РассчитатьНДС(ОбрабатываемаяСтрока)
	
	Если Не ЗначениеЗаполнено(ОбрабатываемаяСтрока.СтавкаНДС) Тогда
		ОбрабатываемаяСтрока.СтавкаНДС = ПредопределенноеЗначение("Справочник.СтавкиНДС.БезНДС");
	КонецЕсли;
	
	ДанныеСтроки = Новый Структура;
	ДанныеСтроки.Вставить("СтавкаНДС", ОбрабатываемаяСтрока.СтавкаНДС);
	ДанныеСтроки.Вставить("СуммаНДС", ОбрабатываемаяСтрока.СуммаНДС);
	ДанныеСтроки.Вставить("Сумма", ОбрабатываемаяСтрока.Сумма);
	
	ПараметрыПересчетаНДС = Новый Структура("ЦенаВключаетНДС", Истина);
	СтруктураДействий = Новый Структура("ПересчитатьСуммуНДС", ПараметрыПересчетаНДС);
	ПакетнаяОбработкаТабличнойЧастиКлиент.ОбработатьСтрокуТЧ(ДанныеСтроки, СтруктураДействий, КэшированныеЗначения);
	
	ОбрабатываемаяСтрока.СуммаНДС = ДанныеСтроки.СуммаНДС;
	
КонецПроцедуры

// СтандартныеПодсистемы.ПодключаемыеКоманды
&НаСервере
Процедура ВыполнитьКомандуНаСервере(ПараметрыВыполнения)
	ПодключаемыеКоманды.ВыполнитьКоманду(ЭтотОбъект, ПараметрыВыполнения, Объект);
КонецПроцедуры
// // Конец СтандартныеПодсистемы.ПодключаемыеКоманды

&НаКлиенте
Процедура ТекстАвансовыйОтчетОбработкаНавигационнойСсылкиПродолжение(Результат, ДополнительныеПараметры) Экспорт
	
	Если Не Результат = КодВозвратаДиалога.Да Тогда
		Возврат;
	КонецЕсли;
	
	Если Результат = КодВозвратаДиалога.Да Тогда
		Если ДополнительныеПараметры.ТребуетсяЗаписьБилета Тогда
			БилетЗаписан = Записать();
		Иначе
			БилетЗаписан = Истина;
		КонецЕсли;
	КонецЕсли;
	
	Если Не БилетЗаписан Тогда
		Возврат;
	КонецЕсли;
	
	Если ДополнительныеПараметры.НавигационнаяСсылкаФорматированнойСтроки = "ОчиститьАвансовыйОтчет" Тогда
		
		СообщениеОбОшибке = "";
		Если ИзменениеАвансовогоОтчетаЗапрещено(Объект.АвансовыйОтчет, СообщениеОбОшибке) Тогда
			ОбщегоНазначенияКлиент.СообщитьПользователю(СообщениеОбОшибке, , , "ТекстАвансовыйОтчет");
		Иначе
			Объект.АвансовыйОтчет = Неопределено;
			Модифицированность = Истина;
			ТекстАвансовыйОтчет = Новый ФорматированнаяСтрока(НСтр("ru = 'Включить в авансовый отчет'"),,,, "ВключитьВАвансовыйОтчет");
		КонецЕсли;
		
	ИначеЕсли ДополнительныеПараметры.НавигационнаяСсылкаФорматированнойСтроки = "ВключитьВАвансовыйОтчет" Тогда
		
		Если ПокупкаПолностьюВозвращена() Тогда
			ОчиститьСообщения();
			ОбщегоНазначенияКлиент.СообщитьПользователю(НСтр("ru = 'Покупка полностью возвращена. Авансовый отчет не требуется.'"));
			Возврат;
		КонецЕсли;
		
		Отбор = Новый Структура;
		Отбор.Вставить("Организация", Объект.Организация);
		Отбор.Вставить("Подразделение", Объект.ПодразделениеПодотчетногоЛица);
		Отбор.Вставить("ПодотчетноеЛицо", Объект.ПодотчетноеЛицо);
		
		ПараметрыФормы = Новый Структура("Отбор", Отбор);
		ПараметрыФормы.Вставить("Дата", Объект.Дата);
		ПараметрыФормы.Вставить("ДокументЗакупки", Объект.Ссылка);
		ПараметрыФормы.Вставить("Валюта", Объект.Валюта);
		
		Оповещение = Новый ОписаниеОповещения("ПослеВыбораАвансовогоОтчета", ЭтотОбъект);
		
		ОткрытьФорму("Документ.АвансовыйОтчет.Форма.ФормаВыбораСоздания", ПараметрыФормы, ЭтотОбъект,,,, Оповещение);
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПослеВыбораАвансовогоОтчета(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат <> Неопределено Тогда
		СообщениеОбОшибке = "";
		Если ИзменениеАвансовогоОтчетаЗапрещено(Результат, СообщениеОбОшибке) Тогда
			ОбщегоНазначенияКлиент.СообщитьПользователю(СообщениеОбОшибке, , , "ТекстАвансовыйОтчет");
		Иначе
			Объект.АвансовыйОтчет = Результат;
			Модифицированность = Истина;
			ОбновитьТекстАвансовыйОтчет();
		КонецЕсли;
	Иначе
		ЭтотОбъект.Прочитать();
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ПодотчетноеЛицоПриИзмененииНаСервере()
	Объект.ПодразделениеПодотчетногоЛица = ФизическиеЛицаУТ.ПодразделениеФизическогоЛица(Объект.ПодотчетноеЛицо);
КонецПроцедуры

&НаСервере
Процедура ПеревозчикПриИзмененииНаСервере()
	
	ПартнерыИКонтрагенты.ЗаполнитьКонтрагентаПартнераПоУмолчанию(Объект.Перевозчик, Объект.КонтрагентПеревозчик);
	ЗаполнитьДоговорПоУмолчанию();
	
КонецПроцедуры

&НаСервере
Процедура ДатаПокупкиПриИзмененииНаСервере()
	
	ПерезаполнитьСтавкуНДС();
	ОпределитьПечатьЕдиногоАвансовогоОтчета();
	НастроитьЗависимыеЭлементыФормыНаСервере();
	
КонецПроцедуры

&НаСервере
Процедура ДатаПрибытияПриИзмененииНаСервере()
	АктуализироватьЗакупкуПодДеятельность(Истина);
КонецПроцедуры

&НаСервере
Процедура ОрганизацияПриИзмененииСервер()
	
	Если Не ЗначениеЗаполнено(Объект.Валюта) Тогда
		Объект.Валюта = ЗначениеНастроекПовтИсп.ВалютаРегламентированногоУчетаОрганизации(Объект.Организация);
	КонецЕсли;
	
	Объект.АвансовыйОтчет = Неопределено;
	
	ПерезаполнитьСтавкуНДС();
	ЗаполнитьПодчиненныеСвойстваПоСтатистике("Организация");
	АктуализироватьЗакупкуПодДеятельность(Истина);
	ЗаполнитьДоговорПоУмолчанию();
	
КонецПроцедуры

&НаСервере
Процедура АгентПриИзмененииНаСервере()
	
	ПартнерыИКонтрагенты.ЗаполнитьКонтрагентаПартнераПоУмолчанию(Объект.Агент, Объект.КонтрагентАгент);
	ЗаполнитьДоговорПоУмолчанию();
	
КонецПроцедуры

&НаСервере
Процедура ХозяйственнаяОперацияПриИзмененииНаСервере()
	
	Объект.Договор = Неопределено;
	
	Если Объект.ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.БронированиеЧерезАгента
		Или Объект.ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.БронированиеУПоставщика Тогда
		Если Не ПолучитьФункциональнуюОпцию("ИспользоватьДоговорыСПоставщиками") Тогда
			ТекстСообщения = НСтр("ru = 'Для отражения покупки билета через агента или у перевозчика 
				|необходимо указать договор - включить использование договоров с поставщиками в разделе ""Закупки"".'");
			ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);
			Объект.ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.БронированиеЧерезПодотчетноеЛицо;
		КонецЕсли;
	КонецЕсли;
	
	ЗаполнитьПодчиненныеСвойстваПоСтатистике("ХозяйственнаяОперация");
	ЗаполнитьДоговорПоУмолчанию();
	
	УправлениеЭлементамиФормы();
	НастроитьЗависимыеЭлементыФормыНаСервере("ХозяйственнаяОперация");
	
КонецПроцедуры

