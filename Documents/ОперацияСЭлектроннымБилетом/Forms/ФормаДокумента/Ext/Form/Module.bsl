КонецПроцедуры

&НаКлиенте
Процедура ОперацииБилетаПередУдалением(Элемент, Отказ)
	
	ТекущиеДанные = ОперацииБилета.НайтиПоИдентификатору(Элемент.ТекущаяСтрока);
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если ТекущиеДанные.ЭтоТекущийЭлектронныйБилет Тогда
		Возврат;
	КонецЕсли;
	
	Отказ = Истина;
	ДополнительныеСвойства = Новый Структура;
	ДополнительныеСвойства.Вставить("Операция", ТекущиеДанные.Ссылка);
	ОписаниеОповещения = Новый ОписаниеОповещения("ОперацииБилетаПослеУстановкиПометкиНаУдаление", ЭтотОбъект, ДополнительныеСвойства);
	ОбщегоНазначенияУТКлиент.УстановитьПометкуУдаления(Элементы.ОперацииБилета, Заголовок, ОписаниеОповещения);
	
КонецПроцедуры

&НаКлиенте
Процедура ОперацииБилетаПриАктивизацииСтроки(Элемент)
	
	Если Элемент.ТекущаяСтрока = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ТекущиеДанные = ОперацииБилета.НайтиПоИдентификатору(Элемент.ТекущаяСтрока);
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если ТекущиеДанные.ЭтоТекущийЭлектронныйБилет Тогда
		ЗаголовокКомандыУдаления = НСтр("ru = 'Удалить'");
	Иначе
		ЗаголовокКомандыУдаления = НСтр("ru = 'Пометить на удаление / Снять пометку'");
	КонецЕсли;
	
	Элементы.ОперацииБилетаКонтекстноеМенюУдалить.Заголовок = ЗаголовокКомандыУдаления;
	Элементы.ОперацииБилетаУдалить.Заголовок = ЗаголовокКомандыУдаления;
	
КонецПроцедуры
