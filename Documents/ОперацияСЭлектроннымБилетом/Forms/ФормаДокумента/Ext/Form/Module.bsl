&НаКлиенте
Процедура ОперацииБилетаВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	ТекущиеДанные = ОперацииБилета.НайтиПоИдентификатору(ВыбраннаяСтрока);
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если ТекущиеДанные.ЭтоТекущийЭлектронныйБилет Тогда
		Если Поле = Элементы.ОперацииБилетаСуммаШтрафа
			И ТекущиеДанные.ТипОперации = ПредопределенноеЗначение("Перечисление.ТипыОперацийСБилетами.Возврат") Тогда
			РедактироватьКорректировку(ТекущиеДанные);
		КонецЕсли;
		Возврат;
	КонецЕсли;
	
	ПараметрыОткрытия = Новый Структура("Ключ", ТекущиеДанные.Ссылка);
	ОткрытьФорму("Документ.ОперацияСЭлектроннымБилетом.Форма.ФормаОперацииЭлектронногоБилета", ПараметрыОткрытия);
	
КонецПроцедуры

&НаКлиенте
Процедура ОперацииБилетаСуммаПриИзменении(Элемент)
	ТекущиеДанные = Элементы.ОперацииБилета.ТекущиеДанные;
	РассчитатьНДС(ТекущиеДанные);
	ОбновитьСтрокуОпераций(ТекущиеДанные, "Сумма,СуммаНДС");
