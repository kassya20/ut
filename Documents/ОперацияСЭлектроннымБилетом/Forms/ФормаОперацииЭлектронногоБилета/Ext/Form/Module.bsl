#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Процедура ЗавершениеОбработкиЗаданий(ДанныеСообщения, ДополнительныеПараметры = Неопределено) Экспорт
	
	Если ДанныеСообщения.ОбработанныйДокумент = Объект.Ссылка Тогда
		Прочитать();
	КонецЕсли;
	
Конецпроцедуры

&НаСервере
Процедура ПриСозданииПолногоВозврата(Отказ, Основание)
	
	Если ТипЗнч(Основание) = Тип("Структура")
		И Основание.Свойство("ДанныеДляСозданияОперацииБилета")
		И Параметры.Основание.ДанныеДляСозданияОперацииБилета.ОписаниеОперации.ЭтоПолныйВозврат
		И НЕ Объект.Операции.Количество() Тогда
		Отказ = Истина;
		ВызватьИсключение НСтр("ru = 'Покупка уже полностью возвращена.'");
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ОбработкаПроверкиСоставаОпераций(Отказ)
		
	Если Объект.Дата < НачалоДня(Объект.ДатаБилета) Тогда
		
		Если Объект.ТипОперации = Перечисления.ТипыОперацийСБилетами.Доплата Тогда
			ТекстОшибки = НСтр("ru = 'Нельзя ввести доплату раньше даты покупки.'");
		Иначе
			ТекстОшибки = НСтр("ru = 'Нельзя ввести возврат раньше даты покупки.'");
		КонецЕсли;
		ОбщегоНазначения.СообщитьПользователю(ТекстОшибки,, "Дата", "Объект", Отказ);
		
	КонецЕсли;
		
	Если Объект.ТипОперации = Перечисления.ТипыОперацийСБилетами.Возврат Тогда
			
		ОперацииБилета = Документы.ОперацияСЭлектроннымБилетом.ОперацииЭлектронногоБилета(Объект.ЭлектронныйБилет,, Объект.Ссылка, Истина);
		АктивныеОперацииБилета = ОперацииБилета.Скопировать(Новый Структура("ПометкаУдаления", Ложь));
		АктивныеОперацииБилета.Сортировать("Дата,ПорядокОперации");
		ОстаткиВРазрезеСтавок = Новый Соответствие;
			
		Для Каждого СтрокаСостава Из Объект.Операции Цикл
				
			СтрокиПоСтавкеНДС = АктивныеОперацииБилета.НайтиСтроки(Новый Структура("СтавкаНДС", СтрокаСостава.СтавкаНДС));
			СуммаОпераций = 0;
			Для Каждого СтрокаСтавкиНДС Из СтрокиПоСтавкеНДС Цикл
				
				Если НачалоДня(СтрокаСтавкиНДС.Дата) > НачалоДня(Объект.Дата) Тогда
					Продолжить;
				КонецЕсли;
				
				ЭтоВозврат = СтрокаСтавкиНДС.ТипОперации = Перечисления.ТипыОперацийСБилетами.Возврат;
				СуммаОпераций = СуммаОпераций + ?(ЭтоВозврат, -СтрокаСтавкиНДС.Сумма, СтрокаСтавкиНДС.Сумма);
				
			КонецЦикла;
				
			ОстатокПослеВозврата = ОстаткиВРазрезеСтавок.Получить(СтрокаСостава.СтавкаНДС);
			Если ОстатокПослеВозврата = Неопределено Тогда
				ОстатокПослеВозврата = СуммаОпераций;
			КонецЕсли;
			ОстатокПослеВозврата = ОстатокПослеВозврата - СтрокаСостава.Сумма;
			ОстаткиВРазрезеСтавок.Вставить(СтрокаСостава.СтавкаНДС, ОстатокПослеВозврата);
			
			Если ОстатокПослеВозврата < 0 Тогда
					
				Поле = ОбщегоНазначенияКлиентСервер.ПутьКТабличнойЧасти("Операции", СтрокаСостава.НомерСтроки, "Сумма");
					
				ТекстСообщения = СтрШаблон(
					НСтр("ru = 'Сумма возврата от %1 по ставке НДС ""%2""
						|превышает сумму ранее совершенных покупок на %3 %4'"),
						Формат(Объект.Дата, "ДЛФ=D"),
						СтрокаСостава.СтавкаНДС,
						-ОстатокПослеВозврата,
						Объект.Валюта);
						
				ОбщегоНазначения.СообщитьПользователю(ТекстСообщения, Объект.Ссылка, Поле, "Объект", Отказ);
					
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЕсли;
		
КонецПроцедуры

&НаСервере
Процедура ПриЧтенииСозданииНаСервере()
	
	ОбновитьЗаголовокФормы();
	ОбновитьСведенияОбЭлектронномБилете();
	
	НастройкиПолейФормы = Документы.ОперацияСЭлектроннымБилетом.НастройкиПолейФормыДляОперацииСБилетом();
	ЗначениеВРеквизитФормы(НастройкиПолейФормы, "НастройкиПолей");
	ЗависимостиПолейФормы = ДенежныеСредстваСервер.ЗависимостиПолейФормы(НастройкиПолейФормы);
	ЗначениеВРеквизитФормы(ЗависимостиПолейФормы, "ЗависимостиПолей");
	
	ДенежныеСредстваКлиентСервер.НастроитьЭлементыФормы(ЭтотОбъект);
	
КонецПроцедуры

&НаКлиенте
Процедура ИнициализироватьСоставОперации()
	
	Если Не Объект.Операции.Количество() Тогда
		НоваяСтрока = Объект.Операции.Добавить();
		НоваяСтрока.СтавкаНДС = ПредопределенноеЗначение("Справочник.СтавкиНДС.БезНДС");
		НоваяСтрока.ТипОперации = Объект.ТипОперации;
		НоваяСтрока.Дата = Объект.Дата;
		Элементы.Операции.ТекущаяСтрока = НоваяСтрока.ПолучитьИдентификатор();
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьЗаголовокФормы()
	
	Если ЗначениеЗаполнено(Объект.Ссылка) Тогда
		Шаблон = НСтр("ru='%1 по электронному билету %2 %3 от %4'");
		Заголовок = СтрШаблон(
			Шаблон,
			Строка(Объект.ТипОперации),
			Строка(Объект.ТипУслуги),
			Объект.НомерБилета,
			Объект.ДатаБилета);
	Иначе
		Шаблон = НСтр("ru='%1 (создание)'");
		Заголовок = СтрШаблон(Шаблон, Объект.ТипОперации);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьСведенияОбЭлектронномБилете()
	
	ЭлектронныйБилетФИОПассажира =
		ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.ЭлектронныйБилет, "ФИОПассажира");
	
КонецПроцедуры

&НаСервере
Процедура УстановитьУсловноеОформление()
	
	УсловноеОформление.Элементы.Очистить();
	
	// СуммаНДС
	Элемент = УсловноеОформление.Элементы.Добавить();
	
	Поля = Элемент.Поля.Элементы;
	ПолеЭлемента = Поля.Добавить();
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(Элементы.ОперацииСуммаНДС.Имя);
	
	ОтборЭлемента = Элемент.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ОтборЭлемента.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("Объект.Операции.СтавкаНДС");
	ОтборЭлемента.ВидСравнения = ВидСравненияКомпоновкиДанных.ВСписке;
	
	СтавкиБезНДС = УчетНДСУПСлужебныйКлиентСерверПовтИсп.СписокНезначащихСтавок();
	СтавкиБезНДС.Добавить(Справочники.СтавкиНДС.ПустаяСсылка());
	
	ОтборЭлемента.ПравоеЗначение = СтавкиБезНДС;
	
	Элемент.Оформление.УстановитьЗначениеПараметра("ТолькоПросмотр", Истина);
		
	// Сумма штрафа в таблице операций
	Элемент = УсловноеОформление.Элементы.Добавить();
	
	Поля              = Элемент.Поля.Элементы;
	ПолеЭлемента      = Поля.Добавить();
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(Элементы.ОперацииСуммаШтрафа.Имя);
	
	ОтборЭлемента                = Элемент.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ОтборЭлемента.ЛевоеЗначение  = Новый ПолеКомпоновкиДанных("Объект.ТипОперации");
	ОтборЭлемента.ВидСравнения   = ВидСравненияКомпоновкиДанных.Равно;
	ОтборЭлемента.ПравоеЗначение = Перечисления.ТипыОперацийСБилетами.Возврат;
	
	ОтборЭлемента                = Элемент.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ОтборЭлемента.ЛевоеЗначение  = Новый ПолеКомпоновкиДанных("Объект.Операции.СуммаШтрафа");
	ОтборЭлемента.ВидСравнения   = ВидСравненияКомпоновкиДанных.НеЗаполнено;
		
	Элемент.Оформление.УстановитьЗначениеПараметра("Текст", НСтр("ru = 'Нет штрафа'"));
	
КонецПроцедуры

&НаКлиенте
Процедура РедактироватьКорректировку(ИдСтроки)
	
	ЗначенияРеквизитов = Новый Структура(РеквизитыВводаШтрафа);
	СтрокаКорректировки = Объект.Операции.НайтиПоИдентификатору(ИдСтроки);
	Если СтрокаКорректировки = Неопределено Тогда
		Возврат;
	КонецЕсли;
	ЗаполнитьЗначенияСвойств(ЗначенияРеквизитов, СтрокаКорректировки);
	ЗначенияРеквизитов.Вставить("Организация", Объект.Организация);
	ЗначенияРеквизитов.ТипОперации = Объект.ТипОперации;
	ЗначенияРеквизитов.Дата = Объект.Дата;
	
	ДопПараметры = Новый Структура("ИдСтроки", ИдСтроки);
	
	ПараметрыФормыВвода = Новый Структура;
	ПараметрыФормыВвода.Вставить("ЗначенияРеквизитов", ЗначенияРеквизитов);
	ПараметрыФормыВвода.Вставить("РеквизитыКорректировок", РеквизитыВводаШтрафа);
	
	ОткрытьФорму("Документ.ОперацияСЭлектроннымБилетом.Форма.ВводКорректировки",
		ПараметрыФормыВвода,
		,,,,
		Новый ОписаниеОповещения("ПослеВводаКорректировки", ЭтотОбъект, ДопПараметры),
		РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	
КонецПроцедуры
	
&НаКлиенте
Процедура ПослеВводаКорректировки(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено
		ИЛИ Результат = КодВозвратаДиалога.Отмена Тогда
		Возврат;
	КонецЕсли;
	
	СтрокаКорректировки = Объект.Операции.НайтиПоИдентификатору(ДополнительныеПараметры.ИдСтроки);
	Если СтрокаКорректировки <> Неопределено Тогда
		ЗаполнитьЗначенияСвойств(СтрокаКорректировки, Результат,, "Дата,ТипОперации");
	КонецЕсли;
	Модифицированность = Истина;
	
КонецПроцедуры

&НаКлиенте
Процедура РассчитатьНДС()
	
	ТекущаяСтрока = Элементы.Операции.ТекущиеДанные;
	
	Если Не ЗначениеЗаполнено(ТекущаяСтрока.СтавкаНДС) Тогда
		ТекущаяСтрока.СтавкаНДС = ПредопределенноеЗначение("Справочник.СтавкиНДС.БезНДС");
	КонецЕсли;
	
	ДанныеСтроки = Новый Структура;
	ДанныеСтроки.Вставить("СтавкаНДС", ТекущаяСтрока.СтавкаНДС);
	ДанныеСтроки.Вставить("СуммаНДС", ТекущаяСтрока.СуммаНДС);
	ДанныеСтроки.Вставить("Сумма", ТекущаяСтрока.Сумма);
	
	ПараметрыПересчетаНДС = Новый Структура("ЦенаВключаетНДС", Истина);
	СтруктураДействий = Новый Структура("ПересчитатьСуммуНДС", ПараметрыПересчетаНДС);
	ПакетнаяОбработкаТабличнойЧастиКлиент.ОбработатьСтрокуТЧ(ДанныеСтроки, СтруктураДействий, КэшированныеЗначения);
	
	ТекущаяСтрока.СуммаНДС = ДанныеСтроки.СуммаНДС;
	
КонецПроцедуры

