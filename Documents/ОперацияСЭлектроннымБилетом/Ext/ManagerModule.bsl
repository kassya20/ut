		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ДокументыКИзменению.Ссылка КАК Ссылка,
		|	ДокументыКИзменению.ВерсияДанных КАК ВерсияДанных,
		|	ДокументыКИзменению.ФИОПассажира КАК ФИОПассажира,
		|	ДокументыКИзменению.ТребуетсяПересчетИтогов КАК ТребуетсяПересчетИтогов,
		|	ДокументыКИзменению.ТребуетсяСозданиеНовогоБронирования КАК ТребуетсяСозданиеНовогоБронирования
		|ИЗ
		|	ВТДокументыКИзменению КАК ДокументыКИзменению";
	
	Запрос.УстановитьПараметр("ДанныеДляОбновления", ОбновляемыеДанные);
	
	ТипыОперацийДляПересчета = Новый Массив;
	ТипыОперацийДляПересчета.Добавить(Перечисления.ТипыОперацийСБилетами.Покупка);
	ТипыОперацийДляПересчета.Добавить(Перечисления.ТипыОперацийСБилетами.Доплата);
	Запрос.УстановитьПараметр("ТипыОперацийДляПересчета", ТипыОперацийДляПересчета);
	
	ПакетЗапросов = Запрос.ВыполнитьПакет();
	ПоследнийПакет = ПакетЗапросов.Количество() - 1;
	ВыборкаДокументов = ПакетЗапросов[ПоследнийПакет].Выбрать();
	ВыборкаДокументовСВложениями = ПакетЗапросов[ПоследнийПакет-1].Выбрать(ОбходРезультатаЗапроса.ПоГРуппировкам);
	ИмяСправочникаПрисоединенныхФайлов =
		Метаданные.Справочники.ОперацияСЭлектроннымБилетомПрисоединенныеФайлы.ПолноеИмя();
	
	Пока ВыборкаДокументов.Следующий() Цикл
		
		Рекомендация = "";
		УдалятьОбъект = Ложь;
		ВыборкаФайлов = Неопределено;
		
		НачатьТранзакцию();
		
		Попытка 
			
			ПричинаИсключения = "Блокировка";
			
			#Область Блокировки
			
			Блокировка = Новый БлокировкаДанных;
			
			ЭлементБлокировки = Блокировка.Добавить(ПолноеИмяОбъекта);
			ЭлементБлокировки.УстановитьЗначение("Ссылка", ВыборкаДокументов.Ссылка);
			ЭлементБлокировки.Режим = РежимБлокировкиДанных.Исключительный;
			
			Если ВыборкаДокументов.ТребуетсяСозданиеНовогоБронирования Тогда
			
				ЭлементБлокировки = Блокировка.Добавить("РегистрСведений.СуммыДокументовВВалютахУчета.НаборЗаписей");
				ЭлементБлокировки.УстановитьЗначение("Регистратор", ВыборкаДокументов.Ссылка);
				ЭлементБлокировки.Режим = РежимБлокировкиДанных.Исключительный;
				
				ЭлементБлокировки = Блокировка.Добавить("РегистрСведений.РеестрДокументов");
				ЭлементБлокировки.УстановитьЗначение("Ссылка", ВыборкаДокументов.Ссылка);
				ЭлементБлокировки.Режим = РежимБлокировкиДанных.Исключительный;
				
				ЭлементБлокировки = Блокировка.Добавить("РегистрСведений.КлючиДоступаКОбъектам");
				ЭлементБлокировки.УстановитьЗначение("Объект", ВыборкаДокументов.Ссылка);
				ЭлементБлокировки.Режим = РежимБлокировкиДанных.Исключительный;
				
				ЭлементБлокировки = Блокировка.Добавить("РегистрСведений.КлючиДоступаКРегиструРезультатыПроверкиУчета");
				ЭлементБлокировки.УстановитьЗначение("Поле1", ВыборкаДокументов.Ссылка);
				ЭлементБлокировки.Режим = РежимБлокировкиДанных.Исключительный;
				
				ЭлементБлокировки = Блокировка.Добавить("РегистрСведений.ДанныеПервичныхДокументов");
				ЭлементБлокировки.УстановитьЗначение("Документ", ВыборкаДокументов.Ссылка);
				ЭлементБлокировки.Режим = РежимБлокировкиДанных.Исключительный;
				
				ЭлементБлокировки = Блокировка.Добавить("РегистрСведений.ЗаданияНеоперативногоДопроведенияДокументов");
				ЭлементБлокировки.УстановитьЗначение("Документ", ВыборкаДокументов.Ссылка);
				ЭлементБлокировки.Режим = РежимБлокировкиДанных.Исключительный;
				
				ЭлементБлокировки = Блокировка.Добавить("РегистрСведений.ЗаданияКЗакрытиюМесяца");
				ЭлементБлокировки.УстановитьЗначение("Документ", ВыборкаДокументов.Ссылка);
				ЭлементБлокировки.Режим = РежимБлокировкиДанных.Исключительный;
				
				
				Пока ВыборкаДокументовСВложениями.НайтиСледующий(Новый Структура("Ссылка", ВыборкаДокументов.Ссылка)) Цикл
					ВыборкаФайлов = ВыборкаДокументовСВложениями.Выбрать();
					Пока ВыборкаФайлов.Следующий() Цикл
						ЭлементБлокировки = Блокировка.Добавить(ИмяСправочникаПрисоединенныхФайлов);
						ЭлементБлокировки.УстановитьЗначение("Ссылка", ВыборкаФайлов.ПрисоединенныйФайл);
						ЭлементБлокировки.Режим = РежимБлокировкиДанных.Исключительный;
					КонецЦикла;
					ВыборкаФайлов.Сбросить();
				КонецЦикла;
				
			КонецЕсли;
			
			Блокировка.Заблокировать();
			
			#КонецОбласти
			
			ДокументОбъект = ОбновлениеИнформационнойБазыУТ.ПроверитьПолучитьОбъект(
					ВыборкаДокументов.Ссылка, ВыборкаДокументов.ВерсияДанных, Параметры.Очередь);
					
			ПричинаИсключения = "ПлохиеДанные";
			Рекомендация = НСтр("ru = 'Перепроведите документ вручную.'");
			
			Если ДокументОбъект <> Неопределено Тогда
								
				Если Не ЗначениеЗаполнено(ДокументОбъект.ФИОПассажира)
						И ЗначениеЗаполнено(ВыборкаДокументов.ФИОПассажира) Тогда
					ДокументОбъект.ФИОПассажира = ВыборкаДокументов.ФИОПассажира;
				КонецЕсли;
				
				Если ВыборкаДокументов.ТребуетсяПересчетИтогов Тогда
					ТекущийИтог = 0;
					Для Каждого СтрокаТЧ Из ДокументОбъект.Операции Цикл
						Если СтрокаТЧ.ТипОперации = Перечисления.ТипыОперацийСБилетами.Покупка
							Или СтрокаТЧ.ТипОперации = Перечисления.ТипыОперацийСБилетами.Доплата Тогда
							ТекущийИтог = ТекущийИтог + СтрокаТЧ.Сумма;
							СтрокаТЧ.СуммаИтог = ТекущийИтог;
						КонецЕсли;
					КонецЦикла;
				КонецЕсли;
				
				Если ВыборкаДокументов.ТребуетсяСозданиеНовогоБронирования Тогда
					
					//++ Локализация
					
					НовыйДокументБронирования = Документы.БронированиеSmartway.СоздатьДокумент();
					ЗаполнитьЗначенияСвойств(НовыйДокументБронирования, ДокументОбъект);
					
					НовыйДокументБронирования.НомерБронирования = ДокументОбъект.НомерБилета;
					НовыйДокументБронирования.ДатаНачала = ДокументОбъект.ДатаОтправления;
					НовыйДокументБронирования.ДатаОкончания = ДокументОбъект.ДатаПрибытия;
					НовыйДокументБронирования.ДеталиБронирования = ДокументОбъект.ДеталиПоездки;
					
					НовыйДокументБронирования.Операции.Загрузить(ДокументОбъект.Операции.Выгрузить());
					НовыйДокументБронирования.Записать(РежимЗаписиДокумента.Запись);
					
					// Присоединенные файлы
					Если ВыборкаФайлов <> Неопределено Тогда
						
						Пока ВыборкаФайлов.Следующий() Цикл
							
							ДвоичныеДанные = РаботаСФайлами.ДвоичныеДанныеФайла(ВыборкаФайлов.ПрисоединенныйФайл);
							АдресВременногоХранилищаФайла = ПоместитьВоВременноеХранилище(ДвоичныеДанные);
							
							ПараметрыФайла = РаботаСФайлами.ПараметрыДобавленияФайла();
							ЗаполнитьЗначенияСвойств(ПараметрыФайла, ВыборкаФайлов);
							ПараметрыФайла.ВладелецФайлов = НовыйДокументБронирования.Ссылка;
							РаботаСФайлами.ДобавитьФайл(ПараметрыФайла, АдресВременногоХранилищаФайла, "");
							
						КонецЦикла;
						
						ВыборкаФайлов.Сбросить();
						
					КонецЕсли;
					
					// Суммы документов в валютах учета
					НаборЗаписей = РегистрыСведений.СуммыДокументовВВалютахУчета.СоздатьНаборЗаписей();
					НаборЗаписей.Отбор.Регистратор.Установить(ВыборкаДокументов.Ссылка);
					НаборЗаписей.Прочитать();
					
					КэшЗаписей = НаборЗаписей.Выгрузить();
					НаборЗаписей.Очистить();
					НаборЗаписей.ОбменДанными.Загрузка = Истина;
					НаборЗаписей.Записать();
					
					Для Каждого ЗаписьНабора Из КэшЗаписей Цикл
						ЗаписьНабора.Регистратор = НовыйДокументБронирования.Ссылка;
					КонецЦикла;
					
					НаборЗаписей.ДополнительныеСвойства.Очистить();
					НаборЗаписей.Отбор.Регистратор.Установить(НовыйДокументБронирования.Ссылка);
					НаборЗаписей.Загрузить(КэшЗаписей);
					НаборЗаписей.Записать();
					
					// Реестр документов
					НаборЗаписей = РегистрыСведений.РеестрДокументов.СоздатьНаборЗаписей();
					НаборЗаписей.Отбор.Ссылка.Установить(ВыборкаДокументов.Ссылка);
					НаборЗаписей.Прочитать();
					
					КэшЗаписей = НаборЗаписей.Выгрузить();
					НаборЗаписей.Очистить();
					НаборЗаписей.Записать();
					
					Для Каждого ЗаписьНабора Из КэшЗаписей Цикл
						ЗаписьНабора.ТипСсылки = ОбщегоНазначения.ИдентификаторОбъектаМетаданных(Тип("ДокументСсылка.БронированиеSmartway"));
						ЗаписьНабора.Ссылка = НовыйДокументБронирования.Ссылка;
						ЗаполнитьЗначенияСвойств(ЗаписьНабора, НовыйДокументБронирования, "Проведен,ПометкаУдаления");
					КонецЦикла;
					
					НаборЗаписей.Отбор.Ссылка.Установить(НовыйДокументБронирования.Ссылка);
					НаборЗаписей.Загрузить(КэшЗаписей);
					НаборЗаписей.Записать();
					//-- Локализация
					
					ДокументОбъект.ДополнительныеСвойства.Вставить("ПропускатьРегистрациюВНеоперативнуюОчередь");
					ДокументОбъект.ПометкаУдаления = Истина;
					ДокументОбъект.Записать(РежимЗаписиДокумента.ОтменаПроведения);
					
					//++ Локализация
					
					// Ключи доступа к объектам
					НаборЗаписей = РегистрыСведений.КлючиДоступаКОбъектам.СоздатьНаборЗаписей();
					НаборЗаписей.Отбор.Объект.Установить(ВыборкаДокументов.Ссылка);
					НаборЗаписей.ОбменДанными.Загрузка = Истина;
					НаборЗаписей.Записать();
					
					// Ключи доступа к результатам проверки учета
					НаборЗаписей = РегистрыСведений.КлючиДоступаКРегиструРезультатыПроверкиУчета.СоздатьНаборЗаписей();
					НаборЗаписей.Отбор.Поле1.Установить(ВыборкаДокументов.Ссылка);
					НаборЗаписей.ОбменДанными.Загрузка = Истина;
					НаборЗаписей.Записать();
					
					Для Каждого ИмяРегистраСведений Из МассивИменОчищаемыхРегистров Цикл
						МенеджерРегистра = ОбщегоНазначения.МенеджерОбъектаПоПолномуИмени(ИмяРегистраСведений);
						НаборЗаписей = МенеджерРегистра.СоздатьНаборЗаписей();
						НаборЗаписей.Отбор.Документ.Установить(ВыборкаДокументов.Ссылка);
						НаборЗаписей.ОбменДанными.Загрузка = Истина;
						НаборЗаписей.Записать();
					КонецЦикла;
				
					УдалятьОбъект = Истина
					
					//-- Локализация
					
				КонецЕсли;
				
			КонецЕсли;
			
			ПричинаИсключения = "Запись";
				
			Если ДокументОбъект.Модифицированность() Тогда
				ОбновлениеИнформационнойБазы.ЗаписатьДанные(ДокументОбъект);
			Иначе
				ОбновлениеИнформационнойБазы.ОтметитьВыполнениеОбработки(ВыборкаДокументов.Ссылка);
			КонецЕсли;
			
			Если УдалятьОбъект И
					ВыборкаФайлов <> Неопределено Тогда
					
				Пока ВыборкаФайлов.Следующий() Цикл
					ФайлОбъект = ВыборкаФайлов.ПрисоединенныйФайл.ПолучитьОбъект();
					ФайлОбъект.Удалить();
				КонецЦикла;
					
			КонецЕсли;
			
			Если УдалятьОбъект
				И Не НайтиПоСсылкам(
					ОбщегоНазначенияКлиенТСервер.ЗначениеВМассиве(ВыборкаДокументов.Ссылка)).Количество() Тогда
				ДокументОбъект.Удалить();
			КонецЕсли;
			
			ОбъектовОбработано = ОбъектовОбработано + 1;
			
			ЗафиксироватьТранзакцию();
			
		Исключение
			
			ОтменитьТранзакцию();
			
			ПроблемныхОбъектов = ПроблемныхОбъектов + 1;
			ОбновлениеИнформационнойБазыУТ.СообщитьОНеудачнойОбработке(ИнформацияОбОшибке(), ВыборкаДокументов.Ссылка);
			
			Если ПричинаИсключения = "ПлохиеДанные" Тогда
				
				ОписаниеПроблемы = ОбновлениеИнформационнойБазыУТ.ПроблемаСДанными(
					ВыборкаДокументов.Ссылка, Рекомендация, ИнформацияОбОшибке());
				ИсключенияПриОбновлении.Добавить(ОписаниеПроблемы);
				
			ИначеЕсли ПричинаИсключения = "Запись" Тогда
				
				ОбновлениеИнформационнойБазыУТ.ЗаписатьПлохиеДанные(
					ИсключенияПриОбновлении, ОбъектовОбработано, Параметры);
				ВызватьИсключение СтрСоединить(СписокОписаний, Символы.ПС);
				
			КонецЕсли;
			
		КонецПопытки;
		
	КонецЦикла;
	
	Параметры.ОбработкаЗавершена =
		ОбновлениеИнформационнойБазы.ОбработкаДанныхЗавершена(Параметры.Очередь, ПолноеИмяОбъекта);
	
	Если ОбъектовОбработано = 0 И ПроблемныхОбъектов <> 0 Тогда
		
		СписокОписаний.Добавить(НСтр("ru = 'Всего пропущено: %1'"));
		ТекстСообщения = СтрШаблон(СтрСоединить(СписокОписаний, Символы.ПС), ПроблемныхОбъектов);
		ВызватьИсключение ТекстСообщения;
		
	КонецЕсли;
	
	ОбновлениеИнформационнойБазыУТ.ЗаписатьПлохиеДанные(ИсключенияПриОбновлении, ОбъектовОбработано, Параметры);
	
КонецПроцедуры

#КонецОбласти

Процедура ЗаполнитьНастройкиОбщихПолейФормы(Настройки, ДляОперацииСБилетом = Ложь)
	
	Финансы = ФинансоваяОтчетностьСервер;
	
	#Область Реквизиты
	
	// Контрагент
	Элемент = Настройки.Добавить();
	Элемент.Поля.Добавить("Агент");
	Элемент.Поля.Добавить("КонтрагентАгент");
	Финансы.НовыйОтбор(Элемент.Условие, "ХозяйственнаяОперация", Перечисления.ХозяйственныеОперации.БронированиеЧерезАгента);
	Элемент.Свойства.Вставить("Видимость");
	
	Элемент = Настройки.Добавить();
	Элемент.Поля.Добавить("ПодотчетноеЛицо");
	Элемент.Поля.Добавить("ПодразделениеПодотчетногоЛица");
	Финансы.НовыйОтбор(Элемент.Условие, "ХозяйственнаяОперация", Перечисления.ХозяйственныеОперации.БронированиеЧерезПодотчетноеЛицо);
	Элемент.Свойства.Вставить("Видимость");
	
	Элемент = Настройки.Добавить();
	Элемент.Поля.Добавить("Договор");
	ГруппаИли = Финансы.НовыйОтбор(Элемент.Условие,,, Тип("ГруппаЭлементовОтбораКомпоновкиДанных"));
	ГруппаИли.ТипГруппы = ТипГруппыЭлементовОтбораКомпоновкиДанных.ГруппаИли;
	Финансы.НовыйОтбор(ГруппаИли, "ХозяйственнаяОперация", Перечисления.ХозяйственныеОперации.БронированиеЧерезАгента);
	Финансы.НовыйОтбор(ГруппаИли, "ХозяйственнаяОперация", Перечисления.ХозяйственныеОперации.БронированиеУПоставщика);
	Элемент.Свойства.Вставить("Видимость");
	
	// Реквизиты
	Элемент = Настройки.Добавить();
	Элемент.Поля.Добавить("Сотрудник");
	Финансы.НовыйОтбор(Элемент.Условие, "СпособСписанияНапрямую", Ложь);
	Элемент.Свойства.Вставить("Видимость");
	
	Элемент = Настройки.Добавить();
	Элемент.Поля.Добавить("СтатьяДвиженияДенежныхСредств");
	Финансы.НовыйОтбор(Элемент.Условие, "СпособСписанияНапрямую", Ложь);
	Элемент.Свойства.Вставить("Заголовок", НСтр("ru = 'Цель выдачи'"));
	
	Элемент = Настройки.Добавить();
	Элемент.Поля.Добавить("СтатьяДвиженияДенежныхСредств");
	Финансы.НовыйОтбор(Элемент.Условие, "СпособСписанияНапрямую", Истина);
	Элемент.Свойства.Вставить("Заголовок", НСтр("ru = 'Статья движения ДС'"));
	
	Если ДляОперацииСБилетом Тогда
	
		Элемент = Настройки.Добавить();
		Элемент.Поля.Добавить("ОперацииСуммаШтрафа");
		Финансы.НовыйОтбор(Элемент.Условие, "ТипОперации", Перечисления.ТипыОперацийСБилетами.Возврат);
		Элемент.Свойства.Вставить("Видимость");
		
	КонецЕсли;
	
	#КонецОбласти
	
КонецПроцедуры

#КонецОбласти

#КонецЕсли


