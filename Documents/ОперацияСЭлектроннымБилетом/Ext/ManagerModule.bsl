// Актуализирует состояние билета и операции билета.
//
// Параметры - СсылкаНаДокумент - ДокументСсылка.ОперацияСЭлектроннымБилетом - электронный билет или его операция.
//                                Если входящяя ссылка является электронным билетом, то выполняется актуализации его операций.
//                                Актуализируются только те операции, значения ключевых рекаизитов которых отличаются от значений реквизитов билета.
//                                Если входящая ссылка является операцией, то выполняется расчет соятояния электронного билета:
//                                ("Куплен", "С доплатой", "Возвращен").
//
Процедура АктуализироватьОперацииИСостояниеЭлектронногоБилета(СсылкаНаДокумент) Экспорт
	
	ШаблонТекста =
	"ВЫБРАТЬ
	|	ДанныеДокумента.Ссылка КАК ЭлектронныйБилет,
	|	&КлючевыеДанные КАК КлючевыеДанные
	|ИЗ
	|	Документ.ОперацияСЭлектроннымБилетом КАК ДанныеДокумента
	|ГДЕ
	|	ДанныеДокумента.Ссылка = &СсылкаНаДокумент
	|	И ДанныеДокумента.ЭлектронныйБилет = ЗНАЧЕНИЕ(Документ.ОперацияСЭлектроннымБилетом.ПустаяСсылка)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ДанныеДокумента.Ссылка КАК ОперацияБилета,
	|	&КлючевыеДанные КАК КлючевыеДанные
	|ИЗ
	|	Документ.ОперацияСЭлектроннымБилетом КАК ДанныеДокумента
	|ГДЕ
	|	ДанныеДокумента.ЭлектронныйБилет = &СсылкаНаДокумент
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ДанныеОперации.ЭлектронныйБилет КАК ЭлектронныйБилет,
	|	ДанныеЭлектронногоБилета.Состояние КАК СостояниеЭлектронногоБилета
	|ИЗ
	|	Документ.ОперацияСЭлектроннымБилетом КАК ДанныеОперации
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ОперацияСЭлектроннымБилетом КАК ДанныеЭлектронногоБилета
	|		ПО ДанныеОперации.ЭлектронныйБилет = ДанныеЭлектронногоБилета.Ссылка
	|ГДЕ
	|	ДанныеОперации.Ссылка = &СсылкаНаДокумент
	|	И НЕ ДанныеОперации.ЭлектронныйБилет = ЗНАЧЕНИЕ(Документ.ОперацияСЭлектроннымБилетом.ПустаяСсылка)";
	
	ИсключаемыеРеквизиты = ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве("Дата");
	КлючевыеРеквизиты = КлючевыеРеквизитыЭлектронногоБилета(, ИсключаемыеРеквизиты);
	КлючевыеРеквизитыУдаленнойОперации = КлючевыеРеквизитыЭлектронногоБилета(Ложь, ИсключаемыеРеквизиты);
	
	ПоляЗапроса = Новый Массив;
	Для Каждого КлючевойРеквизит Из КлючевыеРеквизиты Цикл
		ПоляЗапроса.Добавить(СтрШаблон("ДанныеДокумента.%1 КАК %1", КлючевойРеквизит));
	КонецЦикла;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
		СтрЗаменить(ШаблонТекста,
					"&КлючевыеДанные КАК КлючевыеДанные",
					СтрСоединить(ПоляЗапроса, "," + Символы.ПС + Символы.Таб));
		
	Запрос.УстановитьПараметр("СсылкаНаДокумент", СсылкаНаДокумент);
	МассивРезультатов = Запрос.ВыполнитьПакет();

	ДанныеВходящегоБилета = МассивРезультатов[0].Выбрать();
	
	Если ДанныеВходящегоБилета.Следующий() Тогда
		
		// Актуализация операций билета
		
		ДанныеОперацийВходящегоБилета = МассивРезультатов[1].Выбрать();
		ОбновляемыеОперации = Новый Массив;
		Пока ДанныеОперацийВходящегоБилета.Следующий() Цикл
			
			ПроверяемыеРеквизиты = КлючевыеРеквизиты;
			Если ДанныеОперацийВходящегоБилета.ПометкаУдаления Тогда
				ПроверяемыеРеквизиты = КлючевыеРеквизитыУдаленнойОперации;
			КонецЕсли;
			
			Для Каждого ИмяРеквизита Из ПроверяемыеРеквизиты Цикл
				Если ДанныеОперацийВходящегоБилета[ИмяРеквизита] <> ДанныеВходящегоБилета[ИмяРеквизита] Тогда
					ОбновляемыеОперации.Добавить(ДанныеОперацийВходящегоБилета.ОперацияБилета);
					Прервать;
				КонецЕсли;
			КонецЦикла;

		КонецЦикла;

		Если ОбновляемыеОперации.Количество() Тогда
		
			Для Каждого ОперацияБилета Из ОбновляемыеОперации Цикл
				
				НачатьТранзакцию();
			
				Попытка
					
					ОперацияОбъект = ОперацияБилета.ПолучитьОбъект();
					
					Если ОперацияОбъект.ПометкаУдаления Тогда
						ЗаполнитьЗначенияСвойств(ОперацияОбъект, ДанныеВходящегоБилета, СтрСоединить(КлючевыеРеквизитыУдаленнойОперации, ","));
						РежимЗаписи = РежимЗаписиДокумента.ОтменаПроведения;
					Иначе
						ЗаполнитьЗначенияСвойств(ОперацияОбъект, ДанныеВходящегоБилета, СтрСоединить(КлючевыеРеквизиты, ","));
						Если ДанныеВходящегоБилета.Проведен Тогда
							РежимЗаписи = РежимЗаписиДокумента.Проведение;
						ИначеЕсли ДанныеВходящегоБилета.ПометкаУдаления Тогда
							РежимЗаписи = РежимЗаписиДокумента.ОтменаПроведения;
						Иначе
							РежимЗаписи = РежимЗаписиДокумента.Запись;
						КонецЕсли;
					КонецЕсли;
					
					ОперацияОбъект.ДополнительныеСвойства.Вставить("ПропускатьРегистрациюВНеоперативнуюОчередь");
					
					ОперацияОбъект.Записать(РежимЗаписи);
					
					ДанныеСообщения = Новый Структура("ОбработанныйДокумент", ОперацияОбъект.Ссылка);
					УведомленияКлиента.ОтправитьУведомление("ОбновитьФормуОперацииСЭлектроннымБилетом", ДанныеСообщения);
					
					ЗафиксироватьТранзакцию();
					
				Исключение
					
					ОтменитьТранзакцию();
					
					ОписаниеОшибки = ИнформацияОбОшибке();
					ТекстОшибки = НСтр("ru = '%1
						|%2'");
					
					ВызватьИсключение СтрШаблон(ТекстОшибки,
							ОписаниеОшибки.Описание,
							НСтр("ru = 'Произошли ошибки при записи документа.'", ОбщегоНазначения.КодОсновногоЯзыка()));
						
				КонецПопытки;
				
			КонецЦикла;
			
		КонецЕсли;
		
	Иначе
		
		// Расчет нового состояния билета
		
		ДанныеВходящейОперации = МассивРезультатов[2].Выбрать();
		ДанныеВходящейОперации.Следующий();
		НовоеСостояниеБилета = НовоеСостояниеБилета(ДанныеВходящейОперации.ЭлектронныйБилет);
		
		Если ДанныеВходящейОперации.СостояниеЭлектронногоБилета <> НовоеСостояниеБилета Тогда
			
			НачатьТранзакцию();
		
			Попытка
			
				ЭлектронныйБилетОбъект = ДанныеВходящейОперации.ЭлектронныйБилет.ПолучитьОбъект();
				
				ЭлектронныйБилетОбъект.Состояние = НовоеСостояниеБилета;
				ЭлектронныйБилетОбъект.ДополнительныеСвойства.Вставить("ЗаписьБезДвижений");
				ЭлектронныйБилетОбъект.ДополнительныеСвойства.Вставить("ПропускатьРегистрациюВНеоперативнуюОчередь");
				ЭлектронныйБилетОбъект.ОбменДанными.Загрузка = Истина;
				
				ЭлектронныйБилетОбъект.Записать(РежимЗаписиДокумента.Запись);
				
				ДанныеСообщения = Новый Структура("ОбработанныйДокумент", ЭлектронныйБилетОбъект.Ссылка);
				УведомленияКлиента.ОтправитьУведомление("ОбновитьФормуЭлектронногоБилета", ДанныеСообщения);
				
				ЗафиксироватьТранзакцию();
				
			Исключение
				
				ОтменитьТранзакцию();
				
				ОписаниеОшибки = ИнформацияОбОшибке();
				ТекстОшибки = НСтр("ru = '%1
					|%2'");
				
				ВызватьИсключение СтрШаблон(ТекстОшибки,
						ОписаниеОшибки.Описание,
						НСтр("ru = 'Произошли ошибки при записи документа.'", ОбщегоНазначения.КодОсновногоЯзыка()));
						
			КонецПопытки;
			
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбновлениеИнформационнойБазы

// см. ОбновлениеИнформационнойБазыБСП.ПриДобавленииОбработчиковОбновления
Процедура ПриДобавленииОбработчиковОбновления(Обработчики) Экспорт

	Обработчик = Обработчики.Добавить();
	Обработчик.Процедура = "Документы.ОперацияСЭлектроннымБилетом.ОбработатьДанныеДляПереходаНаНовуюВерсию";
	Обработчик.Версия = "11.5.26.62";
	Обработчик.РежимВыполнения = "Отложенно";
	Обработчик.Идентификатор = Новый УникальныйИдентификатор("889b810a-2a3b-4906-a027-aea0d23ec512"); // Идентификатор сгенерирован, а не скопирован
	Обработчик.Многопоточный = Истина;
	Обработчик.ПроцедураЗаполненияДанныхОбновления = "Документы.ОперацияСЭлектроннымБилетом.ЗарегистрироватьДанныеКОбработкеДляПереходаНаНовуюВерсию";
	Обработчик.ПроцедураПроверки = "ОбновлениеИнформационнойБазы.ДанныеОбновленыНаНовуюВерсиюПрограммы";
	
	СписокОписаний = Новый Массив;
	СписокОписаний.Добавить(НСтр("ru = 'Обновление документов ""Операция с электронным билетом"":'"));
	СписокОписаний.Добавить(НСтр("ru = '- заполнение реквизита ""ФИО пассажира"" из наименования физического лица, указанного в реквизите ""Сотрудник""';"));
	СписокОписаний.Добавить(НСтр("ru = '- пересчет итоговой суммы в табличной части ""Операции""';"));
	СписокОписаний.Добавить(НСтр("ru = '- перенос документа ""Бронирование""';"));

	Обработчик.Комментарий = СтрСоединить(СписокОписаний, Символы.ПС);
	Обработчик.Порядок = Перечисления.ПорядокОбработчиковОбновления.Обычный;
	
	Читаемые = Новый Массив;
	Читаемые.Добавить(Метаданные.Документы.ОперацияСЭлектроннымБилетом.ПолноеИмя());
	Обработчик.ЧитаемыеОбъекты = СтрСоединить(Читаемые, ",");
	
	Изменяемые = Новый Массив;
	Изменяемые.Добавить(Метаданные.Справочники.ОперацияСЭлектроннымБилетомПрисоединенныеФайлы.ПолноеИмя());
	Изменяемые.Добавить(Метаданные.Документы.ОперацияСЭлектроннымБилетом.ПолноеИмя());
	Изменяемые.Добавить(Метаданные.РегистрыСведений.ДанныеПервичныхДокументов.ПолноеИмя());
	Изменяемые.Добавить(Метаданные.РегистрыСведений.ЗаданияНеоперативногоДопроведенияДокументов.ПолноеИмя());
	Изменяемые.Добавить(Метаданные.РегистрыСведений.ЗаданияКЗакрытиюМесяца.ПолноеИмя());
	
	
	Изменяемые.Добавить(Метаданные.РегистрыСведений.СуммыДокументовВВалютахУчета.ПолноеИмя());
	Изменяемые.Добавить(Метаданные.РегистрыСведений.РеестрДокументов.ПолноеИмя());
	Изменяемые.Добавить(Метаданные.РегистрыСведений.КлючиДоступаКОбъектам.ПолноеИмя());
	Изменяемые.Добавить(Метаданные.РегистрыСведений.КлючиДоступаКРегиструРезультатыПроверкиУчета.ПолноеИмя());
	Обработчик.ИзменяемыеОбъекты = СтрСоединить(Изменяемые, ",");
	
КонецПроцедуры

// Параметры:
// 	Параметры - см. ОбновлениеИнформационнойБазы.ОсновныеПараметрыОтметкиКОбработке
//
Процедура ЗарегистрироватьДанныеКОбработкеДляПереходаНаНовуюВерсию(Параметры) Экспорт
	
	ПараметрыВыборки = Параметры.ПараметрыВыборки;
	ПараметрыВыборки.ПолныеИменаОбъектов = ПустаяСсылка().Метаданные().ПолноеИмя();
	ПараметрыВыборки.СпособВыборки = ОбновлениеИнформационнойБазы.СпособВыборкиСсылки();
	ПараметрыВыборки.ПоляУпорядочиванияПриРаботеПользователей.Добавить("Дата УБЫВ");
	ПараметрыВыборки.ПоляУпорядочиванияПриОбработкеДанных.Добавить("Дата УБЫВ");
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ОперацияСЭлектроннымБилетом.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.ОперацияСЭлектроннымБилетом КАК ОперацияСЭлектроннымБилетом
	|ГДЕ
	|	ОперацияСЭлектроннымБилетом.ФИОПассажира = """"
	|	И НЕ ОперацияСЭлектроннымБилетом.Сотрудник = ЗНАЧЕНИЕ(Справочник.ФизическиеЛица.ПустаяСсылка)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ОперацияСЭлектроннымБилетом.Ссылка
	|ИЗ
	|	Документ.ОперацияСЭлектроннымБилетом.Операции КАК ОперацияСЭлектроннымБилетом
	|ГДЕ
	|	ОперацияСЭлектроннымБилетом.ТипОперации В (ЗНАЧЕНИЕ(Перечисление.ТипыОперацийСБилетами.Покупка), ЗНАЧЕНИЕ(Перечисление.ТипыОперацийСБилетами.Доплата))
	|	И НЕ ОперацияСЭлектроннымБилетом.Сумма = 0
	|	И ОперацияСЭлектроннымБилетом.СуммаИтог = 0
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ОперацияСЭлектроннымБилетом.Ссылка
	|ИЗ
	|	Документ.ОперацияСЭлектроннымБилетом КАК ОперацияСЭлектроннымБилетом
	|ГДЕ
	|	ОперацияСЭлектроннымБилетом.УдалитьТипБронирования = ЗНАЧЕНИЕ(Перечисление.УдалитьТипыБронирования.Бронирование)
	|	И НЕ ОперацияСЭлектроннымБилетом.ПометкаУдаления";
	
	ОбновлениеИнформационнойБазы.ОтметитьКОбработке(Параметры, Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Ссылка"));
	
КонецПроцедуры

// Обработчик обновления
// 
// Параметры:
// 	Параметры - См. ОбновлениеИнформационнойБазы.ДополнительныеПараметрыВыборкиДанныхДляМногопоточнойОбработки 
//
Процедура ОбработатьДанныеДляПереходаНаНовуюВерсию(Параметры) Экспорт
	
	Параметры.ОбработкаЗавершена = Ложь;
	
	ПолноеИмяОбъекта = ПустаяСсылка().Метаданные().ПолноеИмя();
	
	ОбновляемыеДанные = ОбновлениеИнформационнойБазы.ДанныеДляОбновленияВМногопоточномОбработчике(Параметры);
	
	Если ОбновляемыеДанные.Количество() = 0 Тогда
		
		Параметры.ОбработкаЗавершена =
			ОбновлениеИнформационнойБазы.ОбработкаДанныхЗавершена(Параметры.Очередь, ПолноеИмяОбъекта);
		Возврат;
		
	КонецЕсли;
	
	МассивИменОчищаемыхРегистров = Новый Массив;
	МассивИменОчищаемыхРегистров.Добавить(Метаданные.РегистрыСведений.ДанныеПервичныхДокументов.ПолноеИмя());
	МассивИменОчищаемыхРегистров.Добавить(Метаданные.РегистрыСведений.ЗаданияНеоперативногоДопроведенияДокументов.ПолноеИмя());
	МассивИменОчищаемыхРегистров.Добавить(Метаданные.РегистрыСведений.ЗаданияКЗакрытиюМесяца.ПолноеИмя());
	
	
	ОбъектовОбработано = 0;
	ПроблемныхОбъектов = 0;
	ИсключенияПриОбновлении = Новый Массив;
	
	СписокОписаний = Новый Массив;
	СписокОписаний.Добавить(НСтр("ru = 'Не удалось обработать документы ""Операция с электронным билетом"" по обработчику:'"));	
	СписокОписаний.Добавить(НСтр("ru = '- заполнение реквизита ""ФИО пассажира"" из наименования физического лица, указанного в реквизите ""Сотрудник""';"));
	СписокОписаний.Добавить(НСтр("ru = '- пересчет итоговой суммы в табличной части ""Операции""';"));
	СписокОписаний.Добавить(НСтр("ru = '- перенос документов ""Бронирование""';"));
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ДанныеДляОбновления.Ссылка КАК Ссылка
		|ПОМЕСТИТЬ ТаблицаДокументов
		|ИЗ
		|	&ДанныеДляОбновления КАК ДанныеДляОбновления
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ТаблицаДокументов.Ссылка КАК Ссылка,
		|	ДанныеДокумента.ВерсияДанных КАК ВерсияДанных,
		|	ЕСТЬNULL(ФизическиеЛица.Наименование, НЕОПРЕДЕЛЕНО) КАК ФИОПассажира,
		|	МАКСИМУМ(ВЫБОР
		|			КОГДА ОперацииДокумента.ТипОперации В (&ТипыОперацийДляПересчета)
		|					И НЕ ОперацииДокумента.Сумма = 0
		|					И ОперацииДокумента.СуммаИтог = 0
		|				ТОГДА ИСТИНА
		|			ИНАЧЕ ЛОЖЬ
		|		КОНЕЦ) КАК ТребуетсяПересчетИтогов,
		|	ДанныеДокумента.УдалитьТипБронирования =
		|		ЗНАЧЕНИЕ(Перечисление.УдалитьТипыБронирования.Бронирование) КАК ТребуетсяСозданиеНовогоБронирования
		|ПОМЕСТИТЬ ВТДокументыКИзменению
		|ИЗ
		|	ТаблицаДокументов КАК ТаблицаДокументов
		|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ОперацияСЭлектроннымБилетом КАК ДанныеДокумента
		|		ПО ТаблицаДокументов.Ссылка = ДанныеДокумента.Ссылка
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ФизическиеЛица КАК ФизическиеЛица
		|		ПО (ДанныеДокумента.Сотрудник = ФизическиеЛица.Ссылка)
		|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ОперацияСЭлектроннымБилетом.Операции КАК ОперацииДокумента
		|		ПО ТаблицаДокументов.Ссылка = ОперацииДокумента.Ссылка
		|
		|СГРУППИРОВАТЬ ПО
		|	ТаблицаДокументов.Ссылка,
		|	ДанныеДокумента.ВерсияДанных,
		|	ЕСТЬNULL(ФизическиеЛица.Наименование, НЕОПРЕДЕЛЕНО),
		|	ДанныеДокумента.УдалитьТипБронирования
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ДокументыКИзменению.Ссылка КАК Ссылка,
		|	ФайлыБронирований.Ссылка КАК ПрисоединенныйФайл,
		|	ФайлыБронирований.Наименование КАК ИмяБезРасширения,
		|	ФайлыБронирований.Автор КАК Автор,
		|	ФайлыБронирований.ДатаЗаема КАК ДатаЗаема,
		|	ФайлыБронирований.ДатаМодификацииУниверсальная КАК ВремяИзмененияУниверсальное,
		|	ФайлыБронирований.ДатаСоздания КАК ДатаСоздания,
		|	ФайлыБронирований.Зашифрован КАК Зашифрован,
		|	ФайлыБронирований.Изменил КАК Изменил,
		|	ФайлыБронирований.ИндексКартинки КАК ИндексКартинки,
		|	ФайлыБронирований.Описание КАК Описание,
		|	ФайлыБронирований.ПодписанЭП КАК ПодписанЭП,
		|	ФайлыБронирований.ПутьКФайлу КАК ПутьКФайлу,
		|	ФайлыБронирований.Размер КАК Размер,
		|	ФайлыБронирований.Расширение КАК РасширениеБезТочки,
		|	ФайлыБронирований.Редактирует КАК Редактирует,
		|	ФайлыБронирований.СтатусИзвлеченияТекста КАК СтатусИзвлеченияТекста,
		|	ФайлыБронирований.ТекстХранилище КАК ТекстХранилище,
		|	ФайлыБронирований.ТипХраненияФайла КАК ТипХраненияФайла,
		|	ФайлыБронирований.Том КАК Том,
		|	ФайлыБронирований.ФайлХранилище КАК ФайлХранилище,
		|	ФайлыБронирований.ХранитьВерсии КАК ХранитьВерсии
		|ИЗ
		|	ВТДокументыКИзменению КАК ДокументыКИзменению
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ОперацияСЭлектроннымБилетомПрисоединенныеФайлы КАК ФайлыБронирований
		|		ПО ДокументыКИзменению.Ссылка = ФайлыБронирований.ВладелецФайла
		|ГДЕ
		|	ДокументыКИзменению.ТребуетсяСозданиеНовогоБронирования
		|ИТОГИ
