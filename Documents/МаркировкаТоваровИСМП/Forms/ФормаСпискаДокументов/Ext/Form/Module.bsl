&НаСервере
Функция СформироватьГиперссылкуСмТакже()
	
	МассивСтрок = Новый Массив;
	МассивСтрок.Добавить(
		Новый ФорматированнаяСтрока(НСтр("ru = 'Групповая генерация и печать штрихкодов упаковок'"),,,,
			"ОбщаяФорма.ГенерацияИПечатьШтрихкодовЛогистическихУпаковок"));

	Возврат Новый ФорматированнаяСтрока(МассивСтрок);
	
КонецФункции

&НаКлиенте
Процедура СоздатьДокумент(ИмяКоманды, ВидПродукции = Неопределено)
	
	ИмяОперации = СтрЗаменить(ИмяКоманды, "Создать", "");
	Операция = ПредопределенноеЗначение(СтрШаблон("Перечисление.ВидыОперацийИСМП.%1", ИмяОперации));
	ЗначенияЗаполнения = Новый Структура;
	ЗначенияЗаполнения.Вставить("Операция", Операция);
	Если ВидПродукции <> Неопределено Тогда
		ЗначенияЗаполнения.Вставить(
			"ТоварнаяГруппа", КонструкторИСМПОбщегоНазначенияКлиентСервер.ТоварнаяГруппаПоВидуПродукции(ВидПродукции));
	КонецЕсли;
	
	СтруктураПараметров = Новый Структура;
	СтруктураПараметров.Вставить("ЗначенияЗаполнения",          ЗначенияЗаполнения);
	СтруктураПараметров.Вставить("РежимОткрытияПоВидуОперации", РежимОткрытияПоВидуОперации);
	ОткрытьФорму("Документ.МаркировкаТоваровИСМП.ФормаОбъекта", СтруктураПараметров);
	
КонецПроцедуры

&НаСервере
Процедура СоздатьЭлементыФормы()
	
	Если Не ПравоДоступа("Добавление", Метаданные.Документы.МаркировкаТоваровИСМП) Тогда
		Элементы.СтраницаКОформлению.Видимость = Ложь;
		Возврат;
	КонецЕсли;
	
	Если РежимОткрытияПоВидуОперации = ИнтеграцияИСМПКлиентСервер.РежимОткрытияАгрегация() Тогда
		
		СобытияФормИСМП.ДобавитьЭлементФормыКнопка(ЭтотОбъект, "Агрегация", Элементы.ГруппаСоздать, Нстр("ru = 'Создать'"), Истина);
		
	ИначеЕсли РежимОткрытияПоВидуОперации = ИнтеграцияИСМПКлиентСервер.РежимОткрытияПоступлениеКИЗ() Тогда
		
		СобытияФормИСМП.ДобавитьЭлементФормыКнопка(ЭтотОбъект, "ПодтверждениеПоступленияКИЗ", Элементы.ГруппаСоздать, Нстр("ru = 'Создать'"), Истина);
		
	Иначе // ВводВОборот, все кроме агрегации и приемки КИЗ
		
		УчитываемыеВидыМаркируемойПродукции = ОбщегоНазначенияИСМПКлиентСерверПовтИсп.УчитываемыеВидыМаркируемойПродукции();
		
		ВключенУчетМеха = ШтрихкодированиеОбщегоНазначенияИС.ПрисутствуетПродукцияИзНатуральногоМеха(УчитываемыеВидыМаркируемойПродукции);
		ТолькоМех = ВключенУчетМеха И УчитываемыеВидыМаркируемойПродукции.Количество() = 1;
		
		ОтчетОНанесенииДоступен = МаркировкаТоваровКлиентСервер.ДоступенОтчетОНанесении();
		
		Если МаркировкаТоваровКлиентСервер.ДоступнаОперацияВводВОборотПроизводствоРФПоДоговоруНаСторонеЗаказчика() Тогда
			ИспользуетсяПереработкаНаСтороне = Истина;
			ИнтеграцияИСМППереопределяемый.ИспользуетсяПереработкаНаСтороне(ИспользуетсяПереработкаНаСтороне);
		Иначе
			ИспользуетсяПереработкаНаСтороне = Ложь;
		КонецЕсли;
		
		ВключенУчетСырья = КонструкторИСМПКлиентСервер.ВидыПродукцииСырьеГИСМТ().Количество() > 0;
		ТолькоСырье      = ВключенУчетСырья И ОбщегоНазначенияИСМПКлиентСерверПовтИсп.УчитываетсяТолькоСырье();
		
		ДобавляемыеКоманды = Новый Массив;
		ДобавляемыеПодменю = Новый Массив;
		
		Если ТолькоМех Тогда
			
			Если МаркировкаТоваровКлиентСервер.ДоступнаОперацияВводВОборотПроизводствоРФ() Тогда
				СобытияФормИСМП.ДобавитьЭлементДляСоздания(ДобавляемыеКоманды, "ВводВОборотПроизводствоРФ");
			КонецЕсли;
			Если МаркировкаТоваровКлиентСервер.ДоступнаОперацияИмпортСФТСМех() Тогда
				СобытияФормИСМП.ДобавитьЭлементДляСоздания(ДобавляемыеКоманды, "ВводВОборотИмпортСФТСМех");
			КонецЕсли;
			Если МаркировкаТоваровКлиентСервер.ДоступнаОперацияВводВОборотПроизводствоРФПоДоговору() Тогда
				СобытияФормИСМП.ДобавитьЭлементДляСоздания(ДобавляемыеКоманды, "ВводВОборотПроизводствоРФПоДоговору");
			КонецЕсли;
			Если ИспользуетсяПереработкаНаСтороне Тогда
				СобытияФормИСМП.ДобавитьЭлементДляСоздания(ДобавляемыеКоманды, "ВводВОборотПроизводствоРФПоДоговоруНаСторонеЗаказчика");
			КонецЕсли;
			Если МаркировкаТоваровКлиентСервер.ДоступноПолучениеПродукцииОтФизическихЛиц() Тогда
				СобытияФормИСМП.ДобавитьЭлементДляСоздания(ДобавляемыеКоманды, "ВводВОборотПолучениеПродукцииОтФизическихЛиц");
			КонецЕсли;
			СобытияФормИСМП.ДобавитьЭлементДляСоздания(ДобавляемыеКоманды, "ИндивидуализацияКИЗ");
			
		ИначеЕсли ТолькоСырье Тогда
			Если МаркировкаТоваровКлиентСервер.ДоступнаОперацияВводВОборотСырьяПроизводствоРФ() Тогда
				СобытияФормИСМП.ДобавитьЭлементДляСоздания(ДобавляемыеКоманды, "ВводВОборотСырьяПроизводствоРФ",, Нстр("ru = 'Производство в РФ'"));
			КонецЕсли;
			Если МаркировкаТоваровКлиентСервер.ДоступнаОперацияВводВОборотСырьяПолучениеТовараИзЕАЭС() Тогда
				СобытияФормИСМП.ДобавитьЭлементДляСоздания(ДобавляемыеКоманды, "ВводВОборотСырьяПолучениеТовараИзЕАЭС",, Нстр("ru = 'Получение товара из стран ЕАЭС'"));
			КонецЕсли;
			Если МаркировкаТоваровКлиентСервер.ДоступнаОперацияВводВОборотСырьяПолучениеТовараВнеЕАЭС() Тогда
				СобытияФормИСМП.ДобавитьЭлементДляСоздания(ДобавляемыеКоманды, "ВводВОборотСырьяПолучениеТовараВнеЕАЭС",, Нстр("ru = 'Получение товара из стран вне ЕАЭС'"));
			КонецЕсли;
			Если МаркировкаТоваровКлиентСервер.ДоступнаОперацияВводВОборотСырьяОстатки() Тогда
				СобытияФормИСМП.ДобавитьЭлементДляСоздания(ДобавляемыеКоманды, "ВводВОборотСырьяОстатки",, Нстр("ru = 'Остатки'"));
			КонецЕсли;
		Иначе
			
			ЕстьОперацииПроизводство = Ложь;
			ЕстьОперацииИмпорт       = Ложь;
			
			Если МаркировкаТоваровКлиентСервер.ДоступнаОперацияВводВОборотПроизводствоРФ() Тогда
				СобытияФормИСМП.ДобавитьЭлементДляСоздания(ДобавляемыеКоманды, "ВводВОборотПроизводствоРФ", "Производство");
				ЕстьОперацииПроизводство = Истина;
			КонецЕсли;
			Если МаркировкаТоваровКлиентСервер.ДоступнаОперацияВводВОборотПроизводствоРФПоДоговору() Тогда
				СобытияФормИСМП.ДобавитьЭлементДляСоздания(ДобавляемыеКоманды, "ВводВОборотПроизводствоРФПоДоговору", "Производство");
				ЕстьОперацииПроизводство = Истина;
			КонецЕсли;
			Если ИспользуетсяПереработкаНаСтороне Тогда
				СобытияФормИСМП.ДобавитьЭлементДляСоздания(ДобавляемыеКоманды, "ВводВОборотПроизводствоРФПоДоговоруНаСторонеЗаказчика", "Производство");
				ЕстьОперацииПроизводство = Истина;
			КонецЕсли;
			Если МаркировкаТоваровКлиентСервер.ДоступенИмпортСФТС() Тогда
				СобытияФормИСМП.ДобавитьЭлементДляСоздания(ДобавляемыеКоманды, "ВводВОборотИмпортСФТС", "Импорт");
				ЕстьОперацииИмпорт = Истина;
			КонецЕсли;
			Если МаркировкаТоваровКлиентСервер.ДоступноПроизводствоВнеЕАЭС() Тогда
				СобытияФормИСМП.ДобавитьЭлементДляСоздания(ДобавляемыеКоманды, "ВводВОборотПроизводствоВнеЕАЭС", "Импорт");
				ЕстьОперацииИмпорт = Истина;
			КонецЕсли;
			Если МаркировкаТоваровКлиентСервер.ДоступнаОперацияВводВОборотТрансграничнаяТорговля() Тогда
				СобытияФормИСМП.ДобавитьЭлементДляСоздания(ДобавляемыеКоманды, "ВводВОборотТрансграничнаяТорговля", "Импорт");
				ЕстьОперацииИмпорт = Истина;
			КонецЕсли;
			Если МаркировкаТоваровКлиентСервер.ДоступнаМаркировкаОстатков() Тогда
				СобытияФормИСМП.ДобавитьЭлементДляСоздания(ДобавляемыеКоманды, "ВводВОборотМаркировкаОстатков");
			КонецЕсли;
			Если МаркировкаТоваровКлиентСервер.ДоступноПолучениеПродукцииОтФизическихЛиц() Тогда
				СобытияФормИСМП.ДобавитьЭлементДляСоздания(ДобавляемыеКоманды, "ВводВОборотПолучениеПродукцииОтФизическихЛиц");
			КонецЕсли;
			
			Если ВключенУчетМеха Тогда
				СобытияФормИСМП.ДобавитьЭлементДляСоздания(ДобавляемыеКоманды, "ВводВОборотИмпортСФТСМех", "Импорт");
				ЕстьОперацииИмпорт = Истина;
			КонецЕсли;
			
			Если ЕстьОперацииПроизводство Тогда
				СобытияФормИСМП.ДобавитьЭлементДляСоздания(ДобавляемыеПодменю, "Производство",, Нстр("ru = 'Производство'"));
			КонецЕсли;
			Если ЕстьОперацииИмпорт Тогда
				СобытияФормИСМП.ДобавитьЭлементДляСоздания(ДобавляемыеПодменю, "Импорт",, Нстр("ru = 'Импорт'"));
			КонецЕсли;
			
			Если ВключенУчетМеха И ОтчетОНанесенииДоступен Тогда
				СобытияФормИСМП.ДобавитьЭлементДляСоздания(ДобавляемыеПодменю, "Нанесение",,  Нстр("ru = 'Нанесение'"));
				СобытияФормИСМП.ДобавитьЭлементДляСоздания(ДобавляемыеКоманды, "ОтчетОВерификацииНанесенныхКМ", "Нанесение");
				СобытияФормИСМП.ДобавитьЭлементДляСоздания(ДобавляемыеКоманды, "ИндивидуализацияКИЗ",           "Нанесение");
			ИначеЕсли ВключенУчетМеха Тогда
				СобытияФормИСМП.ДобавитьЭлементДляСоздания(ДобавляемыеКоманды, "ИндивидуализацияКИЗ");
			ИначеЕсли ОтчетОНанесенииДоступен Тогда
				СобытияФормИСМП.ДобавитьЭлементДляСоздания(ДобавляемыеКоманды, "ОтчетОВерификацииНанесенныхКМ");
			КонецЕсли;
			
			Если ВключенУчетСырья Тогда
				ЕстьОперацииСырье = Ложь;
				Если МаркировкаТоваровКлиентСервер.ДоступнаОперацияВводВОборотСырьяПроизводствоРФ() Тогда
					СобытияФормИСМП.ДобавитьЭлементДляСоздания(
						ДобавляемыеКоманды, "ВводВОборотСырьяПроизводствоРФ", "Сырье", Нстр("ru = 'Производство в РФ'"));
					ЕстьОперацииСырье = Истина;
				КонецЕсли;
				Если МаркировкаТоваровКлиентСервер.ДоступнаОперацияВводВОборотСырьяПолучениеТовараИзЕАЭС() Тогда
					СобытияФормИСМП.ДобавитьЭлементДляСоздания(
						ДобавляемыеКоманды, "ВводВОборотСырьяПолучениеТовараИзЕАЭС", "Сырье", Нстр("ru = 'Получение товара из стран ЕАЭС'"));
					ЕстьОперацииСырье = Истина;
				КонецЕсли;
				Если МаркировкаТоваровКлиентСервер.ДоступнаОперацияВводВОборотСырьяПолучениеТовараВнеЕАЭС() Тогда
					СобытияФормИСМП.ДобавитьЭлементДляСоздания(
						ДобавляемыеКоманды, "ВводВОборотСырьяПолучениеТовараВнеЕАЭС", "Сырье", Нстр("ru = 'Получение товара из стран вне ЕАЭС'"));
					ЕстьОперацииСырье = Истина;
				КонецЕсли;
				Если МаркировкаТоваровКлиентСервер.ДоступнаОперацияВводВОборотСырьяОстатки() Тогда
					СобытияФормИСМП.ДобавитьЭлементДляСоздания(
						ДобавляемыеКоманды, "ВводВОборотСырьяОстатки", "Сырье", Нстр("ru = 'Остатки'"));
					ЕстьОперацииСырье = Истина;
				КонецЕсли;
				Если ЕстьОперацииСырье Тогда
					СобытияФормИСМП.ДобавитьЭлементДляСоздания(ДобавляемыеПодменю, "Сырье",, Нстр("ru = 'Сырье'"));
				КонецЕсли;
			КонецЕсли;
			
		КонецЕсли;
		
		ЭлементРодитель = СобытияФормИСМП.ДобавитьЭлементФормыПодменю(ЭтотОбъект, "Создать", Элементы.ГруппаСоздать, Нстр("ru = 'Создать'"), Истина);
		
		Для Каждого ЭлементКоллекции Из ДобавляемыеПодменю Цикл
			СобытияФормИСМП.ДобавитьЭлементФормыПодменю(ЭтотОбъект, 
				ЭлементКоллекции.ИмяЭлемента,
				ЭлементРодитель,
				ЭлементКоллекции.Заголовок);
		КонецЦикла;
		
		Для Каждого ЭлементКоллекции Из ДобавляемыеКоманды Цикл
			СобытияФормИСМП.ДобавитьЭлементФормыКнопка(ЭтотОбъект, 
				ЭлементКоллекции.ИмяЭлемента,
				?(ЭлементКоллекции.Подменю = Неопределено,
				  ЭлементРодитель,
				  Элементы[ЭлементКоллекции.Подменю]));
		КонецЦикла;
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти