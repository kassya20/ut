#Область АдресМестаОсуществленияДеятельности

&НаКлиенте
Процедура АдресМОДСтрокойОбработкаВыбора(Элемент, ВыбранноеЗначение, ДополнительныеДанные, ВыборДобавлением, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	Если ТипЗнч(ВыбранноеЗначение) <> Тип("Структура") Тогда
		// Отказ от выбора, данные неизменны.
		Возврат;
	КонецЕсли;
	
	Если ВыбранноеЗначение.Свойство("Действие") Тогда
		Если ВыбранноеЗначение.Действие = "ОткрытьСписокМОД" Тогда
			ОткрытьСписокМестОсуществленияДеятельности();
		ИначеЕсли ВыбранноеЗначение.Действие = "ЗаполнитьАдрес" Тогда
			Объект.МестоОсуществленияДеятельностиАдресСтрокой = ВыбранноеЗначение.ПредставлениеАдреса;
			Объект.МестоОсуществленияДеятельностиАдрес        = ВыбранноеЗначение.ДанныеАдреса;
			Объект.ИдентификаторФИАС                          = ВыбранноеЗначение.КодФИАС;
			Модифицированность                                = Истина;
		КонецЕсли;
	Иначе
		Объект.МестоОсуществленияДеятельностиАдрес         = ВыбранноеЗначение.КонтактнаяИнформация;
		Объект.МестоОсуществленияДеятельностиАдресСтрокой  = ВыбранноеЗначение.Представление;
		Объект.ИдентификаторФИАС                           = ИдентификаторФИАСПоДаннымАдреса(ВыбранноеЗначение.КонтактнаяИнформация);
		КомментарийАдресаМестаОсуществленияДеятельности    = ВыбранноеЗначение.Комментарий;
		Модифицированность = Истина;
	КонецЕсли;
	
	ОбновитьСтатусПроверкиМОД();
	
КонецПроцедуры

&НаКлиенте
Процедура АдресМОДСтрокойПриИзменении(Элемент)
	
	Текст = Элемент.ТекстРедактирования;
	
	Если ПустаяСтрока(Текст) Тогда
		// Очистка данных, сбрасываем как представления, так и внутренние значения полей.
		Объект.МестоОсуществленияДеятельностиАдресСтрокой = "";
		Объект.МестоОсуществленияДеятельностиАдрес        = "";
		Объект.ИдентификаторФИАС                          = "";
		КомментарийАдресаМестаОсуществленияДеятельности   = "";
	Иначе
		// Формируем внутренние значения полей по тексту и параметрам формирования из
		// структуры ВидКонтактнойИнформацииАдресаПроизводственногоОбъекта.
		ДанныеАдреса = ОбщегоНазначенияИСВызовСервера.ЗначенияПолейКонтактнойИнформации(
			Текст, ВидКонтактнойИнформацииАдресаМОД);
			
		Объект.МестоОсуществленияДеятельностиАдресСтрокой = Текст;
		Объект.МестоОсуществленияДеятельностиАдрес        = ДанныеАдреса;
		Объект.ИдентификаторФИАС                          = ИдентификаторФИАСПоДаннымАдреса(ДанныеАдреса);
		
	КонецЕсли;
	
	ОбновитьСтатусПроверкиМОД();
	
КонецПроцедуры

&НаКлиенте
Процедура АдресМОДСтрокойОчистка(Элемент, СтандартнаяОбработка)
	
	// Сбрасываем как представления, так и внутренние значения полей.
	Объект.МестоОсуществленияДеятельностиАдресСтрокой = "";
	Объект.МестоОсуществленияДеятельностиАдрес        = "";
	Объект.ИдентификаторФИАС                          = "";
	КомментарийАдресаМестаОсуществленияДеятельности   = "";
	
	ОбновитьСтатусПроверкиМОД();
	
КонецПроцедуры

&НаКлиенте
Процедура АдресМОДСтрокойНачалоВыбора(Элемент, ДанныеВыбора, ВыборДобавлением, СтандартнаяОбработка)
	
	// Если представление было изменено в поле и сразу нажата кнопка выбора, то необходимо 
	// привести данные в соответствие и сбросить внутренние поля для повторного разбора.
	Если Элемент.ТекстРедактирования <> Объект.МестоОсуществленияДеятельностиАдресСтрокой Тогда
		Объект.МестоОсуществленияДеятельностиАдресСтрокой = Элемент.ТекстРедактирования;
		Объект.МестоОсуществленияДеятельностиАдрес        = "";
	КонецЕсли;
	
	// Данные для редактирования
	ПараметрыОткрытия = УправлениеКонтактнойИнформациейКлиент.ПараметрыФормыКонтактнойИнформации(
		ВидКонтактнойИнформацииАдресаМОД,
		Объект.МестоОсуществленияДеятельностиАдрес,
		Объект.МестоОсуществленияДеятельностиАдресСтрокой,
		КомментарийАдресаМестаОсуществленияДеятельности);
	ПараметрыОткрытия.Заголовок = НСтр("ru = 'Адрес места осуществления деятельности'");
	
	УправлениеКонтактнойИнформациейКлиент.ОткрытьФормуКонтактнойИнформации(ПараметрыОткрытия, Элемент);
	
КонецПроцедуры

