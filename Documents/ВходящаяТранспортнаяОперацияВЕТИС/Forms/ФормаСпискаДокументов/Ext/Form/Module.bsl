&НаКлиенте
Процедура ЗапроситьВСДПоИдентификатору(Команда)
	
	ПараметрыОткрытия = Новый Структура;
	
	ОрганизацииВЕТИСДляОбмена = ИнтеграцияВЕТИСКлиент.ОрганизацииВЕТИСДляОбмена(ЭтотОбъект);
	Если ОрганизацииВЕТИСДляОбмена <> Неопределено
		И ОрганизацииВЕТИСДляОбмена.Количество() = 1 Тогда
		
		ОрганизацияВЕТИСДляОбмена = ОрганизацииВЕТИСДляОбмена[0];
		ПараметрыОткрытия.Вставить("ХозяйствующийСубъект", ОрганизацияВЕТИСДляОбмена.Организация);
		
		Если ОрганизацияВЕТИСДляОбмена.Предприятия.Количество() = 1 Тогда
			ПараметрыОткрытия.Вставить("Предприятие", ОрганизацияВЕТИСДляОбмена.Предприятия[0]);
		КонецЕсли;
		
	КонецЕсли;
	
	ОткрытьФорму(
		"Справочник.ВетеринарноСопроводительныйДокументВЕТИС.Форма.ЗапросВСД",
		ПараметрыОткрытия,
		ЭтотОбъект);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура УстановитьУсловноеОформление()

	УсловноеОформление.Элементы.Очистить();
	
	// Ошибки
	Элемент = УсловноеОформление.Элементы.Добавить();
	
	ПолеЭлемента = Элемент.Поля.Элементы.Добавить();
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(Элементы.СтатусВЕТИС.Имя);
	
	ОтборЭлемента = Элемент.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ОтборЭлемента.ЛевоеЗначение = Новый ПолеКомпоновкиДанных(Элементы.СтатусВЕТИС.ПутьКДанным);
	ОтборЭлемента.ВидСравнения  = ВидСравненияКомпоновкиДанных.ВСписке;
	
	СписокСтатусов = Новый СписокЗначений;
	СписокСтатусов.ЗагрузитьЗначения(Документы.ВходящаяТранспортнаяОперацияВЕТИС.СтатусыОшибок());
	ОтборЭлемента.ПравоеЗначение = СписокСтатусов;
	
	Элемент.Оформление.УстановитьЗначениеПараметра("ЦветТекста", ЦветаСтиля.СтатусОбработкиОшибкаПередачиГосИС);
	
	// Требуется ожидание
	Элемент = УсловноеОформление.Элементы.Добавить();
	
	ПолеЭлемента = Элемент.Поля.Элементы.Добавить();
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(Элементы.СтатусВЕТИС.Имя);
	
	ОтборЭлемента = Элемент.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ОтборЭлемента.ЛевоеЗначение = Новый ПолеКомпоновкиДанных(Элементы.ДальнейшееДействиеВЕТИС.ПутьКДанным);
	ОтборЭлемента.ВидСравнения  = ВидСравненияКомпоновкиДанных.ВСписке;
	
	СписокДействий = Новый СписокЗначений;
	СписокДействий.ЗагрузитьЗначения(Документы.ВходящаяТранспортнаяОперацияВЕТИС.ВсеТребующиеОжидания());
	ОтборЭлемента.ПравоеЗначение = СписокДействий;
	
	Элемент.Оформление.УстановитьЗначениеПараметра("ЦветТекста", ЦветаСтиля.СтатусОбработкиПередаетсяГосИС);
	
	// Даты
	СтандартныеПодсистемыСервер.УстановитьУсловноеОформлениеПоляДата(ЭтотОбъект, "Список.Дата",            Элементы.Дата.Имя);
	СтандартныеПодсистемыСервер.УстановитьУсловноеОформлениеПоляДата(ЭтотОбъект, "СписокКОформлению.Дата", Элементы.СписокКОформлениюДата.Имя);
	
КонецПроцедуры

&НаСервере
Процедура УстановитьВидимостьДальнейшихДействий()
	
	КомандВГруппе = 2;
	
	ОперацииДопустимыхДействий = Документы.ВходящаяТранспортнаяОперацияВЕТИС.ОперацииДопустимыхДействий();
	Если ОперацииДопустимыхДействий.Получить(Перечисления.ДальнейшиеДействияПоВзаимодействиюВЕТИС.ПередайтеДанные) <> Неопределено Тогда
		Если НЕ ПользователиВЕТИС.ОперацияДоступнаПользователю(ОперацииДопустимыхДействий.Получить(Перечисления.ДальнейшиеДействияПоВзаимодействиюВЕТИС.ПередайтеДанные)) Тогда
			КомандВГруппе = КомандВГруппе - 1;
			Элементы.СписокПередатьДанные.Видимость = Ложь;
		КонецЕсли;
	КонецЕсли;
	
	Если ОперацииДопустимыхДействий.Получить(Перечисления.ДальнейшиеДействияПоВзаимодействиюВЕТИС.ПроверьтеВозможностьПеремещения) <> Неопределено Тогда
		Если НЕ ПользователиВЕТИС.ОперацияДоступнаПользователю(ОперацииДопустимыхДействий.Получить(Перечисления.ДальнейшиеДействияПоВзаимодействиюВЕТИС.ПроверьтеВозможностьПеремещения)) Тогда
			КомандВГруппе = КомандВГруппе - 1;
			Элементы.СписокПроверитьВозможностьПеремещения.Видимость = Ложь;
		КонецЕсли;
	КонецЕсли;
	
	Если КомандВГруппе<2 Тогда
		Элементы.Действия.Вид = ВидГруппыФормы.ГруппаКнопок;
	КонецЕсли;
	
КонецПроцедуры

//@skip-warning
&НаКлиенте
Процедура Подключаемый_ВыполнитьОбменОбработкаОжидания()
	
	ИнтеграцияВЕТИСКлиент.ПродолжитьВыполнениеОбмена(ЭтотОбъект);
	
КонецПроцедуры

&НаСервере
Процедура УстановитьВидимостьТаблицыКОформлению()
	
	Если ТТНПродукция Тогда
		Элементы.СписокТТНКОформлению.Видимость                      = Истина;
		Элементы.СписокТТНКОформлениюКоманднаяПанельГруппа.Видимость = Истина;
		Элементы.СписокКОформлению.Видимость                         = Ложь;
		Элементы.СписокКОформлениюКоманднаяПанельГруппа.Видимость    = Ложь;
	Иначе 
		Элементы.СписокТТНКОформлению.Видимость                      = Ложь;
		Элементы.СписокТТНКОформлениюКоманднаяПанельГруппа.Видимость = Ложь;
		Элементы.СписокКОформлению.Видимость                         = Истина;
		Элементы.СписокКОформлениюКоманднаяПанельГруппа.Видимость    = Истина;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура УстановитьВидимостьУпрощеннаяИнтеграцияБЭД()
	
	// Страница Оформлено
	Элементы.ГруппаГрузополучатель.Видимость                         = Ложь;
	Элементы.ГрузоотправительПредприятие.Видимость                   = Ложь;
	Элементы.ГрузоотправительХозяйствующийСубъект.ОтображатьВШапке   = Ложь;
	
	// Страница КОформлению
	// ТТН
	Элементы.СписокТТНКОформлениюГруппаГрузополучатель.Видимость          = Ложь;
	Элементы.СписокТТНКОформлениюПеревозчикХозяйствующийСубъект.Видимость = Ложь;
	Элементы.СписокТТНКОформлениюГрузоотправительПредприятие.Видимость    = Ложь;
	
	Элементы.СписокТТНКОформлениюГрузоотправительХозяйствующийСубъект.ОтображатьВШапке = Ложь;
	Элементы.СписокТТНКОформлениюГруппаТТН.Группировка = ГруппировкаКолонок.Горизонтальная;
	// ВСД
	Элементы.СписокКОформлениюГрузоотправительПредприятие.Видимость    = Ложь;
	Элементы.СписокКОформлениюГруппаГрузополучатель.Видимость          = Ложь;
	Элементы.СписокКОформлениюГруппаБланкСтрогойОтчетности.Видимость   = Ложь;
	Элементы.СписокКОформлениюПеревозчикХозяйствующийСубъект.Видимость = Ложь;
	Элементы.СписокКОформлениюГрузоотправительХозяйствующийСубъект.ОтображатьВШапке = Ложь;
	Элементы.СписокКОформлениюГруппаТТН.Группировка = ГруппировкаКолонок.Горизонтальная;
	
КонецПроцедуры
&НаСервере
Процедура СохранитьНастройкиФормы()
	
	ОбщегоНазначения.ХранилищеОбщихНастроекСохранить("ВходящаяТранспортнаяОперацияВЕТИСФормаСпискаДокументов", "ТТНПродукция", ТТНПродукция);
	
КонецПроцедуры

&НаСервере
Процедура ВосстановитьНастройкиФормы()
	
	ТТНПродукция = ОбщегоНазначения.ХранилищеОбщихНастроекЗагрузить("ВходящаяТранспортнаяОперацияВЕТИСФормаСпискаДокументов", "ТТНПродукция", ТТНПродукция);
	
КонецПроцедуры

&НаСервере
Функция ВозможностьВводаВходящейТранспортнойОперации(Знач ВыделенныеСтроки)
	
	ВозвращаемоеЗначение = Новый Структура();
	ВозвращаемоеЗначение.Вставить("ВозможностьВвода",               Ложь);
	ВозвращаемоеЗначение.Вставить("ТребуетсяАвторизацияГИСМТ",      Ложь);
	ВозвращаемоеЗначение.Вставить("ЕстьОшибкиСозданияНоменклатуры", Ложь);
	ВозвращаемоеЗначение.Вставить("Организация",                    Неопределено);
	
	МассивВСД = Новый Массив;
	Если ВыделенныеСтроки = Неопределено Тогда
		Возврат ВозвращаемоеЗначение;
	ИначеЕсли ВыделенныеСтроки.Количество() = 0 Тогда
		Возврат ВозвращаемоеЗначение;
	ИначеЕсли ВыделенныеСтроки.Количество() = 1 Тогда
		ВозвращаемоеЗначение.ВозможностьВвода = Истина;
		МассивВСД.Добавить(ВыделенныеСтроки[0]);
		Результат = ПроверитьЗагрузитьНоменклатуру(МассивВСД);
		ВозвращаемоеЗначение.Организация = Результат.Организация;
		Если Результат.ЕстьОшибки Тогда
			ВозвращаемоеЗначение.ВозможностьВвода               = Ложь;
			ВозвращаемоеЗначение.ЕстьОшибкиСозданияНоменклатуры = Истина;
		ИначеЕсли Результат.ТребуетсяАвторизацияГИСМТ Тогда
			ВозвращаемоеЗначение.ТребуетсяАвторизацияГИСМТ = Истина;
			ВозвращаемоеЗначение.ВозможностьВвода          = Ложь;
		КонецЕсли;
		Возврат ВозвращаемоеЗначение;
	КонецЕсли;
	
	ДанныеОтбора = ИнтеграцияВЕТИСКлиентСервер.РеквизитыПодбораВСДВоВходящуюТранспортнуюОперацию();
	ЗаполнитьЗначенияСвойств(ДанныеОтбора,ВыделенныеСтроки[0]);
	ВыборкаВСД = ДоступныеВСД(ДанныеОтбора);
	Пока ВыборкаВСД.Следующий() Цикл 
		МассивВСД.Добавить(ВыборкаВСД.Ссылка);
	КонецЦикла;
	Для Каждого ВыделеннаяСтрока Из ВыделенныеСтроки Цикл 
		Если МассивВСД.Найти(ВыделеннаяСтрока) = Неопределено Тогда 
			ОбщегоНазначения.СообщитьПользователю(
				НСтр("ru = 'Различаются ключевые реквизиты ВСД. Выделенные строки должны быть включены в различные входящие транспортные операции'"),,"СписокКОформлению");
			Возврат ВозвращаемоеЗначение;
		КонецЕсли;
	КонецЦикла;
	
	ВозвращаемоеЗначение.ВозможностьВвода = Истина;
	
	Если ВозвращаемоеЗначение.ВозможностьВвода Тогда
		Результат = ПроверитьЗагрузитьНоменклатуру(МассивВСД);
		ВозвращаемоеЗначение.Организация = Результат.Организация;
		Если Результат.ЕстьОшибки Тогда
			ВозвращаемоеЗначение.ВозможностьВвода               = Ложь;
			ВозвращаемоеЗначение.ЕстьОшибкиСозданияНоменклатуры = Истина;
		ИначеЕсли Результат.ТребуетсяАвторизацияГИСМТ Тогда
			ВозвращаемоеЗначение.ВозможностьВвода          = Ложь;
			ВозвращаемоеЗначение.ТребуетсяАвторизацияГИСМТ = Истина;
		КонецЕсли;
	КонецЕсли;
	
	Возврат ВозвращаемоеЗначение;
	
КонецФункции

&НаСервере
Функция ВозможностьВводаВСДПоОтбору(Знач СтрокаОтбора, МассивВСД)
	
	ВозвращаемоеЗначение = Новый Структура();
	ВозвращаемоеЗначение.Вставить("ВозможностьВвода",               Ложь);
	ВозвращаемоеЗначение.Вставить("ТребуетсяАвторизацияГИСМТ",      Ложь);
	ВозвращаемоеЗначение.Вставить("ЕстьОшибкиСозданияНоменклатуры", Ложь);
	ВозвращаемоеЗначение.Вставить("Организация",                    Неопределено);
	
	МассивВСД = Новый Массив;
	ДанныеОтбора = ИнтеграцияВЕТИСКлиентСервер.РеквизитыПодбораВСДВоВходящуюТранспортнуюОперацию();
	ЗаполнитьЗначенияСвойств(ДанныеОтбора,СтрокаОтбора);
	ВыборкаВСД = ДоступныеВСД(ДанныеОтбора);
	Пока ВыборкаВСД.Следующий() Цикл 
		МассивВСД.Добавить(ВыборкаВСД.Ссылка);
	КонецЦикла;
	
	ВозвращаемоеЗначение.ВозможностьВвода = (МассивВСД.Количество()>0);
	
	Если ВозвращаемоеЗначение.ВозможностьВвода Тогда
		Результат = ПроверитьЗагрузитьНоменклатуру(МассивВСД);
		ВозвращаемоеЗначение.Организация = Результат.Организация;
		Если Результат.ЕстьОшибки Тогда
			ВозвращаемоеЗначение.ВозможностьВвода               = Ложь;
			ВозвращаемоеЗначение.ЕстьОшибкиСозданияНоменклатуры = Истина;
		ИначеЕсли Результат.ТребуетсяАвторизацияГИСМТ Тогда
			ВозвращаемоеЗначение.ВозможностьВвода          = Ложь;
			ВозвращаемоеЗначение.ТребуетсяАвторизацияГИСМТ = Истина;
		КонецЕсли;
	КонецЕсли;
	
	Возврат ВозвращаемоеЗначение;
	
КонецФункции

&НаСервере
Функция ПроверитьЗагрузитьНоменклатуру(МассивВСД)
	
	ВозвращаемоеЗначение = Новый Структура();
	ВозвращаемоеЗначение.Вставить("ЕстьОшибки",                Ложь);
	ВозвращаемоеЗначение.Вставить("ТребуетсяАвторизацияГИСМТ", Ложь);
	ВозвращаемоеЗначение.Вставить("Организация",               Неопределено);
	
	Если Не ИнтеграцияИС.УпрощеннаяИнтеграцияБЭД() Тогда
		Возврат ВозвращаемоеЗначение;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ
		|	ВетеринарноСопроводительныйДокументВЕТИС.Продукция КАК ПродукцияВЕТИС,
		|	ПродукцияВЕТИС.GTIN                                КАК GTIN
		|ИЗ
		|	Справочник.ВетеринарноСопроводительныйДокументВЕТИС КАК ВетеринарноСопроводительныйДокументВЕТИС
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.ПродукцияКСопоставлениюВЕТИС КАК ПродукцияКСопоставлениюВЕТИС
		|		ПО ВетеринарноСопроводительныйДокументВЕТИС.Продукция = ПродукцияКСопоставлениюВЕТИС.Продукция
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ПродукцияВЕТИС КАК ПродукцияВЕТИС
		|		ПО ВетеринарноСопроводительныйДокументВЕТИС.Продукция = ПродукцияВЕТИС.Ссылка
		|ГДЕ
		|	ВетеринарноСопроводительныйДокументВЕТИС.Ссылка В (&МассивВСД)";
	
	Запрос.УстановитьПараметр("МассивВСД", МассивВСД);
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Количество() = 0 Тогда
		Возврат ВозвращаемоеЗначение;
	КонецЕсли;
	
	СоответствиеGTINПродукции = Новый Соответствие();
	
	ШтрихкодыEAN = Новый Массив;
	Пока Выборка.Следующий() Цикл
		Если ЗначениеЗаполнено(Выборка.GTIN) Тогда
			ШтрихкодыEAN.Добавить(РазборКодаМаркировкиИССлужебныйКлиентСерверПовтИсп.ШтрихкодEANИзGTIN(Выборка.GTIN));
			СоответствиеGTINПродукции.Вставить(Выборка.GTIN, Выборка.ПродукцияВЕТИС);
		КонецЕсли;
	КонецЦикла;
	
	Если ШтрихкодыEAN.Количество() = 0 Тогда
		Возврат ВозвращаемоеЗначение;
	КонецЕсли;
	
	ПараметрыСканирования = ШтрихкодированиеОбщегоНазначенияИС.ПараметрыСканирования(ЭтотОбъект);
	ДанныеПоШтрихкодамEANРезультат = ШтрихкодированиеОбщегоНазначенияИС.ДанныеПоШтрихкодамEAN(
		ШтрихкодыEAN, ПараметрыСканирования,, Истина);
	
	ВозвращаемоеЗначение.Организация = ПараметрыСканирования.Организация;
	
	Если ДанныеПоШтрихкодамEANРезультат.ТребуетсяОбновлениеКлючаСессии Тогда
		ВозвращаемоеЗначение.ТребуетсяАвторизацияГИСМТ = Истина;
	ИначеЕсли ЗначениеЗаполнено(ДанныеПоШтрихкодамEANРезультат.ТекстОшибки) Тогда
		ОбщегоНазначения.СообщитьПользователю(ДанныеПоШтрихкодамEANРезультат.ТекстОшибки);
		ВозвращаемоеЗначение.ЕстьОшибки = Истина;
	ИначеЕсли ДанныеПоШтрихкодамEANРезультат.ТребуетсяПовторОперации Тогда
		ОбщегоНазначения.СообщитьПользователю(НСтр( "ru = 'Повторите операцию'"));
		ВозвращаемоеЗначение.ЕстьОшибки = Истина;
	ИначеЕсли ДанныеПоШтрихкодамEANРезультат.ДанныеПоШтрихкодамEAN.Количество() Тогда
		
		Для Каждого КлючИЗначение Из СоответствиеGTINПродукции Цикл
			
			GTIN           = КлючИЗначение.Ключ;
			ПродукцияВЕТИС = КлючИЗначение.Значение;
			ШтрихкодEAN    = РазборКодаМаркировкиИССлужебныйКлиентСерверПовтИсп.ШтрихкодEANИзGTIN(GTIN);
			
			СтруктураПоиска = Новый Структура;
			СтруктураПоиска.Вставить("ШтрихкодEAN", ШтрихкодEAN);
			
			ПоискСтрок = ДанныеПоШтрихкодамEANРезультат.ДанныеПоШтрихкодамEAN.НайтиСтроки(СтруктураПоиска);
			
			Если ПоискСтрок.Количество() Тогда
				
				Для Каждого СтрокаТаблицы Из ПоискСтрок Цикл
					ИнтеграцияВЕТИС.ЗаписатьСопоставлениеСНоменклатурой(
						ПродукцияВЕТИС,
						СтрокаТаблицы.Номенклатура,
						СтрокаТаблицы.Характеристика,
						СтрокаТаблицы.Серия);
				КонецЦикла;
				
			Иначе
				
				ИнтеграцияВЕТИС.УдалитьПродукциюКСопоставлению(ПродукцияВЕТИС);
				
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЕсли;
	
	Возврат ВозвращаемоеЗначение;
	
КонецФункции

