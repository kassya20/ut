&НаКлиенте
Процедура ОчиститьИзображение(Команда)
	
	ТекущиеДанные = Элементы.Товары.ТекущиеДанные;
	
	Если ОтсутствуютТекущиеДанныеТЧТовары(ТекущиеДанные) 
		Или Не ЗначениеЗаполнено(ТекущиеДанные.Изображение) Тогда
		Возврат;
	КонецЕсли;
			
	ТекущиеДанные.Изображение = Неопределено;
	ТекущиеДанные.ИзображениеАдресДвоичныхДанных = "";
	ПриИзмененииИзображения(ТекущиеДанные);
	
	УстановитьТекстНевыбраннойКартинки(ТекущиеДанные);
	УстановитьДоступностьКомандИзображения(ТекущиеДанные);
		
КонецПроцедуры

&НаКлиенте
Процедура ПросмотретьИзображение(Команда)
	
	ПросмотретьИзображениеОбработчик();
		
КонецПроцедуры

&НаКлиенте
Процедура ВыбратьКартинкуИзПрисоединенныхФайлов(Команда)

	ТекущиеДанные = Элементы.Товары.ТекущиеДанные;
	
	Если ОтсутствуютТекущиеДанныеТЧТовары(ТекущиеДанные) Тогда
		Возврат;	
	КонецЕсли;
		
	АдресТаблицыИзображений = КоммерческиеПредложенияСлужебныйВызовСервера.АдресТаблицыПодобранныхИзображений(
		ТекущиеДанные.Номенклатура, ТекущиеДанные.Характеристика, УникальныйИдентификатор);
		
	ДополнительныеПараметры = Новый Структура("ИдентификаторСтрокиЗапроса", ТекущиеДанные.ИдентификаторСтрокиЗапроса);
	
	ОписаниеОповещения = Новый ОписаниеОповещения(
		"ВыбратьКартинкуИзПрисоединенныхФайловЗавершение", ЭтотОбъект,  ДополнительныеПараметры);		
		
	ПараметрыФормы = КоммерческиеПредложенияДокументыКлиент.НовыеПараметрыОткрытияФормыВыбораИзображений(
		АдресТаблицыИзображений, УникальныйИдентификатор, ТекущиеДанные.Изображение);
	
	КоммерческиеПредложенияДокументыКлиент.ОткрытьФормуВыбораИзображенийИзПрисоединенныхФайлов(
		ЭтотОбъект, ПараметрыФормы, ОписаниеОповещения);
			
КонецПроцедуры

&НаКлиенте
Процедура ПанельИзображение(Команда)
		
	ПанельОтображается = Не ПанельОтображается;
	
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(
		Элементы, "ГруппаТоварыИзображение", "Видимость", ПанельОтображается);	
		
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(
		Элементы, "ПанельИзображение", "Пометка", ПанельОтображается);	
	
	ТекущиеДанные = Элементы.Товары.ТекущиеДанные;
	Если ОтсутствуютТекущиеДанныеТЧТовары(ТекущиеДанные) Тогда
		Возврат;	
	КонецЕсли;

	НастройкаПанелиИзображенийНаСервере(ИмяФормы, ПанельОтображается, АдресКартинки, ТекущиеДанные.Изображение, 
		ТекущиеДанные.ИзображениеАдресДвоичныхДанных, УникальныйИдентификатор);
		
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьВСервисе(Команда)
	
	ОчиститьСообщения();
	
	Если ПустаяСтрока(Объект.ИдентификаторВСервисе) Тогда
		ОбщегоНазначенияКлиент.СообщитьПользователю(
			НСтр("ru = 'Идентификатор в сервисе неопределен, невозможно перейти по ссылке.'"));
		Возврат;
	КонецЕсли;
	
	// ЭлектронноеВзаимодействие.ИнтеграцияСЭлектроннымиТорговымиПлощадками
	Если Не ЗначениеЗаполнено(Объект.УчетнаяЗапись) Тогда
		ОбщегоНазначенияКлиент.СообщитьПользователю("Укажите учетную запись",,"УчетнаяЗапись", "Объект");
		Возврат;
	КонецЕсли;
	
	НавигационнаяСсылка = ИнтеграцияСЭлектроннымиТорговымиПлощадкамиКлиент.СтрокаПодключенияКСервису(Объект.УчетнаяЗапись,
		ИнтеграцияСЭлектроннымиТорговымиПлощадкамиКлиентСервер.РазделУчетаПокупатели()) + СсылкаНаСтраницуЗапроса();
	ФайловаяСистемаКлиент.ОткрытьНавигационнуюСсылку(НавигационнаяСсылка);
	// Конец ЭлектронноеВзаимодействие.ИнтеграцияСЭлектроннымиТорговымиПлощадками

КонецПроцедуры

&НаКлиенте
Процедура ОбновитьДанныеДокумента(Команда)
	
	Прочитать();

	// ЭлектронноеВзаимодействие.ИнтеграцияСЭлектроннымиТорговымиПлощадками
	Если Объект.ЗапрашиватьПредложенияПоставщиков =
			КоммерческиеПредложенияДокументыКлиентСервер.СпособРазмещенияБидзаар() Тогда
			
		Если Не НастройкиУчета.ИспользоватьИнтеграциюСЭТПБидзаарДляПокупателей Тогда
			ПроверитьСвязьСЭТПБидзаар();
		ИначеЕсли Не ПустаяСтрока(Объект.ИдентификаторВСервисе) Тогда
			ПолучитьСостоянияБидзаар();
		КонецЕсли;
		
	КонецЕсли;
	// Конец ЭлектронноеВзаимодействие.ИнтеграцияСЭлектроннымиТорговымиПлощадками

	ИзменитьЭтап();
	ОбновитьЭлементыФормы();

КонецПроцедуры

&НаКлиенте
Процедура ОпубликоватьИзменения(Команда)
	
	// ЭлектронноеВзаимодействие.ИнтеграцияСЭлектроннымиТорговымиПлощадками
	Если Объект.ЗапрашиватьПредложенияПоставщиков =
			КоммерческиеПредложенияДокументыКлиентСервер.СпособРазмещенияБидзаар() Тогда
			
		Если Не ЗначениеЗаполнено(Объект.ИдентификаторВСервисе) Тогда
			ТекстСообщения = НСтр("ru = 'Для начала закупочной компании воспользуйтесь гиперссылкой ''%1'''");
			ТекстСообщения = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(ТекстСообщения, ПредставлениеКомандыНачатьСборПредложений());
			ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения);
			Возврат;
		КонецЕсли;
			
		Если Не НастройкиУчета.ИспользоватьИнтеграциюСЭТПБидзаарДляПокупателей Тогда
			
			ПроверитьСвязьСЭТПБидзаар();
			
		ИначеЕсли ПустаяСтрока(Объект.ИдентификаторВСервисе) Тогда

			Если ПроверитьЗаполнение() Тогда
				ВыполнитьДействиеПриПереходеСостояний(ТекущееСостояние, ТекущееСостояние);
			КонецЕсли;
			
		ИначеЕсли ТекущееСостояние = ПредопределенноеЗначение("Перечисление.СостоянияЗапросаКоммерческихПредложений.СборПредложений")
			Или ТекущееСостояние = ПредопределенноеЗначение("Перечисление.СостоянияЗапросаКоммерческихПредложений.АнализПредложений") Тогда

			Если ПроверитьЗаполнение() Тогда
				ВыполнитьДействиеПриПереходеСостояний(ТекущееСостояние, ТекущееСостояние);
			КонецЕсли;
			
		Иначе
			ТекстСообщения = СтрШаблон(НСтр("ru = 'Публикация запроса недоступна, так как он находится в состоянии: %1'"),
				ТекущееСостояние);
			ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения);
			Возврат;
		КонецЕсли;
	КонецЕсли;
	// Конец ЭлектронноеВзаимодействие.ИнтеграцияСЭлектроннымиТорговымиПлощадками

КонецПроцедуры

