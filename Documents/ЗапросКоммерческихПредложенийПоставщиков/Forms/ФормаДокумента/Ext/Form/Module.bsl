&НаСервере
Процедура ЗаполнитьПодчиненныеСвойстваПоСтатистике(ИмяРеквизитаРодителя, ОписаниеЗаполняемыхРеквизитов = Неопределено)
	
	ЗаполнениеОбъектовПоСтатистике.ЗаполнитьПодчиненныеРеквизитыОбъекта(Объект, ИмяРеквизитаРодителя,
		ОписаниеЗаполняемыхРеквизитов);

КонецПроцедуры

&НаКлиенте
Процедура ПроверитьИзменениеКлючевогоРеквизита(ИмяРеквизита)
	
	Если Объект.ЗапрашиватьПредложенияПоставщиков =
			КоммерческиеПредложенияДокументыКлиентСервер.СпособРазмещенияБидзаар() Тогда
		
		// ЭлектронноеВзаимодействие.ИнтеграцияСЭлектроннымиТорговымиПлощадками	
		УровеньИзмененияБидзаар = Макс(Кэш.УровеньИзмененияБидзаар,
			ИнтеграцияСЭлектроннымиТорговымиПлощадкамиКлиент.ПроверитьИзменениеКлючевогоРеквизита(
			Кэш.ИменаПубликуемыхРеквизитовБидзаар,
			ИмяРеквизита));
			
		Если УровеньИзмененияБидзаар <> Кэш.УровеньИзмененияБидзаар Тогда
			Кэш.УровеньИзмененияБидзаар = УровеньИзмененияБидзаар;
			ИзменитьЭтап();
		КонецЕсли;
		// Конец ЭлектронноеВзаимодействие.ИнтеграцияСЭлектроннымиТорговымиПлощадками
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПроведениеОпросаНачалоСоздания(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат <> КодВозвратаДиалога.Да Тогда
		Возврат;
	КонецЕсли;
	
	ПараметрыОбъекта = Новый Структура;
	ПараметрыОбъекта.Вставить("ДатаНачала", Объект.ДатаНачалаПубликации);
	ПараметрыОбъекта.Вставить("ДатаОкончания", Объект.ДатаОкончанияПубликации);
	ПараметрыОбъекта.Вставить("ТипРеспондентов", ПредопределенноеЗначение("Справочник.Партнеры.ПустаяСсылка"));
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("ЗначенияЗаполнения", ПараметрыОбъекта);
	ПараметрыФормы.Вставить("РежимВыбора", Истина);
	
	ОповещениеОВыборе = Новый ОписаниеОповещения("ПроведениеОпросаОбработкаРезультатаСоздания", ЭтотОбъект);
	
	ОткрытьФорму("Документ.НазначениеОпросов.ФормаОбъекта", ПараметрыФормы, Элементы.ПроведениеОпроса,
		, , , ОповещениеОВыборе);
	
КонецПроцедуры

&НаКлиенте
Процедура ПроведениеОпросаОбработкаРезультатаСоздания(Результат, ДополнительныеПараметры) Экспорт
	
	ПроверитьИзменениеКлючевогоРеквизита("ПроведениеОпроса");
	
КонецПроцедуры

&НаКлиенте
Процедура ПроведениеОпросаВыборПослеЗаписи(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = КодВозвратаДиалога.Да Тогда
		Записать();
		ОткрытьФорму("Документ.НазначениеОпросов.ФормаВыбора", , Элементы.ПроведениеОпроса);
	КонецЕсли;
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ПроверитьПроведениеОпроса(ПроведениеОпроса, ПараметрыФормы)
	
	Результат = Новый Структура("ЕстьОшибки, ТекстОшибки", Ложь, "");
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	НазначениеОпросов.ШаблонАнкеты КАК ШаблонАнкеты
	|ПОМЕСТИТЬ врШаблонАнкеты
	|ИЗ
	|	Документ.НазначениеОпросов КАК НазначениеОпросов
	|ГДЕ
	|	НазначениеОпросов.Ссылка = &ПроведениеОпроса
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ ПЕРВЫЕ 1
	|	ЗапросКоммерческихПредложенийПоставщиков.Ссылка КАК ИсточникОшибки,
	|	1 КАК ВидОшибки
	|ИЗ
	|	Документ.ЗапросКоммерческихПредложенийПоставщиков КАК ЗапросКоммерческихПредложенийПоставщиков
	|ГДЕ
	|	ЗапросКоммерческихПредложенийПоставщиков.ПроведениеОпроса = &ПроведениеОпроса
	|	И ЗапросКоммерческихПредложенийПоставщиков.Ссылка <> &Ссылка
	|	И НЕ ЗапросКоммерческихПредложенийПоставщиков.ПометкаУдаления
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ ПЕРВЫЕ 1
	|	ВопросыШаблонаАнкеты.Ссылка,
	|	2
	|ИЗ
	|	Справочник.ВопросыШаблонаАнкеты КАК ВопросыШаблонаАнкеты
	|ГДЕ
	|	НЕ ВопросыШаблонаАнкеты.ПометкаУдаления
	|	И ВопросыШаблонаАнкеты.Владелец В
	|			(ВЫБРАТЬ
	|				врШаблонАнкеты.ШаблонАнкеты
	|			ИЗ
	|				врШаблонАнкеты КАК врШаблонАнкеты)
	|	И НЕ ВопросыШаблонаАнкеты.ТипВопроса В (ЗНАЧЕНИЕ(Перечисление.ТипыВопросовШаблонаАнкеты.Простой), ЗНАЧЕНИЕ(Перечисление.ТипыВопросовШаблонаАнкеты.ВопросСУсловием))
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ ПЕРВЫЕ 1
	|	ВопросыШаблонаАнкеты.Ссылка,
	|	3
	|ИЗ
	|	Справочник.ВопросыШаблонаАнкеты КАК ВопросыШаблонаАнкеты
	|		ЛЕВОЕ СОЕДИНЕНИЕ ПланВидовХарактеристик.ВопросыДляАнкетирования КАК ВопросыДляАнкетирования
	|		ПО ВопросыШаблонаАнкеты.ЭлементарныйВопрос = ВопросыДляАнкетирования.Ссылка
	|ГДЕ
	|	НЕ ВопросыШаблонаАнкеты.ПометкаУдаления
	|	И ВопросыШаблонаАнкеты.Владелец В
	|			(ВЫБРАТЬ
	|				врШаблонАнкеты.ШаблонАнкеты
	|			ИЗ
	|				врШаблонАнкеты КАК врШаблонАнкеты)
	|	И ВопросыШаблонаАнкеты.ТипВопроса В (ЗНАЧЕНИЕ(Перечисление.ТипыВопросовШаблонаАнкеты.Простой), ЗНАЧЕНИЕ(Перечисление.ТипыВопросовШаблонаАнкеты.ВопросСУсловием))
	|	И ВопросыДляАнкетирования.Ссылка ЕСТЬ NULL";
	
	Запрос.УстановитьПараметр("Ссылка", ПараметрыФормы.Ссылка);
	Запрос.УстановитьПараметр("ПроведениеОпроса", ПроведениеОпроса);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Если РезультатЗапроса.Пустой() Тогда
		Возврат Результат;
	КонецЕсли;
	
	ОшибкиВВопросах = новый Массив;
	Выборка = РезультатЗапроса.Выбрать();
	Пока Выборка.Следующий() Цикл
		Если Выборка.ВидОшибки = 1 Тогда
			ТекстОшибки = СтрШаблон(НСтр("ru = 'Выбранный документ %1 уже используется в %2'"), ПроведениеОпроса, Выборка.ИсточникОшибки);
		ИначеЕсли Выборка.ВидОшибки = 2 Тогда
			ТекстОшибки = НСтр("ru = 'В опросе должны использоваться только простые вопросы. Исключите табличные и комплексные вопросы'");
		ИначеЕсли Выборка.ВидОшибки = 3 Тогда
			ТекстОшибки = НСтр("ru = 'В опросе имеются простые вопросы, для которых не выбран элементарный вопрос'");
		КонецЕсли;
		
		ОшибкиВВопросах.Добавить(ТекстОшибки);
	КонецЦикла;
	
	Результат.ЕстьОшибки = Истина;
	Результат.ТекстОшибки = СтрСоединить(ОшибкиВВопросах, Символы.ПС);
	
	Возврат Результат;
	
КонецФункции

&НаСервере
Процедура ЗаполнитьСписокВыбораЭлектроннойПочты()
	
	Если Объект.ЗапрашиватьПредложенияПоставщиков <>
		КоммерческиеПредложенияДокументыКлиентСервер.СпособРазмещенияБидзаар() Тогда
		
		Возврат;	
	КонецЕсли;
	
	Элементы.МенеджерEmail.СписокВыбора.Очистить();
	Если Не ЗначениеЗаполнено(Объект.Менеджер) Тогда
		Возврат;
	КонецЕсли;
	
	ОбъектыКИ = Новый Массив;
	ОбъектыКИ.Добавить(Объект.Менеджер);
	
	ТипыКИ = Новый Массив;
	ТипыКИ.Добавить(Перечисления.ТипыКонтактнойИнформации.АдресЭлектроннойПочты);
	
	КИМенеджера = УправлениеКонтактнойИнформацией.КонтактнаяИнформацияОбъектов(ОбъектыКИ, ТипыКИ);
	
	Для каждого СтрокаКИ Из КИМенеджера Цикл
		КомментарийКИ = УправлениеКонтактнойИнформацией.КомментарийКонтактнойИнформации(СтрокаКИ.Значение);
		ПредставлениеВСпискеВыбора = ?(ПустаяСтрока(КомментарийКИ),СтрокаКИ.Представление,СтрокаКИ.Представление + " (" + КомментарийКИ + ")");
		Элементы.МенеджерEmail.СписокВыбора.Добавить(СтрокаКИ.Представление,ПредставлениеВСпискеВыбора);
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура ИзменениеКлючевыхСлов()
	Элементы.КлючевыеСловаПредупреждение.Видимость = Ложь;
	// ЭлектронноеВзаимодействие.ИнтеграцияСЭлектроннымиТорговымиПлощадками
	Объект.КлючевыеСлова = ИнтеграцияСЭлектроннымиТорговымиПлощадкамиКлиентСервер.СтрокаКлючевыхСлов(СписокКлючевыхСлов);
	// ЭлектронноеВзаимодействие.ИнтеграцияСЭлектроннымиТорговымиПлощадками
	ПроверитьИзменениеКлючевогоРеквизита("КлючевыеСлова");
КонецПроцедуры

&НаКлиенте
Процедура ВыполнитьПоискКлючевыхСлов()
	
	// ЭлектронноеВзаимодействие.ИнтеграцияСЭлектроннымиТорговымиПлощадками
	ТаблицаКлючевыхСлов.Очистить();
	ИзменитьИнтерфейсВыполнениеЗаданияПолучитьКлючевыеСлова(Истина);
	ИнтеграцияСЭлектроннымиТорговымиПлощадкамиКлиент.КлючевыеСловаБидзаар(Объект.УчетнаяЗапись, Объект.МенеджерEmail,
		УникальныйИдентификатор, СтрокаПоискаКлючевыхСлов);
	// Конец ЭлектронноеВзаимодействие.ИнтеграцияСЭлектроннымиТорговымиПлощадками
	
КонецПроцедуры

&НаКлиенте
Процедура ДобавитьЗначениеВСписокКлючевыхСлов(Знач ДобавляемоеЗначение, СообщитьПриДублировании = Истина)
	
	ДобавляемоеЗначение = НРег(СокрЛП(ДобавляемоеЗначение));
	Если СписокКлючевыхСлов.НайтиПоЗначению(ДобавляемоеЗначение) = Неопределено Тогда
		СписокКлючевыхСлов.Добавить(ДобавляемоеЗначение);
		Модифицированность = Истина;
		ИзменениеКлючевыхСлов();
	Иначе
		Если СообщитьПриДублировании Тогда
			ТекстСообщения = НСтр("ru = 'Данное ключевое слово уже выбрано'");
			ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения);	
		КонецЕсли;	
	КонецЕсли;

КонецПроцедуры

