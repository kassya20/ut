&НаКлиенте
Процедура ПроведениеОпросаОбработкаВыбора(Элемент, ВыбранноеЗначение, ДополнительныеДанные, ВыборДобавлением, СтандартнаяОбработка)
	
	Если ЗначениеЗаполнено(ВыбранноеЗначение) Тогда
		ПараметрыФормы = Новый Структура;
		ПараметрыФормы.Вставить("Ссылка", Объект.Ссылка);
		
		РезультатПроверки = ПроверитьПроведениеОпроса(ВыбранноеЗначение, ПараметрыФормы);
		Если РезультатПроверки.ЕстьОшибки Тогда
			
			ТекстыОщибки = Новый Массив;
			ТекстыОщибки.Добавить(СтрШаблон(НСтр("ru = 'Документ %1 не выбран'"), ВыбранноеЗначение));
			ТекстыОщибки.Добавить(РезультатПроверки.ТекстОшибки);
			
			ТекстОшибки = СтрСоединить(ТекстыОщибки, Символы.ПС);
			
			СтандартнаяОбработка = Ложь;
			ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстОшибки,, "ПроведениеОпроса", "Объект");
			ВыбранноеЗначение = Неопределено;
			
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

