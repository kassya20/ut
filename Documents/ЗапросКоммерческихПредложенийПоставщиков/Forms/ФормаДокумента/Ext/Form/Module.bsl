Функция ПараметрыВидаКонтактнойИнформации(ВидКонтактнойИнформации)

	Возврат УправлениеКонтактнойИнформацией.ПараметрыВидаКонтактнойИнформации(ВидКонтактнойИнформации);

КонецФункции

&НаСервереБезКонтекста
Функция ИспользоватьСервисРаботаСНоменклатурой()
	
	Возврат ПолучитьФункциональнуюОпцию("ИспользоватьСервисРаботаСНоменклатурой");
	
КонецФункции

&НаКлиенте
Процедура ВключитьИспользованиеСервисаРаботыСНоменклатурой(ОписаниеПродолжения)
	
	ПараметрыОткрытия = Новый Структура;
	ПараметрыОткрытия.Вставить("Раздел",    "НастройкиРаботаСНоменклатурой");
	ПараметрыОткрытия.Вставить("Заголовок", НСтр("ru = 'Сервис 1С:Номенклатура'"));
	ПараметрыОткрытия.Вставить("ОписаниеРаздела",
		НСтр("ru = 'Необходимо включить использование сервиса 1С:Номенклатура.'",
		ОбщегоНазначенияКлиент.КодОсновногоЯзыка()));
	
	ОткрытьФорму("Обработка.РаботаСНоменклатурой.Форма.ПанельАдминистрирования", ПараметрыОткрытия, ЭтотОбъект,,,, 
		ОписаниеПродолжения,
		РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	
КонецПроцедуры

&НаКлиенте
Процедура ДобавитьИзображениеОбработчик()
	
	ТекущиеДанные = Элементы.Товары.ТекущиеДанные;
	Если ОтсутствуютТекущиеДанныеТЧТовары(ТекущиеДанные) Тогда
		Возврат;	
	КонецЕсли;
	
	ДобавитьИзображениеСПроверкойЗаписи();
	
КонецПроцедуры

&НаКлиенте
Процедура ДобавитьИзображениеСПроверкойЗаписи()
	
	Если Не ЗначениеЗаполнено(Объект.Ссылка) Тогда
		ТекстВопроса = НСтр("ru='Для добавления изображения необходимо записать документ. Записать?'", 
			ОбщегоНазначенияКлиент.КодОсновногоЯзыка());
		Оповещение = Новый ОписаниеОповещения("ДобавитьИзображениеОбработчикПослеВопроса", ЭтотОбъект);
		ПоказатьВопрос(Оповещение, ТекстВопроса, РежимДиалогаВопрос.ДаНет);
	Иначе
		ДобавитьИзображениеНаКлиентеЗавершение();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ДобавитьИзображениеОбработчикПослеВопроса(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат <> КодВозвратаДиалога.Да Тогда
		Возврат;
	КонецЕсли;
	
	Записать();
		
	ДобавитьИзображениеНаКлиентеЗавершение();
	
КонецПроцедуры

&НаКлиенте
Процедура ДобавитьИзображениеНаКлиентеЗавершение()
		
	ЗаблокироватьДанныеФормыДляРедактирования();	

	ПараметрыЗагрузки = ФайловаяСистемаКлиент.ПараметрыЗагрузкиФайла();
	ПараметрыЗагрузки.ИдентификаторФормы = УникальныйИдентификатор;
	ПараметрыЗагрузки.Диалог.Фильтр = КоммерческиеПредложенияКлиент.ФильтрФайловИзображений();
	ПараметрыЗагрузки.Диалог.МножественныйВыбор = Ложь;
	ПараметрыЗагрузки.Диалог.Заголовок = НСтр("ru = 'Выберите изображение'", 
		ОбщегоНазначенияКлиент.КодОсновногоЯзыка());
	
	Оповещение = Новый ОписаниеОповещения("ОбработатьДобавлениеИзображения", ЭтотОбъект, ПараметрыЗагрузки);
	ФайловаяСистемаКлиент.ЗагрузитьФайл(Оповещение, ПараметрыЗагрузки);	
		
КонецПроцедуры

&НаКлиенте
Процедура ОбработатьДобавлениеИзображения(ПомещенныйФайл, ДополнительныеПараметры) Экспорт
		
	Если ПомещенныйФайл = Неопределено Тогда
		Возврат;	
	КонецЕсли;
		
	ТекущиеДанные = Элементы.Товары.ТекущиеДанные;
	ЭтоТоварРучногоОписания = ТекущиеДанные.ИсточникДобавленияТовара = ИндексРучногоТовара;

	РезультатОбработкиИзображения = ОбработатьДобавлениеИзображенияНаСервере(Объект.Ссылка, ТекущиеДанные.Номенклатура, 
		ТекущиеДанные.Характеристика, ПомещенныйФайл, ЭтоТоварРучногоОписания);
			
	Если РезультатОбработкиИзображения.Отказ Тогда
		ОбщегоНазначенияКлиент.СообщитьПользователю(РезультатОбработкиИзображения.Ошибки);
		Возврат;	
	КонецЕсли;
	
	ТекущиеДанные.Изображение = РезультатОбработкиИзображения.Изображение;
	ТекущиеДанные.ИзображениеАдресДвоичныхДанных = ПомещенныйФайл.Хранение;
	
	ПриИзмененииИзображения(ТекущиеДанные);
	
	УстановитьТекстНевыбраннойКартинки(ТекущиеДанные);
	УстановитьДоступностьКомандИзображения(ТекущиеДанные);	
		
	Модифицированность = Истина;

КонецПроцедуры

&НаСервереБезКонтекста
Функция ОбработатьДобавлениеИзображенияНаСервере(
		ДокументСсылка, Номенклатура, Характеристика, ПомещенныйФайл, ЭтоТоварРучногоОписания)
	
	ИмяФайлаИРасширение = КоммерческиеПредложенияСлужебный.ИмяФайлаИРасширение(ПомещенныйФайл.Имя);
	
	ДанныеДляДобавленияФайла = КоммерческиеПредложенияСлужебный.НовыеДанныеДляДобавленияИзображенияИзФайловойСистемы(
		Номенклатура, Характеристика, ПомещенныйФайл.Хранение, ИмяФайлаИРасширение.ИмяБезРасширения, 
		ИмяФайлаИРасширение.РасширениеБезТочки);
			
	РезультатОбработкиИзображения = КоммерческиеПредложенияСлужебный.ОбработатьДобавлениеИзображения(
		ДокументСсылка, ДанныеДляДобавленияФайла, ЭтоТоварРучногоОписания);
			
	Возврат РезультатОбработкиИзображения;
	
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Процедура УстановитьАдресКартинки(
		АдресКартинки, Изображение, АдресДвоичныхДанных, ПанельОтображается, УникальныйИдентификатор)

	АдресКартинки = АдресДвоичныхДанных;
	КоммерческиеПредложенияДокументыКлиентСервер.УстановитьАдресКартинки(Изображение, АдресКартинки,
		ПанельОтображается, УникальныйИдентификатор);
	АдресДвоичныхДанных = АдресКартинки;	
	
КонецПроцедуры

&НаКлиенте
Процедура ПриИзмененииНоменклатуры(ТекущиеДанные)

	КоммерческиеПредложенияДокументыКлиентПереопределяемый.ПриИзмененииНоменклатуры(
		ЭтотОбъект, ТекущиеДанные, "Номенклатура");
	
	ТекущиеДанные.КлючСинхронизации = Новый УникальныйИдентификатор;
	ТекущиеДанные.ОшибкаПолученияКатегории = Ложь;
	ТекущиеДанные.НоменклатураВСервисеИдентификатор = Неопределено;
	ТекущиеДанные.ХарактеристикаВСервисеИдентификатор = Неопределено;
	ТекущиеДанные.Изображение = Неопределено;
	ТекущиеДанные.ИзображениеАдресДвоичныхДанных = "";
	ТекущиеДанные.ИзображениеВыбрано = Ложь;
	АдресКартинки = "";
	
	УстановитьПризнакКэшированияИзображенияСтроки(ТекущиеДанные, ИспользоватьСервисРаботаСНоменклатурой);
	
	Если Не ТекущиеДанные.ХарактеристикиИспользуются Тогда
		ИдентификаторыСервиса = ИдентификаторыНоменклатурыСервиса(ТекущиеДанные.Номенклатура);
		
		ТекущиеДанные.НоменклатураВСервисеИдентификатор = ИдентификаторыСервиса.Получить(ТекущиеДанные.Номенклатура);
	
		ЗаполнитьПредставлениеКатегории(ТекущиеДанные);
			
		Если Не ПустаяСтрока(ТекущиеДанные.НоменклатураВСервисеИдентификатор) Тогда
			ВнешниеАдресаИзображений = АдресаИзображенийНоменклатурыИзСервиса1СН(
				ТекущиеДанные.НоменклатураВСервисеИдентификатор);
			Если ВнешниеАдресаИзображений.Количество() > 0 Тогда
				ЗаполнитьИзображениеВСтрокеПоВнешнемуАдресу(ТекущиеДанные, ВнешниеАдресаИзображений[0]);
			КонецЕсли;
		Иначе
			ТекущиеДанные.Изображение = КоммерческиеПредложенияСлужебныйВызовСервера.ПодобранноеИзображениеТовараЗКП(
				ТекущиеДанные.Номенклатура, ТекущиеДанные.Характеристика);
		КонецЕсли;

		ПриИзмененииИзображения(ТекущиеДанные);
		
		УстановитьВидимостьПодсказкиИзображения(ТекущиеДанные);
		УстановитьТекстНевыбраннойКартинки(ТекущиеДанные);
		УстановитьДоступностьКомандИзображения(ТекущиеДанные);

	КонецЕсли;
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Процедура ЗаполнитьИзображениеВСтрокеПоВнешнемуАдресу(ТекущиеДанные, ВнешнийАдресИзображения)
			
	ТекущиеДанные.РасширениеИзображения = 
		ОбщегоНазначенияКлиентСервер.ПолучитьРасширениеИмениФайла(ВнешнийАдресИзображения);
	ТекущиеДанные.ТребуетсяСоздатьФайлИзображения = Истина;

	ТекущиеДанные.ИзображениеАдресДвоичныхДанных = 
		АдресДвоичныхДанныхИзображенияПоВнешнейСсылке(ВнешнийАдресИзображения);
				
КонецПроцедуры

&НаСервереБезКонтекста
Функция АдресаИзображенийНоменклатурыИзСервиса1СН(ИдентификаторВСервисе)
	
	Результат = Новый Массив;
	
	ТаблицаДанныхНоменклатурыИзСервиса = РаботаСНоменклатурой.ДанныеНоменклатурыСервиса(ИдентификаторВСервисе);
	Если ТаблицаДанныхНоменклатурыИзСервиса.Количество() = 0 Тогда
		Возврат Результат;
	КонецЕсли;
	
	ДанныеНоменклатурыИзСервиса = ТаблицаДанныхНоменклатурыИзСервиса[0];
	Изображения = ДанныеНоменклатурыИзСервиса.Изображения;
	Результат = Изображения.ВыгрузитьКолонку("ИзображениеURL");
	
	Возврат Результат;
	
КонецФункции

&НаКлиенте
Процедура ПриИзмененииИзображения(ТекущиеДанные)
	
	УстановитьАдресКартинки(АдресКартинки, ТекущиеДанные.Изображение, ТекущиеДанные.ИзображениеАдресДвоичныхДанных,
		ПанельОтображается, УникальныйИдентификатор);
	
	УказатьЗаполненностьИзображенияВСтроке(ТекущиеДанные);
	
	СохранитьВыбранноеИзображение(ТекущиеДанные, ИзмененныеИзображения);
				
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Процедура СохранитьВыбранноеИзображение(СтрокаТоваров, ИзмененныеИзображения)
	
	// Сохраняем выбранное изображение для внутреннего справочника не сопоставленной номенклатуры,
	// в КЭШ выбранных изображений для их последующей записи в регистр
	// сведений ИзображенияЗапросовКоммерческихПредложений при записи документа.
	Если СтрокаТоваров.КэшироватьВыбранноеИзображение Тогда
		
		Отбор = Новый Структура("Номенклатура, Характеристика");
		ЗаполнитьЗначенияСвойств(Отбор, СтрокаТоваров);
		
		НайденныеСтрокиИзмененныхИзображений = ИзмененныеИзображения.НайтиСтроки(Отбор);
		
		Если НайденныеСтрокиИзмененныхИзображений.Количество() > 0 Тогда
			СтрокаИзмененныхЗначений = НайденныеСтрокиИзмененныхИзображений[0];
		Иначе
			СтрокаИзмененныхЗначений = ИзмененныеИзображения.Добавить();
		КонецЕсли;
	
		ЗаполнитьЗначенияСвойств(СтрокаИзмененныхЗначений, СтрокаТоваров, "Номенклатура, Характеристика, Изображение");
	
	КонецЕсли;
		
КонецПроцедуры

&НаКлиенте	
Процедура ПросмотретьИзображениеОбработчик()

	ОчиститьСообщения();
	
	ТекущиеДанные = Элементы.Товары.ТекущиеДанные;	
	Если ОтсутствуютТекущиеДанныеТЧТовары(ТекущиеДанные) Тогда
		Возврат;	
	КонецЕсли;

	Если ЗначениеЗаполнено(ТекущиеДанные.Изображение) Тогда	
		ДанныеФайла = РаботаСФайламиКлиент.ДанныеФайла(ТекущиеДанные.Изображение, УникальныйИдентификатор);		
		РаботаСФайламиКлиент.ОткрытьФайл(ДанныеФайла);
	ИначеЕсли Не ПустаяСтрока(ТекущиеДанные.ИзображениеАдресДвоичныхДанных) Тогда
		ФайловаяСистемаКлиент.ОткрытьФайл(ТекущиеДанные.ИзображениеАдресДвоичныхДанных, , 
			ТекущиеДанные.РасширениеИзображения);
	Иначе
		ТекстСообщения = НСтр("ru='Отсутствует изображение для просмотра'", ОбщегоНазначенияКлиент.КодОсновногоЯзыка());
		ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения);
	КонецЕсли;
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ИзображенияРучныхТоварныхПозиций(Знач ДокументСсылка)
	
	Возврат КоммерческиеПредложенияСлужебный.ИзображенияРучныхТоварныхПозицийЗКППоставщика(ДокументСсылка, Ложь);
	
КонецФункции

&НаСервере
Процедура СохранитьИзмененныеИзображенияТоварныхПозиций()

	ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияПроцедуры();
	ПараметрыВыполнения.ЗапуститьВФоне = Истина;
	
	ИмяДлительнойПроцедуры = "КоммерческиеПредложенияСлужебный.СохранитьВыбранныеИзображенияТоварныхПозицийЗКП";
		
	Отбор = Новый Структура("Номенклатура, Характеристика, Изображение");
	ТаблицаИзмененныхИзображений = ИзмененныеИзображения.Выгрузить().СкопироватьКолонки();
	Для Каждого Строка Из ИзмененныеИзображения Цикл
		
		ЗаполнитьЗначенияСвойств(Отбор, Строка);
		Если Объект.Товары.НайтиСтроки(Отбор).Количество() = 0 Тогда // Могли удалить строку
			Продолжить;
		КонецЕсли;
		
		ЗаполнитьЗначенияСвойств(ТаблицаИзмененныхИзображений.Добавить(), Строка);	
			
	КонецЦикла;
		
	ДлительныеОперации.ВыполнитьПроцедуру(ПараметрыВыполнения, ИмяДлительнойПроцедуры, ТаблицаИзмененныхИзображений);
	
	ИзмененныеИзображения.Очистить();
	
КонецПроцедуры

&НаКлиенте
Процедура ВыбратьКартинкуИзПрисоединенныхФайловЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	Если Не ЗначениеЗаполнено(Результат) 
		Или Результат = КодВозвратаДиалога.Отмена Тогда
		Возврат;
	КонецЕсли;
	
	Отбор = Новый Структура("ИдентификаторСтрокиЗапроса", ДополнительныеПараметры.ИдентификаторСтрокиЗапроса);
	НайденныеСтроки = Объект.Товары.НайтиСтроки(Отбор);
	
	Если НайденныеСтроки.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	Строка = НайденныеСтроки[0];
	Строка.Изображение = Результат;
	Строка.ИзображениеАдресДвоичныхДанных = "";
	
	ПриИзмененииИзображения(Строка);

	УстановитьТекстНевыбраннойКартинки(Строка);
	УстановитьДоступностьКомандИзображения(Строка);
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаписатьНовыйДокументЗКПП(Параметр)
	
	Если ТипЗнч(Параметр) <> Тип("Структура") Тогда
		Возврат;
	КонецЕсли;
	
	Идентификатор = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(Параметр, "Идентификатор", "");
	Если Идентификатор <> УникальныйИдентификатор Тогда			
		Возврат;		
	КонецЕсли;

	Если Записать() Тогда
		ИмяСобытия = КоммерческиеПредложенияДокументыКлиент.ИмяСобытияНовыйДокументЗКППЗаписан();
		Оповестить(ИмяСобытия, Параметр, Объект.Ссылка);	
	КонецЕсли;							
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Функция ОтсутствуютТекущиеДанныеТЧТовары(ТекущиеДанные) 
	Возврат ТекущиеДанные = Неопределено Или Не ЗначениеЗаполнено(ТекущиеДанные.ИдентификаторСтрокиЗапроса);		
КонецФункции

&НаСервереБезКонтекста
Процедура НастройкаПанелиИзображенийНаСервере(
	ИмяФормы, ПанельОтображается, АдресКартинки, Изображение, АдресДвоичныхДанных, УникальныйИдентификатор)

	КоммерческиеПредложенияДокументы.СохранитьНастройкиПанелиИзображенийФормы(ИмяФормы, ПанельОтображается);
							
	УстановитьАдресКартинки(
		АдресКартинки, Изображение, АдресДвоичныхДанных, ПанельОтображается, УникальныйИдентификатор);
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Функция ПредставленияКИМенеджера(Менеджер, ПредставлениеКИ)
	
	Если Не ЗначениеЗаполнено(Менеджер) Тогда
		Возврат "";
	ИначеЕсли Не ПустаяСтрока(ПредставлениеКИ) Тогда
		Возврат ПредставлениеКИ;
	Иначе
		Возврат НСтр("ru ='укажите контактную информацию'");
	КонецЕсли;
	
КонецФункции

// Возвращает ссылку на страницу запроса коммерческих предложений в сервисе.
//
// Возвращаемое значение:
// 	Строка.
//
&НаКлиенте
Функция СсылкаНаСтраницуЗапроса()
	
	Возврат СтрШаблон("/process/light/%1",
		Объект.ИдентификаторВСервисе);
	
КонецФункции

&НаСервере
Процедура ЗаписатьДанныеПредложенийБидзаар(АдресРезультата)

	ТаблицаПредложений = ПолучитьИзВременногоХранилища(АдресРезультата);
	
	Если ТаблицаПредложений.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	Объект.ВыбранныеИсточники.Очистить();
	Для Каждого СтрокаТовар Из ТаблицаПредложений Цикл
		
		Отбор = Новый Структура("ИдентификаторСтрокиЗапроса", СтрокаТовар.ИдентификаторСтрокиЗапроса);
		НайденныеСтроки = Объект.Товары.НайтиСтроки(Отбор);
		
		Если НайденныеСтроки.Количество() = 0 Тогда
			Продолжить;
		КонецЕсли;
		
		НоваяСтрока = Объект.ВыбранныеИсточники.Добавить();
		
		ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТовар);
		
		Если НоваяСтрока.Количество > НайденныеСтроки[0].Количество Тогда
			НоваяСтрока.Количество = НайденныеСтроки[0].Количество;
		КонецЕсли;
		
	КонецЦикла;
	
	Записать();
	
КонецПроцедуры

&НаКлиенте
Процедура НачатьИзменениеСостояния(НавигационнаяСсылкаФорматированнойСтроки, ПодобратьКлючевыеСлова = Ложь)
	
	ПараметрыОповещения = Новый Структура;
    ПараметрыОповещения.Вставить("ПодобратьКлючевыеСлова",ПодобратьКлючевыеСлова);
	ПараметрыОповещения.Вставить("НавигационнаяСсылкаФорматированнойСтроки",НавигационнаяСсылкаФорматированнойСтроки);
	ОписаниеОповещения = Новый ОписаниеОповещения("НачатьИзменениеСостоянияПродолжить",ЭтотОбъект,ПараметрыОповещения);
	
	Если ТребуетсяРегистрацияОрганизации И Не Объект.Организация.Пустая() Тогда

		ПараметрыМетода = Новый Структура;
		ПараметрыМетода.Вставить("ОписаниеОповещения", ОписаниеОповещения);
		
		Если Объект.ЗапрашиватьПредложенияПоставщиков = 2 Тогда
			// ЭлектронноеВзаимодействие.ИнтеграцияСЭлектроннымиТорговымиПлощадками
			Оповещение = Новый ОписаниеОповещения("ПодключениеОрганизацииБидзаарПродолжение", ЭтотОбъект, ПараметрыМетода);
			ИнтеграцияСЭлектроннымиТорговымиПлощадкамиКлиент.ОткрытьФормуПодключенияОрганизацииБидзаар(Объект.Организация,
				ЭтотОбъект, Оповещение);
			// Конец ЭлектронноеВзаимодействие.ИнтеграцияСЭлектроннымиТорговымиПлощадками	
		Иначе
			Оповещение = Новый ОписаниеОповещения("ПодключениеОрганизацииПродолжение", ЭтотОбъект, ПараметрыМетода);
			БизнесСетьСлужебныйКлиент.ОткрытьФормуПодключенияОрганизации(Объект.Организация, ЭтотОбъект, Оповещение);
		КонецЕсли;

	Иначе

		ВыполнитьОбработкуОповещения(ОписаниеОповещения);
		
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура НачатьИзменениеСостоянияПродолжить(Результат, ДополнительныеПараметры) Экспорт

	Если ПустаяСтрока(ДополнительныеПараметры.НавигационнаяСсылкаФорматированнойСтроки) Тогда
		Возврат;
	КонецЕсли;

	ЗаполнитьДанныеПередНачаломИзмененияСтатуса();
	
	ОписаниеОповещения = Новый ОписаниеОповещения("НачатьИзменениеСостоянияЗавершение", ЭтотОбъект, ДополнительныеПараметры);
	
	Если Модифицированность Или Не ЗначениеЗаполнено(Объект.Ссылка) Или Не Объект.Проведен Тогда
		ПоказатьВопросСохраненияДокумента(ОписаниеОповещения, Истина);
		Возврат;
	КонецЕсли;

	ВыполнитьОбработкуОповещения(ОписаниеОповещения,Истина);

КонецПроцедуры

&НаКлиенте
Процедура НачатьИзменениеСостоянияЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Истина Тогда
		ОбработатьИзмененияШапки(ДополнительныеПараметры.НавигационнаяСсылкаФорматированнойСтроки, ДополнительныеПараметры);
	КонецЕсли;			

КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьДанныеПередНачаломИзмененияСтатуса()
	
	Если Объект.ЗапрашиватьПредложенияПоставщиков =
			 КоммерческиеПредложенияДокументыКлиентСервер.СпособРазмещенияБидзаар() Тогда
		
		// Для Бидзаар заполнение даты начала публикации необходиом только при первой выгрузке в сервис
		Если ПустаяСтрока(Объект.ИдентификаторВСервисе)
			И НачалоДня(Объект.ДатаНачалаПубликации) <> НачалоДня(ОбщегоНазначенияКлиент.ДатаСеанса()) Тогда
			
			Объект.ДатаНачалаПубликации = ОбщегоНазначенияКлиент.ДатаСеанса();
			Модифицированность = Истина;
		КонецЕсли;	
		
	Иначе
		
		Если НачалоДня(Объект.ДатаНачалаПубликации) <> НачалоДня(ОбщегоНазначенияКлиент.ДатаСеанса()) Тогда
			Объект.ДатаНачалаПубликации = ОбщегоНазначенияКлиент.ДатаСеанса();
			Модифицированность = Истина;
		КонецЕсли;
	
	КонецЕсли;
		
КонецПроцедуры

&НаКлиенте
Процедура ПроверитьСвязьСЭТПБидзаар()

	Если ТолькоПросмотр Тогда
		Возврат;
	КонецЕсли;
	
	Если ТекущееСостояние = ПредопределенноеЗначение("Перечисление.СостоянияЗапросаКоммерческихПредложений.Завершено") Тогда
		Возврат;
	КонецЕсли;

	Если Объект.ЗапрашиватьПредложенияПоставщиков =
		КоммерческиеПредложенияДокументыКлиентСервер.СпособРазмещенияБидзаар() Тогда 
		
		// ЭлектронноеВзаимодействие.ИнтеграцияСЭлектроннымиТорговымиПлощадками
		Если Не Объект.УчетнаяЗапись.Пустая() Тогда
			Элементы.УчетнаяЗаписьПредупреждение.Видимость = Истина;
			Элементы.УчетнаяЗаписьПредупреждение.Картинка = БиблиотекаКартинок.ДлительнаяОперация16;
			ПараметрыОперации = Новый Структура;
			ПараметрыОперации.Вставить("Источник", Объект.Ссылка);
			ПараметрыОперации.Вставить("УчетнаяЗапись", Объект.УчетнаяЗапись);
			ПараметрыОперации.Вставить("ВидЭТП", ПредопределенноеЗначение(
				"Перечисление.ВидыЭлектронныхТорговыхПлощадок.БидзаарПокупатели"));
			ИнтеграцияСЭлектроннымиТорговымиПлощадкамиКлиент.ПроверитьСвязьСЭТПБидзаар(ПараметрыОперации);
		КонецЕсли;
		// Конец ЭлектронноеВзаимодействие.ИнтеграцияСЭлектроннымиТорговымиПлощадками
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ОформитьЗаказыБидзаар(Элемент, НавигационнаяСсылкаФорматированнойСтроки, СтандартнаяОбработка)

	СтандартнаяОбработка = Ложь;

	ПриЗавершенииСохранения = Новый ОписаниеОповещения("ОформитьЗаказыПослеСохраненияДокументаБидзаар", ЭтотОбъект,
		НавигационнаяСсылкаФорматированнойСтроки);

	Если Модифицированность Или Не ЗначениеЗаполнено(Объект.Ссылка) Тогда
		ПоказатьВопросСохраненияДокумента(ПриЗавершенииСохранения, Истина);
		Возврат;
	Иначе
		Если Не Записать(Новый Структура("РежимЗаписи", РежимЗаписиДокумента.Проведение)) Тогда
			Возврат;
		КонецЕсли;
	КонецЕсли;

	ВыполнитьОбработкуОповещения(ПриЗавершенииСохранения, Истина);

КонецПроцедуры

&НаКлиенте
Процедура ОформитьЗаказыПослеСохраненияДокументаБидзаар(Результат, ДополнительныеПараметры) Экспорт

	Если Не Результат Тогда
		Возврат;
	КонецЕсли;

	ПриЗавершенииСозданияЗаказовБидзаар = Новый ОписаниеОповещения("ПослеЗавершенияСозданияЗаказовБидзаар", ЭтотОбъект);

	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("ЗапросКоммерческихПредложений", Объект.Ссылка);
	ПараметрыФормы.Вставить("ИдентификаторВсервисе", Объект.ИдентификаторВСервисе);
	ПараметрыФормы.Вставить("ИспользоватьЗаказыПоставщикам", ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(НастройкиУчета,
			"ИспользоватьЗаказыПоставщикам", Истина));
	ОткрытьФорму("Документ.ЗапросКоммерческихПредложенийПоставщиков.Форма.ЗагрузкаИтоговБидзаар", ПараметрыФормы,
		ЭтотОбъект, , , , ПриЗавершенииСозданияЗаказовБидзаар, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);

КонецПроцедуры

&НаКлиенте
Процедура ПослеЗавершенияСозданияЗаказовБидзаар(Результат, ДополнительныеПараметры) Экспорт

	ОбновитьОтображениеДанных();

КонецПроцедуры

&НаКлиенте
Процедура УстановитьДоступностьКомандИзображения(ТекущиеДанные)

	ДобавлениеИзображенияКТоваруРазрешено = Ложь;
	ОчисткаРазрешена = Ложь;
	ВыборИзПрисоединенныхФайловРазрешен = Ложь;
	ПросмотрРазрешен = Не ПустаяСтрока(АдресКартинки);
		
	ЭтоТоварИзВнутреннегоСправочника = ЭтоТоварИзСправочника(ТекущиеДанные);
	ЭтоРучнойТовар = ЭтоРучнойТовар(ТекущиеДанные);
	НоменклатураСопоставлена = Не ПустаяСтрока(ТекущиеДанные.НоменклатураВСервисеИдентификатор);
		
	Если ЭтоТоварИзВнутреннегоСправочника И Не НоменклатураСопоставлена Тогда
		
		ДобавлениеИзображенияКТоваруРазрешено = ПозволятьДобавлениеФайлаИзСистемыДляВнутреннейНоменклатуры;
		ОчисткаРазрешена = Не ПустаяСтрока(АдресКартинки);
		ВыборИзПрисоединенныхФайловРазрешен = Истина;
		
	ИначеЕсли ЭтоРучнойТовар Тогда
		
		ДобавлениеИзображенияКТоваруРазрешено = Истина;
		ОчисткаРазрешена = Не ПустаяСтрока(АдресКартинки);
		
	КонецЕсли;
		
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, 
		"ДобавитьИзображение", "Доступность", ДобавлениеИзображенияКТоваруРазрешено);	
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, 
		"ОчиститьИзображение", "Доступность", ОчисткаРазрешена);
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, 
		"ВыбратьКартинкуИзПрисоединенныхФайлов", "Доступность", ВыборИзПрисоединенныхФайловРазрешен);
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, 
		"ПросмотретьИзображение", "Доступность", ПросмотрРазрешен);
	
КонецПроцедуры

&НаКлиенте
Процедура УстановитьВидимостьПодсказкиИзображения(ТекущиеДанные)
	
	НоменклатураСопоставлена = Не ПустаяСтрока(ТекущиеДанные.НоменклатураВСервисеИдентификатор);
	
	ПоказыватьПодсказкуИзображения = Ложь;
	Если Не ПустаяСтрока(АдресКартинки) Тогда
		ПоказыватьПодсказкуИзображения = ЭтоТоварИзСервиса(ТекущиеДанные) 
			Или ЭтоТоварИзСправочника(ТекущиеДанные) И НоменклатураСопоставлена;
	КонецЕсли;
	
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ГруппаПодсказкиИзображения", "Видимость", 
		ПоказыватьПодсказкуИзображения);
	
КонецПроцедуры

&НаКлиенте
Процедура УстановитьТекстНевыбраннойКартинки(ТекущиеДанные)
	
	Если Не ПустаяСтрока(АдресКартинки) Тогда
		Возврат;
	КонецЕсли;
	
	НоменклатураСопоставлена = Не ПустаяСтрока(ТекущиеДанные.НоменклатураВСервисеИдентификатор);
	
	Если ЭтоТоварИзСервиса(ТекущиеДанные)
		Или ЭтоТоварИзСправочника(ТекущиеДанные) И НоменклатураСопоставлена Тогда
		ТекстНевыбраннойКартинки = НСтр("ru = 'Для этой карточки 1С:Номенклатура изображения отсутствуют'", 
			ОбщегоНазначенияКлиент.КодОсновногоЯзыка());
	Иначе
		ТекстНевыбраннойКартинки = НСтр("ru = 'Выберите изображение'", ОбщегоНазначенияКлиент.КодОсновногоЯзыка());
	КонецЕсли;
	
	Если ТекстНевыбраннойКартинки = Элементы.АдресКартинки Тогда
		Возврат;
	КонецЕсли;

	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "АдресКартинки", 
		"ТекстНевыбраннойКартинки", ТекстНевыбраннойКартинки);
				
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьФормуКарточкиНоменклатурыИзСервиса(ТекущиеДанные, РежимВыбораКарточкиНоменклатуры)
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("РежимВыбора", РежимВыбораКарточкиНоменклатуры);
	
	ИдентификаторыНоменклатуры = Новый Структура;
	ИдентификаторыНоменклатуры.Вставить("ИдентификаторНоменклатуры", ТекущиеДанные.НоменклатураВСервисеИдентификатор);
	ИдентификаторыНоменклатуры.Вставить("ИдентификаторХарактеристики", ТекущиеДанные.ХарактеристикаВСервисеИдентификатор);
	
	Идентификаторы = ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(ИдентификаторыНоменклатуры);
	
	РаботаСНоменклатуройКлиент.ОткрытьФормуКарточкиНоменклатуры(Идентификаторы, ЭтотОбъект, , , ПараметрыФормы);
	
КонецПроцедуры

&НаКлиенте
Функция ЭтоТоварИзСервиса(ТекущиеДанные)
	Возврат ТекущиеДанные.ИсточникДобавленияТовара = ИндексТовараИзСервиса;
КонецФункции

&НаКлиенте
Функция ЭтоТоварИзСправочника(ТекущиеДанные)
	Возврат ТекущиеДанные.ИсточникДобавленияТовара = ИндексТовараИзСправочника;
КонецФункции

&НаКлиенте
Функция ЭтоРучнойТовар(ТекущиеДанные)
	Возврат ТекущиеДанные.ИсточникДобавленияТовара = ИндексРучногоТовара;
КонецФункции

&НаКлиенте
Функция ПредставлениеКомандыНачатьСборПредложений()
	Возврат НСтр("ru = 'Начать сбор предложений'");
КонецФункции

&НаКлиенте
Функция ПредставлениеКомандыОпубликоватьИзменения()
	Возврат ?(Кэш.УровеньИзмененияБидзаар = Кэш.УровниИзмененияБидзаар.Обычное,
		НСтр("ru = 'Опубликовать изменения'"),
		НСтр("ru = 'Опубликовать изменения с отменой предложений'"));
КонецФункции

&НаКлиенте
Функция ДоступностьПодбораКлючевыхСлов()
	Возврат Объект.ЗапрашиватьПредложенияПоставщиков = КоммерческиеПредложенияДокументыКлиентСервер.СпособРазмещенияБидзаар()
		И Не ТолькоПросмотр
		И ТекущееСостояние <> ПредопределенноеЗначение("Перечисление.СостоянияЗапросаКоммерческихПредложений.Завершено")
		И ТекущееСостояние <> ПредопределенноеЗначение("Перечисление.СостоянияЗапросаКоммерческихПредложений.ЗагрузкаИтоговыхДанныхБидзаар");
КонецФункции

&НаСервереБезКонтекста
Функция УчетнаяЗаписьДоступна(УчетнаяЗапись)
	
	ДанныеУчетнойЗаписи = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(УчетнаяЗапись, "ПометкаУдаления");
	
	Возврат Не ДанныеУчетнойЗаписи.ПометкаУдаления;
	
КонецФункции

