&НаКлиенте
Процедура ЗагрузитьИзВнешнегоФайла(Команда)
	
	ПараметрыЗагрузки = РаботаСТабличнымиЧастямиКлиент.ПараметрыЗагрузкиНоменклатуры();
	ПараметрыЗагрузки.ДатаЗаполнения  = Объект.Дата;
	ПараметрыЗагрузки.Организация     = Объект.Организация;
	ПараметрыЗагрузки.ЦенаВключаетНДС = Объект.ЦенаВключаетНДС;
	ПараметрыЗагрузки.ЗагружатьЦены   = Истина;
	ПараметрыЗагрузки.ПропускатьПроверкуНоменклатуры   = Истина;
	ПараметрыЗагрузки.ПараметрыОтбора.Вставить("ТипНоменклатуры",
		НоменклатураКлиентСервер.ОтборПоТоваруМногооборотнойТареУслугеРаботе(Ложь));
	
	Оповещение = Новый ОписаниеОповещения("ЗагрузитьИзВнешнегоФайлаЗавершение", ЭтотОбъект);
	РаботаСТабличнымиЧастямиКлиент.ПоказатьФормуЗагрузкиНоменклатуры(ПараметрыЗагрузки, Оповещение);
	
КонецПроцедуры

#КонецОбласти

#КонецОбласти

&НаКлиенте
Процедура ПодобратьКлючевыеСлова(Команда)
	
	// ЭлектронноеВзаимодействие.ИнтеграцияСЭлектроннымиТорговымиПлощадками
	Если Объект.ЗапрашиватьПредложенияПоставщиков =
			КоммерческиеПредложенияДокументыКлиентСервер.СпособРазмещенияБидзаар() Тогда
		
		Если ТолькоПросмотр
			Или ТекущееСостояние = ПредопределенноеЗначение("Перечисление.СостоянияЗапросаКоммерческихПредложений.Завершено")
			Или ТекущееСостояние = ПредопределенноеЗначение("Перечисление.СостоянияЗапросаКоммерческихПредложений.ЗагрузкаИтоговыхДанныхБидзаар") Тогда
			
			ТекстСообщенияПользователю = СтрШаблон(НСтр("ru = 'Подбор ключевых слов недоступен, так как запрос находится в состоянии: %1'"),
				ТекущееСостояние);;
			ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщенияПользователю);
			Возврат;	
		КонецЕсли;
		
		ЗадатьВопрос = Ложь;
		ТекстВопроса = НСтр("ru = 'Для продолжения операции необходимо %1.
						|%2?'");
		
		ТребуетсяСинхронизация = Кэш.УровеньИзмененияБидзаар <> Кэш.УровниИзмененияБидзаар.БезИзменений;
		ТребуетсяВыгрузка = ПустаяСтрока(Объект.ИдентификаторВСервисе);
		ТребуетсяПубликация = ТребуетсяСинхронизация Или ТребуетсяВыгрузка; 
		
		Если ТребуетсяПубликация Тогда
			ЗаполнитьДанныеПередНачаломИзмененияСтатуса();
		КонецЕсли;
		
		ТребуетсяЗапись = Объект.Ссылка.Пустая() Или Модифицированность Или Не Объект.Проведен;
		
		Если ТребуетсяПубликация Тогда
			Если ТребуетсяВыгрузка Тогда
				ТекстПубликации = ПредставлениеКомандыНачатьСборПредложений();	
			ИначеЕсли ТребуетсяСинхронизация Тогда
				ТекстПубликации = ПредставлениеКомандыОпубликоватьИзменения();
			КонецЕсли;
			ТекстПубликацииНРег = НРег(ТекстПубликации);
		КонецЕсли;
		
		Если ТребуетсяЗапись И Не ТребуетсяПубликация Тогда
			ТекстВопроса = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(ТекстВопроса, НСтр("ru = 'записать документ'"), 
				НСтр("ru = 'Записать документ'"));
			ЗадатьВопрос = Истина;
		ИначеЕсли ТребуетсяЗапись И ТребуетсяПубликация Тогда
			ПервыйПараметр = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(НСтр("ru = 'записать документ и %1'"),
				ТекстПубликацииНРег);
			ВторойПараметр = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(НСтр("ru = 'Записать документ и %1'"),
				ТекстПубликацииНРег);
			ТекстВопроса = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(ТекстВопроса, 
				ПервыйПараметр, ВторойПараметр);
			ЗадатьВопрос = Истина;
		ИначеЕсли Не ТребуетсяЗапись И ТребуетсяПубликация Тогда
			ТекстВопроса = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(ТекстВопроса, ТекстПубликацииНРег, 
				ТекстПубликации);
			ЗадатьВопрос = Истина;
		КонецЕсли;
		
		ПараметрыОповещения = Новый Структура;
		ПараметрыОповещения.Вставить("ТребуетсяЗапись",ТребуетсяЗапись);
		ПараметрыОповещения.Вставить("ТребуетсяСинхронизация",ТребуетсяСинхронизация);
		ПараметрыОповещения.Вставить("ТребуетсяВыгрузка",ТребуетсяВыгрузка);
		
		ОписаниеОповещения = Новый ОписаниеОповещения("ПодобратьКлючевыеСловаЗавершение", ЭтотОбъект, ПараметрыОповещения);
		Если ЗадатьВопрос Тогда
			ПоказатьВопрос(ОписаниеОповещения, ТекстВопроса, РежимДиалогаВопрос.ДаНет, , КодВозвратаДиалога.Да);	
		Иначе
			ВыполнитьОбработкуОповещения(ОписаниеОповещения,КодВозвратаДиалога.Да);		
		КонецЕсли;
			
	КонецЕсли;
	// Конец ЭлектронноеВзаимодействие.ИнтеграцияСЭлектроннымиТорговымиПлощадками
	
КонецПроцедуры

