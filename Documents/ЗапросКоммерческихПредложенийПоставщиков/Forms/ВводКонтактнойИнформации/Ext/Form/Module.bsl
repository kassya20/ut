
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ТолькоПросмотр = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(Параметры, "ТолькоПросмотр", Ложь);
	УстановитьТолькоПросмотрФормы(ТолькоПросмотр);
	
	Менеджер = Параметры.Менеджер;
	Параметры.Свойство("Email", Email);
	Параметры.Свойство("Телефон", Телефон);
	Параметры.Свойство("ПредставлениеКИ", ПредставлениеКИ);
	
	ЗаполнитьСпискиВыбораКонтактнойИнфомрации();
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	ПроверитьЗаполнениеАдресаЭлектроннойПочты();

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура EmailПриИзменении(Элемент)
	ПроверитьЗаполнениеАдресаЭлектроннойПочты();
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура ОК(Команда)
	Закрыть(КонтактнаяИнформация());
КонецПроцедуры

&НаКлиенте
Процедура ДобавитьВПредставлениеМенеджер(Команда)

	ДобавитьТекстВПредставление(Строка(Менеджер));	

КонецПроцедуры

&НаКлиенте
Процедура ДобавитьВПредставлениеТелефон(Команда)

	ДобавитьТекстВПредставление(Телефон);	

КонецПроцедуры

&НаКлиенте
Процедура ДобавитьВПредставлениеEmail(Команда)

	ДобавитьТекстВПредставление(Email);	

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Функция КонтактнаяИнформация()
	КонтактнаяИнформация = Новый Структура;
	КонтактнаяИнформация.Вставить("КонтактноеЛицо", "");
	КонтактнаяИнформация.Вставить("Email", "");
	КонтактнаяИнформация.Вставить("Телефон", "");
	КонтактнаяИнформация.Вставить("ПредставлениеКИ", "");
	ЗаполнитьЗначенияСвойств(КонтактнаяИнформация, ЭтотОбъект);
	Возврат КонтактнаяИнформация;
КонецФункции

&НаКлиенте
Процедура ПроверитьЗаполнениеАдресаЭлектроннойПочты()
	ТекстПодсказки = "";
	Если ПустаяСтрока(Email) Тогда
		ТекстПодсказки = НСтр("ru = 'Введите адрес электронной почты'");
	ИначеЕсли Не ОбщегоНазначенияКлиентСервер.АдресЭлектроннойПочтыСоответствуетТребованиям(Email) Тогда
		ТекстПодсказки = НСтр("ru = 'Адрес электронной почты введен неверно'");
	КонецЕсли;
	Элементы.Email.РасширеннаяПодсказка.Заголовок = ТекстПодсказки;
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьСпискиВыбораКонтактнойИнфомрации()
	
	ОбъектыКИ = Новый Массив;
	ОбъектыКИ.Добавить(Менеджер);
	
	ТипыКИ = Новый Массив;
	ТипыКИ.Добавить(Перечисления.ТипыКонтактнойИнформации.Телефон);
	ТипыКИ.Добавить(Перечисления.ТипыКонтактнойИнформации.АдресЭлектроннойПочты);
	
	КИМенеджера = УправлениеКонтактнойИнформацией.КонтактнаяИнформацияОбъектов(ОбъектыКИ, ТипыКИ);
	
	Элементы.Email.СписокВыбора.Очистить();
	Элементы.Телефон.СписокВыбора.Очистить();
	
	Для каждого СтрокаКИ Из КИМенеджера Цикл
		КомментарийКИ = УправлениеКонтактнойИнформацией.КомментарийКонтактнойИнформации(СтрокаКИ.Значение);
		ПредставлениеВСпискеВыбора = ?(ПустаяСтрока(КомментарийКИ),СтрокаКИ.Представление,СтрокаКИ.Представление + " (" + КомментарийКИ + ")");
		Если СтрокаКИ.Тип = Перечисления.ТипыКонтактнойИнформации.Телефон Тогда
			Элементы.Телефон.СписокВыбора.Добавить(СтрокаКИ.Представление,ПредставлениеВСпискеВыбора);
		ИначеЕсли СтрокаКИ.Тип = Перечисления.ТипыКонтактнойИнформации.АдресЭлектроннойПочты Тогда
			Элементы.Email.СписокВыбора.Добавить(СтрокаКИ.Представление,ПредставлениеВСпискеВыбора);
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура ДобавитьТекстВПредставление(ДобавляемыйТекст)

	ПредставлениеКИ = ПредставлениеКИ + ДобавляемыйТекст;

КонецПроцедуры

&НаСервере
Процедура УстановитьТолькоПросмотрФормы(ТолькоПросмотр)
	
	Элементы.Телефон.ТолькоПросмотр = ТолькоПросмотр;
	Элементы.Email.ТолькоПросмотр = ТолькоПросмотр;
	Элементы.ПредставлениеКИ.ТолькоПросмотр = ТолькоПросмотр;
	
	Элементы.ДобавитьВПредставлениеМенеджер.Доступность = Не ТолькоПросмотр;
	Элементы.ДобавитьВПредставлениеТелефон.Доступность = Не ТолькоПросмотр;
	Элементы.ДобавитьВПредставлениеEmail.Доступность = Не ТолькоПросмотр;
		
КонецПроцедуры

#КонецОбласти