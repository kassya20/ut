&НаКлиентеНаСервереБезКонтекста
Процедура УстановитьОтборПросрочено(Форма)
	
	ВидСравненияДатыСобытия = ВидСравненияКомпоновкиДанных.МеньшеИлиРавно;
	
	ГруппаОтбора = ОбщегоНазначенияКлиентСервер.СоздатьГруппуЭлементовОтбора(
		Форма.Список.КомпоновщикНастроек.ФиксированныеНастройки.Отбор.Элементы,
		НСтр("ru='Событие'"), 
		ТипГруппыЭлементовОтбораКомпоновкиДанных.ГруппаИ);
	
	ОбщегоНазначенияКлиентСервер.ДобавитьЭлементКомпоновки(
		ГруппаОтбора,
		"СрокВыполнения",
		ВидСравненияДатыСобытия,
		Форма.ДатаСобытия,,
		ЗначениеЗаполнено(Форма.ДатаСобытия));
		
	ОбщегоНазначенияКлиентСервер.ДобавитьЭлементКомпоновки(
		ГруппаОтбора,
		"СрокВыполнения",
		ВидСравненияКомпоновкиДанных.НеРавно,
		Дата(1,1,1),,
		ЗначениеЗаполнено(Форма.ДатаСобытия));
	
	
КонецПроцедуры

&НаСервере
Функция ОтборПросроченоНажатиеНаСервер()
	
	Возврат ОбщегоНазначения.ТекущаяДатаПользователя();
	
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Процедура УстановитьОтборЗаСегодня(Форма)
	
	Если ЗначениеЗаполнено(Форма.ОтборПериод.ДатаНачала) Тогда
		
		ГруппаЭлементов = ОбщегоНазначенияКлиентСервер.СоздатьГруппуЭлементовОтбора(
			Форма.Список.Отбор.Элементы,
			"ГруппаНачало",
			ТипГруппыЭлементовОтбораКомпоновкиДанных.ГруппаИли);
		
		ОбщегоНазначенияКлиентСервер.ДобавитьЭлементКомпоновки(
			ГруппаЭлементов,
			"Дата", 
			ВидСравненияКомпоновкиДанных.БольшеИлиРавно, 
			Форма.ОтборПериод.ДатаНачала);
			
		ОбщегоНазначенияКлиентСервер.ДобавитьЭлементКомпоновки(
			ГруппаЭлементов,
			"Дата", 
			ВидСравненияКомпоновкиДанных.НеЗаполнено);
			
	Иначе
		
		ОбщегоНазначенияКлиентСервер.УдалитьЭлементыГруппыОтбора(
			Форма.Список.Отбор,
			"Дата");
		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Форма.ОтборПериод.ДатаОкончания) Тогда
		
		ГруппаЭлементов = ОбщегоНазначенияКлиентСервер.СоздатьГруппуЭлементовОтбора(
			Форма.Список.Отбор.Элементы,
			"ГруппаОкончание",
			ТипГруппыЭлементовОтбораКомпоновкиДанных.ГруппаИли);
		
		ОбщегоНазначенияКлиентСервер.ДобавитьЭлементКомпоновки(
			ГруппаЭлементов,
			"Дата", 
			ВидСравненияКомпоновкиДанных.МеньшеИлиРавно, 
			Форма.ОтборПериод.ДатаОкончания);
			
		ОбщегоНазначенияКлиентСервер.ДобавитьЭлементКомпоновки(
			ГруппаЭлементов,
			"Дата", 
			ВидСравненияКомпоновкиДанных.НеЗаполнено);
			
	Иначе
		
		ОбщегоНазначенияКлиентСервер.УдалитьЭлементыГруппыОтбора(
			Форма.Список.Отбор,
			"Дата");
			
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОчиститьОтбор()
	
	СтруктураОтбора = СтруктураОтбораЗаявокНаОтбор();
	
	Для каждого Элемент Из СтруктураОтбора Цикл
		ОбщегоНазначенияКлиентСервер.УдалитьЭлементыГруппыОтбораДинамическогоСписка(Список, Элемент.Ключ); 
	КонецЦикла;

	ОтборСостояние					= Неопределено;
	ОтборНоменклатура				= Неопределено;
	ОтборОтветственный				= Неопределено;
	ОтборЗаСегодня 					= Ложь;
	ОтборИсследованияНеНазначены	= Ложь;
	ОтборПросрочено 				= Ложь;
	ОтборНаИсследовании 			= Ложь;
	ОтборВсе 						= Истина;
	
	НастроитьЗависимыеЭлементыФормы(ЭтотОбъект, "Отбор");
	
КонецПроцедуры

&НаКлиенте
Функция СтруктураОтбораЗаявокНаОтбор()
	
	СтруктураОтбора = Новый Структура;
	СтруктураОтбора.Вставить("Состояние");
	СтруктураОтбора.Вставить("Ссылка");
	СтруктураОтбора.Вставить("Ответственный");
	СтруктураОтбора.Вставить("Дата");
	СтруктураОтбора.Вставить("ГруппаНачало");
	СтруктураОтбора.Вставить("ГруппаОкончание");
	СтруктураОтбора.Вставить("НеНазначеныИсследования");
	СтруктураОтбора.Вставить("Событие");
	СтруктураОтбора.Вставить("СрокВыполнения");
	СтруктураОтбора.Вставить("НаИсследовании");
	СтруктураОтбора.Вставить("Номенклатура");
	
	Возврат СтруктураОтбора;
	
КонецФункции

#КонецОбласти

#Область УправлениеНастройками

&НаСервере
Процедура ВосстановитьНастройкиФормыПриСоздании()
	
	НастройкиФормы = ХранилищеНастроекДанныхФорм.Загрузить(
		МенеджерНастроекКлючОбъекта(), МенеджерНастроекКлючНастроек());
	Если ЗначениеЗаполнено(НастройкиФормы) Тогда
		ЗаполнитьЗначенияСвойств(ЭтотОбъект, НастройкиФормы);
	КонецЕсли; 
	
	УстановитьОтборСостояние(ЭтотОбъект);
	УстановитьОтборНоменклатура();
	УстановитьОтборОтветственный(ЭтотОбъект);
	
	ОтборПериод = Новый СтандартныйПериод(ВариантСтандартногоПериода.Сегодня);
	ДатаСобытия = ОтборПросроченоНажатиеНаСервер();
	Если ОтборЗаСегодня Тогда
		УстановитьОтборЗаСегодня(ЭтотОбъект);
	КонецЕсли;
	Если ОтборНаИсследовании Тогда
		УстановитьОтборНаИсследовании(ЭтотОбъект);
	КонецЕсли;
	Если ОтборИсследованияНеНазначены Тогда
		УстановитьОтборНеНазначеныИсследования(ЭтотОбъект);
	КонецЕсли;
	Если ОтборПросрочено Тогда
		УстановитьОтборПросрочено(ЭтотОбъект);
	КонецЕсли;
	
	НастроитьЗависимыеЭлементыФормы(ЭтотОбъект, "Отбор");
	
КонецПроцедуры

&НаСервере
Процедура СохранитьНастройкиФормы()
	
	НастройкиФормы = СохраняемыеНастройкиФормы();
	
	ЗаполнитьЗначенияСвойств(НастройкиФормы, ЭтотОбъект);
	ХранилищеНастроекДанныхФорм.Сохранить(
		МенеджерНастроекКлючОбъекта(), МенеджерНастроекКлючНастроек(), НастройкиФормы);
	
КонецПроцедуры

&НаСервере
Функция СохраняемыеНастройкиФормы()
	
	Результат = Новый Структура;
	Результат.Вставить("ОтборСостояние");
	Результат.Вставить("ОтборНоменклатура");
	Результат.Вставить("ОтборОтветственный");
	Результат.Вставить("ОтборВсе");
	Результат.Вставить("ОтборЗаСегодня");
	Результат.Вставить("ОтборНаИсследовании");
	Результат.Вставить("ОтборИсследованияНеНазначены");
	Результат.Вставить("ОтборПросрочено");
	
	Возврат Результат;
	
КонецФункции

&НаСервере
Функция МенеджерНастроекКлючОбъекта()
	
	Возврат "ЗаявкиНаКонтрольКачестваТоваров";
	
КонецФункции

&НаСервере
Функция МенеджерНастроекКлючНастроек()
	
	Возврат "НастройкиФормы";
	
КонецФункции

#КонецОбласти

#Область Прочее


&НаСервере
Процедура УстановитьСвойстваДинамическогоСписка()
	
	Возврат;
	
КонецПроцедуры

&НаСервере
Процедура УстановитьУсловноеОформление()

	УсловноеОформление.Элементы.Очистить();
	
	СтандартныеПодсистемыСервер.УстановитьУсловноеОформлениеПоляДата(ЭтотОбъект);
	
	// выделение цветом просроченной заявки на контроль качества
	#Область ПросроченныеИсследования
	
	Элемент = УсловноеОформление.Элементы.Добавить();
	
	Элемент.Поля.Элементы.Добавить().Поле = Новый ПолеКомпоновкиДанных("СрокВыполнения");
	
	ГруппаОтбора = Элемент.Отбор.Элементы.Добавить(Тип("ГруппаЭлементовОтбораКомпоновкиДанных"));
	ГруппаОтбора.ТипГруппы = ТипГруппыЭлементовОтбораКомпоновкиДанных.ГруппаИ;
	
	ОтборЭлемента = ГруппаОтбора.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ОтборЭлемента.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("Список.СрокВыполнения");
	ОтборЭлемента.ВидСравнения = ВидСравненияКомпоновкиДанных.Меньше;
	ОтборЭлемента.ПравоеЗначение = ТекущаяДатаСеанса();
	
	
	Элемент.Оформление.УстановитьЗначениеПараметра("ЦветТекста", ЦветаСтиля.ПросроченныйДокумент);
	
	#КонецОбласти
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Процедура НастроитьЗависимыеЭлементыФормы(Форма, СписокРеквизитов = "")
	
	Элементы = Форма.Элементы;
	
	Инициализация = ПустаяСтрока(СписокРеквизитов);
	СтруктураРеквизитов = Новый Структура(СписокРеквизитов);
	
	Если Инициализация Или СтруктураРеквизитов.Свойство("Отбор") Тогда
		
		УстановитьСостояниеГиперссылки(Форма, Элементы.ГиперссылкаВсе, Форма.ОтборВсе);
		УстановитьСостояниеГиперссылки(Форма, Элементы.ГиперссылкаНаИсследовании, Форма.ОтборНаИсследовании);
		УстановитьСостояниеГиперссылки(Форма, Элементы.ГиперссылкаЗаСегодня, Форма.ОтборЗаСегодня);
		УстановитьСостояниеГиперссылки(Форма, Элементы.ГиперссылкаНеНазначеныИсследования, Форма.ОтборИсследованияНеНазначены);
		УстановитьСостояниеГиперссылки(Форма, Элементы.ГиперссылкаПросрочено, Форма.ОтборПросрочено);
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Процедура УстановитьСостояниеГиперссылки(Форма, Элемент, Нажата)
	
	Если Нажата Тогда
		Элемент.ЦветФона = Форма.Кэш.ЦветНажатогоОтбора;
	Иначе
		Элемент.ЦветФона = Новый Цвет();
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ИнициализироватьКэш()
	
	Кэш = Новый Структура;
	
	Кэш.Вставить("ЦветНажатогоОтбора", ЦветаСтиля.БыстрыеОтборыФонГиперссылки);
	Кэш.Вставить("ДанныеТекущейСтроки", Неопределено);
	
КонецПроцедуры


#КонецОбласти

#КонецОбласти
