#Область Отборы

&НаСервере
Процедура УстановитьОтборНоменклатура()
	
	Если ЗначениеЗаполнено(ОтборНоменклатура) Тогда
	
		СписокОтбора = Новый СписокЗначений;
		
		Запрос = Новый Запрос;
		Запрос.Текст = "
		|ВЫБРАТЬ
		|	Т.Ссылка КАК Ссылка
		|ИЗ
		|	Документ.ЗаявкаНаКонтрольКачестваТоваров.Товары КАК Т
		|ГДЕ
		|	Т.Номенклатура = &Номенклатура
		|";
		Запрос.УстановитьПараметр("Номенклатура", ОтборНоменклатура);
		
		СписокОтбора.ЗагрузитьЗначения(Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Ссылка"));
		
	КонецЕсли;
		
	ОтборПоНоменклатуре = ОбщегоНазначенияКлиентСервер.СоздатьГруппуЭлементовОтбора(
		Список.КомпоновщикНастроек.ФиксированныеНастройки.Отбор.Элементы,
		НСтр("ru = 'Номенклатура'"),
		ТипГруппыЭлементовОтбораКомпоновкиДанных.ГруппаИ);
	
	ОбщегоНазначенияКлиентСервер.ДобавитьЭлементКомпоновки(
			ОтборПоНоменклатуре,
			"Ссылка",
			ВидСравненияКомпоновкиДанных.ВСписке,
			СписокОтбора,
			,
			ЗначениеЗаполнено(ОтборНоменклатура));
	
КонецПроцедуры

