#Область ПрограммныйИнтерфейс

#Область Проведение

// Описывает учетные механизмы используемые в документе для регистрации в механизме проведения.
// 
// Параметры:
//  МеханизмыДокумента - Массив - список имен учетных механизмов, для которых будет выполнена
//              регистрация в механизме проведения.
//
Процедура ЗарегистрироватьУчетныеМеханизмы(МеханизмыДокумента) Экспорт
	
	МеханизмыДокумента.Добавить("Обеспечение");
	МеханизмыДокумента.Добавить("РеестрДокументов");
	МеханизмыДокумента.Добавить("АдресныйСклад");
	
КонецПроцедуры

// Возвращает таблицы для движений, необходимые для проведения документа по регистрам учетных механизмов.
//
// Параметры:
//  Документ - ДокументОбъект.ЗаявкаНаКонтрольКачестваТоваров, ДокументСсылка.ЗаявкаНаКонтрольКачестваТоваров - ссылка на документ или объект, по которому необходимо получить данные
//  Регистры - Структура - список имен регистров, для которых необходимо получить таблицы
//  ДопПараметры - Структура - дополнительные параметры для получения данных, определяющие контекст проведения.
//
// Возвращаемое значение:
//  СписокЗначений, Структура - Данные документа для проведения
Функция ДанныеДокументаДляПроведения(Документ, Регистры, ДопПараметры = Неопределено) Экспорт
	
	Если ДопПараметры = Неопределено Тогда
		ДопПараметры = ПроведениеДокументов.ДопПараметрыИнициализироватьДанныеДокументаДляПроведения();
	КонецЕсли;
	
	Если ТипЗнч(Документ) = Тип("ДокументОбъект.ЗаявкаНаКонтрольКачестваТоваров") Тогда
		ДокументСсылка = Документ.Ссылка;
	Иначе
		ДокументСсылка = Документ;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	ТекстыЗапроса = Новый СписокЗначений();
	
	ПолучитьДанныеДокумента(Запрос, ДокументСсылка);
	
	Если Не ДопПараметры.ПолучитьТекстыЗапроса Тогда
		
		////////////////////////////////////////////////////////////////////////////
		// Создадим запрос инициализации движений
		
		ЗаполнитьПараметрыИнициализации(Запрос, ДокументСсылка);
		
		////////////////////////////////////////////////////////////////////////////
		// Сформируем текст запроса
		ТекстЗапросаТаблицаРеестрДокументов(Запрос, ТекстыЗапроса, Регистры);
		ТекстЗапросаТаблицаДвиженияСерийТоваров(Запрос, ТекстыЗапроса, Регистры);
		
	КонецЕсли;
	
	ОтразитьРаспределениеЗапасовДвижения(Запрос, ТекстыЗапроса, Регистры);
	ОтразитьПоПодсистемеСклад(Запрос, ТекстыЗапроса, Регистры);
	
	////////////////////////////////////////////////////////////////////////////
	// Получим таблицы для движений
	
	Возврат ПроведениеДокументов.ИнициализироватьДанныеДокументаДляПроведения(Запрос, ТекстыЗапроса, ДопПараметры);
	
КонецФункции

#КонецОбласти


#Область Прочее

// Возвращает Организацию, исходя из контролируемой партии документа.
// Параметры:
//  Объект - ДокументОбъект.ЗаявкаНаКонтрольКачестваТоваров - документ
// Возвращаемое значение:
//  СправочникСсылка.Организации - Организация.
Функция ОрганизацияИзКонтролируемойПартии(Объект) Экспорт
	
	Организация = Справочники.Организации.ПустаяСсылка();
	УстановитьПривилегированныйРежим(Истина);
	Запрос = Новый Запрос();
	Запрос.Текст =
		"ВЫБРАТЬ
		|	МИНИМУМ(ВсеКонтролируемыеПартии.Организация) КАК Организация
		|ИЗ
		|	Справочник.КонтролируемыеПартии КАК ВсеКонтролируемыеПартии
		|ГДЕ
		|	ВсеКонтролируемыеПартии.Ссылка В(&Ссылки)
		|ИМЕЮЩИЕ
		|	МИНИМУМ(ВсеКонтролируемыеПартии.Организация) = МАКСИМУМ(ВсеКонтролируемыеПартии.Организация)";
	Запрос.УстановитьПараметр("Ссылки",
		Объект.Товары.Выгрузить(, "КонтролируемаяПартия").ВыгрузитьКолонку("КонтролируемаяПартия"));
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Организация = Выборка.Организация;
	КонецЕсли;
	Возврат Организация;
	
КонецФункции

// Добавляет команду создания документа "Заявка на контроль качества товаров".
// Параметры:
//  КомандыСозданияНаОсновании - см. СозданиеНаОснованииПереопределяемый.ПередДобавлениемКомандСозданияНаОсновании.КомандыСозданияНаОсновании
// Возвращаемое значение:
//  Неопределено -
//  СтрокаТаблицыЗначений -
Функция ДобавитьКомандуСоздатьНаОсновании(КомандыСозданияНаОсновании) Экспорт
	
	Если ПравоДоступа("Добавление", Метаданные.Документы.ЗаявкаНаКонтрольКачестваТоваров) Тогда
		КомандаСоздатьНаОсновании = СозданиеНаОсновании.ДобавитьКомандуСозданияНаОсновании(
			КомандыСозданияНаОсновании, Метаданные.Документы.ЗаявкаНаКонтрольКачестваТоваров);
			КомандаСоздатьНаОсновании.ФункциональныеОпции = "ИспользоватьКонтрольКачестваТоваров";
		Возврат КомандаСоздатьНаОсновании;
	КонецЕсли;
	Возврат Неопределено;
	
КонецФункции

// Параметры документа для механизма заполнения реквизита КонтролируемаяПартия в документе.
// 
// Параметры:
//  ОбъектИлиСсылка - ДокументОбъект.ЗаявкаНаКонтрольКачестваТоваров, ДокументСсылка.ЗаявкаНаКонтрольКачестваТоваров - документ.
//  ИмяПоляКонтролируемаяПартия - Строка - имя поля, контролируемая партия.
// 
// Возвращаемое значение:
//  см. КонтрольКачества.НовыйРеквизитыКонтролируемойПартии
Функция РеквизитыКонтролируемойПартии(ОбъектИлиСсылка, ИмяПоляКонтролируемаяПартия) Экспорт
	
	Запрос = Новый Запрос();
	Ссылка = Неопределено;
	
	ИменаРеквизитовДокумента = "ПричинаБлокировкиТовара,Дата,Номер,ПланироватьРазблокировкуТоваров,ДатаПодтвержденияКачества,Организация";
	Если ОбщегоНазначения.ЭтоСсылка(ТипЗнч(ОбъектИлиСсылка)) Тогда
		
		Ссылка = ОбъектИлиСсылка;
		Запрос.УстановитьПараметр("Ссылка", ОбъектИлиСсылка);
		Запрос.Текст =
			"ВЫБРАТЬ
			|	МАКСИМУМ(ВсеПартии.Партнер) КАК Партнер,
			|	МАКСИМУМ(ВсеПартии.Договор) КАК Договор,
			|	МАКСИМУМ(ВсеПартии.Контрагент) КАК Контрагент,
			|	МАКСИМУМ(ВсеПартии.НаправлениеДеятельности) КАК НаправлениеДеятельности,
			|	МАКСИМУМ(ВсеПартии.ХозяйственнаяОперация) КАК ХозяйственнаяОперация,
			|	МАКСИМУМ(ВсеПартии.Подразделение) КАК Подразделение,
			|	МАКСИМУМ(ВсеПартии.Отправитель) КАК Отправитель,
			|	МАКСИМУМ(ВсеПартии.Партнер) = МИНИМУМ(ВсеПартии.Партнер) КАК ОдинПартнер,
			|	МАКСИМУМ(ВсеПартии.Договор) = МИНИМУМ(ВсеПартии.Договор) КАК ОдинДоговор,
			|	МАКСИМУМ(ВсеПартии.Контрагент) = МИНИМУМ(ВсеПартии.Контрагент) КАК ОдинКонтрагент,
			|	МАКСИМУМ(ВсеПартии.НаправлениеДеятельности) = МИНИМУМ(ВсеПартии.НаправлениеДеятельности) КАК ОдноНаправлениеДеятельности,
			|	МАКСИМУМ(ВсеПартии.ХозяйственнаяОперация) = МИНИМУМ(ВсеПартии.ХозяйственнаяОперация) КАК ОднаХозяйственнаяОперация,
			|	МАКСИМУМ(ВсеПартии.Отправитель) = МИНИМУМ(ВсеПартии.Отправитель) КАК ОдинОтправитель,
			|	МАКСИМУМ(ВсеПартии.Подразделение) = МИНИМУМ(ВсеПартии.Подразделение) КАК ОдноПодразделение
			|ИЗ
			|	Документ.ЗаявкаНаКонтрольКачестваТоваров.Товары КАК Товары
			|		
			|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.КонтролируемыеПартии КАК ВсеПартии
			|		ПО ВсеПартии.Ссылка = Товары.КонтролируемаяПартия
			|ГДЕ
			|	Товары.Ссылка = &Ссылка";
		
		РеквизитыДокумента = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Ссылка, ИменаРеквизитовДокумента);
			
	Иначе
		
		Ссылка = ОбъектИлиСсылка.Ссылка;
		Товары = ОбъектИлиСсылка.Товары;
		Ссылки = Товары.Выгрузить(, "КонтролируемаяПартия").ВыгрузитьКолонку("КонтролируемаяПартия");
		Запрос.УстановитьПараметр("Ссылки", Ссылки);
		Запрос.Текст =
			"ВЫБРАТЬ
			|	МАКСИМУМ(ВсеПартии.Партнер) КАК Партнер,
			|	МАКСИМУМ(ВсеПартии.Договор) КАК Договор,
			|	МАКСИМУМ(ВсеПартии.Контрагент) КАК Контрагент,
			|	МАКСИМУМ(ВсеПартии.НаправлениеДеятельности) КАК НаправлениеДеятельности,
			|	МАКСИМУМ(ВсеПартии.ХозяйственнаяОперация) КАК ХозяйственнаяОперация,
			|	МАКСИМУМ(ВсеПартии.Подразделение) КАК Подразделение,
			|	МАКСИМУМ(ВсеПартии.Отправитель) КАК Отправитель,
			|	МАКСИМУМ(ВсеПартии.Партнер) = МИНИМУМ(ВсеПартии.Партнер) КАК ОдинПартнер,
			|	МАКСИМУМ(ВсеПартии.Договор) = МИНИМУМ(ВсеПартии.Договор) КАК ОдинДоговор,
			|	МАКСИМУМ(ВсеПартии.Контрагент) = МИНИМУМ(ВсеПартии.Контрагент) КАК ОдинКонтрагент,
			|	МАКСИМУМ(ВсеПартии.НаправлениеДеятельности) = МИНИМУМ(ВсеПартии.НаправлениеДеятельности) КАК ОдноНаправлениеДеятельности,
			|	МАКСИМУМ(ВсеПартии.ХозяйственнаяОперация) = МИНИМУМ(ВсеПартии.ХозяйственнаяОперация) КАК ОднаХозяйственнаяОперация,
			|	МАКСИМУМ(ВсеПартии.Отправитель) = МИНИМУМ(ВсеПартии.Отправитель) КАК ОдинОтправитель,
			|	МАКСИМУМ(ВсеПартии.Подразделение) = МИНИМУМ(ВсеПартии.Подразделение) КАК ОдноПодразделение
			|ИЗ
			|	Справочник.КонтролируемыеПартии КАК ВсеПартии
			|ГДЕ
			|	ВсеПартии.Ссылка В(&Ссылки)";
			
		РеквизитыДокумента = Новый Структура(ИменаРеквизитовДокумента);
		ЗаполнитьЗначенияСвойств(РеквизитыДокумента, ОбъектИлиСсылка);
			
	КонецЕсли;
	
	Реквизиты = КонтрольКачества.НовыйРеквизитыКонтролируемойПартии();
	Реквизиты.Партия = Ссылка;
	Реквизиты.ПричинаБлокировкиТовара = РеквизитыДокумента.ПричинаБлокировкиТовара;
	Реквизиты.ПланироватьРазблокировкуТовара = РеквизитыДокумента.ПланироватьРазблокировкуТоваров;
	Реквизиты.НомерДокументаПоступления = РеквизитыДокумента.Номер;
	Реквизиты.ДатаДокументаПоступления = РеквизитыДокумента.Дата;
	Реквизиты.ДатаПодтвержденияКачества = РеквизитыДокумента.ДатаПодтвержденияКачества;
	Реквизиты.Организация = РеквизитыДокумента.Организация;
	
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() И Выборка.ОдинПартнер <> Null Тогда
		Если Выборка.ОдинПартнер Тогда
			Реквизиты.Партнер = Выборка.Партнер;
		КонецЕсли;
		Если Выборка.ОдинДоговор Тогда
			Реквизиты.Договор = Выборка.Договор;
		КонецЕсли;
		Если Выборка.ОдинКонтрагент Тогда
			Реквизиты.Контрагент = Выборка.Контрагент;
		КонецЕсли;
		Если Выборка.ОдноНаправлениеДеятельности Тогда
			Реквизиты.НаправлениеДеятельности = Выборка.НаправлениеДеятельности;
		КонецЕсли;
		Если Выборка.ОднаХозяйственнаяОперация Тогда
			Реквизиты.ХозяйственнаяОперация = Выборка.ХозяйственнаяОперация;
		КонецЕсли;
		Если Выборка.ОдинОтправитель Тогда
			Реквизиты.Отправитель = Выборка.Отправитель;
		КонецЕсли;
		Если Выборка.ОдноПодразделение Тогда
			Реквизиты.Подразделение = Выборка.Подразделение;
		КонецЕсли;
	КонецЕсли;
	
	Возврат Реквизиты;
	
КонецФункции

#КонецОбласти

#КонецОбласти

#Область ОбработчикиСобытий

Процедура ОбработкаПолученияФормы(ВидФормы, Параметры, ВыбраннаяФорма, ДополнительнаяИнформация, СтандартнаяОбработка)
	
	Если ВидФормы = "ФормаСписка" Тогда
		СтандартнаяОбработка = Ложь;
		ИсследованиеТоваровВключены = ИсследованияТоваровВключены();
		Если ИсследованиеТоваровВключены Тогда
			ВыбраннаяФорма = "ВыполнениеЗаявокНаИсследования";
		Иначе
			ВыбраннаяФорма = "ФормаСписка";
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

