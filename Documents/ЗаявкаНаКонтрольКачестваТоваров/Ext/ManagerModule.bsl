Функция ТекстЗапросаДанныеДокументаТаблицаТоварыСводно(Запрос, ТекстыЗапроса, ПакетныйРежим = Ложь)
	
	ИмяТаблицы = "ДанныеДокументаТаблицаТоварыСводно";
	
	ТекстЗапроса =
		"ВЫБРАТЬ
		|	ТаблицаТовары.Ссылка КАК Ссылка,
		|	ВЫБОР
		|		КОГДА КОЛИЧЕСТВО(РАЗЛИЧНЫЕ
		|				ЕСТЬNULL(
		|					ВЫРАЗИТЬ(ТаблицаТовары.КонтролируемаяПартия КАК Справочник.КонтролируемыеПартии).НаправлениеДеятельности,
		|					ЗНАЧЕНИЕ(Справочник.НаправленияДеятельности.ПустаяСсылка))) = 1
		|			ТОГДА
		|				МАКСИМУМ(ЕСТЬNULL(ВЫРАЗИТЬ(ТаблицаТовары.КонтролируемаяПартия КАК Справочник.КонтролируемыеПартии).НаправлениеДеятельности,
		|					ЗНАЧЕНИЕ(Справочник.НаправленияДеятельности.ПустаяСсылка)))
		|		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.НаправленияДеятельности.ПустаяСсылка)
		|	КОНЕЦ КАК НаправлениеДеятельности,
		|	ВЫБОР
		|		КОГДА КОЛИЧЕСТВО(РАЗЛИЧНЫЕ
		|				ЕСТЬNULL(ВЫРАЗИТЬ(ТаблицаТовары.КонтролируемаяПартия КАК Справочник.КонтролируемыеПартии).Партнер,
		|					ЗНАЧЕНИЕ(Справочник.Партнеры.ПустаяСсылка))) = 1
		|			ТОГДА
		|				МАКСИМУМ(ЕСТЬNULL(ВЫРАЗИТЬ(ТаблицаТовары.КонтролируемаяПартия КАК Справочник.КонтролируемыеПартии).Партнер,
		|					ЗНАЧЕНИЕ(Справочник.Партнеры.ПустаяСсылка)))
		|		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.Партнеры.ПустаяСсылка)
		|	КОНЕЦ КАК Партнер,
		|	ВЫБОР
		|		КОГДА КОЛИЧЕСТВО(РАЗЛИЧНЫЕ
		|				ЕСТЬNULL(ВЫРАЗИТЬ(ТаблицаТовары.КонтролируемаяПартия КАК Справочник.КонтролируемыеПартии).Договор,
		|					ЗНАЧЕНИЕ(Справочник.ДоговорыКонтрагентов.ПустаяСсылка))) = 1
		|			ТОГДА
		|				МАКСИМУМ(ЕСТЬNULL(ВЫРАЗИТЬ(ТаблицаТовары.КонтролируемаяПартия КАК Справочник.КонтролируемыеПартии).Договор,
		|					ЗНАЧЕНИЕ(Справочник.ДоговорыКонтрагентов.ПустаяСсылка)))
		|		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.ДоговорыКонтрагентов.ПустаяСсылка)
		|	КОНЕЦ КАК Договор,
		|	ВЫБОР
		|		КОГДА КОЛИЧЕСТВО(РАЗЛИЧНЫЕ
		|				ЕСТЬNULL(ВЫРАЗИТЬ(ТаблицаТовары.КонтролируемаяПартия КАК Справочник.КонтролируемыеПартии).Контрагент,
		|					ЗНАЧЕНИЕ(Справочник.Контрагенты.ПустаяСсылка))) = 1
		|			ТОГДА
		|				МАКСИМУМ(ЕСТЬNULL(ВЫРАЗИТЬ(ТаблицаТовары.КонтролируемаяПартия КАК Справочник.КонтролируемыеПартии).Контрагент,
		|					ЗНАЧЕНИЕ(Справочник.Контрагенты.ПустаяСсылка)))
		|		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.Контрагенты.ПустаяСсылка)
		|	КОНЕЦ КАК Контрагент
		|ПОМЕСТИТЬ ДанныеДокументаТаблицаТоварыСводно
		|ИЗ
		|	ДанныеДокументаТаблицаТовары КАК ТаблицаТовары
		|СГРУППИРОВАТЬ ПО
		|	ТаблицаТовары.Ссылка
		|ИНДЕКСИРОВАТЬ ПО
		|	Ссылка";
	
	Если ПакетныйРежим Тогда
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса,
			"ПОМЕСТИТЬ ДанныеДокументаТаблицаТоварыСводно",
			"");
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса,
			"ИНДЕКСИРОВАТЬ ПО
			|	Ссылка",
			"");
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса,
			"ДанныеДокументаТаблицаТовары",
			"Документ.ЗаявкаНаКонтрольКачестваТоваров.Товары");
		Возврат ТекстЗапроса;
	КонецЕсли;
	
	ТекстыЗапроса.Добавить(ТекстЗапроса, ИмяТаблицы);
	
	Возврат ТекстЗапроса;
	
КонецФункции

