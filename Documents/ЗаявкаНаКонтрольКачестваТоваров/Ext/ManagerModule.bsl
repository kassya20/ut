Функция ТекстЗапросаТаблицаРеестрДокументов(Запрос, ТекстыЗапроса, Регистры, ПакетныйРежим = Ложь)
	
	ИмяРегистра = "РеестрДокументов";
	
	Если НЕ ПроведениеДокументов.ТребуетсяТаблицаДляДвижений(ИмяРегистра, Регистры) Тогда
		Возврат "";
	КонецЕсли;
	
	ТекстЗапроса =
		"ВЫБРАТЬ
		|	ДанныеДокумента.Ссылка КАК Ссылка,
		|	ДанныеДокумента.Дата КАК ДатаДокументаИБ,
		|	ДанныеДокумента.Номер КАК НомерДокументаИБ,
		|	&ИдентификаторМетаданных КАК ТипСсылки,
		|	ДанныеДокумента.Организация КАК Организация,
		|	ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.КонтрольКачестваТоваров) КАК ХозяйственнаяОперация,
		|	ТаблицаТоварыСводно.Партнер КАК Партнер,
		|	ТаблицаТоварыСводно.Контрагент КАК Контрагент,
		|	ТаблицаТоварыСводно.Договор КАК Договор,
		|	ТаблицаТоварыСводно.НаправлениеДеятельности КАК НаправлениеДеятельности,
		|	ДанныеДокумента.Склад КАК МестоХранения,
		|	ДанныеДокумента.Подразделение КАК Подразделение,
		|	ДанныеДокумента.Ответственный КАК Ответственный,
		|	ДанныеДокумента.Автор КАК Автор,
		|	ДанныеДокумента.Комментарий КАК Комментарий,
		|	ЗНАЧЕНИЕ(Справочник.Валюты.ПустаяСсылка) КАК Валюта,
		|	0 КАК Сумма,
		|	НЕОПРЕДЕЛЕНО КАК Статус,
		|	ДанныеДокумента.Проведен КАК Проведен,
		|	ДанныеДокумента.ПометкаУдаления КАК ПометкаУдаления,
		|	ЛОЖЬ КАК ДополнительнаяЗапись,
		|	"""" КАК Дополнительно,
		|	ДанныеДокумента.Дата КАК ДатаПервичногоДокумента,
		|	"""" КАК НаименованиеПервичногоДокумента,
		|	&НомерНаПечать КАК НомерПервичногоДокумента,
		|	ДанныеДокумента.Дата КАК ДатаОтраженияВУчете,
		|	НЕОПРЕДЕЛЕНО КАК Приоритет
		|ИЗ
		|	ДанныеДокументаШапка КАК ДанныеДокумента
		|		
		|		ЛЕВОЕ СОЕДИНЕНИЕ ДанныеДокументаТаблицаТоварыСводно КАК ТаблицаТоварыСводно
		|		ПО ТаблицаТоварыСводно.Ссылка = ДанныеДокумента.Ссылка";
	
	Если ПакетныйРежим Тогда
		
		ТекстСводно = ТекстЗапросаДанныеДокументаТаблицаТоварыСводно(Неопределено, Неопределено, Истина);
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&НомерНаПечать", "ДанныеДокумента.Номер");
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "ДанныеДокумента.Комментарий", "ВЫРАЗИТЬ(ДанныеДокумента.Комментарий КАК Строка (100))");
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "ДанныеДокументаШапка", "Документ.ЗаявкаНаКонтрольКачестваТоваров");
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "ДанныеДокументаТаблицаТоварыСводно", СтрШаблон("(%1)", ТекстСводно));
		Возврат ТекстЗапроса;
		
	КонецЕсли;
	
	Если Не ПроведениеДокументов.ЕстьТаблицаЗапроса("ДанныеДокументаТаблицаТоварыСводно", ТекстыЗапроса) Тогда
		ТекстЗапросаДанныеДокументаТаблицаТоварыСводно(Запрос, ТекстыЗапроса);
	КонецЕсли;
	
	ТекстыЗапроса.Добавить(ТекстЗапроса, ИмяРегистра);
	
	Возврат ТекстЗапроса;
	
КонецФункции

Функция ТекстЗапросаТаблицаДвиженияСерийТоваров(Запрос, ТекстыЗапроса, Регистры)
	
	ИмяРегистра = "ДвиженияСерийТоваров";
	
	Если Не ПроведениеДокументов.ТребуетсяТаблицаДляДвижений(ИмяРегистра, Регистры) Тогда
		Возврат "";
	КонецЕсли;
	
	ТекстЗапроса =
		"ВЫБРАТЬ
		|	Товары.Номенклатура КАК Номенклатура,
		|	Товары.Характеристика КАК Характеристика,
		|	Товары.Назначение КАК Назначение,
		|	Товары.Серия КАК Серия,
		|	Товары.Количество КАК Количество,
		|	Товары.Склад КАК Отправитель,
		|	Товары.Помещение КАК ПомещениеОтправителя,
		|	ЗНАЧЕНИЕ(Перечисление.СкладскиеОперации.ОтражениеНедостач) КАК СкладскаяОперация,
		|	Товары.Ссылка КАК Документ,
		|	Реквизиты.Дата КАК Период
		|ИЗ
		|	ДанныеДокументаТаблицаТовары КАК Товары
		|		
		|		ЛЕВОЕ СОЕДИНЕНИЕ ДанныеДокументаШапка КАК Реквизиты
		|		ПО Реквизиты.Ссылка = Товары.Ссылка
		|ГДЕ
		|	Товары.Серия <> ЗНАЧЕНИЕ(Справочник.СерииНоменклатуры.ПустаяСсылка)";
		
	ТекстыЗапроса.Добавить(ТекстЗапроса, ИмяРегистра);
	
	Возврат ТекстЗапроса;
	
КонецФункции

Процедура ОтразитьРаспределениеЗапасовДвижения(Запрос, ТекстыЗапроса, Регистры)
	
	Если Не ПроведениеДокументов.ЕстьТаблицаЗапроса("ДанныеДокументаТаблицаТоварыСвернутьТоварныеМеста", ТекстыЗапроса) Тогда
		ТекстЗапросаДанныеДокументаТаблицаТоварыСвернутьТоварныеМеста(Запрос, ТекстыЗапроса);
	КонецЕсли;
	
	ТекстЗапросаТабЧасть =
		"ВЫБРАТЬ
		|	Товары.Ссылка КАК Ссылка,
		|	Реквизиты.Дата КАК Период,
		|	Товары.Номенклатура КАК Номенклатура,
		|	Товары.Характеристика КАК Характеристика,
		|	Товары.Склад КАК Склад,
		|	Товары.Назначение КАК Назначение,
		|	Товары.КонтролируемаяПартия КАК КонтролируемаяПартия,
		|	Товары.Количество КАК Количество,
		|	НЕОПРЕДЕЛЕНО КАК ЗапланированныйРасходРаспределенногоЗапаса,
		|	ИСТИНА КАК КонтрольСвободногоОстатка
		|ИЗ
		|	ДанныеДокументаТаблицаТоварыСвернутьТоварныеМеста КАК Товары
		|		
		|		ЛЕВОЕ СОЕДИНЕНИЕ ДанныеДокументаШапка КАК Реквизиты
		|		ПО Реквизиты.Ссылка = Товары.Ссылка";
		
	РаспределениеЗапасовДвижения.РасходЗапаса(Запрос, ТекстыЗапроса, Регистры, ТекстЗапросаТабЧасть, Истина);
	
	ТекстЗапросаТабЧасть =
		"ВЫБРАТЬ
		|	Товары.Ссылка КАК Ссылка,
		|	Реквизиты.Дата КАК Период,
		|	Товары.Номенклатура КАК Номенклатура,
		|	Товары.Характеристика КАК Характеристика,
		|	Товары.Склад КАК Склад,
		|	Товары.Назначение КАК Назначение,
		|	ВЫБОР
		|		КОГДА Товары.КачествоПодтверждено
		|			ТОГДА ЗНАЧЕНИЕ(Справочник.КонтролируемыеПартии.ПустаяСсылка)
		|		ИНАЧЕ Реквизиты.КонтролируемаяПартия
		|	КОНЕЦ КАК КонтролируемаяПартия,
		|	НЕ Товары.КачествоПодтверждено КАК ПроконтролироватьКачество,
		|	Реквизиты.ПланироватьРазблокировкуТоваров КАК ПодлежитРазблокировке,
		|	Реквизиты.ДатаПодтвержденияКачества КАК ДатаПодтвержденияКачества,
		|	Товары.Количество КАК Количество,
		|	ЛОЖЬ КАК ПоГрафику,
		|	НЕОПРЕДЕЛЕНО КАК РаспоряжениеВГрафике
		|ИЗ
		|	ДанныеДокументаТаблицаТоварыСвернутьТоварныеМеста КАК Товары
		|		
		|		ЛЕВОЕ СОЕДИНЕНИЕ ДанныеДокументаШапка КАК Реквизиты
		|		ПО Реквизиты.Ссылка = Товары.Ссылка";
	
	РаспределениеЗапасовДвижения.ПриходЗапаса(Запрос, ТекстыЗапроса, Регистры, ТекстЗапросаТабЧасть, Ложь, Истина);
	
КонецПроцедуры

Процедура ОтразитьПоПодсистемеСклад(Запрос, ТекстыЗапроса, Регистры)
	
	ИмяРегистра = "ТоварыНаСкладах";
	Если ПроведениеДокументов.ТребуетсяТаблицаДляДвижений(ИмяРегистра, Регистры) Тогда
		
		ТекстЗапросаДокумента =
			"ВЫБРАТЬ
			|	Товары.Ссылка КАК Ссылка,
			|	Шапка.Дата КАК Период,
			|	НЕОПРЕДЕЛЕНО КАК Заказ,
			|	НЕОПРЕДЕЛЕНО КАК ЗаданиеНаПеревозку,
			|	НЕОПРЕДЕЛЕНО КАК Получатель,
			|	Товары.Склад КАК Склад,
			|	Товары.Ячейка КАК Ячейка,
			|	Товары.Помещение КАК Помещение,
			|	Товары.Номенклатура КАК Номенклатура,
			|	Товары.Характеристика КАК Характеристика,
			|	Товары.Назначение КАК Назначение,
			|	Товары.КонтролируемаяПартия КАК КонтролируемаяПартия,
			|	Товары.Упаковка КАК Упаковка,
			|	Товары.Серия КАК Серия,
			|	Товары.СтатусУказанияСерий КАК СтатусУказанияСерий,
			|	Товары.Количество КАК Количество,
			|	Товары.КоличествоУпаковок КАК КоличествоУпаковок,
			|	ЗНАЧЕНИЕ(Перечисление.ДействияСоСтрокамиОрдеровНаОтгрузку.Отгрузить) КАК Действие,
			|	ЛОЖЬ КАК КСборке,
			|	ЛОЖЬ КАК Собирается,
			|	ЛОЖЬ КАК Собрано,
			|	ИСТИНА КАК КОтгрузке
			|ИЗ
			|	ДанныеДокументаШапка КАК Шапка
			|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ДанныеДокументаТаблицаТовары КАК Товары
			|		ПО Шапка.Ссылка = Товары.Ссылка";
			
		СкладыСервер.ОтгрузитьТоварСоСклада(Запрос, ТекстыЗапроса, ИмяРегистра, ТекстЗапросаДокумента, Истина);
		
	КонецЕсли;
	
	ИмяРегистра = "ТоварыВЯчейках";
	Если ПроведениеДокументов.ТребуетсяТаблицаДляДвижений(ИмяРегистра, Регистры) Тогда
		
		ТекстЗапросаДокумента =
			"ВЫБРАТЬ
			|	Товары.Ссылка КАК Ссылка,
			|	Шапка.Дата КАК Дата,
			|	Товары.Склад КАК Склад,
			|	Товары.Ячейка КАК Ячейка,
			|	Товары.Помещение КАК Помещение,
			|	Товары.Номенклатура КАК Номенклатура,
			|	Товары.Характеристика КАК Характеристика,
			|	Товары.Назначение КАК Назначение,
			|	Товары.КонтролируемаяПартия КАК КонтролируемаяПартия,
			|	Товары.Упаковка КАК Упаковка,
			|	Товары.Серия КАК Серия,
			|	Товары.СтатусУказанияСерий КАК СтатусУказанияСерий,
			|	-Товары.Количество КАК Количество,
			|	-Товары.КоличествоУпаковок КАК КоличествоУпаковок,
			|	ИСТИНА КАК ИзменяетсяОстаток
			|ИЗ
			|	ДанныеДокументаШапка КАК Шапка
			|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ДанныеДокументаТаблицаТовары КАК Товары
			|		ПО Шапка.Ссылка = Товары.Ссылка";
		СкладыСервер.ЗарегистрироватьИзлишкиНедостачиНаСкладе(Запрос, ТекстыЗапроса, ИмяРегистра, ТекстЗапросаДокумента);
		
	КонецЕсли;
	
	// Оприходование товаров с новой партией.
	ТекстЗапросаДокумента =
		"ВЫБРАТЬ
		|	Товары.Ссылка КАК Ссылка,
		|	Шапка.Дата КАК Дата,
		|	Товары.Склад КАК Склад,
		|	Товары.Ячейка КАК Ячейка,
		|	Товары.Помещение КАК Помещение,
		|	НЕОПРЕДЕЛЕНО КАК Отправитель,
		|	НЕОПРЕДЕЛЕНО КАК Распоряжение,
		|	НЕОПРЕДЕЛЕНО КАК ХозяйственнаяОперация,
		|	Товары.Номенклатура КАК Номенклатура,
		|	Товары.Характеристика КАК Характеристика,
		|	Товары.Назначение КАК Назначение,
		|	Товары.Упаковка КАК Упаковка,
		|	ЛОЖЬ КАК ЭтоУпаковочныйЛист,
		|	Товары.Серия КАК Серия,
		|	ИСТИНА КАК ПроконтролироватьКачество,
		// не важно, так как нет движений по Товары к поступлению.
		|	ЛОЖЬ КАК ДвижениеРанееПоступившейПартии,
		|	ВЫБОР
		|		КОГДА Товары.КачествоПодтверждено
		|			ТОГДА ЗНАЧЕНИЕ(Справочник.КонтролируемыеПартии.ПустаяСсылка)
		|		ИНАЧЕ Шапка.КонтролируемаяПартия
		|	КОНЕЦ КАК КонтролируемаяПартия,
		|	Товары.СтатусУказанияСерий КАК СтатусУказанияСерий,
		|	Товары.Количество КАК Количество,
		|	Товары.КоличествоУпаковок КАК КоличествоУпаковок,
		|	ЛОЖЬ КАК Принимается,
		|	ИСТИНА КАК Принят,
		|	ИСТИНА КАК ЭтоПриемкаБезРаспоряжения
		|ИЗ
		|	ДанныеДокументаШапка КАК Шапка
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ДанныеДокументаТаблицаТовары КАК Товары
		|		ПО Шапка.Ссылка = Товары.Ссылка";
		
	СкладыСервер.ПринятьТоварНаСклад(Запрос, ТекстыЗапроса, Регистры, ТекстЗапросаДокумента, "Товары");
	
КонецПроцедуры


Функция АдаптированныйТекстЗапросаДвиженийПоРегистру(ИмяРегистра) Экспорт
	
	ПолноеИмяДокумента = "Документ.ЗаявкаНаКонтрольКачестваТоваров";
	ЗначенияПараметров = Новый Структура();
	ЗначенияПараметров.Вставить("ИдентификаторМетаданных",
		ОбщегоНазначения.ИдентификаторОбъектаМетаданных(ПолноеИмяДокумента));
	
	Если ИмяРегистра <> "РеестрДокументов" Тогда
		ТекстИсключения = НСтр("ru = 'В документе %ПолноеИмяДокумента% не реализована адаптация текста запроса формирования движений по регистру %ИмяРегистра%.'");
		ТекстИсключения = СтрЗаменить(ТекстИсключения, "%ПолноеИмяДокумента%", ПолноеИмяДокумента);
		ТекстИсключения = СтрЗаменить(ТекстИсключения, "%ИмяРегистра%", ИмяРегистра);
		
		ВызватьИсключение ТекстИсключения;
	КонецЕсли;
	
	Если ИмяРегистра = "РеестрДокументов" Тогда
		
		ТекстЗапроса = ТекстЗапросаТаблицаРеестрДокументов(Неопределено, Неопределено, "РеестрДокументов", Истина);
		
	КонецЕсли;
	
	Результат = ОбновлениеИнформационнойБазыУТ.РезультатАдаптацииЗапроса();
	Результат.ЗначенияПараметров = ЗначенияПараметров;
	Результат.ТекстЗапроса = ТекстЗапроса;
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти

Функция ИсследованияТоваровВключены()
	
	ИспользоватьИсследования = Ложь;
	Возврат ИспользоватьИсследования;
	
КонецФункции

Функция СформироватьПечатнуюФормуЗаявкаНаКонтрольКачестваТоваров(МассивОбъектов, ОбъектыПечати, ПараметрыПечати)
	
	УстановитьПривилегированныйРежим(Истина);
	
	МетаданныеДокумента = Документы.ЗаявкаНаКонтрольКачестваТоваров.ПустаяСсылка().Метаданные();
	Если Не ЗначениеЗаполнено(МетаданныеДокумента.ПредставлениеОбъекта) Тогда
		СинонимДокумента = МетаданныеДокумента.Синоним;
	Иначе
		СинонимДокумента = МетаданныеДокумента.ПредставлениеОбъекта;
	КонецЕсли;
	
	ТабличныйДокумент = Новый ТабличныйДокумент;
	ТабличныйДокумент.ИмяПараметровПечати = "ПАРАМЕТРЫ_ПЕЧАТИ_ЗаявкаНаКонтрольКачестваТоваров_ПечатнаяФормаДокумента";
	
	КолонкаКодов = ФормированиеПечатныхФорм.ДополнительнаяКолонкаПечатныхФормДокументов();
	ИмяКолонкиКодов = КолонкаКодов.ИмяКолонки;
	ПредставлениеКолонкиКодов = КолонкаКодов.ПредставлениеКолонки;
	ВыводитьКоды = ЗначениеЗаполнено(ИмяКолонкиКодов);
	ВыводитьСерии = ПолучитьФункциональнуюОпцию("ИспользоватьСерииНоменклатуры");
	
	Запрос = Новый Запрос();
	Текст =
		"ВЫБРАТЬ
		|	Товары.Ссылка КАК Ссылка,
		|	ВЫБОР
		|		КОГДА МИНИМУМ(Товары.Склад) = МАКСИМУМ(Товары.Склад)
		|			ТОГДА МИНИМУМ(Товары.Склад)
		|		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.Склады.ПустаяСсылка)
		|	КОНЕЦ КАК Склад,
		|	ВЫБОР
		|		КОГДА МИНИМУМ(Товары.Помещение) = МАКСИМУМ(Товары.Помещение)
		|			ТОГДА МИНИМУМ(Товары.Помещение)
		|		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.СкладскиеПомещения.ПустаяСсылка)
		|	КОНЕЦ КАК Помещение,
		|	ВЫБОР
		|		КОГДА МИНИМУМ(Товары.КонтролируемаяПартия.Партия) = МАКСИМУМ(Товары.КонтролируемаяПартия.Партия)
		|			ТОГДА МИНИМУМ(Товары.КонтролируемаяПартия.Партия) 
		|		ИНАЧЕ НЕОПРЕДЕЛЕНО
		|	КОНЕЦ КАК Партия
		|ПОМЕСТИТЬ ТоварыСводно
		|ИЗ
		|	Документ.ЗаявкаНаКонтрольКачестваТоваров.Товары КАК Товары
		|ГДЕ
		|	Товары.Ссылка В(&МассивОбъектов)
		|СГРУППИРОВАТЬ ПО
		|	Товары.Ссылка
		|ИНДЕКСИРОВАТЬ ПО
		|	Ссылка
		|;
		|
		|/////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Шапка.Ссылка КАК Ссылка,
		|	Шапка.Дата КАК Дата,
		|	Шапка.Номер КАК Номер,
		|	ПРЕДСТАВЛЕНИЕ(Шапка.Организация) КАК ОрганизацияПредставление,
		|	Шапка.Ответственный.ФизическоеЛицо КАК Ответственный,
		|	ТоварыСводно.Склад КАК Склад,
		|	ТоварыСводно.Помещение КАК Помещение,
		|	ТоварыСводно.Партия КАК Партия,
		|	ПРЕДСТАВЛЕНИЕ(ТоварыСводно.Склад) КАК СкладПредставление,
		|	ПРЕДСТАВЛЕНИЕ(ТоварыСводно.Помещение) КАК ПомещениеПредставление,
		|	ПРЕДСТАВЛЕНИЕ(ТоварыСводно.Партия) КАК ПартияПредставление
		|ИЗ
		|	Документ.ЗаявкаНаКонтрольКачестваТоваров КАК Шапка
		|		
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ТоварыСводно КАК ТоварыСводно
		|		ПО ТоварыСводно.Ссылка = Шапка.Ссылка
		|ГДЕ
		|	Шапка.Ссылка В(&МассивОбъектов)
		|УПОРЯДОЧИТЬ ПО
		|	Ссылка
		|;
		|
		|/////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Товары.Ссылка КАК Ссылка,
		|	МИНИМУМ(Товары.НомерСтроки) КАК НомерСтроки,
		|	Товары.Номенклатура КАК Номенклатура,
		|	Товары.Характеристика КАК Характеристика,
		|	Товары.Серия КАК Серия,
		|	Товары.КачествоПодтверждено КАК КачествоПодтверждено,
		|	Товары.Упаковка КАК Упаковка,
		|	СУММА(Товары.КоличествоУпаковок) КАК КоличествоУпаковок
		|ПОМЕСТИТЬ ТоварыСгруппированные
		|ИЗ
		|	Документ.ЗаявкаНаКонтрольКачестваТоваров.Товары КАК Товары
		|ГДЕ
		|	Товары.Ссылка В(&МассивОбъектов)
		|СГРУППИРОВАТЬ ПО
		|	Товары.Ссылка,
		|	Товары.Номенклатура,
		|	Товары.Характеристика,
		|	Товары.Серия,
		|	Товары.Упаковка,
		|	Товары.КачествоПодтверждено
		|ИНДЕКСИРОВАТЬ ПО
		|	Номенклатура
		|;
		|
		|//////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Товары.Ссылка КАК Ссылка,
		|	Товары.НомерСтроки КАК НомерСтроки,
		|	Товары.КоличествоУпаковок КАК КоличествоУпаковок,
		|	&ВыводитьКоды КАК Артикул,
		|	Товары.Номенклатура.НаименованиеПолное КАК ПредставлениеНоменклатуры,
		|	Товары.Характеристика.НаименованиеПолное КАК ПредставлениеХарактеристики,
		|	Товары.Серия.Наименование КАК ПредставлениеСерии,
		|	ПРЕДСТАВЛЕНИЕ(Товары.Номенклатура.ЕдиницаИзмерения) КАК ПредставлениеБазовойЕдиницыИзмерения,
		|	ВЫБОР
		|		КОГДА Товары.Упаковка = ЗНАЧЕНИЕ(Справочник.УпаковкиЕдиницыИзмерения.ПустаяСсылка)
		|			ТОГДА ПРЕДСТАВЛЕНИЕССЫЛКИ(Товары.Номенклатура.ЕдиницаИзмерения)
		|		ИНАЧЕ ПРЕДСТАВЛЕНИЕССЫЛКИ(Товары.Упаковка)
		|	КОНЕЦ КАК ПредставлениеЕдиницыИзмеренияУпаковки,
		|	Товары.КачествоПодтверждено КАК КачествоПодтверждено
		|ИЗ
		|	ТоварыСгруппированные КАК Товары
		|ГДЕ
		|	Товары.Ссылка В(&МассивОбъектов)
		|УПОРЯДОЧИТЬ ПО
		|	Ссылка, НомерСтроки
		|ИТОГИ ПО
		|	Ссылка";
	
	ПодстановкаВыводитьКоды = ?(ВыводитьКоды, "Товары.Номенклатура." + ИмяКолонкиКодов, """""");
	Текст = СтрЗаменить(Текст, "&ВыводитьКоды", ПодстановкаВыводитьКоды);
	Запрос.Текст = Текст;
	Запрос.УстановитьПараметр("МассивОбъектов", МассивОбъектов);
	
	Результаты = Запрос.ВыполнитьПакет(); 
	
	ВыборкаПоДокументам = Результаты[1].Выбрать();
	ВыборкаПоТабличнымЧастям = Результаты[3].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	ПервыйДокумент = Истина;
	
	РеквизитыДокумента = Новый Структура("Номер,Дата,Префикс");
	
	ДопПараметрыПредставлениеНоменклатуры = НоменклатураКлиентСервер.ДополнительныеПараметрыПредставлениеНоменклатурыДляПечати();
	ДопПараметрыПредставлениеНоменклатуры.КодОсновногоЯзыка = ОбщегоНазначения.КодОсновногоЯзыка();
	Пока ВыборкаПоДокументам.Следующий() Цикл
		
		Если Не ВыборкаПоТабличнымЧастям.НайтиСледующий(Новый Структура("Ссылка", ВыборкаПоДокументам.Ссылка)) Тогда
			Продолжить;
		КонецЕсли;
		
		ЕстьСклад = ЗначениеЗаполнено(ВыборкаПоДокументам.Склад);
		ЕстьПартия = ЗначениеЗаполнено(ВыборкаПоДокументам.Партия);
		
		// Макет получаем в цикле,т.к. ширина колонок зависит от склада и помещения в документе.
		Макет = УправлениеПечатью.МакетПечатнойФормы("Документ.ЗаявкаНаКонтрольКачестваТоваров.ПФ_MXL_ЗаявкаНаКонтрольКачестваТоваров");
		
		ОбластьЗаголовок = Макет.ПолучитьОбласть("Заголовок");
		ОбластьПодписей = Макет.ПолучитьОбласть("Подписи");
		
		Если ЕстьСклад И ЕстьПартия Тогда
			ИмяОбластиШапка = "ШапкаИСкладИПартия";
		ИначеЕсли ЕстьСклад И Не ЕстьПартия Тогда
			ИмяОбластиШапка = "ШапкаИСклад";
		ИначеЕсли ЕстьПартия Тогда
			ИмяОбластиШапка = "ШапкаБезСкладаИПартия";
		Иначе
			ИмяОбластиШапка = "ШапкаБезСклада";
		КонецЕсли;
		ОбластьШапка = Макет.ПолучитьОбласть(ИмяОбластиШапка);
		
		ОбластьТаблицы = Новый Массив();
		
		Шапка = Макет.ПолучитьОбласть("ШапкаТаблицы|НачалоСтроки");
		Строка = Макет.ПолучитьОбласть("СтрокаТаблицы|НачалоСтроки");
		Подвал = Макет.ПолучитьОбласть("ПодвалТаблицы|НачалоСтроки");
		
		ОбластьТаблицы.Добавить(Новый Структура("Шапка,Строка,Подвал", Шапка, Строка, Подвал));
		
		СкрытаяШирина = 0;
		
		Если ВыводитьКоды Тогда
			
			Шапка = Макет.ПолучитьОбласть("ШапкаТаблицы|КолонкаКодов");
			Строка = Макет.ПолучитьОбласть("СтрокаТаблицы|КолонкаКодов");
			Подвал = Макет.ПолучитьОбласть("ПодвалТаблицы|КолонкаКодов");
			
			ОбластьТаблицы.Добавить(Новый Структура("Шапка,Строка,Подвал", Шапка, Строка, Подвал));
			Шапка.Параметры.ИмяКолонкиКодов = ПредставлениеКолонкиКодов; 
			
		Иначе
			СкрытаяШирина = Макет.Область("КолонкаКодов").ШиринаКолонки;
		КонецЕсли;
		
		Шапка = Макет.ПолучитьОбласть("ШапкаТаблицы|Товар");
		Строка = Макет.ПолучитьОбласть("СтрокаТаблицы|Товар");
		Подвал = Макет.ПолучитьОбласть("ПодвалТаблицы|Товар");
		
		ОбластьТаблицы.Добавить(Новый Структура("Шапка,Строка,Подвал", Шапка, Строка, Подвал));
		
		Шапка = Макет.ПолучитьОбласть("ШапкаТаблицы|Количество");
		Строка = Макет.ПолучитьОбласть("СтрокаТаблицы|Количество");
		Подвал = Макет.ПолучитьОбласть("ПодвалТаблицы|Количество");
		
		ОбластьТаблицы.Добавить(Новый Структура("Шапка,Строка,Подвал", Шапка, Строка, Подвал));
		
		Макет.Область("Товар").ШиринаКолонки = Макет.Область("Товар").ШиринаКолонки + СкрытаяШирина;
		СкрытаяШирина = 0;
		
		Шапка = Макет.ПолучитьОбласть("ШапкаТаблицы|КачествоПодтверждено");
		Строка = Макет.ПолучитьОбласть("СтрокаТаблицы|КачествоПодтверждено");
		Подвал = Макет.ПолучитьОбласть("ПодвалТаблицы|КачествоПодтверждено");
		
		ОбластьТаблицы.Добавить(Новый Структура("Шапка,Строка,Подвал", Шапка, Строка, Подвал));
		
		ВсегоОбластейТаблицы = ОбластьТаблицы.Количество() - 1;
		
		ВыборкаПоСтрокамТЧ = ВыборкаПоТабличнымЧастям.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		
		Если Не ПервыйДокумент Тогда
			ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();
		КонецЕсли;
		
		ПервыйДокумент = Ложь;
		НомерСтрокиНачало = ТабличныйДокумент.ВысотаТаблицы + 1;
		
		ЗаполнитьЗначенияСвойств(РеквизитыДокумента,ВыборкаПоДокументам);
		
		ТекстЗаголовка = ОбщегоНазначенияУТКлиентСервер.СформироватьЗаголовокДокумента(РеквизитыДокумента, СинонимДокумента);
		СтруктураДанныхЗаголовка = Новый Структура();
		СтруктураДанныхЗаголовка.Вставить("ТекстЗаголовка", ТекстЗаголовка);
		
		ОбластьЗаголовок.Параметры.Заполнить(СтруктураДанныхЗаголовка);
		
		ШтрихкодированиеПечатныхФорм.ВывестиШтрихкодВТабличныйДокумент(
			ТабличныйДокумент, Макет, ОбластьЗаголовок, ВыборкаПоДокументам.Ссылка);
		ТабличныйДокумент.Вывести(ОбластьЗаголовок);
		
		ОбластьШапка.Параметры.Заполнить(ВыборкаПоДокументам);
		
		Если ЕстьСклад Тогда
			
			ОбластьШапка.Параметры.СкладПредставление = СкладыСервер.ПолучитьПредставлениеСклада(
				ВыборкаПоДокументам.СкладПредставление,
				ВыборкаПоДокументам.ПомещениеПредставление);
				
		КонецЕсли;
		
		ТабличныйДокумент.Вывести(ОбластьШапка);
		
		Для ИндексОбласти = 0 По ВсегоОбластейТаблицы Цикл
			ОписаниеОбласти = ОбластьТаблицы[ИндексОбласти]; // Структура
			ТекущаяОбласть = ОписаниеОбласти.Шапка; // ТабличныйДокумент
			Если ИндексОбласти = 0 Тогда
				ТабличныйДокумент.Вывести(ТекущаяОбласть);
			Иначе
				ТабличныйДокумент.Присоединить(ТекущаяОбласть);
			КонецЕсли;
		КонецЦикла;
		
		Пока ВыборкаПоСтрокамТЧ.Следующий() Цикл
			
			Товар = НоменклатураКлиентСервер.ПредставлениеНоменклатурыДляПечати(
				ВыборкаПоСтрокамТЧ.ПредставлениеНоменклатуры,
				ВыборкаПоСтрокамТЧ.ПредставлениеХарактеристики,
				, // Упаковка
				ВыборкаПоСтрокамТЧ.ПредставлениеСерии,
				ДопПараметрыПредставлениеНоменклатуры);
			СтруктураПараметров = Новый Структура("Товар", Товар);
			
			Для ИндексОбласти = 0 По ВсегоОбластейТаблицы Цикл
				ОписаниеОбласти = ОбластьТаблицы[ИндексОбласти]; // Структура
				ТекущаяОбласть = ОписаниеОбласти.Строка; // ТабличныйДокумент
				ТекущаяОбласть.Параметры.Заполнить(ВыборкаПоСтрокамТЧ);
				ТекущаяОбласть.Параметры.Заполнить(СтруктураПараметров);
				Если ИндексОбласти = 0 Тогда
					ТабличныйДокумент.Вывести(ТекущаяОбласть);
				Иначе
					ТабличныйДокумент.Присоединить(ТекущаяОбласть);
				КонецЕсли;
			КонецЦикла;
			
		КонецЦикла;
		
		Для ИндексОбласти = 0 По ВсегоОбластейТаблицы Цикл
			ОписаниеОбласти = ОбластьТаблицы[ИндексОбласти]; // Структура
			ТекущаяОбласть = ОписаниеОбласти.Подвал; // ТабличныйДокумент
			Если ИндексОбласти = 0 Тогда
				ТабличныйДокумент.Вывести(ТекущаяОбласть);
			Иначе
				ТабличныйДокумент.Присоединить(ТекущаяОбласть);
			КонецЕсли;
		КонецЦикла;
		
		ОбластьПодписей.Параметры.Ответственный = ФизическиеЛицаУТ.ФамилияИнициалыФизЛица(
			ВыборкаПоДокументам.Ответственный, ВыборкаПоДокументам.Дата);
		ТабличныйДокумент.Вывести(ОбластьПодписей);
		
		УправлениеПечатью.ЗадатьОбластьПечатиДокумента(
			ТабличныйДокумент, НомерСтрокиНачало, ОбъектыПечати, ВыборкаПоДокументам.Ссылка);
		
	КонецЦикла;
	
	ТабличныйДокумент.АвтоМасштаб = Истина;
	Возврат ТабличныйДокумент;
	
КонецФункции

#КонецОбласти

#КонецЕсли
