	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТаблицаТовары.ЗаказКлиента КАК ЗаказКлиента,
	|	ТаблицаТовары.КодСтроки КАК КодСтроки,
	|	ЕСТЬNULL(ВЫБОР
	|		КОГДА ТаблицаОстатков.Количество = 0
	|			ТОГДА 1
	|		ИНАЧЕ ТаблицаОстатков.Количество
	|	КОНЕЦ, 1) КАК Количество,
	|	ЕСТЬNULL(ВЫБОР
	|		КОГДА ТаблицаТовары.СуммаНДСРегл = 0
	|			ТОГДА ЕСТЬNULL(ТаблицаОстатков.СуммаНДСРегл, 0)
	|		ИНАЧЕ ТаблицаТовары.СуммаНДСРегл
	|	КОНЕЦ, 0) КАК СуммаНДСРегл,
	|	ЕСТЬNULL(ВЫБОР
	|		КОГДА ТаблицаТовары.СуммаНДСУпр = 0
	|			ТОГДА ЕСТЬNULL(ТаблицаОстатков.СуммаНДСУпр, 0)
	|		ИНАЧЕ ТаблицаТовары.СуммаНДСУпр
	|	КОНЕЦ, 0) КАК СуммаНДСУпр
	|ИЗ
	|	ТаблицаТовары КАК ТаблицаТовары
	|		ЛЕВОЕ СОЕДИНЕНИЕ ТаблицаОстатков КАК ТаблицаОстатков
	|		ПО ТаблицаТовары.ЗаказКлиента = ТаблицаОстатков.Распоряжение
	|		И ТаблицаТовары.КодСтроки = ТаблицаОстатков.КодСтроки";
	
	ПараметрыФормированияТаблицы = РегистрыНакопления.РаспоряженияНаОтгрузкуИВозврат.НовыйПараметрыФормированияРазвернутойТаблицы();
	ПараметрыФормированияТаблицы.ТекстУсловия =
		"(Распоряжение, КодСтроки) В
		|	(ВЫБРАТЬ
		|		ЗаказКлиента,
		|		КодСтроки
		|	ИЗ
		|		ТаблицаТовары)";
	ПараметрыФормированияТаблицы.Группировка = "Распоряжение, КодСтроки";
	ПараметрыФормированияТаблицы.Показатели = "Оформлено, ОформленоСчетовФактур";
	ПараметрыФормированияТаблицы.Ресурсы = "Количество, СуммаНДСРегл, СуммаНДСУпр";
	
	РаспоряженияНаОтгрузкуОборотыРазвернутая =
		РегистрыНакопления.РаспоряженияНаОтгрузкуИВозврат.ТекстЗапросаРазвернутаяТаблица(
			ПараметрыФормированияТаблицы);
	
	Запрос.Текст = СтрЗаменить(Запрос.Текст,
		"#РаспоряженияНаОтгрузкуОборотыРазвернутая",
		РаспоряженияНаОтгрузкуОборотыРазвернутая);
	
	ПараметрыФормированияТаблицы = РегистрыНакопления.РаспоряженияНаОтгрузкуИВозврат.НовыйПараметрыФормированияРазвернутойТаблицы();
	ПараметрыФормированияТаблицы.ТекстУсловия =
		"(Регистратор, Распоряжение, КодСтроки) В
		|	(ВЫБРАТЬ
		|		&Регистратор,
		|		ЗаказКлиента,
		|		КодСтроки
		|	ИЗ
		|		ТаблицаТовары)";
	ПараметрыФормированияТаблицы.Группировка = "Распоряжение, КодСтроки";
	ПараметрыФормированияТаблицы.Показатели = "Оформлено";
	ПараметрыФормированияТаблицы.Ресурсы = "Количество, СуммаНДСРегл, СуммаНДСУпр";
	ПараметрыФормированияТаблицы.ФизическаяТаблица = Истина;
	
	РаспоряженияНаОтгрузкуДвиженияРазвернутая =
		РегистрыНакопления.РаспоряженияНаОтгрузкуИВозврат.ТекстЗапросаРазвернутаяТаблица(
			ПараметрыФормированияТаблицы);
	
	Запрос.Текст = СтрЗаменить(Запрос.Текст,
		"#РаспоряженияНаОтгрузкуДвиженияРазвернутая",
		РаспоряженияНаОтгрузкуДвиженияРазвернутая);
	
	СтруктураПоиска = Новый Структура("ЗаказКлиента, КодСтроки");
	
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		
		ЗаполнитьЗначенияСвойств(СтруктураПоиска, Выборка);
		ПоискСтрок = Товары.НайтиСтроки(СтруктураПоиска);
		
		Если ПоискСтрок.Количество() Тогда
			
			СтрокаТовары = ПоискСтрок.Получить(0);
			
			Если Не ЗначениеЗаполнено(СтрокаТовары.СуммаНДСРегл) Тогда
				СтрокаТовары.СуммаНДСРегл = Выборка.СуммаНДСРегл / Выборка.Количество * СтрокаТовары.Количество;
			КонецЕсли;
			
			Если Не ЗначениеЗаполнено(СтрокаТовары.СуммаНДСУпр) Тогда
				СтрокаТовары.СуммаНДСУпр = Выборка.СуммаНДСУпр / Выборка.Количество * СтрокаТовары.Количество;
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЦикла;
	
