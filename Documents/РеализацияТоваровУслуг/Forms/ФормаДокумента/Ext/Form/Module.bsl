&НаКлиентеНаСервереБезКонтекста
Процедура ОбновитьВидПланированияДоставки(Форма, ИзмененФлагДоставки = Ложь)
	
	Объект = Форма.Объект;
	
	Если Объект.ТребуетсяДоставка Тогда
		
		Если Объект.РеализацияПоЗаказам Тогда
			
			Объект.ВидПланированияДоставки = ПредопределенноеЗначение("Перечисление.ВидыПланированияДоставки.ТекущимДокументом");
			
		Иначе
			
			ВидПланирования = ВидПланированияДоставкиПоПартнеруСоглашению(
				Объект.Партнер,
				Объект.Соглашение,
				Объект.РеализацияПоЗаказам,
				ИзмененФлагДоставки);
			
			Если ВидПланирования <> Неопределено Тогда
				
				Объект.ВидПланированияДоставки = ВидПланирования;
				
			КонецЕсли;
		
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ВидПланированияДоставкиПоПартнеруСоглашению(Знач Партнер, Знач Соглашение, Знач РеализацияПоЗаказам, Знач ИзмененФлагДоставки)
	
	РасширенныеВозможностиЗаказа = ПолучитьФункциональнуюОпцию("ИспользоватьРасширенныеВозможностиЗаказаКлиента");
	ВидПланированияДоставки = Неопределено;
	
	Если НЕ РасширенныеВозможностиЗаказа
	 ИЛИ НЕ РеализацияПоЗаказам Тогда
		
		ВидПланированияДоставки = ДоставкаТоваров.ВидПланированияДоставкиПоПартнеруСоглашению(Партнер, Соглашение);
		
	ИначеЕсли ИзмененФлагДоставки Тогда
		
		ВидПланированияДоставки = Перечисления.ВидыПланированияДоставки.ТекущимДокументом;
		
	КонецЕсли;
	
	Возврат ВидПланированияДоставки;
	
КонецФункции

&НаКлиенте
Процедура ОткрытьНастройкиПараметровДоставки()
	
	ЗаблокироватьДанныеФормыДляРедактирования();
	
	НастройкиДоставки = СформироватьНастройкиПараметровДоставки();
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("НастройкиДоставки", НастройкиДоставки);
	ПараметрыФормы.Вставить("ТолькоПросмотр", ТолькоПросмотр);
	
	ОписаниеЗавершения = Новый ОписаниеОповещения("ОбработатьНастройкиПараметровДоставки", ЭтотОбъект);
	ДоставкаТоваровКлиент.ОткрытьФормуНастроекДоставки(ПараметрыФормы, ОписаниеЗавершения);
	
КонецПроцедуры

&НаСервере
Функция СформироватьНастройкиПараметровДоставки()
	
	ЕстьПоддержкаДоставкиСвоимиКурьерами = СкладыСервер.ЕстьПоддержкаДоставкиСвоимиКурьерами(
		Объект.Склад, Объект.Дата);
	
	ЕстьПоддержкаДоставкиСвоимиКурьерами =
		(ЕстьПоддержкаДоставкиСвоимиКурьерами
		 И (Объект.ПорядокРасчетов <> Перечисления.ПорядокРасчетов.ПоДоговорамКонтрагентов));
	
	ИспользуемыеСпособыДоставки = Новый Массив; // Массив из ПеречислениеСсылка.СпособыДоставки25
	ИспользуемыеСпособыДоставки.Добавить(Перечисления.СпособыДоставки25.Самовывоз);
	ИспользуемыеСпособыДоставки.Добавить(Перечисления.СпособыДоставки25.НашимиСилами); 
	ИспользуемыеСпособыДоставки.Добавить(Перечисления.СпособыДоставки25.СиламиПеревозчика);
	ИспользуемыеСпособыДоставки.Добавить(Перечисления.СпособыДоставки25.ОпределяетСлужбаДоставки);
	Если ЕстьПоддержкаДоставкиСвоимиКурьерами Тогда
		ИспользуемыеСпособыДоставки.Добавить(Перечисления.СпособыДоставки25.НашКурьер);
	КонецЕсли;
	
	НастройкиДоставки = ДоставкаТоваровКлиентСервер.НовыеПараметрыНастройкиДоставки();
	НастройкиДоставки.СпособУказанияДоставки = Перечисления.СпособыУказанияДоставки.НаВесьДокумент;
	НастройкиДоставки.РазрешитьИзменениеСпособаУказанияДоставки = Ложь;
	НастройкиДоставки.ВидПланированияДоставки = Объект.ВидПланированияДоставки;
	НастройкиДоставки.РазрешитьИзменениеВидаПланированияДоставки = НЕ Объект.РеализацияПоЗаказам;
	НастройкиДоставки.СпособДоставки = Объект.СпособДоставки25;
	НастройкиДоставки.ИспользуемыеСпособыДоставки = ИспользуемыеСпособыДоставки;
	
	НастройкиДоставки.Партнер = Объект.Партнер;
	НастройкиДоставки.ТочкаДоставки = Объект.ТочкаДоставки;
	НастройкиДоставки.ЗонаДоставки = Объект.ЗонаДоставки;
	
	НастройкиДоставки.Курьер = Объект.Курьер;
	
	НастройкиДоставки.ДоставкаДоПеревозчика = Объект.ДоставкаДоПеревозчика;
	НастройкиДоставки.Перевозчик = Объект.ПеревозчикПартнер;
	НастройкиДоставки.ТочкаДоставкиПеревозчика = Объект.ТочкаДоставкиПеревозчика;
	НастройкиДоставки.ЗонаДоставкиПеревозчика = Объект.ЗонаДоставкиПеревозчика;
	
	НастройкиДоставки.ВремяДоставкиС = Объект.ВремяДоставкиС;
	НастройкиДоставки.ВремяДоставкиПо = Объект.ВремяДоставкиПо;
	
	НастройкиДоставки.ДополнительнаяИнформацияПоДоставке = Объект.ДополнительнаяИнформацияПоДоставке;
	НастройкиДоставки.ОсобыеУсловияПеревозки = Объект.ОсобыеУсловияПеревозки;
	НастройкиДоставки.ОсобыеУсловияПеревозкиОписание = Объект.ОсобыеУсловияПеревозкиОписание;
	
	ИменаПолейТоваров = "Склад";
	ПараметрыПоиска = Новый Структура;
	ПараметрыПоиска.Вставить("ТипНоменклатуры", Перечисления.ТипыНоменклатуры.Товар);
	ТоварыКВыгрузке = Объект.Товары.НайтиСтроки(ПараметрыПоиска);
	ТаблицаТоваров = Объект.Товары.Выгрузить(ТоварыКВыгрузке, ИменаПолейТоваров);
	ТаблицаСведенийСкладов = Объект.СкладыСведенияДоставки.Выгрузить();
	
	Запрос = Новый Запрос;
	ТекстЗапроса =
	"ВЫБРАТЬ
	|	ТаблицаТоваров.Склад КАК Склад
	|ПОМЕСТИТЬ ВтТаблицаТоваров
	|ИЗ
	|	&ТаблицаТоваров КАК ТаблицаТоваров
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТаблицаСведенийСкладов.Склад КАК Склад,
	|	ТаблицаСведенийСкладов.ТочкаСклада КАК ТочкаСклада,
	|	ТаблицаСведенийСкладов.ЗонаСклада КАК ЗонаСклада
	|ПОМЕСТИТЬ ВтТаблицаСведенийСкладов
	|ИЗ
	|	&ТаблицаСведенийСкладов КАК ТаблицаСведенийСкладов
	|;
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТаблицаТоваров.Склад КАК Склад,
	|	ВЫБОР
	|		КОГДА ТаблицаСкладыСведенияДоставки.ТочкаСклада ЕСТЬ NULL
	|			ТОГДА ЕСТЬNULL(ТочкиДоставки.Ссылка, ЗНАЧЕНИЕ(Справочник.ТочкиДоставки.ПустаяСсылка))
	|		ИНАЧЕ ТаблицаСкладыСведенияДоставки.ТочкаСклада
	|	КОНЕЦ КАК ТочкаСклада,
	|	ВЫБОР
	|		КОГДА ТаблицаСкладыСведенияДоставки.ЗонаСклада ЕСТЬ NULL
	|			ТОГДА ЕСТЬNULL(ТочкиДоставки.ЗонаДоставки, ЗНАЧЕНИЕ(Справочник.ЗоныДоставки.ПустаяСсылка))
	|		ИНАЧЕ ТаблицаСкладыСведенияДоставки.ЗонаСклада
	|	КОНЕЦ КАК ЗонаСклада
	|ИЗ
	|	ВтТаблицаТоваров КАК ТаблицаТоваров
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ТочкиДоставки КАК ТочкиДоставки
	|		ПО ТаблицаТоваров.Склад = ТочкиДоставки.Владелец
	|		И ТочкиДоставки.ОсновнаяТочка
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВтТаблицаСведенийСкладов КАК ТаблицаСкладыСведенияДоставки
	|		ПО ТаблицаТоваров.Склад = ТаблицаСкладыСведенияДоставки.Склад";
	
	Запрос.Текст = ТекстЗапроса;
	Запрос.УстановитьПараметр("ТаблицаТоваров", ТаблицаТоваров);
	Запрос.УстановитьПараметр("ТаблицаСведенийСкладов", ТаблицаСведенийСкладов);
	
	КешСкладов = Новый Соответствие();
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		
		Если ЗначениеЗаполнено(Выборка.Склад)
			И КешСкладов[Выборка.Склад] = Неопределено Тогда
			
			КешСкладов[Выборка.Склад] = Истина; // Запоминаем, что строку ранее добавили
			
			СтрокаСклада = ДоставкаТоваровКлиентСервер.НовыеДанныеСтрокиСкладовДоставки();
			СтрокаСклада.Склад = Выборка.Склад;
			СтрокаСклада.ТочкаСклада = Выборка.ТочкаСклада;
			СтрокаСклада.ЗонаСклада = Выборка.ЗонаСклада;
			НастройкиДоставки.Склады.Добавить(СтрокаСклада);
			
		КонецЕсли;
		
	КонецЦикла;
	
	Если НЕ Объект.Склад.Пустая()
		И КешСкладов[Объект.Склад] = Неопределено Тогда
		
		ЭтоГруппа = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.Склад, "ЭтоГруппа");
		Если НЕ ЭтоГруппа Тогда
			
			ДанныеТочки = Справочники.ТочкиДоставки.СведенияТочкиДоставкиОсновная(Объект.Склад);
			СтрокаСклада = ДоставкаТоваровКлиентСервер.НовыеДанныеСтрокиСкладовДоставки();
			СтрокаСклада.Склад = Объект.Склад;
			СтрокаСклада.ТочкаСклада = ДанныеТочки.ТочкаДоставки;
			СтрокаСклада.ЗонаСклада = ДанныеТочки.ЗонаДоставки;
			НастройкиДоставки.Склады.Добавить(СтрокаСклада);
			
			КешСкладов[Объект.Склад] = Истина;
			
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат НастройкиДоставки;
	
КонецФункции

// Параметры:
//  Настройки - Неопределено -
//            - см. ДоставкаТоваровКлиентСервер.НастройкиПараметровДоставкиПоУмолчанию
//  ДополнительныеПараметры - Структура
//
&НаКлиенте
Процедура ОбработатьНастройкиПараметровДоставки(Настройки, ДополнительныеПараметры) Экспорт
	
	Если Настройки = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ОбработатьНастройкиПараметровДоставкиСервер(Настройки);
	
	ПодключаемыеКомандыКлиент.НачатьОбновлениеКоманд(ЭтотОбъект);
	Модифицированность = Истина;
	
КонецПроцедуры

&НаСервере
Процедура ОбработатьНастройкиПараметровДоставкиСервер(Знач Настройки)
	
	Объект.ВидПланированияДоставки = Настройки.ВидПланированияДоставки;
	Объект.СпособДоставки25 = Настройки.СпособДоставки;
	
	Объект.ТочкаДоставки = Настройки.ТочкаДоставки;
	Объект.ЗонаДоставки = Настройки.ЗонаДоставки;
	
	Объект.ДоставкаДоПеревозчика = Настройки.ДоставкаДоПеревозчика;
	Объект.ПеревозчикПартнер = Настройки.Перевозчик;
	Объект.ТочкаДоставкиПеревозчика = Настройки.ТочкаДоставкиПеревозчика;
	Объект.ЗонаДоставкиПеревозчика = Настройки.ЗонаДоставкиПеревозчика;
	
	Объект.ВремяДоставкиС = Настройки.ВремяДоставкиС;
	Объект.ВремяДоставкиПо = Настройки.ВремяДоставкиПо;
	
	Объект.ДополнительнаяИнформацияПоДоставке = Настройки.ДополнительнаяИнформацияПоДоставке;
	Объект.ОсобыеУсловияПеревозки = Настройки.ОсобыеУсловияПеревозки;
	Объект.ОсобыеУсловияПеревозкиОписание = Настройки.ОсобыеУсловияПеревозкиОписание;
	
	Объект.Курьер = Настройки.Курьер;
	
	Объект.СкладыСведенияДоставки.Очистить();
	Для Каждого СтрокаСклада Из Настройки.Склады Цикл
	
		НоваяСтрока = Объект.СкладыСведенияДоставки.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаСклада);
		
	КонецЦикла;
	Объект.СкладыСведенияДоставки.Сортировать("Склад");
	
	ИменаПолейАдресаТочкиДоставки = "Адрес, АдресЗначение, АдресЗначенияПолей";
	ПоляАдресаТочкиДоставки = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Объект.ТочкаДоставки, ИменаПолейАдресаТочкиДоставки);
	
	Объект.АдресДоставки = ПоляАдресаТочкиДоставки.Адрес;
	Объект.АдресДоставкиЗначенияПолей = ПоляАдресаТочкиДоставки.АдресЗначение;
	Объект.АдресДоставкиЗначение = ПоляАдресаТочкиДоставки.АдресЗначенияПолей;
	
КонецПроцедуры

// Параметры:
//  Форма - см. Документ.РеализацияТоваровУслуг.Форма.ФормаДокумента
//
&НаКлиентеНаСервереБезКонтекста
Процедура УстановитьДоступностьВидимостьЭлементовДоставки(Форма)
	
	Объект = Форма.Объект;
	Элементы = Форма.Элементы;
	ИспользоватьРасширенныеВозможностиЗаказаКлиента = Форма.ИспользоватьРасширенныеВозможностиЗаказаКлиента;
	
	ИменаЭлементов = Новый Массив; // Массив из Строка
	ИменаЭлементов.Добавить("ТребуетсяДоставка");
	ИменаЭлементов.Добавить("РедактироватьПараметрыДоставкиШапка");
	
	ДоставкаПрименима = ДоставкаТоваровКлиентСервер.ХозяйственнаяОперацияУчаствуетВДоставке(Объект.ХозяйственнаяОперация);
	
	Если Не ДоставкаТоваровКлиентСервер.ИспользуетсяДоставка25()
		Или Объект.Организация = ПредопределенноеЗначение("Справочник.Организации.УправленческаяОрганизация")
		Или Не ДоставкаПрименима Тогда
		
		ИменаЭлементов.Добавить("ДекорацияДействиеДоставки");
		
		ОбщегоНазначенияУТКлиентСервер.УстановитьСвойствоЭлементовФормы(
			Элементы,
			ИменаЭлементов,
			"Видимость",
			Ложь);
		
	Иначе
		
		// Доставка применяется для операций, когда в ТЧ может быть только заказы,
		// поэтому не проверяются другие типы полей
		
		КоличествоРасхождений = 0;
		
		Если Объект.РеализацияПоЗаказам Тогда
			
			КоличествоРасхождений = Объект.Товары.Итог("РасхождениеЗаказ");
			
		КонецЕсли;
		
		Если Объект.РеализацияПоЗаказам Тогда
			
			Если Не ИспользоватьРасширенныеВозможностиЗаказаКлиента Тогда
				
				Элементы.ДекорацияДействиеДоставки.Видимость = Ложь;
				Элементы.ДекорацияДействиеДоставки.Заголовок = "";
				
				ОбщегоНазначенияУТКлиентСервер.УстановитьСвойствоЭлементовФормы(
					Элементы,
					ИменаЭлементов,
					"Видимость",
					Истина);
				
			ИначеЕсли ИспользоватьРасширенныеВозможностиЗаказаКлиента
				И КоличествоРасхождений > 0 Тогда
				
				Элементы.ДекорацияДействиеДоставки.Видимость = Объект.ТребуетсяДоставка;
				Элементы.ДекорацияДействиеДоставки.Заголовок = НСтр("ru = '(действуют только на строки сверх заказов)'");
				
				ОбщегоНазначенияУТКлиентСервер.УстановитьСвойствоЭлементовФормы(
					Элементы,
					ИменаЭлементов,
					"Видимость",
					Истина);
				
			Иначе
				
				ИменаЭлементов.Добавить("ДекорацияДействиеДоставки");
				Элементы.ДекорацияДействиеДоставки.Заголовок = "";
				
				ОбщегоНазначенияУТКлиентСервер.УстановитьСвойствоЭлементовФормы(
					Элементы,
					ИменаЭлементов,
					"Видимость",
					Ложь);
				
			КонецЕсли; 
			
		Иначе
			
			Элементы.ДекорацияДействиеДоставки.Видимость = Ложь;
			
			ОбщегоНазначенияУТКлиентСервер.УстановитьСвойствоЭлементовФормы(
				Элементы,
				ИменаЭлементов,
				"Видимость",
				Истина);
			
		КонецЕсли;
		
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(
			Элементы,
			"РедактироватьПараметрыДоставкиШапка",
			"Доступность",
			Объект.ТребуетсяДоставка);
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область Доставка20

&НаСервере
Процедура ДополнитьИнформациюПоДоставкеКонтактамиСервер()
	
	ДоставкаТоваров.ДополнитьИнформациюПоДоставкеКонтактами(Объект);
	
КонецПроцедуры

#КонецОбласти

#КонецОбласти

#Область Локализация

&НаКлиенте
Процедура ДобавитьПараметрыФормыЛокализация(ПараметрыФормы)
	
	//++ Локализация
	Если РозничныеПродажиКлиентСерверЛокализация.РозничныеПродажиТабачнойПродукцииТолькоПоМРЦ(ЭтотОбъект) Тогда
		ПараметрыФормы.Вставить(
			РозничныеПродажиКлиентСерверЛокализация.ИмяРеквизитаИспользоватьРозничныеПродажиТабачнойПродукцииТолькоПоМРЦ(),
			Истина);
	КонецЕсли;
	//-- Локализация
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаОповещенияЛокализация(ИмяСобытия, Параметр, Источник)
	
	//++ Локализация
	Если ТранспортнаяНакладнаяКлиент.ЭтоОповещениеЗаписиТранспортнойНакладной(ЭтотОбъект, ИмяСобытия, Параметр, Источник) Тогда
		ОбновитьТекстДокументыНаОсновании();
	КонецЕсли;

	Если ИмяСобытия = "ПроверитьКоличествоВДокументе"
		И ТипЗнч(Источник) = Тип("ФормаКлиентскогоПриложения")
		И Источник.УникальныйИдентификатор = УникальныйИдентификатор Тогда
		ПроверитьКоличествоВДокументеКлиент();
	КонецЕсли;
	
	Если ИмяСобытия = "Запись_ДокументыЭПД" Тогда
		ОбновитьТекстЭПД();
	КонецЕсли;
	//-- Локализация
	
	Возврат;
	
КонецПроцедуры

//++ Локализация
&НаСервере
Процедура ОбновитьБанковскийСчетКонтрагента()
	Объект.БанковскийСчетКонтрагента = ПолучитьБанковскийСчетКонтрагентаПоУмолчаниюСервер(Объект.Контрагент, Объект.БанковскийСчетОрганизации);
КонецПроцедуры

&НаСервере
Процедура ОбновитьТекстЭПД()
	
	Если Элементы.ГруппаСостояниеЭПД.Видимость Тогда 
		КоличествоЭПД = ОбменСГИСЭПДПереопределяемый.КоличествоЭлектронныхДокументов(Объект.Ссылка);
		Элементы.ДекорацияЭПД.Заголовок = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку("ЭПД (%1)", КоличествоЭПД);
	КонецЕсли;
	
КонецПроцедуры
//-- Локализация

&НаСервере
Процедура ОбновитьТекстДокументыНаОснованииЛокализация()
	
	//++ Локализация
	Если Не РеализацияЧерезКомиссионера 
			И Объект.ХозяйственнаяОперация <> Перечисления.ХозяйственныеОперации.ПереходПраваСобственности Тогда
		ТекстТТН = Документы.ТранспортнаяНакладная.ТекстТТН(ЭтотОбъект);
		ТекстыПоляДокументыНаОсновании.Добавить(ТекстТТН);
	КонецЕсли;
	
	
	ПараметрыРегистрацииУведомленийОПеремещении =
		Документы.РеализацияТоваровУслуг.ПараметрыРегистрацииУведомленийОПеремещенииПрослеживаемыхТоваров(Объект);
	УведомленияОПеремещенииНаОсновании = 
		УчетПрослеживаемыхТоваровЛокализация.УведомленияОПеремещенииПрослеживаемыхТоваровПоДокументуРеализации(
			ПараметрыРегистрацииУведомленийОПеремещении);
	ТекстыПоляДокументыНаОсновании.Добавить(УведомленияОПеремещенииНаОсновании.ПредставлениеРаспоряженияКОформлению);
	ТекстыПоляДокументыНаОсновании.Добавить(УведомленияОПеремещенииНаОсновании.ПредставлениеУведомленияОПеремещении);
	//-- Локализация
	
	Возврат;
	
КонецПроцедуры

&НаКлиенте
Процедура ТекстДокументыНаОснованииОбработкаНавигационнойСсылкиЛокализация(Элемент, НавигационнаяСсылкаФорматированнойСтроки, СтандартнаяОбработка)
	
	//++ Локализация
	ТранспортнаяНакладнаяКлиент.ОбработкаНавигационнойСсылки(ЭтотОбъект, НавигационнаяСсылкаФорматированнойСтроки,
		СтандартнаяОбработка);
	
	
	ПараметрыРегистрацииУведомленийОПеремещении = ПараметрыРегистрацииУведомленийОПеремещенииПрослеживаемыхТоваровСервер(Объект);
	ПрослеживаемостьФормыКлиентПереопределяемый.ОбработкаНавигационнойСсылкиУведомленияОПеремещенииПрослеживаемыхТоваров(
		ЭтотОбъект,
		НавигационнаяСсылкаФорматированнойСтроки,
		СтандартнаяОбработка,
		ПараметрыРегистрацииУведомленийОПеремещении);

	//-- Локализация

	Возврат;
	
КонецПроцедуры

&НаСервере
Процедура УстановитьДоступностьВидимостьЭлементовСборкиИДоставки()
	
	ДатаРасчетаНастроекСклада = Объект.Дата;
	
	НастройкиСклада = СкладыСервер.НастройкиСкладаДляСборкиИДоставки(Объект.Склад, ДатаРасчетаНастроекСклада);
	
	ЕстьПоддержкаДоставкиСвоимиКурьерами = Ложь;
	ЕстьПоддержкаСборкиЗаказов = Ложь;
	
	Если НастройкиСклада <> Неопределено Тогда
		ЕстьПоддержкаДоставкиСвоимиКурьерами = НастройкиСклада.ВМагазинеПоддерживаетсяДоставкаСвоимиКурьерами;
		ЕстьПоддержкаСборкиЗаказов = НастройкиСклада.ВМагазинеПоддерживаетсяСборкаЗаказов;
	КонецЕсли;
	
	ЕстьПоддержкаДоставкиСвоимиКурьерами = ЕстьПоддержкаДоставкиСвоимиКурьерами
		И (Объект.ПорядокРасчетов <> Перечисления.ПорядокРасчетов.ПоДоговорамКонтрагентов);
		
	Если ДоставкаТоваровКлиентСервер.ИспользуетсяДоставка20()
		И Не ЕстьПоддержкаДоставкиСвоимиКурьерами
		И Объект.СпособДоставки = Перечисления.СпособыДоставки.ДоКлиентаКурьером Тогда
		
		Объект.СпособДоставки = Перечисления.СпособыДоставки.Самовывоз;
		СпособМестоДоставкиПеревозчикПриИзмененииСервер(Элементы.СпособДоставки.Имя);
		
	КонецЕсли;
	
	Если ДоставкаТоваровКлиентСервер.ИспользуетсяДоставка25()
		И Не ЕстьПоддержкаДоставкиСвоимиКурьерами
		И Объект.СпособДоставки25 = Перечисления.СпособыДоставки25.НашКурьер Тогда
		
		Объект.ТребуетсяДоставка = Ложь;
		Объект.СпособДоставки25 = Перечисления.СпособыДоставки25.ПустаяСсылка();
		Объект.Курьер = Справочники.ФизическиеЛица.ПустаяСсылка();
		УстановитьДоступностьВидимостьЭлементовДоставки(ЭтотОбъект);
		
	КонецЕсли;
	
	Если Не ЕстьПоддержкаСборкиЗаказов Тогда
		Объект.Сборщик = Неопределено;
	КонецЕсли;
	
	ДоставкаТоваров.ОбновитьСписокВыбораСпособаДоставкиДляСкладаОтгрузки(Элементы.СпособДоставки, ЕстьПоддержкаДоставкиСвоимиКурьерами);
	Элементы.Сборщик.Видимость = ЕстьПоддержкаСборкиЗаказов;
	
КонецПроцедуры

&НаКлиенте
Процедура ЗакрытьСессиюПроверкиКМНаККТ(Знач Отказ)
	
	//++ Локализация
	
	Если НЕ Отказ Тогда
		РеквизитыОсновногоОбъекта = Новый Структура("Объект", Новый Структура("Контрагент, ХозяйственнаяОперация, Организация"));
		ЗаполнитьЗначенияСвойств(РеквизитыОсновногоОбъекта.Объект, Объект);		
		ПодключенныйККТ = Неопределено;
		ЗакрытьСессиюПроверкиКМНаККТ = ЗакрытьСессиюПроверкиКМНаККТСервер(РеквизитыОсновногоОбъекта, ПодключенныйККТ);
		Если ЗакрытьСессиюПроверкиКМНаККТ Тогда
			РозничныеПродажиКлиент.ЗакрытьСессиюПроверкиКМНаККТ(УникальныйИдентификатор, ПодключенныйККТ);
		КонецЕсли;
	КонецЕсли;
	
	//-- Локализация
	
	Возврат;
	
КонецПроцедуры

&НаСервере
Функция ПроверитьКорректностьЦеныПродажиИМРЦТабачнойПродукцииЛокализация(КонтрольПоТекущейДате)
	
	РезультатПроверки = Истина;
	
	//++ Локализация
	РезультатПроверки = РозничныеПродажиЛокализация.ПроверитьКорректностьЦеныПродажиИМРЦТабачнойПродукции(
		ЭтотОбъект, "ШтрихкодыУпаковок", КонтрольПоТекущейДате, Ложь);
	//-- Локализация
	
	Возврат РезультатПроверки;
	
КонецФункции

&НаСервере
Процедура ПроверитьИсправитьНаличиеСкидокОплатБонуснымиБалламиЛокализация()
	
	//++ Локализация
	РозничныеПродажиЛокализация.ОбновитьПризнакПродажиТабачнойПродукцииТолькоПоМРЦ(ЭтотОбъект);
	
	Если Не РозничныеПродажиКлиентСерверЛокализация.РозничныеПродажиТабачнойПродукцииТолькоПоМРЦ(ЭтотОбъект) Тогда
		Возврат;
	КонецЕсли;
	
	НачалоЗамера = ОценкаПроизводительности.НачатьЗамерВремени();
	
	РозничныеПродажиЛокализация.ПроверитьИсправитьНаличиеСкидокОплатБонуснымиБаллами(ЭтотОбъект, "Товары", Истина, Истина);
	
	ПараметрыСканирования = ШтрихкодированиеОбщегоНазначенияИС.ПараметрыСканирования(ЭтотОбъект);
	
	РозничныеПродажиЛокализация.ПроверитьШтрихкодыУпаковокНаМинимальнуюЦену(
		ЭтотОбъект,
		Объект.ШтрихкодыУпаковок.Выгрузить().ВыгрузитьКолонку("ШтрихкодУпаковки"),
		ПараметрыСканирования,
		Истина,
		Истина);
	
	ШтрихкодыУпаковокСМРЦ = РозничныеПродажиЛокализация.ПолучитьШтрихкодыУпаковокСМРЦ(
		Объект.ШтрихкодыУпаковок.Выгрузить().ВыгрузитьКолонку("ШтрихкодУпаковки"),
		ПараметрыСканирования,
		Истина);
	
	РозничныеПродажиЛокализация.ПривестиЦеныПродажиКМРЦ(ЭтотОбъект, ШтрихкодыУпаковокСМРЦ);
	
	Настройки = ПроверкаИПодборПродукцииИСМПУТ.НастройкиИсточникаКешаЧека();
	Настройки.Объект = "Объект";
	Настройки.Штрихкоды = "ШтрихкодыУпаковок";
	Настройки.ШтрихкодУпаковки = "ШтрихкодУпаковки";
	Настройки.Серии = "Серии";
	ПроверкаИПодборПродукцииИС.ЗаполнитьКешШтрихкодовУпаковок(ЭтотОбъект, Настройки);
	ПроверкаИПодборПродукцииИС.ПрименитьКешШтрихкодовУпаковок(ЭтотОбъект, Настройки);
	ШтрихкодированиеИС.ОбновитьКэшМаркируемойПродукции(ЭтотОбъект);
	
	РассчитатьИтоговыеПоказатели(ЭтотОбъект);
	
	КлючеваяОперацияИмя = "МРЦ.КонтрольСкидокРТУ";
	ОписаниеЛога = Новый Структура;
	ОписаниеЛога.Вставить("Метод", "ПроверитьИсправитьНаличиеСкидокОплатБонуснымиБалламиЛокализация");
	ОписаниеЛога.Вставить("Документ", Строка(Объект.Ссылка));
	ОписаниеЛога.Вставить("КоличествоКМсМРЦ", ШтрихкодыУпаковокСМРЦ.Количество());
	ОценкаПроизводительности.ЗакончитьЗамерВремени(КлючеваяОперацияИмя, 
		НачалоЗамера,, 
		ЗаписатьЗначениеJSON(ОписаниеЛога));
	
	//-- Локализация
	
КонецПроцедуры

