			//++ Локализация
			ОбновитьБанковскийСчетКонтрагента();
			//-- Локализация
		
		КонецЕсли;
		
		ДобавитьКомандуОбновленияСтатусаОплатыСБП();
		
	КонецЕсли;
	
	РассчитатьИтоговыеПоказатели(ЭтотОбъект);
	
