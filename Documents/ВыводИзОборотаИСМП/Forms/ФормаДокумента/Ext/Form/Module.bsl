&НаКлиенте
Процедура ВидПервичногоДокументаПриИзменении(Элемент)
	
	НастроитьЗависимыеЭлементыФормы(ЭтотОбъект, "ВидПервичногоДокумента");
	
	Если Объект.ВидПервичногоДокумента <> ПредопределенноеЗначение("Перечисление.ВидыПервичныхДокументовИСМП.Прочее") Тогда
		Объект.НаименованиеПервичногоДокумента = "";
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Объект.ВидПервичногоДокумента)
		И Элементы.ВидПервичногоДокумента.СписокВыбора.НайтиПоЗначению(Объект.ВидПервичногоДокумента) = Неопределено
		И ВыводИзОборотаКлиентСервер.ДоступноПолеВидПервичногоДокумента(Объект.ТоварнаяГруппа, Объект.Причина) Тогда
		Объект.ВидПервичногоДокумента = Элементы.ВидПервичногоДокумента.СписокВыбора.Получить(0).Значение;
	КонецЕсли;
	
	ОтключитьОтметкуНезаполненного();

КонецПроцедуры

&НаКлиенте
Процедура ПроизводственныйОбъектНачалоВыбора(Элемент, ДанныеВыбора, ВыборДобавлением, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	Отбор = Новый Структура;
	Отбор.Вставить("Организация", Объект.Организация);
	
	ПараметрыОткрытия = Новый Структура;
	ПараметрыОткрытия.Вставить("Отбор", Отбор);
	
	ОткрытьФорму("РегистрСведений.НастройкиОбменаСУЗ.Форма.ФормаВыбораПроизводственногоОбъекта",
		ПараметрыОткрытия, Элемент,,,,, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	
КонецПроцедуры

&НаКлиенте
Процедура ПроизводственныйОбъектПриИзменении(Элемент)
	
	ЗаполнитьАдресПроизводственногоОбъекта(ЭтотОбъект);
	ЗаполнитьКПППоПроизводственномуОбъекту();
	ОбновитьСтатусПроверкиМОД();
	
КонецПроцедуры

&НаКлиенте
Процедура АдресПлощадкиСтрокойОбработкаВыбора(Элемент, ВыбранноеЗначение, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	Если ТипЗнч(ВыбранноеЗначение) <> Тип("Структура") Тогда
		// Отказ от выбора, данные неизменны.
		Возврат;
	КонецЕсли;
	
	Если ВыбранноеЗначение.Свойство("Действие") Тогда
		Если ВыбранноеЗначение.Действие = "ОткрытьСписокМОД" Тогда
			ОткрытьСписокМестОсуществленияДеятельности();
		ИначеЕсли ВыбранноеЗначение.Действие = "ЗаполнитьАдрес" Тогда
			Объект.АдресПлощадкиСтрокой = ВыбранноеЗначение.ПредставлениеАдреса;
			Объект.АдресПлощадки        = ВыбранноеЗначение.ДанныеАдреса;
			Объект.ИдентификаторФИАС    = ВыбранноеЗначение.КодФИАС;
			Модифицированность          = Истина;
		КонецЕсли;
	Иначе
		Объект.АдресПлощадкиСтрокой = ВыбранноеЗначение.Представление;
		Объект.АдресПлощадки        = ВыбранноеЗначение.КонтактнаяИнформация;
		Объект.ИдентификаторФИАС    = ИдентификаторФИАСПоДаннымАдреса(ВыбранноеЗначение.КонтактнаяИнформация);
		КомментарийАдресаПлощадки   = ВыбранноеЗначение.Комментарий;
		Модифицированность          = Истина;
	КонецЕсли;
	
	ОбновитьСтатусПроверкиМОД();
	
КонецПроцедуры

&НаКлиенте
Процедура АдресПлощадкиСтрокойОчистка(Элемент, СтандартнаяОбработка)

	// Сбрасываем как представления, так и внутренние значения полей.
	Объект.АдресПлощадкиСтрокой = "";
	Объект.АдресПлощадки        = "";
	Объект.ИдентификаторФИАС    = "";
	КомментарийАдресаПлощадки   = "";

	ОбновитьСтатусПроверкиМОД();

КонецПроцедуры

&НаКлиенте
Процедура АдресПлощадкиСтрокойПриИзменении(Элемент)
	
	Текст = Элемент.ТекстРедактирования;
	Если ПустаяСтрока(Текст) Тогда
		// Очистка данных, сбрасываем как представления, так и внутренние значения полей.
		Объект.АдресПлощадки        = "";
		Объект.АдресПлощадкиСтрокой = "";
		Объект.ИдентификаторФИАС    = "";
		КомментарийАдресаПлощадки   = "";
	Иначе
		// Формируем внутренние значения полей по тексту и параметрам формирования из
		// реквизита ВидКонтактнойИнформацииАдресаДоставки.
		ДанныеАдреса = ОбщегоНазначенияИСВызовСервера.ЗначенияПолейКонтактнойИнформации(
			Текст, ВидКонтактнойИнформацииАдресаПроизводственногоОбъекта);
		
		Объект.АдресПлощадкиСтрокой = Текст;
		Объект.ИдентификаторФИАС    = ИдентификаторФИАСПоДаннымАдреса(ДанныеАдреса);
		Объект.АдресПлощадки        = ОбщегоНазначенияИСВызовСервера.ЗначенияПолейКонтактнойИнформации(
			Текст, ВидКонтактнойИнформацииАдресаПроизводственногоОбъекта);
		
	КонецЕсли;
	
	ОбновитьСтатусПроверкиМОД();
	
КонецПроцедуры

&НаКлиенте
Процедура АдресПлощадкиСтрокойНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	// Если представление было изменено в поле и сразу нажата кнопка выбора, то необходимо 
	// привести данные в соответствие и сбросить внутренние поля для повторного разбора.
	Если Элемент.ТекстРедактирования <> Объект.АдресПлощадкиСтрокой Тогда
		Объект.АдресПлощадкиСтрокой = Элемент.ТекстРедактирования;
		Объект.АдресПлощадки        = "";
	КонецЕсли;
	ВидыПродукции = КонструкторИСМПОбщегоНазначенияКлиентСервер.ВидыПродукцииПоТоварнойГруппе(Объект.ТоварнаяГруппа);
	// Переопределямый заголовок формы, по умолчанию отобразятся данные по ВидКонтактнойИнформации.
	Если КонструкторИСОбщегоНазначенияКлиентСервер.ЭтоПродукцияМОТП(ВидыПродукции) Тогда
		ЗаголовокВводаАдреса = НСтр("ru = 'Адрес площадки'");
		ВидКонтактнойИнформацииАдресаПроизводственногоОбъекта.НастройкиПроверки.ПроверятьКорректность = Ложь;
	Иначе
		ЗаголовокВводаАдреса = НСтр("ru = 'Адрес'");
		ВидКонтактнойИнформацииАдресаПроизводственногоОбъекта.НастройкиПроверки.ПроверятьКорректность = Истина;
	КонецЕсли;
	
	// Данные для редактирования
	ПараметрыОткрытия = УправлениеКонтактнойИнформациейКлиент.ПараметрыФормыКонтактнойИнформации(
		ВидКонтактнойИнформацииАдресаПроизводственногоОбъекта,
		Объект.АдресПлощадки,
		Объект.АдресПлощадкиСтрокой,
		КомментарийАдресаПлощадки);
	ПараметрыОткрытия.Заголовок = ЗаголовокВводаАдреса;
	
	УправлениеКонтактнойИнформациейКлиент.ОткрытьФормуКонтактнойИнформации(ПараметрыОткрытия, Элемент);
	
КонецПроцедуры

&НаКлиенте
Процедура ПредставлениеСохраненногоВыбораОбработкаНавигационнойСсылки(Элемент, НавигационнаяСсылкаФорматированнойСтроки, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	ИнтеграцияИСКлиент.ПредставлениеСохраненногоВыбораОбработкаНавигационнойСсылки(
		ЭтотОбъект, НавигационнаяСсылкаФорматированнойСтроки);
	
