&НаСервере
Процедура ОбновитьСтатусИСМП()
	
	МенеджерОбъекта = ОбщегоНазначенияИС.МенеджерОбъектаПоСсылке(Объект.Ссылка);
	
	СтатусИСМП = МенеджерОбъекта.СтатусПоУмолчанию();
	
	СтатусПроверкиИПодбора = РегистрыСведений.СтатусыПроверкиИПодбораИС.ТекущийСтатус(Объект.Ссылка, 0);
	
	Реквизиты = Новый Структура(Документы.ВыводИзОборотаИСМП.ИменаРеквизитовДляРасчетаДальнейшегоДействия());
	ЗаполнитьЗначенияСвойств(Реквизиты, Объект);
	
	ДальнейшееДействие = МенеджерОбъекта.ДальнейшееДействиеПоУмолчанию(Реквизиты);
	
	Если СтатусПроверкиИПодбора = Перечисления.СтатусыПроверкиИПодбораИС.Выполняется Тогда
		
		ДальнейшееДействие = Новый Массив;
		
	ИначеЕсли ЗначениеЗаполнено(Объект.Ссылка)
		И ПараметрыОбновленияСтатуса = Неопределено Тогда
		
		Запрос = Новый Запрос(
		"ВЫБРАТЬ
		|	Статусы.Статус КАК Статус,
		|	ВЫБОР
		|		КОГДА Статусы.ДальнейшееДействие1 В (&МассивДальнейшиеДействия)
		|			ТОГДА ЗНАЧЕНИЕ(Перечисление.ДальнейшиеДействияПоВзаимодействиюИСМП.НеТребуется)
		|		ИНАЧЕ Статусы.ДальнейшееДействие1
		|	КОНЕЦ КАК ДальнейшееДействие1,
		|	ВЫБОР
		|		КОГДА Статусы.ДальнейшееДействие2 В (&МассивДальнейшиеДействия)
		|			ТОГДА ЗНАЧЕНИЕ(Перечисление.ДальнейшиеДействияПоВзаимодействиюИСМП.НеТребуется)
		|		ИНАЧЕ Статусы.ДальнейшееДействие2
		|	КОНЕЦ КАК ДальнейшееДействие2,
		|	ВЫБОР
		|		КОГДА Статусы.ДальнейшееДействие3 В (&МассивДальнейшиеДействия)
		|			ТОГДА ЗНАЧЕНИЕ(Перечисление.ДальнейшиеДействияПоВзаимодействиюИСМП.НеТребуется)
		|		ИНАЧЕ Статусы.ДальнейшееДействие3
		|	КОНЕЦ КАК ДальнейшееДействие3
		|ИЗ
		|	РегистрСведений.СтатусыДокументовИСМП КАК Статусы
		|ГДЕ
		|	Статусы.Документ = &Документ");
		
		Запрос.УстановитьПараметр("Документ",                 Объект.Ссылка);
		Запрос.УстановитьПараметр("МассивДальнейшиеДействия", ОбменДаннымиИСМП.НеотображаемыеВДокументахДальнейшиеДействия());
		
		Выборка = Запрос.Выполнить().Выбрать();
		
		Если Выборка.Следующий() Тогда
			
			СтатусИСМП = Выборка.Статус;
			ДальнейшееДействие1 = Выборка.ДальнейшееДействие1;
			
			Если СтатусПроверкиИПодбора <> Перечисления.СтатусыПроверкиИПодбораИС.Выполняется Тогда
				
				ДальнейшееДействие = Новый Массив;
				ДальнейшееДействие.Добавить(Выборка.ДальнейшееДействие1);
				ДальнейшееДействие.Добавить(Выборка.ДальнейшееДействие2);
				ДальнейшееДействие.Добавить(Выборка.ДальнейшееДействие3);
				
			КонецЕсли;
			
		КонецЕсли;
		
	ИначеЕсли ПараметрыОбновленияСтатуса <> Неопределено Тогда
		
		СтатусИСМП = ПараметрыОбновленияСтатуса.НовыйСтатус;
		ДальнейшееДействие1 = ПараметрыОбновленияСтатуса.ДальнейшееДействие1;
		
		ДальнейшееДействие = Новый Массив;
		ДальнейшееДействие.Добавить(ПараметрыОбновленияСтатуса.ДальнейшееДействие1);
		ДальнейшееДействие.Добавить(ПараметрыОбновленияСтатуса.ДальнейшееДействие2);
		ДальнейшееДействие.Добавить(ПараметрыОбновленияСтатуса.ДальнейшееДействие3);
		
	КонецЕсли;

	ДопустимыеДействия = Новый Массив;
	ДопустимыеДействия.Добавить(Перечисления.ДальнейшиеДействияПоВзаимодействиюИСМП.ПередайтеДанные);
	ДопустимыеДействия.Добавить(Перечисления.ДальнейшиеДействияПоВзаимодействиюИСМП.ОтменитеОперацию);
	ДопустимыеДействия.Добавить(Перечисления.ДальнейшиеДействияПоВзаимодействиюИСМП.ОтменитеПередачуДанных);

	СтатусПредставление = ОбменДаннымиИСМП.ПредставлениеСтатуса(СтатусИСМП, ДальнейшееДействие, ДопустимыеДействия);
	
	РедактированиеФормыНеДоступно = СтатусИСМП <> Перечисления.СтатусыОбработкиВыводаИзОборотаИСМП.Черновик
	                              И (СтатусИСМП <> Перечисления.СтатусыОбработкиВыводаИзОборотаИСМП.ОшибкаПередачи
	                                 Или Объект.УведомитьОбОтгрузкеНаЭкспорт)
	                              И СтатусИСМП <> Перечисления.СтатусыОбработкиВыводаИзОборотаИСМП.УведомлениеОбЭкспортеОшибка;
	
КонецПроцедуры

&НаКлиенте
Процедура СтатусПредставлениеОбработкаНавигационнойСсылкиЗавершение(РезультатВопроса, ДополнительныеПараметры) Экспорт

	Если Не РезультатВопроса = КодВозвратаДиалога.Да Тогда
		Возврат;
	КонецЕсли;

	Если ПроверитьЗаполнение() Тогда
		Записать(Новый Структура("РежимЗаписи", РежимЗаписиДокумента.Проведение));
		РазблокироватьДанныеФормыДляРедактирования();
	КонецЕсли;

	Если Не Модифицированность И Объект.Проведен Тогда
		ОбработатьНажатиеНавигационнойСсылки(ДополнительныеПараметры.НавигационнаяСсылкаФорматированнойСтроки);
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ОбработатьНажатиеНавигационнойСсылки(НавигационнаяСсылкаФорматированнойСтроки)
	
	Если НавигационнаяСсылкаФорматированнойСтроки = "ПередатьДанные" Тогда
		
		ПараметрыОбработкиДокументов = ОбменДаннымиИСМПКлиентСервер.ПараметрыОбработкиДокументов();
		ПараметрыОбработкиДокументов.Ссылка             = Объект.Ссылка;
		ПараметрыОбработкиДокументов.Организация        = Объект.Организация;
		ПараметрыОбработкиДокументов.ДальнейшееДействие = ПредопределенноеЗначение("Перечисление.ДальнейшиеДействияПоВзаимодействиюИСМП.ПередайтеДанные");
		
		ОписаниеПриЗавершении = Новый ОписаниеОповещения(
			"Подключаемый_ПриЗавершенииОперации", ЭтотОбъект, ПараметрыОбработкиДокументов);
			
		ОбменДаннымиИСМПКлиент.ПодготовитьКПередаче(
			ЭтотОбъект,
			ПараметрыОбработкиДокументов,
			ОписаниеПриЗавершении);
		
	ИначеЕсли НавигационнаяСсылкаФорматированнойСтроки = "ПередатьУведомлениеОбОтгрузкеНаЭкспорт" Тогда
		
		ПараметрыОбработкиДокументов = ОбменДаннымиИСМПКлиентСервер.ПараметрыОбработкиДокументов();
		ПараметрыОбработкиДокументов.Ссылка             = Объект.Ссылка;
		ПараметрыОбработкиДокументов.Организация        = Объект.Организация;
		ПараметрыОбработкиДокументов.ДальнейшееДействие = ПредопределенноеЗначение(
			"Перечисление.ДальнейшиеДействияПоВзаимодействиюИСМП.ПередайтеУведомлениеОбОтгрузкеНаЭкспорт");
		
		ОписаниеПриЗавершении = Новый ОписаниеОповещения(
			"Подключаемый_ПриЗавершенииОперации", ЭтотОбъект, ПараметрыОбработкиДокументов);
			
		ОбменДаннымиИСМПКлиент.ПодготовитьКПередаче(
			ЭтотОбъект,
			ПараметрыОбработкиДокументов,
			ОписаниеПриЗавершении);
		
	ИначеЕсли НавигационнаяСсылкаФорматированнойСтроки = "ОтменитьОперацию" Тогда
		
		ОбменДаннымиИСМПКлиент.ОтменитьПоследнююОперацию(Объект.Ссылка);
		
	ИначеЕсли НавигационнаяСсылкаФорматированнойСтроки = "ОтменитьПередачуДанных" Тогда
		
		ОбменДаннымиИСМПКлиент.ОтменитьПередачу(Объект.Ссылка);
		
	ИначеЕсли НавигационнаяСсылкаФорматированнойСтроки = "АннулироватьВыводИзОборота" Тогда
		
		ПараметрыОбработкиДокументов = ОбменДаннымиИСМПКлиентСервер.ПараметрыОбработкиДокументов();
		ПараметрыОбработкиДокументов.Ссылка             = Объект.Ссылка;
		ПараметрыОбработкиДокументов.Организация        = Объект.Организация;
		ПараметрыОбработкиДокументов.ДальнейшееДействие = ПредопределенноеЗначение("Перечисление.ДальнейшиеДействияПоВзаимодействиюИСМП.АннулируйтеВыводИзОборота");
		
		ОписаниеПриЗавершении = Новый ОписаниеОповещения(
			"Подключаемый_ПриЗавершенииОперации", ЭтотОбъект, ПараметрыОбработкиДокументов);
		
		ОбменДаннымиИСМПКлиент.ПодготовитьКПередаче(
			ЭтотОбъект,
			ПараметрыОбработкиДокументов,
			ОписаниеПриЗавершении);
	
	ИначеЕсли НавигационнаяСсылкаФорматированнойСтроки = "ПоказатьПричинуОшибки" Тогда
		
		ПараметрыОткрытияФормы = Новый Структура;
		ПараметрыОткрытияФормы.Вставить("Документ", Объект.Ссылка);
		
		ОткрытьФорму(
			"Справочник.ИСМППрисоединенныеФайлы.Форма.ФормаОшибки",
			ПараметрыОткрытияФормы,
			ЭтотОбъект);
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ОбработкаРезультатаПодбораНоменклатуры(ВыбранноеЗначение, КэшированныеЗначения)
	
	ВидыПродукции = КонструкторИСМПОбщегоНазначенияКлиентСервер.ВидыПродукцииПоТоварнойГруппе(Объект.ТоварнаяГруппа);
	ПараметрыЗаполнения = ИнтеграцияИС.ПараметрыЗаполненияТабличнойЧастиТовары(ВидыПродукции);
	ПараметрыЗаполнения.Вставить("ПараметрыУказанияСерий", ПараметрыУказанияСерий);
	ПараметрыЗаполнения.ЗаполнитьСтавкуНДС = Элементы.ТоварыСтавкаНДС.Видимость;
	
	ДобавленныеСтроки = Новый Массив;
	СобытияФормИСМППереопределяемый.ОбработкаРезультатаПодбораНоменклатуры(
		ЭтотОбъект, ВыбранноеЗначение, ПараметрыЗаполнения, КэшированныеЗначения, ДобавленныеСтроки);
	
	Если КонструкторИСМПКлиентСервер.ЭтоСырьеГИСМТ(Объект.ТоварнаяГруппа) Тогда
		РегистрыСведений.СоответствиеНоменклатурыСырьяГИСМТ.ЗаполнитьСопоставленноеСырьеВДокументе(
			ДобавленныеСтроки);
		ИнтеграцияИСМП.ЗаполнитьСлужебныеРеквизитыСырье(ДобавленныеСтроки);
	Иначе
		ПрименитьКешШтрихкодовУпаковок();
		ЗаполнениеОбъектовПоСтатистикеИСМП.ЗаполнитьДанныеПоТоварамВыводаИзОборотаИСМП(
			Объект.Товары, Объект);
	КонецЕсли;
	
	// РаботаСКлючомВидовПродукции
	СобытияФормИС.КлючВидовПродукцииЗаполнитьДанные(ЭтотОбъект, Объект.Товары);
	// Конец РаботаСКлючомВидовПродукции
	
КонецПроцедуры

&НаСервере
Процедура УстановитьУсловноеОформление()
	
	УсловноеОформление.Элементы.Очистить();
	
	СобытияФормИСПереопределяемый.УстановитьУсловноеОформлениеЕдиницИзмерения(ЭтотОбъект);
	СобытияФормИСПереопределяемый.УстановитьУсловноеОформлениеХарактеристикНоменклатуры(ЭтотОбъект);
	СобытияФормИСПереопределяемый.УстановитьУсловноеОформлениеСерийНоменклатуры(ЭтотОбъект);
	
	ИнтеграцияИСМП.УстановитьУсловноеОформлениеПоляСырье(ЭтотОбъект);
	
	// GTIN
	ЭлементУсловногоОформления = УсловноеОформление.Элементы.Добавить();
	
	ПолеЭлемента = ЭлементУсловногоОформления.Поля.Элементы.Добавить();
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(Элементы.ТоварыGTIN.Имя);
	
	ОтборЭлемента = ЭлементУсловногоОформления.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ОтборЭлемента.ЛевоеЗначение  = Новый ПолеКомпоновкиДанных(Элементы.ТоварыGTIN.ПутьКДанным);
	ОтборЭлемента.ВидСравнения   = ВидСравненияКомпоновкиДанных.НеЗаполнено;
	
	ЭлементУсловногоОформления.Оформление.УстановитьЗначениеПараметра("ЦветТекста", ЦветаСтиля.ЦветТекстаНеТребуетВниманияГосИС);
	ЭлементУсловногоОформления.Оформление.УстановитьЗначениеПараметра("Текст",      НСтр("ru = '<выберите существующий GTIN>'"));
	
	// Цены
	ЭлементУсловногоОформления = УсловноеОформление.Элементы.Добавить();
	
	ПолеЭлемента = ЭлементУсловногоОформления.Поля.Элементы.Добавить();
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(Элементы.ТоварыЦена.Имя);
	
	ПолеЭлемента = ЭлементУсловногоОформления.Поля.Элементы.Добавить();
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(Элементы.ТоварыСумма.Имя);
	
	ПолеЭлемента = ЭлементУсловногоОформления.Поля.Элементы.Добавить();
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(Элементы.ТоварыСуммаНДС.Имя);
	
	ПолеЭлемента = ЭлементУсловногоОформления.Поля.Элементы.Добавить();
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(Элементы.ТоварыСтавкаНДС.Имя);
	
	ОтборЭлемента = ЭлементУсловногоОформления.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ОтборЭлемента.ЛевоеЗначение  = Новый ПолеКомпоновкиДанных(Элементы.Причина.ПутьКДанным);
	ОтборЭлемента.ВидСравнения   = ВидСравненияКомпоновкиДанных.НеВСписке;
	ОтборЭлемента.ПравоеЗначение = ВыводИзОборотаКлиентСервер.ПричиныВыводаИзОборотаСПроверкойЗаполненияПоляЦена(Объект.ТоварнаяГруппа);
	
	ЭлементУсловногоОформления.Оформление.УстановитьЗначениеПараметра("ОтметкаНезаполненного", Ложь);
	
	// Коды отдельно от количества
	ИнтеграцияИСМП.УстановитьУсловноеОформлениеПолейКоличества(ЭтотОбъект);
	
КонецПроцедуры

&НаСервере
Процедура ПриСозданииЧтенииНаСервере(ЭтоПерезаполнениеПоОснованию = Ложь)
	
	ЦветГиперссылки = ЦветаСтиля.ЦветГиперссылкиГосИС;
	ЦветТекстаПоля  = ЦветаСтиля.ЦветТекстаПоля;
	
	Если Не Объект.Ссылка.Пустая() Тогда
		ДанныеДокумента = Новый Структура("ТоварнаяГруппа, Причина, ВидПервичногоДокумента");
		ЗаполнитьЗначенияСвойств(ДанныеДокумента, Объект);
		Если ЭтоАдресВременногоХранилища(ДанныеДокументаАдрес) Тогда
			ПоместитьВоВременноеХранилище(ДанныеДокумента, ДанныеДокументаАдрес);
		Иначе
			ДанныеДокументаАдрес = ПоместитьВоВременноеХранилище(ДанныеДокумента, УникальныйИдентификатор);
		КонецЕсли;
	КонецЕсли;
	
	ШтрихкодированиеОбщегоНазначенияИС.ВосстановитьНастройкиВыбораМаркируемойПродукции(ЭтотОбъект, Объект.Ссылка);
	ШтрихкодированиеИСКлиентСервер.ОтобразитьСохраненныйВыборПоМаркируемойПродукции(ЭтотОбъект);
	
	ПравоИзменения = ПравоДоступа("Изменение", Метаданные.Документы.ВыводИзОборотаИСМП);
	
	ИнтеграцияИСПереопределяемый.ЗаполнитьСлужебныеРеквизитыВКоллекции(ЭтотОбъект, Объект.Товары);
	
	ПараметрыУказанияСерий = ИнтеграцияИС.ПараметрыУказанияСерийФормыОбъекта(Объект, Документы.ВыводИзОборотаИСМП);
	
	ВидыПродукцииПоТоварнойГруппе = КонструкторИСМПОбщегоНазначенияКлиентСервер.ВидыПродукцииПоТоварнойГруппе(Объект.ТоварнаяГруппа);
	
	СобытияФормИСКлиентСерверПереопределяемый.УстановитьПараметрыВыбораНоменклатуры(
		ЭтотОбъект,
		ВидыПродукцииПоТоварнойГруппе);
	
	// РаботаСКлючомВидовПродукции
	СобытияФормИС.КлючВидовПродукцииИнициализация(ЭтотОбъект, "Объект.Товары");
	СобытияФормИС.КлючВидовПродукцииЗаполнитьДанные(ЭтотОбъект, Объект.Товары);
	// Конец РаботаСКлючомВидовПродукции
	
	ПараметрыОбновленияСтатуса = Неопределено;
	УказываетсяТранспортноеСредство = ИнтеграцияИС.УказываетсяТранспортноеСредство();
	
	ОбновитьПредставленияНаФорме();
	
	ПроизводственныйОбъектЗаполнитьСписокВыбора(ЭтотОбъект);
	НастроитьЗависимыеЭлементыФормы(ЭтотОбъект);
	НастроитьЭлементыФормы(ЭтотОбъект);
	
	Если КонструкторИСМПКлиентСервер.ЭтоСырьеГИСМТ(Объект.ТоварнаяГруппа) Тогда
		Элементы.ТоварыКоличествоПотребительскихУпаковок.Видимость = Ложь;
		РегистрыСведений.СоответствиеНоменклатурыСырьяГИСМТ.ЗаполнитьСопоставленноеСырьеВДокументе(
			Объект.Товары,
			Не ЗначениеЗаполнено(Объект.Ссылка) Или ЭтоПерезаполнениеПоОснованию,
			Объект.ДокументОснование);
		ИнтеграцияИСМП.ЗаполнитьСлужебныеРеквизитыСырье(Объект.Товары);
	Иначе
		ИнтеграцияИСМП.НастроитьВидимостьКолонкиКоличестваКодовМаркировки(ЭтотОбъект);
	КонецЕсли;
	
	Если Не ПодключенаОбработкаКодовМаркировки Тогда
		ПроверкаИПодборПродукцииИС.ПодключитьОбработкуКодовМаркировки(ЭтотОбъект,,"КоличествоПотребительскихУпаковок,GTIN");
		ПодключенаОбработкаКодовМаркировки = Истина;
	КонецЕсли;
	
	ИнициализироватьКэшСтроки(ЭтотОбъект);
	
	Если Не РедактированиеФормыНедоступно Тогда
		ПроверкаИПодборПродукцииИС.ЗаполнитьКешШтрихкодовУпаковок(ЭтотОбъект, НастройкиКешаШтрихкодовУпаковок());
		ПроверкаИПодборПродукцииИС.ПрименитьКешШтрихкодовУпаковок(ЭтотОбъект, НастройкиКешаШтрихкодовУпаковок());
	КонецЕсли;
	
	СобытияФормИСМП.УстановитьСвязиПараметровВыбораВидПродукции(ЭтотОбъект, "ТоварыСырье");
	
	УстановитьПараметрыВыбораКонтрагентаНаСервере();
	УстановитьПараметрыВыбораСтраныМира();
	ЗаполнитьКПППоПроизводственномуОбъекту();
	ОбновитьСтатусПроверкиМОД();
	ЗаполнитьДоступныеАдресаМОД();
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Процедура НастроитьЭлементыФормы(Форма)
	
	Объект   = Форма.Объект;
	Элементы = Форма.Элементы;
	
	ВидыПродукцииПоТоварнойГруппе = КонструкторИСМПОбщегоНазначенияКлиентСервер.ВидыПродукцииПоТоварнойГруппе(Объект.ТоварнаяГруппа);
	
	ЗависимыеОтСтатусаИСМП = Новый Массив;
	ЗависимыеОтСтатусаИСМП.Добавить("ГруппаНередактируемыеПослеОтправкиРеквизитыОсновное");
	ЗависимыеОтСтатусаИСМП.Добавить("ГруппаНередактируемыеПослеОтправкиКомандыТовары");
	ЗависимыеОтСтатусаИСМП.Добавить("СтраницаТовары");
	ЗависимыеОтСтатусаИСМП.Добавить("ГруппаНередактируемыеПослеОтправкиУведомлениеОбЭкспорте");
	
	ОбщегоНазначенияИСКлиентСервер.УстановитьДоступностьЭлементовФормы(Форма,
		ЗависимыеОтСтатусаИСМП, Не Форма.РедактированиеФормыНеДоступно);
	
	ЗависимыеОтСтатусаПроверкиИПодбора = Новый Массив;
	ЗависимыеОтСтатусаПроверкиИПодбора.Добавить("ТоварыПодменюЗаполнить");
	ЗависимыеОтСтатусаПроверкиИПодбора.Добавить("ГруппаТорговоеОборудование");
	ЗависимыеОтСтатусаПроверкиИПодбора.Добавить("ТоварыНоменклатура");
	ЗависимыеОтСтатусаПроверкиИПодбора.Добавить("ТоварыХарактеристика");
	ЗависимыеОтСтатусаПроверкиИПодбора.Добавить("ТоварыСерия");
	ЗависимыеОтСтатусаПроверкиИПодбора.Добавить("ТоварыКоличествоУпаковок");
	ЗависимыеОтСтатусаПроверкиИПодбора.Добавить("ТоварыУпаковкаЕдиницаИзмерения");
	ЗависимыеОтСтатусаПроверкиИПодбора.Добавить("ТоварыДобавить");
	ЗависимыеОтСтатусаПроверкиИПодбора.Добавить("ТоварыСкопировать");
	ЗависимыеОтСтатусаПроверкиИПодбора.Добавить("ТоварыИзменить");
	ЗависимыеОтСтатусаПроверкиИПодбора.Добавить("ТоварыУдалить");
	ЗависимыеОтСтатусаПроверкиИПодбора.Добавить("ТоварыКонтекстноеМенюДобавить");
	ЗависимыеОтСтатусаПроверкиИПодбора.Добавить("ТоварыКонтекстноеМенюСкопировать");
	ЗависимыеОтСтатусаПроверкиИПодбора.Добавить("ТоварыКонтекстноеМенюИзменить");
	ЗависимыеОтСтатусаПроверкиИПодбора.Добавить("ТоварыКонтекстноеМенюУдалить");

	ОбщегоНазначенияИСКлиентСервер.УстановитьДоступностьЭлементовФормы(Форма,
		ЗависимыеОтСтатусаПроверкиИПодбора,
		Не (Форма.РедактированиеФормыНеДоступно Или РедактированиеНедоступноПоСтатусуПроверкиИПодбора(Форма)));
	
	ВидимостьКолонокЦен = ВыводИзОборотаКлиентСервер.ДоступноПолеЦена(ВидыПродукцииПоТоварнойГруппе, Объект.Причина);
	
	Элементы.ТоварыЦена.Видимость      = ВидимостьКолонокЦен;
	Элементы.ТоварыСумма.Видимость     = ВидимостьКолонокЦен;
	Элементы.ТоварыСтавкаНДС.Видимость = ВидимостьКолонокЦен;
	Элементы.ТоварыСуммаНДС.Видимость  = ВидимостьКолонокЦен;
	Элементы.ТоварыСуммаСНДС.Видимость = ВидимостьКолонокЦен;
	
	Элементы.Контрагент.ОтметкаНезаполненного               = Ложь;
	Элементы.АдресПлощадкиСтрокой.ОтметкаНезаполненного     = Ложь;
	Элементы.ВидПервичногоДокумента.ОтметкаНезаполненного   = Ложь;
	Элементы.ДатаПервичногоДокумента.ОтметкаНезаполненного  = Ложь;
	Элементы.НомерПервичногоДокумента.ОтметкаНезаполненного = Ложь;
	
	Элементы.ТранспортноеСредство.Видимость = Форма.УказываетсяТранспортноеСредство;
	Если Форма.УказываетсяТранспортноеСредство Тогда
		Элементы.НомерТранспортногоСредства.Заголовок = НСтр("ru = '№'");
	Иначе
		Элементы.НомерТранспортногоСредства.Заголовок = НСтр("ru = 'Номер транспортного средства'");
	КонецЕсли;
		
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Функция РедактированиеНедоступноПоСтатусуПроверкиИПодбора(Форма)
	
	Если Форма.СтатусПроверкиИПодбора = ПредопределенноеЗначение("Перечисление.СтатусыПроверкиИПодбораИС.Выполняется")
		Или Форма.СтатусПроверкиИПодбора = ПредопределенноеЗначение("Перечисление.СтатусыПроверкиИПодбораИС.Завершено") Тогда
		Возврат Истина;
	Иначе
		Возврат Ложь;
	КонецЕсли;
	
КонецФункции

&НаСервере
Процедура ТоварыПослеУдаленияСервер()
	
	ПрименитьКешШтрихкодовУпаковок();
	ШтрихкодированиеИС.ОбновитьКэшМаркируемойПродукции(ЭтотОбъект);
	
КонецПроцедуры

#Область Оборудование

&НаКлиенте
Процедура ПодключитьОборудованиеЗавершение(РезультатВыполнения, Параметры) Экспорт

	Если Не РезультатВыполнения.Результат Тогда
		ТекстСообщения = НСтр( "ru = 'При подключении оборудования произошла ошибка:""%ОписаниеОшибки%"".'");
		ТекстСообщения = СтрЗаменить(ТекстСообщения, "%ОписаниеОшибки%" , РезультатВыполнения.ОписаниеОшибки);
		ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения);
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ОтключитьОборудованиеЗавершение(РезультатВыполнения, Параметры) Экспорт
	
	Если Не РезультатВыполнения.Результат Тогда
		ТекстСообщения = НСтр( "ru = 'При отключении оборудования произошла ошибка: ""%ОписаниеОшибки%"".'");
		ТекстСообщения = СтрЗаменить(ТекстСообщения, "%ОписаниеОшибки%" , РезультатВыполнения.ОписаниеОшибки);
		ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения);
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область Штрихкодирование

&НаКлиенте
Функция ОписаниеОповещенияОбработкиКодаМаркировки()
	
	Возврат Новый ОписаниеОповещения("ОбработатьКодМаркировки", ЭтотОбъект);
	
КонецФункции

&НаКлиенте
Процедура ПослеОбработкиШтрихкодов(Результат, ДополнительныеПараметры) Экспорт
	
	Если ЗначениеЗаполнено(Объект.ДокументОснование) Тогда
		Если ДанныеВыбораПоМаркируемойПродукции<>Неопределено Тогда
			КлючиСвязи = Новый Структура(КлючСвязиСтатусаСтрок(ДанныеВыбораПоМаркируемойПродукции.Номенклатура));
			КлючиСвязи.Вставить("Номенклатура");
			КлючиСвязи.Вставить("Характеристика");
			КлючиСвязи.Вставить("Серия");
			ЗаполнитьЗначенияСвойств(КлючиСвязи, ДанныеВыбораПоМаркируемойПродукции);
			СтрокиТовар = Объект.Товары.НайтиСтроки(КлючиСвязи);
			Если СтрокиТовар.Количество() И СтрокиТовар[0].СтатусПроверкиГосИС = 1 Тогда
				ШтрихкодированиеИСКлиентСервер.ОбработатьСохраненныйВыборДанныхПоМаркируемойПродукции(ЭтотОбъект,,Ложь);
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Функция ПараметрыЗавершенияВводаШтрихкода(ИсходныеДанные, РезультатОбработки, ПараметрыСканирования)
	
	ПараметрыЗавершенияВводаШтрихкода = ШтрихкодированиеОбщегоНазначенияИСКлиент.ПараметрыЗавершенияОбработкиШтрихкода();
	ПараметрыЗавершенияВводаШтрихкода.РезультатОбработкиШтрихкода  = РезультатОбработки;
	ПараметрыЗавершенияВводаШтрихкода.Форма                        = ЭтотОбъект;
	ПараметрыЗавершенияВводаШтрихкода.ПараметрыСканирования        = ПараметрыСканирования;
	ПараметрыЗавершенияВводаШтрихкода.ДанныеШтрихкода              = ИсходныеДанные;
	
	Возврат ПараметрыЗавершенияВводаШтрихкода;
	
КонецФункции

&НаСервере
Функция ОбработатьВводШтрихкода(ШтрихкодКоличество, КэшированныеЗначения, ПараметрыСканирования = Неопределено)
	
	РезультатОбработкиШтрихкода = ШтрихкодированиеОбщегоНазначенияИС.ОбработатьВводШтрихкода(
		ЭтотОбъект, ШтрихкодКоличество, КэшированныеЗначения, ПараметрыСканирования);
		
	ПослеОбработкиШтрихкодовСервер(РезультатОбработкиШтрихкода, КэшированныеЗначения);
	
	РезультатОбработкиШтрихкода.ИзмененныеСтроки  = Новый Массив;
	РезультатОбработкиШтрихкода.ДобавленныеСтроки = Новый Массив;
	
	Возврат РезультатОбработкиШтрихкода;
	
КонецФункции

&НаКлиенте
Процедура ОбработкаКодаМаркировкиВыполнитьДействие(ДанныеДляВыполненияДействия, ДополнительныеПараметры) Экспорт
	
	РезультатВыбора             = ДанныеДляВыполненияДействия.РезультатВыбора;
	РезультатОбработкиШтрихкода = ДанныеДляВыполненияДействия.РезультатОбработкиШтрихкода;
	КэшированныеЗначения        = ДанныеДляВыполненияДействия.КэшированныеЗначения;
	ПараметрыСканирования       = ДанныеДляВыполненияДействия.ПараметрыСканирования;
	
	Действие = ДанныеДляВыполненияДействия.Действие;
	РезультатОбработкиШтрихкода = ОбработкаКодаМаркировкиВыполнитьДействиеСервер(Действие, РезультатВыбора, РезультатОбработкиШтрихкода, ПараметрыСканирования, КэшированныеЗначения);
	
	ПараметрыЗавершенияВводаШтрихкода = ПараметрыЗавершенияВводаШтрихкода(
		ДанныеДляВыполненияДействия.ИсходныеДанные, РезультатОбработкиШтрихкода, ДанныеДляВыполненияДействия.ПараметрыСканирования);
	ШтрихкодированиеОбщегоНазначенияИСКлиент.ЗавершитьОбработкуШтрихкода(ПараметрыЗавершенияВводаШтрихкода);
	
КонецПроцедуры

&НаСервере
Функция ОбработкаКодаМаркировкиВыполнитьДействиеСервер(Действие, РезультатВыбора, РезультатОбработкиШтрихкода, ПараметрыСканирования, КэшированныеЗначения)
	
	ПараметрыОбработкиВыбора    = ШтрихкодированиеОбщегоНазначенияИС.ИнициализироватьПараметрыОбработкиВыбора(РезультатВыбора, РезультатОбработкиШтрихкода, КэшированныеЗначения);
	РезультатОбработкиШтрихкода = ШтрихкодированиеИС.ВыполнитьДействие(ЭтотОбъект, Действие, ПараметрыОбработкиВыбора);
	
	ПослеОбработкиШтрихкодовСервер(РезультатОбработкиШтрихкода, КэшированныеЗначения);
	
	РезультатОбработкиШтрихкода.ИзмененныеСтроки  = Новый Массив;
	РезультатОбработкиШтрихкода.ДобавленныеСтроки = Новый Массив;
	
	Возврат РезультатОбработкиШтрихкода;
	
КонецФункции

&НаСервере
Процедура ПослеОбработкиШтрихкодовСервер(РезультатОбработкиШтрихкода, КэшированныеЗначения)
	
	ПрименитьКешШтрихкодовУпаковок();
	ШтрихкодированиеИС.ОбновитьКэшМаркируемойПродукции(ЭтотОбъект);
	
	ИзмененныеСтроки  = РезультатОбработкиШтрихкода.ИзмененныеСтроки;
	ДобавленныеСтроки = РезультатОбработкиШтрихкода.ДобавленныеСтроки;
	
	Если ДобавленныеСтроки.Количество() = 0 И ИзмененныеСтроки.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	Для Каждого ДобавленнаяСтрока Из ДобавленныеСтроки Цикл
		
		СобытияФормИСМППереопределяемый.ПриИзмененииНоменклатуры(
			ЭтотОбъект, ДобавленнаяСтрока, Неопределено, ПараметрыУказанияСерий);
		
	КонецЦикла;
	
	Для Каждого ИзмененнаяСтрока Из ИзмененныеСтроки Цикл
		
		СобытияФормИСМППереопределяемый.ПриИзмененииКоличества(
			ЭтотОбъект, ИзмененнаяСтрока, Неопределено, ПараметрыУказанияСерий);
		
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура Подключаемый_ОткрытьФормуУточненияДанных() Экспорт
	
	ШтрихкодированиеИСКлиент.Подключаемый_ОткрытьФормуУточненияДанных(ЭтотОбъект, ОписаниеОповещенияОбработкиКодаМаркировки());
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработатьКодМаркировки(ИсходныеДанные, ДополнительныеПараметры = Неопределено) Экспорт
	
	Если ИсходныеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ПараметрыСканирования = ШтрихкодированиеОбщегоНазначенияИСКлиент.ПараметрыСканирования(ЭтотОбъект);
	ШтрихкодированиеОбщегоНазначенияИСКлиентСервер.ЗакодироватьШтрихкодДанныхBase64(ИсходныеДанные);
	
	РезультатОбработки = ОбработатьВводШтрихкода(ИсходныеДанные, Неопределено, ПараметрыСканирования);
	
	ПараметрыЗавершенияВводаШтрихкода = ПараметрыЗавершенияВводаШтрихкода(ИсходныеДанные, РезультатОбработки, ПараметрыСканирования);
	ШтрихкодированиеОбщегоНазначенияИСКлиент.ЗавершитьОбработкуШтрихкода(ПараметрыЗавершенияВводаШтрихкода);
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Функция КлючСвязиСтатусаСтрок(Номенклатура = Неопределено)
	
	МассивКлючейСвязи = Новый Массив;
	
	Если Не ЗначениеЗаполнено(Номенклатура) Тогда
		МассивКлючейСвязи.Добавить("GTIN");
	КонецЕсли;
	
	Возврат СтрСоединить(МассивКлючейСвязи, ", ");
	
КонецФункции

#КонецОбласти

#Область КэшСтроки

&НаСервере
Функция НастройкиКешаШтрихкодовУпаковок()
	
	Настройки = ПроверкаИПодборПродукцииИС.НастройкиИсточникаКешаШтрихкодовУпаковок(Истина);
	Операция  = Перечисления.ВидыОперацийИСМП.ВыводИзОборота;
	Если Не Объект.ОбъемноСортовойУчет
		И КонструкторИСОбщегоНазначенияКлиентСервер.ПоддерживаетсяЧастичноеВыбытие(Объект.ТоварнаяГруппа, Операция)
		И КонструкторИСМПКлиентСервер.ПоддерживаетсяЧастичноеВыбытиеПриВыводеИзОборота(Объект.ТоварнаяГруппа, Объект.Причина) Тогда
		Настройки.ЧастичноеВыбытие = Истина;
	КонецЕсли;
	
	Возврат Настройки;
	
КонецФункции

&НаСервере
Процедура ПрименитьКешШтрихкодовУпаковок()
	
	Если Не РедактированиеФормыНедоступно Тогда
		ПроверкаИПодборПродукцииИС.ПрименитьКешШтрихкодовУпаковок(ЭтотОбъект, НастройкиКешаШтрихкодовУпаковок(), Истина);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Процедура ИнициализироватьКэшСтроки(Форма)

	Форма.ДанныеКешаСтроки = Новый Структура;
	Форма.ДанныеКешаСтроки.Вставить("Номенклатура");
	Форма.ДанныеКешаСтроки.Вставить("Характеристика");
	Форма.ДанныеКешаСтроки.Вставить("Серия");
	Форма.ДанныеКешаСтроки.Вставить("КоличествоУпаковок");
	Форма.ДанныеКешаСтроки.Вставить("Количество");

КонецПроцедуры

#КонецОбласти

#Область ФормаПроверкиИПодбора

&НаСервере
Процедура ОбновитьИнформациюОткрытияФормыПроверкиПодбора()
	
	Элементы.ГруппаИнформацияОСканированииВДругойФорме.Видимость = Ложь;
	ТекстНадписи = "";
	
	СтатусПроверкиИПодбора = РегистрыСведений.СтатусыПроверкиИПодбораИС.ТекущийСтатус(Объект.Ссылка, 0);
	
	Если Объект.ОбъемноСортовойУчет Тогда
		
	ИначеЕсли СтатусПроверкиИПодбора = Перечисления.СтатусыПроверкиИПодбораИС.Выполняется Тогда
		
		Если ПравоИзменения Тогда
			Элементы.ГруппаИнформацияОСканированииВДругойФорме.Видимость = Истина;
			ТекстНадписи = НСтр("ru = 'Продолжить подбор и проверку маркированной продукции'");
		Иначе
			ТекстНадписи = НСтр("ru = 'Промежуточные результаты подбора маркированной продукции'");
		КонецЕсли;
		
	ИначеЕсли СтатусИСМП = Перечисления.СтатусыОбработкиВыводаИзОборотаИСМП.Черновик
		Или СтатусИСМП = Перечисления.СтатусыОбработкиВыводаИзОборотаИСМП.ОшибкаПередачи Тогда
			
		Если СтатусПроверкиИПодбора = Перечисления.СтатусыПроверкиИПодбораИС.Завершено Тогда
			ТекстНадписи = НСтр("ru = 'Результаты подбора маркированной продукции'");
		ИначеЕсли ПравоИзменения Тогда
			ТекстНадписи = НСтр("ru = 'Подобрать и проверить маркированную продукцию'");
		КонецЕсли;
		
	ИначеЕсли СтатусПроверкиИПодбора = Перечисления.СтатусыПроверкиИПодбораИС.ПустаяСсылка() Тогда
		
	Иначе
		ТекстНадписи = НСтр("ru = 'Результаты подбора маркированной продукции'");
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ТекстНадписи) Тогда
		Элементы.ТоварыОткрытьФормуПроверкиИПодбора.Заголовок = ТекстНадписи;
		Элементы.ТоварыОткрытьФормуПроверкиИПодбора.Видимость = Истина;
	Иначе
		Элементы.ТоварыОткрытьФормуПроверкиИПодбора.Видимость = Ложь;
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

&НаСервере
Процедура ОбновитьПредставленияНаФорме(Прочитать = Ложь)

	Если Прочитать Тогда
		Прочитать();
	Иначе
		ОбновитьСтатусИСМП();
	КонецЕсли;

	ОбновитьИнформациюОткрытияФормыПроверкиПодбора();

КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Процедура НастроитьЗависимыеЭлементыФормы(Форма, СписокРеквизитов = "")
	
	Элементы = Форма.Элементы;
	Объект   = Форма.Объект;
	ВидыПродукцииПоТоварнойГруппе = КонструкторИСМПОбщегоНазначенияКлиентСервер.ВидыПродукцииПоТоварнойГруппе(Объект.ТоварнаяГруппа);
	
	Инициализация = ПустаяСтрока(СписокРеквизитов);
	СтруктураРеквизитов = Новый Структура(СписокРеквизитов);
	
	Если СтруктураРеквизитов.Свойство("ДокументОснование")
		Или СтруктураРеквизитов.Свойство("Причина") Тогда
		ПодключаемыеКомандыИСКлиентСервер.УправлениеВидимостьюКомандПодключенныхКОбъекту(Форма);
		Элементы.ТоварыПерезаполнитьПоОснованию.Доступность = ЗначениеЗаполнено(Объект.ДокументОснование);
	КонецЕсли;
	
	Если Инициализация
		Или СтруктураРеквизитов.Свойство("ТоварнаяГруппа") Тогда
		
		СтруктураРеквизитов.Вставить("Причина");
		СтруктураРеквизитов.Вставить("ВидУчета");
		СтруктураРеквизитов.Вставить("ИспользуетсяМОД");
		
		ЭтоСырьеГИСМТ = КонструкторИСМПКлиентСервер.ЭтоСырьеГИСМТ(ВидыПродукцииПоТоварнойГруппе);
		Элементы.ВидУчета.Видимость = ВыводИзОборотаКлиентСервер.ДоступноПолеОСУ(ВидыПродукцииПоТоварнойГруппе)
			И Не ЭтоСырьеГИСМТ;
		Элементы.ТоварыСырье.Видимость = ЭтоСырьеГИСМТ;
		Элементы.ЗаполнитьТипСырьяПоОстаткам.Видимость = ЭтоСырьеГИСМТ;
		
		Если КонструкторИСОбщегоНазначенияКлиентСервер.ЭтоПродукцияМОТП(ВидыПродукцииПоТоварнойГруппе) Тогда
			Элементы.ПроизводственныйОбъект.Заголовок = НСтр("ru = 'Площадка'");
			Элементы.АдресПлощадкиСтрокой.Заголовок   = НСтр("ru = 'Адрес площадки'");
			Элементы.ДатаПервичногоДокумента.ФорматРедактирования = "";
		Иначе
			Элементы.ПроизводственныйОбъект.Заголовок = НСтр("ru = 'Подразделение'");
			Элементы.АдресПлощадкиСтрокой.Заголовок   = НСтр("ru = 'Адрес'");
			Элементы.ДатаПервичногоДокумента.ФорматРедактирования = "ДФ=dd.MM.yyyy;";
		КонецЕсли;
		
	КонецЕсли;

	ЭтоОбъемноСортовойУчет = Объект.ОбъемноСортовойУчет;
	Если Инициализация
		Или СтруктураРеквизитов.Свойство("ВидУчета") Тогда
		
		ДоступноПолеGTIN = МаркировкаТоваровКлиентСервер.ДоступноПолеGTIN(
			ВидыПродукцииПоТоварнойГруппе,
			ПредопределенноеЗначение("Перечисление.ВидыОперацийИСМП.ВыводИзОборота"));
		
		Элементы.ЗаполнитьДоступныеGTIN.Видимость             = ЭтоОбъемноСортовойУчет И ДоступноПолеGTIN;
		Элементы.ТоварыGTIN.Видимость                         = ЭтоОбъемноСортовойУчет И ДоступноПолеGTIN;
		Элементы.ТоварыСтатусПроверкиГосИС.Видимость          = Не (Форма.РедактированиеФормыНеДоступно Или ЭтоОбъемноСортовойУчет);
		Элементы.ТоварыОткрытьФормуПроверкиИПодбора.Видимость = (Не ЭтоОбъемноСортовойУчет);
		
		Элементы.Причина.СписокВыбора.Очистить();
		Причины = ВыводИзОборотаКлиентСервер.ДоступныеПричиныВыводаИзОборота(ЭтоОбъемноСортовойУчет, ВидыПродукцииПоТоварнойГруппе);
		Для Каждого Причина Из Причины Цикл
			Элементы.Причина.СписокВыбора.Добавить(Причина);
		КонецЦикла;
		
		Если Не ЗначениеЗаполнено(Объект.Причина)
			И Объект.УдалитьОперация = ПредопределенноеЗначение("Перечисление.ВидыОперацийИСМП.УдалитьВыводИзОборотаРеализацияНезарегистрированномуУчастнику") Тогда
			Элементы.Причина.СписокВыбора.Добавить(Объект.Причина, НСтр( "ru = 'Реализация незарегистрированному участнику'"));
			Элементы.Причина.ОтметкаНезаполненного   = Ложь;
			Элементы.Причина.АвтоВыборНезаполненного = Ложь;
		КонецЕсли;
		
		Элементы.Причина.СписокВыбора.СортироватьПоЗначению();
		
	КонецЕсли;
	
	Если Инициализация
		Или СтруктураРеквизитов.Свойство("ВидУчета")
		Или СтруктураРеквизитов.Свойство("Причина") Тогда
		
		СтруктураРеквизитов.Вставить("ВидПервичногоДокумента");
		СтруктураРеквизитов.Вставить("ИспользуетсяМОД");
		
		Элементы.ВидПервичногоДокумента.СписокВыбора.Очистить();
	
		ДоступноПолеВидПервичногоДокумента = ВыводИзОборотаКлиентСервер.ДоступноПолеВидПервичногоДокумента(ВидыПродукцииПоТоварнойГруппе, Объект.Причина);
	
		Если ДоступноПолеВидПервичногоДокумента Тогда
			ВидыПервичныхДокументов = ДоступныеВидыПервичныхДокументов(Объект.Причина);
			Элементы.ВидПервичногоДокумента.СписокВыбора.ЗагрузитьЗначения(ВидыПервичныхДокументов);
			Элементы.ВидПервичногоДокумента.СписокВыбора.СортироватьПоЗначению();
		КонецЕсли;
	
		Элементы.ВидПервичногоДокумента.Видимость = ДоступноПолеВидПервичногоДокумента;
		
		ПроверятьЗаполнениеПоляВидПервичногоДокумента = ВыводИзОборотаКлиентСервер.ПроверятьЗаполнениеПоляВидПервичногоДокумента(
			ВидыПродукцииПоТоварнойГруппе, Объект.Причина);
		
		Элементы.ВидПервичногоДокумента.АвтоОтметкаНезаполненного   = ПроверятьЗаполнениеПоляВидПервичногоДокумента;
		
		ДоступноПолеНомерДатаПервичногоДокумента = МаркировкаТоваровКлиентСервер.ДоступноПолеНомерДатаПервичногоДокумента(
			ВидыПродукцииПоТоварнойГруппе, Объект.Причина);
		
		ПроверятьЗаполнениеПоляНомерДатаПервичногоДокумента = МаркировкаТоваровКлиентСервер.ПроверятьЗаполнениеПоляНомерДатаПервичногоДокумента(
			ВидыПродукцииПоТоварнойГруппе, Объект.Причина);
			
		Элементы.НомерПервичногоДокумента.Видимость = ДоступноПолеНомерДатаПервичногоДокумента;
		Элементы.ДатаПервичногоДокумента.Видимость = ДоступноПолеНомерДатаПервичногоДокумента;
		Элементы.ДатаПервичногоДокумента.АвтоОтметкаНезаполненного  = ПроверятьЗаполнениеПоляНомерДатаПервичногоДокумента;
		Элементы.НомерПервичногоДокумента.АвтоОтметкаНезаполненного = ПроверятьЗаполнениеПоляНомерДатаПервичногоДокумента;
		
		Элементы.ИдентификаторГосударственногоКонтракта.Видимость = 
			ВыводИзОборотаКлиентСервер.ДоступноПолеИдентификатораГосударственногоКонтракта(ВидыПродукцииПоТоварнойГруппе, Объект.Причина);
		
		Элементы.ОписаниеПричины.Видимость = ВыводИзОборотаКлиентСервер.ДоступноПолеОписаниеПричины(ВидыПродукцииПоТоварнойГруппе, Объект.Причина);
		
		ИспользуетсяАдрес = ВыводИзОборотаКлиентСервер.ДоступноПолеАдрес(ВидыПродукцииПоТоварнойГруппе, Объект.Причина);
		Элементы.АдресПлощадкиСтрокой.Видимость = ИспользуетсяАдрес;
		
		Элементы.АдресПлощадкиСтрокой.АвтоОтметкаНезаполненного = 
			ВыводИзОборотаКлиентСервер.ПроверятьЗаполнениеПоляАдрес(ВидыПродукцииПоТоварнойГруппе, Объект.Причина);
		
		Элементы.ТоварыЦенаИСуммы.Видимость = ВыводИзОборотаКлиентСервер.ДоступноПолеЦена(ВидыПродукцииПоТоварнойГруппе, Объект.Причина);
		
		Элементы.Контрагент.Видимость                           = МаркировкаТоваровКлиентСервер.ДоступноПолеКонтрагент(ВидыПродукцииПоТоварнойГруппе, Объект.Причина);
		Элементы.Контрагент.АвтоОтметкаНезаполненного           = МаркировкаТоваровКлиентСервер.ПроверятьЗаполнениеПоляКонтрагент(ВидыПродукцииПоТоварнойГруппе, Объект.Причина);
		
		Элементы.СтранаНазначения.Видимость = ВыводИзОборотаКлиентСервер.ДоступноПолеСтранаНазначения(ВидыПродукцииПоТоварнойГруппе, Объект.Причина);
		Элементы.НомерТаможеннойДекларации.Видимость = МаркировкаТоваровКлиентСервер.ДоступноПолеТаможеннаяДекларация(ВидыПродукцииПоТоварнойГруппе, Объект.Причина);
		
		ДоступноУведомлениеОбОтгрузкеНаЭкспорт = ВыводИзОборотаКлиентСервер.ДоступноУведомлениеОбОтгрузкеНаЭкспорт(
			ВидыПродукцииПоТоварнойГруппе, Объект.Причина);
		Элементы.СтраницаУведомлениеОбЭкспорте.Видимость = ДоступноУведомлениеОбОтгрузкеНаЭкспорт;
		
		Если ДоступноУведомлениеОбОтгрузкеНаЭкспорт Тогда
			СтруктураРеквизитов.Вставить("УведомитьОбОтгрузкеНаЭкспорт");
		КонецЕсли;
		
		Элементы.ФормаОтменитьУведомлениеОбОтгрузкеНаЭкспорт.Видимость = ДоступноУведомлениеОбОтгрузкеНаЭкспорт
			И Объект.УведомитьОбОтгрузкеНаЭкспорт;
		Элементы.ФормаОтменитьУведомлениеОбОтгрузкеНаЭкспорт.Доступность = ДоступноУведомлениеОбОтгрузкеНаЭкспорт
			И Объект.УведомитьОбОтгрузкеНаЭкспорт
			И ДоступнаОперацияОтменаУведомления(Форма.ДальнейшееДействие1);
		
	КонецЕсли;
	
	Если Инициализация
		Или СтруктураРеквизитов.Свойство("ВидПервичногоДокумента") Тогда
		
		Если ДоступноПолеВидПервичногоДокумента = Неопределено Тогда
			ДоступноПолеВидПервичногоДокумента = ВыводИзОборотаКлиентСервер.ДоступноПолеВидПервичногоДокумента(ВидыПродукцииПоТоварнойГруппе, Объект.Причина);
		КонецЕсли;
		
		Элементы.НаименованиеПервичногоДокумента.Видимость = ДоступноПолеВидПервичногоДокумента 
			И (Объект.ВидПервичногоДокумента = ПредопределенноеЗначение("Перечисление.ВидыПервичныхДокументовИСМП.Прочее"));
		
	КонецЕсли;

	Если СтруктураРеквизитов.Свойство("УведомитьОбОтгрузкеНаЭкспорт") Тогда
		
		Элементы.ГруппаУведомлениеОбЭкспорт.Видимость = Объект.УведомитьОбОтгрузкеНаЭкспорт;
		Если Объект.УведомитьОбОтгрузкеНаЭкспорт Тогда
			
			СтруктураРеквизитов.Вставить("ТранспортныйДокумент");
			
			ИспользованиеКонтрагентаПриВыводеИзОборота = МаркировкаТоваровКлиентСервер.ДоступноПолеКонтрагент(
				ВидыПродукцииПоТоварнойГруппе, Объект.Причина);
			ИспользованиеКонтрагента = Не ИспользованиеКонтрагентаПриВыводеИзОборота
				И МаркировкаТоваровКлиентСервер.ДоступноПолеКонтрагент(
					ВидыПродукцииПоТоварнойГруппе,
					ПредопределенноеЗначение("Перечисление.ВидыОперацийИСМП.УведомлениеОбОтгрузкеНаЭкспорт"));
			Элементы.ГруппаИмпортер.Видимость = ИспользованиеКонтрагента;
		
		КонецЕсли;
		
		Элементы.ТранспортноеСредство.АвтоОтметкаНезаполненного = Форма.УказываетсяТранспортноеСредство
			И Объект.УведомитьОбОтгрузкеНаЭкспорт;
		Элементы.НомерТранспортногоСредства.АвтоОтметкаНезаполненного = Объект.УведомитьОбОтгрузкеНаЭкспорт;
		Элементы.ДатаОтгрузки.АвтоОтметкаНезаполненного = Объект.УведомитьОбОтгрузкеНаЭкспорт;
		
	КонецЕсли;
	
	Если СтруктураРеквизитов.Свойство("ТранспортныйДокумент") Тогда
	
		ЭтоЭПД = Объект.ТранспортныйДокумент;
		Элементы.ГруппаНомерДатаТТН.Видимость = Не ЭтоЭПД;
		Элементы.НомерПеревозочногоДокумента.АвтоОтметкаНезаполненного = Не ЭтоЭПД;
		Элементы.ДатаПеревозочногоДокумента.АвтоОтметкаНезаполненного  = Не ЭтоЭПД;
		Элементы.ГруппаТранспортноеСредство.Видимость = Не ЭтоЭПД;
		
		Элементы.ИдентификаторЭлектронногоПеревозочногоДокумента.Видимость = ЭтоЭПД;
		Элементы.ИдентификаторЭлектронногоПеревозочногоДокумента.АвтоОтметкаНезаполненного = ЭтоЭПД;
	
	КонецЕсли;
	
	Если Инициализация 
		Или СтруктураРеквизитов.Свойство("ИспользуетсяМОД") Тогда
		
		ПараметрыУказанияМОД = ВыводИзОборотаКлиентСервер.ПараметрыУказанияМОД(Объект.Организация,
			ВидыПродукцииПоТоварнойГруппе, Объект.Причина);
		
		Элементы.ГруппаАдресМОД.Видимость                           = ПараметрыУказанияМОД.ВозможноУказаниеМОД;
		Элементы.ИспользуетсяМОД.Доступность                        = Не ПараметрыУказанияМОД.ОбязательноУказаниеМОД;
		Элементы.ОписаниеПричиныОбязательностиУказанияМОД.Видимость = ПараметрыУказанияМОД.ОбязательноУказаниеМОД;
		
		Если ПараметрыУказанияМОД.ОбязательноУказаниеМОД Тогда
			Объект.ИспользуетсяМОД = Истина;
			
			Если ПараметрыУказанияМОД.ПодконтрольныеОбъектыВетИС Тогда
				ОписаниеОбязательностиМОД = НСтр("ru = 'Имеются подконтрольные объекты ВетИС'");
			Иначе
				ОписаниеОбязательностиМОД = НСтр("ru = 'Обязательно для выбранной товарной группы и причины вывода из оборота'");
			КонецЕсли;
			
			Элементы.ОписаниеПричиныОбязательностиУказанияМОД.Заголовок = ОписаниеОбязательностиМОД;
			
		КонецЕсли;
		
		Элементы.ГруппаАдресСтатусПроверки.Видимость = Объект.ИспользуетсяМОД;
		
		ЭтоИндивидуальныйПредприниматель = ОбщегоНазначенияИСВызовСервера.ПартнерОрганизацияЭтоИндивидуальныйПредприниматель(Объект.Организация);
		
		Элементы.ПодразделениеКПП.Видимость       = Не ЭтоИндивидуальныйПредприниматель;
		Элементы.ПроизводственныйОбъект.Видимость = Не ЭтоИндивидуальныйПредприниматель;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Функция ДоступнаОперацияОтменаУведомления(ДальнейшееДействие)
	
	Результат = Ложь;
	Если ДальнейшееДействие = ПредопределенноеЗначение("Перечисление.ДальнейшиеДействияПоВзаимодействиюИСМП.ПередайтеДанные") Тогда
		Результат = Истина;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

#Область РаботаСАдресами

&НаСервере
Процедура ИнициализироватьПоляКонтактнойИнформации()
	
	ВидКонтактнойИнформацииАдресаПроизводственногоОбъекта = УправлениеКонтактнойИнформацией.ПараметрыВидаКонтактнойИнформации(Перечисления.ТипыКонтактнойИнформации.Адрес);
	
	// Считываем данные из полей адреса в реквизиты для редактирования.
	Объект.АдресПлощадкиСтрокой = УправлениеКонтактнойИнформацией.ПредставлениеКонтактнойИнформации(
		Объект.АдресПлощадки);
	КомментарийАдресаПлощадки = ОбщегоНазначенияИС.КомментарийКонтактнойИнформации(
		Объект.АдресПлощадки);

КонецПроцедуры

&НаСервере
Процедура ОбновитьСтатусПроверкиМОД(ВыбранДоступныйМОД=Ложь)
	
	Если Не Объект.ИспользуетсяМОД Тогда
		Возврат;
	КонецЕсли;
	
	ПроверкаНеВыполнялась = Истина;
	МОДЗарегистрирован    = Ложь;
	РегистрацияНеДоступна = Не ВыводИзОборотаКлиентСервер.ДоступнаРегистрацияМОДВГИСМТ(Объект.ТоварнаяГруппа);
	
	Если ВыбранДоступныйМОД Тогда
		МОДЗарегистрирован    = Истина;
		ПроверкаНеВыполнялась = Ложь;

	ИначеЕсли ЗначениеЗаполнено(Объект.Организация) И ЗначениеЗаполнено(Объект.ТоварнаяГруппа) Тогда
		СписокМОД = Неопределено;
		
		Если ЗначениеЗаполнено(Объект.АдресПлощадки) Тогда

			КодФИАС = ОбщегоНазначенияИСМП.ИдентификаторФИАСПоДаннымАдреса(Объект.АдресПлощадки).Идентификатор;

			Если КодФИАС <> Неопределено Тогда
				ПодразделениеКППОтбор = "";
				
				Если Не КонструкторИСМПКлиентСервер.ЭтоСырьеГИСМТ(Объект.ТоварнаяГруппа) Тогда
					ПодразделениеКППОтбор = ПодразделениеКПП;
				КонецЕсли;
				
				СписокМОД = РегистрыСведений.МестаОсуществленияДеятельностиИСМП.СписокЗарегистрированныхМестОсуществленияДеятельности(
				Объект.Организация, Объект.ТоварнаяГруппа, ПодразделениеКППОтбор, КодФИАС, , Истина);

				ПроверкаНеВыполнялась = Ложь;

				Если СписокМОД.Количество() > 0 Тогда
					МОДЗарегистрирован = Истина;
				КонецЕсли;

			КонецЕсли;

		ИначеЕсли ЗначениеЗаполнено(ПодразделениеКПП) Тогда
			СписокМОД = РегистрыСведений.МестаОсуществленияДеятельностиИСМП.СписокЗарегистрированныхМестОсуществленияДеятельности(
				Объект.Организация, Объект.ТоварнаяГруппа, ПодразделениеКПП);
				
			ПроверкаНеВыполнялась = Ложь;

		КонецЕсли;
		
		Если СписокМОД <> Неопределено И СписокМОД.Количество() > 0 Тогда
			МОДЗарегистрирован = Истина;
		КонецЕсли;

	КонецЕсли;
	
	Гиперссылка = "";
	
	Если ПроверкаНеВыполнялась Тогда
		ТекстСтатуса = НСтр("ru = 'Не проверен'");
		ЦветТекста   = ЦветаСтиля.ЦветГиперссылкиГосИС;
	ИначеЕсли МОДЗарегистрирован Тогда
		ТекстСтатуса = НСтр("ru = 'Проверен в ГИС МТ'");
		ЦветТекста   = ЦветаСтиля.ЦветГиперссылкиГосИС;
	ИначеЕсли РегистрацияНеДоступна Тогда
		ТекстСтатуса = НСтр("ru = 'Отсутствует в ГИС МТ'");
		ЦветТекста   = ЦветаСтиля.ЦветТекстаТребуетВниманияГосИС;
	Иначе
		ТекстСтатуса = НСтр("ru = 'Зарегистрировать в ГИС МТ'");
		ЦветТекста   = ЦветаСтиля.ЦветТекстаТребуетВниманияГосИС;
		Гиперссылка  = "ЗарегистрироватьМОД";
	КонецЕсли;
	
	МассивСтатусаПроверкиМОД = Новый Массив;
	МассивСтатусаПроверкиМОД.Добавить(ТекстСтатуса);
	
	СтатусПроверкиМОД = Новый ФорматированнаяСтрока(МассивСтатусаПроверкиМОД, , ЦветТекста, , Гиперссылка);
	
	МассивРасшифровки   = Новый Массив;
	ЦветТекстаПодсказки = ЦветаСтиля.ЦветТекстаНеТребуетВниманияГосИС;
	ШрифтГиперссылки    = Новый Шрифт(, , Истина, , Истина);

	МассивРасшифровки.Добавить(НСтр("ru = 'Просмотреть, актуализировать список МОД из ГИС МТ или добавить новый МОД можно
							   |в рабочем месте'"));
	МассивРасшифровки.Добавить(" ");
	МассивРасшифровки.Добавить(Новый ФорматированнаяСтрока(НСтр("ru = 'Места осуществления деятельности.'"),
		ШрифтГиперссылки, , , "ОткрытьСписокМОД"));

	Элементы.РасшифровкаСтатусаПроверкиМОД.Заголовок = Новый ФорматированнаяСтрока(МассивРасшифровки, ,
		ЦветТекстаПодсказки);

	
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаНавигационнойСсылкиМОД(Действие)
	
	Если Действие = "ЗарегистрироватьМОД" Тогда
		ПараметрыРегистрацииМОД              = ИнтеграцияИСМПКлиент.ПараметрыРегистрацииМОДГИСМТ();
		ПараметрыОткрытияФормыРегистрацииМОД = ИнтеграцияИСМПКлиент.ПараметрыОткрытияФормыРегистрацииМОДГИСМТ();

		Если ЗначениеЗаполнено(Объект.Организация) Тогда
			ПараметрыРегистрацииМОД.Организация = Объект.Организация;
		КонецЕсли;

		Если ЗначениеЗаполнено(Объект.ПроизводственныйОбъект) Тогда
			ПараметрыРегистрацииМОД.Подразделение = Объект.ПроизводственныйОбъект;
		КонецЕсли;

		Если ЗначениеЗаполнено(ПодразделениеКПП) Тогда
			ПараметрыРегистрацииМОД.КПП = ПодразделениеКПП;
		КонецЕсли;

		МассивТоварныхГрупп = Новый Массив;
		Если ЗначениеЗаполнено(Объект.ТоварнаяГруппа) Тогда
			МассивТоварныхГрупп.Добавить(Объект.ТоварнаяГруппа);
		КонецЕсли;
		ПараметрыРегистрацииМОД.ТоварныеГруппы = МассивТоварныхГрупп;

		Если ЗначениеЗаполнено(Объект.АдресПлощадки) Тогда
			ПараметрыРегистрацииМОД.ДанныеАдреса        = Объект.АдресПлощадки;
			ПараметрыРегистрацииМОД.ДанныеАдресаСтрокой = Объект.АдресПлощадкиСтрокой;
		КонецЕсли;

		СписокМОДКРегистрации = Новый Массив;
		СписокМОДКРегистрации.Добавить(ПараметрыРегистрацииМОД);

		ПараметрыОткрытияФормыРегистрацииМОД.НезависимаяРегистрацияМОД = Истина;
		ПараметрыОткрытияФормыРегистрацииМОД.СписокМОДКРегистрации     = СписокМОДКРегистрации;

		ПослеРегистрацииМОД = Новый ОписаниеОповещения("ПослеРегистрацииМОДВГИСМТ", ЭтотОбъект);

		ОткрытьФорму("РегистрСведений.МестаОсуществленияДеятельностиИСМП.Форма.ФормаРегистрацииМОДВСервисе",
			ПараметрыОткрытияФормыРегистрацииМОД, ЭтотОбъект, , , , ПослеРегистрацииМОД,
			РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);

	ИначеЕсли Действие = "ОткрытьСписокМОД" Тогда
		ОткрытьСписокМестОсуществленияДеятельности();
	
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьДоступныеАдресаМОД()
	
	Элементы.АдресПлощадкиСтрокой.СписокВыбора.Очистить();
	
	Если Объект.ИспользуетсяМОД Тогда
		МаксимальноеКоличествоМОДВСписке = 3;
		ПодразделениеКППОтбор            = "";

		Если Не КонструкторИСМПКлиентСервер.ЭтоСырьеГИСМТ(Объект.ТоварнаяГруппа) Тогда
			ПодразделениеКППОтбор = ПодразделениеКПП;
		КонецЕсли;

		СписокМОД = РегистрыСведений.МестаОсуществленияДеятельностиИСМП.СписокЗарегистрированныхМестОсуществленияДеятельности(
			Объект.Организация, Объект.ТоварнаяГруппа, ПодразделениеКППОтбор, , МаксимальноеКоличествоМОДВСписке,
			Истина);

		Для Каждого ДанныеМОД Из СписокМОД Цикл
			ДанныеПодбора = Новый Структура;

			ДанныеПодбора.Вставить("ДанныеАдреса",        ДанныеМОД.ДанныеАдреса);
			ДанныеПодбора.Вставить("ПредставлениеАдреса", ДанныеМОД.ПредставлениеАдреса);
			ДанныеПодбора.Вставить("КодФИАС",             ДанныеМОД.КодФИАС);
			ДанныеПодбора.Вставить("Действие",            "ЗаполнитьАдрес");

			Элементы.АдресПлощадкиСтрокой.СписокВыбора.Добавить(ДанныеПодбора, ДанныеМОД.ПредставлениеАдреса);

		КонецЦикла;

		Если СписокМОД.Количество() = 1 И Не ЗначениеЗаполнено(Объект.АдресПлощадкиСтрокой) Тогда
			ДоступныйМОД = СписокМОД[0];
			
			Объект.АдресПлощадки        = ДоступныйМОД.ДанныеАдреса;
			Объект.АдресПлощадкиСтрокой = ДоступныйМОД.ПредставлениеАдреса;
			Объект.ИдентификаторФИАС    = ДоступныйМОД.КодФИАС;

			ОбновитьСтатусПроверкиМОД(Истина);

		КонецЕсли;

		ДанныеПодбора = Новый Структура;
		ДанныеПодбора.Вставить("Действие", "ОткрытьСписокМОД");
		
		//@skip-check new-font
		Элементы.АдресПлощадкиСтрокой.СписокВыбора.Добавить(ДанныеПодбора,
			Новый ФорматированнаяСтрока("Выбрать МОД из списка", Новый Шрифт(, , , , Истина),
			ЦветаСтиля.ЦветГиперссылкиГосИС, , ""));

	КонецЕсли;	
		
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьСписокМестОсуществленияДеятельности()
	
	ПараметрыОткрытияСпискаМОД = Новый Структура;

	Если ЗначениеЗаполнено(Объект.Организация) Тогда
		ПараметрыОткрытияСпискаМОД.Вставить("Организация", Объект.Организация);
	КонецЕсли;

	Если ЗначениеЗаполнено(Объект.ТоварнаяГруппа) Тогда
		ПараметрыОткрытияСпискаМОД.Вставить("ТоварнаяГруппа", Объект.ТоварнаяГруппа);
	КонецЕсли;
	
	ПараметрыОткрытияСпискаМОД.Вставить("ВыборМОД", Истина);
	
	Если Не КонструкторИСМПКлиентСервер.ЭтоСырьеГИСМТ(Объект.ТоварнаяГруппа) Тогда
		ПараметрыОткрытияСпискаМОД.Вставить("КПП", ПодразделениеКПП);
	КонецЕсли;

	ВыборМОДЗавершение = Новый ОписаниеОповещения("ВыборМестаОсуществленияДеятельностиЗавершение", ЭтотОбъект);
	ОткрытьФорму("РегистрСведений.МестаОсуществленияДеятельностиИСМП.Форма.ФормаСписка", ПараметрыОткрытияСпискаМОД,
		ЭтотОбъект, , , , ВыборМОДЗавершение, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
			
КонецПроцедуры

&НаКлиенте
Процедура ВыборМестаОсуществленияДеятельностиЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Объект.АдресПлощадкиСтрокой = Результат.ПредставлениеАдреса;
	Объект.АдресПлощадки        = Результат.ДанныеАдреса;
	Объект.ИдентификаторФИАС    = Результат.КодФИАС;
	
	Модифицированность = Истина;
	
	ОбновитьСтатусПроверкиМОД(Истина);
	
КонецПроцедуры

&НаКлиенте
Процедура ПослеРегистрацииМОДВГИСМТ(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Или Не Результат.МОДЗарегистрирован Тогда
		Возврат;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(Объект.АдресПлощадкиСтрокой) Тогда
		ЗарегистрированныйМОД = Результат.МОД[0];
		
		Объект.АдресПлощадкиСтрокой = ЗарегистрированныйМОД.ПредставлениеАдреса;
		Объект.АдресПлощадки        = ЗарегистрированныйМОД.ДанныеАдреса;
		Объект.ИдентификаторФИАС    = ЗарегистрированныйМОД.КодФИАС;
		Модифицированность          = Истина;
		
	КонецЕсли;
	
	ОбновитьСтатусПроверкиМОД(Истина);
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ИдентификаторФИАСПоДаннымАдреса(ДанныеАдреса)
	
	Возврат ОбщегоНазначенияИСМП.ИдентификаторФИАСПоДаннымАдреса(ДанныеАдреса).Идентификатор;
	
КонецФункции

#КонецОбласти

#Область ПроизводственныйОбъект

&НаКлиентеНаСервереБезКонтекста
Процедура ПроизводственныйОбъектЗаполнитьСписокВыбора(Форма, ПроверитьПроизводственныйОбъект = Ложь)
	
	Форма.Элементы.ПроизводственныйОбъект.СписокВыбора.Очистить();
	
	Если Не ЗначениеЗаполнено(Форма.Объект.Организация) Тогда
		Если ПроверитьПроизводственныйОбъект Тогда
			Форма.Объект.ПроизводственныйОбъект = Неопределено;
			ЗаполнитьАдресПроизводственногоОбъекта(Форма);
		КонецЕсли;
		Возврат;
	КонецЕсли;
	
	Если ПроверитьПроизводственныйОбъект Тогда
		ПроизводственныйОбъект = Форма.Объект.ПроизводственныйОбъект;
	Иначе
		ПроизводственныйОбъект = Неопределено;
	КонецЕсли;
	
	СписокВыбора = ПроизводственныйОбъектПолучитьСписокВыбора(Форма.Объект.Организация, ПроизводственныйОбъект);
	
	Для Каждого ЭлементСписка Из СписокВыбора Цикл
		Форма.Элементы.ПроизводственныйОбъект.СписокВыбора.Добавить(
			ЭлементСписка.Значение, ЭлементСписка.Представление);
	КонецЦикла;
	
	Форма.Элементы.ПроизводственныйОбъект.СписокВыбора.СортироватьПоПредставлению();
	
	Если ПроверитьПроизводственныйОбъект
		И ПроизводственныйОбъект = Неопределено Тогда
		Форма.Объект.ПроизводственныйОбъект = Неопределено;
		ЗаполнитьАдресПроизводственногоОбъекта(Форма);
	КонецЕсли;
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ПроизводственныйОбъектПолучитьСписокВыбора(Организация, ПроизводственныйОбъект)
	
	Возврат РегистрыСведений.НастройкиОбменаСУЗ.ПроизводственныйОбъектПолучитьСписокВыбора(Организация, ПроизводственныйОбъект);
	
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Процедура ЗаполнитьАдресПроизводственногоОбъекта(Форма)
	
	Объект = Форма.Объект;
	
	Если Не ЗначениеЗаполнено(Объект.Организация) Или Не ЗначениеЗаполнено(Объект.ПроизводственныйОбъект) Тогда
		Объект.АдресПлощадки        = "";
		Объект.АдресПлощадкиСтрокой = "";
		Объект.ИдентификаторФИАС    = "";
		Возврат;
	КонецЕсли;
	
	ЗаполнитьЗначенияСвойств(Объект,
		ПолучитьАдресПроизводственногоОбъекта(Объект.Организация, Объект.ПроизводственныйОбъект));
	
	Объект.ИдентификаторФИАС = ИдентификаторФИАСПоДаннымАдреса(Объект.АдресПлощадки);
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ПолучитьАдресПроизводственногоОбъекта(Организация, ПроизводственныйОбъект)
	
	ДанныеАдресаПроизводственногоОбъекта = РегистрыСведений.НастройкиОбменаСУЗ.ПолучитьАдресПроизводственногоОбъекта(
		Организация, ПроизводственныйОбъект);
	
	Результат = Новый Структура;
	Результат.Вставить("АдресПлощадки",        ДанныеАдресаПроизводственногоОбъекта.ПроизводственныйОбъектАдрес);
	Результат.Вставить("АдресПлощадкиСтрокой", ДанныеАдресаПроизводственногоОбъекта.ПроизводственныйОбъектАдресСтрокой);
	
	Возврат Результат;
	
КонецФункции

&НаСервере
Процедура ЗаполнитьКПППоПроизводственномуОбъекту()
	
	РеквизитыОрганизации = ОбщегоНазначенияИС.ИННКППGLNОрганизации(Объект.Организация, Объект.ПроизводственныйОбъект);
	ПодразделениеКПП     = РеквизитыОрганизации.КПП;
	
КонецПроцедуры

#КонецОбласти

&НаКлиенте
Процедура ЗагрузитьИзТСДЗавершение(РезультатВыполнения, ДополнительныеПараметры) Экспорт
	
	СобытияФормИСМПКлиентПереопределяемый.ПриПолученииДанныхИзТСД(
		Новый ОписаниеОповещения("Подключаемый_ПолученыДанныеИзТСД", ЭтотОбъект),
		ЭтотОбъект, РезультатВыполнения);
	
КонецПроцедуры

&НаКлиенте
Процедура Подключаемый_ПослеВыбораОснования(ДанныеВыбора, ДополнительныеПараметры) Экспорт
	
	Если ДанныеВыбора = Элементы.ДокументОснование.ДоступныеТипы.ПривестиЗначение(ДанныеВыбора) Тогда
		Объект.ДокументОснование = ДанныеВыбора;
		Модифицированность       = Истина;
	КонецЕсли;
	
	Если ТипЗнч(ДополнительныеПараметры) = Тип("Структура")
		И ДополнительныеПараметры.Свойство("ОбработатьПерезаполнение") Тогда
		ОбработчикПерезаполненияПоОснованию(Ложь);
	КонецЕсли;
	
	НастроитьЗависимыеЭлементыФормы(ЭтотОбъект, "ДокументОснование");
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработчикПерезаполненияПоОснованию(ЗадаватьВопрос = Истина)
	
	ОчиститьСообщения();
	
	Если Объект.Товары.Количество() > 0 И ЗадаватьВопрос Тогда
		
		ТекстВопроса = НСтр("ru = 'Данные документа будут перезаполнены. Продолжить?'");
		ОписаниеОповещенияОЗавершении = Новый ОписаниеОповещения("ВопросОПерезаполненииПоОснованиюПриЗавершении", ЭтотОбъект);
		ПоказатьВопрос(ОписаниеОповещенияОЗавершении, ТекстВопроса, РежимДиалогаВопрос.ДаНет);
		
	Иначе
		
		ПерезаполнитьПоОснованиюСервер();
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ВопросОПерезаполненииПоОснованиюПриЗавершении(Результат, Параметры) Экспорт

	Если Результат = КодВозвратаДиалога.Да Тогда
		
		ПерезаполнитьПоОснованиюСервер();
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ПерезаполнитьПоОснованиюСервер()
	
	ТекущийОбъект = РеквизитФормыВЗначение("Объект");
	ТекущийОбъект.Заполнить(Объект.ДокументОснование);
	
	ЗначениеВРеквизитФормы(ТекущийОбъект, "Объект");
	
	ПриСозданииЧтенииНаСервере(Истина);
	ИнтеграцияИСПереопределяемый.ЗаполнитьСтатусыУказанияСерий(Объект, ПараметрыУказанияСерий);
	
	Модифицированность = Истина;
	
КонецПроцедуры

&НаКлиенте
Процедура ВопросПриИзмененииТоварнойГруппыПриЗавершении(РезультатВопроса, ВыбраннаяТоварнаяГруппа) Экспорт
	
	Если РезультатВопроса = КодВозвратаДиалога.Да
		Или РезультатВопроса = Истина Тогда
		Объект.ТоварнаяГруппа = ВыбраннаяТоварнаяГруппа;
		Объект.Товары.Очистить();
		Объект.ШтрихкодыУпаковок.Очистить();
		ПриИзмененииТоварнойГруппы(Элементы.ТоварнаяГруппа, РезультатВопроса = Истина);
		Модифицированность = Истина;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ВопросПриИзмененииВидаУчетаПриЗавершении(РезультатВопроса, ДополнительныеПараметры) Экспорт
	
	Если РезультатВопроса = КодВозвратаДиалога.Да
		Или РезультатВопроса = Истина Тогда
		
		Объект.ОбъемноСортовойУчет = ДополнительныеПараметры;
		Объект.ШтрихкодыУпаковок.Очистить();
		ПриИзмененииВидаУчета(Истина);
		Модифицированность = Истина;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ВопросПриИзмененииОрганизацияПриЗавершении(РезультатВопроса, НоваяОрганизация) Экспорт
	
	Если РезультатВопроса = КодВозвратаДиалога.Да Тогда
		
		Объект.Организация = НоваяОрганизация;
		Объект.ШтрихкодыУпаковок.Очистить();
		ОбновлениеКешей();
		Модифицированность = Истина;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ВопросПриИзмененииПричиныВыбытияПриЗавершении(РезультатВопроса, ДополнительныеПараметры) Экспорт
	
	Если РезультатВопроса <> КодВозвратаДиалога.Да Тогда
		Возврат;
	КонецЕсли;
	
	Объект.Причина = ДополнительныеПараметры;
	Объект.Товары.Очистить();
	Объект.ШтрихкодыУпаковок.Очистить();
	ВопросПриИзмененииПричиныВыбытияПриЗавершенииНаСервере();
	
	Модифицированность = Истина;
	
КонецПроцедуры

&НаСервере
Процедура ВопросПриИзмененииПричиныВыбытияПриЗавершенииНаСервере()
	
	ОбновлениеКешей();
	ОбновитьИнформациюОткрытияФормыПроверкиПодбора();
	ПричинаПриИзмененииНаСервере();
	
КонецПроцедуры

&НаСервере
Процедура ОбновлениеКешей()
	
	Если Не РедактированиеФормыНедоступно Тогда
		ПроверкаИПодборПродукцииИС.ЗаполнитьКешШтрихкодовУпаковок(ЭтотОбъект, НастройкиКешаШтрихкодовУпаковок());
		ПроверкаИПодборПродукцииИС.ПрименитьКешШтрихкодовУпаковок(ЭтотОбъект, НастройкиКешаШтрихкодовУпаковок(), Истина);
	КонецЕсли;
	ШтрихкодированиеИС.ОбновитьКэшМаркируемойПродукции(ЭтотОбъект);
	
КонецПроцедуры

&НаКлиенте
Процедура ПриИзмененииТоварнойГруппы(Элемент, ПерезаполнитьПоОснованию = Ложь)
	
	Если Не ВыводИзОборотаКлиентСервер.ДоступноПолеОСУ(Объект.ТоварнаяГруппа) Тогда
		Объект.ОбъемноСортовойУчет = Ложь;
	ИначеЕсли КонструкторИСМПКлиентСервер.ЭтоСырьеГИСМТ(Объект.ТоварнаяГруппа) Тогда
		Объект.ОбъемноСортовойУчет = Истина;
		Объект.ИспользуетсяМОД     = Истина;
	КонецЕсли;
	
	СобытияФормИСМПКлиент.ТоварнаяГруппаПриИзменении(ЭтотОбъект, Элемент);
	СобытияФормИСКлиентСерверПереопределяемый.УстановитьПараметрыВыбораНоменклатуры(
		ЭтотОбъект,
		КонструкторИСМПОбщегоНазначенияКлиентСервер.ВидыПродукцииПоТоварнойГруппе(Объект.ТоварнаяГруппа));
	
	ПриИзмененииТоварнойГруппыНаСервере(ПерезаполнитьПоОснованию);
	
КонецПроцедуры

&НаКлиенте
Процедура ПриИзмененииВидаУчета(ОбновитьКэшШтрихкодов = Ложь)
	
	ВидУчетаПриИзмененииНаСервере(ОбновитьКэшШтрихкодов);
	
КонецПроцедуры

&НаСервере
Процедура ВидУчетаПриИзмененииНаСервере(ОбновитьКэшШтрихкодов)
	
	Объект.УведомитьОбОтгрузкеНаЭкспорт = ВыводИзОборотаКлиентСервер.ДоступноУведомлениеОбОтгрузкеНаЭкспорт(
		Объект.ТоварнаяГруппа, Объект.Причина);
	Если Не Объект.УведомитьОбОтгрузкеНаЭкспорт Тогда
		ОчиститьЗависимыеРеквизитыУведомлениеОбЭкспорте();
	КонецЕсли;
	
	НастроитьЗависимыеЭлементыФормы(ЭтотОбъект, "ВидУчета");
	УстановитьПараметрыВыбораКонтрагентаНаСервере();
	УстановитьПараметрыВыбораСтраныМира();
	
	Если ОбновитьКэшШтрихкодов Тогда
		ПрименитьКешШтрихкодовУпаковок();
		ШтрихкодированиеИС.ОбновитьКэшМаркируемойПродукции(ЭтотОбъект);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ПриИзмененииТоварнойГруппыНаСервере(ПерезаполнитьПоОснованию)
	
	Объект.УведомитьОбОтгрузкеНаЭкспорт = ВыводИзОборотаКлиентСервер.ДоступноУведомлениеОбОтгрузкеНаЭкспорт(
		Объект.ТоварнаяГруппа, Объект.Причина);
	Если Не Объект.УведомитьОбОтгрузкеНаЭкспорт Тогда
		ОчиститьЗависимыеРеквизитыУведомлениеОбЭкспорте();
	КонецЕсли;
	
	НастроитьЗависимыеЭлементыФормы(ЭтотОбъект, "ТоварнаяГруппа");
	УстановитьПараметрыВыбораКонтрагентаНаСервере();
	УстановитьПараметрыВыбораСтраныМира();
	
	Если КонструкторИСМПКлиентСервер.ЭтоСырьеГИСМТ(Объект.ТоварнаяГруппа) Тогда
		Элементы.ТоварыКоличествоПотребительскихУпаковок.Видимость = Ложь;
	Иначе
		ИнтеграцияИСМП.НастроитьВидимостьКолонкиКоличестваКодовМаркировки(ЭтотОбъект);
	КонецЕсли;
	
	ДополнитьДоступныеПричиныВывода();
	Если ПерезаполнитьПоОснованию И ЗначениеЗаполнено(Объект.ДокументОснование) Тогда
		ПерезаполнитьПоОснованиюСервер();
	КонецЕсли;
	
	ОбновитьДальнейшиеДействия();
	ОбновитьПредставленияНаФорме();
	
	ОбновлениеКешей();
	
	ВидыПродукции = КонструкторИСМПОбщегоНазначенияКлиентСервер.ВидыПродукцииПоТоварнойГруппе(Объект.ТоварнаяГруппа);
	
	Если КонструкторИСОбщегоНазначенияКлиентСервер.ЭтоПродукцияИСМП(ВидыПродукции) Тогда
		Объект.ДатаПервичногоДокумента = НачалоДня(Объект.ДатаПервичногоДокумента);
	КонецЕсли;
	
	ЗаполнитьДоступныеАдресаМОД();
	ОбновитьСтатусПроверкиМОД();
	
КонецПроцедуры

&НаСервере
Процедура ДополнитьДоступныеПричиныВывода()
	
	Если ЭтоАдресВременногоХранилища(ДанныеДокументаАдрес) Тогда
		ДанныеДокумента = ПолучитьИзВременногоХранилища(ДанныеДокументаАдрес);
		Если ДанныеДокумента.ТоварнаяГруппа = Объект.ТоварнаяГруппа
				И ЗначениеЗаполнено(ДанныеДокумента.Причина)
				И Элементы.Причина.СписокВыбора.НайтиПоЗначению(ДанныеДокумента.Причина) = Неопределено Тогда
			Элементы.Причина.СписокВыбора.Добавить(ДанныеДокумента.Причина);
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ДополнитьДоступныеВидыПервичногоДокумента()
	
	Если ЭтоАдресВременногоХранилища(ДанныеДокументаАдрес) Тогда
		ДанныеДокумента = ПолучитьИзВременногоХранилища(ДанныеДокументаАдрес);
		Если ДанныеДокумента.ТоварнаяГруппа = Объект.ТоварнаяГруппа
			И ДанныеДокумента.Причина = Объект.Причина
			И ЗначениеЗаполнено(ДанныеДокумента.ВидПервичногоДокумента)
			И Элементы.ВидПервичногоДокумента.СписокВыбора.НайтиПоЗначению(ДанныеДокумента.ВидПервичногоДокумента) = Неопределено Тогда
			Элементы.ВидПервичногоДокумента.СписокВыбора.Добавить(ДанныеДокумента.ВидПервичногоДокумента);
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Функция ТоварнаяГруппаУказана()
	
	Если Не ЗначениеЗаполнено(Объект.ТоварнаяГруппа) Тогда
		
		ТекстСообщения = НСтр("ru = 'Не указана товарная группа'");
		ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения);
		
		Возврат Ложь;
	КонецЕсли;
	
	Возврат Истина;
	
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Функция ЕстьДанныеЧастичногоВыбытияВШтрихкодахУпаковок(Форма)
	
	Объект = Форма.Объект;
	
	Для Каждого СтрокаТаблицы Из Объект.ШтрихкодыУпаковок Цикл
		Если СтрокаТаблицы.ЧастичноеВыбытиеКоличество > 0
			И ЗначениеЗаполнено(СтрокаТаблицы.ЧастичноеВыбытиеВариантУчета) Тогда
			Возврат Истина;
		КонецЕсли;
	КонецЦикла;

	Возврат Ложь;
	
КонецФункции

#Область GTIN

&НаСервере
Функция МассивЗначенийGTINДляВыбора(ТекущаяСтрока)
	
	ТекущиеДанные = Объект.Товары.НайтиПоИдентификатору(ТекущаяСтрока);
	
	ДопустимыеВидыУпаковок = Новый Массив();
	ДопустимыеВидыУпаковок.Добавить(Перечисления.ВидыУпаковокИС.Потребительская);
	ДопустимыеВидыУпаковок.Добавить(Перечисления.ВидыУпаковокИС.Набор);
	ДопустимыеВидыУпаковок.Добавить(Перечисления.ВидыУпаковокИС.Неопределен);
	
	Возврат ИнтеграцияИСМП.МассивЗначенийGTINДляВыбора(ТекущиеДанные, Объект, Ложь, ДопустимыеВидыУпаковок);
	
КонецФункции

&НаСервере
Процедура ЗаполнитьДоступныеGTINНаСервере()
	
	Документы.ВыводИзОборотаИСМП.ЗаполнитьДоступныеGTIN(Объект)
	
КонецПроцедуры

#КонецОбласти

&НаСервере
Процедура ТоварыНоменклатураХарактеристикаПриИзмененииСервер(ТребуетсяОбновитьКэшУпаковок)
	
	ТекущаяСтрока = Элементы.Товары.ТекущаяСтрока;
	ДанныеСтроки  = Объект.Товары.НайтиПоИдентификатору(ТекущаяСтрока);
	
	Если ДанныеСтроки = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	// РаботаСКлючомВидовПродукции
	СобытияФормИС.КлючВидовПродукцииЗаполнитьДанные(ЭтотОбъект, ДанныеСтроки);
	// Конец РаботаСКлючомВидовПродукции
	
	Если ДанныеСтроки.ХарактеристикиИспользуются Тогда
		НоменклатураХарактеристикаУказана = (ЗначениеЗаполнено(ДанныеСтроки.Номенклатура)
			И ЗначениеЗаполнено(ДанныеСтроки.Характеристика));
	Иначе
		НоменклатураХарактеристикаУказана = ЗначениеЗаполнено(ДанныеСтроки.Номенклатура);
	КонецЕсли;
	
	Если НоменклатураХарактеристикаУказана Тогда
		
		Если Объект.ОбъемноСортовойУчет
			И Не ЗначениеЗаполнено(ДанныеСтроки.GTIN) Тогда
			
			ВременнаяТаблица = Объект.Товары.Выгрузить(Новый Структура("НомерСтроки", ДанныеСтроки.НомерСтроки));
			ЗаполнениеОбъектовПоСтатистикеИСМП.ЗаполнитьДанныеПоТоварамВыводаИзОборотаИСМП(
				ВременнаяТаблица, Объект);
			Если ВременнаяТаблица.Количество() Тогда
				ЗаполнитьЗначенияСвойств(ДанныеСтроки, ВременнаяТаблица[0], "GTIN");
			КонецЕсли;
			
			МассивЗначенийGTINДляВыбора = МассивЗначенийGTINДляВыбора(ТекущаяСтрока);
			Элементы.ТоварыGTIN.СписокВыбора.ЗагрузитьЗначения(МассивЗначенийGTINДляВыбора);
		
			Если Не ЗначениеЗаполнено(ДанныеСтроки.GTIN)
				Или МассивЗначенийGTINДляВыбора.Найти(ДанныеСтроки.GTIN) = Неопределено Тогда
				Если МассивЗначенийGTINДляВыбора.Количество() Тогда
					ДанныеСтроки.GTIN = МассивЗначенийGTINДляВыбора[0];
				Иначе
					ДанныеСтроки.GTIN = "";
				КонецЕсли;
			КонецЕсли;
			
		КонецЕсли;
		
	Иначе
		Если Объект.ОбъемноСортовойУчет Тогда
			ДанныеСтроки.GTIN = "";
		КонецЕсли;
	КонецЕсли;
	
	Если ТребуетсяОбновитьКэшУпаковок Тогда
		ПрименитьКешШтрихкодовУпаковок();
	КонецЕсли;
	
	Если КонструкторИСМПКлиентСервер.ЭтоСырьеГИСМТ(Объект.ТоварнаяГруппа) Тогда
		ДанныеСтроки.ВидПродукцииСырья = Неопределено;
		ДанныеСтроки.Сырье = Неопределено;
		РегистрыСведений.СоответствиеНоменклатурыСырьяГИСМТ.ЗаполнитьСопоставленноеСырьеВДокументе(ДанныеСтроки);
		ИнтеграцияИСМП.ЗаполнитьСлужебныеРеквизитыСырье(ДанныеСтроки);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ТоварыСырьеПриИзмененииНаСервере()
	
	ТекущаяСтрока = Элементы.Товары.ТекущаяСтрока;
	ДанныеСтроки = Объект.Товары.НайтиПоИдентификатору(ТекущаяСтрока);
	ДанныеСтроки.ВидПродукцииСырья = Неопределено;
	ИнтеграцияИСМП.ЗаполнитьСлужебныеРеквизитыСырье(ДанныеСтроки);
	
КонецПроцедуры

&НаСервере
Процедура ПричинаПриИзмененииНаСервере()
	
	ВидыПродукцииПоТоварнойГруппе = КонструкторИСМПОбщегоНазначенияКлиентСервер.ВидыПродукцииПоТоварнойГруппе(Объект.ТоварнаяГруппа);
	
	Если Не ВыводИзОборотаКлиентСервер.ДоступноПолеВидПервичногоДокумента(ВидыПродукцииПоТоварнойГруппе, Объект.Причина) Тогда
		Объект.ВидПервичногоДокумента          = Неопределено;
		Объект.НаименованиеПервичногоДокумента = "";
		Объект.НомерПервичногоДокумента        = "";
		Объект.ДатаПервичногоДокумента         = Неопределено;
	КонецЕсли;
	
	Если Не МаркировкаТоваровКлиентСервер.ДоступноПолеКонтрагент(ВидыПродукцииПоТоварнойГруппе, Объект.Причина) Тогда
		Объект.Контрагент = Неопределено;
	КонецЕсли;
	
	Объект.УведомитьОбОтгрузкеНаЭкспорт = ВыводИзОборотаКлиентСервер.ДоступноУведомлениеОбОтгрузкеНаЭкспорт(
		ВидыПродукцииПоТоварнойГруппе, Объект.Причина);
	Если Не Объект.УведомитьОбОтгрузкеНаЭкспорт Тогда
		ОчиститьЗависимыеРеквизитыУведомлениеОбЭкспорте();
	КонецЕсли;
	
	ОбновитьДальнейшиеДействия();
	ОбновитьПредставленияНаФорме();
	
	НастроитьЗависимыеЭлементыФормы(ЭтотОбъект, "Причина");
	НастроитьЭлементыФормы(ЭтотОбъект);
	ДополнитьДоступныеВидыПервичногоДокумента();
	УстановитьПараметрыВыбораКонтрагентаНаСервере();
	УстановитьПараметрыВыбораСтраныМира();
	ЗаполнитьДоступныеАдресаМОД();
	ОбновитьСтатусПроверкиМОД();
	
КонецПроцедуры

&НаСервере
Процедура ОчиститьЗависимыеРеквизитыУведомлениеОбЭкспорте()
	
	Объект.ИдентификаторЭлектронногоПеревозочногоДокумента = "";
	Объект.НомерПеревозочногоДокумента                     = "";
	Объект.ДатаПеревозочногоДокумента                      = Неопределено;
	Объект.ТранспортноеСредство                            = Неопределено;
	Объект.НомерТранспортногоСредства                      = "";
	Объект.ДатаОтгрузки                                    = Неопределено;
	Объект.ТранспортныйДокумент                            = Ложь;
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьДальнейшиеДействия()
	
	Реквизиты = Новый Структура(Документы.ВыводИзОборотаИСМП.ИменаРеквизитовДляРасчетаДальнейшегоДействия());
	ЗаполнитьЗначенияСвойств(Реквизиты, Объект);
	
	ДальнейшиеДействия = Новый Массив;
	ДальнейшиеДействия.Добавить(Документы.ВыводИзОборотаИСМП.ДальнейшееДействиеПоУмолчанию(Реквизиты));
	
	ПараметрыОбновленияСтатуса = РегистрыСведений.СтатусыДокументовИСМП.ВозвращаемоеЗначениеДальнейшиеДействияСтатус(
		СтатусИСМП,
		ДальнейшиеДействия);
	
КонецПроцедуры

&НаСервере
Процедура УстановитьПараметрыВыбораКонтрагентаНаСервере()
	
	КонтрагентНерезидент = КонструкторИСМПКлиентСервер.КонтрагентНерезидент(Объект.ТоварнаяГруппа, Объект.Причина);
	
	СобытияФормИСМППереопределяемый.УстановитьПараметрыВыбораКонтрагента(ЭтотОбъект, КонтрагентНерезидент, "Контрагент");
	
	Если ВыводИзОборотаКлиентСервер.ДоступноУведомлениеОбОтгрузкеНаЭкспорт(
		Объект.ТоварнаяГруппа, Объект.Причина) Тогда
		СобытияФормИСМППереопределяемый.УстановитьПараметрыВыбораКонтрагента(ЭтотОбъект, Истина, "УведомлениеОбЭкспортеКонтрагент");
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура УстановитьПараметрыВыбораСтраныМира()
	
	ПараметрыВыбораСтраны = Новый Массив;
	
	ТолькоСтраныУчастникиЕАЭС = КонструкторИСМПКлиентСервер.ДоступныТолькоСтраныЕАЭС(Объект.ТоварнаяГруппа, Объект.Причина);
	ПараметрыВыбораСтраны.Добавить(Новый ПараметрВыбора("Отбор.УчастникЕАЭС", ТолькоСтраныУчастникиЕАЭС));
	
	Элементы.УведомлениеОбЭкспортеСтранаНазначения.ПараметрыВыбора = Новый ФиксированныйМассив(ПараметрыВыбораСтраны);
	Элементы.СтранаНазначения.ПараметрыВыбора = Новый ФиксированныйМассив(ПараметрыВыбораСтраны);
	
КонецПроцедуры

#Область РаботаСТСД

#Область ЗагрузкаИзТСД

&НаКлиенте
Процедура ЗагрузитьИзТСДПослеАвторизации(РезультатАвторизации, Штрихкоды) Экспорт
	
	Подключаемый_ПолученыДанныеИзТСД(Штрихкоды, Истина);
	
КонецПроцедуры

&НаКлиенте
Процедура Подключаемый_ПолученыДанныеИзТСД(Штрихкоды, АвторизацияЗапрашивалась = Неопределено) Экспорт
	
	Если Штрихкоды.Количество() = 0 Тогда
		ГрупповаяОбработкаШтрихкодовИСКлиент.ОповеститьОбОтсутствииДанныхТСД();
		Возврат;
	КонецЕсли;
	
	ГрупповаяОбработкаШтрихкодовИСКлиент.ОповеститьОНачалеОбработкиДанныхТСД();
	ПараметрыСканирования = ШтрихкодированиеОбщегоНазначенияИСКлиент.ПараметрыСканирования(ЭтотОбъект);
	ШтрихкодированиеИСКлиент.ПреобразоватьШтрихкодыТСДВBase64(Штрихкоды);
	ОбработатьПолученныеДанныеТСДНаСервере(Штрихкоды, ПараметрыСканирования, КэшированныеЗначения);
	
	ГрупповаяОбработкаШтрихкодовИСКлиент.ДействияПослеЗагрузкиИзТСД(ЭтотОбъект, Штрихкоды, АвторизацияЗапрашивалась);
	
КонецПроцедуры

&НаКлиенте
Процедура СопоставлениеШтрихкодовЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	ГрупповаяОбработкаШтрихкодовИСКлиент.СопоставлениеШтрихкодовЗавершение(ЭтотОбъект, Результат, ДополнительныеПараметры);
	
КонецПроцедуры

&НаСервере
Процедура ОбработатьПолученныеДанныеТСДНаСервере(ШтрихкодыТСД, ПараметрыСканирования, КэшированныеЗначения)
	
	ЗагрузкаДанныхТСД = ГрупповаяОбработкаШтрихкодовИС.ОбработатьПолученныеДанныеТСДВДокументе(
		ЭтотОбъект, ШтрихкодыТСД, ПараметрыСканирования, (Не Объект.ОбъемноСортовойУчет));
	
	Если ГрупповаяОбработкаШтрихкодовИС.ЗагрузкаШтрихкодовПрервана(ЗагрузкаДанныхТСД) Тогда
		Возврат;
	КонецЕсли;
	
	ДействияПослеЗагрузкиИзТСДНаСервере(КэшированныеЗначения);
	
КонецПроцедуры

&НаКлиенте
Процедура ПослеУточненияДанныхТСД(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ПослеУточненияДанныхТСДНаСервере(КэшированныеЗначения);
	ГрупповаяОбработкаШтрихкодовИСКлиент.ЗавершитьЗагрузкуТСД(ЭтотОбъект);
	
КонецПроцедуры

&НаСервере
Процедура ПослеУточненияДанныхТСДНаСервере(КэшированныеЗначения)
	
	ГрупповаяОбработкаШтрихкодовИС.ОбработатьШтрихкоды(ЭтотОбъект, ЗагрузкаДанныхТСД);
	ДействияПослеЗагрузкиИзТСДНаСервере(КэшированныеЗначения);
	
КонецПроцедуры

&НаСервере
Процедура ДействияПослеЗагрузкиИзТСДНаСервере(КэшированныеЗначения)
	
	Модифицированность = Истина;
	ПослеОбработкиШтрихкодовСервер(ЗагрузкаДанныхТСД, КэшированныеЗначения);
	ЗагрузкаДанныхТСД.ДобавленныеСтроки = Новый Массив;
	ЗагрузкаДанныхТСД.ИзмененныеСтроки  = Новый Массив;
	
КонецПроцедуры

#КонецОбласти

#КонецОбласти

&НаСервереБезКонтекста
Функция ДоступныеВидыПервичныхДокументов(Причина)
	
	Возврат Справочники.ПричиныВыводаИзОборотаИСМП.ДоступныеВидыПервичныхДокументов(Причина, Перечисления.ВидыОперацийИСМП.ВыводИзОборота);
	
КонецФункции

&НаСервере
Процедура ОбновитьЗаписатьПараметрыОбновленияСтатуса(Отказ, ТекущийОбъект)
	
	Если ПараметрыОбновленияСтатуса = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	РегистрыСведений.СтатусыДокументовИСМП.ОбновитьСтатус(
		ТекущийОбъект.Ссылка,
		ПараметрыОбновленияСтатуса);
	
	ПараметрыОбновленияСтатуса = Неопределено;
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ЗначенияРеквизитовТранспортногоСредства(ТранспортноеСредство)
	
	Возврат ИнтеграцияИС.ЗначенияРеквизитовТранспортногоСредства(ТранспортноеСредство);
	
КонецФункции

&НаКлиенте
Процедура ЗаполнитьТипСырьяПоОстаткамНаКлиенте(КОпределениюТипаСырья = Неопределено, ВызовПослеАвторизации = Ложь) Экспорт
	
	Результат = ЗаполнитьТипСырьяПоОстаткамНаСервере(КОпределениюТипаСырья);
	
	Если ЗначениеЗаполнено(Результат.ТекстОшибки) Тогда
		ОбщегоНазначенияКлиент.СообщитьПользователю(Результат.ТекстОшибки);
	ИначеЕсли Результат.ТребуетсяОбновлениеКлючаСессии = Истина Тогда
		Если ВызовПослеАвторизации Тогда
			ТекстОшибки = НСтр("ru = 'Не удалось выполнить авторизацию.'");
			ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстОшибки);
		Иначе
			ПараметрыПроверки = Новый Структура;
			ПараметрыПроверки.Вставить("КОпределениюТипаСырья", КОпределениюТипаСырья);
			ЗапроситьКлючСессииНачало(ПараметрыПроверки);
		КонецЕсли;
	Иначе
		Модифицированность = Истина;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция ЗаполнитьТипСырьяПоОстаткамНаСервере(КОпределениюТипаСырья = Неопределено)
	
	Возврат ИнтеграцияИСМП.ЗаполнитьТипСырьяПоОстаткамНаСервере(Объект, КОпределениюТипаСырья);

КонецФункции

&НаКлиенте
Процедура ЗапроситьКлючСессииНачало(ПараметрыПроверки)
	
	ОповещениеПриЗапросеКлючаСессии = Новый ОписаниеОповещения("ЗапроситьКлючСессииЗавершение", ЭтотОбъект, ПараметрыПроверки);
	ПараметрыЗапроса = ИнтерфейсИСМПОбщегоНазначенияКлиентСервер.ПараметрыЗапросаКлючаСессии(Объект.Организация);
	
	ИнтерфейсАвторизацииИСМПКлиент.ЗапроситьКлючСессии(
		ПараметрыЗапроса, 
		ОповещениеПриЗапросеКлючаСессии);
	
КонецПроцедуры

&НаКлиенте
Процедура ЗапроситьКлючСессииЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	ОтказОтАвторизации = Ложь;
	ОшибкаАвторизации  = Ложь;
	
	Если ТипЗнч(Результат) <> Тип("Соответствие") Тогда
		ОтказОтАвторизации = Истина;
	Иначе
		РезультатАвторизации = Результат[Объект.Организация];
		
		Если РезультатАвторизации = Неопределено Тогда
			ОшибкаАвторизации = Истина;
			ТекстОшибки = НСтр("ru = 'Произошла ошибка при авторизации.'");
		ИначеЕсли РезультатАвторизации <> Истина Тогда
			ОшибкаАвторизации = Истина;
			ТекстОшибки = РезультатАвторизации;
		КонецЕсли;
	КонецЕсли;
	
	Если ОтказОтАвторизации Тогда
		Возврат;
	ИначеЕсли ОшибкаАвторизации Тогда
		ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстОшибки);
	ИначеЕсли ДополнительныеПараметры.Свойство("КОпределениюТипаСырья") Тогда
		ЗаполнитьТипСырьяПоОстаткамНаКлиенте(ДополнительныеПараметры.КОпределениюТипаСырья, Истина);
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти