// Дополнительная обработка данных при переходе на конструктор настроек.
// 
// Параметры:
//  ДокументОбъект - ДокументОбъект.ВыводИзОборотаИСМП
//  ПроблемыСДанными - Соответствие из КлючИЗначение
//  КешКонвертаций - см. ОбновлениеИнформационнойБазыГосИС.КешКонвертацийВидаПродукции
Процедура ДополнительнаяОбработкаДанныхПриПереходеНаКонструкторНастроек(ДокументОбъект, ПроблемыСДанными, КешКонвертаций) Экспорт
	
	Если КешКонвертаций.ПричиныВыбытия = Неопределено Тогда
		КешКонвертаций.ПричиныВыбытия = Перечисления.УдалитьПричиныСписанияКодовМаркировкиИСМП.ПричиныВыбытияКонструктораНастроекПоПеречислению();
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(ДокументОбъект.УдалитьОперация) Тогда
		Возврат;
	КонецЕсли;
	
	Причина = КешКонвертаций.ПричиныВыбытия[ДокументОбъект.УдалитьОперация];
	
	Если ЗначениеЗаполнено(Причина) Тогда
		ДокументОбъект.Причина = Причина;
	ИначеЕсли ДокументОбъект.УдалитьОперация = Перечисления.ВидыОперацийИСМП.УдалитьВыводИзОборотаРеализацияНезарегистрированномуУчастнику Тогда
		Возврат;
	Иначе
		ПроблемыСДанными[ДокументОбъект.Ссылка] = СтрШаблон(
			НСтр("ru = 'Не удалось обработать причину вывода из оборота ""%1"" при переходе на конструктор настроек видов продукции для объекта ""%2""'"),
			ДокументОбъект.УдалитьОперация,
			ДокументОбъект.Ссылка);
	КонецЕсли;
	
КонецПроцедуры

