#КонецОбласти

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Процедура ОбработатьСтрокуТабличнойЧасти(СтрокаТабличнойЧасти, ДокументОбъект)

	ПараметрыУказанияСерий = ПараметрыУказанияСерий(ДокументОбъект);
	ПустойСклад = ОбщегоНазначенияИС.ПустоеЗначениеОпределяемогоТипа("Склад");
	
	СтруктураДействий = Новый Структура;
	СтруктураДействий.Вставить("ПересчитатьКоличествоУпаковок");
	СтруктураДействий.Вставить("ПроверитьСериюРассчитатьСтатус", Новый Структура("Склад, ПараметрыУказанияСерий", ПустойСклад, ПараметрыУказанияСерий));
	
	ИнтеграцияИСПереопределяемый.ОбработатьСтрокуТабличнойЧасти(СтрокаТабличнойЧасти, СтруктураДействий, ДокументОбъект);
	
КонецПроцедуры

Процедура ЗаполнитьДоступныеGTIN(Объект) Экспорт
	
	ДопустимыеВидыУпаковок   = Новый Массив();
	ДопустимыеВидыУпаковок.Добавить(Перечисления.ВидыУпаковокИС.Потребительская);
	ДопустимыеВидыУпаковок.Добавить(Перечисления.ВидыУпаковокИС.Набор);
	ДопустимыеВидыУпаковок.Добавить(Перечисления.ВидыУпаковокИС.Неопределен);
	
	GTINДляВыбора = ИнтеграцияИСМП.ДанныеДляУточненияКоэффициентовУпаковок(Объект.Товары);
	
	Если GTINДляВыбора.Количество() > 0 Тогда
		
		Для Каждого СтрокаДокумента Из Объект.Товары Цикл
			
			Если ЗначениеЗаполнено(СтрокаДокумента.GTIN) Тогда
				Продолжить;
			КонецЕсли;
			
			СтрокиТаблицы = GTINДляВыбора.НайтиСтроки(
				Новый Структура(
					"Номенклатура, Характеристика",
					СтрокаДокумента.Номенклатура,
					СтрокаДокумента.Характеристика));
			Для Каждого СтрокаДанных Из СтрокиТаблицы Цикл 
				Если ЗначениеЗаполнено(СтрокаДанных.ВидУпаковки)
						И ДопустимыеВидыУпаковок.Найти(СтрокаДанных.ВидУпаковки) = Неопределено Тогда
					Продолжить;
				КонецЕсли;
				СтрокаДокумента.GTIN = СтрокаДанных.GTIN;
				Прервать;
			КонецЦикла;
			
		КонецЦикла;
	
	КонецЕсли;
	
КонецПроцедуры

#Область Сообщения

// Формирует сообщение JSON  для операции Уведомление об отгрузке на экспорт
//
// Параметры:
//  ДокументСсылка - ДокументСсылка.ВыводИзОборотаИСМП - Документ Вывод из оборота ИС МП
//  ДополнительныеПараметры - Структура, Неопределено - Дополнительные параметры
//  ОтменаУведомленияОбЭкспорте - Булево - Состояние кодов (action)
//
// Возвращаемое значение:
//  Массив Из См. ИнтеграцияИСМПСлужебный.СтруктураСообщенияJSON - Сообщения к передаче
Функция УведомлениеОбОтгрузкеНаЭкспортJSON(ДокументСсылка, ДополнительныеПараметры = Неопределено, ОтменаУведомленияОбЭкспорте = Ложь)
	
	Если ОтменаУведомленияОбЭкспорте Тогда
		Операция = Перечисления.ВидыОперацийИСМП.ОтменаУведомленияОбОтгрузкеНаЭкспорт;
	Иначе
		Операция = Перечисления.ВидыОперацийИСМП.УведомлениеОбОтгрузкеНаЭкспорт;
	КонецЕсли;
	
	СообщенияJSON  = Новый Массив;
	СписокЗапросов = Новый СписокЗначений;
	
	СписокЗапросов.Добавить(
	"ВЫБРАТЬ
	|	ИСМППрисоединенныеФайлы.Документ                      КАК Ссылка,
	|	МАКСИМУМ(ЕСТЬNULL(ИСМППрисоединенныеФайлы.Версия, 0)) КАК ПоследнийНомерВерсии
	|ПОМЕСТИТЬ Версии
	|ИЗ
	|	Справочник.ИСМППрисоединенныеФайлы КАК ИСМППрисоединенныеФайлы
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ВыводИзОборотаИСМП КАК Шапка
	|		ПО Шапка.Ссылка   = &Ссылка
	|		 И Шапка.Ссылка   = ИСМППрисоединенныеФайлы.Документ
	|		 И ИСМППрисоединенныеФайлы.Операция = &Операция
	|ГДЕ
	|	ИСМППрисоединенныеФайлы.ТипСообщения = ЗНАЧЕНИЕ(Перечисление.ТипыЗапросовИС.Исходящий)
	|СГРУППИРОВАТЬ ПО
	|	ИСМППрисоединенныеФайлы.Документ
	|");
	
	СписокЗапросов.Добавить(
	"ВЫБРАТЬ
	|	Шапка.Номер                              КАК Номер,
	|	Шапка.Дата                               КАК Дата,
	|	ЕСТЬNULL(Версии.ПоследнийНомерВерсии, 0) КАК ПоследнийНомерВерсии,
	|	Шапка.ДокументОснование                  КАК ДокументОснование,
	|
	|	Шапка.Организация                КАК Организация,
	|	Представление(Шапка.Организация) КАК ОрганизацияПредставление,
	|
	|	Шапка.Ответственный                КАК Ответственный,
	|	Представление(Шапка.Ответственный) КАК ОтветственныйПредставление,
	|
	|	Шапка.Причина                 КАК Причина,
	|	Шапка.Причина.ОписаниеПричины КАК ШаблонОписаниеПричины,
	|	Шапка.Причина.Имя             КАК ПричинаВыводаИзОборота,
	|	Шапка.ТоварнаяГруппа          КАК ТоварнаяГруппа,
	|	Шапка.Контрагент              КАК Контрагент,
	|	Шапка.ОписаниеПричины         КАК ОписаниеПричины,
	|
	|	Шапка.ВидПервичногоДокумента          КАК ВидПервичногоДокумента,
	|	Шапка.НаименованиеПервичногоДокумента КАК НаименованиеПервичногоДокумента,
	|	Шапка.НомерПервичногоДокумента        КАК НомерПервичногоДокумента,
	|	Шапка.ДатаПервичногоДокумента         КАК ДатаПервичногоДокумента,
	|	Шапка.ПроизводственныйОбъект          КАК ПроизводственныйОбъект,
	|	Шапка.АдресПлощадки                   КАК АдресПлощадки,
	|	Шапка.АдресПлощадкиСтрокой            КАК АдресПлощадкиСтрокой,
	|
	|	Шапка.ИдентификаторГосударственногоКонтракта КАК ИдентификаторГосударственногоКонтракта,
	|
	|	Шапка.ОбъемноСортовойУчет             КАК ОбъемноСортовойУчет,
	|	Шапка.Ссылка                          КАК Ссылка,
	|	
	|	Шапка.ИдентификаторЭлектронногоПеревозочногоДокумента КАК ИдентификаторЭлектронногоПеревозочногоДокумента,
	|	Шапка.ТранспортныйДокумент                            КАК ТранспортныйДокумент,
	|	Шапка.НомерПеревозочногоДокумента                     КАК НомерПеревозочногоДокумента,
	|	Шапка.ДатаПеревозочногоДокумента                      КАК ДатаПеревозочногоДокумента,
	|	Шапка.ТранспортноеСредство                            КАК ТранспортноеСредство,
	|	Шапка.НомерТранспортногоСредства                      КАК НомерТранспортногоСредства,
	|	Шапка.ДатаОтгрузки                                    КАК ДатаОтгрузки,
	|	Шапка.УведомитьОбОтгрузкеНаЭкспорт                    КАК УведомитьОбОтгрузкеНаЭкспорт,
	|
	|	ЕСТЬNULL(Шапка.СтранаНазначения.Код, """") КАК СтранаНазначенияКод
	|
	|ИЗ
	|	Документ.ВыводИзОборотаИСМП КАК Шапка
	|		ЛЕВОЕ СОЕДИНЕНИЕ Версии КАК Версии
	|		ПО Шапка.Ссылка = Версии.Ссылка
	|ГДЕ
	|	Шапка.Ссылка = &Ссылка",
	"Шапка");
	
	СписокЗапросов.Добавить(
	"ВЫБРАТЬ
	|	// Универсальные реквизиты
	|	Товары.Номенклатура       КАК Номенклатура,
	|	Товары.Характеристика     КАК Характеристика,
	|	Товары.Серия              КАК Серия,
	|	Товары.Упаковка           КАК Упаковка,
	|	Товары.Количество         КАК Количество,
	|	Товары.КоличествоУпаковок КАК КоличествоУпаковок,
	|	Товары.GTIN               КАК GTIN,
	|	Товары.КоличествоПотребительскихУпаковок КАК КоличествоПотребительскихУпаковок,
	|
	|	// Дополнительные реквизиты
	|	Товары.Цена      КАК Цена,
	|	Товары.Сумма     КАК Сумма,
	|	Товары.СуммаНДС  КАК СуммаНДС,
	|	Товары.СуммаСНДС КАК СуммаСНДС,
	|	Товары.СтавкаНДС КАК СтавкаНДС
	|ИЗ
	|	Документ.ВыводИзОборотаИСМП.Товары КАК Товары
	|ГДЕ
	|	Товары.Ссылка = &Ссылка
	|УПОРЯДОЧИТЬ ПО
	|	НомерСтроки
	|",
	"Товары");
	
	СписокЗапросов.Добавить(
	"ВЫБРАТЬ
	|	ШтрихкодыУпаковок.ШтрихкодУпаковки               КАК ШтрихкодУпаковки,
	|	ШтрихкодыУпаковок.ЧастичноеВыбытиеКоличество     КАК ЧастичноеВыбытиеКоличество,
	|	ШтрихкодыУпаковок.ЧастичноеВыбытиеВариантУчета   КАК ЧастичноеВыбытиеВариантУчета,
	|	ШтрихкодыУпаковок.ЧастичноеВыбытиеНоменклатура   КАК ЧастичноеВыбытиеНоменклатура,
	|	ШтрихкодыУпаковок.ЧастичноеВыбытиеХарактеристика КАК ЧастичноеВыбытиеХарактеристика
	|ИЗ
	|	Документ.ВыводИзОборотаИСМП.ШтрихкодыУпаковок КАК ШтрихкодыУпаковок
	|ГДЕ
	|	ШтрихкодыУпаковок.Ссылка = &Ссылка
	|УПОРЯДОЧИТЬ ПО
	|	НомерСтроки
	|",
	"ШтрихкодыУпаковок");
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Ссылка",   ДокументСсылка);
	Запрос.УстановитьПараметр("Операция", Операция);
	
	РезультатЗапроса = ОбщегоНазначенияИС.ВыполнитьПакетЗапросов(Запрос, СписокЗапросов);
	
	//@skip-warning
	Шапка             = РезультатЗапроса["Шапка"].Выбрать();
	//@skip-warning
	Товары            = РезультатЗапроса["Товары"].Выгрузить();
	Товары.Индексы.Добавить("Номенклатура,Характеристика,Серия");
	//@skip-warning
	ШтрихкодыУпаковок = РезультатЗапроса["ШтрихкодыУпаковок"].Выгрузить();
	
	Если Не Шапка.Следующий()
		Или Товары.Количество() = 0 Тогда
		
		СообщениеJSON = ОбменДаннымиИСМП.СтруктураСообщенияJSON();
		СообщениеJSON.Организация = Шапка.Организация;
		СообщениеJSON.Документ    = ДокументСсылка;
		СообщениеJSON.Описание    = ОбменДаннымиИСМП.ОписаниеОперацииПередачиДанных(
			Операция, ДокументСсылка);
		СообщениеJSON.ТекстОшибки = НСтр("ru = 'Нет данных для выгрузки.'");
		СообщениеJSON.ТребуетсяПодписание = Ложь;
		СообщенияJSON.Добавить(СообщениеJSON);
		
		Возврат СообщенияJSON;
		
	КонецЕсли;
	
	НомерВерсии = Шапка.ПоследнийНомерВерсии + 1;
	
	СообщениеJSON = ОбменДаннымиИСМП.СтруктураСообщенияJSON();
	СообщениеJSON.Организация       = Шапка.Организация;
	СообщениеJSON.Документ          = ДокументСсылка;
	СообщениеJSON.ДокументОснование = Шапка.ДокументОснование;
	
	СообщениеJSON.Описание = ОбменДаннымиИСМП.ОписаниеОперацииПередачиДанных(
		Операция, ДокументСсылка, НомерВерсии);
	
	СообщениеJSON.Назначение          = Перечисления.НазначениеСообщенийИСМП.ИСМП;
	СообщениеJSON.ТипСообщения        = Перечисления.ТипыЗапросовИС.Исходящий;
	СообщениеJSON.Версия              = НомерВерсии;
	СообщениеJSON.ТребуетсяПодписание = Истина;
	
	СообщениеJSON.Операция                  = Операция;
	СообщениеJSON.ТоварнаяГруппа            = Шапка.ТоварнаяГруппа;
	СообщениеJSON.СтанцияУправленияЗаказами = Неопределено;
	
	// Заполнение данных по маркируемым товарам
	ВидыПродукцииПоТоварнойГруппе = КонструкторИСМПОбщегоНазначенияКлиентСервер.ВидыПродукции(Шапка.ТоварнаяГруппа);
	ПараметрыСканирования = ШтрихкодированиеОбщегоНазначенияИС.ПараметрыСканирования(Шапка, Неопределено, ВидыПродукцииПоТоварнойГруппе);
	ОбщегоНазначенияИСМПКлиентСервер.УстановитьПараметрСканированияЗапрашиватьДанныеСервисаИСМП(ПараметрыСканирования, Ложь);
	
	ПараметрыЗапроса = Новый Структура();
	
	РезультатПоиска = ШтрихкодированиеИС.ВложенныеШтрихкодыУпаковок(
		ШтрихкодыУпаковок.ВыгрузитьКолонку("ШтрихкодУпаковки"),
		ПараметрыСканирования,, Истина);
	
	ИсточникДанных = РезультатПоиска.МаркированныеТовары;
	
	Если ЕстьКодыАгрегатов(ДокументСсылка, Шапка) Тогда
		
		ИсточникДанных = РезультатПоиска.ДеревоУпаковок.Строки;
		ДанныеДляЗапросаСтатусов = Новый Массив;
		Для Каждого СтрокаДерева Из ИсточникДанных Цикл
			Если СтрокаДерева.ТипШтрихкода = Перечисления.ТипыШтрихкодов.SSCC Тогда
				ДанныеДляЗапросаСтатусов.Добавить(СтрокаДерева);
			КонецЕсли;
		КонецЦикла;
		Если ДанныеДляЗапросаСтатусов.Количество() Тогда
			
			РезультатЗапроса = ИнтерфейсМОТП.ЗапроситьСтатусыКодовМаркировки(
				ДанныеДляЗапросаСтатусов, ПараметрыСканирования.Организация);
			Если РезультатЗапроса.ТребуетсяОбновлениеКлючаСессии Тогда
				
				СообщениеJSON.ПараметрыЗапроса = ДополнительныеПараметры.ПараметрыОбработкиДокумента;
				СообщениеJSON.Операция         = Перечисления.ВидыОперацийИСМП.ПовторноеФормированиеСообщений;
				СообщениеJSON.ТребуетсяПодписание = Ложь;
				СообщенияJSON.Добавить(СообщениеJSON);
				
				Возврат СообщенияJSON;
				
			ИначеЕсли ЗначениеЗаполнено(РезультатЗапроса.ТекстОшибки) Тогда
				ОбщегоНазначенияИСКлиентСервер.ДобавитьТекстОшибки(
					СообщениеJSON,
					РезультатЗапроса.ТекстОшибки);
				СообщенияJSON.Добавить(СообщениеJSON);
				
				Возврат СообщенияJSON;
				
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЕсли;
	
	ПараметрыНормализацииПрочее = РазборКодаМаркировкиИССлужебныйКлиентСервер.ПараметрыНормализацииКодаМаркировки();
	ПараметрыНормализацииПрочее.ИмяСвойстваКодМаркировки = "Штрихкод";
	ПараметрыНормализацииПрочее.НачинаетсяСоСкобки       = Ложь;
	
	ПользовательскиеПараметрыРазбораКодаМаркировки = РазборКодаМаркировкиИССлужебныйКлиентСервер.ПользовательскиеПараметрыРазбораКодаМаркировки();
	ПользовательскиеПараметрыРазбораКодаМаркировки.ПроверятьАлфавитЭлементов = Ложь;
	
	РеквизитыОрганизации = ОбщегоНазначенияИС.ИННКППGLNОрганизации(Шапка.Организация, Шапка.ПроизводственныйОбъект);
	
	Если Не ЗначениеЗаполнено(РеквизитыОрганизации.ИНН) Тогда
		ОбщегоНазначенияИСКлиентСервер.ДобавитьТекстОшибки(
			СообщениеJSON,
			СтрШаблон(
				НСтр("ru = 'Не заполнено поле ""ИНН"" для организации %1'"), Шапка.Организация));
	ИначеЕсли (СтрДлина(РеквизитыОрганизации.ИНН) > 10) Тогда
		ОбщегоНазначенияИСКлиентСервер.ДобавитьТекстОшибки(
			СообщениеJSON,
			НСтр("ru = 'Отправка уведомления об экспорте доступна только юридическим лицам'"));
	КонецЕсли;
	
	ТелоЗапроса = Новый Структура;
	
	Если ОтменаУведомленияОбЭкспорте Тогда
		ТелоЗапроса.Вставить("action", "CANCEL_SHIPPED_ABROAD");
	Иначе
		ТелоЗапроса.Вставить("action", "SHIPPED_ABROAD");
	КонецЕсли;
	
	ТелоЗапроса.Вставить("order_date",     ИнтеграцияИС.ДатаUTC(Шапка.Дата));
	ТелоЗапроса.Вставить("actionDate",     ИнтеграцияИС.ДатаUTC(Шапка.Дата));
	ТелоЗапроса.Вставить("participantInn", РеквизитыОрганизации.ИНН);
	ТелоЗапроса.Вставить("kpp",            РеквизитыОрганизации.КПП);
	
	Если Шапка.ТранспортныйДокумент Тогда
		
		ТелоЗапроса.Вставить("epdId", Шапка.ИдентификаторЭлектронногоПеревозочногоДокумента);
		
	Иначе
		
		ТранспортныйДокумент = Новый Структура;
		ТранспортныйДокумент.Вставить("documentNumber", Шапка.НомерПеревозочногоДокумента);
		ТранспортныйДокумент.Вставить("documentDate",   ИнтеграцияИС.ДатаUTC(Шапка.ДатаПеревозочногоДокумента));
		
		НомерТранспортногоСредства = "";
		УказываетсяТранспортноеСредство = ИнтеграцияИС.УказываетсяТранспортноеСредство();
		Если УказываетсяТранспортноеСредство Тогда
			Если ЗначениеЗаполнено(Шапка.ТранспортноеСредство) Тогда
				РеквизитыТранспортногоСредства =  ИнтеграцияИС.ЗначенияРеквизитовТранспортногоСредства(Шапка.ТранспортноеСредство);
			Иначе
				ОбщегоНазначенияИСКлиентСервер.ДобавитьТекстОшибки(
				СообщениеJSON,
					НСтр("ru = 'Не заполнено поле ""Транспортное средство""'"));
			КонецЕсли;
			НомерТранспортногоСредства = РеквизитыТранспортногоСредства.НомерТранспортногоСредства;
		Иначе
			НомерТранспортногоСредства = Шапка.НомерТранспортногоСредства;
		КонецЕсли;
		
		Если Не ЗначениеЗаполнено(НомерТранспортногоСредства) Тогда
			ОбщегоНазначенияИСКлиентСервер.ДобавитьТекстОшибки(
			СообщениеJSON,
				НСтр("ru = 'Не заполнено поле ""Номер транспортного средства""'"));
		КонецЕсли;
		
		ТранспортныйДокумент.Вставить("numberVehicle", НомерТранспортногоСредства);
		ТелоЗапроса.Вставить("transportDetails", ТранспортныйДокумент);
		
	КонецЕсли;
	
	ТелоЗапроса.Вставить("shippingDate",        ИнтеграцияИС.ДатаUTC(Шапка.ДатаОтгрузки));
	ТелоЗапроса.Вставить("importerCountryCode", Шапка.СтранаНазначенияКод);
	
	Если ЗначениеЗаполнено(Шапка.Контрагент) Тогда
		
		ИдентификаторПолучателя = ИнтеграцияИСВызовСервера.НалоговыйНомерКонтрагента(Шапка.Контрагент);
		Если ЗначениеЗаполнено(ИдентификаторПолучателя) Тогда
			
			ТелоЗапроса.Вставить("recipientInn", ИдентификаторПолучателя);
			
			СведенияОКонтрагенте = Новый Структура();
			СведенияОКонтрагенте.Вставить("Наименование", "");
			
			ИнтеграцияИСПереопределяемый.ЗаполнитьСведенияОбОрганизации(
				Шапка.Контрагент,
				СведенияОКонтрагенте);
			ТелоЗапроса.Вставить("recipientName", СведенияОКонтрагенте.Наименование);
			
		Иначе
			
			ОбщегоНазначенияИСКлиентСервер.ДобавитьТекстОшибки(
				СообщениеJSON,
				СтрШаблон(
					НСтр("ru = 'Не заполнено поле ""Налоговый номер в стране регистрации"".
							   |Контрагент: %1'"), Шапка.Контрагент));
			
		КонецЕсли;
		
	Иначе
		
		ОбщегоНазначенияИСКлиентСервер.ДобавитьТекстОшибки(
			СообщениеJSON,
			НСтр("ru = 'Не заполнено поле ""Контрагент""'"));
		
	КонецЕсли;
	
	//codes
	КодыМаркировки = Новый Массив;
	ТелоЗапроса.Вставить("codes", КодыМаркировки);
	
	Для Каждого СтрокаИсточникаДанных Из ИсточникДанных Цикл
		
		Если СтрокаИсточникаДанных.ВидУпаковки <> Перечисления.ВидыУпаковокИС.Потребительская Тогда
			
			СтрокаТЧ = Новый Структура;
			РезультатРазбора = ШтрихкодированиеОбщегоНазначенияИС.НоваяСтруктураОбработкиШтрихкода(
				СтрокаИсточникаДанных.Штрихкод, ВидыПродукцииПоТоварнойГруппе, ПользовательскиеПараметрыРазбораКодаМаркировки);
		
			Если СтрокаИсточникаДанных.ТипШтрихкода = Перечисления.ТипыШтрихкодов.SSCC20 Тогда
				РезультатРазбора.ТипШтрихкода = Перечисления.ТипыШтрихкодов.SSCC20;
			ИначеЕсли СтрокаИсточникаДанных.ТипШтрихкода = Перечисления.ТипыШтрихкодов.SSCC18 Тогда
				РезультатРазбора.ТипШтрихкода = Перечисления.ТипыШтрихкодов.SSCC18;
			КонецЕсли;
			
			СтрокаТЧ.Вставить(
				"code",
				ОбменДаннымиИСМП.КодМаркировкиДляПередачиИСМП(РезультатРазбора, ПараметрыНормализацииПрочее));
			
			КодыМаркировки.Добавить(СтрокаТЧ);
		Иначе
		ПараметрыОтбора = Новый Структура;
		
		ПараметрыОтбора.Вставить("Номенклатура",   СтрокаИсточникаДанных.Номенклатура);
		ПараметрыОтбора.Вставить("Характеристика", СтрокаИсточникаДанных.Характеристика);
		ПараметрыОтбора.Вставить("Серия",          СтрокаИсточникаДанных.Серия);
		
		НайденныеСтроки = Товары.НайтиСтроки(ПараметрыОтбора);
		Если НайденныеСтроки.Количество() = 1 Тогда
			
			СтрокаТЧ = Новый Структура;
			
			РезультатРазбора = ШтрихкодированиеОбщегоНазначенияИС.НоваяСтруктураОбработкиШтрихкода(
				СтрокаИсточникаДанных.Штрихкод, ВидыПродукцииПоТоварнойГруппе, ПользовательскиеПараметрыРазбораКодаМаркировки);
			СтрокаТЧ.Вставить(
				"code",
				ОбменДаннымиИСМП.КодМаркировкиДляПередачиИСМП(РезультатРазбора, ПараметрыНормализацииПрочее));
			
			КодыМаркировки.Добавить(СтрокаТЧ);
			
		ИначеЕсли НайденныеСтроки.Количество() > 1 Тогда
			
			ТекстОшибки = СтрШаблон(
					НСтр("ru = 'В табличной части ""Товары"" дублируется номенклатура %1.'"),
						ОбщегоНазначенияИС.ПредставлениеНоменклатуры(
									ПараметрыОтбора.Номенклатура,
									ПараметрыОтбора.Характеристика,,
									ПараметрыОтбора.Серия));
			ОбщегоНазначенияИСКлиентСервер.ДобавитьТекстОшибки(СообщениеJSON, ТекстОшибки);
			
		Иначе
			ТекстОшибки = СтрШаблон(
			НСтр("ru = 'В табличной части ""Товары"" не найдена номенклатура %1.'"),
				ОбщегоНазначенияИС.ПредставлениеНоменклатуры(
						ПараметрыОтбора.Номенклатура,
						ПараметрыОтбора.Характеристика,,
						ПараметрыОтбора.Серия));
			ОбщегоНазначенияИСКлиентСервер.ДобавитьТекстОшибки(СообщениеJSON, ТекстОшибки);
		КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	
	ТекстСообщенияJSON                = ОбменДаннымиИСМПКлиентСервер.ОбъектВТекстJSON(ТелоЗапроса, Истина);
	СообщениеJSON.ТекстСообщенияJSON  = ТекстСообщенияJSON;
	СообщениеJSON.ПараметрыЗапроса    = ПараметрыЗапроса;
	СообщенияJSON.Добавить(СообщениеJSON);
	
	Возврат СообщенияJSON;
	
КонецФункции

// Формирует абстрактное JSON сообщение для операции аннулирования отгрузки товаров
//
// Параметры:
//  ДокументСсылка - ДокументСсылка.ОтгрузкаТоваровИСМП - Документ Отгрузка Товаров ИС МП
//  ДополнительныеПараметры - Структура, Неопределено - Дополнительные параметры
//
// Возвращаемое значение:
//  Массив Из См. ИнтеграцияИСМПСлужебный.СтруктураСообщенияJSON - Сообщения к передаче
Функция АннулироватьВыводИзОборотаJSON(ДокументСсылка, ДополнительныеПараметры = Неопределено)
	
	Операция       = Перечисления.ВидыОперацийИСМП.ВыводИзОборотаПриОСУАннулирование;
	СообщенияJSON  = Новый Массив;
	СписокЗапросов = Новый СписокЗначений;
	
	СписокЗапросов.Добавить(
	"ВЫБРАТЬ
	|	ИСМППрисоединенныеФайлы.Документ                      КАК Ссылка,
	|	МАКСИМУМ(ЕСТЬNULL(ИСМППрисоединенныеФайлы.Версия, 0)) КАК ПоследнийНомерВерсии
	|ПОМЕСТИТЬ Версии
	|ИЗ
	|	Справочник.ИСМППрисоединенныеФайлы КАК ИСМППрисоединенныеФайлы
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ВыводИзОборотаИСМП КАК Шапка
	|		ПО Шапка.Ссылка   = &Ссылка
	|		 И ИСМППрисоединенныеФайлы.Операция = &Операция
	|		 И Шапка.Ссылка   = ИСМППрисоединенныеФайлы.Документ
	|ГДЕ
	|	ИСМППрисоединенныеФайлы.ТипСообщения = ЗНАЧЕНИЕ(Перечисление.ТипыЗапросовИС.Исходящий)
	|СГРУППИРОВАТЬ ПО
	|	ИСМППрисоединенныеФайлы.Документ
	|");
	
	СписокЗапросов.Добавить(
	"ВЫБРАТЬ
	|	ИСМППрисоединенныеФайлы.Ссылка               КАК Ссылка,
	|	ИСМППрисоединенныеФайлы.ВладелецФайла        КАК ВладелецФайла,
	|	ИСМППрисоединенныеФайлы.ИдентификаторЗапроса КАК ИдентификаторЗаявки
	|ИЗ
	|	Справочник.ИСМППрисоединенныеФайлы КАК ИСМППрисоединенныеФайлы
	|ГДЕ
	|	ИСМППрисоединенныеФайлы.ВладелецФайла     = &Ссылка
	|	И ИСМППрисоединенныеФайлы.ТипСообщения    = ЗНАЧЕНИЕ(Перечисление.ТипыЗапросовИС.Исходящий)
	|	И ИСМППрисоединенныеФайлы.Операция        <> &Операция
	|	И ИСМППрисоединенныеФайлы.СтатусОбработки = ЗНАЧЕНИЕ(Перечисление.СтатусыОбработкиСообщенийИСМП.ЗаявкаВыполнена)
	|	И ИСМППрисоединенныеФайлы.Версия В
	|			(ВЫБРАТЬ
	|				МАКСИМУМ(ИСМППрисоединенныеФайлыВерсия.Версия) КАК Версия
	|			ИЗ
	|				Справочник.ИСМППрисоединенныеФайлы КАК ИСМППрисоединенныеФайлыВерсия
	|			ГДЕ
	|				ИСМППрисоединенныеФайлыВерсия.ВладелецФайла  = &Ссылка
	|				И ИСМППрисоединенныеФайлыВерсия.ТипСообщения = ЗНАЧЕНИЕ(Перечисление.ТипыЗапросовИС.Исходящий)
	|				И ИСМППрисоединенныеФайлыВерсия.Операция     <> &Операция)
	|",
	"ПрисоединенныеФайлы");
	
	СписокЗапросов.Добавить(
	"ВЫБРАТЬ
	|	Шапка.Номер                              КАК Номер,
	|	Шапка.Дата                               КАК Дата,
	|	Шапка.Организация                        КАК Организация,
	|	ЕСТЬNULL(Версии.ПоследнийНомерВерсии, 0) КАК ПоследнийНомерВерсии,
	|	Представление(Шапка.Организация)         КАК ОрганизацияПредставление,
	|	Шапка.Ответственный                      КАК Ответственный,
	|	Представление(Шапка.Ответственный)       КАК ОтветственныйПредставление,
	|	Шапка.УдалитьОперация                    КАК Операция,
	|	Шапка.Причина                            КАК Причина,
	|	Шапка.Причина.ОписаниеПричины            КАК ШаблонОписаниеПричины,
	|	Шапка.Причина.Имя                        КАК ПричинаВыводаИзОборота,
	|	Шапка.ТоварнаяГруппа                     КАК ТоварнаяГруппа,
	|	Шапка.ДокументОснование                  КАК ДокументОснование,
	|	Шапка.Ссылка                             КАК Ссылка,
	|	Шапка.ИдентификаторЗаявки                КАК ИдентификаторЗаявки,
	|	Шапка.УведомитьОбОтгрузкеНаЭкспорт       КАК УведомитьОбОтгрузкеНаЭкспорт
	|ИЗ
	|	Документ.ВыводИзОборотаИСМП КАК Шапка
	|		ЛЕВОЕ СОЕДИНЕНИЕ Версии КАК Версии
	|		ПО Шапка.Ссылка = Версии.Ссылка
	|ГДЕ
	|	Шапка.Ссылка = &Ссылка",
	"Шапка");
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Ссылка",   ДокументСсылка);
	Запрос.УстановитьПараметр("Операция", Операция);
	
	РезультатЗапроса = ОбщегоНазначенияИС.ВыполнитьПакетЗапросов(Запрос, СписокЗапросов);
	
	//@skip-warning
	Шапка = РезультатЗапроса["Шапка"].Выбрать();
	
	Если Не Шапка.Следующий() Тогда
		
		СообщениеJSON             = ОбменДаннымиИСМП.СтруктураСообщенияJSON();
		СообщениеJSON.Организация = Шапка.Организация;
		СообщениеJSON.Документ    = ДокументСсылка;
		СообщениеJSON.Описание    = ОбменДаннымиИСМП.ОписаниеОперацииПередачиДанных(
			Операция, ДокументСсылка);
		СообщениеJSON.ТекстОшибки         = НСтр("ru = 'Нет данных для выгрузки.'");
		СообщениеJSON.ТребуетсяПодписание = Ложь;
		СообщенияJSON.Добавить(СообщениеJSON);
		
		Возврат СообщенияJSON;
		
	КонецЕсли;
	
	//@skip-warning
	ТаблицаПрисоединенныеФайлы = РезультатЗапроса["ПрисоединенныеФайлы"].Выгрузить();
	Если ТаблицаПрисоединенныеФайлы.Количество() = 0 Тогда
		
		СообщениеJSON             = ОбменДаннымиИСМП.СтруктураСообщенияJSON();
		СообщениеJSON.Документ    = ДокументСсылка;
		СообщениеJSON.Организация = Шапка.Организация;
		СообщениеJSON.Описание    = ОбменДаннымиИСМП.ОписаниеОперацииПередачиДанных(
			Операция, ДокументСсылка);
		СообщениеJSON.ТекстОшибки         = НСтр("ru = 'Нет данных для определения идентификатора исходной операции.'");
		СообщениеJSON.ТребуетсяПодписание = Ложь;
		СообщенияJSON.Добавить(СообщениеJSON);
		
		Возврат СообщенияJSON;
		
	КонецЕсли;
	
	РеквизитыОрганизации = РаботаСКонтрагентамиИСВызовСервера.ИННКПППоОрганизацииКонтрагенту(Шапка.Организация);
	
	Если Не ЗначениеЗаполнено(РеквизитыОрганизации.ИНН) Тогда
		ОбщегоНазначенияИСКлиентСервер.ДобавитьТекстОшибки(
			СообщениеJSON,
			СтрШаблон(
				НСтр("ru = 'Не заполнено поле ""ИНН"" для организации %1'"), Шапка.Организация));
	КонецЕсли;
	
	НомерВерсии = Шапка.ПоследнийНомерВерсии + 1;
	
	СообщениеJSON = ОбменДаннымиИСМП.СтруктураСообщенияJSON();
	
	СообщениеJSON.Организация       = Шапка.Организация;
	СообщениеJSON.Документ          = ДокументСсылка;
	СообщениеJSON.ДокументОснование = Шапка.ДокументОснование;
	
	Если ЗначениеЗаполнено(Шапка.Причина) Тогда
		СообщениеJSON.Описание = ОбменДаннымиИСМП.ОписаниеОперации(
			Шапка.ШаблонОписаниеПричины, ДокументСсылка, НомерВерсии);
	Иначе
		СообщениеJSON.Описание = ОбменДаннымиИСМП.ОписаниеОперацииПередачиДанных(
			Операция, ДокументСсылка, НомерВерсии);
	КонецЕсли;
	
	ТелоЗапроса = Новый Структура();
	ТелоЗапроса.Вставить("version",            1);
	ТелоЗапроса.Вставить("inn",                РеквизитыОрганизации.ИНН);
	ТелоЗапроса.Вставить("lk_gtin_receipt_id", ТаблицаПрисоединенныеФайлы[0].ИдентификаторЗаявки);
	
	ТекстСообщенияJSON = ОбменДаннымиИСМПКлиентСервер.ОбъектВТекстJSON(ТелоЗапроса, Истина);
	
	СообщениеJSON.ТекстСообщенияJSON  = ТекстСообщенияJSON;
	СообщениеJSON.ТипСообщения        = Перечисления.ТипыЗапросовИС.Исходящий;
	СообщениеJSON.Версия              = НомерВерсии;
	СообщениеJSON.ТребуетсяПодписание = Истина;
	
	СообщениеJSON.ТоварнаяГруппа            = Шапка.ТоварнаяГруппа;
	СообщениеJSON.Операция                  = Операция;
	СообщениеJSON.Назначение                = Перечисления.НазначениеСообщенийИСМП.ИСМП;
	СообщениеJSON.СтанцияУправленияЗаказами = Неопределено;
	
	СообщенияJSON.Добавить(СообщениеJSON);
	
	Возврат СообщенияJSON;
	
КонецФункции

// Формирует JSON сообщения для вывода КМ из оборота
//
// Параметры:
//  ДокументСсылка - ДокументСсылка.ВыводИзОборотаИСМП - Документ Маркировка товаров ИС МП.
//  ДополнительныеПараметры - Структура - Дополнительные параметры
//
// Возвращаемое значение:
//  Массив Из См. ИнтеграцияИСМПСлужебный.СтруктураСообщенияJSON - Сообщения к передаче
Функция ВыводИзОборотаJSON(ДокументСсылка, ДополнительныеПараметры = Неопределено)
	
	Операция              = Перечисления.ВидыОперацийИСМП.ВыводИзОборота;
	СообщенияJSON         = Новый Массив;
	СписокЗапросов        = Новый СписокЗначений;
	
	СписокЗапросов.Добавить(
	"ВЫБРАТЬ
	|	ИСМППрисоединенныеФайлы.Документ           КАК Ссылка,
	|	КОЛИЧЕСТВО(ИСМППрисоединенныеФайлы.Ссылка) КАК ПоследнийНомерВерсии
	|ПОМЕСТИТЬ Версии
	|ИЗ
	|	Справочник.ИСМППрисоединенныеФайлы КАК ИСМППрисоединенныеФайлы
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ВыводИзОборотаИСМП КАК Шапка
	|		ПО Шапка.Ссылка   = &Ссылка
	|		 И ИСМППрисоединенныеФайлы.Операция = &Операция
	|		 И Шапка.Ссылка   = ИСМППрисоединенныеФайлы.Документ
	|ГДЕ
	|	ИСМППрисоединенныеФайлы.ТипСообщения = ЗНАЧЕНИЕ(Перечисление.ТипыЗапросовИС.Исходящий)
	|СГРУППИРОВАТЬ ПО
	|	ИСМППрисоединенныеФайлы.Документ
	|");
	
	СписокЗапросов.Добавить(
	"ВЫБРАТЬ
	|	Шапка.Номер                              КАК Номер,
	|	Шапка.Дата                               КАК Дата,
	|	ЕСТЬNULL(Версии.ПоследнийНомерВерсии, 0) КАК ПоследнийНомерВерсии,
	|	Шапка.ДокументОснование                  КАК ДокументОснование,
	|
	|	Шапка.Организация                КАК Организация,
	|	Представление(Шапка.Организация) КАК ОрганизацияПредставление,
	|
	|	Шапка.Ответственный                КАК Ответственный,
	|	Представление(Шапка.Ответственный) КАК ОтветственныйПредставление,
	|
	|	Шапка.Причина                         КАК Причина,
	|	Шапка.Причина.ОписаниеПричины         КАК ШаблонОписаниеПричины,
	|	Шапка.Причина.Имя                     КАК ПричинаВыводаИзОборота,
	|	Шапка.Контрагент                      КАК Контрагент,
	|	Шапка.ОписаниеПричины                 КАК ОписаниеПричины,
	|	Шапка.ВидПервичногоДокумента          КАК ВидПервичногоДокумента,
	|	Шапка.НаименованиеПервичногоДокумента КАК НаименованиеПервичногоДокумента,
	|	Шапка.НомерПервичногоДокумента        КАК НомерПервичногоДокумента,
	|	Шапка.ДатаПервичногоДокумента         КАК ДатаПервичногоДокумента,
	|	Шапка.ТоварнаяГруппа                  КАК ТоварнаяГруппа,
	|	Шапка.ПроизводственныйОбъект          КАК ПроизводственныйОбъект,
	|	Шапка.АдресПлощадки                   КАК АдресПлощадки,
	|	Шапка.АдресПлощадкиСтрокой            КАК АдресПлощадкиСтрокой,
	|	Шапка.ИдентификаторГосударственногоКонтракта КАК ИдентификаторГосударственногоКонтракта,
	|	Шапка.ОбъемноСортовойУчет             КАК ОбъемноСортовойУчет,
	|	Шапка.Ссылка                          КАК Ссылка,
	|	Шапка.УведомитьОбОтгрузкеНаЭкспорт    КАК УведомитьОбОтгрузкеНаЭкспорт,
	|	Шапка.ИспользуетсяМОД                 КАК ИспользуетсяМОД,
	|	Шапка.НомерТаможеннойДекларации       КАК НомерТаможеннойДекларации,
	|	Шапка.ИдентификаторФИАС               КАК ИдентификаторФИАС,
	|
	|	ЕСТЬNULL(Шапка.СтранаНазначения.Код, """") КАК СтранаНазначенияКод
	|
	|ИЗ
	|	Документ.ВыводИзОборотаИСМП КАК Шапка
	|		ЛЕВОЕ СОЕДИНЕНИЕ Версии КАК Версии
	|		ПО Шапка.Ссылка = Версии.Ссылка
	|ГДЕ
	|	Шапка.Ссылка = &Ссылка",
	"Шапка");
	
	ТекстЗапросаТовары = 
	"ВЫБРАТЬ
	|	// Универсальные реквизиты
	|	Товары.Номенклатура       КАК Номенклатура,
	|	Товары.Характеристика     КАК Характеристика,
	|	Товары.Серия              КАК Серия,
	|	Товары.Упаковка           КАК Упаковка,
	|	Товары.Количество         КАК Количество,
	|	Товары.КоличествоУпаковок КАК КоличествоУпаковок,
	|	Товары.GTIN               КАК GTIN,
	|	Товары.КоличествоПотребительскихУпаковок КАК КоличествоПотребительскихУпаковок,
	|
	|	// Дополнительные реквизиты
	|	ОписаниеНоменклатурыИС.КлючВидовПродукции.ВидПродукцииГИСМТ КАК ВидПродукции,
	|	Товары.Сырье                                                КАК Сырье,
	|	Товары.Сырье.ВидПродукции                                   КАК ВидПродукцииСырья,
	|	Товары.Сырье.Идентификатор                                  КАК ИдентификаторСырья,
	|	&ТекстЗапросаКодЕдиницыИзмерения                            КАК ЕдиницаИзмеренияКод,
	|	Товары.Цена      КАК Цена,
	|	Товары.Сумма     КАК Сумма,
	|	Товары.СуммаНДС  КАК СуммаНДС,
	|	Товары.СуммаСНДС КАК СуммаСНДС,
	|	Товары.СтавкаНДС КАК СтавкаНДС
	|ИЗ
	|	Документ.ВыводИзОборотаИСМП.Товары КАК Товары
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ОписаниеНоменклатурыИС КАК ОписаниеНоменклатурыИС
	|		ПО Товары.Номенклатура = ОписаниеНоменклатурыИС.Номенклатура
	|ГДЕ
	|	Товары.Ссылка = &Ссылка
	|УПОРЯДОЧИТЬ ПО
	|	НомерСтроки
	|";
	
	ИнтеграцияИСМП.ИзменитьТекстЗапросаКодЕдиницыИзмерения(ТекстЗапросаТовары);
	СписокЗапросов.Добавить(ТекстЗапросаТовары, "Товары");
	
	СписокЗапросов.Добавить(
	"ВЫБРАТЬ
	|	ШтрихкодыУпаковок.ШтрихкодУпаковки               КАК ШтрихкодУпаковки,
	|	ШтрихкодыУпаковок.ЧастичноеВыбытиеКоличество     КАК ЧастичноеВыбытиеКоличество,
	|	ШтрихкодыУпаковок.ЧастичноеВыбытиеВариантУчета   КАК ЧастичноеВыбытиеВариантУчета,
	|	ШтрихкодыУпаковок.ЧастичноеВыбытиеНоменклатура   КАК ЧастичноеВыбытиеНоменклатура,
	|	ШтрихкодыУпаковок.ЧастичноеВыбытиеХарактеристика КАК ЧастичноеВыбытиеХарактеристика
	|ИЗ
	|	Документ.ВыводИзОборотаИСМП.ШтрихкодыУпаковок КАК ШтрихкодыУпаковок
	|ГДЕ
	|	ШтрихкодыУпаковок.Ссылка = &Ссылка
	|УПОРЯДОЧИТЬ ПО
	|	НомерСтроки
	|",
	"ШтрихкодыУпаковок");
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Ссылка",                ДокументСсылка);
	Запрос.УстановитьПараметр("Операция",              Операция);
	Запрос.УстановитьПараметр("ОперацияАннулирования", Перечисления.ВидыОперацийИСМП.ВыводИзОборотаПриОСУАннулирование);
	
	РезультатЗапроса = ОбщегоНазначенияИС.ВыполнитьПакетЗапросов(Запрос, СписокЗапросов);
	
	//@skip-warning
	Шапка             = РезультатЗапроса["Шапка"].Выбрать();
	//@skip-warning
	Товары            = РезультатЗапроса["Товары"].Выгрузить();
	Товары.Индексы.Добавить("Номенклатура,Характеристика,Серия");
	//@skip-warning
	ШтрихкодыУпаковок = РезультатЗапроса["ШтрихкодыУпаковок"].Выгрузить();
	
	Если Не Шапка.Следующий()
		Или Товары.Количество() = 0 Тогда
		
		СообщениеJSON = ОбменДаннымиИСМП.СтруктураСообщенияJSON();
		СообщениеJSON.Организация = Шапка.Организация;
		СообщениеJSON.Документ    = ДокументСсылка;
		СообщениеJSON.Описание = ОбменДаннымиИСМП.ОписаниеОперации(
			Шапка.ШаблонОписаниеПричины, ДокументСсылка);
		СообщениеJSON.ТекстОшибки = НСтр("ru = 'Нет данных для выгрузки.'");
		СообщениеJSON.ТребуетсяПодписание = Ложь;
		СообщенияJSON.Добавить(СообщениеJSON);
		
		Возврат СообщенияJSON;
		
	КонецЕсли;
	
	НомерВерсии = Шапка.ПоследнийНомерВерсии + 1;
	
	ВидыПродукцииПоТоварнойГруппе = КонструкторИСМПОбщегоНазначенияКлиентСервер.ВидыПродукцииПоТоварнойГруппе(Шапка.ТоварнаяГруппа);
	
	СообщениеJSON = ОбменДаннымиИСМП.СтруктураСообщенияJSON();
	СообщениеJSON.Организация       = Шапка.Организация;
	СообщениеJSON.Документ          = ДокументСсылка;
	СообщениеJSON.ДокументОснование = Шапка.ДокументОснование;
	
	СообщениеJSON.Описание = ОбменДаннымиИСМП.ОписаниеОперации(
		Шапка.ШаблонОписаниеПричины, ДокументСсылка, НомерВерсии);
	
	СообщениеJSON.Назначение          = Перечисления.НазначениеСообщенийИСМП.ИСМП;
	
	СообщениеJSON.ТипСообщения        = Перечисления.ТипыЗапросовИС.Исходящий;
	СообщениеJSON.Версия              = НомерВерсии;
	СообщениеJSON.ТребуетсяПодписание = Истина;
	СообщениеJSON.Операция            = Перечисления.ВидыОперацийИСМП.ВыводИзОборота;
	СообщениеJSON.ТоварнаяГруппа            = Шапка.ТоварнаяГруппа;
	СообщениеJSON.СтанцияУправленияЗаказами = Неопределено;
	
	// Заполнение данных по маркируемым товарам
	ВидыПродукцииПоТоварнойГруппе = КонструкторИСМПОбщегоНазначенияКлиентСервер.ВидыПродукции(Шапка.ТоварнаяГруппа);
	
	РеквизитыОрганизации = ОбщегоНазначенияИС.ИННКППGLNОрганизации(Шапка.Организация, Шапка.ПроизводственныйОбъект);
	
	Если Не ЗначениеЗаполнено(РеквизитыОрганизации.ИНН) Тогда
		ОбщегоНазначенияИСКлиентСервер.ДобавитьТекстОшибки(
			СообщениеJSON,
			СтрШаблон(
				НСтр("ru = 'Не заполнено поле ""ИНН"" для организации %1'"), Шапка.Организация));
	КонецЕсли;
	
	ЭтоСырьеГИСМТ = КонструкторИСМПКлиентСервер.ЭтоСырьеГИСМТ(ВидыПродукцииПоТоварнойГруппе);
	
	ПараметрыСканирования = ШтрихкодированиеОбщегоНазначенияИС.ПараметрыСканирования(Шапка, Неопределено, ВидыПродукцииПоТоварнойГруппе);
	ОбщегоНазначенияИСМПКлиентСервер.УстановитьПараметрСканированияЗапрашиватьДанныеСервисаИСМП(ПараметрыСканирования, Ложь);
	
	ПараметрыФормированияТела = Новый Структура;
	ПараметрыФормированияТела.Вставить("ЭтоСырьеГИСМТ",         ЭтоСырьеГИСМТ);
	ПараметрыФормированияТела.Вставить("Шапка",                 Шапка);
	ПараметрыФормированияТела.Вставить("Товары",                Товары);
	ПараметрыФормированияТела.Вставить("ШтрихкодыУпаковок",     ШтрихкодыУпаковок);
	ПараметрыФормированияТела.Вставить("СообщениеJSON",         СообщениеJSON);
	ПараметрыФормированияТела.Вставить("РеквизитыОрганизации",  РеквизитыОрганизации);
	ПараметрыФормированияТела.Вставить("Операция",              Операция);
	ПараметрыФормированияТела.Вставить("СообщенияJSON",         СообщенияJSON);
	ПараметрыФормированияТела.Вставить("ДокументСсылка",        ДокументСсылка);
	ПараметрыФормированияТела.Вставить("ПараметрыСканирования", ПараметрыСканирования);
	ПараметрыФормированияТела.Вставить("Операция",              Операция);
	ПараметрыФормированияТела.Вставить("ВидыПродукцииПоТоварнойГруппе", ВидыПродукцииПоТоварнойГруппе);
	ПараметрыФормированияТела.Вставить("ПараметрыОбработкиДокумента",   ДополнительныеПараметры.ПараметрыОбработкиДокумента);
	ПараметрыФормированияТела.Вставить("ПараметрыОбмена",               ДополнительныеПараметры.ПараметрыОбмена);
	
	ТелоЗапроса = Новый Структура;
	ТелоЗапроса.Вставить("action",   Шапка.ПричинаВыводаИзОборота);
	ТелоЗапроса.Вставить("products", Новый Массив);
	
	ПараметрыЗапроса = Новый Структура();
	ПараметрыЗапроса.Вставить("ОбъемноСортовойУчет", Шапка.ОбъемноСортовойУчет);
	
	Если ЭтоСырьеГИСМТ Тогда
		СформироватьТелоЗапросаСырье(ПараметрыФормированияТела, ТелоЗапроса);
	ИначеЕсли Шапка.ОбъемноСортовойУчет Тогда
		СформироватьТелоЗапросаОСУ(ПараметрыФормированияТела, ТелоЗапроса);
	ИначеЕсли Не СформироватьТелоЗапросаПоКодамМаркировки(ПараметрыФормированияТела, ТелоЗапроса) Тогда
		Возврат СообщенияJSON;
	КонецЕсли;
	
	ТекстСообщенияJSON                = ОбменДаннымиИСМПКлиентСервер.ОбъектВТекстJSON(ТелоЗапроса, Истина);
	СообщениеJSON.ТекстСообщенияJSON  = ТекстСообщенияJSON;
	СообщениеJSON.ПараметрыЗапроса    = ПараметрыЗапроса;
	СообщенияJSON.Добавить(СообщениеJSON);
	
	Возврат СообщенияJSON;
	
КонецФункции

Функция СформироватьТелоЗапросаПоКодамМаркировки(ПараметрыФормирования, ТелоЗапроса)
	
	Шапка                       = ПараметрыФормирования.Шапка;
	Товары                      = ПараметрыФормирования.Товары;
	ШтрихкодыУпаковок           = ПараметрыФормирования.ШтрихкодыУпаковок;
	СообщениеJSON               = ПараметрыФормирования.СообщениеJSON;
	ПараметрыСканирования       = ПараметрыФормирования.ПараметрыСканирования;
	Операция                    = ПараметрыФормирования.Операция;
	ПараметрыОбработкиДокумента = ПараметрыФормирования.ПараметрыОбработкиДокумента;
	СообщенияJSON               = ПараметрыФормирования.СообщенияJSON;
	ВидыПродукцииПоТоварнойГруппе = ПараметрыФормирования.ВидыПродукцииПоТоварнойГруппе;
	ДоступнаПередачаУведомленияОбЭкспорте = ВыводИзОборотаКлиентСервер.ДоступноУведомлениеОбОтгрузкеНаЭкспорт(
		ВидыПродукцииПоТоварнойГруппе, Шапка.Причина);
	
	МассивУпаковок = Новый Массив;
	Для Каждого СтрокаТаблицы Из ШтрихкодыУпаковок Цикл
		СтрокаДанных = ШтрихкодированиеИС.НовыйЭлементКоллекцииУпаковокДляРаспределенияПоТоварам();
		ЗаполнитьЗначенияСвойств(СтрокаДанных, СтрокаТаблицы);
		МассивУпаковок.Добавить(СтрокаДанных);
	КонецЦикла;
	
	РезультатПоиска = ШтрихкодированиеИС.ВложенныеШтрихкодыУпаковок(
		МассивУпаковок,
		ПараметрыСканирования,, Истина);
		
	ДанныеПоТоварам = РезультатПоиска.ДеревоУпаковок.Строки;
	ДанныеДляЗапросаСтатусов = Новый Массив;
	Для Каждого СтрокаДерева Из ДанныеПоТоварам Цикл
		Если СтрокаДерева.ТипШтрихкода = Перечисления.ТипыШтрихкодов.SSCC Тогда
			ДанныеДляЗапросаСтатусов.Добавить(СтрокаДерева);
		КонецЕсли;
	КонецЦикла;
	
	Если ДанныеДляЗапросаСтатусов.Количество() Тогда
			
		РезультатЗапроса = ИнтерфейсМОТП.ЗапроситьСтатусыКодовМаркировки(
			ДанныеДляЗапросаСтатусов, ПараметрыСканирования.Организация);
		Если РезультатЗапроса.ТребуетсяОбновлениеКлючаСессии Тогда
				
			СообщениеJSON.ПараметрыЗапроса = ПараметрыОбработкиДокумента;
			СообщениеJSON.Операция         = Перечисления.ВидыОперацийИСМП.ПовторноеФормированиеСообщений;
			СообщениеJSON.Назначение       = Перечисления.НазначениеСообщенийИСМП.ИСМП; 
			СообщениеJSON.ТребуетсяПодписание = Ложь;
			СообщенияJSON.Добавить(СообщениеJSON);
			
			Возврат Ложь;
			
		ИначеЕсли ЗначениеЗаполнено(РезультатЗапроса.ТекстОшибки) Тогда
			ОбщегоНазначенияИСКлиентСервер.ДобавитьТекстОшибки(
				СообщениеJSON,
				РезультатЗапроса.ТекстОшибки);
			СообщенияJSON.Добавить(СообщениеJSON);
			
			Возврат Ложь;
			
		КонецЕсли;
		
	КонецЕсли;
	
	ПараметрыНормализацииПрочее = РазборКодаМаркировкиИССлужебныйКлиентСервер.ПараметрыНормализацииКодаМаркировки();
	ПараметрыНормализацииПрочее.ИмяСвойстваКодМаркировки = "Штрихкод";
	ПараметрыНормализацииПрочее.НачинаетсяСоСкобки       = Ложь;
	
	ПользовательскиеПараметрыРазбораКодаМаркировки = РазборКодаМаркировкиИССлужебныйКлиентСервер.ПользовательскиеПараметрыРазбораКодаМаркировки();
	ПользовательскиеПараметрыРазбораКодаМаркировки.ПроверятьАлфавитЭлементов = Ложь;
	
	Если Не ДополнитьТелоЗапросаОбщимиПолями(ПараметрыФормирования, ТелоЗапроса) Тогда
		Возврат Ложь;
	КонецЕсли;
	
	ДополнитьТелоЗапросаПоДаннымКонтрагента(ПараметрыФормирования, ТелоЗапроса);
	
	ИспользованиеЦены       = ВыводИзОборотаКлиентСервер.ДоступноПолеЦена(ВидыПродукцииПоТоварнойГруппе, Шапка.Причина);
	ИспользованиеЦеныВсегда = ВыводИзОборотаКлиентСервер.ПроверятьЗаполнениеПоляЦена(ВидыПродукцииПоТоварнойГруппе, Шапка.Причина);
	ДанныеПоШтрихкодам      = Новый Структура("ТребуетсяЧастичноеВыбытиеИС");

	Для Каждого СтрокаТЧМаркированныеТовары Из ДанныеПоТоварам Цикл
		
		Если ДоступнаПередачаУведомленияОбЭкспорте
			И СтрокаТЧМаркированныеТовары.ВидУпаковки <> Перечисления.ВидыУпаковокИС.Потребительская
			И Не ИспользованиеЦены Тогда
			
			СтрокаТЧ = Новый Структура;
			
			РезультатРазбора = ШтрихкодированиеОбщегоНазначенияИС.НоваяСтруктураОбработкиШтрихкода(
				СтрокаТЧМаркированныеТовары.Штрихкод, ВидыПродукцииПоТоварнойГруппе, ПользовательскиеПараметрыРазбораКодаМаркировки);
			
			Если СтрокаТЧМаркированныеТовары.ТипШтрихкода = Перечисления.ТипыШтрихкодов.SSCC20 Тогда
				РезультатРазбора.ТипШтрихкода = Перечисления.ТипыШтрихкодов.SSCC20;
			ИначеЕсли СтрокаТЧМаркированныеТовары.ТипШтрихкода = Перечисления.ТипыШтрихкодов.SSCC18 Тогда
				РезультатРазбора.ТипШтрихкода = Перечисления.ТипыШтрихкодов.SSCC18;
			КонецЕсли;
			
			СтрокаТЧ.Вставить(
				"cis",
				ОбменДаннымиИСМП.КодМаркировкиДляПередачиИСМП(РезультатРазбора, ПараметрыНормализацииПрочее));
			
			ТелоЗапроса.products.Добавить(СтрокаТЧ);
			
		Иначе
			
			ПараметрыОтбора = Новый Структура;
			
			Если ОбщегоНазначенияИСКлиентСерверПовтИсп.ПоддерживаетсяЧастичноеВыбытие(
				СтрокаТЧМаркированныеТовары.ВидПродукции, Операция)
				И КонструкторИСМПКлиентСервер.ПоддерживаетсяЧастичноеВыбытиеПриВыводеИзОборота(
					Шапка.ТоварнаяГруппа, Шапка.Причина)
				И ШтрихкодированиеОбщегоНазначенияИС.ТребуетсяЧастичноеВыбытие(ПараметрыСканирования, ДанныеПоШтрихкодам)
				И СтрокаТЧМаркированныеТовары.ЧастичноеВыбытие Тогда
				ПараметрыОтбора.Вставить("Номенклатура",   СтрокаТЧМаркированныеТовары.ЧастичноеВыбытиеНоменклатура);
				ПараметрыОтбора.Вставить("Характеристика", СтрокаТЧМаркированныеТовары.ЧастичноеВыбытиеХарактеристика);
				ПараметрыОтбора.Вставить("Серия",          СтрокаТЧМаркированныеТовары.Серия);
			Иначе
				ПараметрыОтбора.Вставить("Номенклатура",   СтрокаТЧМаркированныеТовары.Номенклатура);
				ПараметрыОтбора.Вставить("Характеристика", СтрокаТЧМаркированныеТовары.Характеристика);
				ПараметрыОтбора.Вставить("Серия",          СтрокаТЧМаркированныеТовары.Серия);
			КонецЕсли;
		
			НайденныеСтроки = Товары.НайтиСтроки(ПараметрыОтбора);
			Если НайденныеСтроки.Количество() = 1 Тогда
				
				Для Каждого СтрокаТЧТовары Из НайденныеСтроки Цикл
					
					СтрокаТЧ = Новый Структура;
					
					РезультатРазбора = ШтрихкодированиеОбщегоНазначенияИС.НоваяСтруктураОбработкиШтрихкода(
						СтрокаТЧМаркированныеТовары.Штрихкод, ВидыПродукцииПоТоварнойГруппе, ПользовательскиеПараметрыРазбораКодаМаркировки);
					Если СтрокаТЧМаркированныеТовары.ТипШтрихкода = Перечисления.ТипыШтрихкодов.SSCC20 Тогда
						РезультатРазбора.ТипШтрихкода = Перечисления.ТипыШтрихкодов.SSCC20;
					ИначеЕсли СтрокаТЧМаркированныеТовары.ТипШтрихкода = Перечисления.ТипыШтрихкодов.SSCC18 Тогда
						РезультатРазбора.ТипШтрихкода = Перечисления.ТипыШтрихкодов.SSCC18;
					КонецЕсли;
					СтрокаТЧ.Вставить(
						"cis",
						ОбменДаннымиИСМП.КодМаркировкиДляПередачиИСМП(РезультатРазбора, ПараметрыНормализацииПрочее));
					
					Если ОбщегоНазначенияИСКлиентСерверПовтИсп.ПоддерживаетсяЧастичноеВыбытие(СтрокаТЧТовары.ВидПродукции, Операция)
						И ПараметрыСканирования.ТребуетсяЧастичноеВыбытие
						И ШтрихкодированиеОбщегоНазначенияИС.ТребуетсяЧастичноеВыбытие(ПараметрыСканирования, ДанныеПоШтрихкодам)
						И СтрокаТЧМаркированныеТовары.ЧастичноеВыбытие Тогда
						СтрокаТЧ.Вставить(
							"partial_quantity",
							СтрокаТЧМаркированныеТовары.Количество);
					КонецЕсли;
					
					Если ИспользованиеЦены Тогда
						
						Цена = 0;
						Если ЗначениеЗаполнено(СтрокаТЧТовары.Сумма) Тогда
							Если Шапка.ОбъемноСортовойУчет Тогда
								// Общая стоимость с НДС
								Цена = СтрокаТЧТовары.Сумма * 100;
							ИначеЕсли ЗначениеЗаполнено(СтрокаТЧТовары.КоличествоПотребительскихУпаковок)
								И СтрокаТЧТовары.КоличествоПотребительскихУпаковок <> СтрокаТЧТовары.КоличествоУпаковок Тогда
								// Цена за единицу
								Цена = Окр(СтрокаТЧТовары.Сумма / СтрокаТЧТовары.КоличествоПотребительскихУпаковок, 2) * 100;
							Иначе
								Цена = СтрокаТЧТовары.Цена * 100;
							КонецЕсли;
						КонецЕсли;
						
						Если Цена <> Неопределено Тогда
							СтрокаТЧ.Вставить("product_cost", Цена);
						КонецЕсли;
						
						Если ИспользованиеЦеныВсегда И Не ЗначениеЗаполнено(Цена) Тогда
							ОбщегоНазначенияИСКлиентСервер.ДобавитьТекстОшибки(
								СообщениеJSON,
								СтрШаблон(
									НСтр("ru = 'Не заполнено поле ""Цена"" для номенклатуры %1.'"), ПараметрыОтбора.Номенклатура));
						КонецЕсли;
						
					КонецЕсли;
					
					ТелоЗапроса.products.Добавить(СтрокаТЧ);
					
				КонецЦикла;
				
			ИначеЕсли НайденныеСтроки.Количество() > 1 Тогда
				
				ТекстОшибки = СтрШаблон(
						НСтр("ru = 'В табличной части ""Товары"" дублируется номенклатура %1.'"),
							ОбщегоНазначенияИС.ПредставлениеНоменклатуры(
										ПараметрыОтбора.Номенклатура,
										ПараметрыОтбора.Характеристика,,
										ПараметрыОтбора.Серия));
				ОбщегоНазначенияИСКлиентСервер.ДобавитьТекстОшибки(СообщениеJSON, ТекстОшибки);
				
			Иначе
				
				Если СтрокаТЧМаркированныеТовары.ВидУпаковки = Перечисления.ВидыУпаковокИС.Логистическая
					И Не ИспользованиеЦены Тогда
					
					СтрокаТЧ = Новый Структура;
					РезультатРазбора = ШтрихкодированиеОбщегоНазначенияИС.НоваяСтруктураОбработкиШтрихкода(
						СтрокаТЧМаркированныеТовары.Штрихкод, Шапка.ВидПродукции, ПользовательскиеПараметрыРазбораКодаМаркировки);
					
					Если СтрокаТЧМаркированныеТовары.ТипШтрихкода = Перечисления.ТипыШтрихкодов.SSCC20 Тогда
						РезультатРазбора.ТипШтрихкода = Перечисления.ТипыШтрихкодов.SSCC20;
					ИначеЕсли СтрокаТЧМаркированныеТовары.ТипШтрихкода = Перечисления.ТипыШтрихкодов.SSCC18 Тогда
						РезультатРазбора.ТипШтрихкода = Перечисления.ТипыШтрихкодов.SSCC18;
					КонецЕсли;
					
					СтрокаТЧ.Вставить(
						"cis",
						ОбменДаннымиИСМП.КодМаркировкиДляПередачиИСМП(РезультатРазбора, ПараметрыНормализацииПрочее));
					
					ТелоЗапроса.products.Добавить(СтрокаТЧ);
	
				Иначе
	
					ТекстОшибки = СтрШаблон(
						НСтр("ru = 'В табличной части ""Товары"" не найдена номенклатура %1.'"),
							ОбщегоНазначенияИС.ПредставлениеНоменклатуры(
									ПараметрыОтбора.Номенклатура,
									ПараметрыОтбора.Характеристика,,
									ПараметрыОтбора.Серия));
					ОбщегоНазначенияИСКлиентСервер.ДобавитьТекстОшибки(СообщениеJSON, ТекстОшибки);
					
				КонецЕсли;
				
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Истина;
	
КонецФункции

Функция СформироватьТелоЗапросаОСУ(ПараметрыФормирования, ТелоЗапроса)
	
	Шапка                 = ПараметрыФормирования.Шапка;
	Товары                = ПараметрыФормирования.Товары;
	СообщениеJSON         = ПараметрыФормирования.СообщениеJSON;
	РеквизитыОрганизации  = ПараметрыФормирования.РеквизитыОрганизации;
	ВидыПродукцииПоТоварнойГруппе = ПараметрыФормирования.ВидыПродукцииПоТоварнойГруппе;
	ВесоваяНоменклатураПоGTIN     = Новый Соответствие;
	
	ОписаниеНоменклатуры = ОбщегоНазначенияИС.ОписаниеНоменклатуры(Товары.ВыгрузитьКолонку("Номенклатура"));
	Для Каждого СтрокаТовары Из Товары Цикл
		ТекущееОписание = ОписаниеНоменклатуры[СтрокаТовары.Номенклатура];
		Если ТекущееОписание <> Неопределено
			И ТекущееОписание.ВариантИспользованияЕдиницыХранения = Перечисления.ВариантыИспользованияЕдиницыХраненияИС.МернаяПродукцияТребуетУказанияЗначения Тогда
			ВесоваяНоменклатураПоGTIN.Вставить(СтрокаТовары.GTIN, СтрокаТовары.Номенклатура);
		КонецЕсли;
	КонецЦикла;
	
	ПараметрыНормализацииПрочее = РазборКодаМаркировкиИССлужебныйКлиентСервер.ПараметрыНормализацииКодаМаркировки();
	ПараметрыНормализацииПрочее.ИмяСвойстваКодМаркировки = "Штрихкод";
	ПараметрыНормализацииПрочее.НачинаетсяСоСкобки       = Ложь;
	
	ПользовательскиеПараметрыРазбораКодаМаркировки = РазборКодаМаркировкиИССлужебныйКлиентСервер.ПользовательскиеПараметрыРазбораКодаМаркировки();
	ПользовательскиеПараметрыРазбораКодаМаркировки.ПроверятьАлфавитЭлементов = Ложь;
	
	РеквизитыОрганизации = ОбщегоНазначенияИС.ИННКППGLNОрганизации(Шапка.Организация, Шапка.ПроизводственныйОбъект);
	
	Если Не ЗначениеЗаполнено(РеквизитыОрганизации.ИНН) Тогда
		ОбщегоНазначенияИСКлиентСервер.ДобавитьТекстОшибки(
			СообщениеJSON,
			СтрШаблон(
				НСтр("ru = 'Не заполнено поле ""ИНН"" для организации %1'"), Шапка.Организация));
	КонецЕсли;
	
	Если Не ДополнитьТелоЗапросаОбщимиПолями(ПараметрыФормирования, ТелоЗапроса) Тогда
		Возврат Ложь;
	КонецЕсли;
	
	ДополнитьТелоЗапросаПоДаннымКонтрагента(ПараметрыФормирования, ТелоЗапроса);
	
	ИспользованиеЦены       = ВыводИзОборотаКлиентСервер.ДоступноПолеЦена(ВидыПродукцииПоТоварнойГруппе, Шапка.Причина);
	ИспользованиеЦеныВсегда = ВыводИзОборотаКлиентСервер.ПроверятьЗаполнениеПоляЦена(ВидыПродукцииПоТоварнойГруппе, Шапка.Причина);
	
	ДанныеПоТоварам = Товары.Скопировать();
	ДанныеПоТоварам.Свернуть("GTIN", "Количество,КоличествоПотребительскихУпаковок,КоличествоУпаковок,Сумма");
	
	Для Каждого СтрокаТЧТовары Из ДанныеПоТоварам Цикл
		
		КешПоНоменклатуре = Неопределено;
		
		СтрокаТЧ = Новый Структура;
		
		СтрокаТЧ.Вставить("gtin", СтрокаТЧТовары.GTIN);
		Если ЗначениеЗаполнено(СтрокаТЧТовары.КоличествоПотребительскихУпаковок) Тогда
			СтрокаТЧ.Вставить("gtin_quantity", СтрокаТЧТовары.КоличествоПотребительскихУпаковок);
		Иначе
			СтрокаТЧ.Вставить("gtin_quantity", СтрокаТЧТовары.КоличествоУпаковок);
		КонецЕсли;
		НоменклатураПоGTIN = ВесоваяНоменклатураПоGTIN[СтрокаТЧТовары.GTIN];
		Если НоменклатураПоGTIN <> Неопределено Тогда
			Вес = ИнтеграцияИСМПСлужебный.ВесВГраммахПоНоменклатуре(СтрокаТЧТовары.Количество, НоменклатураПоGTIN, КешПоНоменклатуре);
			Если ЗначениеЗаполнено(Вес) Тогда 
				СтрокаТЧ.Вставить("gtin_weight", Вес);
			КонецЕсли;
		КонецЕсли;
		
		Если ИспользованиеЦены Тогда
			
			Цена = 0;
			Если ЗначениеЗаполнено(СтрокаТЧТовары.Сумма) Тогда
				Цена = СтрокаТЧТовары.Сумма * 100;
			КонецЕсли;
			
			Если Цена <> Неопределено Тогда
				СтрокаТЧ.Вставить("product_cost", Цена);
			КонецЕсли;
			
			Если ИспользованиеЦеныВсегда И Не ЗначениеЗаполнено(Цена) Тогда
				ОбщегоНазначенияИСКлиентСервер.ДобавитьТекстОшибки(
					СообщениеJSON,
					СтрШаблон(
						НСтр("ru = 'Не заполнено поле ""Цена"" для GTIN %1.'"), СтрокаТЧТовары.GTIN));
			КонецЕсли;
			
		КонецЕсли;
		
		ТелоЗапроса.products.Добавить(СтрокаТЧ);
			
	КонецЦикла;
	
	Возврат Истина;
	
КонецФункции

Функция СформироватьТелоЗапросаСырье(ПараметрыФормирования, ТелоЗапроса)
	
	Шапка                = ПараметрыФормирования.Шапка;
	Товары               = ПараметрыФормирования.Товары;
	СообщениеJSON        = ПараметрыФормирования.СообщениеJSON;
	РеквизитыОрганизации = ПараметрыФормирования.РеквизитыОрганизации;
	Операция             = ПараметрыФормирования.Операция;
	ВидыПродукцииПоТоварнойГруппе = ПараметрыФормирования.ВидыПродукцииПоТоварнойГруппе;
	
	ИспользованиеПервичногоДокумента        = ВыводИзОборотаКлиентСервер.ДоступноПолеВидПервичногоДокумента(ВидыПродукцииПоТоварнойГруппе, Шапка.Причина);
	ИспользованиеПервичногоДокументаВсегда  = ВыводИзОборотаКлиентСервер.ПроверятьЗаполнениеПоляВидПервичногоДокумента(ВидыПродукцииПоТоварнойГруппе, Шапка.Причина);
	ИспользованиеТаможеннойДекларации       = МаркировкаТоваровКлиентСервер.ДоступноПолеТаможеннаяДекларация(ВидыПродукцииПоТоварнойГруппе, Шапка.Причина);
	ИспользованиеТаможеннойДекларацииВсегда = МаркировкаТоваровКлиентСервер.ПроверятьЗаполнениеПоляТаможеннаяДекларация(ВидыПродукцииПоТоварнойГруппе, Шапка.Причина);
	
	ТелоЗапроса.Вставить("participantInn", РеквизитыОрганизации.ИНН);
	
	Если ИспользованиеТаможеннойДекларацииВсегда
		Или ИспользованиеТаможеннойДекларации И ЗначениеЗаполнено(Шапка.НомерТаможеннойДекларации) Тогда
		ТелоЗапроса.Вставить("exportDeclarationNumber", Шапка.НомерТаможеннойДекларации);
	КонецЕсли;
	
	ДополнитьТелоЗапросаПоДаннымКонтрагента(ПараметрыФормирования, ТелоЗапроса);
	
	Если ВыводИзОборотаКлиентСервер.ДоступноПолеСтранаНазначения(ВидыПродукцииПоТоварнойГруппе, Шапка.Причина) Тогда
		ТелоЗапроса.Вставить("sourceCountryCode", Шапка.СтранаНазначенияКод);
	КонецЕсли;
	
	Если ИспользованиеПервичногоДокументаВсегда
		Или ЗначениеЗаполнено(Шапка.ВидПервичногоДокумента)
			И ИспользованиеПервичногоДокумента Тогда
		
		ТелоЗапроса.Вставить(
			"sourceDocType",
			Строка(Шапка.ВидПервичногоДокумента));
		ТелоЗапроса.Вставить("sourceDocNum",  Шапка.НомерПервичногоДокумента);
		ТелоЗапроса.Вставить("sourceDocDate", Формат(Шапка.ДатаПервичногоДокумента, "ДФ=yyyy-MM-dd"));
		
	КонецЕсли;
	
	ОписаниеТипаЧисло = ОбщегоНазначения.ОписаниеТипаЧисло(10);
	ДанныеПоТоварам = Товары.СкопироватьКолонки();
	
	ИдентификаторыТипаСырьяПоВидуПродукции = Новый Соответствие;
	
	Для Каждого СтрокаТовары Из Товары Цикл
		
		ЕдиницаИзмеренияКод = СокрЛП(СтрокаТовары.ЕдиницаИзмеренияКод);
		
		Если Не КонструкторИСМПКлиентСервер.СырьеПоддерживаетКодОКЕИ(
			СтрокаТовары.ВидПродукции, ЕдиницаИзмеренияКод, Шапка.Причина) Тогда
			ОбщегоНазначенияИСКлиентСервер.ДобавитьТекстОшибки(
				СообщениеJSON,
				СтрШаблон(
					НСтр("ru = 'Код единицы измерения по ОКЕИ ""%1"" для номенклатуры ""%2"" не поддерживается в системе прослеживаемости'"),
					ЕдиницаИзмеренияКод,
					СтрокаТовары.Номенклатура));
		КонецЕсли;
		
		Если ИдентификаторыТипаСырьяПоВидуПродукции[СтрокаТовары.ВидПродукцииСырья] = Неопределено Тогда
			
			ИдентификаторыТипаСырья = КонструкторИСМПКлиентСервер.ИдентификаторыТипаСырья(СтрокаТовары.ВидПродукцииСырья);
			
			Если ИдентификаторыТипаСырья.Количество() = 1 Тогда
				ИдентификаторыТипаСырьяПоВидуПродукции.Вставить(
					СтрокаТовары.ВидПродукцииСырья, ОписаниеТипаЧисло.ПривестиЗначение(ИдентификаторыТипаСырья[0]));
			Иначе
				ОбщегоНазначенияИСКлиентСервер.ДобавитьТекстОшибки(
				СообщениеJSON,
				СтрШаблон(
					НСтр("ru = 'Не удалось определить код типа сырья ""%1"", проверьте актуальность загруженного ""Классификатора настроек видов продукции БГосИС""'"),
					СтрокаТовары.Сырье));
			КонецЕсли;
			
		КонецЕсли;
		
		НоваяСтрока = ДанныеПоТоварам.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТовары);
		
	КонецЦикла;
	
	Если ЗначениеЗаполнено(СообщениеJSON.ТекстОшибки) Тогда
		Возврат Ложь;
	КонецЕсли;
	
	ДанныеПоТоварам.Свернуть("ИдентификаторСырья,ВидПродукцииСырья,ЕдиницаИзмеренияКод", "Количество,КоличествоУпаковок");
	
	Для Каждого СтрокаТовары Из ДанныеПоТоварам Цикл
		
		СтрокаТЧ = Новый Структура;
		
		СтрокаТЧ.Вставить("productId",       СтрокаТовары.ИдентификаторСырья);
		СтрокаТЧ.Вставить("productType",     ИдентификаторыТипаСырьяПоВидуПродукции[СтрокаТовары.ВидПродукцииСырья]);
		СтрокаТЧ.Вставить("productQuantity", СтрокаТовары.КоличествоУпаковок);
		СтрокаТЧ.Вставить("unit",            СокрЛП(СтрокаТовары.ЕдиницаИзмеренияКод));
		
		ТелоЗапроса.products.Добавить(СтрокаТЧ);
		
	КонецЦикла;
	
	Возврат ДополнитьТелоЗапросаДаннымиМОД(ПараметрыФормирования, ТелоЗапроса);
	
КонецФункции

Функция ДополнитьТелоЗапросаОбщимиПолями(ПараметрыФормирования, ТелоЗапроса)
	
	Шапка                          = ПараметрыФормирования.Шапка;
	РеквизитыОрганизации           = ПараметрыФормирования.РеквизитыОрганизации;
	ВидыПродукцииПоТоварнойГруппе  = ПараметрыФормирования.ВидыПродукцииПоТоварнойГруппе;
	ИспользованиеПервичногоДокумента       = ВыводИзОборотаКлиентСервер.ДоступноПолеВидПервичногоДокумента(ВидыПродукцииПоТоварнойГруппе, Шапка.Причина);
	ИспользованиеПервичногоДокументаВсегда = ВыводИзОборотаКлиентСервер.ПроверятьЗаполнениеПоляВидПервичногоДокумента(ВидыПродукцииПоТоварнойГруппе, Шапка.Причина);
	ИспользованиеПервичногоДокумента       = ВыводИзОборотаКлиентСервер.ДоступноПолеВидПервичногоДокумента(ВидыПродукцииПоТоварнойГруппе, Шапка.Причина);
	
	Если Шапка.ИспользуетсяМОД И ЗначениеЗаполнено(РеквизитыОрганизации.КПП)
		И ВыводИзОборотаКлиентСервер.ДоступноПолеКПП(ВидыПродукцииПоТоварнойГруппе, Шапка.Причина) Тогда
		ТелоЗапроса.Вставить("kpp", РеквизитыОрганизации.КПП);
	КонецЕсли;
	Если ВыводИзОборотаКлиентСервер.ДоступноПолеОписаниеПричины(ВидыПродукцииПоТоварнойГруппе, Шапка.Причина) Тогда
		ТелоЗапроса.Вставить("withdrawal_type_other", Шапка.ОписаниеПричины);
	КонецЕсли;
	
	Если ВыводИзОборотаКлиентСервер.ДоступноПолеИдентификатораГосударственногоКонтракта(ВидыПродукцииПоТоварнойГруппе, Шапка.Причина) Тогда
		ТелоЗапроса.Вставить("state_contract_id", Шапка.ИдентификаторГосударственногоКонтракта);
	КонецЕсли;
	
	ТелоЗапроса.Вставить("inn", РеквизитыОрганизации.ИНН);
	Если ИспользованиеПервичногоДокументаВсегда
		Или (ИспользованиеПервичногоДокумента
			И (ЗначениеЗаполнено(Шапка.НомерПервичногоДокумента) И ЗначениеЗаполнено(Шапка.ДатаПервичногоДокумента))) Тогда
		ТелоЗапроса.Вставить("action_date", ИнтеграцияИС.ДатаUTC(Шапка.ДатаПервичногоДокумента));
	Иначе
		ТелоЗапроса.Вставить("action_date", ИнтеграцияИС.ДатаUTC(Шапка.Дата));
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Шапка.ВидПервичногоДокумента) И ИспользованиеПервичногоДокумента Тогда
		
		ТелоЗапроса.Вставить(
			"document_type",
			ИнтерфейсИСМПСлужебный.ВидПервичногоДокумента(Шапка.ВидПервичногоДокумента));
		ТелоЗапроса.Вставить("document_number", Шапка.НомерПервичногоДокумента);
		ТелоЗапроса.Вставить("document_date",   ИнтеграцияИС.ДатаUTC(Шапка.ДатаПервичногоДокумента));
		
		Если Шапка.ВидПервичногоДокумента = Перечисления.ВидыПервичныхДокументовИСМП.Прочее Тогда
			ТелоЗапроса.Вставить("primary_document_custom_name", Шапка.НаименованиеПервичногоДокумента);
		КонецЕсли;
		
	КонецЕсли;
	
	Если КонструкторИСМПКлиентСервер.КонтрагентНерезидент(ВидыПродукцииПоТоварнойГруппе, Шапка.Причина) Тогда
		ТелоЗапроса.Вставить("destination_country_code", Шапка.СтранаНазначенияКод);
	КонецЕсли;
	
	Возврат ДополнитьТелоЗапросаДаннымиМОД(ПараметрыФормирования, ТелоЗапроса);
	
КонецФункции

Функция ДополнитьТелоЗапросаДаннымиМОД(ПараметрыФормирования, ТелоЗапроса)
	
	Шапка                          = ПараметрыФормирования.Шапка;
	СообщениеJSON                  = ПараметрыФормирования.СообщениеJSON;
	СообщенияJSON                  = ПараметрыФормирования.СообщенияJSON;
	РеквизитыОрганизации           = ПараметрыФормирования.РеквизитыОрганизации;
	ВидыПродукцииПоТоварнойГруппе  = ПараметрыФормирования.ВидыПродукцииПоТоварнойГруппе;
	ПараметрыОбмена                = ПараметрыФормирования.ПараметрыОбмена;
	ПараметрыОбработкиДокумента    = ПараметрыФормирования.ПараметрыОбработкиДокумента;
	ДокументСсылка                 = ПараметрыФормирования.ДокументСсылка;
	
	Если Шапка.ИспользуетсяМОД Тогда
		ИдентификаторАдреса = "";

		Если ЗначениеЗаполнено(Шапка.ИдентификаторФИАС) Тогда

			Если ПараметрыФормирования.ЭтоСырьеГИСМТ Тогда
				МестаОсуществленияДеятельности = РегистрыСведений.МестаОсуществленияДеятельностиИСМП.СписокЗарегистрированныхМестОсуществленияДеятельности(
					Шапка.Организация, Шапка.ТоварнаяГруппа, "", Шапка.ИдентификаторФИАС, 1);

				Если МестаОсуществленияДеятельности.Количество() Тогда
					ТелоЗапроса.Вставить("modId", МестаОсуществленияДеятельности[0].ИдентификаторМОД);
				Иначе
					ОбщегоНазначенияИСКлиентСервер.ДобавитьТекстОшибки(
						СообщениеJSON, СтрШаблон(НСтр("ru = 'Не найден идентификатор МОД по коду ФИАС:
													  |%1'"), Шапка.ИдентификаторФИАС));
				КонецЕсли;
				
			Иначе
				ИдентификаторАдреса = Шапка.ИдентификаторФИАС;
				ТелоЗапроса.Вставить("fias_id", Шапка.ИдентификаторФИАС);
			КонецЕсли;

		ИначеЕсли ЗначениеЗаполнено(Шапка.АдресПлощадки) Тогда

			ИдентификаторАдреса = ОбщегоНазначенияИСМП.ИдентификаторФИАСПоДаннымАдреса(
				Шапка.АдресПлощадки).Идентификатор;

			Если ЗначениеЗаполнено(ИдентификаторАдреса) Тогда

				Если ПараметрыФормирования.ЭтоСырьеГИСМТ Тогда
					МестаОсуществленияДеятельности = РегистрыСведений.МестаОсуществленияДеятельностиИСМП.СписокЗарегистрированныхМестОсуществленияДеятельности(
						Шапка.Организация, Шапка.ТоварнаяГруппа, "", ИдентификаторАдреса, 1);
					
					Если МестаОсуществленияДеятельности.Количество() Тогда
						ТелоЗапроса.Вставить("modId", МестаОсуществленияДеятельности[0].ИдентификаторМОД);
					Иначе
						ОбщегоНазначенияИСКлиентСервер.ДобавитьТекстОшибки(
							СообщениеJSON, СтрШаблон(
								НСтр("ru = 'Не найден идентификатор МОД по коду ФИАС:
								 	|%1'"), ИдентификаторАдреса));
					КонецЕсли;
					
				Иначе
					ТелоЗапроса.Вставить("fias_id", ИдентификаторАдреса);
				КонецЕсли;
				
			Иначе
				ОбщегоНазначенияИСКлиентСервер.ДобавитьТекстОшибки(
					СообщениеJSON, СтрШаблон(
						НСтр("ru = 'Не найден идентификатор ФИАС по адресу:
							 |%1'"), Шапка.АдресПлощадкиСтрокой));
			КонецЕсли;

		КонецЕсли;

	КонецЕсли;
	
	Если Шапка.ИспользуетсяМОД И ЗначениеЗаполнено(ИдентификаторАдреса) И Не ПараметрыФормирования.ЭтоСырьеГИСМТ Тогда
		ДоступнаРегистрацияМОДВГИСМТ = ВыводИзОборотаКлиентСервер.ДоступнаРегистрацияМОДВГИСМТ(ВидыПродукцииПоТоварнойГруппе);
		
		Если ДоступнаРегистрацияМОДВГИСМТ И Не РегистрыСведений.МестаОсуществленияДеятельностиИСМП.МестоОсуществленияДеятельностиЗагруженоИзГИСМТ(
			Шапка.Организация, Шапка.ТоварнаяГруппа, РеквизитыОрганизации.КПП, ИдентификаторАдреса) Тогда
			
			ТоварныеГруппы = Новый Массив;
			ТоварныеГруппы.Добавить(Шапка.ТоварнаяГруппа);
			
			ДанныеМОДВДокументе = Новый Структура;
			ДанныеМОДВДокументе.Вставить("КодФИАС",             ИдентификаторАдреса);
			ДанныеМОДВДокументе.Вставить("ДанныеАдреса",        Шапка.АдресПлощадки);
			ДанныеМОДВДокументе.Вставить("ДанныеАдресаСтрокой", Шапка.АдресПлощадкиСтрокой);
			ДанныеМОДВДокументе.Вставить("КПП",                 РеквизитыОрганизации.КПП);
			ДанныеМОДВДокументе.Вставить("ИНН",                 РеквизитыОрганизации.ИНН);
			ДанныеМОДВДокументе.Вставить("Организация",         Шапка.Организация);
			ДанныеМОДВДокументе.Вставить("Документ",            ДокументСсылка);
			ДанныеМОДВДокументе.Вставить("Подразделение",       Шапка.ПроизводственныйОбъект);
			ДанныеМОДВДокументе.Вставить("ТоварныеГруппы",      ТоварныеГруппы);
			
			Если ПараметрыОбмена.МОДКПроверкеРегистрации <> Неопределено Тогда
				ПараметрыОбмена.МОДКПроверкеРегистрации.Добавить(ДанныеМОДВДокументе);
			Иначе
				МОДКПроверкеРегистрации = Новый Массив;
				МОДКПроверкеРегистрации.Добавить(ДанныеМОДВДокументе);
				ПараметрыОбмена.МОДКПроверкеРегистрации = МОДКПроверкеРегистрации;
			КонецЕсли;
			
			ТекстСообщенияJSON                = ОбменДаннымиИСМПКлиентСервер.ОбъектВТекстJSON(ТелоЗапроса, Истина);
			СообщениеJSON.ТекстСообщенияJSON  = ТекстСообщенияJSON;
			СообщениеJSON.Операция            = Перечисления.ВидыОперацийИСМП.ПовторноеФормированиеСообщений;
			СообщениеJSON.ПараметрыЗапроса    = ПараметрыОбработкиДокумента;
			СообщениеJSON.ТребуетсяПодписание = Ложь;
			СообщенияJSON.Добавить(СообщениеJSON);
			
			Возврат Ложь;
			
		КонецЕсли;

	КонецЕсли;
	
	Возврат Истина;
	
КонецФункции

Процедура ДополнитьТелоЗапросаПоДаннымКонтрагента(ПараметрыФормирования, ТелоЗапроса)
	
	Шапка                          = ПараметрыФормирования.Шапка;
	СообщениеJSON                  = ПараметрыФормирования.СообщениеJSON;
	ВидыПродукцииПоТоварнойГруппе  = ПараметрыФормирования.ВидыПродукцииПоТоварнойГруппе;
	ИспользованиеКонтрагента       = МаркировкаТоваровКлиентСервер.ДоступноПолеКонтрагент(ВидыПродукцииПоТоварнойГруппе, Шапка.Причина);
	ИспользованиеКонтрагентаВсегда = МаркировкаТоваровКлиентСервер.ПроверятьЗаполнениеПоляКонтрагент(ВидыПродукцииПоТоварнойГруппе, Шапка.Причина);
	ЭтоСырьеГИСМТ                  = ПараметрыФормирования.ЭтоСырьеГИСМТ;
	
	Если ИспользованиеКонтрагента Тогда
		
		Если КонструкторИСМПКлиентСервер.КонтрагентНерезидент(ВидыПродукцииПоТоварнойГруппе, Шапка.Причина) Тогда
			
			Если ЗначениеЗаполнено(Шапка.Контрагент) Тогда
				ИдентификаторПолучателя = ИнтеграцияИСВызовСервера.НалоговыйНомерКонтрагента(Шапка.Контрагент);
				Если Не ЗначениеЗаполнено(ИдентификаторПолучателя) Тогда
					ОбщегоНазначенияИСКлиентСервер.ДобавитьТекстОшибки(
						СообщениеJSON,
						СтрШаблон(
							НСтр("ru = 'Не заполнено поле ""Налоговый номер в стране регистрации"".
									   |Контрагент: %1'"), Шапка.Контрагент));
				КонецЕсли;
				Если ЭтоСырьеГИСМТ Тогда
					ТелоЗапроса.Вставить("supplierName", Строка(Шапка.Контрагент));
					ТелоЗапроса.Вставить("supplierId",   ИдентификаторПолучателя);
				Иначе
					ТелоЗапроса.Вставить("importer_id", ИдентификаторПолучателя);
				КонецЕсли;
			КонецЕсли;
			
		ИначеЕсли ЗначениеЗаполнено(Шапка.Контрагент) Тогда
			
			РеквизитыКонтрагента = РаботаСКонтрагентамиИСВызовСервера.ИННКПППоОрганизацииКонтрагенту(Шапка.Контрагент);
			Если ЗначениеЗаполнено(РеквизитыКонтрагента.ИНН) Тогда
				Если ЭтоСырьеГИСМТ Тогда
					ТелоЗапроса.Вставить("supplierName", Строка(Шапка.Контрагент));
					ТелоЗапроса.Вставить("supplierId",   РеквизитыКонтрагента.ИНН);
				Иначе
					ТелоЗапроса.Вставить("buyer_inn", РеквизитыКонтрагента.ИНН);
				КонецЕсли;
			Иначе
				ОбщегоНазначенияИСКлиентСервер.ДобавитьТекстОшибки(
					СообщениеJSON,
					СтрШаблон(
						НСтр("ru = 'Не заполнено поле ""ИНН"" контрагента %1'"), Шапка.Контрагент));
			КонецЕсли;
			
		ИначеЕсли ИспользованиеКонтрагентаВсегда Тогда
			
			ОбщегоНазначенияИСКлиентСервер.ДобавитьТекстОшибки(
				СообщениеJSON,
				НСтр("ru = 'Не заполнено поле ""Контрагент""'"));
			
		КонецЕсли;
	
	КонецЕсли;
	
КонецПроцедуры

Функция ЕстьКодыАгрегатов(ДокументСсылка, Реквизиты)

	Запрос = Новый Запрос(
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	ШтрихкодыУпаковокТоваровВложенныеШтрихкоды.Штрихкод КАК Штрихкод
		|ИЗ
		|	Документ.ВыводИзОборотаИСМП.ШтрихкодыУпаковок КАК ШтрихкодыУпаковок
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ШтрихкодыУпаковокТоваров.ВложенныеШтрихкоды КАК ШтрихкодыУпаковокТоваровВложенныеШтрихкоды
		|		ПО (ШтрихкодыУпаковокТоваровВложенныеШтрихкоды.Ссылка = ШтрихкодыУпаковок.ШтрихкодУпаковки)
		|			И (ШтрихкодыУпаковок.Ссылка = &Ссылка)");
	
	Запрос.УстановитьПараметр("Ссылка", ДокументСсылка);
	ЕстьКодыАгрегатов = Не Запрос.Выполнить().Пустой();
	
	Возврат ЕстьКодыАгрегатов;
	
КонецФункции

#КонецОбласти

#Область ОбработкаКодовМаркировки

Функция ОбработатьДанныеШтрихкодаУпаковкиМаркируемойПродукции(Форма, ДанныеШтрихкода, ПараметрыСканирования, ВложенныеШтрихкоды)
	
	РезультатОбработки = ШтрихкодированиеОбщегоНазначенияИС.ИнициализироватьРезультатОбработкиШтрихкода(ПараметрыСканирования, ДанныеШтрихкода);
	
	ПараметрыЗаполнения = ПараметрыЗаполнения();
	
	ЗаполнитьДанныеОбъектаФормыПоДеревуУпаковок(Форма, ВложенныеШтрихкоды.ДеревоУпаковок, ПараметрыЗаполнения);
	
	РезультатОбработки.ИзмененныеСтроки  = ПараметрыЗаполнения.ИзмененныеСтроки;
	РезультатОбработки.ДобавленныеСтроки = ПараметрыЗаполнения.ДобавленныеСтроки;
	
	Возврат РезультатОбработки;
	
КонецФункции

Процедура ЗаполнитьДанныеОбъектаФормыПоДеревуУпаковок(Форма, ДеревоУпаковок, ПараметрыЗаполнения, УпаковкаВерхнегоУровня = Неопределено)
	
	Для Каждого СтрокаДерева Из ДеревоУпаковок.Строки Цикл
		
		Если УпаковкаВерхнегоУровня = Неопределено
			И СтрокаДерева.ТипУпаковки <> Перечисления.ТипыУпаковок.МаркированныйТовар
			И ЗначениеЗаполнено(СтрокаДерева.ШтрихкодУпаковки) Тогда
			УпаковкаВерхнегоУровняСтрокиДерева = СтрокаДерева.ШтрихкодУпаковки;
		Иначе
			УпаковкаВерхнегоУровняСтрокиДерева = УпаковкаВерхнегоУровня;
		КонецЕсли;
		
		ЗаполнитьДанныеОбъектаФормыПоДеревуУпаковок(
			Форма, СтрокаДерева, ПараметрыЗаполнения, УпаковкаВерхнегоУровняСтрокиДерева);
		
		Если СтрокаДерева.ТипУпаковки = Перечисления.ТипыУпаковок.МаркированныйТовар Тогда
			
			ПараметрыЗаполнения.РодительскийШтрихкод = УпаковкаВерхнегоУровня;
			ОбработатьДанныеШтрихкодаПотребительскойУпаковки(Форма, СтрокаДерева, Неопределено, ПараметрыЗаполнения);
			
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

Функция ОбработатьДанныеШтрихкодаПотребительскойУпаковки(Форма, ДанныеШтрихкода, ПараметрыСканирования, ПараметрыЗаполнения = Неопределено)
	
	ИсточникДанных = Форма.Объект;
	
	Если ПараметрыЗаполнения = Неопределено Тогда
		
		ПараметрыЗаполнения  = ПараметрыЗаполнения();
		РезультатОбработки   = ШтрихкодированиеОбщегоНазначенияИС.ИнициализироватьРезультатОбработкиШтрихкода(Неопределено, ДанныеШтрихкода);
		РодительскийШтрихкод = Неопределено;
		
	Иначе
		
		РезультатОбработки   = ПараметрыЗаполнения;
		РодительскийШтрихкод = ПараметрыЗаполнения.РодительскийШтрихкод;
		
	КонецЕсли;
	
	ОбработкаБезМаркировки = ТипЗнч(ДанныеШтрихкода) = Тип("Структура")
		И ДанныеШтрихкода.Свойство("ОбработатьБезМаркировки")
		И ДанныеШтрихкода.ОбработатьБезМаркировки
		Или ИсточникДанных.ОбъемноСортовойУчет;
	
	СпецификаОбработки = "";
	Если ДанныеШтрихкода.ПроизвольнаяЕдиницаУчета Тогда
		СпецификаОбработки = СпецификаОбработки + ",КоличествоКодов";
	КонецЕсли;
	ИспользоватьGTIN = Ложь;
	Если ИсточникДанных.ОбъемноСортовойУчет Тогда
		Если ДанныеШтрихкода.ЭтоШтрихкодНоменклатуры
			И (Не МенеджерОборудованияКлиентСервер.ПроверитьКорректностьGTIN(ДанныеШтрихкода.GTIN)
			Или РазборКодаМаркировкиИССлужебныйКлиентСервер.ЭтоВнутреннийШтрихкод(ДанныеШтрихкода.GTIN)
			Или РазборКодаМаркировкиИССлужебныйКлиентСервер.ЭтоШтрихкодВводаОстатков(ДанныеШтрихкода.GTIN)) Тогда
			ИспользоватьGTIN = Ложь;
		Иначе
			ИспользоватьGTIN = Истина;
		КонецЕсли;
	КонецЕсли;
	Если ИспользоватьGTIN Тогда
		СпецификаОбработки = СпецификаОбработки + ",GTIN";
	КонецЕсли;
	
	ЭтоСтрокаДанныхЧастичногоВыбытия = ШтрихкодированиеОбщегоНазначенияИСКлиентСервер.ЭтоСтрокаДанныхЧастичногоВыбытия(
		ДанныеШтрихкода,
		ПараметрыСканирования,
		Истина);
		
	СтрокаШтрихкодаУпаковки = Неопределено;	
	Если ЭтоСтрокаДанныхЧастичногоВыбытия Тогда
		СтруктураПоиска = Новый Структура();
		СтруктураПоиска.Вставить("ШтрихкодУпаковки", ДанныеШтрихкода.ШтрихкодУпаковки);
		
		ПоискСтрокШтрихкодовУпаковки = ИсточникДанных.ШтрихкодыУпаковок.НайтиСтроки(СтруктураПоиска);
		
		Если ПоискСтрокШтрихкодовУпаковки.Количество() Тогда
			СтрокаШтрихкодаУпаковки = ПоискСтрокШтрихкодовУпаковки[0];
		КонецЕсли;
	КонецЕсли;
	
	ОбновляемаяСтрока = ПроверкаИПодборПродукцииИС.ДанныеШтрихкодаДляДобавленияВКеш(ДанныеШтрихкода, СпецификаОбработки);
	ОбновляемаяСтрока.СтрокаШтрихкодаУпаковки = СтрокаШтрихкодаУпаковки;
	
	Если ДанныеШтрихкода.ПроизвольнаяЕдиницаУчета
		Или ЭтоСтрокаДанныхЧастичногоВыбытия Тогда
		КоличествоМаркируемыхЕдиниц = ДанныеШтрихкода.Количество;
		ОбновляемаяСтрока.ЧастичноеВыбытиеКоличество = ДанныеШтрихкода.Количество;
	Иначе
		КоличествоМаркируемыхЕдиниц = ДанныеШтрихкода.КоличествоПотребительскихУпаковок;
	КонецЕсли;
	
	//Замена количества в строке
	Если СтрокаШтрихкодаУпаковки <> Неопределено
		И ЭтоСтрокаДанныхЧастичногоВыбытия Тогда
		КоличествоМаркируемыхЕдиниц = КоличествоМаркируемыхЕдиниц - СтрокаШтрихкодаУпаковки.ЧастичноеВыбытиеКоличество;
		Если ДанныеШтрихкода.ПроизвольнаяЕдиницаУчета Тогда
			ОбновляемаяСтрока.КоличествоПотребительскихУпаковок = 0;
		КонецЕсли;
	КонецЕсли;
	ОбновляемаяСтрока.Количество = КоличествоМаркируемыхЕдиниц;
	
	Если РодительскийШтрихкод <> Неопределено Тогда
		ОбновляемаяСтрока.ШтрихкодУпаковки = РодительскийШтрихкод;
	КонецЕсли;
	ОбновляемаяСтрока.СтрокаШтрихкодаУпаковки = СтрокаШтрихкодаУпаковки;
	
	Если ДанныеШтрихкода.ПроизвольнаяЕдиницаУчета
		Или ЭтоСтрокаДанныхЧастичногоВыбытия Тогда
		КоличествоМаркируемыхЕдиниц = ДанныеШтрихкода.Количество;
		ОбновляемаяСтрока.ЧастичноеВыбытиеКоличество = ДанныеШтрихкода.Количество;
	Иначе
		КоличествоМаркируемыхЕдиниц = ДанныеШтрихкода.КоличествоПотребительскихУпаковок;
	КонецЕсли;
	
	Если СтрокаШтрихкодаУпаковки <> Неопределено
		И ЭтоСтрокаДанныхЧастичногоВыбытия Тогда
		КоличествоМаркируемыхЕдиниц = КоличествоМаркируемыхЕдиниц - СтрокаШтрихкодаУпаковки.ЧастичноеВыбытиеКоличество;
	КонецЕсли;
	ОбновляемаяСтрока.Количество = КоличествоМаркируемыхЕдиниц;
	
	ПараметрыПоиска = ИнтеграцияИС.ПоляПоискаМаркируемойПродукции(, ИспользоватьGTIN);
	ЗаполнитьЗначенияСвойств(ПараметрыПоиска, ДанныеШтрихкода);
	
	НайденныеСтрокиТовары = ИсточникДанных.Товары.НайтиСтроки(ПараметрыПоиска);
	Если НайденныеСтрокиТовары.Количество() > 0 Тогда
		
		СтрокаТовары = НайденныеСтрокиТовары[0];
		
		// Поле Количество
		КоличествоМаркируемыхЕдиниц = ОбновляемаяСтрока.Количество;
		
		ВсегоПоПараметрамПоиска = 0;
		Для Каждого ПодходящаяСтрока Из НайденныеСтрокиТовары Цикл
			ВсегоПоПараметрамПоиска = ВсегоПоПараметрамПоиска + ПодходящаяСтрока.Количество;
		КонецЦикла;
		
		ВсегоВКеше = 0;
		Если Не ОбработкаБезМаркировки Тогда
			
			ВсегоВКеше = ПроверкаИПодборПродукцииИС.КоличествоПоДаннымКеша(Форма, ОбновляемаяСтрока);
			
			Если ВсегоВКеше < ВсегоПоПараметрамПоиска Тогда
				КоличествоМаркируемыхЕдиниц = Макс(0, КоличествоМаркируемыхЕдиниц + ВсегоВКеше - ВсегоПоПараметрамПоиска);
			КонецЕсли;
			
		КонецЕсли;
		
		СтрокаТовары.Количество         = СтрокаТовары.Количество + КоличествоМаркируемыхЕдиниц;
		СтрокаТовары.КоличествоУпаковок = СтрокаТовары.КоличествоУпаковок + КоличествоМаркируемыхЕдиниц;
		
		Если КоличествоМаркируемыхЕдиниц > 0 Тогда
			ДобавленныеСтроки = ПараметрыЗаполнения.ДобавленныеСтроки.Найти(СтрокаТовары);
			Если ДобавленныеСтроки = Неопределено Тогда
				ПараметрыЗаполнения.ИзмененныеСтроки.Добавить(СтрокаТовары);
			КонецЕсли;
		КонецЕсли;
		
		Если ДанныеШтрихкода.ПроизвольнаяЕдиницаУчета Тогда
			// Поле Количество потребительских кодов маркировки
			КоличествоМаркируемойПродукции = ОбновляемаяСтрока.КоличествоПотребительскихУпаковок;
			
			ВсегоПоПараметрамПоиска = 0;
			Для Каждого ПодходящаяСтрока Из НайденныеСтрокиТовары Цикл
				ВсегоПоПараметрамПоиска = ВсегоПоПараметрамПоиска + ПодходящаяСтрока.КоличествоПотребительскихУпаковок;
			КонецЦикла;
			
			ВсегоВКеше = ПроверкаИПодборПродукцииИС.КоличествоПоДаннымКеша(Форма, ОбновляемаяСтрока, "КоличествоПотребительскихУпаковок");
			
			Если ВсегоВКеше < ВсегоПоПараметрамПоиска Тогда
				КоличествоМаркируемойПродукции = Макс(0, КоличествоМаркируемойПродукции + ВсегоВКеше - ВсегоПоПараметрамПоиска);
			КонецЕсли;
			
			Если КоличествоМаркируемойПродукции > 0 Тогда
				
				СтрокаТовары.КоличествоПотребительскихУпаковок = СтрокаТовары.КоличествоПотребительскихУпаковок + КоличествоМаркируемойПродукции;
				
			КонецЕсли;
			
		КонецЕсли;
		
	Иначе
		
		СтрокаТовары = ИсточникДанных.Товары.Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаТовары, ОбновляемаяСтрока);
		СтрокаТовары.КоличествоУпаковок = СтрокаТовары.Количество;
		
		РезультатОбработки.ДобавленныеСтроки.Добавить(СтрокаТовары);
		
		Если КонструкторИСМПКлиентСервер.ЭтоСырьеГИСМТ(ИсточникДанных.ТоварнаяГруппа) Тогда
			РегистрыСведений.СоответствиеНоменклатурыСырьяГИСМТ.ЗаполнитьСопоставленноеСырьеВДокументе(СтрокаТовары);
			СтрокаТовары.ВидПродукцииСырья = Неопределено;
			ИнтеграцияИСМП.ЗаполнитьСлужебныеРеквизитыСырье(СтрокаТовары);
		КонецЕсли;
		
	КонецЕсли;
		
	Если Не ОбработкаБезМаркировки Тогда
		
		ПроверкаИПодборПродукцииИС.ДополнитьКешИТаблицуШтрихкодовУпаковок(Форма, ОбновляемаяСтрока, ПараметрыЗаполнения.ДобавленныеШтрихкоды);
		
	КонецЕсли;
	
	Возврат РезультатОбработки;
	
КонецФункции

Функция ПараметрыЗаполнения()
	
	Результат = Новый Структура;
	Результат.Вставить("ИзмененныеСтроки", Новый Массив);
	Результат.Вставить("ДобавленныеСтроки", Новый Массив);
	Результат.Вставить("ДобавленныеШтрихкоды", Новый Массив);
	Результат.Вставить("РодительскийШтрихкод");
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти

#КонецОбласти

#КонецЕсли
