#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Если Параметры.Свойство("АвтоТест") Тогда // Возврат при получении формы для анализа.
		Возврат;
	КонецЕсли;
	
	Упаковка = Параметры.Упаковка;
	Если Не ЗначениеЗаполнено(Упаковка) Тогда
		Упаковка = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Параметры.Номенклатура, "ЕдиницаИзмерения");
	КонецЕсли;
	
	ЗаполнитьТаблицу();
	УстановитьЗаголовкиПриСозданииФормы();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура ПодбиратьТоварыПриИзменении(Элемент)
	
	ЗаполнитьТаблицу();
	ОбновитьПодобрано();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыТаблицаНазначений

&НаКлиенте
Процедура ТаблицаПриАктивизацииЯчейки(Элемент)

	Если Элемент.ТекущийЭлемент.Имя = Элементы.ТаблицаПереместитьВправо.Имя Тогда
		ТекущиеДанные = Элементы.ТаблицаНазначений.ТекущиеДанные;
		Если ТекущиеДанные <> Неопределено Тогда
			ТекущиеДанные.Подобрано = ТекущиеДанные.ВНаличии;
			ОбновитьПодобрано();
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ТаблицаПодобраноПриИзменении(Элемент)
	
	ОбновитьПодобрано();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура ПеренестиВДокумент(Команда)
	
	Подобрано = ТаблицаНазначений.Итог("Подобрано");
	Если Подобрано <> Параметры.Подобрать Тогда
		Шаблон = НСтр("ru = 'Подобранное количество (%1 %3) не совпадает с количеством, которое необходимо подобрать (%2 %3). Команда не может быть выполнена.'");
		Текст = СтрШаблон(
			Шаблон,
			Формат(Подобрано, "ЧДЦ=3; ЧН=0,000;"),
			Формат(Параметры.Подобрать, "ЧДЦ=3; ЧН=0,000;"),
			Упаковка);
		ПоказатьПредупреждение(, Текст);
		Возврат;
	КонецЕсли;
	Результат = Новый Структура("ПодобранныеТовары", ПодобранныеТовары());
	Закрыть(Результат);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура ЗаполнитьТаблицу()
	
	ТекстЗапроса =
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	Запасы.Номенклатура КАК Номенклатура,
		|	Запасы.Характеристика КАК Характеристика,
		|	Запасы.Склад КАК Склад,
		|	Запасы.Назначение КАК Назначение,
		|	Запасы.Заказ КАК Заказ,
		|	Запасы.ЗаблокированоВНаличииОстаток КАК ЗаблокированоВНаличииОстаток,
		|	Запасы.ЗаблокированоПоступитОстаток КАК ЗаблокированоПоступитОстаток,
		|	Запасы.КРазблокировкеОстаток КАК КРазблокировкеОстаток,
		|	Запасы.РезервироватьНаСкладеИзЗаблокированныхОстаток КАК РезервироватьНаСкладеИзЗаблокированныхОстаток,
		|	Запасы.РезервироватьПоМереПоступленияИзЗаблокированныхОстаток КАК РезервироватьПоМереПоступленияИзЗаблокированныхОстаток,
		|	Запасы.РезервироватьНаСкладеОстаток КАК РезервироватьНаСкладеОстаток,
		|	Запасы.РезервироватьПоМереПоступленияОстаток КАК РезервироватьПоМереПоступленияОстаток,
		|	Запасы.ОтложитьРезервированиеОстаток КАК ОтложитьРезервированиеОстаток,
		|	Запасы.КОбеспечениюОстаток КАК КОбеспечениюОстаток,
		|	Запасы.НеОбеспечиватьОстаток КАК НеОбеспечиватьОстаток
		|ПОМЕСТИТЬ ЗапасыИПотребностиОстаткиКонтролируемыхПартий
		|ИЗ
		|	РегистрНакопления.ЗапасыИПотребности.Остатки(,
		|		Номенклатура = &Номенклатура
		|			И Характеристика = &Характеристика
		|			И Склад = &Склад
		|			И Назначение <> &НазначениеПолучатель
		|			И Назначение <> ЗНАЧЕНИЕ(Справочник.Назначения.ПустаяСсылка)
		|			И &ПолучатьОстаткиПартий) КАК Запасы
		|ИНДЕКСИРОВАТЬ ПО
		|	Номенклатура, Характеристика, Склад, Назначение
		|;
		|
		|////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	Запасы.Номенклатура КАК Номенклатура,
		|	Запасы.Характеристика КАК Характеристика,
		|	Запасы.Склад КАК Склад,
		|	Запасы.Назначение КАК Назначение,
		|	Запасы.ВНаличииОстаток КАК ВНаличииОстаток,
		|	Запасы.ЗаблокированоВНаличииОстаток КАК ЗаблокированоВНаличииОстаток,
		|	Запасы.ЗаказаноОстаток КАК ЗаказаноОстаток,
		|	Запасы.ПоступитОстаток КАК ПоступитОстаток,
		|	Запасы.ЗаблокированоПоступитОстаток КАК ЗаблокированоПоступитОстаток,
		|	Запасы.РезервироватьНаСкладеОстаток КАК РезервироватьНаСкладеОстаток,
		|	Запасы.РезервироватьПоМереПоступленияОстаток КАК РезервироватьПоМереПоступленияОстаток,
		|	Запасы.ОтложитьРезервированиеОстаток КАК ОтложитьРезервированиеОстаток,
		|	Запасы.КОбеспечениюОстаток КАК КОбеспечениюОстаток,
		|	Запасы.НеОбеспечиватьОстаток КАК НеОбеспечиватьОстаток
		|ПОМЕСТИТЬ ЗапасыИПотребностиОстатки
		|ИЗ
		|	РегистрНакопления.ЗапасыИПотребности.Остатки(,
		|		Номенклатура = &Номенклатура
		|			И Характеристика = &Характеристика
		|			И Склад = &Склад
		|			И Назначение <> &НазначениеПолучатель
		|			И Назначение <> ЗНАЧЕНИЕ(Справочник.Назначения.ПустаяСсылка)) КАК Запасы
		|ИНДЕКСИРОВАТЬ ПО
		|	Номенклатура, Характеристика, Склад, Назначение
		|;
		|
		|////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	Таблица.Назначение КАК Назначение,
		|	Таблица.КонтролируемаяПартия КАК КонтролируемаяПартия,
		|	Таблица.КонтролируемаяПартия <> ЗНАЧЕНИЕ(Справочник.КонтролируемыеПартии.ПустаяСсылка) КАК НаКонтроле,
		|	Таблица.КоличествоДляДействияОтгрузить КАК ВНаличии,
		|	ЕСТЬNULL(
		|		ВЫБОР
		|			КОГДА ОбеспечениеТоварамиПроверенногоКачества.КоличествоДляДействияОтгрузить > 0
		|				ТОГДА ОбеспечениеТоварамиПроверенногоКачества.КоличествоНаСкладеДляДействияРезервироватьПоМереПоступления
		|						- ОбеспечениеТоварамиПроверенногоКачества.КоличествоДляДействияОтгрузить
		|			КОГДА ОбеспечениеТоварамиПроверенногоКачества.КоличествоНаСкладеДляДействияРезервироватьПоМереПоступления > 0
		|				ТОГДА ОбеспечениеТоварамиПроверенногоКачества.КоличествоНаСкладеДляДействияРезервироватьПоМереПоступления
		|			ИНАЧЕ 0
		|		КОНЕЦ, 0) КАК ДоступноПоВсемПартиям
		|ИЗ
		|	ДанныеОбеспечения КАК Таблица
		|		
		|		ЛЕВОЕ СОЕДИНЕНИЕ ДанныеОбеспечения КАК ОбеспечениеТоварамиПроверенногоКачества
		|		ПО ОбеспечениеТоварамиПроверенногоКачества.Номенклатура =Таблица.Номенклатура
		|		 И ОбеспечениеТоварамиПроверенногоКачества.Характеристика = Таблица.Характеристика
		|		 И ОбеспечениеТоварамиПроверенногоКачества.Склад = Таблица.Склад
		|		 И ОбеспечениеТоварамиПроверенногоКачества.Назначение = Таблица.Назначение
		|		 И ОбеспечениеТоварамиПроверенногоКачества.КонтролируемаяПартия = ЗНАЧЕНИЕ(Справочник.КонтролируемыеПартии.ПустаяСсылка)
		|		
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Назначения КАК НазначениеПолучатель
		|		ПО НазначениеПолучатель.Ссылка = &НазначениеПолучатель
		|ГДЕ
		|	ВЫБОР
		|		КОГДА
		|			НазначениеПолучатель.ТипНазначения В(
		//++ Устарело_Переработка24
		|						ЗНАЧЕНИЕ(Перечисление.ТипыНазначений.ДавальческоеМатериалы22),
		//-- Устарело_Переработка24
		|						ЗНАЧЕНИЕ(Перечисление.ТипыНазначений.ДавальческоеМатериалыПодЭтап22))
		|			ТОГДА
		|				Таблица.Назначение.ТипНазначения В(
		//++ Устарело_Переработка24
		|							ЗНАЧЕНИЕ(Перечисление.ТипыНазначений.ДавальческоеМатериалы22),
		//-- Устарело_Переработка24
		|							ЗНАЧЕНИЕ(Перечисление.ТипыНазначений.ДавальческоеМатериалыПодЭтап22))
		|						И НазначениеПолучатель.Партнер = Таблица.Назначение.Партнер
		|						И НазначениеПолучатель.Договор = Таблица.Назначение.Договор
		|					ИЛИ Таблица.Назначение.ТипНазначения = ЗНАЧЕНИЕ(Перечисление.ТипыНазначений.Собственное)
		|		ИНАЧЕ
		|			НЕ Таблица.Назначение.ТипНазначения В(
		//++ Устарело_Переработка24
		|				ЗНАЧЕНИЕ(Перечисление.ТипыНазначений.ДавальческоеПродукция22),
		//-- Устарело_Переработка24
		|				ЗНАЧЕНИЕ(Перечисление.ТипыНазначений.ПоставкаПодПринципала))
		|	КОНЕЦ
		|	И Таблица.КоличествоДляДействияОтгрузить > 0
		|УПОРЯДОЧИТЬ ПО
		|	Назначение, НаКонтроле, ВНаличии УБЫВ";
	
	ИменаТаблиц = ОбеспечениеВДокументахСервер.НовыеИменаТаблицДляРасчетаОстатковДляУстановкиДействий();
	ИменаТаблиц.Остатки = "ЗапасыИПотребностиОстатки"; // @query-part-1
	ИменаТаблиц.ОстаткиКонтролируемыхПартий = "ЗапасыИПотребностиОстаткиКонтролируемыхПартий"; // @query-part-1
	ИменаТаблиц.Результат = "ДанныеОбеспечения"; // @query-part-1
	ОбеспечениеВДокументахСервер.ДанныеОбеспечения(ТекстЗапроса, ИменаТаблиц);
	
	ЭтоПодборПартий = ПодбиратьТовары = ПодбиратьТоварыЗначениеВсе();
	Запрос = Новый Запрос();
	Запрос.Текст = ТекстЗапроса;
	Запрос.УстановитьПараметр("Номенклатура", Параметры.Номенклатура);
	Запрос.УстановитьПараметр("Характеристика", Параметры.Характеристика);
	Запрос.УстановитьПараметр("Склад", Параметры.Склад);
	Запрос.УстановитьПараметр("НазначениеПолучатель", Параметры.Назначение);
	Запрос.УстановитьПараметр("ПолучатьОстаткиПартий", ЭтоПодборПартий);
	Результат = Запрос.Выполнить().Выгрузить();
	ТаблицаНазначений.Очистить();
	ТаблицаНазначений.Загрузить(Результат);
	
	КоэффициентУпаковки = Справочники.УпаковкиЕдиницыИзмерения.КоэффициентУпаковки(Упаковка, Параметры.Номенклатура);
	Для Каждого Строка Из ТаблицаНазначений Цикл
		Строка.ВНаличии = Строка.ВНаличии / КоэффициентУпаковки;
		Строка.ДоступноПоВсемПартиям = Строка.ДоступноПоВсемПартиям / КоэффициентУпаковки;
	КонецЦикла;
	
	Элементы.ТаблицаКонтролируемаяПартия.Видимость = ЭтоПодборПартий;
	Элементы.ГруппаИтоги.Видимость = ЭтоПодборПартий;
	Элементы.ТаблицаНаКонтроле.Видимость = ЭтоПодборПартий;
	Элементы.ПеренестиВДокумент.Доступность = ТаблицаНазначений.Количество() > 0;
	
КонецПроцедуры

&НаСервере
Процедура УстановитьЗаголовкиПриСозданииФормы()
	
	Элементы.ТаблицаВНаличии.Заголовок = СтрШаблон(Элементы.ТаблицаВНаличии.Заголовок, Упаковка);
	Элементы.ТаблицаПодобрано.Заголовок = СтрШаблон(Элементы.ТаблицаПодобрано.Заголовок, Упаковка);
	
	Если ЗначениеЗаполнено(Параметры.Характеристика) Тогда
		Заголовок = НСтр("ru = 'Указание назначений для товара: %1,%3 на складе: %2'");
		Заголовок = СтрШаблон(Заголовок, Параметры.Номенклатура, Параметры.Склад, Параметры.Характеристика);
	Иначе
		Заголовок = НСтр("ru = 'Указание назначений для товара: %1 на складе: %2'");
		Заголовок = СтрШаблон(Заголовок, Параметры.Номенклатура, Параметры.Склад);
	КонецЕсли;
	
	Элементы.ДекорацияПодобрать.Заголовок = СтрШаблон(Элементы.ДекорацияПодобрать.Заголовок,
		Формат(Параметры.Подобрать, "ЧДЦ=3; ЧН=0,000;"), Упаковка);
	Подобрано = ТаблицаНазначений.Итог("Подобрано");
	Элементы.ДекорацияПодобрано.Заголовок = СтрШаблон(НСтр("ru = 'Подобрано: %1 %2'"),
		Формат(Подобрано, "ЧДЦ=3; ЧН=0,000;"), Упаковка);
	
КонецПроцедуры

&НаСервере
Функция ПодобранныеТовары()
	
	Результат = ТаблицаНазначений.Выгрузить(Новый Массив(), "Назначение,КонтролируемаяПартия,Подобрано");
	
	Для Каждого Строка Из ТаблицаНазначений Цикл
		Если Строка.Подобрано > 0 Тогда
			ЗаполнитьЗначенияСвойств(Результат.Добавить(), Строка);
		КонецЕсли;
	КонецЦикла;
	
	Адрес = ПоместитьВоВременноеХранилище(Результат);
	Возврат Адрес;
	
КонецФункции

&НаКлиенте
Процедура ОбновитьПодобрано()
	
	Подобрано = ТаблицаНазначений.Итог("Подобрано");
	Элементы.ДекорацияПодобрано.Заголовок = СтрШаблон(НСтр("ru = 'Подобрано: %1 %2'"),
		Формат(Подобрано, "ЧДЦ=3; ЧН=0,000;"), Упаковка);
	
КонецПроцедуры

&НаСервере
Функция ПодбиратьТоварыЗначениеВсе()
	
	Возврат 1;
	
КонецФункции

#КонецОбласти
